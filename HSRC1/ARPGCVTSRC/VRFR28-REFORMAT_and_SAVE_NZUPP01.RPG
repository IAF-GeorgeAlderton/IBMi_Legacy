     F********************************************
     FNZUPL03 UF  E           K        DISK         KINFDS INF1
     FNZUPP01BO   E                    DISK
     F            NZUPP011                          KRENAMENZUPP01X
      ***************************************************
     IINF1        DS
     I                                    B 156 1590RCNT
     I            DS
     I                                        1  100N2HAHB
     I                                        1   80N2HAHZ
     I                                        9  100N2HABB
     I            DS
     I                                        1  100WYMD
     I                                        1   80@YMD
     I                                        9  100@BB
      *
     C           *ENTRY    PLIST
     C                     PARM           PDATE   8
     C                     PARM           PREC1   9
     C                     PARM           PREC2   9
      *
     C                     MOVE PDATE     XDATE   80
      *
      * set file cursor past zero shipment date...
     C           N2DEHZ    SETGTNZUPL03
      * LOOP
     C           *IN90     DOWEQ*OFF
     C                     READ NZUPL03                  90
     C           *IN90     IFEQ *OFF
     C           N2DEHZ    IFLE XDATE
     C           N2DEHZ    ANDNE*ZERO
     C                     WRITENZUPP01X
     C                     DELETNZUPL011
     C                     ADD  1         WDEL    90
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      * FOOT
     C                     Z-ADDRCNT      WREC1   90
     C                     MOVE WREC1     PREC1
     C           WREC1     SUB  WDEL      WREC2   90
     C                     MOVE WREC2     PREC2
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
