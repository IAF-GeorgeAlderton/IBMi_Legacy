     F******************************************************
     FINQPW03 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN   KSFILE SFREC1
     FAJSPLCD IF  E           K        DISK
      *
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
     I            DS
     I                                        1   80SBSKHZ
     I                                        1   40SBSKYY
     I                                        5   60SBSKMM
     I                                        7   80SBSKDD
     I            DS
     I                                        1   80JAKOHZ
     I                                        1   40JAKOYY
     I                                        5   60JAKOMM
     I                                        7   80JAKODD
     I            DS
     I                                        1   40JAKOTM
     I                                        1   20JAKOHH
     I                                        3   40JAKOSS
      *****************************************************
      * MAIN ROUTINE                                      *
      *****************************************************
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*  INITIAL SET
     C*===============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $ID     6
      *
     C                     MOVEA*ALL'0'   *IN
     C*  SFLCLR
     C                     SETON                     82
     C                     WRITESFCTL1
     C                     SETOF                     82
     C                     Z-ADD0         RRN     40
     C                     Z-ADD0         ENDRRN  40
     C                     MOVE *BLANK    @@UMU   1
      *
     C                     MOVEL$ID       K#PL01  6
      *
     C           K#PL01    SETLLAJSPLCD
     C*-------------------------
S1   C                     DO   *HIVAL
     C                     READ AJSPLCD                  90
     C   90                LEAVE
 S2  C           JASKJY    IFEQ 'D'
     C                     ITER
 E2  C                     ENDIF
     C*
     C                     MOVELJAWKCD    @CODE
     C                     MOVELJAWKNM    @NAME
     C                     Z-ADDJAKOHZ    @KOHZ
     C                     Z-ADDJAKOTM    @KOTM
     C                     MOVELJAKOME    @KOUS
      *
     C                     MOVEL*BLANK    WCODE   4
     C                     MOVEL*BLANK    WNAME  15
     C                     MOVELJAWKCD    WCODE
     C                     MOVELJAWKNM    WNAME
      *
     C                     ADD  1         RRN
     C                     WRITESFREC1
E1   C                     ENDDO
     C*-------------------------
     C           RRN       IFEQ 0
     C                     MOVE '#END    '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     Z-ADD1         DSPRRN
     C                     ENDIF
     C                     ENDSR
     C*===============================================================
      *  DISPLAY SREEN
     C*===============================================================
     C           #DSP1     BEGSR
     C                     SETON                     71
     C                     WRITEDSP01
     C                     EXFMTSFCTL1
     C                     SETOF                     71
     C                     MOVEA'0'       *IN,99
     C                     Z-ADD$$RRN     DSPRRN
      *----*
      * F3 *
