     H            Y.
     F** INQR16 ********************************************
     F*  DELIVERY CODE INQ BY CODE                         *
     F*  J.WATANABE  2021.06.24                            *
     F******************************************************
     FINQPW16 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN   KSFILE SFREC1
     FFGBPL01 IF  E           K        DISK
      *
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
     I            DS
     I                                        1   80SBSKHZ
     I                                        1   40SBSKYY
     I                                        5   60SBSKMM
     I                                        7   80SBSKDD
     I            DS
     I                                        1   80B2KOHZ
     I                                        1   40B2KOYY
     I                                        5   60B2KOMM
     I                                        7   80B2KODD
     I            DS
     I                                        1   40B2KOTM
     I                                        1   20B2KOJI
     I                                        3   40B2KOPN
      *****************************************************
      * MAIN ROUTINE                                      *
      *****************************************************
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*  INITIAL SET
     C*===============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $ID     4
      *
     C                     MOVEA*ALL'0'   *IN
     C*  SFLCLR
     C                     SETON                     82
     C                     WRITESFCTL1
     C                     SETOF                     82
     C                     Z-ADD0         RRN     40
     C                     Z-ADD0         ENDRRN  40
     C                     MOVE *BLANK    @@UMU   1
      *
     C           $ID       IFEQ *BLANK
     C                     Z-ADD0         K#PL01  40
     C                     ELSE
     C                     MOVEL$ID       K#PL01
     C                     ENDIF
      *
     C           K#PL01    SETLLFGBPL01
     C*-------------------------
S1   C                     DO   *HIVAL
     C                     READ FGBPL01                  90
     C   90                LEAVE
 S2  C           B2SKJY    IFEQ 'D'
     C                     ITER
 E2  C                     ENDIF
     C*
     C                     MOVELB2CODE    @CODE
     C                     MOVELB2SMEI    @NAME
      *
     C                     MOVELB2CODE    $DLV
     C                     CALL 'UTLR62D'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $GNAM  10
     C                     MOVEL$GRP      @GRP
     C                     MOVEL$GNAM     @GNAM
      *
     C                     Z-ADDB2KOHZ    @KOHZ
     C                     Z-ADDB2KOTM    @KOTM
     C                     MOVELB2KOME    @KOUS
      *
     C                     MOVEL*BLANK    WCODE   4
     C                     MOVEL*BLANK    WNAME  15
     C                     MOVELB2CODE    WCODE
     C                     MOVELB2SMEI    WNAME
      *
     C                     ADD  1         RRN
     C                     WRITESFREC1
E1   C                     ENDDO
     C*-------------------------
     C           RRN       IFEQ 0
     C                     MOVE '#END    '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     Z-ADD1         DSPRRN
     C                     ENDIF
     C                     ENDSR
     C*===============================================================
      *  DISPLAY SREEN
     C*===============================================================
     C           #DSP1     BEGSR
     C                     SETON                     71
     C                     WRITEDSP01
     C                     EXFMTSFCTL1
     C                     SETOF                     71
     C                     MOVEA'0'       *IN,99
     C                     Z-ADD$$RRN     DSPRRN
      *----*
      * F3 *
      *----*
     C   KA                MOVE '#END    '@STEP
     C   KC                MOVE '#END    '@STEP
     C   KL                MOVE '#END    '@STEP
      *
     C                     ENDSR
