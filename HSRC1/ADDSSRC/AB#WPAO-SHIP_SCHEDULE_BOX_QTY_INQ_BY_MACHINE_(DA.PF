     A**AB#WPAO ************************************
     A* SHIP/SCHEDULE BOX/QTY INQ BY MACHINE       *
     A* J. WATANABE  2021.03.04                    *
     A**********************************************
      *
     A          R AB#WPAO1                  TEXT('MACHINE#')
     A            W#WSID        10A         COLHDG('INPUT USER')
     A            W#SEQ          2S 0       COLHDG('SEQ#')
     A            W#SIZE         3A         COLHDG('SIZE')
     A            W#MCN          3A         COLHDG('MACHINE')
     A            W#DATE         8S 0       COLHDG('SHIP DATE')
     A            W#QTY         11S 0       COLHDG('QTY')
     A            W#BOX         11S 1       COLHDG('BOX')
     A*
     A          K W#WSID
     A          K W#DATE
     A          K W#SEQ
     A          K W#SIZE
     A          K W#MCN
