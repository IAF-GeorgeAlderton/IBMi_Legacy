     A** AB#PPDC **********************
     A*  TOYOTA EXPORT DOCK CODE FILE *
     A********************** AB#PPDC **
      *
     A          R AB#PPDC1                  TEXT('TOYOTA EXP DOCK CODE FILE')
     A            ADSKJY         1A         COLHDG('DELETE CODE D')
     A            ADSKDT         8S 0       COLHDG('DELETE DATE')
     A            ADKODT         8S 0       COLHDG('UPDATE DATE')
     A            ADKOTM         6S 0       COLHDG('UPDATE TIME')
     A            ADUSER        10A         COLHDG('UPDATE USER')
     A            ADDOCK         4A         COLHDG('DOCK CODE')
     A            ADTOKU         4A         COLHDG('CUSTOMER CODE')
     A            ADNONY         4A         COLHDG('DELIVERY CODE')
     A            ADNKOJ         1A         COLHDG('FACTORY CODE')
     A            ADNUKE         4A         COLHDG('RECEIVING')
     A            ADDEST         5A         COLHDG('DESTINATION')
      *
     A          K ADDOCK
