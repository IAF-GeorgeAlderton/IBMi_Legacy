     A            W1TIM1         6S 0       COLHDG('TIM1')
     A            W1DAT2         8S 0       COLHDG('DAT2')
     A            W1TIM2         6S 0       COLHDG('TIM2')
     A            W1DAY          5S 0       COLHDG('DAY')
