      ** AJSWPF1 ******************************************************
      *  PLATING  ADMIT RESULTS FILES.
      *  2018.11.13
      ****************************************************** AJSWPF1 **
     A          R AJSWPF11
     A            W1MKKB         2A         COLHDG('PLATING MACHINE NO')
     A            W1WINY         4S 0       COLHDG('WORK ADMITTABLE DATE' -
     A                                             'YEAR')
     A            W1WINM         2S 0       COLHDG('WORK ADMITTABLE DATE' -
     A                                             'MONTH')
     A            W1IROK         1A         COLHDG('COLOR INSTRUCTION')
     A            W1SAIK         1A         COLHDG('RELOADING CLASS')
     A            W1WMJY        12S 2       COLHDG('WORK BEFORE' -
     A                                             'ADMITTABLE WEIGHT')
      *
     A          K W1MKKB
     A          K W1WINY
     A          K W1WINM
     A          K W1IROK
     A          K W1SAIK
