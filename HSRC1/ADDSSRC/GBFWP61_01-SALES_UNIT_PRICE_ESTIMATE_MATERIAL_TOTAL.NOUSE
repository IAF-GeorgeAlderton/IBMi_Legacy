     A*** GBFWP61 ******************************************
     A* SALES UNIT PRICE ESTIMATE MATERIAL TOTALIZATION FILE ( PF ) *
     A*             M-OKUDA        1986.01.14              *
     A******************************************************
     A          R GBFWP611                  TEXT('MATERIAL TOTALIZATION FILE')
     A            I9DKBN         1A         COLHDG('NEW OLD')
     A            I9TOKU         4S 0       COLHDG('CUSTOMER')
     A            I9TKOJ         1A         COLHDG('FACTORY IS NOT' -
     A                                             'APPOINTED *')
     A            I9KKEY         1A         COLHDG('FACTORY KEY')
     A            I9MHN1         5A         COLHDG('ESTIMATE PART NO 1')
     A            I9MHN2         5A         COLHDG('ESTIMATE PART NO 2')
     A            I9MHN3         5A         COLHDG('ESTIMATE PART NO 3')
     A            I9MHN4         5A         COLHDG('ESTIMATE PART NO 4')
     A            I9SAIZ         2S 0       COLHDG('SIZE')
     A            I9ZCOD        15A         COLHDG('MATERIAL CODE')
     A            I9ZKGT         7P 5       COLHDG('MATERIAL PRICE')
     A            I9SZIJ         7P 2       COLHDG('MATERIAL UNIT WEIGHT')
     A            I9SZIH         7P 5       COLHDG('MATERIAL PRICE')
     A            I9ZAIH         7P 5       COLHDG('MATERIAL COSTS')
     A            I9MTAN         7P 5       COLHDG('SELLING PRICE')
     A            I9SRYO         9P 0       COLHDG('SALES PLAN NUMBER')
