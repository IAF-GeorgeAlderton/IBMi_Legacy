     A** AB#EP60B *************************************
     A* EDI PROCESSING FLAT FILE FOR 856        *
     A*                                               *
     A*                                               *
     A************************************** AB#EP60 **
      *
     A          R AB#E60B1                  TEXT('FOR EDI856')
     A            E1SHID        10          COLHDG('SHIPMENT NO.')
     A            E1PRTN        10          COLHDG('PARTNER ID')
     A            E1DATE         8S 0       COLHDG('PROCESS DATE')
     A            E1TIME         6S 0       COLHDG('PROCESS TIME')
     A            E1TOKU         4S 0       COLHDG('CUSTOMER')
     A            E1NONY         4S 0       COLHDG('SHIP TO')
     A            E1NKOJ         1          COLHDG('FACTORY')
     A            E1NUKE         4          COLHDG('DOCK')
     A            E1NOHZ         8S 0       COLHDG('SHIP DATE')
     A            E1NBIN         2S 0       COLHDG('BIN')
     A            E1NOTM         4S 0       COLHDG('SHIP TIME')
     A            E1INVN        16          COLHDG('INVOICE#')
     A            E1ORDN        10          COLHDG('ORDER#')
     A            E1TRCK        10          COLHDG('TRACK#')
     A            ETPLT          7S 0       COLHDG('# OF PALLETS')
     A            ETBOX          7S 0       COLHDG('# OF BOXES')
     A            ETRMD          2          COLHDG('TRANS METHOD')
     A            ETWHT         10S 2       COLHDG('CONT WGHT')
     A            ESIRE          5          COLHDG('SUPPLISER CODE')
     A            ESIRK          1          COLHDG('SUPPLIER FACT')
     A            ESCAC          4          COLHDG('SCAC CODE')
     A            ETNET         10S 2       COLHDG('NET WGHT')
      *
ADD  A            E1REL#        12A         COLHDG('RLS#/SUBARU ASN#')
ADD  A            E1FIL1        15A         COLHDG('FILLER')
      *
     A            ETGRS         10S 2       COLHDG('GROSS WGT')
     A            ESCNAM        20A         COLHDG('SHIPPER CONTACT NAME')
     A            ESCTEL        15A         COLHDG('SHIPPER CONTACT TEL#')
     A            EFOB           2A         COLHDG('FOB CODE')
     A            ESNAM         30A         COLHDG('SHIP TO NAME')
     A            ESLOC         20A         COLHDG('SHIP TO LOCATION')
      *
JW   A            ECRDT          8S 0       COLHDG('CREATE DATE')
JW   A            ECRTM          6S 0       COLHDG('CREATE TIME')
JW   A            ECRWS         10          COLHDG('CREATE WSID')
JW   A            ECRUS         10          COLHDG('CREATE USER')
JW   A            ECRPG          8          COLHDG('CREATE PGM ')
      *
     A          K E1SHID
