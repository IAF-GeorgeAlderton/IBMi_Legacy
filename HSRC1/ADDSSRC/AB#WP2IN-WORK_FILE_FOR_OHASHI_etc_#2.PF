     A            INUNIT         5A         COLHDG('QTY / CONTAINERS')
     A            INCNAM        10A         COLHDG('CUSTOMER NAME')
     A            INWEIT         4A         COLHDG('WEIGHT')
     A            INSERL        18A         COLHDG('SERIAL NUMBER')
     A            INSBN5         5A         COLHDG('SBAN 5')
     A            INSB10        10          COLHDG('SBAN 10')
     A            INRELS        15          COLHDG('RELEASE#')
     A            INTTL1        10          COLHDG('TITLE 1')
     A            INFLD1        20          COLHDG('FIELD 1')
     A            INFLDA        20          COLHDG('SPLIER')
     A            INFLDB        50          COLHDG('CUST NAME')
     A            INFLDC        50          COLHDG('ADDR 1')
     A            INFLDD        50          COLHDG('ADDR 2')
