     A            INQTY          5A         COLHDG('QTY')
     A            INDOCK         4A         COLHDG('DOCK CODE')
     A            INADDR        15A         COLHDG('STORE ADDRESS')
     A            INSIRE         4A         COLHDG('SUPPLIER')
     A            INPNAM        30A         COLHDG('PART NAME')
     A            INIPAR        20A         COLHDG('INTERNAL PART')
     A            INSHDT         8A         COLHDG('SHIP DATE')
     A            INSEQ#         6A         COLHDG('SERIAL NUMBER')
     A            INORDR        10A         COLHDG('ORDER NUMBER')
     A            INDUMY         5A         COLHDG('DUMMY')
     A*
     A            INLOC1         1A         COLHDG('LOCATION 1')
     A            INLOC2         2A         COLHDG('LOCATION 2')
     A            INLOC3         2A         COLHDG('LOCATION 3')
     A            INLOC4         1A         COLHDG('LOCATION 4')
     A            INDELY         4A         COLHDG('DELIVERY')
     A            INFACT         1A         COLHDG('FACTORY')
