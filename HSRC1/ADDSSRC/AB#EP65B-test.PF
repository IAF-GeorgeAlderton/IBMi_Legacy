     A** AB#EP65B *************************************
     A* EDI PROCESSING FILE FOR 856        *
     A*************************************************
      *
     A          R AB#E65B1                  TEXT('FOR EDI856')
     A            E5SHID        10          COLHDG('SHIPMENT NO.')
     A            E5MHIN        20          COLHDG('CUST PART#')
     A            E5RF01         2          COLHDG('REF-01')
     A            E5RF02        20          COLHDG('REF-02')
     A            E5RF03        20          COLHDG('REF-03')
ADD  A            E5ODLN         6S         COLHDG('PO LINE#')
      *
JW   A            E5CRDT         8S 0       COLHDG('CREATE DATE')
JW   A            E5CRTM         6S 0       COLHDG('CREATE TIME')
      *
     A          K E5SHID
     A          K E5MHIN
