     A** FMDATA/AFFWP12 ********************************
     A*  UPLOAD WORK FILE FOR FIRM ORDERS              *
     A*  JW(SRA) 2020.03.18                            *
     A**************************************************
     A          R FMDATAR                   TEXT('FIRM.CSV')
     A            FMSEQ#         4S 0       COLHDG('SEQ#')
     A            FMISDT         8S 0       COLHDG('ISSUE DATE')
     A            FMTOKU         4S 0       COLHDG('CUSTOMER#')
     A            FMNONY         4S 0       COLHDG('DELIVERY#')
     A            FMNKOJ         1A         COLHDG('FACTORY')
     A            FMNUKE         4A         COLHDG('DOCK')
     A            FMMHIN        20A         COLHDG('USER PART')
     A            FMSHDT         8S 0       COLHDG('SHIP DATE')
     A            FMSHBN         2S 0       COLHDG('SHIP BIN')
     A            FMSRYO         9S 0       COLHDG('QTY')
     A            FMORDN        10A         COLHDG('ORDER#')
     A            FMINVN        16A         COLHDG('INVOICE#')
      *
     A            FMCRDT         8S 0       COLHDG('CREATE DATE')
     A            FMCRTM         6S 0       COLHDG('CREATE TIME')
     A            FMCRWS        10A         COLHDG('CREATE WSID')
     A            FMCRUS        10A         COLHDG('CREATE USER')
