     A            AZADJS         5S 0       COLHDG('INCREASE/DECREASE')
     A***         AZACTQ         5S 0       COLHDG('ACTUAL VARIANCE')
     A            AZODR1         5S 0       COLHDG('ORDER BOX1')
     A            AZODR2         5S 0       COLHDG('ORDER BOX2')
     A            AZODR3         5S 0       COLHDG('ORDER BOX3')
     A            AZODR4         5S 0       COLHDG('ORDER BOX4')
     A            AZODR5         5S 0       COLHDG('ORDER BOX5')
     A            AZODR6         5S 0       COLHDG('ORDER BOX6')
     A            AZODR7         5S 0       COLHDG('ORDER BOX7')
     A****        AZOTOT         5S 0       COLHDG('ORDER TOTAL')
     A            AZAKAN         5S 0       COLHDG('NECESSARY # OF' -
     A                                             'KANBAN BY ACTUAL')
     A            AZBKAN         5S 0       COLHDG('NECESSARY # OF' -
     A                                             'KANBAN /DAY BY ACT')
     A            AZCKAN         5S 0       COLHDG('NECESSARY # OF' -
     A                                             'KANBAN BY MASTER')
     A            AZDKAN         5S 0       COLHDG('NECESSARY # OF' -
