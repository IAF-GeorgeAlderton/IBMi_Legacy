     A            AZKTR1         1          COLHDG('LOCATION 1')
     A            AZKTR2         2          COLHDG('LOCATION 2')
     A            AZKTR3         2          COLHDG('LOCATION 3')
     A            AZKTR4         1          COLHDG('LOCATION 4')
     A            AZLTIM         3S 0       COLHDG('L/T')
     A*
     A          K AZSHN1
