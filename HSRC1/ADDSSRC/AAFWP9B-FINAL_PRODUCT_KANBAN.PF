     A            IPLOC3         7A         COLHDG('LOC 3')
     A            IPPRO4         3A         COLHDG('PROC 4')
     A            IPFAC4         3A         COLHDG('MACHINE 4')
     A            IPLOC4         7A         COLHDG('LOC 4')
     A            IPPRO5         3A         COLHDG('PROC 5')
