     A                                             'INSTRUCTION')
     A* MATERIAL
     A            X3OTNK         7S 2       COLHDG('OLD UNIT PRICE')
     A            X3OTNI         1          COLHDG('UNIT')
     A            X3OTKB         1          COLHDG('INSTRUCTION')
     A            X3NTNK         7S 2       COLHDG('NEW UNIT PRICE')
