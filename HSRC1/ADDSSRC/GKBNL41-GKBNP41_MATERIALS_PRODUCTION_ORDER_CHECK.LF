     A                                             'YY')
     A            X3KSTM         2S 0       COLHDG('MM')
     A            X3KSTD         2S 0       COLHDG('DD')
     A            X3KETY         2S 0       COLHDG('CONTRACT EXIT DAY YY')
     A            X3KETM         2S 0       COLHDG('MM')
     A            X3KETD         2S 0       COLHDG('DD')
     A* KEY
