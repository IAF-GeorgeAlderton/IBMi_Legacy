     A            X3BSTM         2S 0       COLHDG('MM')
     A            X3BSTD         2S 0       COLHDG('DD')
     A            X3BETY         2S 0       COLHDG('CONTRACT EXIT DAY YY')
     A            X3BETM         2S 0       COLHDG('MM')
     A            X3BETD         2S 0       COLHDG('DD')
     A            X3KIBN         3          COLHDG('MACHINE NO')
     A            X3EDBN         1          COLHDG('BRANCH NUMBER')
     A            X3KASK         1          COLHDG('COMPLETION MATERIALS' -
     A                                             'STOCKING FACTORY')
     A            X3BOSK         1          COLHDG('MATERIAL STOCKING' -
     A                                             'FACTORY')
     A            X3AKI1        15          COLHDG('REMARKS')
     A* COMPLETION MATERIALS
     A            X3KOTN         7S 2       COLHDG('OLD UNIT PRICE')
     A            X3KOTI         1          COLHDG('UNIT')
