     A** GTAWP40 ************************************************
     A*  PACKING LIST DATA FOR PRINT                            *
     A*                                                         *
     A* TCHK  08/27/12 CREATE                                   *
     A***********************************************************
     A          R GTAWP411
     A*
     A            W1CASE         4          COLHDG('CASE#')
     A            W1CANY         4          COLHDG('CASE SHIPTO')
     A            W1CAHK         8          COLHDG('CASE ISSUE DATE')
     A            W1CACK         1          COLHDG('CASE C/D')
     A*
     A            W1ODR1         2S 0       COLHDG('ORDER#1 YEAR')
     A            W1ODR2         2S 0       COLHDG('ORDER#2 MONTH')
     A            W1ODR3         2          COLHDG('ORDER#3 SEQ')
     A            W1ITEM         5          COLHDG('ITEM#')
     A*
     A            W1IHN1         5          COLHDG('USER PART#1')
     A            W1IHN2         5          COLHDG('USER PART#2')
     A            W1IHN3         5          COLHDG('USER PART#3')
     A            W1IHN4         5          COLHDG('USER PART#4')
     A*
     A            W1ITK1         1          COLHDG('USER STORE ADDR1')
     A            W1ITK2         2          COLHDG('USER STORE ADDR2')
     A            W1ITK3         2          COLHDG('USER STORE ADDR3')
     A            W1ITK4         1          COLHDG('USER STORE ADDR4')
     A*
     A            W1SRYO         9S 0       COLHDG('#OF QTY')
     A            W1QPC          5S 0       COLHDG('USER QPC')
     A            W1BOXS         2S 0       COLHDG('#OF BOX')
     A*
     A          K W1CASE
     A          K W1CANY
     A          K W1CAHK
     A          K W1CACK
     A          K W1ODR1
     A          K W1ODR2
     A          K W1ODR3
     A          K W1IHN1
     A          K W1IHN2
     A          K W1IHN3
     A          K W1IHN4
