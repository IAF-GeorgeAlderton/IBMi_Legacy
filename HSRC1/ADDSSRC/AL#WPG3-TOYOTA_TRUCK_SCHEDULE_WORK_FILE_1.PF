     A***********************************************
     A          R AL#WPG31
      *
     A            W1TOKU         4S 0       COLHDG('CUSTOMER CODE')
     A            W1NONY         4S 0       COLHDG('DELIVERY CODE')
     A            W1NKOJ         1A         COLHDG('DELIVERY FACTORY')
     A            W1NUKE         4A         COLHDG('DELIVERY RECEIVING')
     A            W1SHID         8A         COLHDG('SHIP DATE')
     A            W1SURT         9A         COLHDG('SUB ROUTE')
     A            W1TRKB         2A         COLHDG('IAF TRUCK BIN#')
     A            W1STTN         4S 0       COLHDG('START TIME')
     A            W1EDTN         4S 0       COLHDG('END TIME')
     A            W1MHN1         5A         COLHDG('USER PART# 1')
     A            W1MHN2         5A         COLHDG('2')
     A            W1MHN3         5A         COLHDG('3')
     A            W1MHN4         5A         COLHDG('4')
     A            W1SHN1         5A         COLHDG('IAF PART NO1')
     A            W1SHN2         5A         COLHDG('2')
     A            W1SHN3         2A         COLHDG('3')
     A            W1QPC          5S 0       COLHDG('QPC.')
     A            W1QTY         13S 3       COLHDG('QTY.')
     A            W1BOX         10S 0       COLHDG('BOX.')
     A            W1DIVN         3S 0       COLHDG('NUMBER OF TRUCK')
     A            W1EGBC         1A         COLHDG('E.G.BOLT')
      *
     A          K W1TOKU
     A          K W1NONY
     A          K W1NKOJ
     A          K W1NUKE
     A          K W1SHID
     A          K W1SURT
     A          K W1MHN1
