     A                                             'WHO UPDATED')
     A            L6SHN1         5          COLHDG('REPRESENTING PART' -
     A                                             'NUMBER1')
     A            L6SHN2         5          COLHDG('2')
     A            L6SHN3         2          COLHDG('3')
     A            L6TKYY         4S 0       COLHDG('EFFECTIVE DATE' -
     A                                             'BEFORE CHANGE(YEAR))')
     A            L6TKMM         2S 0       COLHDG('MONTH')
     A            L6TKDD         2S 0       COLHDG('DAY')
