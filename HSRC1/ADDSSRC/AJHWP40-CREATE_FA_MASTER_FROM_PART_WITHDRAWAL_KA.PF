     A            L6KAIS         5S 0       COLHDG('NUMBER OF KANBAN' -
     A                                             'SHEETS')
     A            L6KMIN         5S 0       COLHDG('MIN')
     A            L6KMAX         5S 0       COLHDG('MAX')
     A            L6SRMS         5S 0       COLHDG('NUMBER OF HANDLING' -
     A                                             'SHEETS')
     A            L6ALHK         5S 0       COLHDG('CHANGE  ALL')
     A            L6MXHK         5S 0       COLHDG('CHANGE  MAX')
     A            L6KSHK         1          COLHDG('UPDATE INSTRUCTION' -
     A                                             'CHANGE ')
     A            L6KTSU         9S 0       COLHDG('FIXED SETTING NUMBER' -
     A                                             'PAR DAY')
     A            L6KSSU         9S 0       COLHDG('CALCULATION SETTING' -
     A                                             'NUMBER PAR DAY ')
     A            L6KOUT         1          COLHDG('KANBAN PUBLICATION' -
     A                                             'INSTRUCTION')
     A            L6DOUT         1          COLHDG('DISKETT PUBLICATION' -
     A                                             'INSTRUCTION')
     A            L6DTKO         1          COLHDG('DATA UPDATE METHOD')
     A            L6DTHE         1          COLHDG('DATA CHANGE' -
     A                                             'INSTRUCTION')
     A            L6JDMS         5S 0       COLHDG('AUTOMATIC BALANCE' -
     A                                             'NUMBER OF SHEETS')
     A            L6SHIY         2S 0       COLHDG('SORT INSTRUCTION')
     A            L6HINM         5          COLHDG('PART NAME LARGE')
      *
     A            UPKBN          1
     A            SYKBN          1
     A            JISEN          3S 1
