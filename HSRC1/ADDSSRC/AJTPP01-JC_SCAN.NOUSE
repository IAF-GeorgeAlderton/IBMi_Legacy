     A** AJTPP01 ******************************************************
     A*  S/T SCAN                                                     *
     A****************************************************** AFAPP85 **
     A          R AJTPP011                  TEXT('LOT DETAIL')
     A            AJSKJY         1A         COLHDG('DELETE CODE D')
     A            AJSKDT         8  0       COLHDG('DELETE DATE')
     A            AJKODT         8  0       COLHDG('UPDATE DATE')
     A            AJKOTM         6  0       COLHDG('UPDATE TIME')
     A            AJKOME        10A         COLHDG('UPDATE TEAM MEMBER' -
     A                                             'PROFILE')
     A            AJAPCS        17          COLHDG('APICS BARCODE')
     A            AJKANR         1A         COLHDG('CONTROL CODE')
     A            AJZETI         4A         COLHDG('ABSOLUTE #')
     A            AJTEHI         3A         COLHDG('TEHAI NO.')
     A            AJPAGE         2A         COLHDG('PAGE NO.')
     A            AJLTNO         8          COLHDG('LOT')
     A            AJSHN1         5          COLHDG('PART1')
     A            AJSHN2         5          COLHDG('PART2')
     A            AJSHN3         2          COLHDG('PART3')
     A            AJQTY          9  0       COLHDG('QTY')
