     A** ACMWP10 ************************************
     A*  AUTO-COMPILE PF/LF STATUS W/F              *
     A*  JW    2022.10.11                           *
     A***********************************************
     A          R ACMWP101
     A            A1PF          10A         COLHDG('PF NAME')
     A            A1LF          10A         COLHDG('LF NAME')
     A            A1SLIB        10A         COLHDG('SOURCE LIBRARY')
     A            A1SFIL        10A         COLHDG('SOURCE FILE')
     A            A1STYP        10A         COLHDG('SOURCE TYPE')
     A            A1STAT         4A         COLHDG('COMPILE STATUS')
      *
     C            A1CRHZ         8S 0       COLHDG('COMPILE DATE')
     C            A1CRTM         6S 0       COLHDG('COMPILE TIME')
     C            A1CRUS        10A         COLHDG('COMPILE USER')
     C            A1CRWS        10A         COLHDG('COMPILE WSID')
      *
     A          K A1PF
