     A                                      COLHDG('STANDARD 3')
     A            M8ANZ4         4S 2       TEXT('STANDARD COEFFICIENT 4')
     A                                      COLHDG('STANDARD 4')
     A            M8ANZ5         4S 2       TEXT('STANDARD COEFFICIENT 5')
