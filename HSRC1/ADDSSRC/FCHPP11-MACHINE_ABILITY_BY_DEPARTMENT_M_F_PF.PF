     A                                      COLHDG('GROUP')
     A            M8KKR3         1          TEXT('TEAM-3')
     A                                      COLHDG('TEAM')
     A            M8SAIZ         5S 2       TEXT('PROCESSING SIZE')
     A                                      COLHDG('SIZE')
     A            M8KMIN         3S 0       TEXT('NOMINAL LENGTH -MIN')
     A                                      COLHDG('NOMINAL LENGTH MIN')
     A            M8KMAX         3S 0       TEXT('NOMINAL LENGTH -MAX')
     A                                      COLHDG('NOMINAL LENGTH MAX')
     A            M8GRUP         3          TEXT('MACHINE GROUP')
     A                                      COLHDG('MACHINE GROUP')
     A            M8SPDI         5S 0       TEXT('PROCESSING SPEED HIGHT')
     A                                      COLHDG('SPEED HIGHT')
     A            M8SPCY         5S 0       TEXT('PROCESSING SPEED MEDIUM ')
     A                                      COLHDG('SPEED MEDIUM ')
     A            M8SPSY         5S 0       TEXT('PROCESSING SPEED LOW')
     A                                      COLHDG('SPEED LOW')
     A            M8KADO         5S 2       TEXT('IDEAL RATE OF OPERATION')
     A                                      COLHDG('OPERATION')
     A            M8DNJJ         2S 0       TEXT('SETUP HH')
     A                                      COLHDG('SETUP HH')
     A            M8DNMM         2S 0       TEXT('SETUP MM')
     A                                      COLHDG('SETUP MM')
     A            M8KINO        10          TEXT('MACHINE MAKER')
     A                                      COLHDG('MAKER')
     A            M8KSIK        10          TEXT('MACHINE MODEL NO')
     A                                      COLHDG('MODEL')
     A            M8KONY         4S 0       TEXT('MACHINE PURCHASE POINT')
