     A** FCGPP41 *************************************
     A*  ..製品図面　情報名称マスター（海外向け）  *
     A*     T.SAKASHITA       2014.08.04             *
     A***************************** FCGPP11 **********
      *
     A          R FCGPP411                  TEXT('製品図面情報Ｍ')
     A            E@SKJY         1          COLHDG('削除コード')
     A            E@SKYY         4S 0       COLHDG('削除予定日　年')
     A            E@SKMM         2S 0       COLHDG('　　　　　　月')
     A            E@SKDD         2S 0       COLHDG('　　　　　　日')
     A            E@KOYY         4S 0       COLHDG('更新作業日　年')
     A            E@KOMM         2S 0       COLHDG('　　　　　　月')
     A            E@KODD         2S 0       COLHDG('　　　　　　日')
     A            E@KOHH         2S 0       COLHDG('更新作業時刻　時')
     A            E@KOSS         2S 0       COLHDG('　　　　　　　分')
     A            E@KOME        10          COLHDG('更新作業者名')
      *
     A            E@SHPE         1A
     A            E@SHP2         1A
     A            E@TYPE         1A
      *
     A            E@ENGN        15A
      *
     A          K E@SHPE
     A          K E@SHP2
     A          K E@TYPE
