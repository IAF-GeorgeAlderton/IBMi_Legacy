     A            E5KOTM         6S 0       COLHDG('UPDATE TIME')
     A            E5KOME        10A         COLHDG('UPDATE PERSON')
     A            E5KOPG        10A         COLHDG('UPDATE PGM')
      *
     A            E5JYKB         2A         COLHDG('PARTNER GROUP')
     A            E5NONY         4A         COLHDG('DETAIL CODE')
     A            E5SNRV         1A         COLHDG('SEND OR RECEIVE')
     A            E5DKBN         3A         COLHDG('EDI DATA CODE')
      *******************************************************
      * 830 HEADER
      *******************************************************
     A            E5SHPT         5A         COLHDG('SHIP TO')
     A            E5SHPF         5A         COLHDG('SHIP FROM')
     A            E5SELP         5A         COLHDG('SELLING PARTY')
      *******************************************************
      * 830 DETAIL
      *******************************************************
     A            E5DOCK        30A         COLHDG('IAF DOCK')
     A            E5ALF1        30A         COLHDG('ASEMBLE LINE FD LOC')
     A            E5ALF2        30A         COLHDG('RSV ASM LINE FD LOC')
     A            E5FRF1        60A         COLHDG('FREE FORM1')
     A            E5FRF2        60A         COLHDG('FREE FORM2')
     A            E5FRF3        60A         COLHDG('FREE FORM3')
     A            E5FRF4        60A         COLHDG('FREE FORM4')
      *******************************************************
      * 830 850 COMMON
      *******************************************************
     A            E5STCP        35A         COLHDG('IAF EXPEDITOR')
     A            E5STPH        21A         COLHDG('IAF PHONE #')
      *******************************************************
     A* 850 HEADER
     A*******************************************************
     A            E5SFCP        35A         COLHDG('SHIP FROM PERSON')
     A            E5SFPH        21A         COLHDG('SHIP FROM PHONE #')
      *
     A          K E5NONY
