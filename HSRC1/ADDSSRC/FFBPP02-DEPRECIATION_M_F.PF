      **** FFBPP02 ****************************
      * * DEPRECIATION M/F (PHYSICAL)
      * *     A.IDOTA         1990.02.14      *
      ****************************************
     A          R FFBPP021
     A            H3SKJY         1          COLHDG('DELETE CODE')
     A            H3SKYY         4S 0       COLHDG('DELETE DUE DATE' -
     A                                             '<YEAR>')
     A            H3SKMM         2S 0       COLHDG('DELETE DUE DATE' -
     A                                             '<MONTH>')
     A            H3SKDD         2S 0       COLHDG('DELETE DUE DATE' -
     A                                             '<DAY>')
     A            H3KOYY         4S 0       COLHDG('UPDATE WORKDAY' -
     A                                             '<YEAR>')
     A            H3KOMM         2S 0       COLHDG('UPDATE WORKDAY' -
     A                                             '<MONTH>')
     A            H3KODD         2S 0       COLHDG('UPDATE WORKDAY <DAY>')
     A            H3KOJI         2S 0       COLHDG('UPDATE WORK TIME' -
     A                                             '<TIME>')
     A            H3KOPN         2S 0       COLHDG('UPDATE WORK' -
     A                                             'TIME<MINUTES>')
     A            H3KOME        10          COLHDG('UPDATE NAME OF TEAM' -
     A                                             'MEMBER')
     A            H3SIKB         4S 0       COLHDG('USER INSTRUCTION')
     A            H3KAMK         4          COLHDG('TITLE OF ACCOUNT')
     A            H3TRN1         4          COLHDG('INPUT NUMBER .1')
     A            H3TRN2         4          COLHDG('INPUT NUMBER .2')
     A            H3HZKB         2          COLHDG('AFFILIATION' -
     A                                             'INSTRUCTION')
     A            H3SYKB         4S 0       COLHDG('OWNER INSTRUCTION')
     A            H3JOCH         4S 0       COLHDG('COMFORTABLE PLACE')
     A            H3COS1         2          COLHDG('PRIMITIVE COST' -
     A                                             'DEPARTMENT .1')
     A            H3COS2         2          COLHDG('PRIMITIVE COST' -
     A                                             'DEPARTMENT .2')
     A            H3COS3         2          COLHDG('PRIMITIVE COST' -
     A                                             'DEPARTMENT .3')
     A            H3TSKB         1          COLHDG('SPECIAL DEPRECIATION' -
     A                                             'INSTRUCTION')
     A            H3TRIT         5S 4       COLHDG('SPECIAL DEPRECIATION' -
     A                                             'RATE')
     A            H3STKB         1          COLHDG('ACQUISITION' -
     A                                             'INSTRUCTION')
     A            H3MIKB         4          COLHDG('NAME INSTRUCTION')
     A            H3KHKB         1          COLHDG('EXPENSE INSTRUCTION')
     A            H3HIZY         4S 0       COLHDG('ACQUISITION <YEAR>')
     A            H3HIZM         2S 0       COLHDG('ACQUISITION <MONTH>')
     A            H3HIZD         2S 0       COLHDG('ACQUISITION <DAY>')
     A            H3TINS         2S 0       COLHDG('DURABILITY')
     A            H3STKG        10S 0       COLHDG('ACQUISITION CHARGE')
     A            H3TBKG        10S 0       COLHDG('ACCOUNT BOOK CHARGE' -
     A                                             '<PREVIOUS>')
     A            H3GOTB        10S 0       COLHDG('AFTER DEPRECIATION' -
     A                                             'ACCOUNT BOOK CHARGE')
     A            H3FZTA         9S 0       COLHDG('THE CURRENT TERM' -
     A                                             'DEPRECIATION TOTAL')
     A            H3FUTU         9S 0       COLHDG('AMOUNT OF GENERAL' -
     A                                             'DEPRECIATION 12/12')
     A            H3FUTK         9S 0       COLHDG('AMOUNT OF GENERAL' -
     A                                             'DEPRECIATION 1/02')
     A            H3ZOKA         9S 0       COLHDG('INCREASE' -
     A                                             'DEPRECIATION')
     A            H3TOKU         9S 0       COLHDG('SPECIAL DEPRECIATION')
     A            H3SRIT         4S 3       COLHDG('DEPRECIATION RATE')
     A            H3SCOD         8          COLHDG('ASSETS CODE')
     A            H3SYKG         9S 0       COLHDG('AMOUNT OF')
     A            H3SHZY         4S 0       COLHDG('REEVALUATION <YEAR>')
     A            H3SHZM         2S 0       COLHDG('<MONTH>')
     A            H3SHZD         2S 0       COLHDG('<DAY>')
     A            H3SIKG        10S 0       COLHDG('REEVALUATION PRICE')
     A            H3TYUK         1          COLHDG('USED INSTRUCTION')
     A            H3SYOK         1          COLHDG('PURPOSE OF USE' -
     A                                             'INSTRUCTION')
     A            H3KEYY         4S 0       COLHDG('ADDING UP <YEAR>')
     A            H3KEMM         2S 0       COLHDG('ADDING UP <MONTH>')
     A            H3TIYO         2S 0       COLHDG('DURABILITY OF THE' -
     A                                             'CURRENT TERM')
