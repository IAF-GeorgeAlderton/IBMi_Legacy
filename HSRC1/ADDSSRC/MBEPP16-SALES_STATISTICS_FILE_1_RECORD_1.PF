     A            Y1SU11         9S 0       COLHDG('AMOUNT- 11')
     A            Y1SU12         9S 0       COLHDG('AMOUNT- 12')
     A            Y1SURI        11S 0       COLHDG('AMOUNT ACCUMULATED' -
