     A            Y1KN12         7S 0       COLHDG('DATA COUNT- 12')
     A            Y1KNRI         9S 0       COLHDG('COUNT ACCUMULATED' -
     A                                             'TOTAL')
      * * * * * * * SALES AMOUNT * * * * * * * * * * * * * * * * * * * * * * * *
