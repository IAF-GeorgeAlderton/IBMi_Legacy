     A** ADAPP77 *************************************
     A* *PRODUCTION  REORDER AND OVER MADE BAR CODE READ COUNT
     A*                     92.11.27    S.YAMAGAMI *
     A************************************************
     A          R ADAPP771
     A            AWKOYY         4S 0       COLHDG('UPDATE WORK DATE YY')
     A            AWKOMM         2S 0       COLHDG('UPDATE WORK DATE MM')
     A            AWKODD         2S 0       COLHDG('UPDATE WORK DATE DD')
     A            AWSAIT         4S 0       COLHDG('PRODUCTION' -
     A                                             'REORDER NUMBER')
     A            AWTSUK         4S 0       COLHDG('OVER MADE NUMBER')
     A          K AWKOYY
     A          K AWKOMM
     A          K AWKODD
