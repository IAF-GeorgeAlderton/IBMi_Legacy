      *** EAEPP88 *****************************************
      *   DELIVERY DETAILS DATA FILE (IINOU&IIKJCD)    *
      *   PHIGICAL-FILE. : EAEPP88 <PF>                   *
      *   CREATE DATE. : 1996.MAR.22.                     *
      *   AUTHOR.         : SHINICHIRO.OHTAKE             *
      *   USER SECTION. : THE DELIVERY SECTION. *
      ****************************************** EAEPP88 **
     A          R EAEPP881                  TEXT('DELIVERY DETAILS DATA FILE')
     A            EEHAKK         1          COLHDG('PUBLISHED CODE')
     A            EEHAYY         4S 0       COLHDG('PUBLICATION DATE YY')
     A            EEHAMM         2S 0       COLHDG('PUBLICATION DATE MM')
     A            EEHADD         2S 0       COLHDG('PUBLICATION DATE DD')
      *
     A            EENONY         4S 0       COLHDG('DELIVERY POINT')
     A            EENKOJ         1          COLHDG('FACTORY')
     A            EENUKE         4          COLHDG('RECEIVING')
     A            EENOYY         4S 0       COLHDG('DELIVERY DAY (YEAR)')
     A            EENOMM         2S 0       COLHDG('DELIVERY DAY (MONTH)')
     A            EENODD         2S 0       COLHDG('DELIVERY DAY (DAY)')
     A            EEUHIN        12          COLHDG('USER PART NUMBER')
     A            EESRYO         6S 0       COLHDG('DELIVERY AMOUNT')
     A            EENOBN         7          COLHDG('STATEMENT OF' -
     A                                             'DELIVERY NUMBER')
     A            EETOKU         4S 0       COLHDG('CUSTOMER')
     A            EEHAKO         3S 0       COLHDG('NUMBER OF BOXES')
