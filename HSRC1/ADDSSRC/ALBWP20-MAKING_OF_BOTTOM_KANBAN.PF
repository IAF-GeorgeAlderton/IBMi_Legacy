     A          K ALUHN3
     A          K ALCHK4
     A          K ALST5
     A          K ALINX5
     A          K ALUSYS
     A          K ALKNO
     A          K ALCHK5
     A          K ALST6
     A          K ALINX6
     A          K ALROUT
     A          K ALUKEI
     A          K ALRESV
     A          K ALCHK6
