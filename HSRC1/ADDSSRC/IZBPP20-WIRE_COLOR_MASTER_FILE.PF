     A** IZBPP20 *******************
     A* MATERIAL COLOR MASTER FILE *
     A*  I-HASADA      2000.07.24  *
     A******************* IZBPP20 **
      *
     A          R IZBPP201                  TEXT('MATERIAL COLOR+
     A                                            MASTER FILE')
      *
     A            ZHSKJY         1          COLHDG('DELETE CODE')
     A            ZHSKYY         4S 0       COLHDG('DELETE DUE DATE' -
     A                                             '(YEAR)')
     A            ZHSKMM         2S 0       COLHDG('(MONDAY)')
     A            ZHSKDD         2S 0       COLHDG('(SUNDAY )')
     A            ZHKOYY         4S 0       COLHDG('UPDATE WORK DAY' -
     A                                             '(YEAR)')
     A            ZHKOMM         2S 0       COLHDG('MONTH')
     A            ZHKODD         2S 0       COLHDG('DAY')
     A            ZHKOHH         2S 0       COLHDG('UPDATE WORK TIME')
     A            ZHKOSS         2S 0       COLHDG('(MINUTES)')
     A            ZHKOME        10A         COLHDG('NAME OF TEAM MEMBER' -
     A                                             'WHO UPDATED')
     A            ZHZAIS        15A         COLHDG('MATERIAL')
     A            ZHZIRO        20A         COLHDG('MATERIAL COLOR')
     A            ZHZRCD         1A         COLHDG('MATERIAL COLOR CODE')
