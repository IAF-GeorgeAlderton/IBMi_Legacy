     A** ALDPPX1
     A* TEST SAKAKI
     A******************************
      *
     A          R ALDPPX11                  TEXT('EKANBAN SERIAL')
     A            A6SCDT         8  0       COLHDG('SCAN DATE')
     A            A6SCTM         6  0       COLHDG('SCAN TIME')
     A            A6NONY         4A         COLHDG('DELIVERY CODE')
     A            A6NKOJ         1A         COLHDG('FACTORY')
     A            A6NUKE         4A         COLHDG('DOCK')
     A            A6ORNO        12          COLHDG('ORDER#')
     A            A6LTNO         3          COLHDG('LOT#')
      *
     A            A6SHN1         5A         COLHDG('IAF PART#1')
     A            A6SHN2         5A         COLHDG('2')
     A            A6SHN3         2A         COLHDG('3')
     A            A6NOYY         4  0       COLHDG('INVOICE YY')
     A            A6NOMM         2  0       COLHDG('INVOICE MM')
     A            A6NODD         2  0       COLHDG('INVOICE DD')
     A            A6NOBN         2  0       COLHDG('BIN')
     A            A6DEYY         4  0       COLHDG('SHIP YY')
     A            A6DEMM         2  0       COLHDG('MM')
     A            A6DEDD         2  0       COLHDG('DD')
     A            A6DETM         6  0       COLHDG('DELIVERY TIME')
     A            A6SRYO        10  0       COLHDG('DELIVERY QUANTITY')
     A            A6MHN1         5          COLHDG('CUST PART#1')
     A            A6MHN2         5          COLHDG('CUST PART#2')
     A            A6MHN3         5          COLHDG('CUST PART#3')
     A            A6MHN4         5          COLHDG('CUST PART#4')
     A            A6UKAN       250          COLHDG('QR')
     A            A6ODAT         8  0       COLHDG('MINO DATE')
     A            A6OTIM         6  0       COLHDG('MINO')
     A            A6RDAT         8  0       COLHDG('RECOVERY DATE')
     A            A6RTIM         6  0       COLHDG('MINO')
