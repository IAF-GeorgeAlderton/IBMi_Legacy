     A** AFDWP25I ******************************************
     A*  WF FOR BIN INQUIRY                                *
     A*  LEC    2021.08.26                                 *
     A******************************************************
     A          R AFDWP251                  TEXT('BIN# WF')
     A*
     A            BINOBN         3          COLHDG('BIN#')
     A*
     A* FROM BIN M/F
     A            BISKJY         1          COLHDG('STATUS')
     A            BIKODT        10          COLHDG('STS_CHG_DT')
     A            BIKOTM         8          COLHDG('STS_CHG_TM')
     A            BIKOME        15          COLHDG('CHANGED_BY')
     A            BIISDT        10          COLHDG('ISSUED_DT')
     A            BIISTM         8          COLHDG('ISSUED_TM')
     A            BIISME        15          COLHDG('ISSUED_BY')
     A            BILBDT        10          COLHDG('LBL_PRT_DT')
     A            BILBTM         8          COLHDG('LBL_PRT_TM')
     A            BILBME        15          COLHDG('PRINTED_BY')
      *
     A* FROM OUTSOURCE ORDER FILE
     A            BISUPP         4          COLHDG('SUPPLIER CODE')
     A            BISHIN        12          COLHDG('PART NUMBER')
     A            BIBOX#         3S 0       COLHDG('# OF BOXES')
     A            BIQPC          5S 0       COLHDG('QPC')
     A            BIORD#         6S 0       COLHDG('O/S ORDER#')
     A            BIORDT         8S 0       COLHDG('O/S ORDER DATE')
     A            BIRCDT         8S 0       COLHDG('RECEIVED DATE')
