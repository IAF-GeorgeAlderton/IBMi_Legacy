     A*** A$DPP11 ******************************************************
     A* REGULAR CALENDAR FILE(INCLUDE HOLIDAY)                         *
     A* J.WATANABE 2017.06.19                                          *
     A* FIELD EXPLANATION                                              *
     A* 1. DAY IN A WEEK 1=MONDAY ,2=TUESDAY,  3=WEDNESDAY, 4=TURSDAY  *
     A*                  5=FRIDAY, 6=SATURDAY, 7=SUNDAY                *
     A* 2. DAY , NIGHT ATTENDANCE HOLIDAY                              *
     A*   (*=HOLIDAY, BLANK=OPERATION DAY)                             *
     A* 3. WORK ON UNWORKING DAY                                       *
     A* * S=START DATE OF UNWORKING NIGHT                              *
     A* * E=END   DATE OF UNWORKING NIGHT                              *
     A* * R=WORK ON UNWORKING DAY                                      *
     A* * M=WORK ON UNWORKING NIGHT                                    *
     A******************************************************************
     A          R AGDPP111                  TEXT('REGULAR CALENDAR')
     A            F8KAYY         4S 0       COLHDG('YEAR')
     A            F8KAMM         2S 0       COLHDG('MONTH')
     A            F8KADD         2S 0       COLHDG('DAY')
     A            F8YOBI         1S 0       COLHDG('DAY ID#')
      *                                            1=MONDAY
      *                                            2=TUESDAY
      *                                            3=WEDNESDAY
      *                                            4=THURSDAY
      *                                            5=FRIDAY
      *                                            6=SATURDAY
      *                                            7=SUNDAY
     A            F8HIRU         1A         COLHDG('DAY WORK')
     A            F8YORU         1A         COLHDG('NIGHT WORK')
      *                                            *=HOLIDAY
      *                                            BLANK=WORK
     A            F8MAEY         1A         COLHDG('UNWORKING NIGHT WORK')
