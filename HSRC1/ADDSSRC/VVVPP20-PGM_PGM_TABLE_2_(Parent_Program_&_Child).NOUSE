     A*** VVVPPC2 ******************************
     A* PGM-PGM TABLE                          *
     A*           ATR: R=RPG, C=CLP            *
     A******************************************
     A          R VVVPPC21                  TEXT('PGM-PGM')
     A            VWPNAM        10A         COLHDG('PARENT PGM')
     A            VWPNAA         1A         COLHDG('PARENT ATR: R,C')
     A            VWFNAM        10A         COLHDG('CHILD PGM')
     A            VWFNAA         1A         COLHDG('CHILD ATR: R,C')
     A            VWTEXT        50A         COLHDG('PARENT TEXT')
     A            VWTEXT        50A         COLHDG('PARENT TEXT')
     A            VWCRHZ         8S 0       COLHDG('CREATE DATE')
     A            VWCRTM         6S 0       COLHDG('CREATE TIME')
     A            VWCRID        10A         COLHDG('CREATE ID  ')
     A            VWCRPG        10A         COLHDG('CREATE RPG ')
      *
     A          K VWPNAM
     A          K VWFNAM
