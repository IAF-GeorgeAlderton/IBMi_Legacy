     A** AL#WP13 ************************************
     A*  PALLET FILE                                *
     A*     ITS.        2015.05.19                  *
     A***********************************************
     A          R AL#WP131
     A            W3SHID         8A         COLHDG('SHIP DATE')
     A            W3SHIT         6A         COLHDG('SHIP TIME')
     A            W3NONY         4S 0       COLHDG('DELIVERY CODE')
     A            W3NKOJ         1A         COLHDG('DELIVERY FACTORY')
     A            W3NUKE         4A         COLHDG('DELIVERY RECEIVING')
     A            W3ORD#        12A         COLHDG('ORDER#')
     A            W3SURT         9A         COLHDG('SUB ROUTE')
     A            W3EXTR         3S 0       COLHDG('EXTRA#')
     A            W3FIXD         8S 0       COLHDG('PALLET FIX DATE')
     A            W3FIXT         6S 0       COLHDG('PALLET FIX TIME')
     A            W3PALT         2A         COLHDG('PALLET CODE')
     A            W3BOX          8S 0       COLHDG('DATA COUNT')
     A            W3TRKB         2A         COLHDG('IAF TRUCK BIN#')
     A            W3IAFB         3A         COLHDG('IAF BIN#')
     A            W3IAFP         3A         COLHDG('IAF PALLET CODE')
     A            W3PRT          5S 0       COLHDG('KIND OF PART#')
     A            W3PPUL         1A         COLHDG('PALLET PULLING')
     A            W3SAT          1A         COLHDG('SATURDAY')
     A            W3SHN1         5A         COLHDG('PART NO1')
     A            W3SHN2         5A         COLHDG('2')
     A            W3SHN3         2A         COLHDG('3')
     A            W3PSEQ         4S 0       COLHDG('IAF PALLET# DEC')
     A          K W3TRKB
     A          K W3SURT
     A          K W3IAFB
     A          K W3PPUL                    DESCEND
     A          K W3NONY
     A          K W3NKOJ
     A          K W3NUKE
     A****      K W3SHID
     A****      K W3SHIT
