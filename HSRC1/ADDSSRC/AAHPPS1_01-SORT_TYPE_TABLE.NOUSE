     A          R AAHPPS11
     A            H@SKJY         1          COLHDG('DELETE CODE')
     A            H@SKDT         8S 0       COLHDG('DELETE DATE')
     A            H@KODT         8S 0       COLHDG('UPDATE DATE')
     A            H@KOTM         6S 0       COLHDG('UPDATE TIME')
     A            H@KOPG        10A         COLHDG('UPDATE PGM')
     A            H@KOUS        10A         COLHDG('UPDATE USER')
      *
     A            J@KUBN         1          COLHDG('S:SORT #:# J:SND ST')
      *
     A            J@JOKN         2          COLHDG('CONDITION CODE')
     A            J@KANB         1          COLHDG('KANBAN KIND')
      *
     A          K J@KUBN
     A          K J@JOKN
     A          K J@KANB
