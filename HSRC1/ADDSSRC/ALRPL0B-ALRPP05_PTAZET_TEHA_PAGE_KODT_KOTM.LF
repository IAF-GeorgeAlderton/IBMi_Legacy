     A            PTODER                    COLHDG('P/T ORDER NO.')
     A            PTPRCD                    COLHDG('P/T PRODUCT CODE')
     A            PTLOTN                    COLHDG('P/T LOT NO.')
     A            PTPBN1                    COLHDG('P/T LOCATION 1 ')
     A            PTPBN2                    COLHDG('P/T LOCATION 2 ')
     A            PTPBN3                    COLHDG('P/T LOCATION 3 ')
     A            PTPBN4                    COLHDG('P/T LOCATION 4 ')
     A* RESULT
     A            PTOKNG                    COLHDG('OK/NG')
     A            PTERCD                    COLHDG('ERROR CODE')
     A*
     A*<< KEY >>
     A          K PTAZET
     A          K PTTEHA
     A          K PTPAGE
     A          K PTKODT
     A          K PTKOTM
     A*
