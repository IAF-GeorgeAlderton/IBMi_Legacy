      ** ALDPP3X ***************************************
      * OUT-GOING TRACK DATA FILE. <APICS KANBAN>      *
      * FILE-NAME.       :  ALDPP30    <PFILE>         *
      * CREATE DATE.     :  JUN/27/1997.               *
      * AUTHOR.          :  SHINICHIRO.OHTAKE          *
      *
      * ADD SERIAL NUMBER FIELD
      *      NOV/07/01     TCH
      *************************************** ALDPP30 **
     A          R ALDPP3X1                  TEXT('OUT-GOING TRACK FILE')
     A            AXKSYY         4S 0       COLHDG('UPDATE DATE YY')
     A            AXKSMM         2S 0       COLHDG('UPDATE DATE MM')
     A            AXKSDD         2S 0       COLHDG('UPDATE DATE DD')
     A            AXKSJI         2S 0       COLHDG('UPDATE TIME JI')
     A            AXKSPN         2S 0       COLHDG('UPDATE TIME FN')
     A            AXKSNA        10A         COLHDG('UPDATE TEAM NO')
     A            AXKANS         1A         COLHDG('KANBAN TYPE')
     A            AXZETI         4A         COLHDG('ABSOLUTE NO')
     A            AXTEHI         3A         COLHDG('TEHI NO')
     A            AXPAGE         2A         COLHDG('PAGE NO')
     A            AX2KAK         1A         COLHDG('SECOND WORK TYPE')
     A            AXTASY         1A         COLHDG('OBJECT TYPE')
     A            AXYUKO         1A         COLHDG('YUKO KUBUN')
     A            AXHASY         1A         COLHDG('BOX TYPE')
     A            AXSHN1         5A         COLHDG('IN-HOUSE PARTS NO 1')
     A            AXSHN2         5A         COLHDG('IN-HOUSE PARTS NO 2')
     A            AXSHN3         2A         COLHDG('IN-HOUSE PARTS NO 3')
     A            AXSYYY         4S 0       COLHDG('OUT-GOING DATE YY')
     A            AXSYMM         2S 0       COLHDG('OUT-GOING DATE MM')
     A            AXSYDD         2S 0       COLHDG('OUT-GOING DATE DD')
     A            AXSYJI         2S 0       COLHDG('OUT-GOING TIME JI')
     A            AXSYFN         2S 0       COLHDG('OUT-GOING TIME FN')
     A            AXTKR1         1A         COLHDG('ADDRESS 1')
     A            AXTKR2         2A         COLHDG('ADDRESS 2')
     A            AXTKR3         2A         COLHDG('ADDRESS 3')
     A            AXTKR4         1A         COLHDG('ADDRESS 4')
     A            AXOPER         6A         COLHDG('OPERATOR ID')
     A            AXMHN1         5A         COLHDG('USER PARTS NO  1')
     A            AXMHN2         5A         COLHDG('USER PARTS NO  2')
     A            AXMHN3         5A         COLHDG('USER PARTS NO  3')
     A            AXMHN4         5A         COLHDG('USER PARTS NO  4')
     A            AXSSYS         5S 0       COLHDG('IN-HOUSE QUANTITY')
     A            AXUSYS         7S 0       COLHDG('USER QUANTITY')
     A            AXNONY         4S 0       COLHDG('DELIVERY POINT')
     A            AXNKOJ         1A         COLHDG('DELIVERY POINT F')
     A            AXNUKE         4A         COLHDG('DELIVERY PINT RCV')
     A            AXTOPX         6A         COLHDG('TOPIX CODE')
     A            AXSALE         1A         COLHDG('EFU OR KANBAN')
     A            AXSERL        18A         COLHDG('SERIAL NUMBER')
