     A          R MBDPL161                  PFILE(MBDPP11)
     A            F4SKJY                    COLHDG('DLT')
     A            F4SKYY                    COLHDG('DLT YY')
     A            F4SKMM                    COLHDG('DLT MM')
     A            F4SKDD                    COLHDG('DLT DD')
     A            F4TOKU                    COLHDG('CUST#')
     A            F4TKOJ                    COLHDG('T FACTORY')
     A            F4TUKE                    COLHDG('T DOCK')
