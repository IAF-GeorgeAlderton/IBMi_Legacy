      *
JW1  A            BESTAT         2A         COLHDG('STATE')
 .   A            BECNTY         3A         COLHDG('COUNTRY')
 .   A            BECRHZ         8S 0       COLHDG('CRT DATE')
 .   A            BECRTM         6S 0       COLHDG('CRT TIME')
 .   A            BECRUS        10A         COLHDG('CRT USER')
 .   A            BEKOHZ         8S 0       COLHDG('UPD DATE')
 .   A            BEKOTM         6S 0       COLHDG('UPD TIME')
 .   A            BEKOUS        10A         COLHDG('UPD USER')
 .   A            BEDLHZ         8S 0       COLHDG('DLT DATE')
 .   A            BEDLTM         6S 0       COLHDG('DLT TIME')
JW1  A            BESLUS        10A         COLHDG('DLT USER')
