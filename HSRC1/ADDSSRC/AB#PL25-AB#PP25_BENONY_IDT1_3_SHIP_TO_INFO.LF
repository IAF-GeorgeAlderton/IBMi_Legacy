     A            BEADD3        35A         COLHDG('        3')
     A            BEADD4        35A         COLHDG('        4')
     A            BECITY        30A         COLHDG('CITY NAME')
     A            BEPOST        15A         COLHDG('POSTAL CODE')
     A            BEIDT2        20A         COLHDG('IDENTIFICATION CODE')
     A            BENAM2        35A         COLHDG('NAME LINE2')
     A            BEIDT3        20A         COLHDG('IDENTIFICATION CODE')
     A            BENAM3        35A         COLHDG('NAME LINE3')
     A**          BEIDT4        20A         COLHDG('IDENTIFICATION CODE')
