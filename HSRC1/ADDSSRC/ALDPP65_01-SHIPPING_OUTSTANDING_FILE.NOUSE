      ** ALDPP65 ***************************************
      * SHIPPING OUTSTANDING FILE                      *
      *                                                *
      * TCHK  05/02/13 CREATE                          *
      *************************************** ALDPP60 **
     A          R ALDPP651                  TEXT('SHIPPING OUTSTANDING')
     A            AFDATE         8S 0       COLHDG('DATE')
     A            AFTIME         6S 0       COLHDG('TIME')
     A            AFUSER        10          COLHDG('INPUT USER')
     A            AFWSID        10          COLHDG('INPUT WS')
     A            AFPGID        10          COLHDG('INPUT PGM')
     A            AFTMCD        10          COLHDG('INPUT TM')
     A*
     A            AFUKAN       250A         COLHDG('USER KANBAN')
     A*
     A            AFLOC         10A         COLHDG('LOCATION')
     A            AFLZET         4          COLHDG('ZETI')
     A            AFLOC1         1          COLHDG('LOC1')
     A            AFLOC2         2          COLHDG('LOC2')
     A            AFLOC3         2          COLHDG('LOC3')
     A            AFLOC4         1          COLHDG('LOC4')
     A            AFLPR1         5          COLHDG('PART21')
     A            AFLPR2         5          COLHDG('PART22')
     A            AFLPR3         2          COLHDG('PART23')
     A* OUTSTANDING INF
     A            AFODAT         8S 0       COLHDG('DATE')
     A            AFOTIM         6S 0       COLHDG('TIME')
     A            AFOTMC        10          COLHDG('INPUT TM')
     A* APICS KANBAN
     A            AFAKAN        17A         COLHDG('APICS KANBAN')
     A            AFAZET         4A         COLHDG('ID#')
     A            AFALOT         3A         COLHDG('LOT#')
     A            AFAPAG         2A         COLHDG('PAGE#')
     A* RECOVERY INF
     A            AFRDAT         8S 0       COLHDG('DATE')
     A            AFRTIM         6S 0       COLHDG('TIME')
     A            AFRTMC        10          COLHDG('INPUT TM')
     A*
     A          K AFUKAN
