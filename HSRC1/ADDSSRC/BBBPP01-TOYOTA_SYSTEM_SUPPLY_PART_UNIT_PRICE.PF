     A*********************************************** BBBPP01 **
     A          R BBBPP011                  TEXT('TOYOTA SYSTEM SUPPLY PART -
     A                                      UNIT PRICE M/F')
     A            BBSKJY         1          COLHDG('DELETE CODE')
     A            BBSKYY         4S 0       COLHDG('DELETE DUE DATE YEAR')
     A            BBSKMM         2S 0       COLHDG('MONTH')
     A            BBSKDD         2S 0       COLHDG('DAY')
     A            BBKOYY         4S 0       COLHDG('UPDATE WORK DATE' -
     A                                             'YEAR')
     A            BBKOMM         2S 0       COLHDG('MONTH')
     A            BBKODD         2S 0       COLHDG('DAY')
     A            BBKOHH         2S 0       COLHDG('UPDATE TIME TIME')
     A            BBKOSS         2S 0       COLHDG('MINUTES')
     A            BBKOME        10          COLHDG('UPDATE NAME OF TEAM' -
     A                                             'MEMBER')
     A            BBBHKB         2A         COLHDG('PART INSTRUCTION')
     A            BBHIN1         5A         COLHDG('USER PART NUMBER 1')
     A            BBHIN2         5A         COLHDG('USER PART NUMBER 2')
     A            BBHIN3         5A         COLHDG('USER PART NUMBER 3')
     A            BBSHN1         5A         COLHDG('INTRAL COMPANY PART' -
     A                                             'NO 1')
     A            BBSHN2         5A         COLHDG('INTRAL COMPANY PART' -
     A                                             'NO 2')
     A            BBSHN3         2A         COLHDG('INTRAL COMPANY PART' -
     A                                             'NO 3')
     A            BBSRCD         4S 0       COLHDG('SUPPLIER')
     A            BBTKCD         4S 0       COLHDG('CUSTOMER')
     A            BBMHKB         1          COLHDG('CARRYING IN' -
     A                                             'INSTRUCTION')
     A            BBHSKB         1A         COLHDG('PACKING INSTRUCTION')
     A            BBKANO        10A         COLHDG('MANAGEMENT NO')
     A* PURCHASE UNIT PRICE FOR THIS TIME
     A            BBKTNK         9S 2       COLHDG('UNIT PRICE')
     A            BBKSYY         4S 0       COLHDG('APPLYING START DATE' -
     A                                             'YEAR')
     A            BBKSMM         2S 0       COLHDG('APPLYING START DATE' -
     A                                             'MONTH')
     A            BBKSDD         2S 0       COLHDG('APPLYING START DATE' -
     A                                             'DAY')
     A            BBKEYY         4S 0       COLHDG('APPLYING EXIT DATE' -
     A                                             'YEAR')
     A            BBKEMM         2S 0       COLHDG('APPLYING EXIT DATE' -
     A                                             'MONTH')
     A            BBKEDD         2S 0       COLHDG('APPLYING EXIT DATE' -
     A                                             'DAY')
     A            BBKGKB         1A         COLHDG('PRESENT OR OLD' -
     A                                             'INSTRUCTION)')
     A            BBKKKB         1A         COLHDG('OLD DIE INSTRUCTION')
     A* BREAKDOWN
     A            BBUBTN         9S 2       COLHDG('PART UNIT PRICE')
     A            BBKEIS         3S 2       COLHDG('COEFFICIENT UNIT' -
     A                                             'PRICE')
     A            BBKKST         9S 2       COLHDG('PECULIAR  COST')
     A* PURCHASE UNIT PRICE FOR LAST TIME
     A            BBZTNK         9S 2       COLHDG('UNIT PRICE')
     A            BBZSYY         4S 0       COLHDG('APPLYING START DATE' -
     A                                             'YEAR')
     A            BBZSMM         2S 0       COLHDG('APPLYING START DATE' -
     A                                             'MONTH')
     A            BBZSDD         2S 0       COLHDG('APPLYING START DATE' -
     A                                             'DAY')
     A            BBZEYY         4S 0       COLHDG('APPLYING EXIT DAY' -
     A                                             'YEAR')
     A            BBZEMM         2S 0       COLHDG('APPLYING EXIT DATE' -
     A                                             'MONTH')
     A            BBZEDD         2S 0       COLHDG('APPLYING EXIT DATE' -
     A                                             'DAY')
     A            BBZGKB         1A         COLHDG('PRESENT OR OLD' -
     A                                             'INSTRUCTION)')
     A            BBZKKB         1A         COLHDG('OLD DIE INSTRUCTION')
     A*
     A            BBKBKK         2A         COLHDG('PURCHASING TEAM')
