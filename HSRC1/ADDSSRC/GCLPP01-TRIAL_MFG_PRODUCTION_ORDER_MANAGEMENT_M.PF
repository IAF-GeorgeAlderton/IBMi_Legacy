     A                                             'NO 1')
     A            GCSHN2         5A         COLHDG('2')
     A            GCSHN3         2A         COLHDG('3')
     A            GCMHN1         5A         COLHDG('USER PART NUMBER 1')
     A            GCMHN2         5A         COLHDG('2')
     A            GCMHN3         5A         COLHDG('3')
     A            GCSRYO         7S 0       COLHDG('RECEIPT AMOUNT')
     A            GCTANI         1A         COLHDG('AMOUNT UNIT')
