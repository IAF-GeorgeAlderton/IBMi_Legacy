     A                                             'ORDER DATE YY')
     A            GCTHMM         2S 0       COLHDG('MM')
     A            GCTHDD         2S 0       COLHDG('DD')
     A            GCNOYY         4S 0       COLHDG('DELIVERY DATE YY')
     A            GCNOMM         2S 0       COLHDG('MM')
     A            GCNODD         2S 0       COLHDG('DD')
     A            GCHKYY         4S 0       COLHDG('PROD ORDER' -
     A                                             'PUBLICATION DATE YY')
     A            GCHKMM         2S 0       COLHDG('MM')
     A            GCHKDD         2S 0       COLHDG('DD')
     A            GCHKBB         2S 0       COLHDG('BIN')
     A            GCKUB1         1A         COLHDG('TRIAL MFG.' -
     A                                             'LIMITATION' -
     A                                             'INSTRUCTION NEW')
     A            GCKUB2         1A         COLHDG('TRIAL MFG.' -
     A                                             'LIMITATION' -
     A                                             'INSTRUCTION OLD')
     A            GCKRYY         4S 0       COLHDG('INSTRUCTION CHANGE' -
     A                                             'DATE YY')
     A            GCKRMM         2S 0       COLHDG('MM')
     A            GCKRDD         2S 0       COLHDG('DD')
     A            GCTHAI         2A         COLHDG('INTRAL COMPANY' -
     A                                             'PROD ORDER POINT' -
     A                                             'INSTRUCTION')
     A            GCZTHI         2A         COLHDG('LAST TIME INTRAL' -
     A                                             'COMPANY PROD' -
     A                                             'ORDER POINT INST')
     A            GCBAN1         1A         COLHDG('T LOCATION 1')
     A            GCBAN2         2A         COLHDG('T LOCATION 2')
     A            GCBAN3         2A         COLHDG('T LOCATION 3')
     A            GCBAN4         1A         COLHDG('T LOCATION 4')
     A            GCTHIM         1A         COLHDG('PROD ORDER BOOK' -
     A                                             'NO.M')
     A            GCTHID         1A         COLHDG('PROD ORDER BOOK' -
     A                                             'NO.D')
     A            GCTHIR         2S 0       COLHDG('PROD ORDER BOOK' -
     A                                             'NO.LOT')
     A            GCTHIS         2S 0       COLHDG('PROD ORDER BOOK' -
     A                                             'NO. ORDER')
     A            GCBKO1        28A         COLHDG('REMARKS COLUMN 1')
     A            GCBKO2        28A         COLHDG('REMARKS COLUMN 2')
     A            GCBKO3        28A         COLHDG('REMARKS COLUMN 3')
     A            GC01SH         4S 0       COLHDG('DEVELOPMENT START' -
     A                                             'DAY')
     A            GC01EH         4S 0       COLHDG('EXIT DAY')
     A            GC02SH         4S 0       COLHDG('ENGINEERING' -
     A                                             'DEPT.START DAY')
     A            GC02EH         4S 0       COLHDG('EXIT DAY')
     A            GC03SH         4S 0       COLHDG('PLAN START DAY')
     A            GC03EH         4S 0       COLHDG('EXIT DAY')
