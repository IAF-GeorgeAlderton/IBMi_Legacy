     A          R GCLPP011                  TEXT('TRIAL MFG PRODUCTION ORDER  +
     A                                      MANAGEMENT M/F')
     A            GCSKJY         1A         COLHDG('DELETE CODE D')
     A            GCSKYY         4S 0       COLHDG('DELETE DATE YEAR')
     A            GCSKMM         2S 0       COLHDG('DELETE DATE MONTH')
     A            GCSKDD         2S 0       COLHDG('DELETE DATE DAY')
     A            GCKOYY         4S 0       COLHDG('UPDATE DATE YEAR')
     A            GCKOMM         2S 0       COLHDG('UPDATE DATE MONTH')
     A            GCKODD         2S 0       COLHDG('UPDATE DATE DAY')
     A            GCKOJI         2S 0       COLHDG('UPDATE TIME  ')
     A            GCKOPN         2S 0       COLHDG('UPDATE TIME MINUTES')
     A            GCKOME        10A         COLHDG('UPDATE PERSON')
     A            GCTOKU         4S 0       COLHDG('CUSTOMER CODE')
     A            GCTKOJ         1A         COLHDG('FACTORY')
     A            GCTUKE         4A         COLHDG('RECEIVING')
     A            GCNONY         4S 0       COLHDG('DELIVERY POINT CODE')
     A            GCNKOJ         1A         COLHDG('FACTORY')
     A            GCNUKE         4A         COLHDG('RECEIVING')
