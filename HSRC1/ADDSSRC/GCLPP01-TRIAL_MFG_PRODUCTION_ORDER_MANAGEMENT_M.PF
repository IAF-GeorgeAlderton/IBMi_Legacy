     A            GCKNMM         2S 0       COLHDG('COMPLETION DAY MM')
     A            GCKNDD         2S 0       COLHDG('COMPLETION DAY DD')
     A            GCBNYY         4S 0       COLHDG('DIVISION')
     A            GCBNMM         2S 0       COLHDG('DIVISION')
     A            GCBNDD         2S 0       COLHDG('DIVISION COMPLETION' -
     A                                             'DAY DD')
