     A*** ACDPP01 **********************************
     A* BAR CODE M/F BY KIND OF IAF*
     A*       H.ITO             90.11.21           *
     A********************************** ACDPP01 ***
     A          R ACDPP011                  TEXT('BAR CODE M/F')
     A            C1SKJY         1          COLHDG('DELETE CODE')
     A            C1SKYY         4S 0       COLHDG('DELETE DUE DATE YEAR')
     A            C1SKMM         2S 0       COLHDG('               MONTH')
     A            C1SKDD         2S 0       COLHDG('                 DAY')
     A            C1KOYY         4S 0       COLHDG('UPDATE WORK DAY YEAR')
     A            C1KOMM         2S 0       COLHDG('               MONTH')
     A            C1KODD         2S 0       COLHDG('                 DAY')
     A            C1KOHH         2S 0       COLHDG('UPD WORK TIME TIME')
     A            C1KOSS         2S 0       COLHDG('           MINUTES')
     A            C1KOME        10          COLHDG('UPDATE NAME OF' -
     A                                             'TEAM MEMBER')
     A            C1SURI         1A         COLHDG('KIND')
     A            C1BUKO         4S 0       COLHDG('SECTION CODE')
     A            C1TAIP         1          COLHDG('TYPE')
     A            C1BKO1         1          COLHDG('BAR CODE 1 COLUMN')
     A            C1BKO2         2          COLHDG('　　　 2 COLUMN')
