      ** ALBPP30 ***************************
      *  3 POINT SCAN LOCK FILE            *
      * TCH 02/04/05                       *
      *************************** ALBPP30 **
     A          R ALDPP621
     A            ALDATE         8  0       COLHDG('ENTRY DATE')
     A            ALTIME         6  0       COLHDG('ENTRY TIME')
     A            ALKOME        10A         COLHDG('TEAM MEMBER PROFILE')
     A            ALWKCD         6S 0       COLHDG('WORKER CD NO')
     A            ALWKNM        20A         COLHDG('WORKER CD NAME')
     A            ALSCID         2S 0       COLHDG('SCANNER ID')
     A            ALWKID        10A         COLHDG('WORKSTATION ID')
     A          K ALWKCD
