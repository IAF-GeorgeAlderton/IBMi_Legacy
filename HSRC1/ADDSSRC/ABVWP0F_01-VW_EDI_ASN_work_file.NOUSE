     A          R ABVWP0F1                  TEXT('EDI856 WORK')
     A            WTOKU          4  0       COLHDG('CUST')
     A            WNONY          4  0       COLHDG('SHIP TO')
     A            WNKOJ          1          COLHDG('FACTORY')
     A            WNUKE          4          COLHDG('DOCK')
     A            WNOHZ          8  0       COLHDG('SHIP DATE')
     A            WNOTM          4  0       COLHDG('SHIP TIME')
     A            WINV#         20          COLHDG('INVOICE#')
     A            WORDN         10          COLHDG('ORDER#')
     A            WSBAN          4          COLHDG('SBAN')
     A            WSYOS          6  0       COLHDG('QTY/BOX')
     A            WSQTY         10  0       COLHDG('QTY')
     A            WMHIN         20          COLHDG('CUST PART#')
     A            WNBIN          2  0       COLHDG('BIN')
     A            WTANK         13  5       COLHDG('UNIT PRICE')
     A            WCQTY         11  0       COLHDG('CUM QTY')
     A            WSHIN         12          COLHDG('IAF PART#')
     A            WBLNO         10          COLHDG('B/L #')
     A            WFILR         15          COLHDG('FILR')
     A          K WTOKU
     A          K WNONY
     A          K WNKOJ
     A          K WNUKE
     A          K WNOHZ
     A          K WINV#
     A          K WORDN
