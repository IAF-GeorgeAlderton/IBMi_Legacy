     A          R AM#WP45Z1                 TEXT('PALLET CSV WORKFILE')
     A            NAMC          20A         COLHDG('PLANT NAME')
     A            SUPPLIER       5A         COLHDG('SUPPLIER NAME')
     A            ORDER#        12A         COLHDG('ORDER NUMBER')
     A            DOCK_CD        2A         COLHDG('DOCK CODE')
     A            PALLET_CD      2A         COLHDG('PALLET CODE')
     A            CYCLE#         2A         COLHDG('CYCLE#')
     A            RECEIVED       3A         COLHDG('RECEIVED')
     A            DAMAGED        3A         COLHDG('DAMAGED')
     A            SUPPL_CD       5A         COLHDG('SUPPLIER CODE')
