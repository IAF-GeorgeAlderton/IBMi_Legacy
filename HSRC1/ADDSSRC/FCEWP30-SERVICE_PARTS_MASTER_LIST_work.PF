     A** FCEWP30 *******************************************
     A*  SERVICE PARTS MASTER LIST WORK                    *
     A*                                                    *
     A* TCHK1 05/07/09 CREATE(COPY FROM FCEPP30)           *
     A******************************************************
      *
     A          R FCEWP301                  TEXT('SERVICE PARTS M/F')
     A            F3GSKD         1          COLHDG('DELETE CODE')
     A            F3GSDT         8S 0       COLHDG('DELETE DUE DATE')
     A            F3GKDT         8S 0       COLHDG('UPDATE DATE')
     A            F3GTIM         6S 0       COLHDG('UPDATE TIME')
     A            F3GKNM        10          COLHDG('UPDATE NAME OF TEAM' -
     A                                             'MEMBER')
     A            F3BHB1         5          COLHDG('INTRAL COMPANY PART' -
     A                                             'NO 1')
     A            F3BHB2         5          COLHDG('2')
     A            F3BHB3         2          COLHDG('3')
     A            F3ZETI         4          COLHDG('ID NUMBER')
     A            F3KSYS         5P 0       COLHDG('OLD ACCOMMODATED' -
     A                                             'QUANTITY')
     A            F3SSYS         5P 0       COLHDG('NEW ACCOMMODATED' -
     A                                             'QUANTITY')
     A            F3SYMD         8S 0       COLHDG('ACCOMMODATED' -
     A                                             'QUANTITY CHANGE DATE')
     A            F3KTRK         1          COLHDG('OLD LOCATION CODE 1')
     A            F3KTRT         2          COLHDG('2')
     A            F3KTRR         2          COLHDG('3')
     A            F3KTRD         1          COLHDG('4')
     A            F3STRK         1          COLHDG('NEW LOCATION CODE 1')
     A            F3STRT         2          COLHDG('2')
     A            F3STRR         2          COLHDG('3')
     A            F3STRD         1          COLHDG('4')
     A            F3TYMD         8S 0       COLHDG('LOC CODE CHG DATE')
     A            F3KASI         7P 2       COLHDG('COMPLETION UNIT' -
     A                                             'WEIGHT')
     A            F3SMEI        15          COLHDG('PART NAME')
     A            F3DMEI        15          COLHDG('LARGE NAME')
     A            F3TEHI         1          COLHDG('PROD' 'ORDR FLG')
     A            F3FLG1         2          COLHDG('FLAG1')
     A            F3FLG2         2          COLHDG('FLAG2')
     A            F3FLG3         2          COLHDG('FLAG3')
     A            F3FLG4         2          COLHDG('FLAG4')
     A            F3FLG5         2          COLHDG('FLAG5')
     A            F3FILR        10          COLHDG('FILLER')
     A            F3PTRK         1          COLHDG('ORIGINAL LOC CODE 1')
     A            F3PTRT         2          COLHDG('2')
     A            F3PTRR         2          COLHDG('3')
     A            F3PTRD         1          COLHDG('4')
