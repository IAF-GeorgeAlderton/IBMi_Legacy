      ** ALFWP06 ***************************************
      * THE NUMBER OF PROCESSED BOXES BY WORKER LIST   *
      *     WASHER                                     *
      * TCHK1 10/19/10 CREATE(COPY FROM ALCWP06)       *
      *************************************** ALDCP06 **
     A          R ALFWP061                  TEXT('# OF BOXES BY WORKER')
     A            D6OPER         6A         COLHDG('WORKER CODE')
     A            D6NAME        20A         COLHDG('WORKER NAME')
     A            D6BOX          6S 0       COLHDG('# OF BOX')
     A*
     A          K D6OPER
