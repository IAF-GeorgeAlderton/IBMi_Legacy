     A** AB#WP2H **************************************
     A* WORK FILE FOR TRW-KOYO LABEL                  *
     A*                                               *
     A* TCH 2000.07.19                                *
      * TCH 2001/11/07  ADD SERIAL NUMBER FIELD
     A************************************** AB#WP2H **
      *
     A          R AB#WP2H1                  TEXT('W/F FOR TRW-KOYO LABEL')
     A            H2FLAG         1A         COLHDG('LABEL FLAG' -
     A                                             'M:MASTER' -
     A                                             'P:BOX' )
     A            H2PART        20A         COLHDG('PART NUMBER')
     A            H2QTY          5A         COLHDG('QTY')
     A            H2RAN#         7A         COLHDG('RAN NUMBER')
     A            H2SEQ#         9A         COLHDG('SERIAL NUMBER')
     A            H2REV          3A         COLHDG('REVISION LEBEL')
     A            H2PAGE         2A         COLHDG('PAGE')
     A            H2#PAG         2A         COLHDG('NUMBER OF PAGE')
     A            H2PNAM        30A         COLHDG('PART NAME')
     A            H2LOC1         1A         COLHDG('LOCATION 1')
     A            H2LOC2         2A         COLHDG('LOCATION 2')
     A            H2LOC3         2A         COLHDG('LOCATION 3')
     A            H2LOC4         1A         COLHDG('LOCATION 4')
     A            H2DELY         4A         COLHDG('DELIVERY')
     A            H2FACT         1A         COLHDG('FACTORY')
     A            H2DOCK         4A         COLHDG('DOCK CODE')
     A            H2ZETI         4A         COLHDG('ABSOLUTE NUMBER')
     A            H2UNIT         5A         COLHDG('QTY / CONTAINERS')
