     A** IZAWP99 *****************************
     A* TEST SAKAKI ERIAL KANBAN MASTER FILE *
     A***************************** IZAPP01 **
      *
     A          R IZAWP991                  TEXT('FINISHED MATERIAL KANBAN+
     A                                            MASTER FILE-DOWNLOAD')
      *
     A            ZCKAKE         4S 0       COLHDG('SUPPLIER')
  2  A            ZCZAIS        15A         COLHDG('MATERIAL')
  3  A            ZCZAIK         5S 2       COLHDG('DTAMETER')
     A            ZCMKJR         8S 0       COLHDG('MONTHLY CONFIRMEDWHT')
     A            ZCTKJR         5S 0       COLHDG('WEIGHT OF A COIL')
     A            ZCKEIS         3S 2       COLHDG('KEISUU')
     A            ZCSLTM         3S 0       COLHDG('LEAD TIME')
     A            ZCLOTO         2S 0       COLHDG('LOT')
     A*
     A            ZCCHOS         3S 0       COLHDG('ADJUST')
     A            ZCKMAL         3S 0       COLHDG('ALL')
     A            ZCKMMN         3S 0       COLHDG('MIN')
     A            ZCKMMX         3S 0       COLHDG('MAX')
     A*
     A            ZCNEWK         3S 0       COLHDG('NEW KMAX')
     A*
