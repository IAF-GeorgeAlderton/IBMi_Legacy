     A** FCBPP01 ***********************
     A* SUPPLY RACK M/F PHYSICAL *
     A* C:Y.AOYAMA 1992.06.09 *
     A*********************** FCBPP01 **
     A          R FCBPP011                  TEXT('SUPPLY RACK M/F')
     A            R1SKJY         1A         COLHDG('DELETE CODE')
     A            R1SKYY         4S 0       COLHDG('DELETE DUE DATE YEAR')
     A            R1SKMM         2S 0       COLHDG('MONTH')
     A            R1SKDD         2S 0       COLHDG('DAY')
     A            R1KOYY         4S 0       COLHDG('UPDATE WORK DAY YEAR')
     A            R1KOMM         2S 0       COLHDG('MONTH')
     A            R1KODD         2S 0       COLHDG('DAY')
     A            R1KOHH         2S 0       COLHDG('UPDATE WORK TIME' -
     A                                             'TIME')
     A            R1KOSS         2S 0       COLHDG('MINUTES')
     A            R1KOME        10A         COLHDG('UPDATE NAME OF TEAM' -
     A                                             'MEMBER')
     A            R1NONY         4S 0       COLHDG('DELIVERY POINT')
     A            R1NKOJ         1A         COLHDG('FACTORY')
     A            R1UHN1         5A         COLHDG('USER PART NUMBER 1')
     A            R1UHN2         5A         COLHDG('2')
     A            R1UHN3         5A         COLHDG('3')
     A            R1UHN4         5A         COLHDG('4')
     A            R1SYOS         6S 0       COLHDG('RACKACCOMMODATED' -
     A                                             'QUANTITY')
     A            R1KIGU         2A         COLHDG('APPLIANCE')
     A            R1FZSU         4S 0       COLHDG('PACKING ACCOMMODATED' -
     A                                             'QUANTITY')
     A            R1SETT         2S 0       COLHDG('SET POSITION')
     A            R1BAN1         1A         COLHDG('RACK LOCATION' -
     A                                             'FACTORY')
     A            R1BAN2         2A         COLHDG('PASSAGE')
     A            R1BAN3         2A         COLHDG('LINE')
     A            R1BAN4         1A         COLHDG('STAIR')
     A            R1MAIS         2S 0       COLHDG('KANBAN NUMBER OF' -
     A                                             'SHEETS')
     A            R1STSU         7S 0       COLHDG('SETTING NUMBER')
