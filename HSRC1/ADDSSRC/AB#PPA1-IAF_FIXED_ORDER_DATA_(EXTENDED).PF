      *
ADD  A            BAPAL#         2S 0       COLHDG('PALLET SPLIT#')
ADD  A            BAPALT        10A         COLHDG('PALLET TYPE')
ADD  A            BAPLNT         5A         COLHDG('PLANT ID')
ADD  A            BAEDII         7A         COLHDG('EDI ID 850/862')
ADD  A            BASHCD        10A         COLHDG('SHIP TO CODE')
ADD  A            BAREVN         6A         COLHDG('DESIGN CHG LVL')
ADD  A            BACTTP        10A         COLHDG('CONTAINER TYPE')
ADD  A            BAORD#        15A         COLHDG('ORDER# 15')
