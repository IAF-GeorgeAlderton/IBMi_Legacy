     A            BAMHN4         5A         COLHDG('USER PARTS4')
     A            BASHN1         5A         COLHDG('INT PART1')
     A            BASHN2         5A         COLHDG('INT PART2')
     A            BASHN3         2A         COLHDG('INT PART3')
     A            BANOYY         4S 0       COLHDG('INVOICE YEAR')
     A            BANOMM         2S 0       COLHDG('INVOICE MONTH')
     A            BANODD         2S 0       COLHDG('INVOICE DAY')
     A            BANOTM         4S 0       COLHDG('INVOICE TIME')
     A            BAINVN        16A         COLHDG('INVOICE NO')
     A            BAODRN        10A         COLHDG('ORDER NO')
     A            BASRYO        10S 0       COLHDG('ORDER QTY')
     A            BASYOS         6S 0       COLHDG('Q/C')
     A            BATANK        11S 4       COLHDG('SALES UNIT PRICE')
     A            BAURYY         4S 0       COLHDG('BILLED YEAR')
     A            BAURMM         2S 0       COLHDG('BILLED MONTH')
     A            BAURDD         2S 0       COLHDG('BILLED DAY')
ADD  A            BAURTM         6S 0       COLHDG('BILLED TIME')
ADD  A            BAURME        10A         COLHDG('BILLED USER')
ADD  A            BAURPG        10A         COLHDG('BILLED PROGRAM')
     A            BACARD         4A         COLHDG('CARD')
     A            BARCOD         7S 0       COLHDG('RECORD NO')
     A            BAALFL         4A         COLHDG('LINE FEED')
     A            BANOBN         2S 0       COLHDG('BIN')
     A            BAUSYS         6S 0       COLHDG('USER Q/C')
     A            BAODER        10S 0       COLHDG('ORIGINAL QTY')
     A            BAHENK         1A         COLHDG('CHANGE REASON')
     A            BAJYKB         1A         COLHDG('ORDER TYPE')
     A            BAEDIK         1A         COLHDG('ORDER ENTRY TYPE')
      **                         E=EDI, M=MANUAL, S=EXCEL SHEET, I=IFS.CSV
     A            BARESE         4A         COLHDG('RESERVE LOCATION')
