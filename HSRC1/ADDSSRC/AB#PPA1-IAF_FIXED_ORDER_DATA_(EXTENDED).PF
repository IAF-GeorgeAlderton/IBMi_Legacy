ADD  A            BASKTM         6S 0       COLHDG('DLT TIME')
ADD  A            BASKME        10A         COLHDG('DLT USER')
ADD  A            BASKPG        10A         COLHDG('DLT PROGRAM')
     A            BAKOYY         4S 0       COLHDG('UPD YEAR')
     A            BAKOMM         2S 0       COLHDG('UPD MONTH')
     A            BAKODD         2S 0       COLHDG('UPD DAY')
