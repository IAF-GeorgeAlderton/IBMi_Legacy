     A** ASNPP10 ************************************
     A*  UNIVERSAL ASN - BARCODE ENTRY DATA (WORK)  *
     A*  JW      2022.12.07                         *
     A***********************************************
     A          R ASNPP101                  TEXT('BARCODE ENTRY DATA')
     A            P1NONY         4S 0       COLHDG('DELIV#')
     A            P1NKOJ         1A         COLHDG('FACTORY')
     A            P1KUKE         4A         COLHDG('DOCK')
     A            P1NOHZ         8S 0       COLHDG('SHIP DATE')
     A            P1NOBN         2S 0       COLHDG('BIN#')
     A            P1ODRN        10A         COLHDG('ORDER#')
     A            P1WEIG         5S 2       COLHDG('CONT WGT')
     A            P1NOTM         4B 0       COLHDG('SHIP TIME')
     A            P1RISU         1A         COLHDG('RECREATE=1')
     A            P1SERL         9A         COLHDG('PACKING LIST#')
     A            P1SLI#        10A         COLHDG('SLI#')
      *
     C            P1CRHZ         8S 0       COLHDG('CRT DATE')
     C            P1CRTM         6S 0       COLHDG('CRT TIME')
     C            P1CRUS        10A         COLHDG('CRT USER')
     C            P1CRWS        10A         COLHDG('CRT WSID')
      *
     A          K P1SERL
