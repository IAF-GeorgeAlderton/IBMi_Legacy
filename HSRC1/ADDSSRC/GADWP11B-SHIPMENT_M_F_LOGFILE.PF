     A**GADPP11****************************************
     A*        SHIPMENT M/F        PHYSICAL   *.
     A*             H.ITO         S.86.06.18          *
     A************************************** GADPP11 **
     A          R GADWP111                  TEXT('SHIPMENT M/F PHYSICAL')
     A            WWTOKU         4S 0       COLHDG('CUSTOMER CODE')
     A            WWNONY         4S 0       COLHDG('DELIVERY POINT CODE')
     A            WWNKOJ         1          COLHDG('FACTORY CODE')
     A            WWKMEI        15          COLHDG('FACTORY NAME (KANA)')
     A            WWNUKE         4          COLHDG('RECEIVING')
     A            WWTRAN         1          COLHDG('TRANSACTION')
     A            WWDATE         8  0       COLHDG('DATE')
     A            WWTIME         6  0       COLHDG('TIME')
     A            WWPRNT         1          COLHDG('PRINT')
     A          K WWDATE
     A          K WWTOKU
     A          K WWNONY
     A          K WWNKOJ
     A          K WWNUKE
     A          K WWTIME
