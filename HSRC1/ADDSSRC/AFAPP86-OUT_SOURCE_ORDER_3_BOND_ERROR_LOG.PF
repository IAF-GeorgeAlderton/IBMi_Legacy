      ** AFAPP86 ***************************************
      * OUT-SOURCE ORDER 3-BOND  ERROR LOGOG           *
      * FILE-NAME.       :  AFAPP86    <PFILE>         *
      * CREATE DATE.     :  DEC/12/2017.               *
      * AUTHOR.          :  LEC                        *
      *                                                *
      *                                                *
      *************************************** AFAPP86 **
     A          R AFAPP861                  TEXT('OUT-SOURCE ORDER ERROR LOG')
     A            A6KSDT         8  0       COLHDG('UPDATE DATE')
     A            A6KSTM         6  0       COLHDG('UPDATE TIME')
     A            A6OPER         6A         COLHDG('OPERATOR ID')
     A            A6EMSG        15A         COLHDG('ERROR ID')
     A            A6ERPS         2A         COLHDG('ERROR SCREEN')
     A            A6BRC1        15A         COLHDG('BARCODE')
     A            A6ZETI         4A         COLHDG('ABSOLUTE ID')
     A            A6KASI         7P 2       COLHDG('COMPLETION UNIT' -
     A                                             'WEIGHT')
     A            A6BHB1         5A         COLHDG('PART#1')
     A            A6BHB2         5A         COLHDG('PART#2')
     A            A6BHB3         2A         COLHDG('PART#3')
     A            A6ATOB         4A         COLHDG('SUPPLIER')
     A            A6LTNO         8A         COLHDG('BARCODE 2 - LOTID')
     A            A6FIL1        10A         COLHDG('FILLER#1')
     A            A6FIL2        20A         COLHDG('FILLER#2')
     A            A6FIL3        30A         COLHDG('FILLER#3')
