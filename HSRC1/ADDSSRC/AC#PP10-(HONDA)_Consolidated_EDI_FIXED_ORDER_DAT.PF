     A            BCSIRE        10A         COLHDG('SUPPLIER CODE')
     A            BCSIRK         1A         COLHDG('FACTORY CODE')
     A            BCTOKU         4S 0       COLHDG('CUSTOMER CODE')
     A            BCNONY         4S 0       COLHDG('DELIVERY CODE')
     A            BCNKOJ         1A         COLHDG('DELIVERY FACTORY')
     A            BCNUKE         4A         COLHDG('DELIVERY DOCK')
