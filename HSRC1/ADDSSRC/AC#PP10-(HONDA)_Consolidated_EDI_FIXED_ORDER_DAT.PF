     A            BCUSYS         6S 0       COLHDG('USER PACK CAPACITY')
     A            BCODER        10S 0       COLHDG('# OF ORDERS')
     A            BCHENK         1A         COLHDG('CHANGE REASON')
     A            BCJYKB         1A         COLHDG('ORDER TYPE')
     A            BCEDIK         1A         COLHDG('EDI ID')
     A            BCRESE         4A         COLHDG('RESERVE LOCATION')
     A            BCDEYY         4S 0       COLHDG('DELIVERY YEAR')
     A            BCDEMM         2S 0       COLHDG('DELIVERY MONTH')
     A            BCDEDD         2S 0       COLHDG('DELIVERY DAY')
     A            BCPGID        12A         COLHDG('FORD PGM ID')
