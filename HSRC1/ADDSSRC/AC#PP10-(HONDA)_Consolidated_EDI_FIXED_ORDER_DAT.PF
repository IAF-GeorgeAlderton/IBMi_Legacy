     A            BCSHN2         5A         COLHDG('INT PART2')
     A            BCSHN3         2A         COLHDG('INT PART3')
     A            BCNOYY         4S 0       COLHDG('INVOICE YEAR')
     A            BCNOMM         2S 0       COLHDG('INVOICE MONTH')
     A            BCNODD         2S 0       COLHDG('INVOICE DAY')
     A            BCNOTM         4S 0       COLHDG('INVOICE TIME')
     A            BCINVN        16A         COLHDG('INVOICE NO')
     A            BCODRN        10A         COLHDG('ORDER NO')
     A            BCSRYO        10S 0       COLHDG('DELIVERY QTY')
     A            BCSYOS         6S 0       COLHDG('PACKAGE CAPACITY')
     A            BCTANK        11S 4       COLHDG('SALES UNIT PRICE')
     A            BCURYY         4S 0       COLHDG('BILLED YEAR')
     A            BCURMM         2S 0       COLHDG('BILLED MONTH')
     A            BCURDD         2S 0       COLHDG('BILLED DAY')
