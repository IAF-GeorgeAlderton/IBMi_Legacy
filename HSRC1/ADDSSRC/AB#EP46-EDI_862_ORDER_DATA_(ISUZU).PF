     A            E6HEDT         8S 0       COLHDG('HORIZON END')
     A            E6STIQ         2          COLHDG('SHIP TO QUAL')
     A            E6STID         5          COLHDG('SHIP TO ID')
     A            E6IDCD         5          COLHDG('NAME 01 ID')
     A            E6PART        40          COLHDG('BUYER PART #ITEM')
     A            E6DOCK         4          COLHDG('DOCK CODE')
     A            E6ALFL        10          COLHDG('ASSY LINE FEED')
     A            E6RALF        10          COLHDG('RESERVE ASSY LF')
     A            E6UBM1         2          COLHDG('UNIT MEASURE')
     A            E6PKCD         5          COLHDG('PACKAGING CODE')
     A            E6QTY1         7S 0       COLHDG('QUANTITY')
     A            E6WEIT        10S 0       COLHDG('WEIGHT')
     A            E6UBM2         2          COLHDG('WGT U/M')
     A            E6EQMT        10          COLHDG('EQUIPMENT#')
     A            E6QTY2        10S 0       COLHDG('QUANTITY')
     A            E6DLDT         8S 0       COLHDG('DELIVERY DATE')
      *
     A            E6TIME         6S 0       COLHDG('CREATE TIME')
     A            E6DATE         8S 0       COLHDG('CREATE DATE')
     A            E6IPAR        20          COLHDG('NO BLANK PART')
      *
     A            E6LRDT         6S 0       COLHDG('LAST RECEIVED DATE')
