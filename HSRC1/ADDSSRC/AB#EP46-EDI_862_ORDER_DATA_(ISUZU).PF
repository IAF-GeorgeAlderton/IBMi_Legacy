     A            E6LSDT         8S 0       COLHDG('LAST SHIPPED DATE')
     A            E6LSQY        10S 0       COLHDG('LAST SHIPPED QTY')
     A            E6YRDT         8S 0       COLHDG('YTD CUM RECIVED DATE')
