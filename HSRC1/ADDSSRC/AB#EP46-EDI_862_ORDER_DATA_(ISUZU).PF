ADD  A            E6STSC         1          COLHDG('STATUS CODE')
ADD  A            E6DLTM         4S 0       COLHDG('DELIVERY TIME')
ADD  A            E6USYS         6S 0       COLHDG('USER QPC')
ADD  A            E6INVN        16          COLHDG('INVOICE#')
ADD  A            E6FIL1        20          COLHDG('FILLER1')
ADD  A            E6FIL2        20          COLHDG('FILLER2')
      *
     A          K E6DATE
