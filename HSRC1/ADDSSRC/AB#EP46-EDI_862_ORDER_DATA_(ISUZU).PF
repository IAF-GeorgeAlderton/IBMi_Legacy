     A            E6PONO        10          COLHDG('ORDER#')
     A            E6STFC         5          COLHDG('STORAGE')
      *
ADD  A            E6TOKU         4S 0       COLHDG('CUSTOMER#')
ADD  A            E6NONY         4S 0       COLHDG('DELIVERY#')
ADD  A            E6EDIT         3          COLHDG('EDI TYPE')
ADD  A            E6N1SF        10          COLHDG('N1-SF')
ADD  A            E6N1ST        10          COLHDG('N1-ST')
ADD  A            E6N1SU        25          COLHDG('N1-SU')
ADD  A            E6N1MI        10          COLHDG('N1-MI')
