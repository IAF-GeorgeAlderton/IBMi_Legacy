     A** AAAPP21 *********************************
     A*          UNIT PRICE FORM CONVERSION M/F *
     A* C:N.HAYAKAWA                87.04.10     *
     A********************************************
     A          R AAAPP211                  TEXT('UNIT PRICE FORM CONVERSION +
     A                                            M/F')
     A            DHSKJY         1          COLHDG('DELETE CODE')
     A            DHSKYY         4S 0       COLHDG('DELETE DUE DATE YEAR')
     A            DHSKMM         2S 0       COLHDG('MONTH')
     A            DHSKDD         2S 0       COLHDG('DAY')
     A            DHKOYY         4S 0       COLHDG('UPDATE WORK DAY YEAR')
     A            DHKOMM         2S 0       COLHDG('MONTH')
     A            DHKODD         2S 0       COLHDG('DAY')
     A            DHKOHH         2S 0       COLHDG('UPDATE WORK TIME')
     A            DHKOSS         2S 0       COLHDG('MINUTES')
     A            DHKOME        10          COLHDG('NAME OF TEAM MEMBER' -
     A                                             'WHO UPDATED')
     A            DHTOKU         4S 0       COLHDG('CUSTOMER CODE')
     A            DHNONY         4S 0       COLHDG('RECEIVING CO. CODE')
     A            DHNKOJ         1          COLHDG('RECEIVING CO.' -
     A                                             'FACTORY')
     A            DHNUKE         4          COLHDG('RECEIVING CO.' -
     A                                             'RECEIVING')
     A            DHTTAI         1          COLHDG('UNIT PRICE FORM')
