     A            EKLTNO         3          COLHDG('LOT#')
     A            EKISNO         3          COLHDG('ISSUE#')
      *
     A            EKODRN        10A         COLHDG('ORDER NO')
     A            EKSHN1         5A         COLHDG('IAF PART1')
     A            EKSHN2         5A         COLHDG('IAF PART2')
     A            EKSHN3         2A         COLHDG('IAF PART3')
     A            EKNOYY         4  0       COLHDG('INVOICE YY')
     A            EKNOMM         2  0       COLHDG('INVOICE MM')
     A            EKNODD         2  0       COLHDG('INVOICE DD')
     A            EKDEYY         4  0       COLHDG('DELV YY')
     A            EKDEMM         2  0       COLHDG('DELV MM')
     A            EKDEDD         2  0       COLHDG('DELV DD')
     A            EKDETM         6  0       COLHDG('DELV TIME')
     A            EKSRYO        10  0       COLHDG('SHIP QTY')
     A            EKTOKU         4  0       COLHDG('CUST#')
     A            EKNOBN         2          COLHDG('BIN')
     A            EKMHN1         5          COLHDG('CUST PART1')
     A            EKMHN2         5          COLHDG('CUST PART2')
     A            EKMHN3         5          COLHDG('CUST PART3')
     A            EKMHN4         5          COLHDG('CUST PART4')
     A            EKRLYY         4  0       COLHDG('RLS YY')
     A            EKRLMM         2  0       COLHDG('RLS MM')
     A            EKRLDD         2  0       COLHDG('RLS DD')
      * ADDED
     A            EKCRHZ         8  0       COLHDG('CRT DATE')
     A            EKCRTM         6  0       COLHDG('CRT TIME')
     A            EKCRUS        10          COLHDG('CRT USER')
     A            EKCRPG        10          COLHDG('CRT PGM ')
     A            EKCRWS        10          COLHDG('CRT WSID')
     A            EKUPHZ         8  0       COLHDG('UPD DATE')
     A            EKUPTM         6  0       COLHDG('UPD TIME')
     A            EKUPUS        10          COLHDG('UPD USER')
     A            EKUPPG        10          COLHDG('UPD PGM ')
