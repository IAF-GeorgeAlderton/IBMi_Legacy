     A            EKHENK         1A         COLHDG('UPD REASON')
     A            EKNONY         4A         COLHDG('DELIV#')
     A            EKNKOJ         1A         COLHDG('FACTORY')
     A            EKNUKE         4A         COLHDG('DOCK')
     A            EKZETI         4A         COLHDG('ABSOLUTE')
     A            EKSYOS         5A         COLHDG('QPC')
     A            EKLOC1         1A         COLHDG('LOC 1')
     A            EKLOC2         2A         COLHDG('LOC 2')
     A            EKLOC3         2A         COLHDG('LOC 3')
     A            EKLOC4         1A         COLHDG('LOC 4')
