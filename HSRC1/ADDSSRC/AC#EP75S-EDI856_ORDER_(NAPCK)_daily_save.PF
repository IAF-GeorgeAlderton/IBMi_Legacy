     A**AC#EP75S **************************************
     A* EDI856 ORDER  (NAPCK) DAILY SAVE              *
     A*************************************************
     A          R AC#E75S1                  TEXT('FOR EDI856')
     A            E2FILE         8          COLHDG('FILE NAME')
     A            E2SHID        10          COLHDG('SHIPMENT NO.')
     A            E2PRTN        10          COLHDG('PARTNER ID')
     A            E2MAN#        20          COLHDG('MANIFEST#')
     A            E2BLN#        20          COLHDG('B/L#')
     A            E2INVN        16          COLHDG('INVOICE#')
     A            E2ORDN        10          COLHDG('ORDER#')
     A            E2SUPL        10          COLHDG('SUPPLIER CODE')
      *
ADD  A            E2CRDT         8S 0       COLHDG('CREATE DATE')
ADD  A            E2CRTM         6S 0       COLHDG('CREATE TIME')
ADD  A            E2CRPG        10          COLHDG('CREATE PGM ')
ADD  A            E2CRUS        10          COLHDG('CREATE USER')
ADD  A            E2CRWS        10          COLHDG('CREATE WSID')
      *
     A          K E2SHID
     A          K E2ORDN
