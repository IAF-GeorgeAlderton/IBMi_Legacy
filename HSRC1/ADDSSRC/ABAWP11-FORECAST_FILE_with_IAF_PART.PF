     A** ABAWP11 **************************************
     A*  EDI FORECAST DATA                         .  *
     A*************************************************
      *
     A          R ABAWP111                  TEXT('EDI FORECAST DATA')
     A            A1TOKU         4  0       COLHDG('CUSTOMER#')
     A            A1NONY         4  0       COLHDG('DELIVERY#')
     A            A1NKOJ         1          COLHDG('FACTORY')
     A            A1NUKE         4          COLHDG('DOCK')
     A            A1MHN1         5          COLHDG('USER PART 1')
     A            A1MHN2         5          COLHDG('USER PART 2')
     A            A1MHN3         5          COLHDG('USER PART 3')
     A            A1MHN4         5          COLHDG('USER PART 4')
     A            A1DATE         6  0       COLHDG('SHIP YYMM')
     A            A1NNSU         9  0       COLHDG('MONTHLY QTY')
     A            A1SHN1         5          COLHDG('IAF PART 1')
     A            A1SHN2         5          COLHDG('IAF PART 2')
     A            A1SHN3         2          COLHDG('IAF PART 3')
      *
     A          K A1SHN1
     A          K A1SHN2
     A          K A1SHN3
     A          K A1DATE
     A          K A1TOKU
     A          K A1NONY
     A          K A1NKOJ
     A          K A1NUKE
