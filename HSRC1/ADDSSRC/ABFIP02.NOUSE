     A************************************************** ABF2P01 ****
     A          R ABFIP021                  TEXT('EDI FORD W/F 1PROCESS')
     A            AIDLTD         8S 0       COLHDG('DELETE DATE')
     A            AIDLTT         6S 0       COLHDG('DELETE TIME')
     A            AITPCD        15          COLHDG('TRADING PARTNER CODE')
     A            AITSID         3          COLHDG('TRANSACTION SET ID')
     A            AISPCD         2          COLHDG('TRANSACTION SET' -
     A                                             'PURPOSE CODE')
     A            AIREF#        10          COLHDG('SENDER REFERENCE' -
     A                                             'NUMBER')
     A            AIPOR#         6          COLHDG('FORD PROGRAM' -
     A                                             'NUMBER')
     A            AISIDT         8S 0       COLHDG('SCHEDULE ISSUE DATE')
     A            AIHSDT         8S 0       COLHDG('DATE HORIZON START' -
     A                                             'YYYYMMDD')
     A            AIHEDT         8S 0       COLHDG('DATE HORIZON END' -
     A                                             'YYYYMMDD')
     A            AISTIQ         2          COLHDG('SHIP TO ID CODE' -
     A                                             'QUALIFIER')
     A            AISTID         5          COLHDG('SHIP TO ID CODE')
     A            AIIDCD         5          COLHDG('NAME 01 ID CODE')
     A            AIPART        40          COLHDG('BUYER PART #ITEM')
     A            AIDOCK         4          COLHDG('DOCK NUMBER')
     A            AIALFL        10          COLHDG('ASSEMBLY LINE FEED' -
     A                                             'LOCATION')
     A            AIRALF        10          COLHDG('RESERVE ASSEMBLY' -
     A                                             'LINE FEED LOCATION')
     A            AIUBM1         2          COLHDG('UNIT OF BASIS FOR' -
     A                                             'MEASURERMENT CODE')
     A            AIPKCD         5          COLHDG('PACKAGING CODE')
     A            AIQTY1         7S 0       COLHDG('QUANTITY')
     A            AIWEIT        10S 0       COLHDG('WEIGHT')
     A            AIUBM2         2          COLHDG('UNIT OF BASIS FOR' -
     A                                             'MEASURERMENT CODE')
     A            AIEQMT        10          COLHDG('EQUIPMENT NUMBER')
     A            AIQTY2        10S 0       COLHDG('QUANTITY')
     A            AIDLDT         8S 0       COLHDG('DELIVERY DATE')
      *
     A            AITIME         6S 0       COLHDG('CREATE TIME')
     A            AIDATE         6S 0       COLHDG('CREATE DATE')
     A            AIIPAR        20          COLHDG('NO BLANK PART')
      *
     A            AILRDT         6S 0       COLHDG('LAST RECEIVED DATE')
     A            AILRQY        10S 0       COLHDG('LAST RECEIVED QTY')
     A            AILSDT         6S 0       COLHDG('LAST SHIPPED DATE')
     A            AILSQY        10S 0       COLHDG('LAST SHIPPED QTY')
     A            AIYRDT         6S 0       COLHDG('YTD CUM RECIVED DATE')
     A            AIYRQY        10S 0       COLHDG('YTD CUM RECIVED QTY')
     A            AIYSDT         6S 0       COLHDG('YTD CUM SHIPPED DATE')
     A            AIYSQY        10S 0       COLHDG('YTD CUM SHIPPED QTY')
     A            AIEXCD         4          COLHDG('CONTACT CODE'-
     A                                             '(EXPEDITER)')
     A            AIRDCD         4          COLHDG('CONTACT CODE'-
     A                                             '(RECEIVING DOCK)')
