     A** FGBPP01 ***********************************************
     A* CUSTOMER MASTER                                        *
     A*               M-OKUDA 1985.03.26                       *
     A**********************************************************
     A          R FGBPP011
     A            B2SKJY         1A         COLHDG('DELETE CODE D')
     A            B2SKYY         4S 0       COLHDG('DELETE DATE YEAR')
     A            B2SKMM         2S 0       COLHDG('DELETE DATE MONTH')
     A            B2SKDD         2S 0       COLHDG('DELETE DATE DAY')
     A            B2KOYY         4S 0       COLHDG('UPDATE DATE YEAR')
     A            B2KOMM         2S 0       COLHDG('UPDATE DATE MONTH')
     A            B2KODD         2S 0       COLHDG('UPDATE DATE DAY')
     A            B2KOJI         2S 0       COLHDG('UPDATE TIME TIME')
     A            B2KOPN         2S 0       COLHDG('UPDATE TIME MINUTES')
     A            B2KOME        10A         COLHDG('UPDATE PERSON')
     A            B2CODE         4S 0       COLHDG('DETAIL CODE')
     A            B2SMEI        15A         COLHDG('DETAIL NAME KANA')
     A            B2ONCD         1A         COLHDG('SOUND INSTRUCTION')
     A            B2TORI         1A         COLHDG('BUSINESS CONTENTS')
     A            B2GRUP         1A         COLHDG('TRANSACTION FORM')
     A            B2GYOS         2A         COLHDG('TYPE OF INDUSTRY')
     A            B2TKEN         1A         COLHDG('CLASSIFICATION 1')
     A            B2TIHO         2A         COLHDG('CLASSIFICATION 2')
     A            B2KEMI        16O         COLHDG('DETAIL NAME KANJI')
     A            B2ME18        18O         COLHDG('ONLY DETAIL NAME' -
     A                                             'KANJI  ')
