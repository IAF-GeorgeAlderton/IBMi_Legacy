     A***********************************************
     A* PLATING BUYING ON CREDIT UNIT PRICE M/F (PHYSICAL ) AASPP11
     A***********************************************
     A          R AASPP111
     A            CRSKJY         1          COLHDG('DELETE CODE D')
     A            CRSKYY         4S 0       COLHDG('DELETE DUE DATE' -
     A                                             '(YEAR)')
     A            CRSKMM         2S 0       COLHDG('DELETE DUE DATE' -
     A                                             'MONTH  ')
     A            CRSKDD         2S 0       COLHDG('DELETE DUE DATE DAY' -
     A                                             ' ')
     A            CRKOYY         4S 0       COLHDG('UPDATE WORK DATE' -
     A                                             '(YEAR)')
     A            CRKOMM         2S 0       COLHDG('UPDATE WORK DATE' -
     A                                             'MONTH  ')
     A            CRKODD         2S 0       COLHDG('UPDATE WORK DATE DAY' -
     A                                             ' ')
     A            CRKOHH         2S 0       COLHDG('UPDATE WORK DATE  ' -
     A                                             ' ')
     A            CRKOSS         2S 0       COLHDG('UPDATE WORK DATE' -
     A                                             '(MINUTES)')
     A            CRKOME        10          COLHDG('UPDATE WORK PROFILE')
     A            CRKACD         4S 0       COLHDG('PROCESSING POINT' -
     A                                             'CODE')
     A            CRHIN1         5          COLHDG('PART NUMBER 1')
     A            CRHIN2         5          COLHDG('PART NUMBER 2')
     A            CRHIN3         2          COLHDG('PART NUMBER 3')
     A            CRSYR1         4          COLHDG('SURFACE TREATMENT' -
     A                                             'CODE 1')
     A            CRSYR2         2          COLHDG('SURFACE TREATMENT' -
     A                                             'CODE 2')
     A            CRSYR3         1          COLHDG('SURFACE TREATMENT' -
     A                                             'CODE 3')
     A            CRTANJ         7S 3       COLHDG('UNIT WEIGHT 1')
     A            CRTANI         1          COLHDG('UNIT OF UNIT WEIGHT')
     A            CRMTNO         7S 3       COLHDG('PLATING UNIT PRICE' -
     A                                             '(OLD)')
     A            CRMTKO         1          COLHDG('PLATING UNIT PRICE' -
     A                                             'INSTRUCTION (OLD)')
     A            CRMTNN         7S 3       COLHDG('PLATING UNIT PRICE' -
     A                                             '(NEW)')
     A            CRMTKN         1          COLHDG('PLATING UNIT PRICE' -
     A                                             'INSTRUCTION (NEW)')
     A            CRMKYY         4S 0       COLHDG('NEW UNIT PRICE' -
     A                                             'CHANGE DATE (YEAR)')
     A            CRMKMM         2S 0       COLHDG('NEW UNIT PRICE' -
     A                                             'CHANGE DATE MONTH  ')
     A            CRMKDD         2S 0       COLHDG('NEW UNIT PRICE' -
     A                                             'CHANGE DATE DAY  ')
     A            CRMHSO         5S 0       COLHDG('THE LOWEST GUARANTEE' -
     A                                             'NUMBER (OLD)')
     A            CRMHSN         5S 0       COLHDG('THE LOWEST GUARANTEE' -
     A                                             'NUMBER (NEW)')
     A            CRMHYY         4S 0       COLHDG('GUARANTEE CHANGE' -
     A                                             'DATE (YEAR)')
     A            CRMHMM         2S 0       COLHDG('GUARANTEE CHANGE' -
     A                                             'DATE MONTH  ')
     A            CRMHDD         2S 0       COLHDG('GUARANTEE CHANGE' -
     A                                             'DATE DAY  ')
     A            CR2TNO         7S 3       COLHDG('SECONDARY PROCESSING' -
     A                                             'UNIT PRICE OLD')
     A            CR2TKO         1          COLHDG('UNIT PRICE' -
     A                                             'INSTRUCTION OLD')
     A            CR2TNN         7S 3       COLHDG('SECONDARY PROCESSING' -
     A                                             'UNIT PRICE NEW')
     A            CR2TKN         1          COLHDG('UNIT PRICE' -
     A                                             'INSTRUCTION NEW')
     A            CR2KYY         4S 0       COLHDG('NEW UNIT PRICE' -
     A                                             'CHANGE DATE (YEAR)')
     A            CR2KMM         2S 0       COLHDG('NEW UNIT PRICE' -
     A                                             'CHANGE DATE MONTH  ')
     A            CR2KDD         2S 0       COLHDG('NEW UNIT PRICE' -
     A                                             'CHANGE DATE DAY  ')
