     A**AE#WP01C **************************************
     A* CONTAINER LABEL FOR TB ADIENT (3324)          *
     A* JW    2022.03.15                              *
     A*************************************************
     A          R AE#WP1C1                  TEXT('CONTAINER LABEL')
      * CONTAINER
     A            C1TYPE        15A         COLHDG('LABEL TYPE')
     A            C1PART        20A         COLHDG('USER PART#')
     A            C1PNAM        30A         COLHDG('DESCRIPION')
     A            C1QTY          6A         COLHDG('QTY')
     A            C1SIRE         6A         COLHDG('SUPPLIER')
     A            C1SERL        20A         COLHDG('SERIAL#')
     A            C1SHDT         8A         COLHDG('SHIP DATE')
     A            C1CORG        15A         COLHDG('COUNTRY OF ORIGIN')
     A            C1LOT#        10A         COLHDG('LOT#')
     A            C1ECHG         8A         COLHDG('ENG CHANGE LEVEL')
     A            C1TAD1        50A         COLHDG('SHIP TO ADDR1')
     A            C1TAD2        50A         COLHDG('SHIP TO ADDR2')
     A            C1TAD3        50A         COLHDG('SHIP TO ADDR3')
     A            C1FAD1        50A         COLHDG('SHIP FROM ADDR1')
     A            C1FAD2        50A         COLHDG('SHIP FROM ADDR2')
     A            C1FAD3        50A         COLHDG('SHIP FROM ADDR3')
      * BANGTAIL
     A            C1REF1        20A         COLHDG('REF1')
     A            C1LOC          9A         COLHDG('LOCATION')
     A            C1NONY         4A         COLHDG('DELIVERY CODE')
     A            C1NKOJ         1A         COLHDG('FACTORY')
     A            C1NUKE         4A         COLHDG('DOCK')
     A            C1NOBN         2A         COLHDG('BIN')
     A            C1TOKU         4A         COLHDG('CUSTOMER CODE')
      * OTHER INFORMATION
     A            C1IPAR        15A         COLHDG('IAF PART#')
     A            C1ZETI         4A         COLHDG('ABSOLUTE')
     A            C1SYOS         6A         COLHDG('QPC')
     A            C1INVN        16A         COLHDG('INVOICE#')
     A            C1FL01        20A         COLHDG('FILLER 1')
     A            C1FL02        20A         COLHDG('FILLER 2')
     A            C1FL03        20A         COLHDG('FILLER 3')
     A            C1FL04        20A         COLHDG('FILLER 4')
     A            C1FL05        20A         COLHDG('FILLER 5')
      *
     A          K C1SERL
