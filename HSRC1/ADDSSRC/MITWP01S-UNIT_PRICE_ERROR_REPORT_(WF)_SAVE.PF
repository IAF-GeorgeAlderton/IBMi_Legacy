     A* MITWP01 ************************************************
     A* FILE NAME : UNIT PRICE ERROR REPORT (WF) - MITANKF     *
     A* CREATE    : J.WATANABE                                 *
     A**********************************************************
     A          R MITWP011                  TEXT('UNIT PRICE ERROR')
     A            W1TOKU         4S 0       COLHDG('CUST CODE  ')
     A            W1NONY         4S 0       COLHDG('DELIV CODE ')
     A            W1TKOJ         1          COLHDG('FACTORY    ')
     A            W1TUKE         4          COLHDG('DOCK       ')
     A            W1NKOJ         1          COLHDG('FACTORY    ')
     A            W1NUKE         4          COLHDG('DOCK       ')
     A            W1MHIN        20          COLHDG('USER PART  ')
     A            W1SHIN        12          COLHDG('IAF PART   ')
     A            W1ODNO        10          COLHDG('ORDER#     ')
ADD  A            W1INVN        16          COLHDG('INVOICE    ')
     A            W1EDNO         3S 0       COLHDG('EDI ID     ')
     A            W1NOHZ         8S 0       COLHDG('SHIP DATE  ')
ADD  A            W1BIN          2S 0       COLHDG('BIN#       ')
ADD  A            W1SRYO         7S 0       COLHDG('QTY        ')
ADD  A            W1TANK        11S 4       COLHDG('UNIT PRICE ')
     A            W1KING        11S 4       COLHDG('AMOUNT     ')
      * ADDED FIRLDS
     A            W1SERL         9          COLHDG('PACKING LST')
     A            W1MSG         30          COLHDG('ERROR MSG  ')
     A            W1CRHZ         8S 0       COLHDG('CRT DATE   ')
     A            W1CRTM         6S 0       COLHDG('CRT TIME   ')
     A            W1CRUS        10          COLHDG('CRT USER   ')
     A            W1CRPG        10          COLHDG('CRT PROGRAM')
     A            W1CRWS        10          COLHDG('CRT WSID   ')
     A            W1FIL1        20          COLHDG('FIL 1      ')
     A            W1FIL2        20          COLHDG('FIL 2      ')
