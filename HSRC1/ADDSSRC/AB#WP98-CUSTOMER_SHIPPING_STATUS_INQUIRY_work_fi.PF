     A** AB#WP98 *******************************************
     A*  CUST SHIPPING STATUS INQUIRY WORK FILE            *
     A*                                                    *
     A* TCHK1 02/02/07 CREATE                              *
     A******************************************************
      *
     A          R AB#WP981                  TEXT('CHECK SHEET')
     A*
     A            W8NOYY         4S 0       COLHDG('DELI YY')
     A            W8NOMM         2S 0       COLHDG('DELI MM')
     A            W8NODD         2S 0       COLHDG('DELI DD')
     A            W8BINN         2S 0       COLHDG('DELI BIN')
     A            W8CUST         4S 0       COLHDG('CUST')
     A            W8NONY         4S 0       COLHDG('DELI')
     A            W8NKOJ         1A         COLHDG('FACTORY')
     A            W8NUKE         4A         COLHDG('DOCK')
     A            W8SERL        10A         COLHDG('SERIAL#')
     A            W8ODRN        10A         COLHDG('ORDER#')
     A*
     A          K W8NOYY
     A          K W8NOMM
     A          K W8NODD
     A          K W8BINN
     A          K W8CUST
     A          K W8NONY
     A          K W8NKOJ
     A          K W8NUKE
     A          K W8SERL
     A          K W8ODRN
