     A*  ..DIE ALLOTMENT M/F ( AOYAMA-->IAF )..  */
     A*     I-HASADA                97.02.22     */
     A********************************* GCQWP31 **/
      *
     A          R GCQWP311                  TEXT('DIE ALLOTMENT M/F RECORD')
     A            IASKJY         1          COLHDG('DELETE CODE')
     A            IASKYY         4S 0       COLHDG('DELETE DUE DATE YEAR')
     A            IASKMM         2S 0       COLHDG('MONTH')
     A            IASKDD         2S 0       COLHDG('DAY')
     A            IAKOYY         4S 0       COLHDG('UPDATE WORK DAY YEAR')
     A            IAKOMM         2S 0       COLHDG('MONTH')
     A            IAKODD         2S 0       COLHDG('DAY')
     A            IAKOHH         2S 0       COLHDG('UPDATE WORK TIME  ')
     A            IAKOSS         2S 0       COLHDG('MINUTES')
     A            IAKOME        10          COLHDG('UPDATE NAME OF TEAM' -
     A                                             'MEMBER')
     A            IASHN1         5          COLHDG('INTRAL COMPANY PART' -
     A                                             'NO 1')
     A            IASHN2         5          COLHDG('2')
     A            IASHN3         2          COLHDG('3')
     A            IAKOTI         3          COLHDG('PROCESS')
     A            IAKSEI         2S 0       COLHDG('COMPONENTS NO.')
     A            IAKATA        15          COLHDG('DIE NO')
     A            IAKOSU         2S 0       COLHDG('NUMBER')
     A            IAKUBN         1          COLHDG('INSTRUCTION')
     A            IAKSKB         1          COLHDG('UPDATE INSTRUCTION')
     A            IAKTBN         1          COLHDG('DIE PARTS')
