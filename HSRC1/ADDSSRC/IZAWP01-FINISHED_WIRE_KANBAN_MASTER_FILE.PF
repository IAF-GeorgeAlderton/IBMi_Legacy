     A** IZAPP01 *****************************
     A* FINISHED MATERIAL KANBAN MASTER FILE *
     A* TCH76 05/06/24 DOWNLOAD FILE         *
     A***************************** IZAPP01 **
      *
     A          R IZAWP011                  TEXT('FINISHED MATERIAL KANBAN+
     A                                            MASTER FILE-DOWNLOAD')
      *
  1  A            ZCZIRO        20A         COLHDG('MATERIAL COLOR')
  2  A            ZCZAIS        15A         COLHDG('MATERIAL')
  3  A            ZCZAIK         5S 2       COLHDG('DTAMETER')
  4  A            ZCKNO1         1A         COLHDG('NUMBER PLANT')
  4  A            ZCKNO2         1A         COLHDG('NUMBER TYPE')
  4  A            ZCKNO3         4A         COLHDG('NUMBER ABS' -
     A                                             'NUMBER')
  4  A            ZCKNOE         1A         COLHDG('NUMBER BRANCH NUMBER')
  5  A            ZCADR1         1A         COLHDG('ADDRESS FOR FINISHED' -
     A                                             'MATERIAL')
  5  A            ZCADR2         2A         COLHDG('AISLE FOR FINISHED' -
     A                                             'MATERIAL')
  5  A            ZCADR3         2A         COLHDG('AISLE FOR FINISHED' -
     A                                             'MATERIAL')
  5  A            ZCADR4         1A         COLHDG('STEP FOR FINISHED' -
 TC  A                                             'MATERIAL')
  5  A            @DSJRP         7  0       COLHDG('MONTHLY SETTING  ')
     A            ZCTKJR         5S 0       COLHDG('WEIGHT OF A COIL')
     A            B2SMEX        15          COLHDG('SUPPLIER NAME   ')
