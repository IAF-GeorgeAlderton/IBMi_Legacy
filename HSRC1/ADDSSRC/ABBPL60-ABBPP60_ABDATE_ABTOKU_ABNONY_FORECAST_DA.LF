     A            ABSU09                    COLHDG('THE 9TH. DAY')
     A            ABSU10                    COLHDG('THE 10TH. DAY')
     A            ABSU11                    COLHDG('THE 11TH. DAY')
     A            ABSU12                    COLHDG('THE 12TH. DAY')
     A            ABSU13                    COLHDG('THE 13TH. DAY')
     A            ABSU14                    COLHDG('THE 14TH. DAY')
     A            ABSU15                    COLHDG('THE 15TH. DAY')
     A            ABSU16                    COLHDG('THE 16TH. DAY')
     A            ABSU17                    COLHDG('THE 17TH. DAY')
     A            ABSU18                    COLHDG('THE 18TH. DAY')
     A            ABSU19                    COLHDG('THE 19TH. DAY')
     A            ABSU20                    COLHDG('THE 20TH. DAY')
     A            ABSU21                    COLHDG('THE 21TH. DAY')
     A            ABSU22                    COLHDG('THE 22TH. DAY')
     A            ABSU23                    COLHDG('THE 23TH. DAY')
     A            ABSU24                    COLHDG('THE 24TH. DAY')
     A            ABSU25                    COLHDG('THE 25TH. DAY')
     A            ABSU26                    COLHDG('THE 26TH. DAY')
