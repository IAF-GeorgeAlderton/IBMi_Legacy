     A          R ABBPL601                  PFILE(ABBPP60)
     A                                      TEXT('FORECAST DATA INPUT')
     A            ABSKJY                    COLHDG('DELETE CODE')
     A            ABSKYY                    COLHDG('DELETE DUE DATE' -
     A                                             '(YEAR)')
     A            ABSKMM                    COLHDG('(MONDAY)')
     A            ABSKDD                    COLHDG('(SUNDAY )')
     A            ABKOYY                    COLHDG('UPDATE WORK DAY' -
     A                                             '(YEAR)')
     A            ABKOMM                    COLHDG('MONTH')
     A            ABKODD                    COLHDG('DAY')
     A            ABKOHH                    COLHDG('UPDATE WORK TIME')
     A            ABKOSS                    COLHDG('(MINUTES)')
     A            ABKOME                    COLHDG('NAME OF TEAM MEMBER' -
     A                                             'WHO UPDATED')
     A            ABTOKU                    COLHDG('CUSTOMER')
     A            ABNONY                    COLHDG('DELIVERY')
     A            ABNKOJ                    COLHDG('FACTORY')
     A            ABNUKE                    COLHDG('DOCK')
     A            ABSEBN                    COLHDG('IDENTIFICATION' -
     A                                             'NUMBER')
     A            ABMHN1                    COLHDG('USER PARTS NO 1')
     A            ABMHN2                    COLHDG('2')
     A            ABMHN3                    COLHDG('3')
     A            ABMHN4                    COLHDG('4')
     A            ABSHN1                    COLHDG('INTRAL COMPANY PART' -
     A                                             'NO 1')
     A            ABSHN2                    COLHDG('2')
     A            ABSHN3                    COLHDG('3')
     A            ABKUBN                    COLHDG('INPUT FORM')
     A            ABDATE                    COLHDG('FORECAST DATE YYMM')
      *
     A            ABDT11                    COLHDG('1 WEEK DATE MMDD')
     A            ABDT21                    COLHDG('1 WEEK DATE MMDD')
     A            ABNS01                    COLHDG('1 WEEK FORECAST QTY')
     A            ABWK01                    COLHDG('INCLUDING NEXT MONTH')
      *
     A            ABDT12                    COLHDG('2 WEEK DATE MMDD')
     A            ABDT22                    COLHDG('2 WEEK DATE MMDD')
     A            ABNS02                    COLHDG('2 WEEK FORECAST QTY')
     A            ABWK02                    COLHDG('INCLUDING NEXT MONTH')
      *
     A            ABDT13                    COLHDG('3 WEEK DATE MMDD')
     A            ABDT23                    COLHDG('3 WEEK DATE MMDD')
     A            ABNS03                    COLHDG('3 WEEK FORECAST QTY')
     A            ABWK03                    COLHDG('INCLUDING NEXT MONTH')
      *
     A            ABDT14                    COLHDG('4 WEEK DATE MMDD')
     A            ABDT24                    COLHDG('4 WEEK DATE MMDD')
     A            ABNS04                    COLHDG('4 WEEK FORECAST QTY')
     A            ABWK04                    COLHDG('INCLUDING NEXT MONTH')
      *
     A            ABDT15                    COLHDG('5 WEEK DATE MMDD')
     A            ABDT25                    COLHDG('5 WEEK DATE MMDD')
     A            ABNS05                    COLHDG('5 WEEK FORECAST QTY')
     A            ABWK05                    COLHDG('INCLUDING NEXT MONTH')
      *
     A            ABGEKN                    COLHDG('MONTHLY PRODUCT' -
     A                                             'DEMAND FORECAST QTY')
     A            ABWKSU                    COLHDG('QTY INCLUDING' -
     A                                             'NEXT MONTH')
      *
     A            ABSU01                    COLHDG('THE 1ST. DAY')
     A            ABSU02                    COLHDG('THE 2ND. DAY')
     A            ABSU03                    COLHDG('THE 3RD. DAY')
     A            ABSU04                    COLHDG('THE 4TH. DAY')
     A            ABSU05                    COLHDG('THE 5TH. DAY')
     A            ABSU06                    COLHDG('THE 6TH. DAY')
