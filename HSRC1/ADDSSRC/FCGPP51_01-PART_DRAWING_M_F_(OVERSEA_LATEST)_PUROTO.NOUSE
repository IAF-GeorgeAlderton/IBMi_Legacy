     A** FCGPP51 *****************************
     A*  PART DRAWING M/F (OVERSEA-LATEST) PUROTORA
     A*  ..  EDMICSより情報取得            *
     A*     A.INOUE           2005.05.23     *
     A***************************** FCGPP01 **
      *
     A          R FCGPP511                  TEXT('PART DRAWING M/F')
     A            E5SKJY         1          COLHDG('削除コード')
     A            E5SKYY         4S 0       COLHDG('削除予定日　年')
     A            E5SKMM         2S 0       COLHDG('　　　　　　月')
     A            E5SKDD         2S 0       COLHDG('　　　　　　日')
     A            E5KOYY         4S 0       COLHDG('更新作業日　年')
     A            E5KOMM         2S 0       COLHDG('　　　　　　月')
     A            E5KODD         2S 0       COLHDG('　　　　　　日')
     A            E5KOHH         2S 0       COLHDG('更新作業時刻　時')
     A            E5KOSS         2S 0       COLHDG('　　　　　　　分')
     A            E5KOME        10          COLHDG('更新作業者名')
     **
     A            E5SHN1         5A         COLHDG('社内品番1')
     A            E5SHN2         5A         COLHDG('社内品番2')
     A            E5SHN3         2A         COLHDG('社内品番3')
     **
     ******* ＥＤＭＩＣＳ図面照会情報 ****
     A            E5STAT        15A         COLHDG('図面承認状況')
     A            E5VERS         7S 0       COLHDG('最新図番')
     A            E5CABN        20A         COLHDG('保存gｫﾍﾞrｮnNO.')
     **
     A            E5DHNS         1A         COLHDG('代表品番有無')
     **                 0：なし   1 : あり
     A            E5DHN1         5A         COLHDG('代表品番1')
     A            E5DHN2         5A         COLHDG('代表品番2')
     A            E5DHN3         2A         COLHDG('代表品番3')
     **       図面を共有する場合は、図面登録されている品番を代表品番
     *
     ******* 製品図面情報 ****
     A            E5ZUSU         1A         COLHDG('図面種類')
     A            E5SIZE         4A         COLHDG('ネジサイズ')
     **
     A            E5SHP1         1A         COLHDG('形状１')
     A            E5SHP2         1A         COLHDG('形状２')
     A            E5SHP3         1A         COLHDG('形状３')
     A            E5SHP4         1A         COLHDG('形状４')
     A            E5SHP5         1A         COLHDG('形状５')
     A            E5SHP6         1A         COLHDG('形状６')
     **
     A            E5KUBI         8S 3       COLHDG('首下長さ')
     A            E5HYMN         5A         COLHDG('表面処理')
     A            E5KODO         5A         COLHDG('強度')
     A            E5ZAIS         5A         COLHDG('材質')
     A            E5NETU         5A         COLHDG('熱処理')
     A            E5HDSC         8S 3       COLHDG('頭部高さ')
     A            E52SDS         8S 3       COLHDG('２面巾')
     A            E5DVRP         6A         COLHDG('開発製品名')
     A            E5NJPT        20A         COLHDG('ねじピッチ')
     A            E5ZAGI         8S 3       COLHDG('座外径')
     A            E5ZAAT         8S 3       COLHDG('座厚み')
     A            E5JIKE         8S 3       COLHDG('軸径')
     A            E5JINA         8S 3       COLHDG('軸長さ')
     **
     A            E5ADDT         8S 0       COLHDG('作成日')
     A            E5ADTM         6S 0       COLHDG('作成時刻')
     A            E5CGDT         8S 0       COLHDG('変更日')
     A            E5CGTM         6S 0       COLHDG('変更時刻')
