     A** AFDPPOS ******************************************************
     A*  OUTSOURCE RACK STORE IN FILE                                 *
     A* LEC   11/22/2023  CREATE                                      *
     A*****************************************************************
     A          R AFDPPOS1                  TEXT('O/S RACK STORE IN')
     A            ARSKJY         1A         COLHDG('DELETE CODE D')
     A            ARSKDT         8S 0       COLHDG('DELETE DATE')
     A            ARSKTM         6S 0       COLHDG('DELETE TIME')
     A            ARSKWK        10A         COLHDG('DELETE WORKER CD')
     A            ARCODT         8S 0       COLHDG('SCAN DATE')
     A            ARCOTM         6S 0       COLHDG('SCAN TIME')
     A            ARCOWK        10A         COLHDG('SCAN WORKER CD')
     A            ARCOPG        10A         COLHDG('UPDATE PGM')
      *
     A* STORE IN LOCATION
     A            ARLBAR        20A         COLHDG('LOCATION BARCODE')
     A            ARLZET         4A         COLHDG('LOCATION PART ID')
     A            ARLOCN         4A         COLHDG('LOCATION')
      *
     A* STORE IN KANBAN
     A            ARPBAR        20A         COLHDG('BARCODE')
     A            ARPBQR       512A         COLHDG('QR')
     A            ARPZET         4A         COLHDG('ABSOLUTE #')
     A            ARPHN1         5A         COLHDG('PART NO1')
     A            ARPHN2         5A         COLHDG('PART NO2')
     A            ARPHN3         2A         COLHDG('PART NO3')
     A* LOT ID
     A            ARLTNO         8A         COLHDG('LOT ID')
      *
     A* BIN #
     A            ARBIN#         3A         COLHDG('BIN#')
      *
     A            AROKNG         2A         COLHDG('OK / NG')
     A            AREMSG        20A         COLHDG('ERROR MSG')
     A            ARLOBR        20A         COLHDG('ACTUAL LOC BARCD')
     A          K ARPBAR
