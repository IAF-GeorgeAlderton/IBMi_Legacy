     A* GDGPP06 **********************************************
     A* IAF IMPORT ORDER(SEIHIN) ORDER DATA FILE             *
     A* JW  2020.09.03                                       *
     A********************************************************
     A          R GDGPP061                  TEXT('ORDER DATA FILE')
     A            IASKJY         1          COLHDG('DLT FLAG')
     A            IASKDT         8S 0       COLHDG('DLT DATE')
     A            IAKODT         8S 0       COLHDG('UPD DATE')
     A            IAKOTM         6S 0       COLHDG('UPD TIME')
     A            IAKOME        10          COLHDG('UPD USER')
ADD  A            IAKOPG        10          COLHDG('UPD PGM')
     A            IAODER         6S 0       COLHDG('ORDER#')
     A            IAZETI         4          COLHDG('PART ID#')
     A            IASEIH         1          COLHDG('PART CODE')
     A            IARENB         4S 0       COLHDG('OUTPUT#')
     A            IACD           1          COLHDG('C/D')
     A            IAHIN1         5          COLHDG('IAF PART1')
     A            IAHIN2         5          COLHDG('IAF PART2')
     A            IAHIN3         2          COLHDG('IAF PART3')
     A            IASYOS         7P 0       COLHDG('QTY/BOX')
     A            IAMAIS         3P 0       COLHDG('BOX')
     A            IASYHZ         8S 0       COLHDG('TOTALIZATION DATE')
     A            IAHADT         8S 0       COLHDG('ORDER DATE')
      *
ADD  A            IAFLG1         1          COLHDG('FLAG1     ')
ADD  A            IAFLG2         1          COLHDG('FLAG2     ')
"    A            IAPFLG         1          COLHDG('P/T FLAG  ')
"    A            IAPDER         6          COLHDG('P/T ORDER#')
"    A            IAPOTN         4          COLHDG('P/T LOT#')
