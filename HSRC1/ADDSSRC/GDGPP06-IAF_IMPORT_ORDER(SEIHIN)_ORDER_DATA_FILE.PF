"    A            IAPBAR        20          COLHDG('P/T BAR CODE')
"    A            IAPBN1         1          COLHDG('P/T LOC1')
"    A            IAPBN2         2          COLHDG('P/T LOC2')
"    A            IAPBN3         2          COLHDG('P/T LOC3')
"    A            IAPBN4         1          COLHDG('P/T LOC4')
