     A** ECNTP15 ********************************************
     A* ... INTRA-PROCESS NON-CONFORMING PRODUCT MATERIALS ACCUMULATION DATA ...
     A* WORKFILE *
     A*          I-HASADA                 87.04.01          *
     A******************************************** ECNTP15 **
     A          R ECNTP151                  TEXT('INTRA-PROCESS NON-CONFORMING+
     A                                       PRODUCT MATERIALS ACCUMULATION +
     A                                      DATA ..WORKFILE ..')
     A            N2HAYY         4S 0       TEXT('OUTBREAK DATE YY')
     A            N2HAMM         2S 0       TEXT('MM')
     A            N2HADD         2S 0       TEXT('DD')
     A            N2TINO         3S 0       TEXT('LIST NO.')
     A            N2KINO         5          TEXT('MACHINE NO.')
     A            N2BUBU         2S 0       TEXT('DEPARTMENT DEPARTMENT')
     A            N2BUKA         2S 0       TEXT('SECTION')
     A            N2BURI         1S 0       TEXT('TEAM')
     A            N2BUHN         1S 0       TEXT('GROUP')
     A            N2HIYO         1          TEXT('DAYTIME -H.NIGHTTIME -Y')
     A            N2FURY         3S 0       TEXT('NON-CONFORMING PRODUCT CONTE+
     A                                      NTS NO.')
     A            N2FUSU         5S 0       TEXT('NON-CONFORMING PRODUCT NUMBE+
     A                                      R')
     A            N2FUGI         6S 3       TEXT('WEIGHT')
     A            N2HIB1         5          TEXT('PART NUMBER 1')
     A            N2HIB2         5          TEXT('2')
     A            N2HIB3         2          TEXT('3')
     A            N2SINO         4S 0       TEXT('POST NO.')
     A            N2BUCD         2          TEXT('DEPARTMENT INSTRUCTION')
     A          K N2BUBU
     A          K N2BUKA
     A          K N2KINO
     A          K N2FURY
     A          K N2FUGI
