     A            Z1STMM         2S         COLHDG('        月')
     A            Z1STDD         2S         COLHDG('        日')
     A            Z1SBIN         2S         COLHDG('        便')
      *
     A            Z1MAXH         4S 0       COLHDG('安全在庫数')
     A            Z1KAIH         3S 0       COLHDG('海外分')
     A            Z1SINH         3S 0       COLHDG('新設品')
     A            Z1DUPH         3S 0       COLHDG('出荷の重なり')
     A            Z1HRH1         3S 0       COLHDG('出荷の振れ１')
     A            Z1NON1         4S 0       COLHDG('　　　　　　納入先')
