      ** ALDWP15 ***************************************
      * THE NUMBER OF PROCESSED BOXES BY WORKER LIST   *
      *                                                *
      *                                                *
      *                                                *
      *************************************** ALDWP15 **
     A          R ALDWP161                  TEXT('# OF BOXES BY WORKER')
     A            D6OPER         6A         COLHDG('WORKER CODE')
     A            D6BOX         11S 0       COLHDG('# OF BOX')
     A            D6SHFT         1S 0       COLHDG('SHIFT')
     A            D6YYYY         4S 0       COLHDG('SHIP DATE YY')
     A            D6MMMM         2S 0       COLHDG('SHIP DATE MM')
     A            D6DDDD         2S 0       COLHDG('SHIP DATE DD')
     A*
     A          K D6YYYY
     A          K D6MMMM
     A          K D6DDDD
     A          K D6SHFT
