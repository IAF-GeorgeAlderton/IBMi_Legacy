     A** BBHPP11 *******************************************
     A* ..TNS ZENGIN NETWORK SERVICE SEND AND RECEIVE INFORMATION HANDLING CHECK
     A*  M/F   *.
     A* I-HASADA                            91.01.08       *
     A******************************************* BBHPP11 **
     A                                      UNIQUE
     A          R BBHPP111                  TEXT('TNS SEND AND RECEIVE +
     A                                      INFORMATION HANDLING CHECK M/F')
     A            BCFILE         8          COLHDG('FILE CODE')
      *
     A            BCSRZM         1          COLHDG('SEND AND RECEIVE' -
     A                                             'INFORMATION HANDLING' -
     A                                             'FINISHED')
     A            BCSRYY         4S 0       COLHDG('DATA')
     A            BCSRMM         2S 0       COLHDG('MONTH')
     A            BCSRDD         2S 0       COLHDG('DAY')
     A            BCJSYY         4S 0       COLHDG('SEND AND RECEIVE')
     A            BCJSMM         2S 0       COLHDG('MONTH')
     A            BCJSDD         2S 0       COLHDG('DAY')
      *
     A            BCASKB         1          COLHDG('AS/400 HANDLING' -
     A                                             'INSTRUCTION')
     A*                                             Y-YES N-NO
     A            BCASZM         1          COLHDG('HANDLING FINISHED')
     A            BCASYY         4S 0       COLHDG('HANDLING DATE YEAR')
     A            BCASMM         2S 0       COLHDG('MONTH')
     A            BCASDD         2S 0       COLHDG('DAY')
      *
     A            BCTYPE         1          COLHDG('BACKUP MEDIUM')
     A*                                             T-TAPE D-DISKETT
     A            BCBCOD         1          COLHDG('DEPARTMENT HANDLING' -
     A                                             'INSTRUCTION')
     A*                                             COMPUTATION ROOM-E OTHER DEP
     A*ARTMENT-B
     A            BCRPGM         6          COLHDG('PROGRAM NAME')
      *
     A          K BCFILE
