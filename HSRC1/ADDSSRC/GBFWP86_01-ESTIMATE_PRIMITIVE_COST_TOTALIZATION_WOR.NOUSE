     A*** GBFWP86 ******************************************
     A*ESTIMATE PRIMITIVE COST TOTALIZATION WORK BY NAME ...PHYSICAL ... *
     A*             M-OKUDA        1986.05.06              *
     A******************************************************
     A          R GBFWP861                  TEXT('FILE BY NAME')
     A            G9TOKU         4S 0       COLHDG('CUSTOMER')
     A            G9TKOJ         1A         COLHDG('FACTORY IS NOT' -
     A                                             'APPOINTED *')
     A            G9MHN1         5A         COLHDG('ESTIMATE PART NO 1')
     A            G9MHN2         5A         COLHDG('ESTIMATE PART NO 2')
     A            G9MHN3         5A         COLHDG('ESTIMATE PART NO 3')
     A            G9MHN4         5A         COLHDG('ESTIMATE PART NO 4')
     A            G9MSYO         2A         COLHDG('PART NAME')
     A            G9MSKB         1A         COLHDG('NAME LARGE CLASS')
     A            G9SAIZ         2S 0       COLHDG('SIZE')
     A            G9KUBI         3S 0       COLHDG('NOMINAL LENGTH' -
     A                                             'LENGTH')
     A            G9YAKI         3A         COLHDG('QUENCHING')
     A            G9TKBN         1A         COLHDG('ESTIMATE CALCULATE' -
     A                                             'INSTRUCTION')
     A            G9KTNK         7P 4       COLHDG('COMPLETION PART' -
     A                                             'PURCHASE PRICE')
     A*************** MATERIAL *******************************
     A            G9SKYU         1A         COLHDG('MATERIAL PROVISION')
     A            G9ZCOD        15A         COLHDG('MATERIAL CODE')
     A            G9ZKGT         7P 4       COLHDG('MATERIAL PRICE')
     A            G9SZIJ         7P 2       COLHDG('MATERIAL UNIT WEIGHT')
     A            G9SZAJ         7P 2       COLHDG('MATERIAL UNIT WEIGHT')
     A            G9KANJ         7P 2       COLHDG('FINISHED UNIT WEIGHT')
     A*************** MATERIAL COSTS ********************
     A            G9SZIH         7P 4       COLHDG('MATERIAL PRICE')
