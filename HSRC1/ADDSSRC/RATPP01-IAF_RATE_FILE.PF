      *************************** RATPP01 **
     A          R RATPP011
     A            RASKJY         1A         COLHDG('DELETE CODE D')
     A            RASKYY         4S 0       COLHDG('DELETE DUE DATE' -
     A                                             '(YEAR)')
     A            RASKMM         2S 0       COLHDG('DELETE DUE DATE' -
     A                                             '(MONTH) ')
     A            RASKDD         2S 0       COLHDG('DELETE DUE DATE' -
     A                                             '(DAY)')
     A            RAKOYY         4S 0       COLHDG('UPDATE WORK DATE' -
     A                                             '(YEAR)')
     A            RAKOMM         2S 0       COLHDG('UPDATE WORK DATE' -
     A                                             '(MONTH)')
     A            RAKODD         2S 0       COLHDG('UPDATE WORK DATE' -
     A                                             '(DAY)')
     A            RAKOHH         2S 0       COLHDG('UPDATE WORK (TIME)' -
     A                                             '    ')
     A            RAKOSS         2S 0       COLHDG('UPDATE WORK TIME' -
     A                                             '(MINUTES)')
     A            RAKOME        10A         COLHDG('UPDATE TEAM MEMBER' -
     A                                             'PROFILE')
     A            RATEYY         4S 0       COLHDG('RANGE DATE YY')
     A            RATEMM         2S 0       COLHDG('RANGE DATE MM')
     A            RACODE         3A         COLHDG('CURRENCY CODE')
     A            RARATE        10S 5       COLHDG('CURRENCY RATE')
