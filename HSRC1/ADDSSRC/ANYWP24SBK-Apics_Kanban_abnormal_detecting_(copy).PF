     A          R ANYW24S1
     A            PART          14A         COLHDG('PART')
     A            A_UNSCAN       6S 1       COLHDG('UNSCAN A')
     A            B_NOTRANM      6S 1       COLHDG('NOTRANSM B')
     A            C_NOTRANS      6S 1       COLHDG('NOTRANS C')
     A            D_BARRELF      6S 2       COLHDG('BARREL FRACTION D')
