     A            QPC            5S 0       COLHDG('QPC')
     A            BOX@DAY        7S 2       COLHDG('BOX/DAY')
     A            LAST_SHIP      8S 0       COLHDG('LAST SHIP')
     A            Y_@_BOXDAY     5S 2       COLHDG('Y/BOX-DAY')
