     A            C8CRUS        10          COLHDG('CREATE USER')
     A            C8CRDT         8S 0       COLHDG('CREATE DATE')
     A            C8CRTM         6S 0       COLHDG('CREATE TIME')
     A            C8TBCD         4S 0       COLHDG('TRANS DEPT')
     A            C8DTHZ         8S 0       COLHDG('DATA CREATE DATE')
     A            C8DTBB         2S 0       COLHDG('BIN')
