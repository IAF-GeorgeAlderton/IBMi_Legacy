     A** AB#EP61B *************************************
     A* EDI PROCESSING FLAT FILE FOR 856        *
     A*                                               *
     A*                                               *
     A************************************** AB#EP60 **
      *
     A          R AB#E75B1                  TEXT('FOR EDI856')
     A            E2SHID        10          COLHDG('SHIPMENT#')
     A            E2PRTN        10          COLHDG('PARTNER ID')
     A            E2MAN#        20          COLHDG('MANI#, PACK#-FORD')
     A            E2BLN#        20          COLHDG('B/L#')
     A            E2INVN        16          COLHDG('INVOICE#')
     A            E2ORDN        10          COLHDG('ORDER#')
     A            E2SUPL        10          COLHDG('SUPPLIER CODE')
      *
JW   A            E2CRDT         8S 0       COLHDG('CREATE DATE')
JW   A            E2CRTM         6S 0       COLHDG('CREATE TIME')
JW   A            E2CRPG        10          COLHDG('CREATE PGM ')
      *
     A          K E2SHID
     A          K E2ORDN
