     A** GCQWP20 *******************************************
     A* DIE EXCEL WORK FILE                                *
     A*                                                    *
     A******************************************* GCQWP20 **
     A          R GCQWP20R                  TEXT('DIE KANBAN WORK')
     A            Q0KAT          7A         COLHDG('DIE#')
     A            Q0#01          1A
     A            Q0LOC         11A         COLHDG('LOCATION')
     A            Q0#02          1A
     A            Q0SYOS         3S 0       COLHDG('ACCOMMODATED' -
     A                                             'QUANTITY')
     A            Q0#03          1A
     A            Q0MAIS         3S 0       COLHDG('KANBAN NUMBER OF' -
     A                                             'SHEETS')
     A            Q0#04          1A
     A            Q0MAI1         3S 0       COLHDG('RESULT X')
     A            Q0#05          1A
     A            Q0MAI2         3S 0       COLHDG('DIFFER')
     A            Q0#06          1A
     A            Q0AVRS         7S 2       COLHDG('AVERAGE SHEET')
     A            Q0#07          1A
     A            Q0DTL1         5S 0       COLHDG('N-1')
     A            Q0#08          1A
     A            Q0DTL2         5S 0       COLHDG('N-2')
     A            Q0#09          1A
     A            Q0DTL3         5S 0       COLHDG('N-3')
     A            Q0#10          1A
     A            Q0DTL4         5S 0       COLHDG('N-4')
     A            Q0#11          1A
     A            Q0DTL5         5S 0       COLHDG('N-5')
     A            Q0#12          1A
     A            Q0DTL6         5S 0       COLHDG('N-6')
     A            Q0#13          1A
     A            Q0SRYO         7S 2       COLHDG('MONTHLY NECESSARY' -
     A                                             'NUMBER')
     A            Q0#14          1A
     A            Q0KIDT         8S 0       COLHDG('CHANGE DATE')
