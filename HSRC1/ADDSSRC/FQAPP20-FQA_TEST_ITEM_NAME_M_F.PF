     A** FQAPP20 *****************************
     A* FQA TEST ITEM NAME M/F               *
     A*    K.OKACHI            1998.04.03    *
     A***************************** FQAPP20 **
     A          R FQAPP201
     A                                      TEXT('FQA TEST ITEM NAME M/F')
     A            F2SKJY         1A         COLHDG('DELETE CODE D')
     A            F2SKYY         4S 0       COLHDG('DELETE DUE DATE' -
     A                                             '(YEAR)')
     A            F2SKMM         2S 0       COLHDG('DELETE DUE DATE' -
     A                                             '(MONTH) ')
     A            F2SKDD         2S 0       COLHDG('DELETE DUE DATE' -
     A                                             '(DAY)')
     A            F2KOYY         4S 0       COLHDG('UPDATE WORK DATE' -
     A                                             '(YEAR)')
     A            F2KOMM         2S 0       COLHDG('UPDATE WORK DATE' -
     A                                             '(MONTH)')
     A            F2KODD         2S 0       COLHDG('UPDATE WORK DATE' -
     A                                             '(DAY)')
     A            F2KOHH         2S 0       COLHDG('UPDATE WORK (TIME)' -
     A                                             '    ')
     A            F2KOSS         2S 0       COLHDG('UPDATE WORK TIME' -
     A                                             '(MINUTES)')
     A            F2KOME        10A         COLHDG('UPDATE TEAM MEMBER' -
     A                                             'PROFILE')
      **********************
     A            F2CODE         2A         COLHDG('TEST ITEM CODE')
     A            F2ITEM        40A         COLHDG('TEST ITEM')
