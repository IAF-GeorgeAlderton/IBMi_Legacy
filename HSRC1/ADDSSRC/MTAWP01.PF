     A          R MTAWP011
     A            W@DTID         2A         COLHDG('DATA ID')
     A            W@MSNN        20A         COLHDG('MACHINE #')
     A            W@DATE         8A         COLHDG('DATE')
     A            W@SFT          3A         COLHDG('SHIFT')
     A            W@TM          10A         COLHDG('TM')
      *
     A            W@STUP        10A         COLHDG('SETUP')
     A            W@ADJS        10A         COLHDG('ADJUST')
      *
     A            W@WATC        10A         COLHDG('WAIT CHANGE')
     A            W@WATM        10A         COLHDG('WAIT MATERIAL')
     A            W@WATK        10A         COLHDG('WAIT KANBAN')
     A            W@WATT        10A         COLHDG('WAIT TOOLING')
      *
     A            W@REPR        10A         COLHDG('REPAIRS')
     A            W@OTHR        10A         COLHDG('OTHERS')
      *
     A            W@OUTS        10A         COLHDG('OUTPUT')
      *
     A            W@CHNG        10A         COLHDG('NO OF CHANGES')
      *
     A            W@HOUR        10A         COLHDG('OUTPUT HOURS')
