      ** ALFWP20 *******************************************
      *  CONVEYANCE PULL SCAN RESULT TM,DATE WORK          *
      *       WASHER                                       *
      * TCHK1 10/21/10 CREATE(COPY FROM ALCWP20)           *
      ******************************************************
     A          R ALFWP201                  TEXT('# OF BOXES BY TM')
     A            W20TMC        10A         COLHDG('WORKER CODE')
     A            W20TMN        20A         COLHDG('WORKER NAME')
     A            W20ABX         6S 0       COLHDG('ASJ #OF BOX')
     A            W20FBX         6S 0       COLHDG('FREEWAY #OF BOX')
     A            W20RBX         6S 0       COLHDG('RETRIEVAL #OF BOX')
     A*
     A          K W20TMC
