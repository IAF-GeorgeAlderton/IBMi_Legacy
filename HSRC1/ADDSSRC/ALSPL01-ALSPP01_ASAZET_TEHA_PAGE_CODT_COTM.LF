     A            ASABN2                    COLHDG('A-PICS/PT 2')
     A            ASABN3                    COLHDG('A-PICS/PT 3')
     A            ASABN4                    COLHDG('A-PICS/PT 4')
      *
     A            ASOKNG                    COLHDG('OK/NG')
     A            ASERCD                    COLHDG('ERROR CODE')
      *
     A          K ASAZET
