     A            AWMHN2         5          COLHDG('USER PART2')
     A            AWMHN3         5          COLHDG('USER PART3')
     A            AWCD01         1          COLHDG('ORDER/FORECAST')
     A                                      TEXT('ORDER:C,FORECAST:D')
