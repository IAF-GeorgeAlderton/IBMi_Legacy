      ** APSPP01 ***************************************
      * Part Setting# file for Customer                *
      *                                                *
      *************************************** APSPP01 **
     A          R APSPP011                  TEXT('Part Setting#')
     A*
     A            SPSKJY         1A         COLHDG('DLT CODE')
     A            SPSKYY         4S 0       COLHDG('DLT YEAR')
     A            SPSKMM         2S 0       COLHDG('DLT MONTH')
     A            SPSKDD         2S 0       COLHDG('DLT DAYS')
     A            SPSKME        10A         COLHDG('DLT USER')
     A            SPSKWS        10A         COLHDG('DLT WS')
     A            SPSKPG        10A         COLHDG('DLT PGM')
     A            SPKOYY         4S 0       COLHDG('UPD YEAR')
     A            SPKOMM         2S 0       COLHDG('UPD MONTH')
     A            SPKODD         2S 0       COLHDG('UPD DAYS')
     A            SPKOHH         2S 0       COLHDG('UPD HOUR')
     A            SPKOSS         2S 0       COLHDG('UPD MIN')
     A            SPKOME        10A         COLHDG('UPD USER')
     A            SPKOWS        10A         COLHDG('UPD WS')
     A            SPKOPG        10A         COLHDG('UPD PGM')
     A*
     A            SPUKEY        19A         COLHDG('UNIQUE KEY')
     A*
     A            SPIPT1         5A         COLHDG('INTRA PART 1')
     A            SPIPT2         5A         COLHDG('INTRA PART 2')
     A            SPIPT3         2A         COLHDG('INTRA PART 3')
     A            SPTOKU         4S 0       COLHDG('CUSTOMER')
     A            SPNONY         4S 0       COLHDG('DELIVERY')
     A            SPPRJT         5A         COLHDG('PROJRCT')
     A            SPUSG          7A         COLHDG('USAGE')
     A            SPPOSI         5A         COLHDG('POS ISSUE')
     A            SPAINF        30A         COLHDG('ADDTIONAL INF.')
     A            SPDLTR        30A         COLHDG('DE-ISSUE REASON')
     A*
