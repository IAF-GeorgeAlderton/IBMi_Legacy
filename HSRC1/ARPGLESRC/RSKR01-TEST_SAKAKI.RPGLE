     H DFTACTGRP(*NO)
      //************************************************************************
      // RSKR01
      // T.SAKAKI     2018/05/25
      //    IN        9999999999
      //    OUT   '9,999,999,999' + InUNT
      //************************************************************************
     C     *Entry        PList
     C                   Parm                    InQTY            10 0
     C                   Parm                    InUNT             5
     C                   Parm                    OuWRD            60
      **********************************************************
      *         M    A    I    N    L    I    N    E
      **********************************************************
      *
               OuWRD = *blank;
               OuWRD = %TRIM(%EDITC(InQTY:'N')) + ' ' + InUNT;
      *
               *InLR = *On;
               Return;
