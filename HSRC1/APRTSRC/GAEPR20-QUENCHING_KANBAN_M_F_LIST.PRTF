     A                                      SPACEA(1)
     A                                   111'|MFG      | PLAN    |'
     A                                      SPACEA(1)
     A                                    86'TIME'
     A            @TIME          6S 0    + 1EDTWRD('  :  :  ')
     A                                   111'|1 SECTION| SECTION |'
     A                                      SPACEA(1)
