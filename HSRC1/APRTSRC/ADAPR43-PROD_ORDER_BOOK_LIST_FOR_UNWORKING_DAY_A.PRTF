     A                                    27'BOXES'
     A                                    36'POINT NAME'
     A                                    51'LOC CODE'
     A                                    63'LOC CODE'
     A                                      SPACEA(1)
     A*
     A          R ADAPR432                  SPACEA(1)
     A            @HIN          14         3
     A            DASYUY         5S 0     20EDTCDE(1)
     A            DAKBMX         3S 0     29EDTCDE(4)
