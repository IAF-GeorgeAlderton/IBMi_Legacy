     A*
     A                                    55'TIME'
     A                                    60TIME EDTWRD('  :  :  ')
     A                                    70'.         .'
     A                                      SPACEA(1)
     A*
     A                                    55'DATE'
     A                                    60DATE EDTCDE(Y)
     A                                    70'.         .'
     A                                      SPACEA(1)
     A*
     A                                     2'ADAR43-1'
     A                                    22'PRODUCTION ORDER BOOK LIST'
     A                                    60'PAGE'
     A                                    64PAGNBR EDTCDE(4)
     A                                    70'...........'
     A                                      SPACEA(1)
     A                                    30'FOR UNWORKING DAY AND NIGHT ATTEN+
     A                                       DANCE'
     A                                      SPACEA(1)
     A*
     A            @NAME         10         3
     A            @YMD           8S 0     13EDTWRD('    .  .  ')
     A                                    26'PURCHASING'
     A                                    37'KANBAN'
     A                                      SPACEA(2)
     A*
     A                                     3'PART'
     A                                     8'NO'
     A                                    12'ACCOMMODATED'
     A                                    35'PROD ORDER'
     A                                    51'INTRA-PROC'
     A                                    63'COMPLETION'
     A                                      SPACEA(1)
