             PGM
             /** MRAC11 **************************************/
             /* TRANSMIT TO ASJ                              */
             /*    TRANCOM ITS.        2012.09.17            */
             /************************************************/
             DCL        VAR(&USER)     TYPE(*CHAR) LEN(10)
             DCL        VAR(&WSID)     TYPE(*CHAR) LEN(10)
             DCL        VAR(&WS3)      TYPE(*CHAR) LEN(3)
             DCL        VAR(&PRT)      TYPE(*CHAR) LEN(7)
             DCL        VAR(&TYPE)     TYPE(*CHAR) LEN(1)
             DCL        VAR(&PRTG)     TYPE(*CHAR) LEN(10)
             DCL        VAR(&P1KEN)  TYPE(*CHAR) LEN(10)
             DCL        VAR(&P1SHN1) TYPE(*CHAR) LEN(5)
             DCL        VAR(&P1SHN2) TYPE(*CHAR) LEN(5)
             DCL        VAR(&P1SHN3) TYPE(*CHAR) LEN(2)
             DCL        VAR(&P1TMEI) TYPE(*CHAR) LEN(10)
             DCL        VAR(&P1MHN1) TYPE(*CHAR) LEN(5)
             DCL        VAR(&P1MHN2) TYPE(*CHAR) LEN(5)
             DCL        VAR(&P1MHN3) TYPE(*CHAR) LEN(5)
             DCL        VAR(&P1MHN4) TYPE(*CHAR) LEN(5)
             DCL        VAR(&P1BHN1) TYPE(*CHAR) LEN(5)
             DCL        VAR(&P1BHN2) TYPE(*CHAR) LEN(5)
             DCL        VAR(&P1BHN3) TYPE(*CHAR) LEN(2)
             DCL        VAR(&P1IPD1) TYPE(*CHAR) LEN(8)
             DCL        VAR(&P1IPD2) TYPE(*CHAR) LEN(8)
             DCL        VAR(&P1STD1) TYPE(*CHAR) LEN(8)
             DCL        VAR(&P1STD2) TYPE(*CHAR) LEN(8)
             DCL        VAR(&P1SYKI) TYPE(*CHAR) LEN(4)
             DCL        VAR(&P1CRAT) TYPE(*CHAR) LEN(10)
             DCL        VAR(&PCMD) TYPE(*CHAR) LEN(2)
             DCL        VAR(&MRAWP05) TYPE(*CHAR) LEN(10)
             DCL        VAR(&PMSG) TYPE(*CHAR) LEN(256)
             DCL        VAR(&PKINP) TYPE(*CHAR) LEN(5)
             DCL        VAR(&PKOUT) TYPE(*CHAR) LEN(1)

             RTVJOBA    JOB(&WSID) USER(&USER)

             CALL       PGM(AGAR00) PARM(&WSID &PRT &TYPE &PRTG)
             CHGVAR     VAR(&WS3)   VALUE(%SST(&WSID 1 3))
             CHGVAR     VAR(&MRAWP05) VALUE('MRAWP05' *CAT &WS3)

             CRTDTAARA  DTAARA(HFILE1/MRAC11ACT) TYPE(*CHAR) LEN(1) +
                          TEXT('TRANSMIT TO ASJ')
             MONMSG     MSGID(CPF1023) EXEC(GOTO CMDLBL(STP00))
             GOTO       CMDLBL(STP01)
 STP00:
             CHGVAR     VAR(&PMSG) VALUE('SOMEONE ELSE USING THIS +
                          MENU.WAIT FOR A WHILE.(G)')
             CHGVAR     VAR(&PKINP) VALUE('G    ')
             CHGVAR     VAR(&PKOUT) VALUE(' ')
             CALL       PGM(APLR80) PARM(&PMSG &PKINP &WSID &PKOUT)
             GOTO       CMDLBL(#END)
 STP01:
             CALL       PGM(MRAR05) PARM('3' &P1KEN &P1SHN1 +
                          &P1SHN2 &P1SHN3 &P1TMEI &P1MHN1 &P1MHN2 +
                          &P1MHN3 &P1MHN4 &P1BHN1 &P1BHN2 &P1BHN3 +
                          &P1IPD1 &P1IPD2 &P1STD1 &P1STD2 &P1SYKI +
                          &P1CRAT &PCMD)
             IF         COND(&PCMD *EQ '01') THEN(GOTO CMDLBL(END))
 STP02:
             DLTF       FILE(HWFILE1/&MRAWP05)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(HWFILE1/&MRAWP05) +
                          SRCFILE(HSRC1/ADDSSRC) SRCMBR(MRAWP05) +
                          OPTION(*NOLIST *NOSRC) SIZE(1000 1000 +
                          3) LVLCHK(*NO) AUT(*ALL)
             OVRDBF     FILE(MRAWP05) TOFILE(HWFILE1/&MRAWP05)
             CALL       PGM(MRAR04) PARM('3' &P1KEN &P1SHN1 +
                          &P1SHN2 &P1SHN3 &P1TMEI &P1MHN1 &P1MHN2 +
                          &P1MHN3 &P1MHN4 &P1BHN1 &P1BHN2 &P1BHN3 +
                          &P1IPD1 &P1IPD2 &P1STD1 &P1STD2 &P1SYKI +
                          &P1CRAT &PCMD)
 STP03:
             OVRDBF     FILE(MRAWP05) TOFILE(HWFILE1/&MRAWP05)
             CALL       PGM(MRAR11) PARM(&PCMD)
             IF         COND(&PCMD *EQ '05') THEN(GOTO CMDLBL(STP02))
             GOTO       CMDLBL(STP01)

 END:
    /* TRANSMIT TO ASJ                */
             CALL       PGM(MRAC21)
    /* TRANSMIT TO ASJ(NEW PRODUCTFILE) */
             CALL       PGM(MRAC31)
    /* TRANSMIT TO ASJ(PROGRESS DATA) */
             CALL       PGM(MRAC41)

             DLTDTAARA  DTAARA(HFILE1/MRAC11ACT)
 #END:
             ENDPGM
