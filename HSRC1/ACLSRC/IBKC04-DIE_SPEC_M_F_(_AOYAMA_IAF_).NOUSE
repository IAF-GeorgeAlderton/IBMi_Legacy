             CLRPFM     FILE(FCQWP31)

             RSTOBJ     OBJ(FCQWP31) SAVLIB(WORKLIB) DEV(*SAVF) +
                          OBJTYPE(*FILE) SAVF(APSAVLIB/FCQWP31) +
                          MBROPT(*ALL) ALWOBJDIF(*ALL) +
                          FRCOBJCVN(*YES) RSTLIB(HWFILE1)
             MONMSG     MSGID(CPF3773)

             DLTF       FILE(APSAVLIB/FCQWP31)

             CALL       PGM(IBKR04)
