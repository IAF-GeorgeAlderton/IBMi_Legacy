             DLTF       FILE(APSAVLIB/FCQWP31)
             MONMSG     MSGID(CPF3261 CPF2105)

             CRTSAVF    FILE(APSAVLIB/FCQWP31) AUT(*ALL)

             RCVNETF    FROMFILE(FCQWP31) TOFILE(APSAVLIB/FCQWP31) +
