             PGM        PARM(&PNO &PCHK)
             /** ALAC11 ************************************/
             /*  ..ＴＯＰＩＣＳへのマスターデータ準備..  */
             /*  ..ＴＯＰＩＣＳ受信データコピー          */
             /*       I-HASADA              89.07.17       */
             /************************************ ALAC11 **/
             DCL        VAR(&PNO) TYPE(*CHAR) LEN(1)
             DCL        VAR(&PCHK) TYPE(*CHAR) LEN(1)

             CHKOBJ     OBJ(ALACHK) OBJTYPE(*DTAARA)
             MONMSG     MSGID(CPF9801) EXEC(GOTO CMDLBL(STP2))

             CHGVAR     VAR(&PCHK) VALUE('E')
             RETURN

 STP2:       CRTDTAARA  DTAARA(APLIB/ALACHK) TYPE(*CHAR) LEN(10) +
                          TEXT('TOPICS ﾆﾞｬﾆ] uﾇjｰmﾞｰj ﾅhﾈb kｩｮh') +
                          AUT(*ALL)
             MONMSG     MSGID(CPF1023) EXEC(DO)
             CHGVAR     VAR(&PCHK) VALUE('E')
             RETURN
             ENDDO

             /*--------------------------------------------*/
             /*  ..他社納品書作成機　かんばんマスター..  */
             /*  ..　　　　　　　　　チェックマスター..  */
             /*--------------------------------------------*/
             IF         (&PNO *EQ '1') DO

             /*--------------------------------------------*/
             /*  ..他社納品書作成機　かんばんマスター..  */
             /*--------------------------------------------*/
             CHKOBJ     OBJ(ALBNPA5) OBJTYPE(*FILE)
             MONMSG     MSGID(CPF9801) EXEC(CRTPF +
                          FILE(APWRKLIB/ALBNPA5) RCDLEN(130) +
                          TEXT('TOPICS jﾆｫﾉcﾍ]ﾆｭﾅhﾈbg f]ﾌﾞ]uﾇjｰ') +
                          OPTION(*NOSRC *NOLIST) SIZE(*NOMAX) +
                          AUT(*ALL))
             CHKOBJ     OBJ(ALBNPA5B) OBJTYPE(*FILE)
             MONMSG     MSGID(CPF9801) EXEC(CRTPF +
                          FILE(APWRKLIB/ALBNPA5B) RCDLEN(130) +
                          TEXT('TOPICS ﾈﾞ]fb jﾆｫﾉcﾍ]ﾆｭﾅhﾈbg +
                          f]ﾌﾞ]uﾇjｰ') OPTION(*NOSRC *NOLIST) +
                          SIZE(*NOMAX) AUT(*ALL))

             CPYF       FROMFILE(ALBNPA5) TOFILE(ALBNPA5B) +
                          MBROPT(*REPLACE) FMTOPT(*NOCHK)
             MONMSG     MSGID(CPF2817 CPF2963) EXEC(DO)
             CLRPFM     FILE(ALBNPA5B)
             ENDDO
             CPYF       FROMFILE(ALBWPA5) TOFILE(ALBNPA5) +
                          MBROPT(*REPLACE) FMTOPT(*NOCHK)
             MONMSG     MSGID(CPF2817 CPF2963) EXEC(DO)
             CLRPFM     FILE(ALBNPA5)
             ENDDO
             CLRPFM     FILE(ALBWPA5)

             /*--------------------------------------------*/
             /*  ..他社納品書作成機　チェックマスター..  */
             /*--------------------------------------------*/
             CHKOBJ     OBJ(ALBNPB5) OBJTYPE(*FILE)
             MONMSG     MSGID(CPF9801) EXEC(CRTPF +
                          FILE(APWRKLIB/ALBNPB5) RCDLEN(130) +
                          TEXT('TOPICS jﾆｫﾉcﾍ]ﾆｭﾅhﾈbg kｩｮhuﾇjｰ') +
                          OPTION(*NOSRC *NOLIST) SIZE(*NOMAX) +
                          AUT(*ALL))
             CHKOBJ     OBJ(ALBNPB5B) OBJTYPE(*FILE)
             MONMSG     MSGID(CPF9801) EXEC(CRTPF +
                          FILE(APWRKLIB/ALBNPB5B) RCDLEN(130) +
                          TEXT('TOPICS ﾈﾞ]fb jﾆｫﾉcﾍ]ﾆｭﾅhﾈbg +
                          kｩｮhuﾇjｰ') OPTION(*NOSRC *NOLIST) +
                          SIZE(*NOMAX) AUT(*ALL))

             CPYF       FROMFILE(ALBNPB5) TOFILE(ALBNPB5B) +
                          MBROPT(*REPLACE) FMTOPT(*NOCHK)
             MONMSG     MSGID(CPF2817 CPF2963) EXEC(DO)
             CLRPFM     FILE(ALBNPB5B)
             ENDDO
             CPYF       FROMFILE(ALBWPB5) TOFILE(ALBNPB5) +
                          MBROPT(*REPLACE) FMTOPT(*NOCHK)
             MONMSG     MSGID(CPF2817 CPF2963) EXEC(DO)
             CLRPFM     FILE(ALBNPB5)
             ENDDO
             CLRPFM     FILE(ALBWPB5)
             ENDDO

             /*----------------------------------------------*/
             /*  ..トヨタ納品書作成機　かんばんマスター..  */
             /*----------------------------------------------*/
             IF         (&PNO *EQ '2') DO
             CHKOBJ     OBJ(ALBNPH5) OBJTYPE(*FILE)
             MONMSG     MSGID(CPF9801) EXEC(CRTPF +
                          FILE(APWRKLIB/ALBNPH5) RCDLEN(130) +
                          TEXT('TOPICS nﾑjﾉcﾍ]ﾆｭﾅhﾈbg f]ﾌﾞ]uﾇjｰ') +
                          OPTION(*NOSRC *NOLIST) SIZE(*NOMAX) +
                          AUT(*ALL))
             CHKOBJ     OBJ(ALBNPH5B) OBJTYPE(*FILE)
             MONMSG     MSGID(CPF9801) EXEC(CRTPF +
                          FILE(APWRKLIB/ALBNPH5B) RCDLEN(130) +
                          TEXT('TOPICS ﾈﾞ]fb nﾑjﾉcﾍ]ﾆｭﾅhﾈbg +
                          f]ﾌﾞ]uﾇjｰ') OPTION(*NOSRC *NOLIST) +
                          SIZE(*NOMAX) AUT(*ALL))

             CPYF       FROMFILE(ALBNPH5) TOFILE(ALBNPH5B) +
                          MBROPT(*REPLACE) FMTOPT(*NOCHK)
             MONMSG     MSGID(CPF2817 CPF2963) EXEC(DO)
             CLRPFM     FILE(ALBNPH5B)
             ENDDO
             CPYF       FROMFILE(ALBWPH5) TOFILE(ALBNPH5) +
                          MBROPT(*REPLACE) FMTOPT(*NOCHK)
             MONMSG     MSGID(CPF2817 CPF2963) EXEC(DO)
             CLRPFM     FILE(ALBNPH5)
             ENDDO
             CLRPFM     FILE(ALBWPH5)
             ENDDO

             /*------------------------------------------*/
             /*  ..かんばん仕分機　かんばんマスター..  */
             /*  ..　　　　　　　　チェックマスター..  */
             /*------------------------------------------*/
             IF         (&PNO *EQ '3') DO

             /*------------------------------------------*/
             /*  ..かんばん仕分機　かんばんマスター..  */
             /*------------------------------------------*/
             CHKOBJ     OBJ(ALBNPI5) OBJTYPE(*FILE)
             MONMSG     MSGID(CPF9801) EXEC(CRTPF +
                          FILE(APWRKLIB/ALBNPI5) RCDLEN(130) +
                          TEXT('TOPICS f]ﾌﾞ]ﾆﾝig f]ﾌﾞ]uﾇjｰ') +
                          OPTION(*NOSRC *NOLIST) SIZE(*NOMAX) +
                          AUT(*ALL))
             CHKOBJ     OBJ(ALBNPI5B) OBJTYPE(*FILE)
             MONMSG     MSGID(CPF9801) EXEC(CRTPF +
                          FILE(APWRKLIB/ALBNPI5B) RCDLEN(130) +
                          TEXT('TOPICS ﾈﾞ]fb f]ﾌﾞ]ﾆﾝig f]ﾌﾞ]uﾇjｰ') +
                          OPTION(*NOSRC *NOLIST) SIZE(*NOMAX) +
                          AUT(*ALL))

             CPYF       FROMFILE(ALBNPI5) TOFILE(ALBNPI5B) +
                          MBROPT(*REPLACE) FMTOPT(*NOCHK)
             MONMSG     MSGID(CPF2817 CPF2963) EXEC(DO)
             CLRPFM     FILE(ALBNPI5B)
             ENDDO
             CPYF       FROMFILE(ALBWPI5) TOFILE(ALBNPI5) +
                          MBROPT(*REPLACE) FMTOPT(*NOCHK)
             MONMSG     MSGID(CPF2817 CPF2963) EXEC(DO)
             CLRPFM     FILE(ALBNPI5)
             ENDDO
             CLRPFM     FILE(ALBWPI5)

             /*------------------------------------------*/
             /*  ..かんばん仕分機　チェックマスター..  */
             /*------------------------------------------*/
             CHKOBJ     OBJ(ALBNPJ5) OBJTYPE(*FILE)
             MONMSG     MSGID(CPF9801) EXEC(CRTPF +
                          FILE(APWRKLIB/ALBNPJ5) RCDLEN(130) +
                          TEXT('TOPICS f]ﾌﾞ]ﾆﾝig kｩｮhuﾇjｰ') +
                          OPTION(*NOSRC *NOLIST) SIZE(*NOMAX) +
                          AUT(*ALL))
             CHKOBJ     OBJ(ALBNPJ5B) OBJTYPE(*FILE)
             MONMSG     MSGID(CPF9801) EXEC(CRTPF +
                          FILE(APWRKLIB/ALBNPJ5B) RCDLEN(130) +
                          TEXT('TOPICS ﾈﾞ]fb f]ﾌﾞ]ﾆﾝig kｩｮhuﾇjｰ') +
                          OPTION(*NOSRC *NOLIST) SIZE(*NOMAX) +
                          AUT(*ALL))

             CPYF       FROMFILE(ALBNPJ5) TOFILE(ALBNPJ5B) +
                          MBROPT(*REPLACE) FMTOPT(*NOCHK)
             MONMSG     MSGID(CPF2817 CPF2963) EXEC(DO)
             CLRPFM     FILE(ALBNPJ5B)
             ENDDO
             CPYF       FROMFILE(ALBWPJ5) TOFILE(ALBNPJ5) +
                          MBROPT(*REPLACE) FMTOPT(*NOCHK)
             MONMSG     MSGID(CPF2817 CPF2963) EXEC(DO)
             CLRPFM     FILE(ALBNPJ5)
             ENDDO
             CLRPFM     FILE(ALBWPJ5)
             ENDDO


             DLTDTAARA  DTAARA(ALACHK)
             MONMSG     MSGID(CPF2105)

             ENDPGM
