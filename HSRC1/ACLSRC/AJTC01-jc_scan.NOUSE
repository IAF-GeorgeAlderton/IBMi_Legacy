             PGM
             /** ALDC0Y **********************************/
             CHGMSGQ    MSGQ(*USRPRF) DLVRY(*HOLD)
             ADDLIBLE   LIB(TWFILE1)
             MONMSG     MSGID(CPF0000)
             ADDLIBLE   LIB(TFILE1)
             MONMSG     MSGID(CPF0000)
             ADDLIBLE   LIB(TOBJ1)
             MONMSG     MSGID(CPF0000)
             CALL       PGM(AJTR01)

             SIGNOFF

             ENDPGM
