             PGM
             /** IBKC06 **********************************/
             /*    ..出庫管理 M/F ( AOYAMA-->IAF )..   */
             /*     A.IDOTA               2006.07.01     */
             /********************************** IBKC06 **/

             DLTF       FILE(APSAVLIB/FOAWP01)
             MONMSG     MSGID(CPF3261 CPF2105)

             CRTSAVF    FILE(APSAVLIB/FOAWP01) AUT(*ALL)

             RCVNETF    FROMFILE(FOAWP01) TOFILE(APSAVLIB/FOAWP01) +
                          USER(QFILE)

             CLRPFM     FILE(FOAWP01)

             RSTOBJ     OBJ(FOAWP01) SAVLIB(WORKLIB) DEV(*SAVF) +
                          OBJTYPE(*FILE) SAVF(APSAVLIB/FOAWP01) +
                          MBROPT(*ALL) ALWOBJDIF(*ALL) +
                          FRCOBJCVN(*YES) RSTLIB(HWFILE1)
             MONMSG     MSGID(CPF3773)

             DLTF       FILE(APSAVLIB/FOAWP01)

             CALL       PGM(IBKR06)
             CLRPFM     FILE(FOAWP01)

             ENDPGM
