             /** EDSC00 ************************************/
             /* CUMULATE EDI DAILY DATA (NOT PASS)         */
             /*       CREATE DATE : 2016.02.29             */
             /*       CODING      : J.WATANABE             */
             /**********************************************/
             PGM
             DCLF       FILE(EDSPW02)
             DCL        VAR(&WSID)   TYPE(*CHAR) LEN(10)
             DCL        VAR(&USER)   TYPE(*CHAR) LEN(10)
             RTVJOBA    JOB(&WSID) USER(&USER)
@DSP00:
             SNDRCVF    DEV(&WSID) RCDFMT(DSP01)
 /* F1: EXIT */
             IF         COND(&IN01 *EQ '1') THEN(GOTO CMDLBL(@EXIT))

 /* F5: RUN  */
             IF         COND(&IN05 *NE '1') THEN(GOTO CMDLBL(@DSP00))

 /* PURGE AB#EPXXS */
             CALL       PGM(EDSC04)

 @EXIT:      ENDPGM
