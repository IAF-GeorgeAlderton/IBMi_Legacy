             PGM

             DCL        VAR(&NONY) TYPE(*DEC) LEN(4 0) VALUE(9005)
             DCL        VAR(&NKOJ) TYPE(*CHAR) LEN(1) VALUE('0')
             DCL        VAR(&NUKE) TYPE(*CHAR) LEN(4) VALUE('NM')
             DCL        VAR(&NOHZ) TYPE(*DEC) LEN(8 0) VALUE(20170724)
             DCL        VAR(&NOBN) TYPE(*DEC) LEN(2 0) VALUE(1)
             DCL        VAR(&ODRN) TYPE(*CHAR) LEN(10) +
                          VALUE('4500035655')
             DCL        VAR(&MHN) TYPE(*CHAR) LEN(20) +
                          VALUE('90119A015800')
             DCL        VAR(&RTN) TYPE(*CHAR) LEN(1) VALUE(' ')

             CALL       PGM(AB#R2V) PARM(&NONY &NKOJ &NUKE &NOHZ +
                          &NOBN &ODRN &MHN &RTN)

             ENDPGM
