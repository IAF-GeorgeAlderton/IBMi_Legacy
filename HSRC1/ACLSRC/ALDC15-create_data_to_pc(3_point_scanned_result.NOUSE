             PGM
             /** ALDC15 ************************************/
             DCL        VAR(&END) TYPE(*CHAR) LEN(1)
             DCL        VAR(&EDT) TYPE(*CHAR) LEN(8)
             DCL        VAR(&SDT) TYPE(*CHAR) LEN(8)
             DCL        VAR(&YM) TYPE(*CHAR) LEN(6)

             CLRPFM ALDWP15

             CALL       PGM(ALDR15) PARM(&END &SDT &EDT &YM)

             IF         COND(&END *EQ '1') THEN(GOTO CMDLBL(@END))

             CLRPFM ALDWP16
             CLRPFM ALDWP17

             CALL       PGM(ALDR16) PARM(&SDT &EDT)
             CALL       PGM(ALDR17) PARM(&YM)
             STRPCO
             MONMSG     MSGID(IWS0000)

             STRPCCMD   PCCMD('C:¥PROGRA‾1¥MICROS‾1¥OFFICE¥EXCEL.EXE +
                          S:¥LIST¥ALDWP17.XLS')
  @END:

             ENDPGM
