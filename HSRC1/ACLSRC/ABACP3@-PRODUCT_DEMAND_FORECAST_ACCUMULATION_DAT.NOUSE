             PGM
             /** ABACP3 ******************************************/
             /*PRODUCT DEMAND FORECAST ACCUMULATION DATA CREATE  */
             /*   USER KANBAN M/F CREATE                         */
             /*                                                  */
             /* TCHK1 08/11/06 CHG &SLC(NONY CODE)               */
             /******************************** ABACP3 ************/
             DCL        VAR(&WSID)   TYPE(*CHAR) LEN(10)
             DCL        VAR(&PRT)    TYPE(*CHAR) LEN(7)
             DCL        VAR(&TYPE)   TYPE(*CHAR) LEN(1)
             DCL        VAR(&PRTG)   TYPE(*CHAR) LEN(10)
             DCL        VAR(&MBAN)   TYPE(*CHAR) LEN(4)
             DCL        VAR(&KOTAE)  TYPE(*CHAR) LEN(1)
             DCL        VAR(&PYMD)   TYPE(*CHAR) LEN(6)
             DCL        VAR(&WYMD)   TYPE(*CHAR) LEN(8)
             DCL        VAR(&PDEVT)  TYPE(*CHAR) LEN(6)
             DCL        VAR(&PIGCD)  TYPE(*CHAR) LEN(4)
             DCL        VAR(&WS)     TYPE(*CHAR) LEN(2)
             DCL        VAR(&USR)    TYPE(*CHAR) LEN(10)
             DCL        VAR(&WLIB)   TYPE(*CHAR) LEN(8)
             DCL        VAR(&END)   TYPE(*CHAR) LEN(1)
/* TCHK1     DCL        VAR(&SLC)   TYPE(*CHAR) LEN(20) */
/* TCHK1 */  DCL        VAR(&SLC)   TYPE(*CHAR) LEN(04)

             RTVSYSVAL  SYSVAL(QDATE) RTNVAR(&PYMD)

             RTVJOBA    JOB(&WSID) USER(&USR)

             CALL       PGM(AGAR01) PARM(&WSID &PDEVT &PIGCD)

             CALL       PGM(AGAR00) PARM(&WSID &PRT &TYPE &PRTG)
             CHGJOB     OUTQ(&PRTG)

             CALL       PGM(ALBC00) PARM(&USR  &WLIB)

             CHKOBJ     OBJ(HFILE1/GENABA) OBJTYPE(*DTAARA)
             MONMSG     MSGID(CPF9801) EXEC(GOTO CMDLBL(YTP0))

             CALL       PGM(QUILNGTX) PARM('GENTRAN IS WORKING NOW. +
                          PLEASE TRY IT AGAIN IN ONE MINUTE. THANK +
                          YOU. ' X'00000046' '       ' +
                          '                    ' X'00000000')

             GOTO       SEND


 YTP0:
             CHKOBJ     OBJ(HFILE1/ABAACT) OBJTYPE(*DTAARA)
             MONMSG     MSGID(CPF9801) EXEC(GOTO CMDLBL(YTP1))

 YTP2:       SNDPGMMSG  MSG('( G ) USER KANBAN M/F UPDATE HANDLING +
                          IS ACTIVE, WAIT FOR A WHILE. < G= +
                          EXECUTION >') TOMSGQ(&WSID) MSGTYPE(*INQ) +
                          KEYVAR(&MBAN)
             RCVMSG     MSGTYPE(*RPY) MSGKEY(&MBAN) WAIT(*MAX) +
                          MSG(&KOTAE)
             IF         COND((&KOTAE *NE 'G') *AND (&KOTAE *NE 'g')) +
                          THEN(GOTO CMDLBL(YTP2))
             GOTO       SEND

 YTP1:       CRTDTAARA  DTAARA(HFILE1/ABAACT) TYPE(*CHAR) LEN(10) +
                          TEXT('DURING USER PROD DEMAND FORECAST +
                          DATA UPD HANDLING') AUT(*ALL)

             CALL       PGM(TOBJ1/ABAR33) PARM(&END &SLC)
             IF         COND(&END *EQ '1') THEN(GOTO CMDLBL(END))

             CALL       PGM(ABACP4) PARM(&SLC)

 END:

             DLTDTAARA  DTAARA(HFILE1/ABAACT)
             MONMSG     MSGID(CPF2105)

 SEND:       CHGJOB     RUNPTY(20)

             ENDPGM
