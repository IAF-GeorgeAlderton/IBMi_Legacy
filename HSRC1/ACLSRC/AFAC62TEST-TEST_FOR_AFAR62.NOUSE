             PGM
             /** AFAC61 **************************************/
             /*  COMBINED PARTIAL CONTAINERS MENU            */
             /*  TCH 2000.05.22                              */
             /*  TCH 2000.07.07 DISPLAY COMPLETED MESSAGE    */
             /*  TCH 2001.01.30 ADD TEST MODE                */
             /*  TCH 2002.05.21 CONVERT KANBAN DATA          */
             /************************************** AFAC61 **/
             DCL        VAR(&WSID) TYPE(*CHAR) LEN(10)
             DCL        VAR(&USID) TYPE(*CHAR) LEN(10)
             DCL        VAR(&PRT)     TYPE(*CHAR) LEN(7)
             DCL        VAR(&PRTG)    TYPE(*CHAR) LEN(10)
             DCL        VAR(&TYPE)    TYPE(*CHAR) LEN(1)
             DCL        VAR(&PRCD1)   TYPE(*CHAR) LEN(1)
             DCL        VAR(&PRCD2)   TYPE(*CHAR) LEN(1)
             DCL        VAR(&WLIB)  TYPE(*CHAR) LEN(8)
             DCL        VAR(&CNT1) TYPE(*DEC) LEN(10 0)
             DCL        VAR(&CNT2) TYPE(*DEC) LEN(10 0)

             RTVJOBA    JOB(&WSID) USER(&USID)

             CALL       PGM(AGAR00) PARM(&WSID &PRT &TYPE &PRTG)

             CALL       PGM(ALBC00) PARM(&USID &WLIB)

 STP1:

 /* CREATE KANBAN DATA */

             CRTPF      FILE(TWFILE1/WAFT0111) RCDLEN(512) +
                          OPTION(*NOLIST) SIZE(1000 1000 2) +
                          LVLCHK(*NO) AUT(*ALL)
             MONMSG     MSGID(CPF0000)
             CLRPFM     FILE(TWFILE1/WAFT0111)

             CRTPF      FILE(TWFILE1/WAA1111) RCDLEN(256) +
                          OPTION(*NOLIST) SIZE(1000 1000 2) +
                          LVLCHK(*NO) AUT(*ALL)
             MONMSG     MSGID(CPF0000)
             CLRPFM     FILE(TWFILE1/WAA1111)

             OVRDBF     FILE(AAA1111) TOFILE(TWFILE1/WAA1111)
             OVRDBF     FILE(AAFT0111) TOFILE(TWFILE1/WAFT0111)

             OVRDBF     FILE(AFAPL61) TOFILE(TFILE1/AFAPL61)
             OVRDBF     FILE(AAHPL03) TOFILE(HFILE1/AAHPL03)
             OVRDBF     FILE(FCETL11) TOFILE(HFILE1/FCETL11)
             OVRDBF     FILE(MBDPL01) TOFILE(HFILE1/MBDPL01)
             OVRDBF     FILE(FAAPL04) TOFILE(HFILE1/FAAPL04)
             OVRDBF     FILE(FGBPL01) TOFILE(HFILE1/FGBPL01)
             OVRDBF     FILE(AU#PP11) TOFILE(TFILE1/AU#PP11)

             OVRDBF     FILE(AGAPL31) TOFILE(HFILE1/AGAPL31)
             OVRDBF     FILE(FCEPL01) TOFILE(HFILE1/FCEPL01)
             OVRDBF     FILE(AGDPL12) TOFILE(HFILE1/AGDPL12)
             OVRDBF     FILE(AUDPPNO) TOFILE(TFILE1/AUDPPNO)
             OVRDBF     FILE(AH#PL11) TOFILE(HFILE1/AH#PL11)

             CHGVAR     VAR(&PRCD1) VALUE(' ')
             CALL       PGM(AFAR62) PARM(&PRCD1)

             OVRDBF     FILE(AFAPL64) TOFILE(TFILE1/AFAPL64)
             OVRDBF     FILE(AATPL01) TOFILE(HFILE1/AATPL01)
             OVRDBF     FILE(AAFTL06) TOFILE(HFILE1/AAFTL06)
             OVRDBF     FILE(AAAPL01) TOFILE(HFILE1/AAAPL01)

             CHGVAR     VAR(&PRCD2) VALUE(' ')
             CALL       PGM(AFAR67) PARM(&PRCD2)

 END:
             ENDPGM
