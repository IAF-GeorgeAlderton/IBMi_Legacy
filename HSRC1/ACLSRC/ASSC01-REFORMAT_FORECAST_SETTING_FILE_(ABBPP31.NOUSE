             PGM        PARM(&WFILE &WLIBR &WNUKI &WSKRE &WSKHI)
             /*** ASSC01 ****************************/
             /*  設定数予想３か月ファイル再編成   */
             /*       H.ITO          87.10.28       */
             /**************************** ASSC01 ***/
             DCLF       FILE(ASSPW01)
             DCL        VAR(&WSID) TYPE(*CHAR) LEN(10)
             DCL        VAR(&KOTAE) TYPE(*CHAR) LEN(1)
             DCL        VAR(&MBAN) TYPE(*CHAR) LEN(4)
             DCL        VAR(&WFILE) TYPE(*CHAR) LEN(7)
             DCL        VAR(&WLIBR) TYPE(*CHAR) LEN(8)
             DCL        VAR(&WNUKI) TYPE(*CHAR) LEN(8)
             DCL        VAR(&WSKRE) TYPE(*CHAR) LEN(3)
             DCL        VAR(&WSKHI) TYPE(*CHAR) LEN(3)
             DCL        VAR(&WKTIM) TYPE(*CHAR) LEN(6)
             DCL        VAR(&WSTIM) TYPE(*CHAR) LEN(6)
             DCL        VAR(&WRECD) TYPE(*CHAR) LEN(7)
             DCL        VAR(&WKENS) TYPE(*CHAR) LEN(7)
             RTVJOBA    JOB(&WSID)
             CHGVAR     VAR(&PHIZ) VALUE(&WNUKI)

             CHKOBJ     OBJ(ASSACT) OBJTYPE(*DTAARA)
             MONMSG     MSGID(CPF9801) EXEC(GOTO CMDLBL(VTP1))

 VTP2:       SNDPGMMSG  MSG('( G ) OTHER MASTER FILES ARE BEING +
                          REORGANIZED. PLEASE WAIT FOR A WHILE. ') +
                          TOMSGQ(&WSID) MSGTYPE(*INQ) KEYVAR(&MBAN)
             RCVMSG     MSGTYPE(*RPY) MSGKEY(&MBAN) WAIT(*MAX) +
                          MSG(&KOTAE)
             IF         COND((&KOTAE *NE 'G') *AND (&KOTAE *NE 'g')) +
                          THEN(GOTO CMDLBL(VTP2))
             GOTO       SEND

 VTP1:       CRTDTAARA  DTAARA(ASSACT) TYPE(*CHAR) LEN(10) +
                          AUT(*ALL)

             IF         (&WFILE *EQ 'ABBPP01') DO
             GOTO       STP10
             ENDDO

             IF         (&WFILE *EQ 'ABBPP11') DO
             CHGVAR     VAR(&WNAME) VALUE('** DELIVERY NUMBER +
                          SETTING FILE REFORMATION **')
             ENDDO

             IF         (&WFILE *EQ 'ABBPP21') DO
             CHGVAR     VAR(&WNAME) VALUE('** SETTING NO. +
                          EXPECTATION TO PART NO FOR 3MONTHS FILE +
                          REFORMATION **')
             ENDDO

             IF         (&WFILE *EQ 'ABBPP31') DO
             CHGVAR     VAR(&WNAME) VALUE('** SETTING NO. +
                          EXPECTATION USER OTHER 3 MONTHS FILE +
                          REFORMATION **')
             ENDDO

 STP1:       SNDRCVF    DEV(&WSID) RCDFMT(ASSPW011)
             IF         (&IN01 *EQ '1') GOTO END
             CHGVAR     VAR(&IN02) VALUE('0')
             CHGVAR     VAR(&IN99) VALUE('0')

             IF         (&PHIZ *EQ '        ') DO
             CHGVAR     VAR(&IN02) VALUE('1')
             CHGVAR     VAR(&IN99) VALUE('1')
             CHGVAR     VAR(&MSG) VALUE('THE DATE IS NOT INPUT.')
             GOTO       STP1
             ENDDO

             IF         (%SST(&PHIZ 1 4) *LT '1984') GOTO STP2
             IF         (%SST(&PHIZ 5 2) *GT '12') GOTO STP2
             IF         (%SST(&PHIZ 5 2) *LT '01') GOTO STP2
             IF         (%SST(&PHIZ 7 2) *GT '31') GOTO STP2
             IF         (%SST(&PHIZ 7 2) *LT '01') GOTO STP2
             GOTO       STP3
 STP2:       CHGVAR     VAR(&IN02) VALUE('1')
             CHGVAR     VAR(&IN99) VALUE('1')
             CHGVAR     VAR(&MSG) VALUE('THE DATE IS NOT CORRECT.')
             GOTO       STP1

 STP3:       IF         (&IN05 *EQ '0') GOTO STP1
             RTVSYSVAL  SYSVAL(QTIME) RTNVAR(&WKTIM)

             IF         (&WFILE *EQ 'ABBPP11') DO
             GOTO       @EX1
 STP4:       SNDPGMMSG  MSG('( G.I.C ) SET THE BACKUP TAPE IN < +
                          ABBPP11 >') TOMSGQ(QSYSOPR) MSGTYPE(*INQ) +
                          KEYVAR(&MBAN)
             RCVMSG     MSGTYPE(*RPY) MSGKEY(&MBAN) WAIT(*MAX) +
                          MSG(&KOTAE)
             IF         COND((&KOTAE = 'G') *OR (&KOTAE = 'g')) +
                          THEN(GOTO CMDLBL(STP5))
             IF         COND(&KOTAE = 'I') THEN(GOTO CMDLBL(@EX1))
             IF         COND((&KOTAE = 'C') *OR (&KOTAE = 'c')) +
                          THEN(GOTO CMDLBL(END))
             GOTO       STP4

 STP5:       INZTAP     DEV(TAP01) NEWVOL(IAF) CHECK(*NO) +
                          DENSITY(*ULTRIUM4)
             SAVOBJ     OBJ(ABBPP11) LIB(HFILE1) DEV(TAP01) +
                          OBJTYPE(*FILE) VOL(IAF) ENDOPT(*UNLOAD) +
                          CLEAR(*ALL) PRECHK(*YES) ACCPTH(*YES)
 @EX1:       ENDDO

             IF         (&WFILE *EQ 'ABBPP21') DO
             GOTO       @EX2

 STP7:       SNDPGMMSG  MSG('( G.I.C ) SET THE BACKUP TAPE IN < +
                          ABBPP21 >') TOMSGQ(QSYSOPR) MSGTYPE(*INQ) +
                          KEYVAR(&MBAN)
             RCVMSG     MSGTYPE(*RPY) MSGKEY(&MBAN) WAIT(*MAX) +
                          MSG(&KOTAE)
             IF         COND((&KOTAE = 'G') *OR (&KOTAE = 'g')) +
                          THEN(GOTO CMDLBL(STP8))
             IF         COND(&KOTAE = 'I') THEN(GOTO CMDLBL(@EX2))
             IF         COND((&KOTAE = 'C') *OR (&KOTAE = 'c')) +
                          THEN(GOTO CMDLBL(END))
             GOTO       STP7

 STP8:       INZTAP     DEV(TAP01) NEWVOL(IAF) CHECK(*NO) +
                          DENSITY(*ULTRIUM4)
             SAVOBJ     OBJ(ABBPP21) LIB(HFILE1) DEV(TAP01) +
                          OBJTYPE(*FILE) VOL(IAF) ENDOPT(*UNLOAD) +
                          CLEAR(*ALL) PRECHK(*YES) ACCPTH(*YES)
 @EX2:       ENDDO

             IF         (&WFILE *EQ 'ABBPP31') DO
             GOTO       STP10

 @STP7:      SNDPGMMSG  MSG('( G.I.C ) SET THE BACKUP TAPE IN < +
                          ABBPP31 >') TOMSGQ(QSYSOPR) MSGTYPE(*INQ) +
                          KEYVAR(&MBAN)
             RCVMSG     MSGTYPE(*RPY) MSGKEY(&MBAN) WAIT(*MAX) +
                          MSG(&KOTAE)
             IF         COND((&KOTAE = 'G') *OR (&KOTAE = 'g')) +
                          THEN(GOTO CMDLBL(@STP8))
             IF         COND(&KOTAE = 'I') THEN(GOTO CMDLBL(STP10))
             IF         COND((&KOTAE = 'C') *OR (&KOTAE = 'c')) +
                          THEN(GOTO CMDLBL(END))
             GOTO       @STP7

 @STP8:      INZTAP     DEV(TAP01) NEWVOL(IAF) CHECK(*NO) +
                          DENSITY(*ULTRIUM4)
             SAVOBJ     OBJ(ABBPP31) LIB(HFILE1) DEV(TAP01) +
                          OBJTYPE(*FILE) VOL(IAF) ENDOPT(*UNLOAD) +
                          CLEAR(*ALL) PRECHK(*YES) ACCPTH(*YES)
             ENDDO

 STP10:      CLRPFM     FILE(ASSWP0A)
             CLRPFM     FILE(ASSWP0B)
             CLRPFM     FILE(ASSWP0C)
             CLRPFM     FILE(ASSWP0D)

             IF         (&WFILE *EQ 'ABBPP01') DO
             RTVSYSVAL  SYSVAL(QTIME) RTNVAR(&WKTIM)
             GOTO       STP13

 STP11:      SNDPGMMSG  MSG('( G.I.C ) SET THE BACKUP TAPE IN < +
                          ABBPP01 >') TOMSGQ(QSYSOPR) MSGTYPE(*INQ) +
                          KEYVAR(&MBAN)
             RCVMSG     MSGTYPE(*RPY) MSGKEY(&MBAN) WAIT(*MAX) +
                          MSG(&KOTAE)
             IF         COND((&KOTAE = 'G') *OR (&KOTAE = 'g')) +
                          THEN(GOTO CMDLBL(STP12))
             IF         COND(&KOTAE = 'I') THEN(GOTO CMDLBL(STP13))
             IF         COND((&KOTAE = 'C') *OR (&KOTAE = 'c')) +
                          THEN(GOTO CMDLBL(END))
             GOTO       STP11

 STP12:      INZTAP     DEV(TAP01) NEWVOL(IAF) CHECK(*NO) +
                          DENSITY(*ULTRIUM4)
             SAVOBJ     OBJ(ABBPP01) LIB(HFILE1) DEV(TAP01) +
                          OBJTYPE(*FILE) VOL(IAF) ENDOPT(*UNLOAD) +
                          CLEAR(*ALL) PRECHK(*YES) ACCPTH(*YES)

 STP13:      DLTF       FILE(VJBWP15)
             MONMSG     MSGID(CPF3261 CPF2105)
             DSPFD      FILE(ABBPP01) TYPE(*MBR) OUTPUT(*OUTFILE) +
                          FILEATR(*PF) OUTFILE(HWFILE1/VJBWP15)
             CALL       PGM(VJBR15) PARM(&WRECD &WKENS)
             DLTF       FILE(VJBWP15)

             CALL       PGM(ASSR01) PARM(&PHIZ &WFILE &WRECD &WKENS)
             CPYF       FROMFILE(ASSWP0A) TOFILE(ABBPP01) +
                          MBROPT(*REPLACE) FMTOPT(*DROP *MAP)
             MONMSG     MSGID(CPF2817)
             CLRPFM     ASSWP0A
             ENDDO

             IF         (&WFILE *EQ 'ABBPP11') DO
             CALL       PGM(ASSR01) PARM(&PHIZ &WFILE &WRECD &WKENS)
             CPYF       FROMFILE(ASSWP0B) TOFILE(ABBPP11) +
                          MBROPT(*REPLACE) FMTOPT(*DROP *MAP)
             MONMSG     MSGID(CPF2817)
             CLRPFM     FILE(ASSWP0B)
             ENDDO

             IF         (&WFILE *EQ 'ABBPP21') DO
             CALL       PGM(ASSR01) PARM(&PHIZ &WFILE &WRECD &WKENS)
             CPYF       FROMFILE(ASSWP0C) TOFILE(ABBPP21) +
                          MBROPT(*REPLACE) FMTOPT(*DROP *MAP)
             MONMSG     MSGID(CPF2817)
             CLRPFM     FILE(ASSWP0C)
             ENDDO

             IF         (&WFILE *EQ 'ABBPP31') DO
             CALL       PGM(ASSR01) PARM(&PHIZ &WFILE &WRECD &WKENS)
             CPYF       FROMFILE(ASSWP0D) TOFILE(ABBPP31) +
                          MBROPT(*REPLACE) FMTOPT(*DROP *MAP)
             MONMSG     MSGID(CPF2817)
             CLRPFM     FILE(ASSWP0D)
             ENDDO

             RTVSYSVAL  SYSVAL(QTIME) RTNVAR(&WSTIM)
             CHGVAR     VAR(&WNUKI) VALUE(&PHIZ)

             CALL       PGM(VJBR14) PARM(&WFILE &WNUKI &WKTIM &WSTIM +
                          &WRECD &WKENS)

 END:        DLTDTAARA  DTAARA(ASSACT)

 SEND:       ENDPGM
