             PGM

             DCL        VAR(&CNT) TYPE(*DEC) LEN(2) VALUE(0)
             DCL        VAR(&RPY) TYPE(*CHAR) LEN(1)

             CHGVAR     VAR(&CNT) VALUE(0)

             OVRDBF     FILE(AFAWP15) TOFILE(TWFILE1/AFAWP15)
             OVRDBF     FILE(FCEPL01) TOFILE(HFILE1/FCEPL01)

             CALL       PGM(HOBJ1/AFAR17) PARM(&CNT)
             IF         COND(&CNT = 0) THEN(GOTO CMDLBL(END))

             OVRDBF     FILE(AFAWP15) TOFILE(TWFILE1/AFAWP15)
             OVRDBF     FILE(FGBPL01) TOFILE(HFILE1/FGBPL01)
             OVRDBF     FILE(OUTF1)   TOFILE(TFILE1/AAA0111)

             CLRPFM     FILE(TFILE1/AAA0111)

 @0601XX:    CALL       PGM(HOBJ1/AFAR14)
             MONMSG     MSGID(CPF0000) EXEC(DO)
             SNDUSRMSG  +
                          MSG('ERROR PGM(AFAR14) HANDLING +
                          IAF(0111) DATA. +
                          < RETRY-R +
                          CANCEL-C >') VALUES('R' 'C') +
                          MSGTYPE(*INQ) TOMSGQ(QSYSOPR) MSGRPY(&RPY)
             IF         COND((&RPY *EQ 'R') *OR (&RPY *EQ 'r')) +
                          THEN(GOTO CMDLBL(@0601XX))
             RETURN
             ENDDO

 END:
             ENDPGM
