 PGM     PARM(&SHIFT)

/** AFAC71 ************************************************/
/*  COMBINED PARTIAL DAILY+SHIFT DETAIL LIST              */
/*                                                        */
/* TCHK1  : 11/18/08 CREATE                               */
/**********************************************************/

             DCL        VAR(&USER)  TYPE(*CHAR) LEN(10)
             DCL        VAR(&WSID)  TYPE(*CHAR) LEN(10)
             DCL        VAR(&NBR)   TYPE(*CHAR) LEN(6)
             DCL        VAR(&RSLT)  TYPE(*CHAR) LEN(1)
             DCL        VAR(&SHIFT) TYPE(*CHAR) LEN(1)

             RTVJOBA    JOB(&WSID) USER(&USER) NBR(&NBR)

             OVRPRTF    FILE(QPRINT) OUTQ(SAVEOUTQ) HOLD(*YES)

             CALL       PGM(AFAR71) PARM(&SHIFT &RSLT)

             DLTOVR     FILE(QPRINT)

             IF         (&RSLT *EQ '1') THEN(DO)
             CPYSPLF    FILE(QPRINT) TOFILE(HWFILE1/PRT132A) +
                          JOB(&NBR/&USER/&WSID) SPLNBR(*LAST)
             OVRDBF     FILE(PRT132) TOFILE(HWFILE1/PRT132A)
             CALL       PGM(AB#RW0)
             SNDDST     TYPE(*FILE) +
                          TOINTNET((Dreama.Hamilton@iafi.com) +
                          (Katsunori.Tanebe@iafi.com *CC)) +
                          DSTD('Combine Partial Scan Result  List') +
                          MSG('Please check attached list. +
                          (AFAC71)') DOCFILE(HWFILE1/PRT132A) +
                          DOCTYPE(*FFT) SNDFMT(*NOTE) DOCD('Combine +
                          Partial Scan Result  List.')
             DLTOVR     FILE(PRT132)
             ENDDO

             DLTOVR     FILE(*ALL)

 ENDPGM
