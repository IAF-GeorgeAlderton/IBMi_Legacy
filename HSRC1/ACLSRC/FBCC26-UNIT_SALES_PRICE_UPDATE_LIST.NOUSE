             PGM
             /** FBCC26 ************************************/
             /* UNIT SALES PRICE UPDATE LIST 単価一括変更*/
             /*    I-HASADA                    2000.09.27  */
             /************************************ FBCC26 **/
             DCL        VAR(&USER)   TYPE(*CHAR) LEN(10)
             DCL        VAR(&WSID) TYPE(*CHAR) LEN(10)
             DCL        VAR(&PRT) TYPE(*CHAR) LEN(7)
             DCL        VAR(&TYPE) TYPE(*CHAR) LEN(1)
             DCL        VAR(&PRTG) TYPE(*CHAR) LEN(10)
             DCL        VAR(&WLIB) TYPE(*CHAR) LEN(8)
             RTVJOBA    JOB(&WSID) USER(&USER)
             CHGJOB     SWS(00000000)

             CALL       PGM(AGAR00) PARM(&WSID &PRT &TYPE &PRTG)

             CALL       PGM(ALBC00) PARM(&USER &WLIB)

             DLTF       FILE(FBCWP26)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(&WLIB/FBCWP26) RCDLEN(100) +
                          OPTION(*NOLIST) SIZE(100000 10000 3) +
                          LVLCHK(*NO)

      /*     CALL       PGM(FBCR26)    */
             CALL       PGM(FBCR98)

             IF         (%SWITCH(0XXXXXXX)) DO
             DLTF       FILE(FBCWP26)
             GOTO       END
             ENDDO

             DLTF       FILE(FBCWP27)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(&WLIB/FBCWP27) RCDLEN(100) +
                          OPTION(*NOLIST) SIZE(100000 10000 3) +
                          LVLCHK(*NO)

             FMTDTA     INFILE((&WLIB/FBCWP26)) +
                          OUTFILE(&WLIB/FBCWP27) +
                          SRCFILE(HSRC1/FMTSRC) SRCMBR(FBCS27) +
                          OPTION(*NOPRT)
             DLTF       FILE(FBCWP26)

             DLTF       FILE(FBCWP28)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(&WLIB/FBCWP28) RCDLEN(100) +
                          OPTION(*NOLIST) SIZE(100000 10000 3) +
                          LVLCHK(*NO)

             CALL       PGM(FBCR27)
             DLTF       FILE(FBCWP27)

             OVRPRTF    FILE(QPRINT) LPI(6) RPLUNPRT(*YES) +
                          OUTQ(&PRTG) FORMTYPE(K6H1)
             CALL       PGM(FBCR28) PARM(&USER)
             DLTF       FILE(FBCWP28)
             DLTOVR     FILE(*ALL)

 END:        ENDPGM
