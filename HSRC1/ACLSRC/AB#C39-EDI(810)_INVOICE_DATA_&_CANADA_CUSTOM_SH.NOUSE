             PGM        PARM(&PSIRE &PSIRK &PNOHZ &PWEIG &PNOBN &STM +
                          &PSCAC &PTRAN)
             /** AB#C39 *****************************************/
             /*  ..EDI(810) INVOICE DATA & CANADA CUSTOM SHEET  */
             /*       I-HASADA                   97.06.26       */
             /*       TCH 2000.05.22 NUMBER OF PAGES FROM MASTER*/
             /*       TCH 2000.08.04 ADD ASC, INC.              */
             /*       TCH 2000.09.22 ADD TMMWV                  */
             /*       TCH 2001.07.27 ADD AWNC                   */
             /*       TCH 2002.05.15 ADD SHIP TIME              */
             /*       TCH 2002.06.26 SIA                        */
             /*       TCH 2002.10.03 TISA, TOYOTETSU            */
             /*       TCH 2002.10.29 TMMAL                      */
             /***************************************** AB#C39 **/
             DCL        VAR(&WSID) TYPE(*CHAR) LEN(10)
             DCL        VAR(&USER) TYPE(*CHAR) LEN(10)
             DCL        VAR(&PRT) TYPE(*CHAR) LEN(7)
             DCL        VAR(&TYPE) TYPE(*CHAR) LEN(1)
             DCL        VAR(&PRTG) TYPE(*CHAR) LEN(10)
             DCL        VAR(&KOTAE) TYPE(*CHAR) LEN(1)
             DCL        VAR(&MBAN) TYPE(*CHAR) LEN(4)
             DCL        VAR(&PFLG) TYPE(*CHAR) LEN(1)
             DCL        VAR(&PSIRE) TYPE(*CHAR) LEN(4)
             DCL        VAR(&PSIRK) TYPE(*CHAR) LEN(1)
             DCL        VAR(&PNOHZ) TYPE(*CHAR) LEN(8)
             DCL        VAR(&PNOBN) TYPE(*CHAR) LEN(1)
             DCL        VAR(&PWEIG) TYPE(*DEC) LEN(5 2)
             DCL        VAR(&PDEVT) TYPE(*CHAR) LEN(6)
             DCL        VAR(&PIGCD) TYPE(*CHAR) LEN(4)
             DCL        VAR(&PNOBI) TYPE(*DEC) LEN(1)
             DCL        VAR(&PMANI) TYPE(*CHAR) LEN(18)
             DCL        VAR(&PPALT) TYPE(*CHAR) LEN(7)
             DCL        VAR(&PPICK) TYPE(*DEC)  LEN(2)
             DCL        VAR(&PCUST) TYPE(*DEC)  LEN(2)
             DCL        VAR(&PTYPE) TYPE(*CHAR) LEN(2)
             DCL        VAR(&PGROS) TYPE(*DEC) LEN(10 0)
             DCL        VAR(&TRAN)  TYPE(*CHAR) LEN(30)
             DCL        VAR(&CTYP)  TYPE(*CHAR) LEN(2)
             DCL        VAR(&PCNAM) TYPE(*CHAR) LEN(10)
             DCL        VAR(&WLIB)  TYPE(*CHAR) LEN(8)
             DCL        VAR(&STM)  TYPE(*CHAR) LEN(4)
             DCL        VAR(&BIN) TYPE(*DEC)  LEN(1)
             DCL        VAR(&PSCAC)  TYPE(*CHAR) LEN(4)
             DCL        VAR(&PTRAN)  TYPE(*CHAR) LEN(1)

             CHGVAR     VAR(&PPICK) VALUE(0)
             CHGVAR     VAR(&PCUST) VALUE(0)
             CHGVAR     VAR(&PTYPE) VALUE('  ')

             IF         COND(&PNOBN *EQ ' ') THEN(CHGVAR VAR(&PNOBN) +
                          VALUE('1'))
             CHGVAR     VAR(&BIN) VALUE(&PNOBN)

             RTVJOBA    JOB(&WSID) USER(&USER)
             CHGJOB     SWS(00000000)

             CALL       PGM(AGAR01) PARM(&WSID &PDEVT &PIGCD)

             CALL       PGM(AGAR00) PARM(&WSID &PRT &TYPE &PRTG)

             CALL       PGM(ALBC00) PARM(&USER &WLIB)

             DLTF       FILE(AB#WP38)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(&WLIB/AB#WP38) RCDLEN(100) +
                          OPTION(*NOLIST *NOSRC) LVLCHK(*NO) AUT(*ALL)

             DLTF       FILE(AB#WP381)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(&WLIB/AB#WP381) RCDLEN(100) +
                          OPTION(*NOLIST *NOSRC) LVLCHK(*NO) AUT(*ALL)

             DLTF       FILE(AB#WP382)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(&WLIB/AB#WP382) RCDLEN(100) +
                          OPTION(*NOLIST *NOSRC) LVLCHK(*NO) AUT(*ALL)

             DLTF       FILE(AB#WP383)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(&WLIB/AB#WP383) RCDLEN(128) +
                          OPTION(*NOLIST *NOSRC) LVLCHK(*NO) AUT(*ALL)


/* CREATE EDI810 W/F(=INPUT FILE OF CUSTOM SHEET)      */
             CHGVAR     VAR(&PFLG) VALUE(' ')
             CALL       PGM(AB#R38) PARM(&PSIRE &PSIRK &PNOHZ &PNOBN +
                          &PFLG)

             IF         (%SWITCH(0XXXXXXX)) DO
 STP4:       SNDPGMMSG  MSG('( G ) THERE IS NO DATA CORRESPONDS TO +
                          FRS.  < G-ENTER >') TOMSGQ(&WSID) +
                          MSGTYPE(*INQ) KEYVAR(&MBAN)
             RCVMSG     MSGTYPE(*RPY) MSGKEY(&MBAN) WAIT(*MAX) +
                          MSG(&KOTAE)
             IF         COND((&KOTAE = 'G') *OR (&KOTAE = 'g')) +
                          THEN(GOTO CMDLBL(END))
             GOTO       STP4
             ENDDO


/* CREATE TMMC 810 */
             IF         COND(&PSIRE *EQ '3503' *OR &PSIRE *EQ +
                          '3504') THEN(DO)
             DLTF       FILE(AB#WP47)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(&WLIB/AB#WP47) RCDLEN(100) +
                          OPTION(*NOLIST) LVLCHK(*NO) AUT(*ALL)

             FMTDTA     INFILE((&WLIB/AB#WP381)) +
                          OUTFILE(&WLIB/AB#WP47) +
                          SRCFILE(HSRC1/FMTSRC) SRCMBR(AB#S47) +
                          OPTION(*NOPRT)
             DLTF       FILE(AB#WP381)

             CALL       PGM(AB#R47)

             ENDDO

/* CREATE NUMMI810 */
             IF         COND(&PSIRE *EQ '0541' *OR &PSIRE *EQ +
                          '0542') THEN(DO)
             DLTF       FILE(AB#WP47)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(&WLIB/AB#WP47) RCDLEN(100) +
                          OPTION(*NOLIST) LVLCHK(*NO) AUT(*ALL)

             FMTDTA     INFILE((&WLIB/AB#WP381)) +
                          OUTFILE(&WLIB/AB#WP47) +
                          SRCFILE(HSRC1/FMTSRC) SRCMBR(AB#S47) +
                          OPTION(*NOPRT)
             DLTF       FILE(AB#WP381)

             CALL       PGM(AB#R4E)

             ENDDO


/* SIA 856 */
             IF         COND(&PSIRE *EQ '0437' *OR &PSIRE *EQ +
                          '0590') THEN(DO)
             DLTF       FILE(AB#WP78)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(&WLIB/AB#WP78) RCDLEN(100) +
                          OPTION(*NOLIST) LVLCHK(*NO) AUT(*ALL)

             FMTDTA     INFILE((&WLIB/AB#WP381)) +
                          OUTFILE(&WLIB/AB#WP78) +
                          SRCFILE(HSRC1/FMTSRC) SRCMBR(AB#S47) +
                          OPTION(*NOPRT)
             DLTF       FILE(AB#WP381)

/* GET THE MANIFEST # */
       /*    CHGVAR     VAR(&PNOBI) VALUE(0)  */
             CHGVAR     VAR(&PMANI) VALUE('                  ')
             CALL       PGM(AB#R95) PARM(&USER &PSIRE &PNOHZ &BIN +
                          &PMANI)

/* CREATE ISUZU856 DATA    */
             OVRDBF     FILE(AB#WP65) TOFILE(AB#WP78)
             CALL       PGM(AB#R78) PARM(&PMANI &PSIRE)
             ENDDO


/* MAP 856 */
             IF         COND(&PSIRE *EQ '4126') THEN(DO)
             DLTF       FILE(AB#WP79)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(&WLIB/AB#WP79) RCDLEN(100) +
                          OPTION(*NOLIST) LVLCHK(*NO) AUT(*ALL)

             FMTDTA     INFILE((&WLIB/AB#WP381)) +
                          OUTFILE(&WLIB/AB#WP79) +
                          SRCFILE(HSRC1/FMTSRC) SRCMBR(AB#S47) +
                          OPTION(*NOPRT)
             DLTF       FILE(AB#WP381)

             CHGVAR     VAR(&PNOBI) VALUE(0)
             CHGVAR     VAR(&PMANI) VALUE('                  ')
/* GET THE MANIFEST #    */
             CALL       PGM(AB#R95) PARM(&USER &PSIRE &PNOHZ &BIN +
                          &PMANI)
             OVRDBF     FILE(AB#WP65) TOFILE(AB#WP79)

/* CREATE MAP 856 DATA  */
             CALL       PGM(AB#R79) PARM(&PMANI &PSIRE &PNOHZ &PWEIG)
             ENDDO

/* TMMK */
             IF         COND(&PSIRE *EQ '3347' *OR &PSIRE *EQ +
                          '3348') THEN(DO)

             DLTF       FILE(AB#WP7B)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(&WLIB/AB#WP7B) RCDLEN(128) +
                          OPTION(*NOLIST) LVLCHK(*NO) AUT(*ALL)

             FMTDTA     INFILE((&WLIB/AB#WP383)) +
                          OUTFILE(&WLIB/AB#WP7B) +
                          SRCFILE(HSRC1/FMTSRC) SRCMBR(AB#S7B) +
                          OPTION(*NOPRT)
             DLTF       FILE(AB#WP383)

             OVRDBF     FILE(AB#WP65) TOFILE(AB#WP7B)
             CALL       PGM(AB#R7C) PARM(&PPALT)
             OVRDBF     FILE(AB#WP65) TOFILE(AB#WP7B)
             CALL       PGM(AB#R7B) PARM(&PSIRE &PNOBN &PPALT &STM)
             ENDDO

/* TMMWV */
             IF         COND(&PSIRE *EQ '3931' *OR &PSIRE *EQ +
                          '3932') THEN(DO)

             DLTF       FILE(AB#WP7F)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(&WLIB/AB#WP7F) RCDLEN(128) +
                          OPTION(*NOLIST) LVLCHK(*NO) AUT(*ALL)

             FMTDTA     INFILE((&WLIB/AB#WP383)) +
                          OUTFILE(&WLIB/AB#WP7F) +
                          SRCFILE(HSRC1/FMTSRC) SRCMBR(AB#S7B) +
                          OPTION(*NOPRT)
             DLTF       FILE(AB#WP383)

             OVRDBF     FILE(AB#WP65) TOFILE(AB#WP7F)
             CALL       PGM(AB#R7C) PARM(&PPALT)
             OVRDBF     FILE(AB#WP65) TOFILE(AB#WP7F)
             CALL       PGM(AB#R7F) PARM(&PSIRE &PNOBN &PPALT)
             ENDDO
/* TMMI */
             IF         COND(&PSIRE *EQ '3804' *OR &PSIRE *EQ +
                          '3805') THEN(DO)

             DLTF       FILE(AB#WP7F)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(&WLIB/AB#WP7F) RCDLEN(128) +
                          OPTION(*NOLIST) LVLCHK(*NO) AUT(*ALL)

             FMTDTA     INFILE((&WLIB/AB#WP383)) +
                          OUTFILE(&WLIB/AB#WP7F) +
                          SRCFILE(HSRC1/FMTSRC) SRCMBR(AB#S7B) +
                          OPTION(*NOPRT)
             DLTF       FILE(AB#WP383)

             OVRDBF     FILE(AB#WP65) TOFILE(AB#WP7F)
             CALL       PGM(AB#R7C) PARM(&PPALT)
             OVRDBF     FILE(AB#WP65) TOFILE(AB#WP7F)
             CALL       PGM(AB#R7G) PARM(&PSIRE &PNOBN &PPALT)
             ENDDO
/* TMMAL */
             IF         COND(&PSIRE *EQ '3765') THEN(DO)

             DLTF       FILE(QTEMP/AB#WP7F)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(QTEMP/AB#WP7F) RCDLEN(128) +
                          OPTION(*NOLIST) LVLCHK(*NO) AUT(*ALL)

             FMTDTA     INFILE((&WLIB/AB#WP383)) +
                          OUTFILE(QTEMP/AB#WP7F) +
                          SRCFILE(HSRC1/FMTSRC) SRCMBR(AB#S7B) +
                          OPTION(*NOPRT)
             DLTF       FILE(AB#WP383)

             OVRDBF     FILE(AB#WP65) TOFILE(QTEMP/AB#WP7F)
             CALL       PGM(AB#R7C) PARM(&PPALT)
             OVRDBF     FILE(AB#WP65) TOFILE(AB#WP7F)
             CALL       PGM(AB#R7I) PARM(&PSIRE &PNOBN &PPALT)
             ENDDO

/* AWNC  */
             IF         COND(&PSIRE *EQ '0492') THEN(DO)

             DLTF       FILE(AB#WP7H)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(&WLIB/AB#WP7H) RCDLEN(128) +
                          OPTION(*NOLIST) LVLCHK(*NO) AUT(*ALL)

             FMTDTA     INFILE((&WLIB/AB#WP383)) +
                          OUTFILE(&WLIB/AB#WP7H) +
                          SRCFILE(HSRC1/FMTSRC) SRCMBR(AB#S7B) +
                          OPTION(*NOPRT)
             DLTF       FILE(AB#WP383)

             OVRDBF     FILE(AB#WP65) TOFILE(AB#WP7H)
             CALL       PGM(AB#R7C) PARM(&PPALT)
             OVRDBF     FILE(AB#WP65) TOFILE(AB#WP7H)
             CALL       PGM(AB#R7H) PARM(&PSIRE &PNOBN &PPALT)
             ENDDO
/* TAKATA */
             IF         COND((&PSIRE *EQ '3656') *OR +
                        (&PSIRE *EQ '3712')) THEN(DO)

             IF         COND(&PSIRE *EQ '3656') THEN(DO)
             OVRDBF     FILE(OUTPUT) TOFILE(EDI856TT)
             ENDDO

             IF         COND(&PSIRE *EQ '3712') THEN(DO)
             OVRDBF     FILE(OUTPUT) TOFILE(EDI856TX)
             ENDDO

             DLTF       FILE(AB#WP7D)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(&WLIB/AB#WP7D) RCDLEN(128) +
                          OPTION(*NOLIST) LVLCHK(*NO) AUT(*ALL)

             FMTDTA     INFILE((&WLIB/AB#WP383)) +
                          OUTFILE(&WLIB/AB#WP7D) +
                          SRCFILE(HSRC1/FMTSRC) SRCMBR(AB#S7D) +
                          OPTION(*NOPRT)
             DLTF       FILE(AB#WP383)

             OVRDBF     FILE(AB#WP65) TOFILE(AB#WP7D)
             CHGVAR     VAR(&PNOBI) VALUE(0)
             CHGVAR     VAR(&PMANI) VALUE('                  ')
/* GET THE MANIFEST #    */
             CALL       PGM(AB#R95) PARM(&USER &PSIRE &PNOHZ &BIN +
                          &PMANI)
             CALL       PGM(AB#R7E) PARM(&PPALT &PWEIG &PGROS)
             CALL       PGM(AB#R7D) PARM(&PSIRE &PNOHZ &PGROS &PPALT +
                          &PMANI)
             ENDDO
/* TISA */
             IF         COND(&PSIRE *EQ '0701') THEN(DO)

             DLTF       FILE(QTEMP/AB#WP7F)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(QTEMP/AB#WP7F) RCDLEN(128) +
                          OPTION(*NOLIST) LVLCHK(*NO) AUT(*ALL)

             FMTDTA     INFILE((&WLIB/AB#WP383)) +
                          OUTFILE(QTEMP/AB#WP7F) +
                          SRCFILE(HSRC1/FMTSRC) SRCMBR(AB#S7B) +
                          OPTION(*NOPRT)
             DLTF       FILE(AB#WP383)

             OVRDBF     FILE(AB#WP65) TOFILE(QTEMP/AB#WP7F)
             CALL       PGM(AB#R7J) PARM(&PSIRE &PNOBN &STM &PSCAC +
                          &PTRAN)
             ENDDO
/* TOYOTETSU */
             IF         COND(&PSIRE *EQ '3556' *OR &PSIRE *EQ +
                          '3550') THEN(DO)

             DLTF       FILE(QTEMP/AB#WP7F)
             MONMSG     MSGID(CPF3261 CPF2105)
             CRTPF      FILE(QTEMP/AB#WP7F) RCDLEN(128) +
                          OPTION(*NOLIST) LVLCHK(*NO) AUT(*ALL)

             FMTDTA     INFILE((&WLIB/AB#WP383)) +
                          OUTFILE(QTEMP/AB#WP7F) +
                          SRCFILE(HSRC1/FMTSRC) SRCMBR(AB#S7B) +
                          OPTION(*NOPRT)
             DLTF       FILE(AB#WP383)

             OVRDBF     FILE(AB#WP65) TOFILE(QTEMP/AB#WP7F)
             CALL       PGM(AB#R7C) PARM(&PPALT)
             OVRDBF     FILE(AB#WP65) TOFILE(QTEMP/AB#WP7F)
             CALL       PGM(AB#R7K) PARM(&PSIRE &PNOBN &PPALT &STM  +
                          &PSCAC &PTRAN)
             ENDDO

 END:
             DLTOVR     FILE(*ALL)
             ENDPGM
