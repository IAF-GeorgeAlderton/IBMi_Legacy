            PGM
            /** IBKC08 *************************************/
            /*  型メーカ行き型番リスト ( AOYAMA-->IAF )  */
            /*     A.IDOTA               2006.07.31        */
            /************************************* IBKC08 **/

            DLTF       FILE(APSAVLIB/FOAWP03)
            MONMSG     MSGID(CPF3261 CPF2105)

            CRTSAVF    FILE(APSAVLIB/FOAWP03) AUT(*ALL)

            RCVNETF    FROMFILE(FOAWP03) TOFILE(APSAVLIB/FOAWP03) +
                         USER(QFILE)

            CLRPFM     FILE(FOAWP03)

             RSTOBJ     OBJ(FOAWP03) SAVLIB(WORKLIB) DEV(*SAVF) +
                          OBJTYPE(*FILE) SAVF(APSAVLIB/FOAWP03) +
                          MBROPT(*ALL) ALWOBJDIF(*ALL) +
                          FRCOBJCVN(*YES) RSTLIB(HWFILE1)
             MONMSG     MSGID(CPF3773)

             DLTF       FILE(APSAVLIB/FOAWP03)

             CALL       PGM(IBKR08)
             CLRPFM     FILE(FOAWP03)

             ENDPGM
