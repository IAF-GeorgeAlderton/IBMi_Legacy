             PGM
             /** SNDC20  *********************************************/
             /*  SET DATA AND SEND BODY(997) BY MAIL                 */
             /*  J.W  2025.10.27                                     */
             /********************************************************/

             DCL        VAR(&TOEMAIL) TYPE(*CHAR) LEN(100)
             DCL        VAR(&SUBJECT) TYPE(*CHAR) LEN(100)
             DCL        VAR(&STMF)    TYPE(*CHAR) LEN(100)

/* SEND TO EMAIL ADDRESS                                                  */
             CHGVAR     VAR(&TOEMAIL) VALUE('AS400-SYSTEM@IAFI.COM')
/* SUBJECT OF EMAIL                                                       */
             CHGVAR     VAR(&SUBJECT) VALUE('EDI (FORD997) OK - GENTRAN')
/* IFS STREAM FILE                                                        */
             CHGVAR     VAR(&STMF) +
                          VALUE('/QNTC/IAF-AS400-FILE/AS400-TRANS/PC/D+
                          OWNLOAD/FORD/')

/* DOWNLOAD QPRINT TO &STMF                                               */
             CALL SNDC21  (&TOEMAIL &SUBJECT &STMF)

/* UPLOAD &STMF TO BODY(997) AND SEND MAIL                                */
             CALL SNDC22  (&TOEMAIL &SUBJECT &STMF)

             ENDPGM
