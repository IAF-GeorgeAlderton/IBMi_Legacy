  PGM PARM(&PB0111 &PI0111 &DAY)

             DCL        VAR(&PB0111) TYPE(*CHAR) LEN(4)
             DCL        VAR(&PI0111) TYPE(*CHAR) LEN(2)
             DCL        VAR(&DAY)    TYPE(*CHAR) LEN(8)
             DCL        VAR(&PRTER)  TYPE(*CHAR) LEN(1)

/*           CPYF FROMFILE(HFILE1/AGAPP31) +  */
/*                TOFILE(TFILE1/AGAPP31)   +  */
/*                MBROPT(*REPLACE)         +  */
/*                FMTOPT(*NOCHK)              */
/*                                            */
/*           CPYF FROMFILE(HFILE1/ADAPP60) +  */
/*                TOFILE(TFILE1/ADAPP60)   +  */
/*                MBROPT(*REPLACE)         +  */
/*                FMTOPT(*NOCHK)              */

             CLRPFM     FILE(TWFILE1/AFAWP12)

             OVRDBF     FILE(AGAPP31) TOFILE(TFILE1/AGAPP31)

             OVRDBF     FILE(AAMPL11) TOFILE(HFILE1/AAMPL11)
             OVRDBF     FILE(AAJPL11) TOFILE(HFILE1/AAJPL11)
             OVRDBF     FILE(FCEPL01) TOFILE(HFILE1/FCEPL01)
             OVRDBF     FILE(AAFPL03) TOFILE(HFILE1/AAFPL03)
             OVRDBF     FILE(AAGPL03) TOFILE(HFILE1/AAGPL03)
             OVRDBF     FILE(AAHPL03) TOFILE(HFILE1/AAHPL03)
             OVRDBF     FILE(AAPPL03) TOFILE(HFILE1/AAPPL03)
             OVRDBF     FILE(AAWTL11) TOFILE(HFILE1/AAWTL11)
             OVRDBF     FILE(ACAPL11) TOFILE(HFILE1/ACAPL11)
             OVRDBF     FILE(OABPL01) TOFILE(HFILE1/OABPL01)
             OVRDBF     FILE(OACPL01) TOFILE(HFILE1/OACPL01)
             OVRDBF     FILE(MBDPL01) TOFILE(HFILE1/MBDPL01)
             OVRDBF     FILE(FAAPL04) TOFILE(HFILE1/FAAPL04)
             OVRDBF     FILE(AHDPP60) TOFILE(HFILE1/AHDPP60)

             OVRDBF     FILE(AFAWP12) TOFILE(TWFILE1/AFAWP12)

             CALL       PGM(TOBJ1/AFAR12@) PARM(&PB0111 &PI0111 &DAY)

             OVRDBF     FILE(ADAPL62) TOFILE(TFILE1/ADAPL62)
             OVRDBF     FILE(AGAPL31) TOFILE(TFILE1/AGAPL31)

             OVRPRTF    FILE(QPRINT) DEVTYPE(*SCS) LPI(6) +
                          RPLUNPRT(*YES) OUTQ(QDKT) FORMTYPE(K6H1) +
                          IGCDTA(*NO)

             CHGVAR     VAR(&PRTER) VALUE(' ')
             CALL  PGM(TOBJ1/AFAR32@) PARM(&DAY &PB0111 &PI0111 &PRTER)

             ENDPGM
