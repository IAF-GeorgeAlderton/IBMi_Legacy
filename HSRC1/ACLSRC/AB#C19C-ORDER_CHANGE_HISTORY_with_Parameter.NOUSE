             PGM        PARM(&SDAT &EDAT &SHN1 &SHN2 &SHN3)
             /***AB#C19********************************************/
             /* ORDER CHANGE HISTORY                                   -EDP */
             /*         JAN/22/2004  TCH                          */
             /*                                                   */
             /* TCHK1 08/20/14 ADD WORK-FILE FOR DISPLAYSEQ CHANGE*/
             /*****************************************************/
             DCL        VAR(&WSID) TYPE(*CHAR) LEN(10)
             DCL        VAR(&PRT) TYPE(*CHAR) LEN(7)
             DCL        VAR(&TYPE) TYPE(*CHAR) LEN(1)
             DCL        VAR(&PRTG) TYPE(*CHAR) LEN(10)
             DCL        VAR(&PDEVT) TYPE(*CHAR) LEN(6)
             DCL        VAR(&PIGCD) TYPE(*CHAR) LEN(4)
             DCL        VAR(&USER) TYPE(*CHAR) LEN(10)
             DCL        VAR(&WLIB) TYPE(*CHAR) LEN(8)

             DCL        VAR(&SDAT ) TYPE(*CHAR) LEN(8)
             DCL        VAR(&EDAT ) TYPE(*CHAR) LEN(8)
             DCL        VAR(&SHN1 ) TYPE(*CHAR) LEN(5)
             DCL        VAR(&SHN2 ) TYPE(*CHAR) LEN(5)
             DCL        VAR(&SHN3 ) TYPE(*CHAR) LEN(2)

             RTVJOBA    JOB(&WSID) USER(&USER)

             CALL       PGM(AGAR00) PARM(&WSID &PRT &TYPE &PRTG)
             CALL       PGM(AGAR01) PARM(&WSID &PDEVT &PIGCD)
             CALL       PGM(ALBC00) PARM(&USER &WLIB)

/* TCHK1 S */
             CRTDUPOBJ  OBJ(AB#WHP10) FROMLIB(HWFILE1) +
                          OBJTYPE(*FILE) TOLIB(QTEMP)
             MONMSG     MSGID(CPF0000)
             CLRPFM     QTEMP/AB#WHP10
             OVRDBF     FILE(AB#WHP10) TOFILE(QTEMP/AB#WHP10)
/* TCHK1 E */

             CALL       PGM(AB#R19) PARM(&SDAT &EDAT &SHN1 &SHN2 &SHN3)

             ENDPGM
