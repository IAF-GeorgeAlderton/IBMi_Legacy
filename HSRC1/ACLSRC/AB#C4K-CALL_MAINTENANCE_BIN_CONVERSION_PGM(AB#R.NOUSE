             PGM
             /** AB#C4K ***********************************/
             /* CALL BIN CONVERSION TABLE MAINTENANCE PGM  */
             /*    K.KASHIWAGI  2001.02.01                 */
             /************************************ AB#C4K **/
             DCL        VAR(&WSID)  TYPE(*CHAR) LEN(10)
             DCL        VAR(&USER)  TYPE(*CHAR) LEN(10)
             RTVJOBA    JOB(&WSID)  USER(&USER)

             CALL       PGM(AB#R4K) PARM(&USER)

             ENDPGM
