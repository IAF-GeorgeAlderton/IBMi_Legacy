             PGM
             /** IBKC05 **********************************/
             /*  ..DIE ALLOTMENT M/F ( AOYAMA-->IAF )..  */
             /*     I-HASADA                97.02.22     */
             /********************************** IBKC05 **/

             DLTF       FILE(APSAVLIB/GCQWP3Y)
             MONMSG     MSGID(CPF3261 CPF2105)

             CRTSAVF    FILE(APSAVLIB/GCQWP3Y) AUT(*ALL)

             RCVNETF    FROMFILE(GCQWP3Y) TOFILE(APSAVLIB/GCQWP3Y) +
                          USER(QFILE)

             CLRPFM     FILE(GCQWP3Y)

             RSTOBJ     OBJ(GCQWP3Y) SAVLIB(WORKLIB) DEV(*SAVF) +
                          OBJTYPE(*FILE) SAVF(APSAVLIB/GCQWP3Y) +
                          MBROPT(*ALL) ALWOBJDIF(*ALL) +
                          FRCOBJCVN(*YES) RSTLIB(HWFILE1)
             MONMSG     MSGID(CPF3773)

             DLTF       FILE(APSAVLIB/GCQWP3Y)

          /* 追記 CCQWP4Y,Z        2020.10.23 */
             DLTF       FILE(APSAVLIB/CCQWP4Y)
             MONMSG     MSGID(CPF3261 CPF2105)

             CRTSAVF    FILE(APSAVLIB/CCQWP4Y) AUT(*ALL)

             RCVNETF    FROMFILE(CCQWP4Y) TOFILE(APSAVLIB/CCQWP4Y) +
                          USER(QFILE)

             CLRPFM     FILE(CCQWP4Y)

             RSTOBJ     OBJ(CCQWP4Y) SAVLIB(APWRKLIB) DEV(*SAVF) +
                          OBJTYPE(*FILE) SAVF(APSAVLIB/CCQWP4Y) +
                          MBROPT(*ALL) ALWOBJDIF(*ALL) +
                          FRCOBJCVN(*YES) RSTLIB(HWFILE1)
             MONMSG     MSGID(CPF3773)

             DLTF       FILE(APSAVLIB/CCQWP4Y)

             DLTF       FILE(APSAVLIB/CCQWP4Z)
             MONMSG     MSGID(CPF3261 CPF2105)

             CRTSAVF    FILE(APSAVLIB/CCQWP4Z) AUT(*ALL)

             RCVNETF    FROMFILE(CCQWP4Z) TOFILE(APSAVLIB/CCQWP4Z) +
                          USER(QFILE)

             CLRPFM     FILE(CCQWP4Z)

             RSTOBJ     OBJ(CCQWP4Z) SAVLIB(APWRKLIB) DEV(*SAVF) +
                          OBJTYPE(*FILE) SAVF(APSAVLIB/CCQWP4Z) +
                          MBROPT(*ALL) ALWOBJDIF(*ALL) +
                          FRCOBJCVN(*YES) RSTLIB(HWFILE1)
             MONMSG     MSGID(CPF3773)

             DLTF       FILE(APSAVLIB/CCQWP4Z)


          /* GCQWP3Y -> GCQWP3Z  &  (CCQWP4Y,Z -> WK400P0,WK420P0) */
             CALL       PGM(GCQR3W)

             RGZPFM     FILE(WK400P0)
             MONMSG     MSGID(CPF0000)
             RGZPFM     FILE(WK420P0)
             MONMSG     MSGID(CPF0000)

             ENDPGM
