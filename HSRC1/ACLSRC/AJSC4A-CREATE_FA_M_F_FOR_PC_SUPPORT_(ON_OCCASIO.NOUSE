             PGM
             /** AJSC4A **************************************/
             /* CREATE FA M/F FOR PC SUPPORT (ON OCCASION)   */
             /* S.YAMAGAMI              94.04.01             */
             /***************** AJSC40 COPY ******************/
             DCLF       FILE(AJSPW40)
             DCL        VAR(&US)     TYPE(*CHAR) LEN(10)
             DCL        VAR(&PRT)    TYPE(*CHAR) LEN(7)
             DCL        VAR(&WSID)   TYPE(*CHAR) LEN(10)
             DCL        VAR(&TYPE)   TYPE(*CHAR) LEN(1)
             DCL        VAR(&PRTG)   TYPE(*CHAR) LEN(10)
             DCL        VAR(&MBAN)   TYPE(*CHAR) LEN(4)
             DCL        VAR(&ANS)    TYPE(*CHAR) LEN(1)
             DCL        VAR(&KOTAE)  TYPE(*CHAR) LEN(1)
             DCL        VAR(&PDEVT) TYPE(*CHAR) LEN(6)
             DCL        VAR(&PIGCD) TYPE(*CHAR) LEN(4)
             RTVJOBA    JOB(&WSID)   USER(&US)
             CALL       AGAR00 PARM(&WSID &PRT &TYPE &PRTG)
             CALL       PGM(AGAR01) PARM(&WSID &PDEVT &PIGCD)
             CHGVAR     VAR(&PRTG) VALUE('FAOUTQ')
             CHGJOB     OUTQ(&PRTG) RUNPTY(40)

             /* DATA AREA CHECK */
             CHKOBJ     OBJ(HFILE1/FAMASMAK) OBJTYPE(*DTAARA) AUT(*ALL)
             MONMSG     MSGID(CPF9801) EXEC(GOTO CMDLBL(STP2))

 STP1:       SNDPGMMSG  MSG('( G ) IT IS USING AT ANOTHER TV. PLEASE +
                          WAIT FOR A WHILE.') TOMSGQ(&WSID) +
                          MSGTYPE(*INQ) KEYVAR(&MBAN)
             RCVMSG     MSGTYPE(*RPY) MSGKEY(&MBAN) WAIT(*MAX) +
                        MSG(&ANS)

             IF         COND((&ANS *NE 'G') *AND (&ANS *NE 'g')) +
                          THEN(GOTO CMDLBL(STP1))
             GOTO       CMDLBL(END)

 STP2:       CRTDTAARA  DTAARA(HFILE1/FAMASMAK) TYPE(*CHAR) LEN(1) +
                          VALUE('*') AUT(*ALL)


             /*DISPLAY  SCREEN */
             SNDRCVF  DEV(&WSID) RCDFMT(AJSPW401)
             IF         (&IN01 *EQ '1') DO
             DLTDTAARA  DTAARA(HFILE1/FAMASMAK)
             GOTO       CMDLBL(END)
             ENDDO

             /* FA M/F COPY  TO A DISK */

             CLRPFM     FILE(HFILE1/AJSPPBK)
             CPYF       FROMFILE(HFILE1/AJSPP01) +
                          TOFILE(HFILE1/AJSPPBK) MBROPT(*REPLACE) +
                          FMTOPT(*MAP *DROP)
             MONMSG     MSGID(CPF2817)

             /* WORK FILE DELETE */
 STEP4:      DLTF       FILE(HWFILE1/AJSWP40)
             MONMSG     MSGID(CPF3261 CPF2105)
             DLTF       FILE(HWFILE1/AJSWP42)
             MONMSG     MSGID(CPF3261 CPF2105)

             /****************************************/
             /*   DLTF       FILE(HWFILE1/AJSWP41)   */
             /*   MONMSG     MSGID(CPF3261 CPF2105)  */
             /*   DLTF       FILE(HWFILE1/AJSWP46)   */
             /*   MONMSG     MSGID(CPF3261 CPF2105)  */
             /*   DLTF       FILE(HWFILE1/AJSWP48)   */
             /*   MONMSG     MSGID(CPF3261 CPF2105)  */
             /*   DLTF       FILE(HWFILE1/AJSWP49)   */
             /*   MONMSG     MSGID(CPF3261 CPF2105)  */
             /*   DLTF       FILE(HWFILE1/AJSWP4A)   */
             /*   MONMSG     MSGID(CPF3261 CPF2105)  */
             /****************************************/

             /*CREATE WORK FILE */

             CRTPF      FILE(HWFILE1/AJSWP40) RCDLEN(229) TEXT('WORK +
                          FROM FA M/F PLATING KANBAN') +
                          OPTION(*NOLIST) SIZE(10000 3000) +
                          LVLCHK(*NO) AUT(*ALL)
             GRTOBJAUT  OBJ(AJSWP40) OBJTYPE(*FILE) USER(*PUBLIC) +
                          AUT(*ALL)
             CRTPF      FILE(HWFILE1/AJSWP42) RCDLEN(13) TEXT('FA +
                          M/F CHANGE DISKETT WORK') OPTION(*NOLIST) +
                          SIZE(10000 3000) LVLCHK(*NO) AUT(*ALL)
             GRTOBJAUT  OBJ(AJSWP42) OBJTYPE(*FILE) USER(*PUBLIC) +
                          AUT(*ALL)

             /***************************************************************/
             /*   CRTPF      FILE(HWFILE1/AJSWP41) RCDLEN(298) +            */
             /*                TEXT('WORK FROM FA M/F TUNNEL KANBAN') +     */
             /*                OPTION(*NOLIST) SIZE(3000 500) LVLCHK(*NO) + */
             /*                AUT(*ALL)                                    */
             /*   GRTOBJAUT  OBJ(AJSWP41) OBJTYPE(*FILE) USER(*PUBLIC) +    */
             /*                AUT(*ALL)                                    */
             /*   CRTPF      FILE(HWFILE1/AJSWP46) RCDLEN(197) +            */
             /*                TEXT('WORK FROM FA M/F ARRSM/F') +           */
             /*                OPTION(*NOLIST) SIZE(3000 500) LVLCHK(*NO) + */
             /*                AUT(*ALL)                                    */
             /*   GRTOBJAUT  OBJ(AJSWP46) OBJTYPE(*FILE) USER(*PUBLIC) +    */
             /*                AUT(*ALL)                                    */
             /*   CRTPF    FILE(HWFILE1/AJSWP48) RCDLEN(488) +              */
             /*            TEXT('WORK FROM FA M/F INSTRUCTION KANBAN M/F') +*/
             /*              OPTION(*NOLIST) SIZE(3000 500) LVLCHK(*NO) +   */
             /*              AUT(*ALL)                                      */
             /*   GRTOBJAUT  OBJ(AJSWP48) OBJTYPE(*FILE) USER(*PUBLIC) +    */
             /*                AUT(*ALL)                                    */
             /*   CRTPF      FILE(HWFILE1/AJSWP49) RCDLEN(248) +            */
             /*     TEXT('WORK FROM FA M/F COMPONENTS PLATING KANBAN M/F +  */
             /*          ') OPTION(*NOLIST) SIZE(3000 500) +                */
             /*           LVLCHK(*NO) AUT(*ALL)                             */
             /*   GRTOBJAUT  OBJ(AJSWP49) OBJTYPE(*FILE) USER(*PUBLIC) +    */
             /*                AUT(*ALL)                                    */
             /*   CRTPF      FILE(HWFILE1/AJSWP4A) RCDLEN(315) +            */
             /*     TEXT('WORK FROM FAM/F COMPONENTS TUNNEL KANBAN M/F +    */
             /*        ') OPTION(*NOLIST) SIZE(3000 500) +                  */
             /*      LVLCHK(*NO) AUT(*ALL)                                  */
             /*   GRTOBJAUT  OBJ(AJSWP4A) OBJTYPE(*FILE) USER(*PUBLIC) +    */
             /*                AUT(*ALL)                                    */
             /***************************************************************/

             /* WHICH DATA IS INPUT INTO FROM PLATING KANBAN */
             CALL AJSR40

             /****************************************************************/
             /* WHICH DATA IS INPUT INTO FROM TUNNEL KANBAN                  */
             /*       CALL AJSR41                                            */
             /* WHICH DATA IS INPUT INTO FROM  ARRS M/F                      */
             /*       CALL AJSR45                                            */
             /*   WHICH DATA IS INPUT INTO FROM  INSTRUCTION KANBAN M/F      */
             /*         CALL AJSR48                                          */
             /* WHICH DATA IS INPUT INTO FROM  COMPONENTS PLATING KANBAN M/F */
             /*       CALL AJSR49 HOLDING                                    */
             /* WHICH DATA IS INPUT INTO FROM  COMPONENTS TUNNEL KANBAN M/F  */
             /*       CALL AJSR4A HOLDING                                    */
             /****************************************************************/

             /* FA M/F UPDATE  */
             OVRPRTF    FILE(QPRINT) DEVTYPE(&PDEVT) OUTQ(FAOUTQ) +
                          HOLD(*YES) IGCDTA(&PIGCD)
             OVRPRTF    FILE(QPRINT2) DEVTYPE(&PDEVT) PAGESIZE(66 +
                          198) LPI(6) CPI(15) OUTQ(FAOUTQ) +
                          IGCDTA(&PIGCD)
             CALL AJSR42
             DLTOVR QPRINT
             DLTOVR QPRINT2
             /*DELETE DATA MAKING OF FA M/F */
             /* PLATING, TUNNEL, ARRS, INSTRUCTION, COMPONENTS PLATING */
             /* MARK * IN THE DATA WHICH THERE IS NOT INTO COMPONENTS TUNNEL */
             OVRPRTF    FILE(QPRINT) DEVTYPE(&PDEVT) PAGESIZE(66 +
                          198) LPI(6) CPI(15) OUTQ(FAOUTQ) +
                          HOLD(*NO) IGCDTA(&PIGCD)
             CALL AJSR44
             DLTOVR QPRINT

             /*******************************************/
             /*  A DISKETTE MAKES WITH CHANGE WORK FILE */
             /********************** COPY FROM AJSC15 ***/
             DLTF       FILE(HWFILE1/AJSWP43)
             MONMSG     MSGID(CPF3261 CPF2105)
             DLTF       FILE(HWFILE1/AJSWP45)
             MONMSG     MSGID(CPF3261 CPF2105)

             /******************************************/
             /*     DLTF       FILE(HWFILE1/AJSWP44)   */
             /*     MONMSG     MSGID(CPF3261 CPF2105)  */
             /*     DLTF       FILE(HWFILE1/AJSWP47)   */
             /*     MONMSG     MSGID(CPF3261 CPF2105)  */
             /******************************************/

             /*CREATE WORK FILE */

             CRTPF      FILE(HWFILE1/AJSWP43) RCDLEN(145) +
                          TEXT('OUTPUT A FOR PC SUPPORT DKT') +
                          OPTION(*NOLIST) SIZE(1000 300) +
                          LVLCHK(*NO) AUT(*ALL)
             GRTOBJAUT  OBJ(AJSWP43) OBJTYPE(*FILE) USER(*PUBLIC) +
                          AUT(*ALL)
             CRTPF      FILE(HWFILE1/AJSWP45) RCDLEN(145) +
                          TEXT('OUTPUT AZ FOR PC SUPPORT DKT') +
                          OPTION(*NOLIST) SIZE(10000 3000) +
                          LVLCHK(*NO) AUT(*ALL)
             GRTOBJAUT  OBJ(AJSWP45) OBJTYPE(*FILE) USER(*PUBLIC) +
                          AUT(*ALL)

             /**************************************************************/
             /*     CRTPF      FILE(HWFILE1/AJSWP44) RCDLEN(145) +         */
             /*                  TEXT('OUTPUT AZ FOR PC SUPPORT DKT') +    */
             /*                  OPTION(*NOLIST) SIZE(10000 3000) +        */
             /*                  LVLCHK(*NO) AUT(*ALL)                     */
             /*     GRTOBJAUT  OBJ(AJSWP44) OBJTYPE(*FILE) USER(*PUBLIC) + */
             /*                  AUT(*ALL)                                 */
             /*     CRTPF      FILE(HWFILE1/AJSWP47) RCDLEN(145) +         */
             /*                  TEXT('OUTPUT ARS FOR PC SUPPORT DKT'+     */
             /*                  ) OPTION(*NOLIST) SIZE(1000 300) +        */
             /*                  LVLCHK(*NO) AUT(*ALL)                     */
             /*     GRTOBJAUT  OBJ(AJSWP47) OBJTYPE(*FILE) USER(*PUBLIC) + */
             /*                  AUT(*ALL)                                 */
             /**************************************************************/

             /* IT IS MAKING FROM  FA M/F COPY FROM AJSR15 */
             OVRPRTF    FILE(QPRINT) DEVTYPE(&PDEVT) OUTQ(FAOUTQ) +
                          HOLD(*YES) IGCDTA(&PIGCD)
             CALL       PGM(AJSR43)
             DLTOVR QPRINT

             /*DELETE WORK FILE */
             /******************************/
             /* DLTF FILE(HWFILE1/AJSWP43) */
             /* DLTF FILE(HWFILE1/AJSWP44) */
             /* DLTF FILE(HWFILE1/AJSWP45) */
             /* DLTF FILE(HWFILE1/AJSWP46) */
             /* DLTF FILE(HWFILE1/AJSWP47) */
             /* DLTF FILE(HWFILE1/AJSWP48) */
             /* DLTF FILE(HWFILE1/AJSWP49) */
             /* DLTF FILE(HWFILE1/AJSWP4A) */
             /******************************/
             /*DELETE WORK FILE */
             /******************************/
             /* DLTF FILE(HWFILE1/AJSWP40) */
             /* DLTF FILE(HWFILE1/AJSWP41) */
             /* DLTF FILE(HWFILE1/AJSWP42) */
             /******************************/
             /* EXIT */

             DLTDTAARA  DTAARA(HFILE1/FAMASMAK)

 END:        CHGJOB     RUNPTY(20)

             ENDPGM
