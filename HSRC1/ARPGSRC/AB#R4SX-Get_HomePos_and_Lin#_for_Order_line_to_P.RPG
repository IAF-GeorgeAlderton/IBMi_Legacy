     H            Y.
      ** AB#R4SX  ******************************************
      * GET HOMEPOS AND LIN# FOR ORDER LINE TO AB#PP10     *
      *                                                    *
      * LEC   11/30/2022 CREATE                            *
      ******************************************************
     FAM#PL43DIF  E           K        DISK
     FAB#PL44EIF  E           K        DISK
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *
     C           *ENTRY    PLIST
     C                     PARM           MHN    12
     C                     PARM           ODRN   12
     C                     PARM           HOME    1
     C                     PARM           LINE    5
      *
     C           KEY01     KLIST
     C                     KFLD           MHN
      *
     C           KEY02     KLIST
     C                     KFLD           MHN
     C                     KFLD           ODRN
      *
     C                     MOVELMHN       MHN20  20
      *
     C           KEY02     CHAINAM#PL43D             50
      *
     C           *IN50     IFEQ *OFF
     C                     MOVELM1HOME    HOME
     C                     MOVELM1LINO    LINE
     C                     ELSE
     C           KEY02     SETGTAM#PL43D
     C           KEY01     REDPEAM#PL43D                 50
     C           *IN50     IFEQ *OFF
     C                     MOVELM1HOME    HOME
     C                     MOVELM1LINO    LINE
     C                     ELSE
     C           MHN20     CHAINAB#PL44E             51
     C           *IN51     IFEQ *OFF
     C                     MOVELDAHOME    HOME
     C                     MOVELDALINE    LINE
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
