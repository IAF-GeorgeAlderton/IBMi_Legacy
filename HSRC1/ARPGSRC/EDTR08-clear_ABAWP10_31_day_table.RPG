     C                     KFLD           K#MHN2
     C                     KFLD           K#MHN3
     C                     KFLD           K#MHN4
     C                     KFLD           K#DATE  60
     C                     KFLD           K#NONY  40
      *
     C                     MOVEL$MHIN     K#MHIN
     C                     MOVEL$YM       K#DATE
     C                     MOVEL$NONY     K#NONY
      *
     C           K#14      SETLLABAWL14
     C                     DO   *HIVAL
     C           K#14      READEABAWL14                  98
     C   98                LEAVE
      *
     C                     Z-ADD0         ABNN01
