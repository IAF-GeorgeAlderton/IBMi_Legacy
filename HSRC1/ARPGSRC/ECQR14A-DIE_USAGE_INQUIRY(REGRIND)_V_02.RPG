 E2  C                     ENDIF
 B2  C           X         IFEQ 17
 B3  C           RRN1      IFGE ZRRN
     C                     LEAVE
     C                     ELSE
     C                     Z-ADD*ZERO     X
 E3  C                     ENDIF
 E2  C                     ENDIF
