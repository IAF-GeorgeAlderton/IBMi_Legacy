      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR 3RD SCREEN
      *------------------------------------------------------
     C           #SET2     BEGSR
      *
     C                     Z-ADD*ZERO     RRN2    40
     C                     MOVE *ON       *IN54
     C                     WRITECTL02
     C                     MOVE *OFF      *IN54
     C                     MOVE S@KAT1    D@KAT1
     C                     MOVE S@KAT2    D@KAT2
     C                     MOVE S@KAT3    D@KAT3
     C                     MOVE S@KAT1    #KAT1
     C                     MOVE S@KAT2    #KAT2
     C                     Z-ADDD@MM      M       20
      *
     C           DFKATA    SETLLGCQTL311
     C           *IN95     DOUEQ*ON
     C           DFKATA    READEGCQTL311                 95
     C           *IN95     IFEQ *OFF
     C                     CLEARSFL02
      *
     C           KEY       CHAINMBEPL051             65
     C           *IN65     IFEQ *OFF
     C                     SETON                     40
     C                     Z-ADDI6S,M     S@QTY
     C                     ENDIF
     C           S@QTY     IFEQ *ZERO
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         RRN2
     C                     MOVE DFSHN1    S@PRT1
     C                     MOVE DFSHN2    S@PRT2
     C                     MOVE DFSHN3    S@PRT3
     C                     WRITESFL02
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           RRN2      IFEQ *ZERO
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  DISPLAY 3RD SCREEN
      *------------------------------------------------------
     C           #SCRN3    BEGSR
      *
     C                     MOVE *BLANK    D@OPT
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN53
     C                     EXFMTCTL02
     C                     MOVE *OFF      *IN53
      *
     C                     SELEC
      * F1: END
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * F12: BACK
     C           *INKL     WHEQ *ON
     C                     EXSR #CHK2
      *
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SET3     BEGSR
      *-----------------------------------------------------
      * UNIT PRICE
      *
     C                     MOVE S@KAT1    D@DIEA
     C                     MOVE S@KAT2    D@DIEB
     C                     MOVE S@KAT3    D@DIEC
     C                     Z-ADD*ZERO     D@UPRC
     C                     Z-ADD*ZERO     D@VALD
     C           K#ECQ     SETGTECQPP01
     C           *IN20     DOUEQ*ON
     C           K#ECQ     REDPEECQPP01             N    20
     C           *IN20     IFEQ *OFF
     C           ECVALD    ANDLE*DATE
     C           ECSKJY    ANDNE'D'
     C                     Z-ADDECUPRC    D@UPRC
     C                     Z-ADDECVALD    D@VALD
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      * DISPLAY 4TH SCREEN
      *------------------------------------------------------
     C           #SCRN4    BEGSR
      *
     C                     EXFMTDSP03
      *
     C                     SELEC
      * F12: BACK
     C           *INKL     WHEQ *ON
     C                     MOVE '02'      W@ID
     C                     OTHER
     C                     EXSR #CHK4
      * F5: UPDATE
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
     C                     EXSR #SET1
     C                     MOVE '2'       W@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------
      * CHECK 4
      *-----------------------------------------------------
     C           #CHK4     BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00'      *IN,61
     C                     Z-ADDD@VALD    KYMD
     C           K#AGX     CHAINAGDPL12              96
     C           *IN96     IFEQ *ON
     C                     SETON                     6199
     C                     ENDIF
      *
     C           D@UPRC    IFEQ *ZERO
     C                     SETON                     6299
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
      * CHECK 5
      *-----------------------------------------------------
     C           #CHK5     BEGSR
      *
     C                     CLEARDIE15
     C                     CLEARD@MSGX
     C                     MOVE *OFF      *IN99
     C                     MOVEA'000'     *IN,61
     C                     MOVELD@DIXX    DIE15  15
      * DIE EXISTS
     C           DIE15     CHAINGCQPL361             96
B0   C           *IN96     IFEQ *OFF
     C                     SETON                     6199
     C                     MOVELMSX,1     D@MSGX
E0   C                     ENDIF
      * NEW DIE CAN'T BE BLANK
B0   C           D@DIXX    IFEQ *BLANKS
     C                     SETON                     6199
     C                     MOVELMSX,4     D@MSGX
E0   C                     ENDIF
      * CUST. WANTS COPY
B0   C           D@DICC    IFNE *BLANKS
     C                     CLEARDIE16
     C                     MOVELD@DICC    DIE16  15
     C           DIE16     CHAINGCQPL361             96
B1   C           *IN96     IFEQ *ON
     C                     SETON                     6399
     C                     MOVELMSX,2     D@MSGX
E1   C                     ENDIF
B0   C                     ENDIF
      * CUST. DOESN'T WNAT COPY
B0   C           D@DICC    IFEQ *BLANKS
     C           KEY5      CHAINFCEPL011             96
B1   C           *IN96     IFEQ *ON
     C                     SETON                     6299
     C                     MOVELMSX,3     D@MSGX
E1   C                     ENDIF
E0   C                     ENDIF
   |  *
TCH52C                     ENDSR
      *-----------------------------------------------------
      * UPDATE PRICE MASTER (ECQPP01)
      *-----------------------------------------------------
     C           #UPD      BEGSR
      *
     C           K#ECQX    CHAINECQPP01              96
     C           *IN96     IFEQ *OFF
     C           ECSKJY    ANDNE'D'
     C                     Z-ADDD@UPRC    ECUPRC
     C                     Z-ADD*DATE     ECKODT
     C                     TIME           ECKOTM
     C                     MOVEL#USER     ECKOME
     C                     UPDATECQPP011
     C                     ELSE
     C                     CLEARECQPP011
     C                     MOVELD@DIEA    ECKAT1
     C                     MOVELD@DIEB    ECKAT2
     C                     MOVELD@DIEC    ECKAT3
     C                     Z-ADDD@UPRC    ECUPRC
     C                     Z-ADDD@VALD    ECVALD
     C                     Z-ADD*DATE     ECKODT
     C                     TIME           ECKOTM
     C                     MOVEL#USER     ECKOME
     C                     WRITEECQPP011
     C                     ENDIF
      *
     C                     ENDSR
TCH52 *-----------------------------------------------------
      * UPDATE DIE ALLOTMENT MASTER (GCQPP31)
      *-----------------------------------------------------
     C           #UPD5     BEGSR
      * NO COPY
B0   C           D@DICC    IFEQ *BLANKS
      *
     C* WRITE TO GCQPP31
     C           DIE15     CHAINGCQPL361             96
B1   C           *IN96     IFEQ *OFF
     C                     MOVEL#USER     DFKOME
     C                     UPDATGCQPL361
X1   C                     ELSE
     C                     CLEARGCQPL361
     C                     Z-ADD*YEAR     DFKOYY
     C                     Z-ADDUMONTH    DFKOMM
     C                     Z-ADDUDAY      DFKODD
     C                     Z-ADDHH        DFKOHH
     C                     Z-ADDMM        DFKOSS
     C                     MOVEL#USER     DFKOME
     C                     MOVELD@DIXX    DFKATA
     C                     MOVELD@DPA1    DFSHN1
     C                     MOVELD@DPA2    DFSHN2
     C                     MOVELD@DPA3    DFSHN3
     C                     MOVELD@DPRO    DFKOTI
     C                     Z-ADDD@DCMP    DFKSEI
     C                     Z-ADD1         DFKOSU
     C                     MOVEL'0'       DFKSKB
     C                     WRITEGCQPL361
     C* WRITE TO FCQPP32
     C                     MOVELDFKATA    KATA7
     C           KEY7      CHAINFCQPP321             78
     C           *IN78     IFEQ '1'
     C                     CLEARFCQPP321
     C                     MOVE TTKAT1    Q4KAT1
     C                     MOVE TTKAT2    Q4KAT2
     C                     MOVE TTKAT3    Q4KAT3
     C                     WRITEFCQPP321
     C                     ENDIF
      *
E1   C                     ENDIF
      *
X0   C                     ELSE
      * COPY FROM GCQPP31
     C* WRITE TO GCQPP31
     C                     CLEARGCQPL361
     C                     MOVE '0'       *IN94
     C           DIE16     SETLLGCQPL361
B1   C           *IN94     DOWEQ'0'
     C           DIE16     READEGCQPL361                 94
B2   C           *IN94     IFEQ *OFF
     C                     Z-ADD*YEAR     DFKOYY
     C                     Z-ADDUMONTH    DFKOMM
     C                     Z-ADDUDAY      DFKODD
     C                     Z-ADDHH        DFKOHH
     C                     Z-ADDMM        DFKOSS
     C                     MOVEL#USER     DFKOME
     C                     MOVELDIE15     DFKATA
     C                     MOVELDFSHN1    DFSHN1
     C                     MOVELDFSHN2    DFSHN2
     C                     MOVELDFSHN3    DFSHN3
     C                     MOVELDFKOTI    DFKOTI
     C                     Z-ADDDFKSEI    DFKSEI
     C                     Z-ADDDFKOSU    DFKOSU
     C                     MOVELDFKSKB    DFKSKB
     C                     WRITEGCQPL361
     C* WRITE TO FCQPP32
     C                     MOVELDFKATA    KATA7
     C           KEY7      CHAINFCQPP321             78
     C           *IN78     IFEQ '1'
     C                     CLEARFCQPP321
     C                     MOVE TTKAT1    Q4KAT1
     C                     MOVE TTKAT2    Q4KAT2
     C                     MOVE TTKAT3    Q4KAT3
     C                     WRITEFCQPP321
     C                     ENDIF
      *
E2   C                     ENDIF
E1   C                     ENDDO
      *
E0   C                     ENDIF
   |  *
TCH52C                     ENDSR
      *------------------------------------------------------
      * OUTPUT ECQWP16
      *------------------------------------------------------
     C           #DOWN     BEGSR
      *
     C                     MOVE *OFF      *IN98
     C                     MOVE *OFF      *IN80
     C                     TIME           @@TIM   60
     C                     Z-ADD*ZERO     D@TOTL
      *
     C           *LOVAL    SETLLFCQPP32
      *-----------------------------------------XXX
B0   C           *IN80     DOWEQ*OFF
     C                     READ FCQPP32                  80
B1   C           *IN80     IFEQ *OFF
     C           Q4SKJY    ANDEQ*BLANK
      *
     C                     EXSR #OUT
      *
E1   C                     ENDIF
E0   C                     ENDDO
      *-----------------------------------------XXX
      *
     C**         *IN98     IFEQ *ON
     C**                   CLEARECQWP161
     C**                   MOVEL'TOT'     EQDIE2
     C**                   Z-ADDD@TOTL    EQAMNT
     C**                   WRITEECQWP161
     C**                   ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      * DOWNLOAD FILE ECQWP16
      *------------------------------------------------------
     C           #OUT      BEGSR
      *
     C           WDD       IFEQ 0
     C           KATKEX    SETLLECSPL05
     C                     ELSE
     C           KATKEP    SETLLECSPL05
     C                     ENDIF
      *
     C                     DO   *HIVAL
     C           WDD       IFEQ 0
     C           KATKEX    READEECSPL05                  20
     C                     ELSE
     C           KATKEP    READEECSPL05                  20
     C                     ENDIF
     C   20                LEAVE
      *
     C           EQSKJY    IFNE *BLANK
     C           EQBMON    ORNE 0111
     C                     ITER
     C                     ENDIF
      *
     C                     CLEARECQWP161
     C                     MOVELEQYOHZ    EQDATE
     C                     MOVELEQKAT1    EQDIE1
     C                     MOVELEQKAT2    EQDIE2
     C                     MOVELEQKAT3    EQDIE3
      * LOCATION
     C                     MOVELEQKAT1    S@KAT1
     C                     MOVELEQKAT2    S@KAT2
     C                     MOVELEQKAT3    S@KAT3
     C           K#DIE     CHAINGCQPL12              95
     C           *IN95     IFEQ *OFF
     C                     MOVELT6LOCT    EQLOCT
     C                     ENDIF
      *
     C                     MOVELEQKINO    EQMCHN
      * WORK CENTER
     C                     MOVE EQMCHN    K@MCHN
     C           K#MFA     CHAINMFAPL25              95
     C           *IN95     IFEQ *OFF
     C                     MOVE @@CNTR    EQWCTR
     C                     ENDIF
      *
     C                     Z-ADDEQKOSU    EQUSGE
      *
     C                     MOVE *BLANK    K@KAT4
     C                     Z-ADD*ZERO     S@UPRC
     C                     EXSR #PRC
     C                     Z-ADDS@UPRC    EQUPRC
     C           EQUSGE    MULT S@UPRC    EQAMNT
      *
     C                     WRITEECQWP161
      *
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      * DIDPLAY 5TH SCREEN
      *------------------------------------------------------
     C           #SCRN5    BEGSR
      *
     C                     CLEARD@DIXX
     C                     CLEARD@DICC
     C                     CLEARD@DPRO
     C                     CLEARD@DCMP
     C                     CLEARD@DPA1
     C                     CLEARD@DPA2
     C                     CLEARD@DPA3
     C                     MOVE '0'       *IN77
     C           *IN77     DOWEQ'0'
     C                     EXFMTDSP05
      *
     C                     SELEC
      * F12: BACK
     C           *INKL     WHEQ *ON
     C                     MOVE '02'      W@ID
     C                     LEAVE
     C                     OTHER
     C                     EXSR #CHK5
     C           *IN99     IFEQ *OFF
      * F5: UPDATE
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD5
      *
     C           ' '       IFEQ FSCREN
     C                     EXSR #SET1
     C                     ENDIF
      *
     C                     MOVE '2'       W@ID
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDSL
     C                     ENDDO
   |  *
TCH52C                     ENDSR
