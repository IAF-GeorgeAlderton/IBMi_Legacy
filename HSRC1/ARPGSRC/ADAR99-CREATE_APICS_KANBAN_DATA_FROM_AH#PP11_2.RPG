     H            Y.                      F
     F***************************************************
     F*   CREATE APICS KANBAN DATA                      *
     F*                                                 *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FAH#WP98 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FOUTF1   O   F     256            DISK                      A    UC
      *------------------------------------------------------------
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1  30 DS30
     I                                        1   1 D
     I                                        2   5 X0111
     I                                        6   9 X9431
     I                                       18  19 HD
     I                                       20  21 DT
     I                                       22  23 BK
     I                                       24  25 AA
     I                                       26  27 EE
     I                                       28  28 X0
     I                                       28  29 X00
     I                                       30  30 BLK
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C                     EXSR #HED
     C                     EXSR #MAIN
     C                     EXSR #TRL
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@DATE  8
     C                     PARM           P@BIN   2
      *
     C           K#KEY     KLIST
     C                     KFLD           K@BMN   40
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C                     KFLD           D@BIN   20
      *
     C                     MOVE P@DATE    D@DATE  80
     C                     MOVE P@BIN     D@BIN   20
      *
     C                     Z-ADD0111      K@BMN
      *
     C                     ENDSR
      *------------------------------------------------------
      *   WRITE RECORDS
      *------------------------------------------------------
     C           #MAIN     BEGSR
      *
     C                     MOVE *BLANK    FSW1    1
     C                     Z-ADD0         SQ1     40
     C                     Z-ADD0         CNT1    40
     C                     MOVE *BLANK    BLK1    2
     C                     MOVE '0000'    WBMN1   4
      *
     C           *LOVAL    SETLLAH#WP98
     C           *IN90     DOUEQ*ON
     C                     READ AH#WP98                  90
     C           *IN90     IFEQ *OFF
      *
     C           FSW1      IFEQ *BLANK
     C                     OPEN OUTF1
     C                     EXCPTA01
     C                     MOVE *BLANK    BLK1
     C                     MOVEL'*'       FSW1
     C                     END
      *
     C           WFBMON    IFNE WBMN1
     C                     ADD  1         CNT1
     C                     Z-ADD0         SQ1
     C                     EXCPTA02
     C                     MOVE WFBMON    WBMN1
     C                     MOVELCFBLOK    BLK1
     C                     MOVELCFKDAI    KDA1    1
     C                     ELSE
     C           CFKDAI    IFNE KDA1
     C                     ADD  1         CNT1
     C                     Z-ADD0         SQ1
     C                     EXCPTA02
     C                     MOVELCFBLOK    BLK1
     C                     MOVELCFKDAI    KDA1
     C                     ELSE
     C           CFBLOK    IFNE BLK1
     C                     ADD  1         CNT1
     C                     Z-ADD0         SQ1
     C                     EXCPTA02
     C                     MOVELCFBLOK    BLK1
     C                     END
     C                     END
     C                     END
      *
     C                     ADD  1         CNT1
     C                     ADD  1         SQ1
     C                     MOVE *BLANK    F30
     C                     MOVELSQ1       F30
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVELF30       XSQ1    4
      *
     C                     MOVEL@BLK18    BLK18  18
      *
     C                     MOVELWFTOKU    F30
     C                     CALL 'AZZR12'
     C                     PARM           F30
     C                     MOVELF30       WTOKU   40
      *
     C           WTOKU     IFNE 0
     C                     SETOF                     11
     C           WTOKU     CHAINFGBPL011             11
     C           *IN11     IFEQ '0'
     C                     MOVELB2SMEI    F30       P
     C                     ENDIF
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVELF30       BLK18
     C                     END
      *
     C                     EXCPTA03
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   HEADER SET
      *------------------------------------------------------
     C           #HED      BEGSR
      *
     C                     MOVE *BLANK    DS30
     C                     MOVEL'D'       D
     C                     MOVEL'0111'    X0111
     C                     MOVEL'9431'    X9431
     C                     MOVEL'HD'      HD
     C                     MOVEL'DT'      DT
     C                     MOVEL'BK'      BK
     C                     MOVEL'AA'      AA
     C                     MOVEL'EE'      EE
     C                     MOVEL'00'      X00
     C                     MOVE *BLANK    BLK
     C                     MOVE *BLANK    WB28   28
     C                     MOVE *BLANK    WB22   22
      *
     C                     MOVE *BLANK    F30    30
     C                     MOVELDS30      F30
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVELF30       DS30
      *
     C                     MOVE *BLANK    F30
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVELF30       @BLK18 18
      *
     C                     MOVE *BLANK    F30
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVELF30       BLK30  30
      *
     C                     MOVE *BLANK    F30
     C                     MOVEL'SC'      F30
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVELF30       SC      2
      *
     C                     MOVE *BLANK    F30
     C                     MOVELWB28      F30
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVELF30       WB28
      *
     C                     MOVE *BLANK    F30
     C                     MOVELWB22      F30
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVELF30       WB22
      *
     C* 97.05.05
     C                     MOVE *BLANK    F30
     C                     MOVEL'00'      F30
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVELF30       @BLOK   2
      *
      *
     C                     ENDSR
      *------------------------------------------------------
      *   TRAILER  RECORD
      *------------------------------------------------------
     C           #TRL      BEGSR
      *
     C           FSW1      IFNE *BLANK
     C                     MOVE *BLANK    F30
     C                     MOVELCNT1      F30
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVELF30       XCNT1   4
     C                     EXCPTA04
     C                     CLOSEOUTF1
     C                     END
      *
     C                     ENDSR
      *------------------------------------------------------
