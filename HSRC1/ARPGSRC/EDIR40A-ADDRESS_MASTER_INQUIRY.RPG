     H            Y,
      *** EDIR40A ***********************************************
      * ADDRESS MASTER INQUIRY                                  *
      * JW     : 2021.11.10                                     *
      ***********************************************************
     FEDIPW40ACF  E                    WORKSTN
     FEDIPP42 IF  E           K        DISK
     FEDIPL40 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FRGAPL11 IF  E           K        DISK
      ***********************************************************
     I            DS
     I                                        1   80E4KOHZ
     I                                        1   40E4KOYY
     I                                        5   60E4KOMM
     I                                        7   80E4KODD
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
     I            DS
     I                                        1   60WTIME
     I                                        1   40E4KOTM
     I                                        1   20E4KOHH
     I                                        3   40E4KOSS
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      **********************
      *  MAIN ROUTINE      *
      **********************
     C                     EXSR #INIT
      *
     C           *IN85     IFEQ *ON
     C                     GOTO ENDP
     C                     ENDIF
      *
     C                     MOVEL$NONY     #NONY   4
     C                     EXSR #SET
      *
     C                     DO   *HIVAL
      *  DISPLAY 1 SCREEN
     C                     EXFMTDSP01
     C                     SELEC
      * F1:  EXIT
      * F12: EXIT
     C           *INKA     WHEQ *ON
     C           *INKL     OREQ *ON
     C                     LEAVE
      * PAGE-DOWN
     C           *IN51     WHEQ *ON
     C                     EXSR #NEXT
     C                     EXSR #SET
      * PAGE-UP
     C           *IN52     WHEQ *ON
     C                     EXSR #BACK
     C                     EXSR #SET
     C                     ENDSL
      *
     C                     ENDDO
      *
     C           ENDP      TAG
     C                     MOVE *ON       *INLR
     C                     RETRN
      **********************
      *  SET DATA          *
      **********************
     C           #SET      BEGSR
      *
     C                     CLEARDSP01
      *
     C           #STS      IFEQ 'D'
     C                     MOVEL'DELETED 'XSTS      P
     C                     MOVE *ON       *IN86
     C                     ELSE
     C                     MOVEL'ACTIVE  'XSTS      P
     C                     MOVE *OFF      *IN86
     C                     ENDIF
     C                     Z-ADD#SKHZ     XSKHZ
      *
     C                     MOVEL#NONY     @NONY
     C           @NONY     CHAINFGBPL01              91
     C           *IN91     IFEQ *OFF
     C                     MOVEL#NONY     XNONY
     C                     MOVELB2SMEI    XSMEI
     C                     ENDIF
      *
     C           #NONY     CHAINEDIPP42              92
     C           *IN92     IFEQ *OFF
     C                     MOVELE4CITY    XCITY
     C                     MOVELE4STCD    XSTC
     C                     MOVELE4ZIPC    XZIPCD
     C                     MOVELE4CNT     XCNT
     C                     MOVELE4GRP     XGRP1
     C                     MOVELE4GRP2    XGRP2
     C                     ENDIF
      *
     C           #NONY     CHAINEDIPL40              93
     C           *IN93     IFEQ *OFF
     C                     Z-ADDE4KOHZ    @UDAT
     C                     Z-ADDE4KOTM    @UTIM
     C                     MOVELE4KOME    @ID
      * NAME
     C                     MOVEL@ID       LTR10  10 P
     C           LTR10     CHAINRGAPL11              94
     C           *IN94     IFEQ *OFF
     C                     MOVELJ8NAME    XNAME
     C                     ENDIF
      *
     C                     MOVELE4ADD1    XAD1
     C                     MOVELE4ADD2    XAD2
     C                     MOVELE4ADD3    XAD3
     C                     MOVELE4ADD4    XAD4
     C                     MOVELE4ADD5    XAD5
     C                     MOVELE4ADD6    XAD6
     C                     ENDIF
      *
     C                     ENDSR
      ************************
      *  NEXT DELIVERY#      *
      ************************
     C           #NEXT     BEGSR
      *
     C**                   MOVE *BLANK    #STS
     C                     MOVEL#NONY     @NONY
     C           @NONY     SETLLFGBPL01
     C                     READ FGBPL01                  99
     C                     READ FGBPL01                  99
     C           *IN99     IFEQ *OFF
     C                     MOVELB2CODE    #NONY
     C                     MOVELB2SKJY    #STS
     C           B2SKJY    IFEQ 'D'
     C                     Z-ADDB2SKHZ    #SKHZ   80
     C                     ELSE
     C                     Z-ADD0         #SKHZ
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      ************************
      *  PREVIOUS DELIVERY#  *
      ************************
     C           #BACK     BEGSR
      *
     C**                   MOVE *BLANK    #STS
     C                     MOVEL#NONY     @NONY
     C           @NONY     SETGTFGBPL01
     C                     READPFGBPL01                  99
     C                     READPFGBPL01                  99
     C           *IN99     IFEQ *OFF
     C                     MOVELB2CODE    #NONY
     C                     MOVELB2SKJY    #STS
     C           B2SKJY    IFEQ 'D'
     C                     Z-ADDB2SKHZ    #SKHZ   80
     C                     ELSE
     C                     Z-ADD0         #SKHZ
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      **********************
      *  INITIAL SET       *
      **********************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4
      *
     C                     MOVEL$NONY     @NONY   40
     C                     TIME           WSDT
     C                     MOVE *BLANK    #STS    1
      * CHECK NONY
     C           @NONY     CHAINFGBPL01              85
     C                     MOVELB2SKJY    #STS
     C           *IN85     IFEQ *OFF
     C                     Z-ADDB2SKHZ    #SKHZ
     C                     ELSE
     C                     Z-ADD0         #SKHZ
     C                     ENDIF
      *
     C                     ENDSR
