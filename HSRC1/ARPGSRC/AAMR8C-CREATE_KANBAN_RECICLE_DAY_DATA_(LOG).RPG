     H            Y.
     F** AAMR8C ********************************************
     F*かんばん回転日数データ作成（履歴作成）            *
     F*   MSK.                            2011.02.16       *
     F******************************************************
     FAAMWP80 IF  E                    DISK
     FAAMPP80 IF  E           K        DISK                      A
     FAAMPP81 O   E                    DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  120WTIYM
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------*
      *   PLIST                                            *
      *----------------------------------------------------*
      *
     C           *ENTRY    PLIST
     C                     PARM           PBMON   4
     C                     PARM           PKOTE   3
     C                     PARM           PK1F    1
     C                     PARM           PK1T    1
     C                     PARM           PT1F    2
     C                     PARM           PT1T    2
     C                     PARM           POUT    1
     C                     PARM           PCMD    2
      *----------------------------------------------------*
      *   KLIST                                            *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     EXSR #SB500
      *
     C                     READ AAMWP801                 81
     C           *IN81     DOWEQ'0'
     C                     EXSR #SB510
     C                     READ AAMWP801                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *起動履歴                                          *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYA01    KLIST
     C                     KFLD           #KYM    60
      *
     C                     Z-ADDWTIYM     #KYM
     C           KEYA01    SETGTAAMPP801
     C           KEYA01    REDPEAAMPP801                 81
     C           *IN81     IFEQ '0'
     C           A0SEQ     ADD  1         WKSEQ   30
     C                     ELSE
     C                     Z-ADD1         WKSEQ
     C                     ENDIF
      *
     C                     TIME           WTIME
     C                     CLEARAAMPP801
     C                     Z-ADDWTIYM     A0YM
     C                     Z-ADDWKSEQ     A0SEQ
     C                     Z-ADDWTIYY     A0CRYY
     C                     Z-ADDWTIMM     A0CRMM
     C                     Z-ADDWTIDD     A0CRDD
     C                     Z-ADDTIMHH     A0CRTH
     C                     Z-ADDTIMMM     A0CRTM
     C                     Z-ADDTIMSS     A0CRTS
     C                     MOVEL@@USER    A0CRNA
     C                     MOVELW$PGM     A0CRPG
     C                     MOVELPBMON     A0BMON
     C                     MOVELPKOTE     A0KOTE
     C                     MOVELPK1F      A0K1F
     C                     MOVELPK1T      A0K1T
     C                     MOVELPT1F      A0T1F
     C                     MOVELPT1T      A0T1T
     C                     MOVELPOUT      A0OUT
     C                     WRITEAAMPP801
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      *履歴データ                                        *
      *----------------------------------------------------*
     CSR         #SB510    BEGSR
      *
     C                     CLEARAAMPP811
     C                     Z-ADDWTIYY     A1KOYY
     C                     Z-ADDWTIMM     A1KOMM
     C                     Z-ADDWTIDD     A1KODD
     C                     Z-ADDTIMHH     A1KOTH
     C                     Z-ADDTIMMM     A1KOTM
     C                     Z-ADDTIMSS     A1KOTS
     C                     MOVEL@@USER    A1KONA
     C                     MOVELW$PGM     A1KOPG
     C                     Z-ADDA0YM      A1YM
     C                     Z-ADDA0SEQ     A1SEQ
     C                     Z-ADDWTIYY     A1CRYY
     C                     Z-ADDWTIMM     A1CRMM
     C                     Z-ADDWTIDD     A1CRDD
     C                     Z-ADDTIMHH     A1CRTH
     C                     Z-ADDTIMMM     A1CRTM
     C                     Z-ADDTIMSS     A1CRTS
     C                     MOVEL@@USER    A1CRNA
     C                     MOVELW$PGM     A1CRPG
     C                     MOVELW0BMON    A1BMON
     C                     MOVELW0SHN1    A1SHN1
     C                     MOVELW0SHN2    A1SHN2
     C                     MOVELW0SHN3    A1SHN3
     C                     MOVELW0KOTE    A1KOTE
     C                     MOVELW0TKR1    A1TKR1
     C                     MOVELW0TKR2    A1TKR2
     C                     MOVELW0TKR3    A1TKR3
     C                     MOVELW0TKR4    A1TKR4
     C                     Z-ADDW0KTSU    A1KTSU
     C                     Z-ADDW0KSSU    A1KSSU
     C                     Z-ADDW0KHSU    A1KHSU
     C                     Z-ADDW0SYUY    A1SYUY
     C                     Z-ADDW0LOTK    A1LOTK
     C                     Z-ADDW0KJNK    A1KJNK
     C                     Z-ADDW0SETO    A1SETO
     C                     Z-ADDW0KMAX    A1KMAX
     C                     MOVELW0KCD1    A1KCD1
     C                     MOVELW0KCD2    A1KCD2
      *
     C                     WRITEAAMPP811
      *
     CSR         ESB510    ENDSR
