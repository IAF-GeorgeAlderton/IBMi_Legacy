     C                     PARM           PSKHZ   8
     C                     PARM           PKOHZ   8
     C                     PARM           PTIME   4
     C                     PARM           PKOME  10
     C                     PARM           PHHIN  12
     C                     PARM           PHYMD   8
     C                     PARM           PHBIN   2
     C                     PARM           PSYST   6
     C                     PARM           P2SFLG  1
     C                     PARM           P2RFLG  1
     C                     PARM           OUTQ    8
