     H            Y.
     F** ECSR30 **********************************
     F* DIE INVENTORY INQUIRY
     F* PROGRAM ID. : ECSR30
     F* CREATE DATE. : SEP.03.02                 *
     F* AUTHOR.         : TCH                    *
     F********************************** ECSR30 **
     FECSPW30 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                        RRN2  KSFILE SFL02
     F                                              KINFDS @INFDS
     FECSPL10 IF  E           K        DISK
     FECSPL11 IF  E           K        DISK
     F            ECSPP101                          KRENAMEECSP11R
     FECSPL20 IF  E           K        DISK
     FECSPL05 IF  E           K        DISK
      *-----------------------------------------------------------
     E                    CMD     1   2 78
     E                    MSG     1   2 78
      *-----------------------------------------------------------
     I@INFDS      DS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80W@YMD1
     I                                        1   40W@YY
     I                                        5   60W@MM
     I                                        7   80W@DD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------
      *  MAIN ROUTINE
      *--------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C           W@ID      CASEQ'03'      #SCRN3
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------------
     C           K#KEY1    KLIST
     C                     KFLD           D@KAT1
     C                     KFLD           D@KAT2
     C                     KFLD           D@KAT3
     C*****                KFLD           D@KAT4
      *
     C           K#KEY2    KLIST
     C                     KFLD           D@LOC1
     C                     KFLD           D@LOC2
     C                     KFLD           D@LOC3
     C                     KFLD           D@LOC4
     C           K#KEY3    KLIST
     C                     KFLD           D@DIE1
     C                     KFLD           D@DIE2
     C                     KFLD           D@DIE3
     C           K#KEY4    KLIST
     C                     KFLD           D@DIE1
     C                     KFLD           D@DIE2
     C                     KFLD           D@DIE3
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#KEY5    KLIST
     C                     KFLD           D@DIE1
     C                     KFLD           D@DIE2
     C                     KFLD           D@DIE3
     C*********            KFLD           D@DIE4
     C           K#KEY6    KLIST
     C                     KFLD           D@DIE1
     C                     KFLD           D@DIE2
     C                     KFLD           D@DIE3
     C********             KFLD           D@DIE4
     C                     KFLD           K@YMD
      *
     C                     MOVE '01'      W@ID    2
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SCRN1    BEGSR
      *-----------------------------------------------------
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #CHK1     BEGSR
      *-----------------------------------------------------
     C                     SETOF                     616299
     C                     MOVE *BLANK    D@MSG
      *
     C           D@KAT1    IFNE *BLANK
     C           K#KEY1    CHAINECSPL10              90
     C           *IN90     IFEQ *ON
     C                     MOVE MSG,2     D@MSG
     C                     SETON                     6199
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SET      BEGSR
      *-----------------------------------------------------
     C           D@KAT1    IFNE *BLANK
     C                     MOVE W@ID      @@ID    2
     C                     MOVE D@KAT1    D@DIE1
     C                     MOVE D@KAT2    D@DIE2
     C                     MOVE D@KAT3    D@DIE3
     C*********            MOVE D@KAT4    D@DIE4
     C                     Z-ADDE1SQTY    D@WQTY
     C                     EXSR #SET2
     C                     ELSE
     C                     EXSR #SET1
     C           RRN1      IFEQ *ZERO
     C                     MOVE MSG,1     D@MSG
     C                     SETON                     6199
     C                     ELSE
     C                     MOVE '02'      W@ID
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SET1     BEGSR
      *-----------------------------------------------------
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @RRN1   40
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
      *
     C           D@LOC2    CAT  '99':0    W@LOC2  2 P
     C           D@LOC3    CAT  '99':0    W@LOC3  2 P
      *
     C           K#KEY2    SETLLECSPL11
     C           *IN90     DOUEQ*ON
     C                     READ ECSPL11                  90
     C           *IN90     IFEQ *OFF
     C           E1SKJY    ANDEQ*BLANK
      *
     C           D@LOC1    IFNE *BLANK
     C           E1LOC1    ANDNED@LOC1
     C                     LEAVE
     C                     ENDIF
      *
     C           D@LOC2    IFNE *BLANK
     C           E1LOC2    ANDGTW@LOC2
     C                     LEAVE
     C                     ENDIF
      *
     C           D@LOC3    IFNE *BLANK
     C           E1LOC3    ANDGTW@LOC3
     C                     LEAVE
     C                     ENDIF
      *
     C           D@LOC4    IFNE *BLANK
     C           E1LOC4    ANDGTD@LOC4
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  1         RRN1
     C                     CLEARSFL01
     C                     MOVE E1LOC1    S@LOC1
     C                     MOVE E1LOC2    S@LOC2
     C                     MOVE E1LOC3    S@LOC3
     C                     MOVE E1LOC4    S@LOC4
     C                     MOVE E1KAT1    S@KAT1
     C                     MOVE E1KAT2    S@KAT2
     C                     MOVE E1KAT3    S@KAT3
     C                     MOVE E1KAT4    S@KAT4
     C                     Z-ADDE1SQTY    S@WQTY
     C           S@WQTY    IFLT *ZERO
     C                     MOVE *ON       *IN21
     C                     ELSE
     C                     MOVE *OFF      *IN21
     C                     ENDIF
      *
     C                     WRITESFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD1         #RCNO1
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCNO1
     C                     MOVE W@ID      @@ID
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
     C                     OTHER
     C                     EXSR #CHK2
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     Z-ADD*ZERO     @RRN1
     C           *IN90     DOUEQ*ON
     C                     ADD  1         @RRN1
     C           @RRN1     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           S@SLCT    IFNE *BLANK
      *
     C                     MOVE *BLANK    S@SLCT
     C           S@WQTY    IFLT *ZERO
     C                     MOVE *ON       *IN21
     C                     ELSE
     C                     MOVE *OFF      *IN21
     C                     ENDIF
      *
     C                     UPDATSFL01
      *
     C                     MOVE S@KAT1    D@DIE1
     C                     MOVE S@KAT2    D@DIE2
     C                     MOVE S@KAT3    D@DIE3
     C********             MOVE S@KAT4    D@DIE4
     C                     Z-ADDS@WQTY    D@WQTY
     C                     EXSR #SET2
     C                     LEAVE
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SET2     BEGSR
      *-----------------------------------------------------
     C                     MOVE '03'      W@ID
     C                     Z-ADD*ZERO     RRN2    40
     C                     MOVE *ON       *IN54
     C                     WRITECTL02
     C                     MOVE *OFF      *IN54
      *
     C                     Z-ADD*ZERO     W@YMD1
     C                     Z-ADD*ZERO     W@YMD2  80
     C           K#KEY3    SETGTECSPL05
     C           *IN90     DOUEQ*ON
     C           K#KEY3    REDPEECSPL05                  90
     C           *IN90     IFEQ *OFF
     C           EQSKJY    ANDEQ*BLANK
     C                     Z-ADDEQYOHZ    W@YMD1
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           K#KEY5    SETGTECSPL20
     C           *IN90     DOUEQ*ON
     C           K#KEY5    REDPEECSPL20                  90
     C           *IN90     IFEQ *OFF
     C           E2SKJY    ANDEQ*BLANK
     C                     Z-ADDE2DATE    W@YMD2
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           W@YMD1    IFNE *ZERO
     C           W@YMD2    ORNE *ZERO
     C                     EXSR #SET21
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SET21    BEGSR
      *-----------------------------------------------------
     C                     Z-ADD*ZERO     @CNT    30
      *
     C                     DO   *HIVAL
      *
     C                     CLEARSFL02
     C           W@YMD1    COMP W@YMD2               111213
     C                     SELEC
     C           *IN11     WHEQ *ON
     C                     EXSR #SET3
     C           *IN12     WHEQ *ON
     C                     EXSR #SET4
     C           *IN13     WHEQ *ON
     C                     EXSR #SET3
     C                     EXSR #SET4
     C                     ENDSL
      *
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C                     ADD  1         @CNT
      *
     C           @CNT      IFEQ 1
     C                     Z-ADDRRN2      #RCNO2
     C                     ENDIF
      *
     C           @CNT      IFEQ 17
     C                     LEAVE
     C                     ENDIF
      *
     C           W@YMD1    IFEQ *ZERO
     C           W@YMD2    ANDEQ*ZERO
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SET3     BEGSR
      *-----------------------------------------------------
     C           W@YMD1    IFNE *ZERO
     C                     Z-ADDW@YMD1    K@YMD
     C           K#KEY4    SETGTECSPL05
     C           *IN81     DOUEQ*ON
     C           K#KEY3    REDPEECSPL05                  81
     C           *IN81     IFEQ *ON
     C                     Z-ADD*ZERO     W@YMD1
     C                     LEAVE
     C                     ELSE
     C           EQYOHZ    IFNE W@YMD1
     C                     Z-ADDEQYOHZ    W@YMD1
     C                     LEAVE
     C                     ENDIF
      *
     C                     Z-ADDEQYOHZ    S@DATE
     C                     ADD  EQKOSU    S@OQTY
     C                     MOVE EQKINO    S@MCNO
     C                     MOVE EQKTEI    S@PROC
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SET4     BEGSR
      *-----------------------------------------------------
     C           W@YMD2    IFNE *ZERO
     C                     Z-ADDW@YMD2    K@YMD
     C           K#KEY6    SETGTECSPL20
     C           *IN81     DOUEQ*ON
     C           K#KEY5    REDPEECSPL20                  81
     C           *IN81     IFEQ *ON
     C                     Z-ADD*ZERO     W@YMD2
     C                     LEAVE
     C                     ELSE
     C           E2SKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
     C           E2DATE    IFNE W@YMD2
     C                     Z-ADDE2DATE    W@YMD2
     C                     LEAVE
     C                     ENDIF
      *
     C                     Z-ADDE2DATE    S@DATE
     C                     ADD  E2WQTY    S@IQTY
     C                     MOVE E2ISNO    S@ISNO
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   3RD SCREEN
      *------------------------------------------------------
     C           #SCRN3    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN53
     C                     EXFMTCTL02
     C                     MOVE *OFF      *IN53
      *
     C                     Z-ADD@@REC     #RCNO2
      *
     C           *INKA     IFEQ '0'
     C           *IN38     ANDEQ'0'
     C           *IN53     ANDEQ'0'
     C                     MOVEL'1'       *INKL
     C                     ENDIF
     C*
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *IN38     WHEQ *ON
     C           W@YMD1    IFNE *ZERO
     C           W@YMD2    ORNE *ZERO
     C                     EXSR #SET21
     C                     ENDIF
     C*
     C           *INKL     WHEQ *ON
     C                     MOVEL@@ID      W@ID
     C           @@ID      IFEQ '02'
     C                     EXSR #CHK2
     C                     ENDIF
     C                     ENDSL
     C*
      *
     C                     ENDSR
** CMD
  F1:END
  F1:END    F12:GO BACK    PAGE UP/DWN
** MSG
NO DATA
DIE# ERROR
