     C*--------------------------------------------*
     C*  ...Ｎ　Ｎ＋１　Ｎ＋２月　日当箱数...    *
     C*  ...　　　　　　　　　　日当内示数       *
     C*--------------------------------------------*
     C                     Z-ADD1         B
     C           1         DO   31        B
     C           A         IFEQ 1
     C                     Z-ADDCA1,B     D       20
     C                     END
     C           A         IFEQ 2
     C                     Z-ADDCA2,B     D
     C                     END
     C           A         IFEQ 3
     C                     Z-ADDCA3,B     D
     C                     END
      *
     C           D         IFNE 0
      *
     C           A         IFEQ 1
     C           CW1,B     IFNE 0
     C           CW1,B     IFEQ 1
     C                     Z-ADDWND3      HNS1,D
     C                     Z-ADDWND1      HSS1,D
     C                     ELSE
      *
     C                     Z-ADDWND6      HNS1,D
     C           WND1      DIV  2         HSS1,D    H
     C                     END
     C                     END
     C                     END
      *
     C           A         IFEQ 2
     C           CW2,B     IFNE 0
     C           CW2,B     IFEQ 1
     C                     Z-ADDWND3      HNS2,D
     C                     Z-ADDWND3      HND,1
     C                     Z-ADDWND1      HSS2,D
     C                     ELSE
      *
     C                     Z-ADDWND6      HNS2,D
     C                     Z-ADDWND3      HND,1
     C           WND1      DIV  2         HSS2,D    H
     C                     END
     C                     END
     C                     END
      *
     C           A         IFEQ 3
     C           CW3,B     IFNE 0
     C           CW3,B     IFEQ 1
     C                     Z-ADDWND3      HNS3,D
     C                     Z-ADDWND3      HND,2
     C                     Z-ADDWND1      HSS3,D
     C                     ELSE
      *
     C                     Z-ADDWND6      HNS3,D
     C                     Z-ADDWND3      HND,2
     C           WND1      DIV  2         HSS3,D    H
     C                     END
     C                     END
     C                     END
      *
     C                     END
     C                     END
     C           SAP1      TAG
     C                     END
