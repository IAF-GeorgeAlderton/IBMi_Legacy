     C                     PARM           PAPDPT  40
     C                     PARM           PARTN   1
      *
     C           PARTN     IFNE '*'                                    S
     C           PAPDPT    ANDEQ0111                                   S
     C           PAPKIN    ANDEQ'C'                                    S
     C           PAKIND    ANDNE'C'                                    S
     C                     MOVELPAPLOC    PPLOC   6
     C                     EXSR #SB540
     C                     ENDIF                                       S
      *
     CSR         ESB530    ENDSR
      *----------------------------------------------------*
      * PLASTIC STATUS                                     *
      *----------------------------------------------------*
     CSR         #SB540    BEGSR
      *
     C                     CALL 'ALOR29'
     C                     PARM           PHSHN1  5
     C                     PARM           PHSHN2  5
     C                     PARM           PHSHN3  2
     C                     PARM           PAPPRC  3
     C                     PARM           PAPMCN  3
     C                     PARM           W#3DAT  80
     C                     PARM           W#TIME  60
     C                     PARM           P@BZK   40        BZ計量済み
     C                     PARM           P@DSK   40        DS計量済み
     C                     PARM           P@JCK   40        JC計量済み
     C                     PARM           P@BZI   40        BZ投入中
     C                     PARM           P@DSI   40        DS投入中
     C                     PARM           P@JCI   40        JC投入中
     C                     PARM           P@PLBZ  40        BZ PRE
     C                     PARM           P@PLDS  40        DS PRE
     C                     PARM           P@PLJC  40        JC PRE
     C                     PARM           P@LPLD  80        LAST PRE DATE
     C                     PARM           P@LPLT  60        TIME
JW1   * P/T STATUS
"    C                     PARM           P@PLPD  80       PT BF OUT DATE
"    C                     PARM           P@PLPS  40       PT SHIP PRELOAD
      *
     C***                  ADD  P@BZK     P9BZK   40
     C***                  ADD  P@DSK     P9DSK   40
     C***                  ADD  P@JCK     P9JCK   40
     C                     ADD  P@BZI     P9BZI   40
     C                     ADD  P@DSI     P9DSI   40
     C                     ADD  P@JCI     P9JCI   40
     C                     ADD  P@PLBZ    P9PLBZ  40
     C                     ADD  P@PLDS    P9PLDS  40
     C                     ADD  P@PLJC    P9PLJC  40
      *
     C                     Z-ADDP@LPLD    P9LP2D  80
     C                     Z-ADDP@LPLT    P9LP2T  60
      *
     C                     MOVEL'*'       PCHK    1
      *
      *
     CSR         ESB540    ENDSR
      *----------------------------------------------------*
      *  GET PREVIOUS DATA                                 *
      *----------------------------------------------------*
     CSR         #SB590    BEGSR
      *
     C           KEYW2     KLIST
     C                     KFLD           KASHN1
     C                     KFLD           KASHN2
     C                     KFLD           KASHN3
     C                     MOVELBASHN1    KASHN1  5
     C                     MOVELBASHN2    KASHN2  5
     C                     MOVELBASHN3    KASHN3  2
      *
     C           KEYW2     CHAINABTWL30              19
      *
     C           *IN19     IFEQ '0'
     C                     Z-ADDW1ALD3    P9ALD3  40
     C                     Z-ADDW1ADA1    P9ADA1  40
     C                     Z-ADDW1NYKO    P9NYKO  40
     C                     Z-ADDW1SRT     P9SRT   40
     C                     Z-ADDW1OUK     P9OUK   40
     C                     Z-ADDW1BZK     P9BZK   40
     C                     Z-ADDW1DSK     P9DSK   40
     C                     Z-ADDW1JCK     P9JCK   40
     C                     Z-ADDW1SBK     P9SBK   40
     C                     Z-ADDW1LOQK    P9LOQK  40
     C                     Z-ADDW1OUI     P9OUI   40
     C                     Z-ADDW1BZI     P9BZI   40
     C                     Z-ADDW1DSI     P9DSI   40
     C                     Z-ADDW1JCI     P9JCI   40
     C                     Z-ADDW1SBI     P9SBI   40
     C                     Z-ADDW1LOQI    P9LOQI  40
     C                     Z-ADDW1PLOU    P9PLOU  40
     C                     Z-ADDW1PLBZ    P9PLBZ  40
     C                     Z-ADDW1PLDS    P9PLDS  40
     C                     Z-ADDW1PLJC    P9PLJC  40
     C                     Z-ADDW1PLSB    P9PLSB  40
     C                     Z-ADDW1PLLO    P9PLLO  40
     C                     Z-ADDW1PRE     P9PRE   40
