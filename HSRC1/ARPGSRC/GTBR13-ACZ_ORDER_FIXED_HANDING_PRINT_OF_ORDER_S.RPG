     C           KEY3      KLIST
     C                     KFLD           KYEAR
     C                     KFLD           KMONTH
     C                     Z-ADD*YEAR     KYEAR   40
     C                     Z-ADD*MONTH    KMONTH  20
     C                     SETOF                     30
     C                     Z-ADD0         $$KADO  31
     C           KEY3      SETLLAGDPL121
     C                     DO   *HIVAL
     C           KEY3      READEAGDPL12                  30
     C           *IN30     IFEQ '0'
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
