     C*
     C* DAYLY ORDER DATA BEFOR ADDING FILE
     C           *LOVAL    SETLLGTBPL10
     C*--------------------
S1   C                     DO   *HIVAL
     C                     READ GTBPL10                  90
     C   90                LEAVE
 S2  C           IBSKJY    IFEQ 'D'
     C           IBSKHZ    ANDLE*DATE
     C                     ITER
 E2  C                     ENDIF
     C*
     C                     MOVE *BLANK    S1CHG            CHG
     C                     MOVE *BLANK    S1HIN            PART NO.
     C                     MOVE IBHIN1    S1HIN1           PART NO1
     C                     MOVE IBHIN2    S1HIN2           PART NO2
     C                     MOVE IBHIN3    S1HIN3           PART NO3
     C                     MOVE '-'       S1HF1
     C                     MOVE '-'       S1HF2
     C           S1HIN3    IFEQ *BLANK                     PART NO3
     C                     MOVE ' '       S1HF2
     C           S1HIN2    IFEQ *BLANK                     PART NO2
     C                     MOVE ' '       S1HF1
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADDIBSURY    S1SURY           QTY
     C                     Z-ADDIBSYOS    S1SYOS           QTY/BOX
     C                     Z-ADDIBMAIS    S1MAIS           BOX
     C                     Z-ADDIBMAIS    S1SHIP           SHIP/BOX
     C                     Z-ADD0         S1AIR            AIR/BOX
     C                     Z-ADD0         S1DLVR           DELIVERY
 %002C*製品区分再入力
     C                     MOVE *BLANK    WWSEIH           PART CODE
     C                     MOVE *BLANK    WWZETI  4        ID NO.
     C                     EXSR #TYPE
     C           WWSEIH    IFEQ *BLANK
     C                     MOVE IBSEIH    S1SEIH
     C                     ELSE
     C                     MOVE WWSEIH    S1SEIH
