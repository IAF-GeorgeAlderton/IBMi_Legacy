     C                     Z-ADDD2SHIP    S1SHIP           SHIP/BOX
     C                     Z-ADDD2AIR     S1AIR            AIR/BOX
     C                     Z-ADDD2DLVR    S1DLVR           DELIVERY
     C  N91                UPDATSFREC1
     C                     Z-ADDCHGRRN    RRN
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
      *===============================================================
      *===============================================================
      *<ORDER SHEET>
      *===============================================================
     C           #LIST     BEGSR
     C                     MOVE ' '       @FIRST  1
     C                     MOVEL'1'       *INOF
     C*--------------------
S1   C                     DO   ENDRRN    RRN1
     C           RRN1      CHAINSFREC1               91
     C   91                LEAVE
     C*
     C                     EXSR #WRT01
     C*
E1   C                     ENDDO
     C*--------------------
     C*
     C                     MOVE '#END    '@STEP
     C                     ENDSR
      *===============================================================
      *
      *===============================================================
     C           #WRT01    BEGSR
     C*
     C                     TIME           @@TIME
     C                     MOVE *BLANK    ICSKJY           DELETE CODE
     C                     Z-ADD0         ICSKHZ
     C                     Z-ADD*DATE     ICKOHZ
     C                     Z-ADD@TIME     ICKOTM
     C                     MOVEL@@USID    ICKOME
     C*
     C                     MOVELD1ODER    ICODER
     C                     MOVELS1ZETI    ICZETI
     C                     MOVELS1SEIH    ICSEIH
     C                     MOVELS1HIN1    ICHIN1
     C                     MOVELS1HIN2    ICHIN2
     C                     MOVELS1HIN3    ICHIN3
     C                     Z-ADDS1SYOS    ICSYOS
     C                     Z-ADDW1YEAR    ICODRY
     C                     Z-ADDW1MONT    ICODRM
     C                     Z-ADDW1DAY     ICODRD
     C                     MOVE *BLANK    ICINVO
     C                     Z-ADD0         ICSURT
     C                     Z-ADD0         ICSIPY
     C                     Z-ADD0         ICSIPM
     C                     Z-ADD0         ICSIPD
     C                     MOVE *BLANK    ICIFMK
     C                     Z-ADD0         ICIFNY
     C                     Z-ADD0         ICIFNM
     C                     Z-ADD0         ICIFND
     C                     Z-ADD0         ICMJHZ
     C*
     C           KEY01     KLIST
     C                     KFLD           ICHIN1
     C                     KFLD           ICHIN2
     C                     KFLD           ICHIN3
     C                     MOVE *BLANK    $$HAKO  1
     C                     MOVE *BLANK    $$KTRK  1
     C                     MOVE *BLANK    $$KTRT  2
     C                     MOVE *BLANK    $$KTRR  2
     C                     MOVE *BLANK    $$KTRD  1
     C                     Z-ADD0         $$GEKN  90
     C                     Z-ADD0         $$TUSZ  20
     C                     MOVE *BLANK    $$SMEI 15
     C                     MOVE *BLANK    $$TMEI 15
     C                     MOVE *BLANK    $$DMEI 15
     C                     Z-ADD0         $$GEK2  90       月間必要数
     C*
     C* S1SEIH <> '3' FCEPL01
     C           KEY01     CHAINFCEPL01              95
     C  N95      A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     95
     C                     ENDIF
     C           *IN95     IFEQ *OFF
     C                     Z-ADDA2GEKN    $$GEKN
     C                     Z-ADDA2TUSZ    $$TUSZ
     C                     MOVE A2SMEI    $$SMEI
     C                     MOVE *BLANK    $$TMEI
     C                     MOVE *BLANK    $$DMEI
     C           A2SYHZ    IFGT *DATE
     C                     MOVE A2KSYT    $$HAKO
     C                     ELSE
     C                     MOVE A2SSYT    $$HAKO
     C                     ENDIF
     C           A2TRHZ    IFGT *DATE
     C                     MOVE A2KTRK    $$KTRK
     C                     MOVE A2KTRT    $$KTRT
     C                     MOVE A2KTRR    $$KTRR
     C                     MOVE A2KTRD    $$KTRD
     C                     ELSE
     C                     MOVE A2STRK    $$KTRK
     C                     MOVE A2STRT    $$KTRT
     C                     MOVE A2STRR    $$KTRR
     C                     MOVE A2STRD    $$KTRD
     C                     ENDIF
     C                     ENDIF
     C*上のルーチンで決めた収容数と所番地を
     C*各かんばんマスターから引きなおす！
     C                     EXSR #TYPE2
     C*
     C                     MOVE '0'       GETFLG  1
      *     < AIR >
     C           S1AIR     IFNE 0                          AIR/BOX
     C                     Z-ADDS1AIR     ICMAIS
     C           S1AIR     MULT S1SYOS    ICSURY
     C                     Z-ADDS1DLYY    ICDLVY           DELLIVERY DATE YEAR
     C                     Z-ADDS1DLMM    ICDLVM           DELIVERY DATE MONTH
     C                     Z-ADDS1DLDD    ICDLVD           DELIVERY DATE DAY
     C                     MOVE 'A'       ICHANY           CARRY CODE
     C                     MOVEL' AIR'    W1CRY   4
      * MSK 2004.11.10
     C           S1SURY    SUB  ICSURY    @@SURY  90
     C           @@SURY    IFEQ 0
     C                     MOVE '1'       GETFLG
     C                     END
     C                     EXSR #WRT02
     C           S1SURY    SUB  ICSURY    S1SURY
     C                     ENDIF
      *     < SHIP >
     C           S1SURY    IFNE 0
     C                     Z-ADDS1SHIP    ICMAIS
     C                     Z-ADDS1SURY    ICSURY
     C                     Z-ADD0         ICDLVY           DELLIVERY DATE YEAR
     C                     Z-ADD0         ICDLVM           DELIVERY DATE MONTH
     C                     Z-ADD0         ICDLVD           DELIVERY DATE DAY
     C                     MOVE 'S'       ICHANY           CARRY CODE
     C                     MOVEL'SHIP'    W1CRY
     C                     MOVE '1'       GETFLG
     C                     EXSR #WRT02
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *
      *===============================================================
     C           #WRT02    BEGSR
     C*
     C                     ADD  1         W1NO
     C           W1NO      IFEQ 0
     C                     Z-ADD1         W1NO
     C                     ENDIF
     C                     Z-ADDW1NO      ICITEM
     C*
     C                     WRITEGTBPP151
     C*
     C                     MOVELICODRY    W@ODRY
     C                     MOVELICODRM    W@ODRM
     C                     MOVELICODRD    W@ODRD
     C                     MOVELW@ODDT    ICODDT
     C                     MOVEL'IAF'     W@ODR1
     C                     MOVELICODER    W@ODR2
     C                     MOVELW@ODR#    ICODR#
     C                     MOVELICITEM    ICITM#
     C                     MOVELICHIN1    W@HIN1
     C                     MOVELICHIN2    W@HIN2
     C                     MOVELICHIN3    W@HIN3
     C                     MOVELW@HIN#    ICHIN#
     C                     MOVEL$$KTRK    W@LOC1
     C                     MOVEL$$KTRT    W@LOC2
     C                     MOVEL$$KTRR    W@LOC3
     C                     MOVEL$$KTRD    W@LOC4
     C                     MOVELW@LOC     ICLOC
     C                     WRITEGTBWP131
     C*
     C                     EXCPTDTE
      * MSK 2004.11.10
     C           GETFLG    IFEQ '1'
     C                     EXSR $SB900
     C                     END
     C*
     C                     ENDSR
      *--------------------------------------------------------------*
      * NUMBER OF SHEETS RECORD FILE  GET                            *
      *--------------------------------------------------------------*
     CSR         $SB900    BEGSR
     C           KEYXA1    KLIST
     C                     KFLD           ICHIN1
     C                     KFLD           ICHIN2
     C                     KFLD           ICHIN3
     C                     SETOF                       29
     C           KEYXA1    CHAINGTBPPY11             29
     C           *IN29     IFEQ '0'
     C                     Z-ADDXZMAS5    @@MAIS  50
     C                     MOVEL'IAF'     XAFACT
     C                     MOVELD1ODER    XAODER
     C                     UPDATGTBPPY11
     C                     END
     CSR         $S900E    ENDSR
      *===============================================================
      *  確認画面表示
      *===============================================================
     C           #CONF     BEGSR
      *
     C                     WRITEW1
     C                     EXFMTDSP09
      *  < F3 >  BACK
     C           *INKC     IFEQ *ON
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
      *  < F5 >  OK
     C           *INKE     IFEQ *ON
     C                     MOVE '#LIST   '@STEP
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
     OGTBWPE1 E                DTE
     O                         ICSEIH
     O                                      '-'
     O                         W1NO
     O                                      ';'
     O                         ICHIN1
     O                                      '-'
     O                         ICHIN2
     O                      N15             '-'
     O                         ICHIN3
     O                                      ';'
     O                         ICSURY1
     O                                      ';'
     O                         ICMAIS3
     O                                      ';'
     O                         ICSYOS1
      *===============================================================
**  MSG
 CHANGE IS '1'
 SELECT CHANGE DATA.
 SELECT ONLY ONE.
 INCORRECT AIR BOX.
 INPUT DELIVERY DATE.
 INCORRECT DELIVERY DATE.
 INPUT 'Y' OR 'N'
