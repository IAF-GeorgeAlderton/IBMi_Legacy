     C                     MOVE L5ZETI    WWZETI
     C                     GOTO ETYPE
     C                     END
     C  N54                ENDDO
      *
     C                     SETOF                     54
     C           KEY02     SETLLAANPL061                 54
     C                     DO   *HIVAL
     C           ##3       TAG
     C           KEY02     READEAANPL061                 54
     C           *IN54     IFEQ '0'
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    IFLE *DATE
     C                     GOTO ##3
     C                     END
     C                     END
     C           L7UKHZ    IFGT *DATE
     C                     GOTO ##3
     C                     END
     C           L7STHZ    IFLE *DATE
     C                     GOTO ##3
     C                     END
