 %002C           #TYPE     BEGSR                                     *
     C****************************************************************
     C*<KANBAN TYPE>
     C           KEY02     KLIST
     C                     KFLD           IBHIN1
     C                     KFLD           IBHIN2
     C                     KFLD           IBHIN3
     C                     SETOF                     54
     C           KEY02     SETGTAAPTL011
     C                     DO   *HIVAL
     C           ##1       TAG
     C           KEY02     REDPEAAPTL011                 54
     C           *IN54     IFEQ '0'
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    IFLE *DATE
     C                     GOTO ##1
     C                     END
     C                     END
     C*
     C           L5UKHZ    IFGT *DATE
     C                     GOTO ##1
     C                     END
     C*
     C           L5STHZ    IFLE *DATE
     C                     GOTO ##1
     C                     END
     C*
