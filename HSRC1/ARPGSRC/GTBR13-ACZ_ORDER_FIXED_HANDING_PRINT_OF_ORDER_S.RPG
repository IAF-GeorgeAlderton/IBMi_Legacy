     C                     ENDIF
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ'*'
     C                     ADD  .5        $$KADO
     C                     ENDIF
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  .5        $$KADO
     C                     ENDIF
     C                     ENDIF
     C  N30                ENDDO
