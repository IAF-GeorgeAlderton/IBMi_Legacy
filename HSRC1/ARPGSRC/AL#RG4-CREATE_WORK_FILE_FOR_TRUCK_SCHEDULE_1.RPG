     H            Y.
     F** AL#RG4  *******************************************
     F* CREATE WORK FILE FOR TRUCK SCHEDULE 1              *
     F*      T.SAKAKI    2016.08.12                        *
     F******************************************************
     FAGDPL12 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FAL#PP81 IF  E           K        DISK
     FABAWL13 IF  E           K        DISK
     FAL#PPC1 IF  E           K        DISK
     FAL#PLG1 IF  E           K        DISK
     FAL#WPG3 UF  E           K        DISK                      A
      *
     E                    NSU        31  7 0             DAILY FORECAST
     E                    TRC        50  9               TRUCK PATTERN
     E                    TRB        50  2               TRUCK BIN
     E                    TRT        50  4 0             START TIME
     E                    TRE        50  4 0             END TIME
     E                    DTRC       50  9               TRUCK PATTERN
     E                    DTRB       50  2               TRUCK PATTERN
     E                    DTRT       50  4 0             START TIME
     E                    DTRE       50  4 0             END TIME
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
     I            DS
     I                                        1   80F8KYMD
     I                                        1   60K1YMD
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I                                        7   80@D
     I            DS
     I                                        1   80WKSDAT
     I                                        1   60WKSYM
     I                                        1   40WKSDYY
     I                                        5   60WKSDMM
     I                                        7   80WKSDDD
     I            DS
     I                                        1   80WKEDAT
     I                                        1   60WKEYM
     I                                        1   40WKEDYY
     I                                        5   60WKEDMM
     I                                        7   80WKEDDD
     I            DS
     I                                        1  12 W@SHN
     I                                        1   5 @HIN1
     I                                        6  10 @HIN2
     I                                       11  12 @HIN3
     I            DS
     I                                        1  20 @MHIN
     I                                        1   5 @MHIN1
     I                                        6  10 @MHIN2
     I                                       11  15 @MHIN3
     I                                       16  20 @MHIN4
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     I            DS
     I                                        1   80A2SYMD
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
     I            DS
     I                                        1 2170NSU
     I                                        1   70ABNN01
     I                                        8  140ABNN02
     I                                       15  210ABNN03
     I                                       22  280ABNN04
     I                                       29  350ABNN05
     I                                       36  420ABNN06
     I                                       43  490ABNN07
     I                                       50  560ABNN08
     I                                       57  630ABNN09
     I                                       64  700ABNN10
     I                                       71  770ABNN11
     I                                       78  840ABNN12
     I                                       85  910ABNN13
     I                                       92  980ABNN14
     I                                       99 1050ABNN15
     I                                      106 1120ABNN16
     I                                      113 1190ABNN17
     I                                      120 1260ABNN18
     I                                      127 1330ABNN19
     I                                      134 1400ABNN20
     I                                      141 1470ABNN21
     I                                      148 1540ABNN22
     I                                      155 1610ABNN23
     I                                      162 1680ABNN24
     I                                      169 1750ABNN25
     I                                      176 1820ABNN26
     I                                      183 1890ABNN27
     I                                      190 1960ABNN28
     I                                      197 2030ABNN29
     I                                      204 2100ABNN30
     I                                      211 2170ABNN31
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *-----------------------------------------------------
      *  ENTRY LIST
      *-----------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           P1SDAT  80
     C                     PARM           P1EDAT  80
     C                     PARM           P1KIHZ  80
     C                     PARM           P9CMD   2
      *-----------------------------------------------------
      *  KEY LIST
      *-----------------------------------------------------
     C           KEYAG     KLIST
     C                     KFLD           WKSDYY
     C                     KFLD           WKSDMM
     C                     KFLD           WKSDDD
     C           KEYA1     KLIST
     C                     KFLD           ABTOKU
     C                     KFLD           ABNONY
     C***                  KFLD           ABNKOJ
     C                     KFLD           WKNKOJ  1
     C                     KFLD           ABNUKE
     C                     KFLD           P1KIHZ
     C           KEYW1     KLIST
     C                     KFLD           ABTOKU
     C                     KFLD           ABNONY
     C                     KFLD           ABNKOJ
     C                     KFLD           ABNUKE
     C                     KFLD           K1KYMD  8
     C                     KFLD           K1SURT  9
     C                     KFLD           ABMHN1
     C                     KFLD           ABMHN2
     C                     KFLD           ABMHN3
     C                     KFLD           ABMHN4
     C                     KFLD           K1EGBC
     C           KEYFC     KLIST
     C                     KFLD           @HIN1   5
     C                     KFLD           @HIN2   5
     C                     KFLD           @HIN3   2
     C           KEY81     KLIST
     C                     KFLD           @HIN1
     C                     KFLD           @HIN2
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      * INITIALIZE
     C                     MOVEL*BLANK    WKNKOJ
     C                     Z-ADDP1SDAT    WKSDAT
     C                     Z-ADDP1EDAT    WKEDAT
     C                     Z-ADD1         X       30
     C                     Z-ADD0         @SAKA   50
     C                     CLEARTRC
     C                     CLEARTRB
     C                     CLEARTRT
     C                     CLEARTRE
      * GET TRUCK PATTERN
     C           P1KIHZ    SETLLAL#PPC1
     C                     DO   *HIVAL
     C           P1KIHZ    READEAL#PPC11                 80
     C   80                LEAVE
     C           *IN80     IFEQ '0'
     C           C5SKJY    IFEQ 'D'
     C           C5SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELC5SURT    TRC,X
     C                     MOVELC5TRKB    TRB,X
     C                     Z-ADDC5STTN    TRT,X
     C                     Z-ADDC5EDTN    TRE,X
     C                     ADD  1         X
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      * SHIP DATE
     C           KEYAG     SETLLAGDPL121
     C                     READ AGDPL121                 81
      *
     C           *IN81     DOWEQ'0'
      *
     C           F8KYMD    IFGT P1EDAT
     C                     LEAVE
     C                     ENDIF
      *
     C                     EXSR #SB400
      *
     C                     READ AGDPL121                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  ABAWP10  FORECAST
      *-----------------------------------------------------
     CSR         #SB400    BEGSR
      *
     C                     MOVEL*BLANK    GET     1
      *
     C           K1YMD     SETLLABAWL13
     C                     DO   *HIVAL
     C           K1YMD     READEABAWL13                  82
     C   82                LEAVE
      *
     C           *IN82     IFEQ '0'
     C                     EXSR #SB410
     C                     ENDIF
      *
     C           CNT       IFGE 1
     C                     EXSR #SB420
     C                     ENDIF
      *
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *-----------------------------------------------------
      *  AL#PPG1  CHECK TRUCK PATTERN AND TRUCK BIN M/F
      *-----------------------------------------------------
     CSR         #SB410    BEGSR
      *
     C                     CLEARDTRC
     C                     CLEARDTRB
     C                     CLEARDTRT
     C                     CLEARDTRE
     C                     Z-ADD0         CNT     30
     C                     Z-ADD0         X       30
      *
     C           KEYA1     SETGTAL#PLG1
   D1C                     DO   *HIVAL
     C           KEYA1     REDPEAL#PLG1                  82
     C   82                LEAVE
   S1C           *IN82     IFEQ '0'
      *
  S2 C           CGSKJY    IFEQ 'D'
     C           CGSKHZ    ANDLE*DATE
     C                     ITER
  S2 C                     ENDIF
      *
  S2 C***        F8KYMD    IFGE CGKIHZ
     C                     Z-ADD1         Z       30
     C           CGSURT    LOKUPTRC,Z                    84
 S3  C           *IN84     IFEQ '1'
     C                     ADD  1         X
     C                     ADD  1         CNT
     C                     MOVELCGSURT    DTRC,X
     C                     MOVELTRB,Z     DTRB,X
     C                     Z-ADDTRT,Z     DTRT,X
     C                     Z-ADDTRE,Z     DTRE,X
 E3  C                     ENDIF
  S2 C***                  ENDIF
      *
   E1C                     ENDIF
      *
   D1C                     ENDDO
      *
     CSR         ESB410    ENDSR
      *-----------------------------------------------------
      * GET NUMBER OF BOXES
      *-----------------------------------------------------
     CSR         #SB420    BEGSR
      * IAF PART#
     C                     MOVELABTOKU    PTOKU   4
     C                     MOVELABNKOJ    PNKOJ   1
     C                     MOVELABNUKE    PNUKE   4
     C                     MOVELABNONY    PNONY   4
     C                     MOVELABMHN1    @MHIN1  5
     C                     MOVELABMHN2    @MHIN2  5
     C                     MOVELABMHN3    @MHIN3  5
     C                     MOVELABMHN4    @MHIN4  5
     C                     MOVEL*BLANK    @SHIN  12
     C                     MOVEL*BLANK    @FLG    1
      *
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           @MHIN  20
     C                     PARM           @SHIN  12
     C                     PARM           @FLG    1
      *
     C                     MOVEL@SHIN     W@SHN
      *
     C           KEYFC     CHAINFCEPL011             85
    1C           *IN85     IFEQ '0'
   2 C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLEF8KYMD
     C                     ELSE
      *
  3  C           F8KYMD    IFGE A2SYMD                     NEW
     C                     Z-ADDA2SSYS    WKQPC   50
     C                     ELSE
     C                     Z-ADDA2KSYS    WKQPC            OLD
 4   C           A2KSYS    IFEQ 0
     C                     Z-ADDA2SSYS    WKQPC   50
 4   C                     ENDIF
  3  C                     ENDIF
   2 C                     ENDIF
    1C                     ENDIF
      *
   S1C           WKQPC     IFEQ 0
     C                     ADD  1         @SAKA
     C                     ELSE
      *
     C                     Z-ADDNSU,@D    WK1QTY 100       DAILY
     C           WK1QTY    DIV  CNT       WK2QTY 133       PER TRUCK
     C           WK2QTY    DIV  WKQPC     WK1BOX 100       PER BOX
     C                     MVR            WK2BOX 133       MVR
   S2C           WK2BOX    IFNE 0
     C                     ADD  1         WK1BOX
   E2C                     ENDIF
      *
      * GET PALLET PULLING (E.G.BLOT)
     C                     MOVEL*BLANK    K1EGBC  1
     C                     SETOF                     45
     C           KEY81     CHAINAL#PP811             45
  S2 C           *IN45     IFEQ '0'
     C                     MOVEL'1'       K1EGBC
  E2 C                     ENDIF
      *
   D1C           1         DO   CNT       Y       30
      *
  S2 C           WK2QTY    IFNE 0
     C                     EXSR #SB500
  E2 C                     ENDIF
      *
   D1C                     ENDDO
      * NO IAF PART
   E1C                     ENDIF
      *
     CSR         ESB420    ENDSR
      *-----------------------------------------------------
      *  WRITE AL#WPG3
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C                     MOVEL*BLANK    K1KYMD
     C                     MOVELF8KYMD    K1KYMD
     C                     MOVEL*BLANK    K1SURT
     C                     MOVELDTRC,Y    K1SURT
      *
     C           KEYW1     CHAINAL#WPG31             85
     C           *IN85     IFEQ '0'
     C                     ADD  WK2QTY    W1QTY
     C                     ADD  WK1BOX    W1BOX
     C                     UPDATAL#WPG31
     C                     ELSE
     C                     CLEARAL#WPG31
     C                     Z-ADDABTOKU    W1TOKU
     C                     Z-ADDABNONY    W1NONY
     C                     MOVELABNKOJ    W1NKOJ
     C                     MOVELABNUKE    W1NUKE
     C                     MOVELF8KYMD    W1SHID
     C                     MOVELDTRC,Y    W1SURT
     C                     MOVELDTRB,Y    W1TRKB
     C                     Z-ADDDTRT,Y    W1STTN
     C                     Z-ADDDTRE,Y    W1EDTN
     C                     MOVELABMHN1    W1MHN1
     C                     MOVELABMHN2    W1MHN2
     C                     MOVELABMHN3    W1MHN3
     C                     MOVELABMHN4    W1MHN4
     C                     MOVEL@HIN1     W1SHN1
     C                     MOVEL@HIN2     W1SHN2
     C                     MOVEL@HIN3     W1SHN3
     C                     Z-ADDWK2QTY    W1QTY
     C                     Z-ADDWK1BOX    W1BOX
     C                     Z-ADDWKQPC     W1QPC
     C                     MOVELK1EGBC    W1EGBC
     C                     Z-ADDCNT       W1DIVN
     C                     WRITEAL#WPG31
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
