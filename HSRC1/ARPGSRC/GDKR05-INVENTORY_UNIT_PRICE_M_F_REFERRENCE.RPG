      *** GDKR05 *************************************
      *        INVENTORY UNIT PRICE M/F REFERRENCE   *
      *  G.B.C                         97/07/25      *
      ************************************************
     H            Y/                                    1
     FGDKPW05 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL01
     FGDKPL05 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     E****************************************************************
     E                    MSG     1   2 59
     I****************************************************************
     I            DS
     I                                        1  20 W1HIN
     I                                        1   5 W1HIN1
     I                                        6  10 W1HIN2
     I                                       11  12 W1HIN3
     I                                        1   2 W1KAT1
     I                                        3   6 W1KAT2
     I                                        7   7 W1KAT3
     I                                        8   8 W1KAT4
     I            DS
     I                                        1  14 WWHIN
     I                                        1   5 WWHIN1
     I                                        6   6 WWH1
     I                                        7  11 WWHIN2
     I                                       12  12 WWH2
     I                                       13  14 WWHIN3
     I            DS
     I                                        1  14 WWKATA
     I                                        1   2 WWKAT1
     I                                        3   3 WWKA1
     I                                        4   7 WWKAT2
     I                                        8   8 WWKA2
     I                                        9   9 WWKAT3
     I                                       10  10 WWKA3
     I                                       11  11 WWKAT4
     I*
     I* ORDER DATE *
     I            DS
     I                                        1   80ITHTDT
     I                                        1   20ITHTMM
     I                                        3   40ITHTDD
     I                                        5   80ITHTYY
     I* RECEIPT DATE *
     I            DS
     I                                        1   80ITUKDT
     I                                        1   20ITUKMM
     I                                        3   40ITUKDD
     I                                        5   80ITUKYY
     I* DUE DATE *
     I            DS
     I                                        1   80ITSIDT
     I                                        1   20ITSIMM
     I                                        3   40ITSIDD
     I                                        5   80ITSIYY
     I* ORDER & ITEM *
     I            DS
     I                                        1  12 W@ODIT
     I                                        1   6 W@ODER
     I I            '-'                       7   7 W@HFN
     I                                        8  12 W@ITEM
     C****************************************************************
     C*           KEY LIST                                           *
     C****************************************************************
     C*** ACTUAL PRUCHACE OF INPRTED GODDS ** (GDKPL05)
     C           ITKEY1    KLIST
     C                     KFLD           ITINVO
     C*
     C           ITKEY2    KLIST
     C                     KFLD           ITINVO
     C                     KFLD           ITVEND
     C                     KFLD           ITTYPE
     C                     KFLD           ITHIN
     C                     KFLD           ITODER
     C                     KFLD           ITITEM
     C****************************************************************
     C*           MAIN ROUTINE                                       *
     C****************************************************************
     C           @START    TAG
     C                     CLEARDSP01
     C*** DSP01 ***
     C           @DSP01    TAG
     C                     MOVE '0'       *IN30
     C                     WRITEDSP03
     C                     EXFMTDSP01
     C*
     C                     EXSR #CLEAR
     C           *INKA     CABEQ'1'       @END
     C*
     C                     EXSR #D1CHK
     C           *IN99     CABEQ'1'       @DSP01
     C*
     C                     EXSR #S1SET                     SFL01 SET
     C**
     C           @SFL01    TAG
     C                     MOVE *ON       *IN26
     C                     WRITEDSP04
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN26
     C                     EXSR #CLEAR
     C*
     C           *INKA     CABEQ*ON       @END
     C           *INKC     CABEQ*ON       @DSP01
     C*
     C                     EXSR #S1CHK                     SFL01 CHECK
     C           *IN99     CABEQ*ON       @SFL01
     C**
     C                     Z-ADD*ZERO     RRN
     C                     DO   *HIVAL
     C                     ADD  1         RRN
     C           RRN       CHAINSFL01                80
     C   80                LEAVE
     C*
     C           S1REF     IFEQ '1'
     C                     EXSR #D2SET
     C                     EXSR #D2DSP
     C           *IN01     CABEQ*ON       @END
     C           *IN03     CABEQ*ON       @SFL01
     C*
     C                     MOVEL*BLANK    S1REF
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDDO
     C**
     C                     GOTO @SFL01
     C**
     C           @END      TAG
     C                     SETON                     LR
     C                     RETRN
     C****************************************************************
     C*          #CLEAR    INDICATOR & MSG CLEAR                     *
     C****************************************************************
     C           #CLEAR    BEGSR                                     *
     C                     MOVEA'00'      *IN,11
     C                     SETOF                     010399
     C                     MOVE *BLANK    D#MSG
     C                     ENDSR
     C****************************************************************
     C*          #D1CHK    DSP01 CHECK                               *
     C****************************************************************
     C           #D1CHK    BEGSR                                     *
     C** INVOICE NO. **
     C                     MOVELD1INVO    ITINVO
     C           ITKEY1    SETLLGDKPL051                 90
     C*
     C           *IN90     IFEQ *OFF
     C  N99                MOVELMSG,1     D#MSG
     C                     SETON                     9911
     C                     ENDIF
     C*
     C                     ENDSR
     C****************************************************************
     C*          #S1SET    SFL01 SET                                 *
     C****************************************************************
     C           #S1SET    BEGSR                                     *
     C                     CLEARCTL01
     C                     MOVELD1INVO    C1INVO
     C                     Z-ADD*ZERO     D4TOTL
     C** SFLCLR **
     C                     MOVE *ON       *IN25
     C                     WRITECTL01
     C                     MOVE *OFF      *IN25
     C                     Z-ADD*ZERO     RRN     40
     C**
     C                     MOVELD1INVO    ITINVO
     C           ITKEY1    SETLLGDKPL051
     C** FILE READ **
     C                     DO   *HIVAL
     C           ITKEY1    READEGDKPL051                 91
     C   91                LEAVE
     C*
     C           RRN       IFEQ 1
     C                     MOVELITVEND    C1VEND
     C                     MOVEL*BLANK    C1VDNM
     C                     ENDIF
     C*
     C                     CLEARSFL01
     C*
     C                     MOVELITTYPE    S1TYPE
     C                     MOVEL*BLANK    S1HIN
     C                     MOVELITHIN     SXHIN
     C                     MOVELITHIN     W1HIN
     C                     MOVELITHIN     S1HIN
     C           ITTYPE    IFEQ 'B'
     C           ITTYPE    OREQ 'C'
     C           ITTYPE    OREQ 'D'
     C                     MOVE *BLANK    S1HIN
     C                     MOVE *BLANK    WWHIN
     C                     MOVE W1HIN1    WWHIN1
     C                     MOVE W1HIN2    WWHIN2
     C                     MOVE W1HIN3    WWHIN3
     C                     MOVE '-'       WWH1
     C           WWHIN3    IFNE *BLANK
     C                     MOVE '-'       WWH2
     C                     END
     C                     MOVELWWHIN     S1HIN
     C                     END
     C           ITTYPE    IFEQ 'E'
     C                     MOVE *BLANK    S1HIN
     C                     MOVE *BLANK    WWKATA
     C                     MOVE W1KAT1    WWKAT1
     C                     MOVE W1KAT2    WWKAT2
     C                     MOVE W1KAT3    WWKAT3
     C                     MOVE W1KAT4    WWKAT4
     C                     MOVE '-'       WWKA1
     C           WWKAT3    IFNE *BLANK
     C                     MOVE '-'       WWKA2
     C                     END
     C           WWKAT4    IFNE *BLANK
     C                     MOVE '-'       WWKA3
     C                     END
     C                     MOVELWWKATA    S1HIN
     C                     END
     C                     MOVELITODER    S1ODER
     C                     MOVELITITEM    S1ITEM
     C                     Z-ADDITHAKO    S1HAKO
     C                     Z-ADDITSRY     S1SRY
     C                     Z-ADDITKIN     S1KIN
     C                     ADD  ITKIN     D4TOTL
     C                     MOVELITVEND    S1VEND
     C*
     C                     ADD  1         RRN
     C                     WRITESFL01
     C                     ENDDO
     C*
     C                     Z-ADD1         RRN
     C                     ENDSR
     C****************************************************************
     C*          #S1CHK    SFL01 CHECK                               *
     C****************************************************************
     C           #S1CHK    BEGSR                                     *
     C                     Z-ADD*ZERO     RRN
     C*
     C                     DO   *HIVAL
     C                     ADD  1         RRN
     C           RRN       CHAINSFL01                80
     C   80                LEAVE
     C*
     C                     MOVE *OFF      *IN12
     C*
     C           S1REF     IFNE *BLANK
     C           S1REF     ANDNE'1'
     C                     SETON                     1299
     C                     ENDIF
     C*
     C                     UPDATSFL01
     C                     ENDDO
     C*
     C           *IN99     IFEQ *ON
     C                     MOVELMSG,2     D#MSG
     C                     ENDIF
     C                     ENDSR
     C****************************************************************
     C*          #D2SET    DSP02 SET                                 *
     C****************************************************************
     C           #D2SET    BEGSR
     C                     CLEARDSP02
     C*
     C                     MOVELD1INVO    ITINVO
     C                     MOVELS1VEND    ITVEND
     C                     MOVELS1TYPE    ITTYPE
     C                     MOVELSXHIN     ITHIN
     C                     MOVE S1ODER    ITODER
     C                     MOVE S1ITEM    ITITEM
     C           ITKEY2    CHAINGDKPL051             91
     C*
     C           *IN91     IFEQ *OFF
     C                     MOVELITINVO    D2INVO
     C                     MOVELITVEND    D2VEND
     C                     MOVEL*BLANK    D2VDNM
     C                     MOVE ITVEND    B2CODE
     C           B2CODE    CHAINFGBPL011             91
     C  N91                MOVELB2SMEI    D2VDNM
     C                     MOVELITTYPE    D2TYPE
     C                     MOVEL*BLANK    D2HIN
     C                     MOVELITHIN     W1HIN
     C                     MOVELITHIN     D2HIN
     C           ITTYPE    IFEQ 'B'
     C           ITTYPE    OREQ 'C'
     C           ITTYPE    OREQ 'D'
     C                     MOVE *BLANK    D2HIN
     C                     MOVE *BLANK    WWHIN
     C                     MOVE W1HIN1    WWHIN1
     C                     MOVE W1HIN2    WWHIN2
     C                     MOVE W1HIN3    WWHIN3
     C                     MOVE '-'       WWH1
     C           WWHIN3    IFNE *BLANK
     C                     MOVE '-'       WWH2
     C                     END
     C                     MOVELWWHIN     D2HIN
     C                     END
     C           ITTYPE    IFEQ 'E'
     C                     MOVE *BLANK    D2HIN
     C                     MOVE *BLANK    WWKATA
     C                     MOVE W1KAT1    WWKAT1
     C                     MOVE W1KAT2    WWKAT2
     C                     MOVE W1KAT3    WWKAT3
     C                     MOVE W1KAT4    WWKAT4
     C                     MOVE '-'       WWKA1
     C           WWKAT3    IFNE *BLANK
     C                     MOVE '-'       WWKA2
     C                     END
     C           WWKAT4    IFNE *BLANK
     C                     MOVE '-'       WWKA3
     C                     END
     C                     MOVELWWKATA    D2HIN
     C                     END
     C**
     C                     MOVE ITODER    W@ODER
     C                     MOVE ITITEM    W@ITEM
     C                     MOVELW@ODIT    D2ODER
     C                     Z-ADDITHTDT    D2HTDT
     C                     Z-ADDITUKDT    D2UKDT
     C                     Z-ADDITSIDT    D2SIDT
     C                     MOVELITKAMO    D2KAMO
     C                     MOVELITYUSO    D2YUSO
     C*
     C                     SELEC
     C           ITYUSO    WHEQ 'S'
     C                     MOVEL'(BY SEA)'D2YSNM
     C           ITYUSO    WHEQ 'A'
     C                     MOVEL'(BY AIR)'D2YSNM
     C                     ENDSL
     C                     Z-ADDITTAN     D2TAN
     C                     Z-ADDITSRY     D2SRY
     C                     Z-ADDITRATE    D2RATE
     C                     Z-ADDITKIN     D2KIN
     C                     Z-ADDITDOLL    D2DOLL
     C                     MOVELITTKBN    D2UNIT
     C                     ENDIF
     C                     ENDSR
     C****************************************************************
     C*          #D2DSP    DSP02 DSPLAY                              *
     C****************************************************************
     C           #D2DSP    BEGSR
     C*** DSP02 ***
     C           @DSP02    TAG
     C                     MOVE '1'       *IN30
     C                     WRITEDSP03
     C                     EXFMTDSP02
     C                     EXSR #CLEAR
     C*
     C           *INKA     COMP *ON                      01
     C           *INKC     COMP *ON                      03
     C*
     C           @D2END    ENDSR
**  MSG  **
ACTUAL PURCHASE OF INPORTED NOT FOUND.
INPUT ERROR
