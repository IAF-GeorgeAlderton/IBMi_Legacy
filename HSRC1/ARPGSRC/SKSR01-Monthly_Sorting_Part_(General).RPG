     FFCEPP01 IP  E                    DISK
     FMBEPL02 IF  E           K        DISK
     F**SKSWP01 O   F    1024            DISK
JW1  FSKSWP01 O   F     200            DISK
      *
     C  N44                EXCPTOHED
     C                     SETON                     44
      *
     C           A2GSKD    IFEQ 'D'
     C                     GOTO @END
     C                     END
      *
     C           A2BHB2    IFEQ '10013'
     C                     Z-ADD0         SAKA    40
     C                     END
      *
     C           A2GEKN    DIV  20        W@GEKN  90
      *
     C           W@GEKN    DIV  A2SSYS    W@DBOX  61
      *
     C                     CALL 'SKSR02'
     C                     PARM           A2STRK
     C                     PARM           A2STRT
     C                     PARM           A2STRR
     C                     PARM           A2STRD
     C                     PARM           P@JOK1  2
     C                     PARM           P@JOK2  2
     C                     PARM           P@JOK3  2
     C                     PARM           P@JOK4  2
     C                     PARM           P@JOK5  2
     C                     PARM           P@JOK6  2
     C                     PARM           P@JOK7  2
     C                     PARM           P@JOK8  2
     C                     PARM           P@KDAI  1
      *
     C                     CALL 'AAFRSB'
     C                     PARM           P@KDAI  1
     C                     PARM           P@JOK1  2
     C                     PARM           P@JOK2  2
     C                     PARM           P@JOK3  2
     C                     PARM           P@JOK4  2
     C                     PARM           P@JOK5  2
     C                     PARM           P@JOK6  2
     C                     PARM           P@JOK7  2
     C                     PARM           P@JOK8  2
     C                     PARM           P@NAME 40
      *
     C           P@NAME    IFEQ *BLANK
     C* * *                GOTO @END
     C                     END
      *
JW   C           P@NAME    IFEQ '80-8'
"    C                     MOVE *BLANK    P@NAME
"    C                     ENDIF
      *
     C                     EXSR #MBE
      *
     C                     Z-ADD0         W@8888 100
     C                     ADD  W@3411    W@8888
     C                     ADD  W@5149    W@8888
     C                     ADD  W@3611    W@8888
     C                     ADD  W@0492    W@8888
JW1  C                     ADD  W@HOND    W@8888
      *
     C                     Z-ADD0         W@PER
     C           W@GOKE    IFNE 0
     C           W@8888    DIV  W@GOKE    W@PER  105
     C                     END
      *
     C                     EXCPTODAT
      *
     C           @END      TAG
      *
     C           #MBE      BEGSR
      *
     C           HINKEY    KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
      *
     C                     Z-ADD0         W@GOKE 100
     C                     Z-ADD0         W@3411 100
     C                     Z-ADD0         W@5149 100
     C                     Z-ADD0         W@3611 100
     C                     Z-ADD0         W@0492 100
JW1  C                     Z-ADD0         W@HOND 100
     C                     Z-ADD0         W@9999 100
     C           HINKEY    SETLLMBEPL02
     C                     DO   *HIVAL
     C           HINKEY    READEMBEPL02                  88
     C   88                LEAVE
      *
     C                     ADD  F2GOKE    W@GOKE 100
      *
JW1  C                     SELEC
      * TOYOTA
     C           F2TOKU    WHEQ 3411
     C                     ADD  F2GOKE    W@3411
      * FORD
     C           F2TOKU    WHEQ 5149
     C                     ADD  F2GOKE    W@5149
      * SUBARU
     C           F2TOKU    WHEQ 3611
     C                     ADD  F2GOKE    W@3611
      * AWNC
     C           F2TOKU    WHEQ 0492
     C                     ADD  F2GOKE    W@0492
      *
      * HONDA
     C           F2TOKU    WHEQ 0294
     C           F2TOKU    OREQ 0295
     C           F2TOKU    OREQ 0296
     C           F2TOKU    OREQ 0390
     C           F2TOKU    OREQ 0391
     C           F2TOKU    OREQ 0400
     C           F2TOKU    OREQ 1602
     C           F2TOKU    OREQ 3135
     C                     ADD  F2GOKE    W@HOND
      * OTHER
     C                     OTHER
     C                     ADD  F2GOKE    W@9999
     C                     ENDSL
      *
     C                     ENDDO
      *
     C           EMBE      ENDSR
      *
     OSKSWP01 E                OHED
     O                                      'PART NO.,'
     O                                      'LOCATION,'
     O                                      'SET#/D,'
