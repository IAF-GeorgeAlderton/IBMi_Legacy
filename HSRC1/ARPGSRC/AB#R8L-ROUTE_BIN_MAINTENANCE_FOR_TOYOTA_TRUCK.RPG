      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      * INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     MOVEL'01'      W@ID    2
     C                     Z-ADD0         RRN1    40
     C           *HIVAL    SETGTAB#PP82
     C                     READPAB#PP82             N    90
     C  N90                Z-ADDA8FRDT    D@FROM
      *
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
      *
     C                     ENDSR
      *------------------------------------------------------
      * 1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
      * F3: END
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      W@ID
      * F10: INQ
     C           *INKJ     WHEQ *ON
     C                     CALL 'AL#CC8'
      * ENTR
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET
     C                     MOVE '02'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      * CHECK SCREEN 1
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C           D@FROM    IFEQ *ZERO
     C                     MOVE *ON       *IN61
     C                     MOVE *ON       *IN99
     C                     ELSE
     C           20000000  ADD  D@FROM    W@FROM  80
     C                     ENDIF
      *
     C                     Z-ADDW@FROM    K@YMD
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     MOVE *ON       *IN61
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      * CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVEA'00000000'*IN,61
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      * SET DATA
      *------------------------------------------------------
     C           #SET      BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1
      *
     C           W@FROM    SETGTAB#PP82
     C                     READPAB#PP82                  90
     C           1         DO   30        X       20
     C                     CLEARSFL01
     C                     Z-ADDX         S@TR#
     C  N90                MOVELRTE,X     S@ROUT
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      * 2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      W@ID
     C           *INKL     WHEQ *ON
     C                     EXSR #CLR
     C                     MOVE '01'      W@ID
     C                     OTHER
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
     C                     MOVE '99'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      * CHECK SCREEN 2
      *------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     EXSR #CLR
     C                     Z-ADD*ZERO     RRN1
     C           *IN90     DOUEQ*ON
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C                     MOVE *OFF      *IN61
     C                     MOVE *OFF      *IN62
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      * UPDATE
      *------------------------------------------------------
     C           #UPD      BEGSR
      *
     C           W@FROM    CHAINAB#PP82              80
     C   80                CLEARAB#PP821
     C                     Z-ADD*ZERO     RRN1
     C           *IN90     DOUEQ*ON
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDS@TR#     X
     C                     MOVELS@ROUT    RTE,X
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEL#PGM      A8UPGM
     C                     MOVEL#USER     A8KOME
     C                     MOVEL#WSID     A8UPWS
     C                     Z-ADD*DATE     A8KODT
     C                     TIME           A8KOTM
     C                     Z-ADDW@FROM    A8FRDT
     C   80                WRITEAB#PP821
     C  N80                UPDATAB#PP821
      *
     C                     ENDSR
** CMD
F3: END    F10: INQUIRY
