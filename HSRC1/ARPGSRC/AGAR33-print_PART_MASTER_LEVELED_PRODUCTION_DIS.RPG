   #@C                     END
   #@C*
   #@C           ##@,9     IFEQ *BLANK
   #@C                     MOVEL'0'       ##@,9
   #@C                     END
   #@C*
   #@C           ##@,10    IFEQ *BLANK
   #@C                     MOVEL'0'       ##@,10
   #@C                     END
   #@C*
