   #@C                     ENDSR
     C*
     OQPRINT  E   04           HED
     O                                   89 'TIME'
     O                         TIME      98 '  :  :  '
     O        E   05           HED
     O                                   12 'PGM-AGAR33'
     O                         COM       82
     O                                   89 'DATE'
     O                         DATE  Y   98
     O                                  104 'PAGE'
