     F** AGAR33 ********************************************************
     F*  PRINT PART MASTER/LEVELED PRODUCTION FILE: DISCREPANCY LIST   *
     F*  PROGRAM ID.    :  AGAR33.      <RPG>                          *
     F*  CREATE DATE.   :  JUN.18,'91.                                 *
     F*  AUTHOR.        :  M...                                        *
     F******************************************************************
     FAGAPL31 IP  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     E                    TY      1   1 63
   #@E                    ##@        15  1
     IAGAPL311    01
     I            DS
     I                                        1   80CBSKHZ
     I                                        1   40CBSKYY
     I                                        5   60CBSKMM
     I                                        7   80CBSKDD
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     I            DS
     I                                        1   80A2SYHZ
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
     I            DS
     I                                        1  14 HIN
     I                                        1   5 HIN1
     I                                        6   6 HINA
     I                                        7  11 HIN2
     I                                       12  12 HINB
     I                                       13  14 HIN3
   #@I            DS
   #@I                                        1  15 #@YFC
   #@I                                        1  15 ##@
   #@C                     EXSR S#@C01
     C******************************************************
     C*  START  PROGRAM <AGAR33>                           *
     C******************************************************
     C           KEY1      KLIST
     C                     KFLD           CBSHN1
     C                     KFLD           CBSHN2
     C                     KFLD           CBSHN3
     C*
     C  N01                GOTO @END
     C*
B001 C           *IN,90    IFEQ '0'
     C                     MOVEA'1'       *IN,90
     C                     Z-ADD0         CNT     40
     C                     MOVEL'1'       *INOF
E001 C                     END
   #@C*
   #@C                     EXSR S#@I01
     C*
B001 C           CBSKJY    IFEQ 'D'
   #@C           CBSKH8    ANDLEUD#@01
     C                     GOTO @END
E001 C                     END
     C*
     C                     Z-ADD0         YMD     80
     C                     Z-ADD0         SYOS    50
     C                     Z-ADD0         $KSYS   50
     C                     Z-ADD0         $SSYS   50
     C                     Z-ADD0         $SYHZ   80
     C                     MOVE *BLANK    $TEHI   1
     C           KEY1      CHAINFCEPL011             10
   #@C*
   #@C  N10                EXSR S#@I02
B001 C           *IN,10    IFEQ '0'
     C           A2GSKD    ANDEQ'D'
   #@C           A2#@01    ANDLEUD#@01
     C                     MOVEA'1'       *IN,10
E001 C                     END
     C*
B001 C           *IN,10    IFEQ '1'
     C                     Z-ADD0         $KSYS
     C                     Z-ADD0         $SSYS
     C                     Z-ADD0         $SYHZ
     C                     MOVE *BLANK    $TEHI
     C                     GOTO STP
E001 C                     END
     C*
B001 C           *IN,10    IFEQ '0'
   #@C*
   #@C                     EXSR S#@I03
B00#@C           A2#@02    IFGT UD#@01
     C                     Z-ADDA2KSYS    SYOS
X002 C                     ELSE
     C                     Z-ADDA2SSYS    SYOS
E002 C                     END
     C*
B002 C           A2TEHI    IFEQ 'G'
     C           SYOS      CABEQCBSYUY    @END
E002 C                     END
     C*
     C                     Z-ADDA2KSYS    $KSYS
     C                     Z-ADDA2SSYS    $SSYS
     C                     Z-ADDA2SYHZ    $SYHZ
     C                     MOVELA2TEHI    $TEHI
E001 C                     END
     C*
     C           STP       TAG
B001 C           *INOF     IFEQ '1'
     C                     MOVELTY,1      COM    63
     C                     Z-ADDUDATE     DATE    60
     C                     TIME           TIME    60
     C                     ADD  1         CNT
     C                     EXCPTHED
     C                     MOVEL'0'       *INOF
E001 C                     END
     C*
     C                     MOVE *BLANK    HIN
     C                     MOVELCBSHN1    HIN1
     C                     MOVELCBSHN2    HIN2
     C                     MOVELCBSHN3    HIN3
B001 C           HIN2      IFNE *BLANK
     C                     MOVEL'-'       HINA
E001 C                     END
     C*
B001 C           HIN3      IFNE *BLANK
     C                     MOVEL'-'       HINB
E001 C                     END
     C*
     C                     MOVE *BLANK    NAME    6
B001 C           $TEHI     IFEQ 'G'
     C                     MOVEL'MAS PR'  NAME
E001 C                     END
     C*
B001 C           $TEHI     IFEQ 'Z'
     C                     MOVEL'LIMITD'  NAME
E001 C                     END
     C*
B001 C           $TEHI     IFEQ 'S'
     C                     MOVEL'TRIAL '  NAME
E001 C                     END
     C*
     C                     MOVE *BLANK    $HIHN   1
B001 C           NAME      IFNE *BLANK
     C                     MOVEL'-'       $HIHN
E001 C                     END
     C*
     C                     EXCPTDET
     C*
     C           @END      TAG
   #@C*==============================================================*
   #@C*          S#@C01
   #@C*==============================================================*
   #@C           S#@C01    BEGSR
   #@C*
   #@C                     MOVE CBKOH8    CBKOHZ  80
   #@C                     MOVE CBKOH8    CBKOH8  80
   #@C                     MOVE CBKOY4    CBKOYY  40
   #@C                     MOVE CBKOY4    CBKOY4  40
   #@C                     MOVE CBSKH8    CBSKHZ  80
   #@C                     MOVE CBSKH8    CBSKH8  80
   #@C                     MOVE CBSKY4    CBSKYY  40
   #@C                     MOVE CBSKY4    CBSKY4  40
   #@C                     MOVE CBSTH8    CBSTHZ  80
   #@C                     MOVE CBSTH8    CBSTH8  80
   #@C                     MOVE CBSTY4    CBSTYY  40
   #@C                     MOVE CBSTY4    CBSTY4  40
   #@C                     MOVE CBUK10    CBUKHZ 100
   #@C                     MOVE CBUK10    CBUK10 100
   #@C                     MOVE CBUKY4    CBUKYY  40
   #@C                     MOVE CBUKY4    CBUKY4  40
   #@C                     MOVE CBZAH8    CBZAHZ  80
   #@C                     MOVE CBZAH8    CBZAH8  80
   #@C                     MOVE CBZAY4    CBZAYY  40
   #@C                     MOVE CBZAY4    CBZAY4  40
   #@C*
   #@C                     ENDSR
   #@C*==============================================================*
   #@C*==============================================================*
   #@C*          S#@I01
   #@C*==============================================================*
   #@C           S#@I01    BEGSR
   #@C*<<
   #@C                     MOVE CBSKHZ    #@YFC
   #@C                     EXSR SB#@YD
   #@C                     MOVE #@YTC     CBSKH8
   #@C*<<
   #@C                     MOVE *DATE     #@YFC
   #@C                     EXSR SB#@YD
   #@C                     MOVE #@YTC     UD#@01  80
   #@C*
   #@C                     ENDSR
   #@C*==============================================================*
   #@C*          S#@I02
   #@C*==============================================================*
   #@C           S#@I02    BEGSR
   #@C*<<
   #@C                     MOVE A2GSHZ    #@YFC
   #@C                     EXSR SB#@YD
   #@C                     MOVE #@YTC     A2#@01  80
   #@C*<<
   #@C                     MOVE *DATE     #@YFC
   #@C                     EXSR SB#@YD
   #@C                     MOVE #@YTC     UD#@01  80
   #@C*
   #@C                     ENDSR
   #@C*==============================================================*
   #@C*          S#@I03
   #@C*==============================================================*
   #@C           S#@I03    BEGSR
   #@C*<<
   #@C                     MOVE A2SYHZ    #@YFC
   #@C                     EXSR SB#@YD
   #@C                     MOVE #@YTC     A2#@02  80
   #@C*<<
   #@C                     MOVE *DATE     #@YFC
   #@C                     EXSR SB#@YD
   #@C                     MOVE #@YTC     UD#@01  80
   #@C*
   #@C                     ENDSR
   #@C*==============================================================*
   #@C*          SB#@YD  YYMMDD -> YYYYMMDD
   #@C*==============================================================*
   #@C           SB#@YD    BEGSR
   #@C*
   #@C           #@YFC     IFNE *BLANK
   #@C                     MOVEL#@YFC     #@YTC  15
   #@C                     EXSR SB#@XX
   #@C                     MOVE #@YFC     #@YFN  150
   #@C*
   #@C                     MOVE #@YFN     #@YTC
   #@C                     ELSE
   #@C                     MOVEL*BLANK    #@YTC
   #@C                     END
   #@C*
   #@C                     MOVEL*BLANK    #@YFC
   #@C*
   #@C                     ENDSR
   #@C*==============================================================*
   #@C*          SB#@XX
   #@C*==============================================================*
   #@C           SB#@XX    BEGSR
   #@C*
   #@C           ##@,1     IFEQ *BLANK
   #@C                     MOVEL'0'       ##@,1
   #@C                     END
   #@C*
   #@C           ##@,2     IFEQ *BLANK
   #@C                     MOVEL'0'       ##@,2
   #@C                     END
   #@C*
   #@C           ##@,3     IFEQ *BLANK
