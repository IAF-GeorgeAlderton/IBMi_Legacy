     C                     MOVELER,2      D9ERR
     C                     GOTO ESB221
     C                     ENDSL
      *
     CSR         ESB221    ENDSR
      *----------------------------------------------------*
      * DETAIL                                             *
      *----------------------------------------------------*
     CSR         #SB222    BEGSR
      *
     C                     MOVEL*BLANK    D2TKR
     C                     MOVELH1TKR1    D2TKR1
     C                     MOVEL'-'       D2TKF1
     C                     MOVELH1TKR2    D2TKR2
     C                     MOVEL'-'       D2TKF2
     C                     MOVELH1TKR3    D2TKR3
     C                     MOVEL'-'       D2TKF3
     C                     MOVELH1TKR4    D2TKR4
     C                     MOVEL'-'       D2TKF4
     C                     MOVELH1TKR5    D2TKR5
      *
     C           DSP02     TAG
