     C                     MOVELH1IN39    *IN39
     C                     MOVELH1IN38    *IN38
     C*
     C           P1JUDG    IFEQ '2'
     C                     UPDATSFL2
     C                     ELSE
     C                     UPDATSFL
     C                     ENDIF
     C*
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
     C           *IN99     IFEQ '1'
     C                     GOTO ESB220
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * CHECK                                              *
      *----------------------------------------------------*
     CSR         #SB221    BEGSR
      *
     C                     SELEC
      *
     C           S1SEL     WHEQ ' '
     C           S1SEL     WHEQ 'M'
     C                     EXSR #SB222
     C                     MOVEL*BLANK    S1SEL
     C                     OTHER
