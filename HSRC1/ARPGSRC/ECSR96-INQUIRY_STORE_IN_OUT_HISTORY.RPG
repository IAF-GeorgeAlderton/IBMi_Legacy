     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     ADD  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      *
     C                     Z-ADD1         X       30
     C                     SETOF                     3199
     C*        * X         DOWLE14
     C           X         DOWLE@@MAX
     C           *IN99     ANDEQ'0'
     C*
     C           P1JUDG    IFEQ '2'
     C           X         CHAINSFL2                 23
     C                     ELSE
     C           X         CHAINSFL                  23
     C                     ENDIF
     C*
     C                     SETOF                     3199
     C           *IN23     IFEQ '0'
