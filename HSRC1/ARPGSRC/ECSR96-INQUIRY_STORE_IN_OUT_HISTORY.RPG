     C           *ENTRY    PLIST
     C                     PARM           P1YMD1  80
     C                     PARM           P1TIM1  40
     C                     PARM           P1YMD2  80
     C                     PARM           P1TIM2  40
     C                     PARM           P1DIE1  2
     C                     PARM           P1DIE2  4
     C                     PARM           P1DIE3  1
     C                     PARM           P1DIE4  1
     C                     PARM           P1RIYU  1
     C                     PARM           P1KIBN  3
     C                     PARM           P1IOKB  1
     C                     PARM           P1GSKB  1
     C                     PARM           P1JUDG  1
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * CONTROL                                            *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INIT                                               *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     C                     Z-ADDP1YMD1    C1DAT1
     C                     Z-ADDP1TIM1    C1TIM1
     C                     Z-ADDP1YMD2    C1DAT2
     C                     Z-ADDP1TIM2    C1TIM2
     C                     MOVELP1DIE1    C1KAT
     C           P1DIE2    IFNE *BLANK
     C           C1KAT     CAT  '-':0     C1KAT
     C           C1KAT     CAT  P1DIE2:0  C1KAT
     C                     ENDIF
     C           P1DIE3    IFNE *BLANK
     C           C1KAT     CAT  '-':0     C1KAT
     C           C1KAT     CAT  P1DIE3:0  C1KAT
     C                     ENDIF
     C           P1DIE4    IFNE *BLANK
     C           C1KAT     CAT  '-':0     C1KAT
     C           C1KAT     CAT  P1DIE4:0  C1KAT
     C                     ENDIF
     C                     MOVELP1RIYU    C1RIYU
     C                     MOVELP1KIBN    C1KIBN
     C                     SELEC
     C           P1IOKB    WHEQ ' '
     C                     MOVEL'ALL  '   C1IOKB
     C           P1IOKB    WHEQ '1'
     C                     MOVEL'1:IN '   C1IOKB
     C           P1IOKB    WHEQ '2'
     C                     MOVEL'2:OUT'   C1IOKB
     C                     ENDSL
     C                     SELEC
     C           P1GSKB    WHEQ ' '
     C                     MOVEL'ALL  '   C1GSKB
     C           P1GSKB    WHEQ '1'
     C                     MOVEL'1:HANDY 'C1GSKB
     C           P1GSKB    WHEQ '2'
     C                     MOVEL'1:ADJUST'C1GSKB
     C                     ENDSL
      *
     C                     Z-ADD14        @@MAX   20
     C                     SELEC
     C           P1JUDG    WHEQ ' '
     C                     MOVEL'ALL  '   C1HNTE
     C           P1JUDG    WHEQ '1'
     C                     MOVEL'1:OK'    C1HNTE
     C           P1JUDG    WHEQ '2'
     C                     MOVEL'2:NG'    C1HNTE
     C                     Z-ADD7         @@MAX
     C                     ENDSL
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * READ                                               *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     C                     SETOF                     8166
     C           *LOVAL    SETLLECSWP951
     C                     READ ECSWP951                 81
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ ECSWP951                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     MOVE '02'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * 1ST.                                               *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C           CTRX      IFEQ 0
     C                     SETON                     72
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     ELSE
     C                     SETON                     7273
     C                     ENDIF
      *
     C                     WRITEECSPW969
     C           P1JUDG    IFEQ '2'
     C                     EXFMTSFLCTL2
     C                     ELSE
     C                     EXFMTSFLCTL
     C                     ENDIF
     C                     SETOF                     7273
     C                     SETOF                     3199
     C                     MOVEL*BLANK    D9ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           CTRX      IFEQ 0
     C                     GOTO ESB220
     C                     ENDIF
      *
      *-----------------*
      * ROLLDOWN/PAGEUP *
      *-----------------*
     C           *IN52     IFEQ '1'
     C*                    ADD  1         CTRX
      * 1ST. PAGE
     C           WKPAGE    IFEQ 1
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
     C           *IN81     IFEQ '1'
     C                     SETOF                     81
     C           *HIVAL    SETGTECSWP951
     C                     READPECSWP951                 81
     C                     SUB  1         CTRX
     C                     ENDIF
      *
     C                     ADD  @@MAX     CTRX
      *                         L--表示行数
     C                     SETOF                     6627
      *
     C           *IN81     DOWEQ'0'
     C           *IN27     ANDEQ'0'
     C                     EXSR #READP
     C                     READPECSWP951                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXTP
     C                     ENDDO
      *
     C                     Z-ADD0         CTRX    40
      *
     C           *IN81     IFEQ '1'
     C           *LOVAL    SETLLECSWP951
     C                     READ ECSWP951                 81
     C                     ENDIF
      *
     C                     EXSR #CLR
     C                     SETOF                     8166
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ ECSWP951                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     SUB  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      *--------------------*
      * ROLL-UP            *
      *--------------------*
     C           *IN51     IFEQ '1'
     C           *IN81     ANDEQ'0'
      *
     C                     EXSR #CLR
      *
     C                     SETOF                     6681
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ ECSWP951                 81
     C                     ENDDO
      * NEXT
