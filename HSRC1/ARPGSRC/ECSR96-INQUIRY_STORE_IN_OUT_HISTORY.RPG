     CSR         #EDIT     BEGSR
      *
     C                     MOVEL*BLANK    S1SEL
     C                     MOVELW0IOKB    S1IOKB
     C                     Z-ADDW0IOHZ    S1IOHZ
     C                     MOVEL*BLANK    S1IOJK
     C           S1IOJK    CAT  W0IOJH:0  S1IOJK
     C           S1IOJK    CAT  ':':0     S1IOJK
     C           S1IOJK    CAT  W0IOJM:0  S1IOJK
     C                     MOVEL*BLANK    S1KAT
     C                     MOVELW0KAT1    S1KAT1
     C                     MOVEL'-'       S1KAF1
     C                     MOVELW0KAT2    S1KAT2
     C                     MOVEL'-'       S1KAF2
     C                     MOVELW0KAT3    S1KAT3
     C                     MOVEL'-'       S1KAF3
     C                     MOVELW0KAT4    S1KAT4
     C                     MOVELW0KIBN    S1KIBN
     C                     Z-ADDW0KOSU    S1KOSU
     C                     MOVEL*BLANK    S1RESN
     C                     MOVELW0RIYU    S1RESN
     C           W0RIYU    CHAINECSPP701             23
     C           *IN23     IFEQ '0'
     C           S1RESN    CAT  E7RSNM:1  S1RESN
     C                     ENDIF
     C                     SELEC
     C           W0GSKB    WHEQ ' '
     C                     MOVEL'      '  S1GSKB
     C           W0GSKB    WHEQ 'H'
     C                     MOVEL'HANDY '  S1GSKB
     C           W0GSKB    WHEQ 'A'
     C                     MOVEL'ADJUST'  S1GSKB
     C                     ENDSL
      *
     C                     SETOF                     39
     C                     MOVEL'0'       H1IN39
     C           W0HNTE    IFEQ 'NG'
