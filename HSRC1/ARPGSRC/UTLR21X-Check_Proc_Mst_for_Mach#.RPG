     H            Y.
     F** UTLR21X *********************************************
     F*  PROGRAM: UTILITY- CHECK PROCESS MST FOR MACH S90    *
     F*  WRITTEN: LEC                                        *
     F*------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR21X'
     F*                    PARM           $ZETI   4
     F*                    PARM           $SHIN  12
     F*                    PARM           $RTN    1
     F*  IN  $ZETI :  4A  ZETI#
     F*      $SHIN : 12A  IAF PART
     F*  OUT $RTN  :  1A  RETURN CODE (Y/N)
     F******************************************************
     FFCETL11 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FAAMPL11 IF  E           K        DISK
     F******************************************************
      * MACHINE NUMBERS
     E                    $KB        15  3
      *
     I            DS
     I                                        1  45 $KB
     I                                        1   3 CKKB01
     I                                        4   6 CKKB02
     I                                        7   9 CKKB03
     I                                       10  12 CKKB04
     I                                       13  15 CKKB05
     I                                       16  18 CKKB06
     I                                       19  21 CKKB07
     I                                       22  24 CKKB08
     I                                       25  27 CKKB09
     I                                       28  30 CKKB10
     I                                       31  33 CKKB11
     I                                       34  36 CKKB12
     I                                       37  39 CKKB13
     I                                       40  42 CKKB14
     I                                       43  45 CKKB15
      *
     I            DS
     I                                        1  12 #SHIN
     I                                        1   5 #SHN1
     I                                        6  10 #SHN2
     I                                       11  12 #SHN3
      * SYSTEM TIME
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *
     C           *ENTRY    PLIST
     C                     PARM           $ZETI   4
     C                     PARM           $SHIN  12
     C                     PARM           $RTN    1
      *
     C           K#SHIN    KLIST
     C                     KFLD           #SHN1
     C                     KFLD           #SHN2
     C                     KFLD           #SHN3
      *
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
     C                     MOVEL$SHIN     #SHIN
     C                     MOVE 'N'       $RTN
     C                     TIME           SDATE
      *
      * get part number...
     C                     SELEC
     C           $ZETI     WHNE *BLANK
     C                     EXSR #ZETI
     C           $SHIN     WHNE *BLANK
     C                     EXSR #PART
     C                     ENDSL
      *
      * does this part number have the machine# in question in process?
     C           K#SHIN    CHAINAAMPL11              50
     C           *IN50     IFEQ *OFF
     C           'S90'     LOKUP$KB                      51
     C           *IN51     IFEQ *ON
     C                     MOVE 'Y'       $RTN
     C                     ENDIF
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *=============================================================
      * GET SUPPLIER BY ZETI
      *=============================================================
     C           #ZETI     BEGSR
      *
     C           $ZETI     CHAINFCETL11              99
     C           *IN99     IFEQ *OFF
     C                     MOVELA2BHB1    #SHN1
     C                     MOVELA2BHB2    #SHN2
     C                     MOVELA2BHB3    #SHN3
     C                     ENDIF
      *
     C                     ENDSR
      *=============================================================
      * GET SUPPLIER BY IAF APRT#
      *=============================================================
     C           #PART     BEGSR
      *
     C           K#SHIN    CHAINFCEPL01              99
     C           *IN99     IFEQ *ON
     C                     MOVEL*BLANKS   $SHIN
     C                     ENDIF
      *
     C                     ENDSR
      *=============================================================
