     F* TCHK2 04/30/09 PATCH READ SKIP SPECIAL PROC
     F* TCHK3 02/13/09 CHG HOLIDAY CONDITION               *
JW1  F* JW    10/12/17 ADD UPDATE FIELDS                   *
     F******************************************************
     FFBCPL09 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FGADPL11 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     F*
     E                    TBL     1   1 40
     I*
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
     I            DS
     I                                        1   80W@RVDT
     I                                        1   40W@RVYY
     I                                        5   60W@RVMM
     I                                        7   80W@RVDD
     I*
     I            DS
     I                                        1   80FBSKHZ
     I                                        1   40FBSKYY
     I                                        5   60FBSKMM
     I                                        7   80FBSKDD
     I            DS
     I                                        1   80FBKOHZ
     I                                        1   40FBKOYY
     I                                        5   60FBKOMM
     I                                        7   80FBKODD
     I            DS
     I                                        1   60FBTIME
     I                                        1   20FBKOHH
     I                                        3   40FBKOSS
     I            DS
     I                                        1   80FBTKHZ
     I                                        1   40FBTKYY
     I                                        5   60FBTKMM
     I                                        7   80FBTKDD
     I            DS
     I                                        1   80FBTSHZ
     I                                        1   40FBTSYY
     I                                        5   60FBTSMM
     I                                        7   80FBTSDD
     C*
     C           K#FBC9    KLIST
     C                     KFLD           W@RVYY
     C                     KFLD           W@RVMM
     C                     KFLD           W@RVDD
     C           K#FBC9    SETLLFBCPL09
     C*
     C                     DO   *HIVAL
     C*
     C           K#FBC9    READEFBCPL09                  99
     C   99                LEAVE
     C*
TCHK2C                     MOVELFBKOME    W@A003  3
TCHK2C           W@A003    IFEQ 'QPG'
TCHK2C                     ITER
TCHK2C                     END
TCHK2C*
     C           W@1STP    IFEQ *ON
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     MOVEL*OFF      W@1STP
     C                     END
     C*
     C           K#GAD1    KLIST
     C                     KFLD           FBTOKU
     C                     KFLD           FBNONY
     C           K#GAD1    CHAINGADPL11              97
     C  N97                MOVELB5KMEI    PRDLNM 15
     C   97                MOVEL*BLANK    PRDLNM
     C*
     C                     MOVEL*BLANK    PRMHNA  1
     C                     MOVEL*BLANK    PRMHNB  1
     C                     MOVEL*BLANK    PRMHNC  1
     C           FBMHN2    IFNE *BLANK
     C                     MOVEL'-'       PRMHNA
     C                     END
     C           FBMHN3    IFNE *BLANK
     C                     MOVEL'-'       PRMHNB
     C                     END
     C           FBMHN4    IFNE *BLANK
     C                     MOVEL'-'       PRMHNC
     C                     END
     C*
     C           FBSKJY    IFEQ 'D'
     C                     MOVEL'DELETED' PRDLT   7
     C                     ELSE
     C                     MOVEL*BLANK    PRDLT
     C                     END
     C*
     C                     EXCPT@DTL
     C                     MOVEL*ON       P@PRC
     C*
     C                     ENDDO
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C*-----------------------------------------------------
     C* INITIAL SET
     C*-----------------------------------------------------
     C           *INZSR    BEGSR
     C*
     C           *ENTRY    PLIST
     C                     PARM           P@RVDT  8
     C                     PARM           P@PRC   1
     C                     MOVEL*OFF      P@PRC
     C*
     C                     TIME           WSDT
     C*
     C           P@RVDT    IFNE *BLANK
     C                     MOVELP@RVDT    W@RVDT
     C                     ELSE
     C           K#AGDP    KLIST
     C                     KFLD           WSSYYY
     C                     KFLD           WSSMMM
     C                     KFLD           WSSDDD
     C* NO RUNNING WHEN TODAY IS HOLIDAY
     C           K#AGDP    CHAINAGDPL12              98
     C           *IN98     IFEQ *OFF
TCHK3C*          F8HIRU    ANDNE*BLANK
TCHK3C           F8YOBI    IFEQ 6
TCHK3C           F8YOBI    OREQ 7
     C                     MOVEL*ON       *INLR
     C                     RETRN
TCHK3C                     END
     C                     END
     C*
     C           K#AGDP    SETLLAGDPL12
     C                     DO   *HIVAL
     C                     READPAGDPL12                  98
     C           *IN98     IFEQ *ON
     C                     Z-ADDWSSYYY    W@RVYY
     C                     Z-ADDWSSMMM    W@RVMM
     C                     Z-ADDWSSDDD    W@RVDD
     C                     LEAVE
     C                     END
TCHK3C*          F8HIRU    IFEQ *BLANK
TCHK3C           F8YOBI    IFNE 6
TCHK3C           F8YOBI    ANDNE7
     C                     Z-ADDF8KAYY    W@RVYY
     C                     Z-ADDF8KAMM    W@RVMM
     C                     Z-ADDF8KADD    W@RVDD
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     END
     C*
     C                     MOVEL*ON       W@1STP  1
     C*
     C                     ENDSR
      *
     OQPRINT  E   01           @HED
     O                         #PGM      10
JW   O                         #USER     20
     O                         TBL,1     76
     O                                   87 'DATE'
     O                         WSSDATY   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O        E   02           @HED
     O                                   87 'TIME'
     O                         WSSTM6    98 '  :  :  '
     O        E   03           @HED
     O                                   14 'UPDATE DATE: '
     O                         W@RVDTY   25
     O        E   05           @HED
     O                                    5 'CUST'
     O                                   10 'DELI'
     O                                   12 'F'
     O                                   17 'DOCK'
     O                                   22 'NAME'
     O                                   48 'USER_PART_NO.'
     O                                   69 'UNIT PRICE'
     O                                   85 'EFFECTIVE_DATE'
     O                                  102 'EXPIRATION_DATE'
JW1  O                                  114 'UPD_TIME'
JW1  O                                  123 'UPD_USER'
     O        E 1              @DTL
     O                         FBTOKU     5
     O                         FBNONY    10
     O                         FBNKOJ    12
