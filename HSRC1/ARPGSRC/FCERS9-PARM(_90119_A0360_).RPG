     H            Y.
     F******************************************************
     F* PARM('90119' 'A0360' '  ' ' ' '  ' '  ' ' ')       *
     F******************************************************
     FFCEPL30 IF  E           K        DISK
     C           *ENTRY    PLIST
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
     C                     PARM           P@BAN1  1
     C                     PARM           P@BAN2  2
     C                     PARM           P@BAN3  2
     C                     PARM           P@BAN4  1
      *
     C                     MOVE *BLANK    P@BAN1  1
     C                     MOVE *BLANK    P@BAN2  2
     C                     MOVE *BLANK    P@BAN3  2
     C                     MOVE *BLANK    P@BAN4  1
      *
     C                     MOVE P@HIN1    K@HIN1  5
     C                     MOVE P@HIN2    K@HIN2  5
     C                     MOVE P@HIN3    K@HIN3  2
      *
     C           HINKEY    KLIST
     C                     KFLD           K@HIN1
     C                     KFLD           K@HIN2
     C                     KFLD           K@HIN3
      *
     C           HINKEY    CHAINFCEPL30              88
     C           *IN88     IFEQ '0'
     C           F3GSKD    IFEQ 'D'
     C                     SETON                     88
     C                     END
     C                     END
     C           *IN88     IFEQ '0'
     C                     MOVE F3STRK    P@BAN1
     C                     MOVE F3STRT    P@BAN2
     C                     MOVE F3STRR    P@BAN3
     C                     MOVE F3STRD    P@BAN4
     C           *DATE     IFLT F3TYMD
     C                     MOVE F3KTRK    P@BAN1
     C                     MOVE F3KTRT    P@BAN2
     C                     MOVE F3KTRR    P@BAN3
     C                     MOVE F3KTRD    P@BAN4
     C                     END
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *
