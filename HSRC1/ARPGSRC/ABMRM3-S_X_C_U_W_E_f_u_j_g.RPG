     C                     MULT -1        SA@
     C*****                ENDIF
      *今回/前回
     C                     Z-ADD0         RITU    72
     C           SVKMAX    IFNE 0
     C           WMAIS     DIV  SVKMAX    RITU
     C                     ENDIF
      *
     C                     MULT 100       RITU
     C           RITU      IFGE 100
     C                     SUB  100       RITU
     C                     ELSE
     C           100       SUB  RITU      RITU
     C                     ENDIF
      *
     C           RITU      IFLT WKADJU
     C*******              Z-ADDSA        L5AUAJ
     C                     Z-ADDSA@       L5AUAJ
     C                     ADD  L5AUAJ    L5AMXH
     C                     ADD  L5AUAJ    L5UZAR
     C                     Z-ADD0         WMAIS   50
     C                     CALL 'ABCR09'  ACALL
     C                     ENDIF
      *
     CSR         ESB720    ENDSR
      *---------------------------*
      *ＬＴ                     *
      *---------------------------*
     CSR         #SB810    BEGSR
