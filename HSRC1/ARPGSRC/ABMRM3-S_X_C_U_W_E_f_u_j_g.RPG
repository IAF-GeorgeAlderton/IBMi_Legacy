     C           KEY2      KLIST
     C                     KFLD           L5BMON
     C                     KFLD           L5TAIP
      *
     C                     Z-ADD0         WLTM1   31
     C                     Z-ADD0         WLTM2   31
     C           KEY2      CHAINGCKPL211             30
     C           *IN30     IFEQ '0'
     C           T2SKJY    IFEQ 'D'
     C           T2SKHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADDT2LTM1    WLTM1
     C                     Z-ADDT2LTM2    WLTM2
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB810    ENDSR
      *---------------------------*
      *後工程引取ロット         *
      *---------------------------*
     CSR         #SB820    BEGSR
      *
     C                     Z-ADD0         XHITO   90
     C           L5UKHZ    COMP *DATE                25
     C           *IN25     IFEQ '1'
     C                     Z-ADDL5UKYY    L5UYY
     C                     Z-ADDL5UKMM    L5UMM
     C                     Z-ADDL5UKDD    L5UDD
     C                     Z-ADDL5UBIN    L5UBN
     C                     ELSE
     C                     Z-ADD*YEAR     L5UYY
     C                     Z-ADDUMONTH    L5UMM
     C                     Z-ADDUDAY      L5UDD
     C                     Z-ADD01        L5UBN
     C                     ENDIF
      *
     C           CKEY      KLIST
     C                     KFLD           L5TKR1
     C                     KFLD           L5TKR2
     C                     KFLD           L5TKR3
     C                     KFLD           L5TKR4
      *
     C           CKEY      SETLLAAJTL141
     C                     DO   *HIVAL
     C           CKEY      READEAAJTL141                 30
     C           *IN30     IFEQ '0'
     C           CJAKHZ    IFNE 0
     C           CJAKHZ    CABLE*DATE     @001
     C                     ENDIF
     C           CJHZBN    IFGT L5HZBN
     C           CJSLOT    IFGT XHITO
     C                     Z-ADDCJSLOT    XHITO
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           @001      TAG
     C  N30                ENDDO
      *
     CSR         ESB820    ENDSR
