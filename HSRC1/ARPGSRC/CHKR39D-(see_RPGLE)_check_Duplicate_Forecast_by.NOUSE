     H            Y.
     F***CHKR39D ***************************************************************
     F*  PROGRAM    : CHECK DUPLICATE FORECAST BY USER PART#                   *
     F*             : READ ABBPL05                                             *
     F*  WRITTEN    : JW   2022.12.02                                          *
     F**************************************************************************
     FABBPL05 IF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
     E                    DK          5  4
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1  23 Q5MHIN
     I                                        1   5 Q5MHN1
     I                                        6   6 HP1
     I                                        7  11 Q5MHN2
     I                                       12  12 HP2
     I                                       13  17 Q5MHN3
     I                                       18  18 HP3
     I                                       19  23 Q5MHN4
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ ABBPL05                  98
     C   98                LEAVE
      * IGNORE
     C**         Q5NNNM    IFEQ 0
     C**         Q51NNM    ANDEQ0
     C**         Q52NNM    ANDEQ0
     C**                   ITER
     C**                   ENDIF
      * IGNORE
     C**         Q5NONY    IFEQ 2030
     C**                   ITER
     C**                   ENDIF
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     Z-ADDQ5TOKU    SVCUST  40
     C                     Z-ADDQ5NONY    SVNONY  40
     C                     MOVELQ5MHIN    SVMHIN 23
     C                     ENDIF
      * BREAK?
     C           Q5NONY    IFNE SVNONY
     C                     EXSR #BRK1
     C                     EXSR #BRK2
     C                     ELSE
     C           Q5MHIN    IFNE SVMHIN
     C                     EXSR #BRK1
     C                     ENDIF
     C                     ENDIF
      *
     C                     ADD  1         PX
     C           PX        IFLE 5
     C                     MOVELQ5NUKE    DK,PX
     C                     ENDIF
      *
     C                     ENDDO
      * LAST BREAK
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK1
     C                     EXSR #BRK2
     C                     ENDIF
      * SET FLAG
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  BREAK1: MHIN                                      *
      *----------------------------------------------------*
     C           #BRK1     BEGSR
      *
     C           PX        IFGE 2
     C                     EXSR #CHKD                      CHECK DOCK
     C           *IN85     IFEQ *ON
     C                     EXSR #PRNT1
     C                     MOVE *ON       PFLG
      *
     C           $UPD      IFEQ 'Y'
     C                     EXSR #PRG1
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
      * RESET
     C                     MOVELQ5MHIN    SVMHIN
     C                     Z-ADD0         PX
     C                     MOVE *ALL' '   DK
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PURGE ABBPP01
      *----------------------------------------------------*
     C           #PRG1     BEGSR
      * REMOVE BLANK
     C                     MOVELSVMHIN    $FLD1
     C                     CALL 'UUUR05 '
     C                     PARM           $FLD1  25
     C                     PARM           $FLD2  25
      * PURGE
     C                     MOVELSVCUST    $CUST
     C                     MOVELSVNONY    $NONY
     C                     MOVEL$FLD2     $MHIN
     C                     CALL 'CHKR39F'
     C                     PARM           $CUST   4
     C                     PARM           $NONY   4
     C                     PARM           $MHIN  20
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  CHECK DOCK CODE = '00'                            *
      *----------------------------------------------------*
     C           #CHKD     BEGSR
      * 00
     C                     MOVE *OFF      *IN85
     C           1         DO   5         IX      20
     C           DK,IX     IFEQ '00'
     C                     MOVE *ON       *IN85
     C                     GOTO XCHKD
     C                     ENDIF
     C                     ENDDO
      *
      * SAME DOCK
     C           DK,1      IFNE *BLANK
     C           DK,2      ANDNE*BLANK
     C           DK,1      IFEQ DK,2
     C                     MOVE *ON       *IN85
     C                     GOTO XCHKD
     C                     ENDIF
     C                     ENDIF
     C           DK,1      IFNE *BLANK
     C           DK,3      ANDNE*BLANK
     C           DK,1      IFEQ DK,3
     C                     MOVE *ON       *IN85
     C                     GOTO XCHKD
     C                     ENDIF
     C                     ENDIF
     C           DK,1      IFNE *BLANK
     C           DK,4      ANDNE*BLANK
     C           DK,1      IFEQ DK,4
     C                     MOVE *ON       *IN85
     C                     GOTO XCHKD
     C                     ENDIF
     C                     ENDIF
     C           DK,1      IFNE *BLANK
     C           DK,5      ANDNE*BLANK
     C           DK,1      IFEQ DK,5
     C                     MOVE *ON       *IN85
     C                     GOTO XCHKD
     C                     ENDIF
     C                     ENDIF
      *
     C           DK,2      IFNE *BLANK
     C           DK,3      ANDNE*BLANK
     C           DK,2      IFEQ DK,3
     C                     MOVE *ON       *IN85
     C                     GOTO XCHKD
     C                     ENDIF
     C                     ENDIF
     C           DK,2      IFNE *BLANK
     C           DK,4      ANDNE*BLANK
     C           DK,2      IFEQ DK,4
     C                     MOVE *ON       *IN85
     C                     GOTO XCHKD
     C                     ENDIF
     C                     ENDIF
     C           DK,2      IFNE *BLANK
     C           DK,5      ANDNE*BLANK
     C           DK,2      IFEQ DK,5
     C                     MOVE *ON       *IN85
     C                     GOTO XCHKD
     C                     ENDIF
     C                     ENDIF
      *
     C           DK,3      IFNE *BLANK
     C           DK,4      ANDNE*BLANK
     C           DK,3      IFEQ DK,4
     C                     MOVE *ON       *IN85
     C                     GOTO XCHKD
     C                     ENDIF
     C                     ENDIF
     C           DK,3      IFNE *BLANK
     C           DK,5      ANDNE*BLANK
     C           DK,3      IFEQ DK,5
     C                     MOVE *ON       *IN85
     C                     GOTO XCHKD
     C                     ENDIF
     C                     ENDIF
      *
     C           DK,4      IFNE *BLANK
     C           DK,5      ANDNE*BLANK
     C           DK,4      IFEQ DK,5
     C                     MOVE *ON       *IN85
     C                     GOTO XCHKD
     C                     ENDIF
     C                     ENDIF
      *
     C           XCHKD     ENDSR
      *----------------------------------------------------*
      *  BREAK2: NONY                                      *
      *----------------------------------------------------*
     C           #BRK2     BEGSR
      *
     C           PFLG      IFEQ *ON
     C                     EXSR #PRNT2
     C                     ENDIF
      * RESET
     C                     Z-ADDQ5TOKU    SVCUST
     C                     Z-ADDQ5NONY    SVNONY
     C                     MOVE *OFF      PFLG
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT 1                                           *
      *----------------------------------------------------*
     C           #PRNT1    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL1
     C                     ADD  1         LIN#
     C                     Z-ADD0         PX      30
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT 2                                           *
      *----------------------------------------------------*
     C           #PRNT2    BEGSR
      *
     C                     EXCPT@DTL2
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $UPD    1
     C                     PARM           $RTN    1
      *
     C           $UPD      IFNE 'Y'
     C                     MOVE 'N'       $UPD
     C                     ENDIF
      *
     C                     MOVE *BLANK    $RTN
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     MOVE 'Y'       FIRST   1
     C                     MOVE *OFF      PFLG    1        PRINT FLG
     C                     MOVE *ALL' '   DK
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   18 'UPDATE='
     O                         $UPD      19
     O                                   40 '** DUPLICATE FORECAS'
     O                                   60 'T DATA (ABBPP01) ** '
     O                                   99 'DATE'
     O                         TODAY     82 '    .  .  '
     O                         NOW       92 '  :  :  '
     O                                   95 'P.'
     O                         PAGE  Z   99
     O        E   03           @HDR
     O                                    6 'SEQ#'
     O                                   12 'DELV'
     O                                   23 'USER_PART'
     O                                   42 'DK1'
     O                                   48 'DK2'
     O                                   54 'DK3'
     O                                   60 'DK4'
     O                                   66 'DK5'
     O        E 1              @DTL1
     O                         SEQ#  Z +002
     O                         SVNONY  +002
     O                         SVMHIN  +002
     O                         DK,1    +002
     O                         DK,2    +002
     O                         DK,3    +002
     O                         DK,4    +002
     O                         DK,5    +002
      *
     O        E 1              @DTL2
     O                                 +000 '.'
