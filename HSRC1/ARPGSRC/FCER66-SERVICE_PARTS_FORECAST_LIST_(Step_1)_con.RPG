     H            Y.
     F** FCER66 ****************************************************************
     F*  PROGRAM    : SERVICE PARTS FORECAST LIST (STEP 1) - CONVERT           *
     F*  WRITTEN    : 2019.01.18                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FABAWL13 IF  E           K        DISK
     FABAWP11 O   E           K        DISK
      *---------------------------------------------------
     I            DS
     I                                        1  20 ABMHIN
     I                                        1   5 ABMHN1
     I                                        6  10 ABMHN2
     I                                       11  15 ABMHN3
     I                                       16  20 ABMHN4
     I            DS
     I                                        1  12 A1SHIN
     I                                        1   5 A1SHN1
     I                                        6  10 A1SHN2
     I                                       11  12 A1SHN3
     I            DS
     I                                        1   60TGTMM6
     I                                        1   40#YY
     I                                        5   60#MM
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        7  120TGTMM
     I                                        7  100@YY
     I                                       11  120@MM
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ***********************************************************
      *
     C                     EXSR #INIT
      *
     C           TGTMM     SETLLABAWL13
      *
     C                     DO   *HIVAL
     C                     READ ABAWL13                  98
     C   98                LEAVE
      * SELECT
     C           ABDATE    IFGT TGTMM6
     C                     LEAVE
     C                     ENDIF
      *
      * CONVERT USER PART TO IAF PART
     C                     EXSR #CONV
     C                     WRITEABAWP111
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * CONVERT USER PART TO IAF PART                      *
      *----------------------------------------------------*
     C           #CONV     BEGSR
      * CLEAR ABAWP11
     C                     CLEARABAWP111
      * CALL BBHR50
     C                     MOVELABTOKU    PTOKU
     C                     MOVELABNONY    PNONY
     C                     MOVELABNKOJ    PNKOJ
     C                     MOVELABNUKE    PNUKE
     C                     MOVELABMHIN    @MHIN
     C                     MOVEL*BLANK    @SHIN
     C                     MOVEL*BLANK    @FLG
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           @MHIN  20
     C                     PARM           @SHIN  12
     C                     PARM           @FLG    1
      *
     C           @FLG      IFEQ *BLANK
     C                     MOVEL@SHIN     A1SHIN
     C                     ELSE
     C                     MOVEL'???'     A1SHIN
     C                     ENDIF
      *
     C                     Z-ADD0         FCNT    40
     C                     Z-ADDABTOKU    A1TOKU
     C                     Z-ADDABNONY    A1NONY
     C                     MOVELABNKOJ    A1NKOJ
     C                     MOVELABNUKE    A1NUKE
     C                     MOVELABMHN1    A1MHN1
     C                     MOVELABMHN2    A1MHN2
     C                     MOVELABMHN3    A1MHN3
     C                     MOVELABMHN4    A1MHN4
     C                     Z-ADDABDATE    A1DATE
     C                     Z-ADDABNNSU    A1NNSU
      *
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C                     TIME           @SDATE
      * GET + 6 MONTH
     C           @MM       IFLE 06
     C                     Z-ADD@YY       #YY
     C           @MM       ADD  6         #MM
     C                     ELSE
     C           @YY       ADD  1         #YY
     C           @MM       SUB  6         #MM
     C                     ENDIF
      *
     C                     ENDSR
