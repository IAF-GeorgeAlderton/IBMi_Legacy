     F************************* ABBR71 **
     FABBPL71 IF  E           K        DISK
     FAH#PL71 IF  E           K        DISK
%0001FOUTPUT1 O   F     512            DISK                      A
      *--------------------------------------------------
     I            DS
     I                                        1   80W@YMD
     I                                        1   40W@YY
     I                                        5   60W@MM
     I                                        7   80W@DD
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           PDAT    8
      *--------------------------------------------------
     C                     EXSR #MAIN
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------
     C           K#71      KLIST
     C                     KFLD           W@YMD   80
     C                     KFLD           W@SHFT
     C           K#AH      KLIST
     C                     KFLD           W@YMD
     C                     KFLD           A7PRT1
     C                     KFLD           A7PRT2
     C                     KFLD           A7PRT3
      *
     C                     MOVE PDAT      W@YMD   80
     C                     MOVE '2'       W@SHFT  1
     C           K#71      CHAINABBPL71              90
     C           *IN90     IFEQ *ON
     C                     MOVE '1'       W@SHFT
     C           K#71      CHAINABBPL71              90
     C                     ENDIF
      *
     C           *IN90     IFEQ *ON
     C                     MOVE '3'       W@SHFT
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------
     C           #MAIN     BEGSR
      *-----------------------------------------------
      *
     C           K#71      SETLLABBPL71
     C           *IN80     DOUEQ*ON
     C           K#71      READEABBPL71                  80
     C           *IN80     IFEQ *OFF
     C           A7KQTY    ANDNE*ZERO
%0001 *
     C           K#AH      CHAINAH#PL71              90
     C           *IN90     IFEQ *OFF
     C                     ITER
     C                     ENDIF
     C                     MOVE *BLANK    APKUBN  1
     C           A7KNID    IFNE 'A'
     C                     MOVE '9'       APKUBN
     C                     END
      *
     C                     EXCPTDAT
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
%0001 *-----------------------------------------------------*
     OOUTPUT1 EADD             DAT
     O                         A7DATE     8
     O                         A7TIME    14
     O                         A7USER    24
     O                         A7WSID    34
     O                         A7PGID    44
     O                         A7LOCT    50
     O                         A7BRCD    65
     O                         A7PRT1    70
     O                         A7PRT2    75
     O                         A7PRT3    77
     O                         A7KQTY    80
     O                         A7KNID    81
     O                         A7ISDT    89
     O                         A7MCHN    92
     O                         A7CMNT   112
     O                         A7LOTS   114
     O                         APKUBN   115
