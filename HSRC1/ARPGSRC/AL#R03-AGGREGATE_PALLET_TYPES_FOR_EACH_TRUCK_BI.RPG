     H            Y.
     F** AL#R03  *******************************************
     F*トラック便ごとのパレット種類を集計                *
     F*      ITS.        2015.05.19                        *
     F******************************************************
     FAL#PL11 IF  E           K        DISK
     FAL#WP10 UF  E           K        DISK                      A
     FAL#WP11 O   E                    DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      *
     C                     READ AL#PL111                 81
     C           *IN81     DOWEQ'0'
     C           C1SKJY    IFEQ 'D'
     C           C1SKHZ    ANDLESDATE
     C                     ELSE
     C                     EXSR #SB500
     C                     EXSR #SB501
     C                     ENDIF
     C                     READ AL#PL111                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AL#WP10  トラック便ごとのパレット種類の合計
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C           KEYW0     KLIST
     C                     KFLD           C1TRKB
     C                     KFLD           C1SURT
     C****                 KFLD           C1SHID
     C****                 KFLD           C1SHIT
      *
     C           KEYW0     CHAINAL#WP101             22
     C           *IN22     IFEQ '0'
     C                     ADD  1         W0KPLT
     C                     UPDATAL#WP101
     C                     ELSE
     C                     CLEARAL#WP101
     C****                 MOVELC1SHID    W0SHID
     C****                 MOVELC1SHIT    W0SHIT
     C                     MOVELC1SURT    W0SURT
     C                     Z-ADDC1EXTR    W0EXTR
     C                     Z-ADDC1FIXD    W0FIXD
     C                     Z-ADDC1FIXT    W0FIXT
     C                     Z-ADD1         W0KPLT
     C                     MOVELC1TRKB    W0TRKB
     C                     WRITEAL#WP101
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
      *-----------------------------------------------------
      *  AL#WP11パレットごとの箱数
      *-----------------------------------------------------
     CSR         #SB501    BEGSR
      *
     C                     CLEARAL#WP111
     C                     MOVELC1NONY    W1NONY
     C                     MOVELC1NKOJ    W1NKOJ
     C                     MOVELC1NUKE    W1NUKE
     C                     MOVELC1ORD#    W1ORD#
     C                     MOVELC1SHID    W1SHID
     C                     MOVELC1SHIT    W1SHIT
     C                     MOVELC1SURT    W1SURT
     C                     Z-ADDC1EXTR    W1EXTR
     C                     Z-ADDC1FIXD    W1FIXD
     C                     Z-ADDC1FIXT    W1FIXT
     C                     MOVELC1PALT    W1PALT
     C                     Z-ADDC1BOX     W1BOX
     C                     MOVELC1TRKB    W1TRKB
     C                     Z-ADDC1PRT     W1PRT
     C                     MOVELC1PPUL    W1PPUL
     C                     MOVELC1SAT     W1SAT
     C                     MOVELC1SHN1    W1SHN1
     C                     MOVELC1SHN2    W1SHN2
     C                     MOVELC1SHN3    W1SHN3
     C                     WRITEAL#WP111
      *
     CSR         ESB501    ENDSR
