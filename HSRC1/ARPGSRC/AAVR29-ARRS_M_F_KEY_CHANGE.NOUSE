     C                     SETON                     LR
     C                     RETRN
      *
     C*----------------*
     C*  ..s]ﾃc lbf..  *
     C*----------------*
     C           ##2       BEGSR
      *
     C*------------------*
     C*  ..ARRS  uﾇjｰ..  *
     C*------------------*
     C                     SETOF                     11
     C           KEY1      CHAINOABPL011             11
      *
     C                     MOVE *BLANK    OBSKJY
     C                     Z-ADD0         OBSKHZ
     C                     Z-ADD*DATE     OBKOHZ
     C                     TIME           WTIME
     C                     MOVE PUSR      OBKOME
     C                     MOVE PSHN1     OBHIN1
     C                     MOVE PSHN2     OBHIN2
     C                     MOVE PSHN3     OBHIN3
      *
     C                     MOVE *BLANK    CKO
     C                     Z-ADD0         CBM
     C                     MOVE *BLANK    CBN
     C                     MOVE *BLANK    CKB
     C                     MOVE *BLANK    CNO
     C                     Z-ADD0         CHZ
     C                     MOVE *BLANK    OBJKCD
     C                     Z-ADD0         OBJBCD
     C                     MOVE *BLANK    OBJBAN
     C                     MOVE *BLANK    OBJHI1
     C                     MOVE *BLANK    OBJHI2
     C                     MOVE *BLANK    OBJKBN
     C                     MOVE *BLANK    OBMKCD
     C                     Z-ADD0         OBMBCD
     C                     MOVE *BLANK    OBMBAN
     C                     Z-ADD0         OBMUHB
     C                     MOVE *BLANK    OBMKBN
     C                     MOVE *BLANK    OBAKCD
     C                     Z-ADD0         OBABCD
     C                     MOVE *BLANK    OBABAN
     C                     Z-ADD0         OBAUHB
     C                     MOVE *BLANK    OBAKBN
      *
     C*-----------------*
     C*  .. AAMPL11 ..  *
     C*-----------------*
     C                     SETOF                     10
     C           KEY1      CHAINAAMPL111             10
     C           *IN10     IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '0'
      *
     C*-----------------*
     C*  ..ﾃcmb  ﾈｮn..  *
     C*-----------------*
     C                     Z-ADD1         A       20
     C                     Z-ADD0         B       20
     C           1         DO   15        A
     C           KKO,A     IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE KKO,A     CKO,B
     C                     Z-ADDKBM,A     CBM,B
     C                     MOVE KBN,A     CBN,B
     C                     MOVE KKB,A     CKB,B
     C                     MOVE KNO,A     CNO,B
     C                     Z-ADDKHZ,A     CHZ,B
     C                     END
     C                     END
      *
     C*----------------*
     C*  ..ﾆﾞ  ﾃcmb..  *
     C*----------------*
     C                     SETOF                     10
     C                     Z-ADD1         I       20
     C           'ARS'     LOKUPCKO,I                    10
     C           *IN10     IFEQ '1'
     C                     MOVE CKO,I     OBJKCD
     C                     Z-ADDCBM,I     OBJBCD
     C                     MOVE CBN,I     OBJBAN
     C                     MOVE CNO,I     OBJHI1
     C                     MOVE CKB,I     OBJKBN
      *
     C*----------------*
     C*  ..ud  ﾃcmb..  *
     C*----------------*
     C                     SETOF                     10
     C                     Z-ADDI         J       20
     C                     DO   *HIVAL
     C                     SUB  1         J
     C           J         IFEQ 0
     C                     SETON                     10
     C                     ELSE
     C           CBN,J     IFNE '------'
     C           CBN,J     ANDNE'++++++'
     C                     SETON                     10
     C                     MOVE CKO,J     OBMKCD
     C                     Z-ADDCBM,J     OBMBCD
     C                     MOVE CBN,J     OBMBAN
     C                     Z-ADDCHZ,J     OBMUHB
     C                     MOVE CKB,J     OBMKBN
     C                     END
     C                     END
     C  N10                END
      *
     C*----------------*
     C*  ..an  ﾃcmb..  *
     C*----------------*
     C                     SETOF                     10
     C                     Z-ADDI         J
     C                     DO   *HIVAL
     C                     ADD  1         J
     C           J         IFEQ 16
     C                     SETON                     10
     C                     ELSE
     C           CBN,J     IFNE '------'
     C           CBN,J     ANDNE'++++++'
     C                     SETON                     10
     C                     MOVE CKO,J     OBAKCD
     C                     Z-ADDCBM,J     OBABCD
     C                     MOVE CBN,J     OBABAN
     C                     Z-ADDCHZ,J     OBAUHB
     C                     MOVE CKB,J     OBAKBN
     C                     END
     C                     END
     C  N10                END
     C                     END
     C                     END
      *
     C                     MOVE *ALL'0'   OBZBAN
     C                     MOVE *BLANK    OBSBAN
     C                     MOVE *BLANK    OBKBAN
     C                     Z-ADD0         OBKSHZ
     C                     Z-ADD0         OBSSUU
     C                     MOVE *BLANK    OBSHKS
     C                     Z-ADD0         OBKSUU
     C                     MOVE *BLANK    OBKHKS
     C                     Z-ADD0         OBNKHZ
      *
     C*------------------*
     C*  .. FCEPL011 ..  *
     C*------------------*
     C                     SETOF                     10
     C           KEY1      CHAINFCEPL011             10
     C           *IN10     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '0'
     C                     MOVE A2STKR    OBSBAN
     C                     MOVE A2KTKR    OBKBAN
      *
     C                     Z-ADDA2TRYY    OBKSYY
     C                     Z-ADDA2TRMM    OBKSMM
     C                     Z-ADDA2TRDD    OBKSDD
      *
     C                     Z-ADDA2SSYS    OBSSUU
     C                     MOVE A2SSYT    OBSHKS
     C                     Z-ADDA2KSYS    OBKSUU
     C                     MOVE A2KSYT    OBKHKS
      *
     C                     Z-ADDA2SYYY    OBNKYY
     C                     Z-ADDA2SYMM    OBNKMM
     C                     Z-ADDA2SYDD    OBNKDD
      *
     C                     MOVE A2ZETI    OBZBAN
     C                     END
      *
     C           *IN11     IFEQ '1'
     C                     Z-ADD0         OBSHSU
     C                     Z-ADD0         OBKHSU
     C                     Z-ADD0         OBKHHZ
     C                     MOVE *BLANK    OBSKBN
     C                     MOVE *BLANK    OBKKBN
     C                     Z-ADD0         OBKBHZ
     C                     MOVE *BLANK    OBTKBN
     C                     Z-ADD0         OBSTCD
     C                     WRITEOABPL011
     C                     ELSE
      *
     C                     UPDATOABPL011
     C                     END
