     C           K#ADGP    CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     MOVE *ON       *IN90
     C                     MOVE *ON       *IN99
     C                     ENDIF
TCHK1C                     MOVEL*BLANK    @OUTQ
TCH62 * CHECK PRINTER SELECTION
   | C           D@PRT     IFLE '7'
     C                     SELEC
     C           D@PRT     WHEQ *BLANK
     C                     MOVEL'QPRINTC' @OUTQ   8
     C           D@PRT     WHEQ '1'
     C                     MOVEL'LANPRT02'@OUTQ
     C           D@PRT     WHEQ '2'
     C                     MOVEL'LANPRT07'@OUTQ
     C           D@PRT     WHEQ '3'
     C                     MOVEL'LANPRT03'@OUTQ
     C           D@PRT     WHEQ '4'
TCHK3C*                    MOVEL'LANPRT01'@OUTQ
TCHK3C                     MOVEL'LANPRT04'@OUTQ
     C           D@PRT     WHEQ '5'
     C                     MOVEL'QPRINTB '@OUTQ
     C           D@PRT     WHEQ '6'
     C                     MOVEL'QPRINT  '@OUTQ
     C           D@PRT     WHEQ '7'
     C                     MOVEL'QDKT    '@OUTQ
     C                     OTHER
     C                     MOVEL'QPRINTC' @OUTQ   8
     C                     ENDSL
     C                     ELSE
     C                     SETON                     6899
     C                     MOVE ERR,2     D@MSG
TCH61C                     ENDIF
