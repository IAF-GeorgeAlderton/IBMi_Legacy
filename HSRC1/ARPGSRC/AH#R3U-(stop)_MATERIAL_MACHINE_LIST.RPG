E03  C                     ENDIF
      *
B03  C           ZBSKJY    IFEQ 'D'
     C           ZBSKHZ    ANDLED@DATE
     C                     ITER
E03  C                     ENDIF
      *
     C                     MOVE ZBSHN1    #KSHN1
