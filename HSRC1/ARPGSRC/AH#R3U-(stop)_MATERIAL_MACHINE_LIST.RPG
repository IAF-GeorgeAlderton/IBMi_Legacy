     C                     Z-ADD0         WKGOKE  90
      *
     C           K#21      SETLLMBEPL021
B03  C           *IN91     DOUEQ*ON
     C           K#21      READEMBEPL021                 91
B03  C           *IN91     IFEQ *OFF
B04  C           F2SKJY    ANDEQ' '
     C                     ADD  F2GOKE    WKGOKE
E04  C                     ENDIF
      *
     C                     ENDDO
     C           WKGOKE    MULT ZBSOZI    WKJIT  112
     C           WKJIT     DIV  1000      @@ACTW  80H
     C                     ADD  @@ACTW    S@ACTW
E03  C                     ENDIF
