     H            Y.
     F** GDGR81 ************************************
     A*   INQUIRY SCREEN OF ORDER INFORMATION      *
     F*       MSK.KUNIEDA         2000.03.17       *
     F*                           2000.11.09       *
     F************************************ GDGR81 **
     FGDGPW81 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL1
     FGDGWP80 IF  E           K        DISK
      *
     E                    MSG     1   4 60
      *
     I            DS
     I                                        1   60TIME
     I                                        1   20TIMHH
     I                                        3   40TIMMM
      *
     I            DS
     I                                        1   80HYMD8
     I                                        3   80HYMD6
     I                                        1   40HYY
     I                                        5   60HMM
     I                                        7   80HDD
     I            DS
     I                                        1   6 WKORDR
     I                                        1   2 WKORD1
     I                                        3   4 WKORD2
     I                                        5   6 WKORD3
     I            DS
     I                                        1  15 @HIN
     I                                        1   5 @HIN1
     I                                        6   6 WKF3
     I                                        7  11 @HIN2
     I                                       12  12 WKF4
     I                                       13  14 @HIN3
     I            DS
     I                                        1  15 WKSP
     I                                        1   8 WKKATA
     I                                        1   2 WKKAT1
     I                                        3   6 WKKAT2
     I                                        7   7 WKKAT3
     I                                        8   8 WKKAT4
     I                                        1   5 WKHIN1
     I                                        6  10 WKHIN2
     I                                       11  12 WKHIN3
      *
     I            DS
     I                                        1  11 @KATA
     I                                        1   2 @KAT1
     I                                        3   3 WKFA
     I                                        4   7 @KAT2
     I                                        8   8 WKFB
     I                                        9   9 @KAT3
     I                                       10  10 WKFC
     I                                       11  11 @KAT4
      *
     I            DS
     I                                        1   8 @ODER
     I                                        1   2 @ORD1
     I                                        3   3 WKF1
     I                                        4   5 @ORD2
     I                                        6   6 WKF2
     I                                        7   8 @ORD3
      *
     I            DS
     I                                        1   6 WKDATE
     I                                        1   20@MM
     I                                        3   40@DD
     I                                        5   60@YY
      *
     I            DS
     I                                        1   7 @INVO
     I                                        1   2 IXINV1
     I                                        3   3 WKF7
     I                                        4   70IXINV2
      *
     I            DS
     I                                        1   80IXDLHZ
     I                                        1   20IXDLVM
     I                                        3   40IXDLVD
     I                                        5   80IXDLVY
      *
     C           *ENTRY    PLIST
     C                     PARM           PSNO    6
     C                     PARM           PENO    6
     C                     PARM           PNO     1
     C                     PARM           PPART  15
     C                     PARM           PRENCD  1
     C                     PARM           TMAIS   50
     C                     PARM           TNOHK   50
     C                     PARM           TMIHK   50
      *
      *
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
     C           KEYSAV    KLIST
     C                     KFLD           #KODER  60
     C                     KFLD           #KITEM  50
     C                     KFLD           #KINV1  2
     C                     KFLD           #KINV2  40
     C                     KFLD           #KPART 15
      *----------------------------------------------------*
      *  メインルーチン                                  *
      *----------------------------------------------------*
     C                     EXSR $SB100
     C           *IN03     DOWEQ'0'
     C                     EXSR $SB200
     C                     END
     C                     EXSR $SB300
      *----------------------------------------------------*
      *   初期処理                                       *
      *----------------------------------------------------*
     CSR         $SB100    BEGSR
     C                     TIME           TIME
     C                     Z-ADD*DATE     HYMD8
     C                     MOVE *BLANK    DSPSW1  1
     C                     MOVE *BLANK    DSPSW2  1
     C                     MOVE *BLANK    DSPSW3  1
     C                     Z-ADD0         X       10
      *
     C                     MOVE TMAIS     @TOBOX
     C                     MOVE TNOHK     @TIBOX
     C                     MOVE TMIHK     @TMBOX
     C                     MOVE PNO       X
     C                     MOVE '-'       WKF1
     C                     MOVE '-'       WKF2
     C                     MOVELMSG,X     @TYPE
     C                     MOVE PSNO      WKORDR
     C                     MOVE WKORD1    @ORD1
     C                     MOVE WKORD2    @ORD2
     C                     MOVE WKORD3    @ORD3
     C                     MOVE @ODER     @ODER1
     C                     MOVE PENO      WKORDR
     C                     MOVE WKORD1    @ORD1
     C                     MOVE WKORD2    @ORD2
     C                     MOVE WKORD3    @ORD3
     C                     MOVE @ODER     @ODER2
     C                     MOVE *BLANK    @ODER
     C                     SETOF                     10
     C           PPART     IFNE *BLANK
     C                     SETON                     10
     C                     MOVE PPART     WKSP
     C                     MOVE '-'       WKF1
     C                     MOVE '-'       WKF2
     C                     MOVE '-'       WKF3
     C                     MOVE '-'       WKF4
     C                     MOVE '-'       WKF7
     C                     MOVE '-'       WKFA
     C                     MOVE '-'       WKFB
     C                     MOVE '-'       WKFC
     C                     MOVELPPART     @PARTS
     C           PNO       IFEQ '1'
      *
     C                     MOVE WKHIN1    @HIN1
     C                     MOVE WKHIN2    @HIN2
     C                     MOVE WKHIN3    @HIN3
     C           @HIN3     IFEQ *BLANK
     C                     MOVE *BLANK    WKF4
     C                     END
     C                     MOVEL@HIN      @PARTS
      *
     C                     END
      *
     C           PNO       IFEQ '2'
     C                     MOVE WKKAT4    @KAT4
     C                     MOVE WKKAT3    @KAT3
     C                     MOVE WKKAT2    @KAT2
     C                     MOVE WKKAT1    @KAT1
     C           @KAT4     IFEQ *BLANK
     C                     MOVE *BLANK    WKFB
     C                     MOVE *BLANK    WKFC
     C                     END
     C                     MOVEL@KATA     @PARTS
     C                     END
     C                     END
      *SFL1 CLEAR
     C                     SETON                     71
     C                     WRITESREC1
     C                     SETOF                     71
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN    40
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         WKPAGE  20
     C                     Z-ADD1         @SFRC1
      *
     C                     MOVE '1'       DSPSW1
     C                     MOVE '0'       DSPSW2
     C                     MOVE *BLANK    @ERR
     CSR         $S100E    ENDSR
      *----------------------------------------------------*
      *   主処理                                         *
      *----------------------------------------------------*
     CSR         $SB200    BEGSR
     C           *IN03     DOWEQ'0'
     C           DSPSW1    ANDEQ'1'
     C                     EXSR $SB210
     C                     END
      *
     C           *IN03     DOWEQ'0'
     C           DSPSW2    ANDEQ'1'
     C                     EXSR $SB220
     C                     END
      *
     CSR         $S200E    ENDSR
      *----------------------------------------------------*
      *   第一画面処理(GDGPW801)                         *
      *----------------------------------------------------*
     CSR         $SB210    BEGSR
      *
     C           *LOVAL    SETLLGDGWP80
     C                     SETOF                     8166
     C                     DO   *HIVAL
     C                     READ GDGWP80                  81
     C           *IN81     IFEQ '0'
  KK C           IXHANY    IFNE 'C'
     C                     EXSR $SB400
  KK C                     END
     C                     END
     C  N81N66             END
      *
     C                     EXSR $SB900
     C                     MOVE '1'       DSPSW2
     C                     MOVE '0'       DSPSW1
      *
     CSR         $S210E    ENDSR
      *----------------------------------------------------*
      *   第二画面処理(SFL.GDGPW818,GDGPW819)            *
      *----------------------------------------------------*
     CSR         $SB220    BEGSR
     C                     SETON                     70
     C                     WRITEGDGPW817
     C                     WRITEGDGPW818
     C                     WRITEGDGPW819
     C                     EXFMTSREC1
     C                     SETOF                     7031
     C                     SETOF                     99
     C                     MOVE *BLANK    @ERR
      * CMD-3
     C           *IN03     IFEQ '1'
     C                     MOVE '1'       PRENCD
     C                     EXSR $SB410
     C                     GOTO $S220E
     C                     END
      * ROLLDOWN
     C           *IN52     IFEQ '1'
     C                     ADD  1         CTRX
      *
     C           WKPAGE    IFEQ 1
     C                     GOTO $S220E
     C                     END
      *
     C           *IN81     IFEQ '1'
     C                     SETOF                       81
     C           *HIVAL    SETGTGDGWP80
     C                     END
      *
     C                     ADD  5         CTRX
     C                     SETOF                     66
      *
     C                     DO   *HIVAL
     C                     READPGDGWP80                  81
     C           *IN81     IFEQ '0'
     C                     SUB  1         CTRX         6666
     C                     END
     C  N81N66             END
      *
      *カウンタクリア
     C                     Z-ADD0         CTRX    40
      *
     C           *IN81     IFEQ '1'
     C                     SETOF                       81
     C           *LOVAL    SETLLGDGWP80
     C                     END
      *サブファイルクリアー
     C                     SETON                     71
     C                     WRITESREC1
     C                     SETOF                     71
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         @SFRC1
      *
     C                     SETOF                         66
     C                     DO   *HIVAL
     C                     READ GDGWP80                  81
     C           *IN81     IFEQ '0'
     C                     EXSR $SB400
     C                     END
     C  N81N66             END
      *
     C                     EXSR $SB900
     C                     SUB  1         WKPAGE
     C                     END
      * ROLL-UP
     C           *IN51     IFEQ '1'
     C           *IN81     ANDEQ'0'
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         @SFRC1
     C                     SETON                       71
     C                     WRITESREC1
     C                     SETOF                       7166
      *
     C                     SETOF                         66
     C                     DO   *HIVAL
     C                     READ GDGWP80                  81
     C           *IN81     IFEQ '0'
     C                     EXSR $SB400
     C                     END
     C  N81N66             END
      *
     C                     EXSR $SB900
     C                     ADD  1         WKPAGE
     C                     END
      * MSK 2000.11.09
     C                     Z-ADD0         IDX     50
     C                     DO   *HIVAL
      *
     C                     ADD  1         IDX
     C                     SETOF                       21
     C           IDX       CHAINSFL1                 21
     C           *IN21     IFEQ '0'
     C           @SEL      IFNE 'M'
     C           @SEL      ANDNE*BLANK
     C                     SETON                     9931
     C                     MOVELMSG,3     @ERR
     C                     UPDATSFL1
     C                     GOTO $S220E
     C                     ELSE
      *
     C                     MOVE *BLANK    PRENCD
     C                     SETOF                     31
     C           @SEL      IFEQ 'M'
     C                     MOVE @ODER     PODER   8
     C                     MOVE @ITEM     PITEM   50
     C                     MOVE @PARTN    PPARTN 22
     C                     MOVE @OQTY     POQTY   90
     C                     MOVE @CQTY     PCQTY   60
     C                     MOVE @OBOX     PMBOX   40
     C                     MOVE @HANY     P@HANY  1
     C                     Z-ADD@DLVR     P@DLVR  80
     C                     CALL 'GDGR82'
     C                     PARM           PSNO    6
     C                     PARM           PENO    6
     C                     PARM           PNO     1
     C                     PARM           PPART  15
     C                     PARM           PRENCD  1
     C                     PARM           PODER   8
     C                     PARM           PITEM   50
     C                     PARM           PPARTN 22
     C                     PARM           POQTY   90
     C                     PARM           PCQTY   60
     C                     PARM           PMBOX   40
     C                     PARM           P@HANY  1
     C                     PARM           P@DLVR  80
     C                     SETOF                     31
     C           PRENCD    IFEQ 'E'
     C                     SETON                     9931
     C                     MOVELMSG,4     @ERR
     C                     MOVE *BLANK    @SEL
     C                     ELSE
     C                     MOVE *BLANK    @SEL
     C                     END
     C                     SETOF                     03
     C                     END
     C                     UPDATSFL1
      *
     C                     END
     C                     END
      *
     C  N21N99             END
      *
     CSR         $S220E    ENDSR
      *----------------------------------------------------*
      *   終了処理                                       *
      *----------------------------------------------------*
     CSR         $SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         $S300E    ENDSR
      *----------------------------------------------------*
      *   INQUIRY SCREEN ITEM SET                        *
      *----------------------------------------------------*
     CSR         $SB400    BEGSR
      *
     C                     ADD  1         RRN
     C                     ADD  1         @RRN
     C                     ADD  1         CTRX
     C                     MOVE '-'       WKF1
     C                     MOVE '-'       WKF2
     C                     MOVE '-'       WKF3
     C                     MOVE '-'       WKF4
     C                     MOVE '-'       WKF7
     C                     MOVE '-'       WKFA
     C                     MOVE '-'       WKFB
     C                     MOVE '-'       WKFC
     C                     MOVELIXPART    @PARTN
     C           PNO       IFEQ '1'
      *
     C                     MOVE IXPART    WKSP
     C                     MOVE WKHIN1    @HIN1
     C                     MOVE WKHIN2    @HIN2
     C                     MOVE WKHIN3    @HIN3
     C           @HIN3     IFEQ *BLANK
     C                     MOVE *BLANK    WKF4
     C                     END
     C                     MOVEL@HIN      @PARTN
      *
     C                     END
      *
     C           PNO       IFEQ '2'
     C                     MOVE IXPART    WKSP
     C                     MOVE WKKAT4    @KAT4
     C                     MOVE WKKAT3    @KAT3
     C                     MOVE WKKAT2    @KAT2
     C                     MOVE WKKAT1    @KAT1
     C           @KAT4     IFEQ *BLANK
     C                     MOVE *BLANK    WKFB
     C                     MOVE *BLANK    WKFC
     C                     END
     C                     MOVEL@KATA     @PARTN
     C                     END
      *
     C                     MOVE IXODER    WKORDR
     C                     MOVE WKORD1    @ORD1
     C                     MOVE WKORD2    @ORD2
     C                     MOVE WKORD3    @ORD3
     C                     MOVE IXODRM    @MM
     C                     MOVE IXODRD    @DD
     C                     MOVE IXODRY    @YY
     C                     MOVE WKDATE    @ODATE
     C           IXODRY    IFEQ *ZERO
     C           IXODRM    ANDEQ*ZERO
     C           IXODRD    ANDEQ*ZERO
     C                     MOVE *BLANK    @ODATE
     C                     END
     C                     Z-ADDIXSYOS    @CQTY
     C                     Z-ADDIXMAIS    @OBOX
     C                     Z-ADDIXSURY    @OQTY
     C                     MOVE IXITEM    @ITEM
     C                     MOVE IXSPMM    @MM
     C                     MOVE IXSPDD    @DD
     C                     MOVE IXSPYY    @YY
     C                     MOVE WKDATE    @RDATE
     C                     Z-ADDIXNOSU    @IQTY
     C                     Z-ADDIXNOHK    @IBOX
     C                     Z-ADDIXMINO    @MQTY
     C                     Z-ADDIXMIHK    @MBOX
     C           IXINV1    IFEQ *BLANK
     C           IXINV2    ANDEQ0
     C                     MOVE *BLANK    @INVO
     C                     END
     C                     MOVE IXHANY    @HANY
     C                     Z-ADDIXDLHZ    @DLVR
      *
     C                     WRITESFL1
      *
     C           CTRX      IFEQ 05
     C                     SETON                       66
     C                     END
      *
     CSR         $S400E    ENDSR
      *----------------------------------------------------*
      *   表示項目クリアー                               *
      *----------------------------------------------------*
     CSR         $SB410    BEGSR
     C                     MOVE '0'       DSPSW1
     C                     MOVE '0'       DSPSW2
     C                     MOVE '0'       DSPSW3
     C                     SETON                     71
     C                     WRITESREC1
     C                     SETOF                     71
     C                     Z-ADD0         RRN
     CSR         $S410E    ENDSR
      *----------------------------------------------------*
      *    NEXT POINTER SETR                               *
      *----------------------------------------------------*
     CSR         $SB900    BEGSR
      *
     C                     SETOF                         68
     C                     DO   *HIVAL
     C                     READ GDGWP80                  81
     C           *IN81     IFEQ '0'
     C                     MOVE IXODER    #KODER
     C                     MOVE IXITEM    #KITEM
     C                     MOVE IXINV1    #KINV1
     C                     MOVE IXINV2    #KINV2
     C                     MOVELIXPART    #KPART
     C                     SETON                         68
     C                     END
     C  N81N68             END
      *
     C           KEYSAV    SETLLGDGWP80
      *
     CSR         $S900E    ENDSR
**
PART & WASHER
TOOL
ER-1 BLANK OR M IS AVAILABLE.
ER-2 INQUIRY DATA NOT FOUND
