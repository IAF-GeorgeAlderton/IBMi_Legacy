     H            Y/
     F* PARM('A' '2849' '665' '20140724' '    ')
     FALDPL30 IF  E           K        DISK                           UC
     FADAPL01 IF  E           K        DISK                           UC
     FALSPL01 IF  E           K        DISK                           UC
     FALJPL10 IF  E           K        DISK                           UC
      *
     I            DS
     I                                        1   80A3SYDT
     I                                        1   40A3SYYY
     I                                        5   60A3SYMM
     I                                        7   80A3SYDD
     I            DS
     I                                        1   80ADKODT
     I                                        1   40ADKOYY
     I                                        5   60ADKOMM
     I                                        7   80ADKODD
      *
     C           *ENTRY    PLIST
     C                     PARM           P@CHYU  1
     C                     PARM           P@ZENO  4
     C                     PARM           P@THNO  3
     C                     PARM           P@HTHZ  8
     C                     PARM           P@MAIS  4
     C                     PARM           P#OPN   1
      *
     C                     Z-ADD0         @CNT
     C           P#OPN     IFEQ '9'
     C           OPNFL     IFEQ '1'
     C                     CLOSEALDPL30
     C                     CLOSEADAPL01
     C                     CLOSEALSPL01
     C                     CLOSEALJPL10
     C                     ENDIF
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
     C           OPNFL     IFEQ *BLANK
     C                     MOVEL'1'       OPNFL   1
     C                     OPEN ALDPL30
     C                     OPEN ADAPL01
     C                     OPEN ALSPL01
     C                     OPEN ALJPL10
     C                     ENDIF
      *
     C                     MOVE P@CHYU    K@CHYU  1
     C                     MOVE P@ZENO    K@ZENO  4
     C                     MOVE P@THNO    K@THNO  3
     C                     MOVE P@HTHZ    K@HTHZ  80
      *
     C           ALDKEY    KLIST
     C                     KFLD           K@ZENO  4
     C                     KFLD           K@THNO  3
      *
     C           ALDKEY    SETLLALDPL30
     C                     DO   *HIVAL
     C           ALDKEY    READEALDPL30                  77
     C   77                LEAVE
     C           A3SYDT    IFLT K@HTHZ
     C                     ITER
     C                     END
     C                     ADD  1         @CNT    40
     C                     ENDDO
      * ALSPP01
     C                     EXSR #SBALS
      * ALJPP10  CREFORM
     C                     EXSR #SBALJ
      *
     C           ADAKEY    KLIST
     C                     KFLD           K@CHYU  1
     C                     KFLD           K@ZENO  4
     C                     KFLD           K@THNO  3
      *
     C           ADAKEY    SETLLADAPL01
     C                     DO   *HIVAL
     C           ADAKEY    READEADAPL01                  77
     C   77                LEAVE
     C           ADKODT    IFLT K@HTHZ
     C                     ITER
     C                     END
     C                     ADD  1         @CNT    40
     C                     ENDDO
      *
     C                     MOVE @CNT      P@MAIS
      *
     C                     EXSR #END
      *
     C           #END      BEGSR
     C*********            SETON                     LR
     C                     RETRN
     C           EEND      ENDSR
     C* ----------------------------------------------------
     CSR         #SBALS    BEGSR
     C* ----------------------------------------------------
     C           ALDKEY    SETLLALSPL011
     C           ALDKEY    READEALSPL011                 92
     C           *IN92     DOWEQ'0'
     C           ASSKJY    IFEQ 'D'
     C           ASSKDT    ANDLE*DATE
     C                     ELSE
     C           ASCODT    IFGE K@HTHZ
     C           ASOKNG    ANDEQ'OK'
     C                     ADD  1         @CNT    40
     C                     ENDIF
     C                     ENDIF
     C           ALDKEY    READEALSPL011                 92
     C                     ENDDO
      *
     CSR         ESBALS    ENDSR
     C* ----------------------------------------------------
     CSR         #SBALJ    BEGSR
     C* ----------------------------------------------------
     C           ALDKEY    SETLLALJPL101
     C           ALDKEY    READEALJPL101                 92
     C           *IN92     DOWEQ'0'
      *
     C           B0DATE    IFGE K@HTHZ
     C                     ADD  1         @CNT    40
     C                     ENDIF
      *
     C           ALDKEY    READEALJPL101                 92
     C                     ENDDO
      *
     CSR         ESBALJ    ENDSR
