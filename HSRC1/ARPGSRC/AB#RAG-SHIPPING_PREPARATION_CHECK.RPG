     FAB#PWAG CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FAB#PL14 IF  E           K        DISK
     FAB#PL70 IF  E           K        DISK
     FAB#PL76 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FAB#PP7W UF  E           K        DISK                      A
      *------------------------------------------------------------
     E                    CMD     1   2 78
     E                    MSG     1   2 78
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   80A2TRDT
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
     I            DS
     I                                        1   80PUYMD
     I                                        1   40PUNOYY
     I                                        5   60PUNOMM
     I                                        7   80PUNODD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------------
      *   MAIN
      *------------------------------------------------------------
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C           @@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------------
      * INITIALIZE
      *------------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#14      KLIST
     C                     KFLD           PUNOYY
     C                     KFLD           PUNOMM
     C                     KFLD           PUNODD
     C                     KFLD           PUBINN
     C                     KFLD           PURLYY
     C                     KFLD           PURLMM
     C                     KFLD           PURLDD
     C                     KFLD           PUNONY
     C                     KFLD           PUNKOJ
     C                     KFLD           PUNUKE
     C           K#70      KLIST
     C                     KFLD           BATOKU
     C                     KFLD           K@NONY  4
     C                     KFLD           BANKOJ
     C                     KFLD           BANUKE
     C                     KFLD           BAMHN1
     C                     KFLD           BAMHN2
     C                     KFLD           BAMHN3
     C                     KFLD           BAMHN4
     C                     KFLD           K@ORDN 10
     C                     KFLD           BANOYY
     C                     KFLD           BANOMM
     C                     KFLD           BANODD
     C                     KFLD           K@NOBN  2
     C                     KFLD           BADEYY
     C                     KFLD           BADEMM
     C                     KFLD           BADEDD
      *
     C           K#FCE     KLIST
     C                     KFLD           BASHN1
     C                     KFLD           BASHN2
     C                     KFLD           BASHN3
      *
     C                     MOVE '01'      @@ID    2
      *
     C                     ENDSR
      *-----------------------------------------------------
      *  1ST SCREEN
      *-----------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C           RRN1      IFEQ *ZERO
     C                     MOVE MSG,1     D@MSG
     C                     ELSE
     C                     MOVE '02'      @@ID
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------
      *  CHECK THE BARCODE
      *-----------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     SETOF                     6199
      *
     C           D@BARC    CHAINAB#PL76              90
     C           *IN90     IFEQ *ON
     C                     MOVE MSG,2     D@MSG
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
      *  CHECK SCANNED DATA
      *-----------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
      *
     C                     MOVE PUCUST    D@CUST
     C                     MOVE PUNONY    D@NONY
     C                     MOVE PUNKOJ    D@NKOJ
     C                     MOVE PUNUKE    D@DOCK
     C                     MOVE PUBINN    D@BIN
     C                     Z-ADDPUYMD     D@SHDT
     C           K#14      SETLLAB#PL14
     C           *IN80     DOUEQ*ON
     C           K#14      READEAB#PL14                  80
     C           *IN80     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C                     MOVELBAINVN    W@INVN 10
     C           PUODRN    IFNE *BLANK
     C           PUODRN    COMP BAODRN                   96
     C  N96      PUODRN    COMP W@INVN                   96
     C  N96                ITER
     C                     ENDIF
      *
     C                     MOVE BANONY    K@NONY
     C                     CLEARSFL01
     C                     MOVE BAODRN    K@ORDN
     C                     MOVE BANOBN    K@NOBN
     C           K#70      SETLLAB#PL70
     C           *IN85     DOUEQ*ON
     C           K#70      READEAB#PL70                  85
     C           *IN85     IFEQ *OFF
     C           EKSKJY    ANDEQ*BLANK
     C**JW1      EKHENK    ANDEQ*BLANK
     C                     ADD  EKSRYO    S@SCAN
     C                     ENDIF
     C                     ENDDO
      *
TCHK1C           S@SCAN    IFEQ *ZERO
     C                     MOVELBAINVN    K@ORDN
     C           K#70      SETLLAB#PL70
     C           *IN85     DOUEQ*ON
     C           K#70      READEAB#PL70                  85
     C           *IN85     IFEQ *OFF
     C           EKSKJY    ANDEQ*BLANK
     C                     ADD  EKSRYO    S@SCAN
     C                     ENDIF
     C                     ENDDO
TCHK1C                     END
      *
     C           S@SCAN    IFGE BASRYO
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         RRN1
     C                     MOVE BASHN1    S@PRT1
     C                     MOVE BASHN2    S@PRT2
     C                     MOVE BASHN3    S@PRT3
     C                     Z-ADDBASRYO    S@ORQY
     C           K#FCE     CHAINFCEPL01              90
     C           *IN90     IFEQ *OFF
     C           BANOHZ    IFGE A2TRDT
     C                     MOVE A2STRK    S@LOC1
     C                     MOVE A2STRT    S@LOC2
     C                     MOVE A2STRR    S@LOC3
     C                     MOVE A2STRD    S@LOC4
     C                     ELSE
     C                     MOVE A2KTRK    S@LOC1
     C                     MOVE A2KTRT    S@LOC2
     C                     MOVE A2KTRR    S@LOC3
     C                     MOVE A2KTRD    S@LOC4
     C                     ENDIF
     C                     ENDIF
      *
     C           S@ORQY    SUB  S@SCAN    W@BAL   90
     C           BAUSYS    IFNE *ZERO
     C           W@BAL     DIV  BAUSYS    S@BOXB
     C                     MVR            W@MVR   50
     C           W@MVR     IFNE *ZERO
     C                     ADD  1         S@BOXB
     C                     ENDIF
     C                     ELSE
     C           BASYOS    IFNE *ZERO
     C           W@BAL     DIV  BASYOS    S@BOXB
     C                     MVR            W@MVR   50
     C           W@MVR     IFNE *ZERO
     C                     ADD  1         S@BOXB
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     WRITESFL01
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           D@BARC    CHAINAB#PP7W              90
     C           *IN90     IFEQ *ON
     C                     CLEARAB#PP7W1
     C                     MOVELD@BARC    PWSERL
     C                     ENDIF
      *
     C                     MOVEL#USER     PWUSER
     C                     Z-ADD*DATE     PWUDAT
     C                     TIME           PWUTIM
     C                     Z-ADD*DATE     PWDAT1
     C           RRN1      IFEQ 0
     C                     MOVE '0'       PWRST1
     C                     ELSE
     C                     MOVE '1'       PWRST1
     C                     ENDIF
     C   90                WRITEAB#PP7W1
     C  N90                UPDATAB#PP7W1
      *
     C                     ENDSR
      *-----------------------------------------------------
      *  2ND SCREEN
      *-----------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      @@ID
     C                     MOVE *BLANK    D@BARC
     C                     ENDSL
      *
     C                     ENDSR
