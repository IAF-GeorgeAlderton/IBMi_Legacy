     H            Y.
     F** AB#R1N ***************************************************
     F*  SPLIT HONDA ORDER OVER 60 BOX (NEW)                      *
     F*  J.WATANABE  2016.10.13                                   *
     F*                                                           *
     F*************************************************************
     FAB#PL1Q IF  E           K        DISK
     FAB#PL2J IF  E           K        DISK
     FAB#PLB1 UF  E           K        DISK                      A
      *============================================================
     I            DS
     I                                        1   80BADEHZ
     I                                        1   40BADEYY
     I                                        5   60BADEMM
     I                                        7   80BADEDD
     I            DS
     I                                        1   80BANOHZ
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I            DS
     I                                        1  140D#TIME
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *============================================================
      *
     C                     EXSR #INIT
      * CHECK IF HONDA ORDER?
     C           P#NONY    CHAINAB#PL2J              99
     C           *IN99     IFEQ *ON
     C                     GOTO ENDP
     C                     ENDIF
      * DELETE CURRENT DATA
     C                     EXSR #DLT
      * MAIN ROUTINE
     C                     Z-ADD0         PL@CNT  20       PALLET#
     C                     Z-ADD0         RM@QTY  70       REMAIN QTY
     C                     Z-ADD0         SP@QTY  70       SPLIT QTY
     C                     Z-ADD0         CR@BOX  30       CURRENT BOX#
     C                     Z-ADD0         EX@BOX  30       PREVIOUS BOX#
     C                     Z-ADD0         NW@BOX  30       NEW BOX#
      *
     C           K@PL1Q    SETLLAB#PL1Q
      * LOOP AB#PL1Q
     C           *IN91     DOWEQ*OFF
     C           K@PL1Q    READEAB#PL1Q                  91
     C           *IN91     IFEQ *OFF
      * SELECT
     C           BASKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C           P@ODRN    IFNE *BLANK
     C           P@ODRN    ANDNEBAODRN
     C                     ITER
     C                     ENDIF
      *
      * PROCESS --------------------------------
      * GET SYOS --> WSYOS
     C                     EXSR #SYOS
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     Z-ADD1         PL@CNT
     C                     ENDIF
      * ADD BOX COUNT
     C                     Z-ADDBASRYO    RM@QTY
     C                     Z-ADDCR@BOX    EX@BOX
     C           BASRYO    DIV  WSYOS     NW@BOX
     C                     MVR            MVR1    53
     C           MVR1      IFNE 0
     C                     ADD  1         NW@BOX
     C                     ENDIF
     C           EX@BOX    ADD  NW@BOX    CR@BOX
      *
      * IF BOX > 60, SPLIT ORDER
     C           CR@BOX    IFGT 60
      *------------------------------------------
     C           CR@BOX    DOWGT60
     C           60        SUB  EX@BOX    WBOX    30
     C           WBOX      MULT WSYOS     SP@QTY
     C                     EXSR #WRTB1
     C                     ADD  1         PL@CNT
     C                     SUB  60        CR@BOX
     C                     SUB  SP@QTY    RM@QTY
     C                     ENDDO
      *
     C           RM@QTY    IFNE 0
     C                     Z-ADDRM@QTY    SP@QTY
     C                     EXSR #WRTB1
     C                     ENDIF
      *------------------------------------------
     C                     ELSE
     C           RM@QTY    IFNE 0
     C                     Z-ADDRM@QTY    SP@QTY
     C                     EXSR #WRTB1
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           ENDP      TAG
     C                     MOVE *ON       *INLR
     C                     RETRN
      *============================================================
      * WRITE AB#PPB1
      *============================================================
     C           #WRTB1    BEGSR
      *
     C                     CLEARAB#PPB11
     C                     Z-ADDSP@QTY    B1SRYO
     C                     Z-ADDPL@CNT    B1PAL#
     C                     MOVEL' '       B1PALT
      * COPY ORDER DATA
     C                     Z-ADDBATOKU    B1TOKU
     C                     Z-ADDBANONY    B1NONY
     C                     MOVELBANKOJ    B1NKOJ
     C                     MOVELBANUKE    B1NUKE
     C                     Z-ADDBANOHZ    B1NOHZ
     C                     Z-ADDBANOBN    B1NOBN
     C                     MOVELBAMHN1    B1MHN1
     C                     MOVELBAMHN2    B1MHN2
     C                     MOVELBAMHN3    B1MHN3
     C                     MOVELBAMHN4    B1MHN4
     C                     MOVELBAODRN    B1ODRN
     C                     MOVELBAINVN    B1INVN
     C                     Z-ADDBASYOS    B1SYOS
     C                     Z-ADDBAUSYS    B1USYS
     C                     Z-ADDBASRYO    B1SRYX
      * BOX
     C                     Z-ADD0         WSYOS1  50
     C           B1USYS    IFNE 0
     C                     Z-ADDB1USYS    WSYOS1
     C                     ENDIF
     C           B1SYOS    IFNE 0
     C                     Z-ADDB1SYOS    WSYOS1
     C                     ENDIF
     C           WSYOS1    IFEQ 0
     C                     Z-ADDB1SRYO    WSYOS1
     C                     ENDIF
     C           B1SRYO    DIV  WSYOS1    B1BOX
     C                     MVR            REM     53
     C           REM       IFNE 0
     C                     ADD  1         B1BOX
     C                     ENDIF
      *
     C                     MOVELBASHN1    B1SHN1
     C                     MOVELBASHN2    B1SHN2
     C                     MOVELBASHN3    B1SHN3
     C                     Z-ADDBATANK    B1TANK
     C                     MOVELBACARD    B1CARD
     C                     Z-ADDBARCOD    B1RCOD
     C                     MOVELBAALFL    B1ALFL
     C                     MOVELBAEDIK    B1EDIK
     C                     Z-ADDBADEHZ    B1DEHZ
     C                     MOVELBASIRE    B1SIRE
     C                     MOVELBASIRK    B1SIRK
     C                     MOVELBASBAN    B1SBAN
     C                     Z-ADDBANOTM    B1NOTM
     C                     Z-ADDTODAY     B1CRHZ
     C                     Z-ADDNOW       B1CRTM
     C                     MOVEL#USER     B1CRME
     C                     MOVEL#WSID     B1CRWS
     C                     MOVEL#PGM      B1CRPG
      * GET PACKING LIST#
     C                     MOVEL'00000000'$RLHZ
     C                     MOVE *BLANK    $ODRN
     C                     MOVE *BLANK    $PICK#
     C                     CALL 'UTLR51'
     C                     PARM           P@NOHZ
     C                     PARM           $TOKU
     C                     PARM           P@NONY
     C                     PARM           K@NKOJ
     C                     PARM           K@NUKE
     C                     PARM           P@NOBN
     C                     PARM           $RLHZ   8
     C                     PARM           $ODRN  10
     C                     PARM           $PICK#  9
     C                     PARM           $RTN    1
     C**                   MOVEL$PICK#    B1SERL
      *
     C                     WRITEAB#PPB11
     C                     ENDSR
      *============================================================
      * DELETE PREVIOUS RECORDS
      *============================================================
     C           #DLT      BEGSR
      *
     C                     MOVELP@NONY    K@NONY
     C                     MOVEL'0'       K@NKOJ
     C                     MOVEL'00  '    K@NUKE
     C                     MOVELP@NOHZ    K@NOHZ
     C                     MOVELP@NOBN    K@NOBN
     C           K@PL1Q    SETLLAB#PLB1
      * LOOP AB#PLB1
     C           *IN90     DOWEQ*OFF
     C           K@PL1Q    READEAB#PLB1                  90
     C           *IN90     IFEQ *OFF
     C           B1SKJY    IFEQ 'D'
     C                     DELETAB#PPB11
     C                     ELSE
     C                     MOVE 'D'       B1SKJY
     C                     Z-ADDTODAY     B1SKHZ
     C                     Z-ADDNOW       B1SKTM
     C                     MOVEL#PGM      B1SKPG
     C                     MOVEL#USER     B1SKME
     C                     UPDATAB#PPB11
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *============================================================
      * GET LATEST QTY/BOX FROM MASTER  --> WSYOS
      *============================================================
     C           #SYOS     BEGSR
      *
     C                     Z-ADD0         WSYOS   60
     C                     MOVELBATOKU    $TOKU
     C                     MOVELBANONY    $NONY
     C                     MOVELBAMHIN    $MHIN
     C                     MOVELBANOHZ    $DATE
     C                     CALL 'UTLR09'
     C                     PARM           $TOKU   4
     C                     PARM           $NONY   4
     C                     PARM           $MHIN  20
     C                     PARM           $DATE   8
     C                     PARM           $SYOS   6
     C                     PARM           $RTN    1
     C           $RTN      IFNE '*'
     C                     MOVEL$SYOS     WSYOS
     C                     ENDIF
      *
     C           WSYOS     IFEQ 0
     C                     Z-ADDBAUSYS    WSYOS
     C                     ENDIF
      *
     C           WSYOS     IFEQ 0
     C                     Z-ADDBASRYO    WSYOS
     C                     ENDIF
      *
     C                     ENDSR
      *============================================================
      * INITIAL SET
      *============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@NONY  4
     C                     PARM           P@NOHZ  8
     C                     PARM           P@NOBN  2
     C                     PARM           P@ODRN 10
      *
     C                     MOVELP@NONY    P#NONY  40
     C                     MOVELP@NOHZ    P#NOHZ  80
     C                     MOVELP@NOBN    P#NOBN  20
      *
     C           K@PL1Q    KLIST
     C                     KFLD           K@NONY  40
     C                     KFLD           K@NKOJ  1
     C                     KFLD           K@NUKE  4
     C                     KFLD           K@NOHZ  80
     C                     KFLD           K@NOBN  20
      *
     C                     Z-ADDP#NONY    K@NONY
     C                     MOVEL'0'       K@NKOJ
     C                     MOVEL'00  '    K@NUKE
     C                     Z-ADDP#NOHZ    K@NOHZ
     C                     Z-ADDP#NOBN    K@NOBN
      *
     C                     TIME           D#TIME
     C                     MOVE 'Y'       FIRST   1
      *
     C                     ENDSR
      *****************************************************************
