      *
     C           *ENTRY    PLIST
     C                     PARM           PMXPL   30
      *
     C                     MOVE '===='    BA1     4
     C                     MOVE '===='    BA2     4
      *
     C           P#CMD     PLIST
     C                     PARM           #CHR    1
     C                     PARM           #L1     6
     C                     PARM           #L2     6
     C                     PARM           #L3     6
     C                     PARM           #L4     6
     C                     PARM           #L5     6
     C                     PARM           #L6     6
     C                     PARM           #L7     6
     C                     PARM           #L8     6
      *
     C           KEY1      KLIST
     C                     KFLD           KTOKU   40       CUSTOMER CODE
     C                     KFLD           KNONY   40       DELIVERY CODE
      *
     C           KEY2      KLIST
     C                     KFLD           KTOKU
     C                     KFLD           KNONY
     C                     KFLD           INUKE
     C                     KFLD           IMHN1
     C                     KFLD           IMHN2
     C                     KFLD           IMHN3
     C                     KFLD           IMHN4
      *
     C                     Z-ADD*ZERO     WW#BOX  90
      *
     C                     OPEN ABWWP38T
     C                     DO   *HIVAL
     C                     READ ABWWP38T                 99
     C           *IN99     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
     C                     ADD  FC#BOX    WW#BOX
     C                     ENDDO
     C                     CLOSEABWWP38T
      *
     C           WW#BOX    DIV  PMXPL     WT#BOX  50
     C                     MVR            @@MVR   50
     C           @@MVR     IFNE *ZERO
     C                     ADD  1         WT#BOX
     C                     ENDIF
      *
     C           *LIKE     DEFN ISBAN     W@SBAN
     C           *LIKE     DEFN IMHN      W@MHN
      *
     C                     MOVEL*BLANK    W@SBAN
     C                     MOVEL*BLANK    W@MHN
     C                     MOVEL*BLANK    W@LOC1  1
     C                     MOVEL*BLANK    W@LOC2  2
     C                     MOVEL*BLANK    W@LOC3  2
     C                     MOVEL*BLANK    W@LOC4  1
     C                     Z-ADD*ZERO     WHAKO
     C                     Z-ADD*ZERO     WD#BOX  50
     C                     MOVEL*OFF      W@1ST   1
      *
     C                     OPEN ABWWP38T
      *
     C                     DO   *HIVAL
      *
     C                     READ ABWWP38T                 99
     C           *IN99     IFEQ *ON
     C                     EXSR SUBR
     C                     EXSR DOCR
     C                     LEAVE
     C                     ENDIF
      *
     C           W@SBAN    IFEQ *BLANK
     C                     MOVELISBAN     W@SBAN
     C                     ENDIF
     C           W@MHN     IFEQ *BLANK
     C                     MOVELIMHN      W@MHN
     C                     ENDIF
      *
     C           W@1ST     IFEQ *OFF
     C                     MOVELFCLOC1    W@LOC1
     C                     MOVELFCLOC2    W@LOC2
     C                     MOVELFCLOC3    W@LOC3
     C                     MOVELFCLOC4    W@LOC4
     C                     MOVEL*ON       W@1ST
     C                     ENDIF
      *
     C           ISBAN     IFNE W@SBAN
     C           IMHN      ORNE W@MHN
     C                     EXSR SUBR
     C                     MOVELISBAN     W@SBAN
     C                     MOVELIMHN      W@MHN
     C                     MOVELFCLOC1    W@LOC1
     C                     MOVELFCLOC2    W@LOC2
     C                     MOVELFCLOC3    W@LOC3
     C                     MOVELFCLOC4    W@LOC4
     C                     ENDIF
      *
     C                     MOVE '-'       FLD1
     C                     MOVE '-'       FLD2
     C                     MOVE '-'       FLD3
     C                     MOVE '-'       FLD4
     C                     MOVE *BLANK    FLD5
     C                     SETOF                     11
     C                     SETOF                     60
     C                     SETOF                     12
     C                     SELEC
     C           ITOKU     WHEQ 5149
     C                     SETON                     11
     C                     MOVE IMHN1     WPART1
     C                     MOVE IMHN2     WPART2
     C                     MOVE IMHN3     WPART3
     C           ITOKU     WHEQ 0295
     C           ITOKU     OREQ 0296
     C                     SETON                     60
     C                     MOVE IMHN1     NPART1
     C                     MOVE IMHN2     NPART2
     C                     MOVE IMHN3     NPART3
     C                     MOVE NMHN1     PART1
     C                     MOVE NMHN2     PART2
     C                     MOVE NMHN3     PART3
     C                     MOVE NMHN4     PART4
     C                     MOVE PARTA     PART   17
     C           ITOKU     WHEQ 0390
     C                     SETON                     60
     C                     MOVE IMHN1     NPART1
     C                     MOVE IMHN2     NPART2
     C                     MOVE IMHN3     NPART3
     C                     MOVE NMHN1     PART5
     C                     MOVE NMHN2     PART6
     C                     MOVE NMHN3     PART7
     C                     MOVE NMHN4     PART8
     C                     MOVELPARTB     PART   17
     C           ITOKU     WHEQ 0291
     C                     SETON                     12
     C                     MOVE IMHN1     WPART4
     C                     MOVE IMHN2     WPART5
     C                     MOVE IMHN3     WPART6
     C                     OTHER
     C                     MOVE IMHN1     WMHN1
     C                     MOVE '-'       WMH1
     C                     MOVE IMHN2     WMHN2
     C                     MOVE '-'       WMH2
     C                     MOVE IMHN3     WMHN3
     C                     MOVE IMHN5     WMHN4
     C                     MOVE '-'       WMH5
     C                     MOVE IMHN6     WMHN6
     C                     MOVE IMHN7     WMHN7
     C                     MOVE '-'       WMH8
     C                     MOVE IMHN8     WMHN9
     C                     MOVE '-'       WMH10
     C                     MOVELIMHN9     WMHN11
     C                     ENDSL
      *
     C                     Z-ADDITOKU     KTOKU
     C                     Z-ADDINONY     KNONY            DELIVERY CODE
     C           KEY2      SETGTAB#PP85
     C           *IN90     DOUEQ*ON
     C           KEY2      REDPEAB#PP85                  90
     C           *IN90     IFEQ *OFF
     C           A5DATE    ANDLEINOHZ
     C                     MOVELA5SBAN    WSBAN     P
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C           *IN90     IFEQ *ON
     C                     MOVELISBAN     WSBAN     P
     C                     ENDIF
      *
      *---
     C                     ADD  FC#BOX    WHAKO
      *---
      *
     C                     MOVE YYYY      WNOYY
     C                     MOVE MM        WNOMM
     C                     MOVE DD        WNODD
     C                     MOVE '/'       WNO1
     C                     MOVE '/'       WNO2
      *
     C                     ENDDO
      *
     C                     CLOSEABWWP38T
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C******************************************************
     C           DOCR      BEGSR
     C******************************************************
      *
     C                     EXSR #LARG
     C                     WRITEAB#PR443
      *
     C                     ENDSR
     C******************************************************
     C           SUBR      BEGSR
     C******************************************************
      *
     C           *IN55     IFEQ '0'
     C                     MOVEL*BLANKS   SPART  17        PART#
     C                     MOVEL*BLANKS   SSBAN   4        KANBAN#
     C                     Z-ADD*DATE     PHZ8
     C                     TIME           WTIME
     C                     ADD  1         WD#BOX
     C                     EXSR PLTEDT
     C                     WRITEAB#PR441
     C                     ENDIF
      *
     C                     ADD  WHAKO     THAKO
     C                     Z-ADD*ZERO     SHAKO   50
      *
     C                     DO   *HIVAL
      *
     C           THAKO     IFLT PMXPL
     C           *IN70     IFEQ '1'
     C                     EXSR PLTEDT
     C                     WRITEAB#PR441
     C                     SETOF                     70
     C                     ENDIF
     C                     WRITEAB#PR442
     C                     Z-ADD0         WHAKO
     C                     LEAVE
     C                     ENDIF
      *
     C           THAKO     SUB  PMXPL     SHAKO
     C                     SUB  SHAKO     WHAKO
     C           *IN70     IFEQ *ON
     C                     EXSR PLTEDT
     C                     WRITEAB#PR441
     C                     SETOF                     70
     C                     ENDIF
     C                     WRITEAB#PR442
     C                     Z-ADDPMXPL     THAKO
     C                     EXSR #LARG
     C                     WRITEAB#PR443
     C                     SETON                     70
     C                     ADD  1         WD#BOX
     C                     EXSR PLTEDT
     C                     WRITEAB#PR441
     C                     SETOF                     70
      *
     C                     Z-ADDSHAKO     THAKO
     C                     Z-ADDSHAKO     WHAKO
      *
     C           WHAKO     IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C  N55                SETON                     55
      *
     C                     ENDSR
     C******************************************************
     C           PLTEDT    BEGSR
     C******************************************************
     C                     MOVELWD#BOX    W@A5    5
     C                     MOVEAW@A5      T1
     C                     Z-ADD*ZERO     X       20
     C                     Z-ADD*ZERO     Y       20
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           X         IFGT 5
     C                     LEAVE
     C                     ENDIF
     C           T1,X      IFEQ *ZERO
     C                     ITER
     C                     ENDIF
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C                     MOVELT1,X      T2,Y
     C                     ADD  1         X
     C           X         IFGT 5
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C           X         IFGT 5
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ADD  1         Y
     C                     MOVEL'/'       T2,Y
      *
     C                     MOVELWT#BOX    W@A5
     C                     MOVEAW@A5      T1
     C                     Z-ADD*ZERO     X       20
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           X         IFGT 5
     C                     LEAVE
     C                     ENDIF
     C           T1,X      IFEQ *ZERO
     C                     ITER
     C                     ENDIF
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C                     MOVELT1,X      T2,Y
     C                     ADD  1         X
     C           X         IFGT 5
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C           X         IFGT 5
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAT2        @#PLT
      *
     C                     ENDSR
     C******************************************************
     C           #LARG     BEGSR
     C******************************************************
      * --- PRINT LARGE CHR ---
     C                     MOVELWNOMM     WW,1
     C                     MOVE WNOMM     WW,2
     C                     MOVELWNODD     WW,3
     C                     MOVE WNODD     WW,4
      *
     C           1         DO   4         CC      10
      *
     C                     MOVE *BLANKS   #L1
     C                     MOVE *BLANKS   #L2
     C                     MOVE *BLANKS   #L3
     C                     MOVE *BLANKS   #L4
     C                     MOVE *BLANKS   #L5
     C                     MOVE *BLANKS   #L6
     C                     MOVE *BLANKS   #L7
     C                     MOVE *BLANKS   #L8
     C                     MOVE WW,CC     #CHR
     C                     CALL 'AB#R4P'  P#CMD
     C           CC        IFEQ 1
     C                     MOVE #L1       #11
     C                     MOVE #L2       #12
     C                     MOVE #L3       #13
     C                     MOVE #L4       #14
     C                     MOVE #L5       #15
     C                     MOVE #L6       #16
     C                     MOVE #L7       #17
     C                     MOVE #L8       #18
     C                     ENDIF
     C           CC        IFEQ 2
     C                     MOVE #L1       #21
     C                     MOVE #L2       #22
     C                     MOVE #L3       #23
     C                     MOVE #L4       #24
     C                     MOVE #L5       #25
     C                     MOVE #L6       #26
     C                     MOVE #L7       #27
     C                     MOVE #L8       #28
     C                     ENDIF
     C           CC        IFEQ 3
     C                     MOVE #L1       #31
     C                     MOVE #L2       #32
     C                     MOVE #L3       #33
     C                     MOVE #L4       #34
     C                     MOVE #L5       #35
     C                     MOVE #L6       #36
     C                     MOVE #L7       #37
     C                     MOVE #L8       #38
     C                     ENDIF
     C           CC        IFEQ 4
     C                     MOVE #L1       #41
     C                     MOVE #L2       #42
     C                     MOVE #L3       #43
     C                     MOVE #L4       #44
     C                     MOVE #L5       #45
     C                     MOVE #L6       #46
     C                     MOVE #L7       #47
     C                     MOVE #L8       #48
     C                     ENDIF
      *
     C                     ENDDO
