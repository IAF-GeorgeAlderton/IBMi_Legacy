     C                     PARM           P#HIN1
     C                     PARM           P#HIN2
     C                     PARM           P#HIN3
     C                     PARM           AFBOXS
     C                     END
     C                     END
      *
     C           AFBOXS    MULT P@SSYS    AFQTYS
      * STORE STOCK
     C                     EXSR #SSTK
     C           I2LOC     IFEQ OTK,@X
     C                     Z-ADDI2QTY     W@KANS
     C                     END
      *
     C           P@SSYS    MULT W@KANS    W@KANQ
      *
     C           A2BHB1    IFEQ 'U1105'
     C           A2BHB2    ANDEQ'B3040'
     C                     Z-ADD0         SAKA    40
     C                     END
      * IN MACHINE
     C                     Z-ADD0         P#RUNB
     C           OKO,@X    IFEQ 'BZ '
