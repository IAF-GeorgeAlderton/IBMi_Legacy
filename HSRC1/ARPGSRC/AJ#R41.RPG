      *工程切替マスター情報
     C           AAMRSB    PLIST
     C                     PARM           A2BHB1  5
     C                     PARM           A2BHB2  5
     C                     PARM           A2BHB3  2
     C                     PARM           OPNCLS  1
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     MOVE *BLANK    PBMN   60
     C                     MOVE *BLANK    PKBN   45
     C                     MOVE *BLANK    PTKR   90
     C                     MOVE *BLANK    PSHR   15
     C                     MOVE *BLANK    PKOT   45
     C                     MOVE *BLANK    PHBN  180
     C                     MOVE *BLANK    STATUS  1
      *
     C                     MOVEA*BLANK    OBM
     C                     MOVEA*BLANK    OKB
     C                     MOVEA*BLANK    OTK
     C                     MOVEA*BLANK    OSH
     C                     MOVEA*BLANK    OKO
     C                     MOVEA*BLANK    OHB
      *
     C           OPNFLG    IFEQ *BLANK
     C                     MOVE '1'       OPNFLG  1
     C                     MOVE '1'       OPNCLS  1
     C                     ELSE
     C                     MOVE '0'       OPNCLS
     C                     END
      *
     C                     CALL 'AAMRSB'  AAMRSB
      *
     C           STATUS    IFNE '1'
     C                     GOTO @END
     C                     END
      *
     C                     MOVEAPBMN      OBM
     C                     MOVEAPKBN      OKB
     C                     MOVEAPTKR      OTK
     C                     MOVEAPSHR      OSH
     C                     MOVEAPKOT      OKO
     C                     MOVEAPHBN      OHB
      *
     C           1         DO   15        @X      20
      *
     C           OKO,@X    IFEQ *BLANK
     C                     LEAVE
     C                     END
      *
     C           A2BHB1    IFEQ '90105'
     C           A2BHB2    ANDEQ'A0119'
     C           A2BHB3    ANDEQ'  '
     C                     Z-ADD0         SAKA    40
     C                     END
      *
     C                     MOVE OBM,@X    P#BMON  4
     C                     MOVE OKO,@X    P#KOTE  3
     C                     MOVE OKB,@X    P#KIBN  3
     C                     MOVE OSH,@X    P#KCD1  1
     C                     MOVE *DATE     P#DATE  8
     C                     MOVE OHB,@X    P#HINA
     C                     MOVE OTK,@X    K@BANA
     C                     MOVE OTK,@X    K#BANA
      *
     C           K#BANA    IFEQ '------'
     C           @X        DO   15        @Y      20
     C           OTK,@Y    IFEQ '------'
     C                     ITER
     C                     END
     C                     MOVE OTK,@Y    K#BANA
     C                     LEAVE
     C                     ENDDO
     C                     END
      * 1TQ040
     C           K@BAN1    IFEQ '1'
     C           K@BAN2    ANDEQ'TQ'
