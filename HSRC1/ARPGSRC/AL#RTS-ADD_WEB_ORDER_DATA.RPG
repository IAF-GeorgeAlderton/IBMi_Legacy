     H            Y.
     F** AL#R01  *******************************************
     F*  ADD WEB ORDER DATA                                *
     F*      ITS.        2015.05.18                        *
     F******************************************************
     FAL#WP01 IF  F     256            DISK
     FAL#PP21 IF  E           K        DISK
     FAL#PP01 O   E                    DISK                      A
      *
     IAL#WP01 AA  01
     I                                        1 256 IALL
     I                                        1   1 IRECT
     I                                        2   2 ICADT
     I                                        3  32 ISUPI
     I                                       33  37 ISUPC
     I                                       38  39 IDOCK
     I                                       40  43 IKNB#
     I                                       44  55 IMHN
     I                                       44  48 IMHN1
     I                                       49  53 IMHN2
     I                                       54  55 IMHN3
     I                                       56  65 ILIAD
     I                                       66  75 ISTAD
     I                                       76  80 IQTBO
     I                                       81 100 ISUPN
     I                                      101 109 IMART
     I                                      110 118 ISURT
     I                                      119 126 IULDA
     I                                      127 134 ISHID
     I                                      135 140 ISHIT
     I                                      141 152 IORD#
     I                                      153 156 IBOX#
     I                                      157 160 IBOXT
     I                                      161 165 INAMC
     I                                      166 196 INAD1
     I                                      197 198 IPALT
     I                                      199 210 INAD2
     I                                      211 255 IFILL
     I                                      256 256 ITERM
      *
     I            DS
     I                                        1   9 @9
     I                                        1   4 XCUST
     I                                        5   5 XFACT
     I                                        6   9 XSHTO
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
     C                     READ AL#WP01                  90
     C           *IN90     DOWEQ'0'
     C           IRECT     IFEQ '2'
     C                     EXSR #SB500
     C                     ENDIF
     C                     READ AL#WP01                  90
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
     CSR         #SB500    BEGSR
      *
     C                     CLEARAL#PP011
     C                     Z-ADDSDATE     CAKOHZ
     C                     Z-ADDSTIME     CAKOTI
     C                     MOVELW#USER    CAKOME
     C           INAMC     CHAINAL#PP211             26
     C           *IN26     IFEQ '0'
     C           C2SKJY    ANDEQ'D'
     C           C2SKHZ    ANDLESDATE
     C                     SETON                     26
     C                     ENDIF
     C           *IN26     IFEQ '0'
     C                     MOVELC2TOKU    CATOKU
     C                     MOVELC2NONY    CANONY
     C                     MOVELC2NKOJ    CANKOJ
     C                     ENDIF
     C                     MOVELIDOCK     CANUKE
     C                     Z-ADDSDATE     CAWBRD
     C                     Z-ADDSTIME     CAWBRT
     C                     MOVELIRECT     CARECT
     C                     MOVELICADT     CACADT
     C                     MOVELISUPI     CASUPI
     C                     MOVELISUPC     CASUPC
     C                     MOVELIDOCK     CADOCK
     C                     MOVELIKNB#     CAKNB#
     C                     MOVELIMHN      CAMHN
     C                     MOVELILIAD     CALIAD
     C                     MOVELISTAD     CASTAD
     C                     MOVELIQTBO     CAQTBO
     C                     MOVELISUPN     CASUPN
     C                     MOVELIMART     CAMART
     C                     MOVELISURT     CASURT
     C                     MOVELIULDA     CAULDA
     C                     MOVELISHID     CASHID
     C                     MOVELISHIT     CASHIT
     C                     MOVELIORD#     CAORD#
     C                     MOVELIBOX#     CABOX#
     C                     MOVELIBOXT     CABOXT
     C                     MOVELINAMC     CANAMC
     C                     MOVELINAD1     CANAD1
     C                     MOVELIPALT     CAPALT
     C                     MOVELINAD2     CANAD2
     C                     MOVELIFILL     CAFILL
     C                     MOVELITERM     CATERM
     C                     MOVELIALL      CAALL
     C                     WRITEAL#PP011
      *
     CSR         ESB400    ENDSR
