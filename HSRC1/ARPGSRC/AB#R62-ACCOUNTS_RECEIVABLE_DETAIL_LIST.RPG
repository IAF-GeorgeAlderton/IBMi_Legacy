     F*     IF FORD, ORDER# = 'F'+PACKING SLIP#
     F*   APR/17/02
     F*      LIST ONLY
     F*   FEB/09/04
     F******************************* AB#R62 **
     FAB#PW62 CF  E                    WORKSTN
     FAB#PL06 UF  E           K        DISK
     FAB#PL1D IF  E           K        DISK
     F**FGBPL01 IF  E           K        DISK
     FGADPL11 IF  E           K        DISK
     FABF9L01 IF  E           K        DISK
     FABF4P01 IF  E           K        DISK
     FAB#WP62 O   F     100            DISK
     FAB#WP621O   F     100            DISK
     E                    ER      1   7 60
     I            DS
     I                                        1   60INOYM
     I                                        1   40INOYY
     I                                        5   60INOMM
     I            DS
     I                                        1   80ISEHZ
     I                                        1   40ISEYY
     I                                        5   60ISEMM
     I                                        7   80ISEDD
     I            DS
     I                                        1   80B1SEHZ
     I                                        1   40B1SEYY
     I                                        5   60B1SEMM
     I                                        7   80B1SEDD
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
     I            DS
     I                                        1   4 B1NUKE
     I                                        1   1 B11
     I            DS
     I                                        1  16 B1NBAN
     I                                        1  10 B1NB1
     I                                       11  16 B1NB2
     I            DS
     I                                        1  20 BAMHIN
     I                                        1   5 BAMHN1
     I                                        6  10 BAMHN2
     I                                       11  15 BAMHN3
     I                                       16  20 BAMHN4
     I            DS
     I                                        1   80BANOHZ
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I            DS
     I                                        1   80BASKHZ
     I                                        1   40BASKYY
     I                                        5   60BASKMM
     I                                        7   80BASKDD
     I            DS
     I                                        1  20 $MHIN
     I                                        1   5 $MHN1
     I                                        6  10 $MHN2
     I                                       11  15 $MHN3
     I                                       16  20 $MHN4
     I            DS
     I I            'F'                       1   7 FNO
     I                                        1   1 FFFF
     I                                        2   7 FPS#
      *
     C           KEY1      KLIST
     C                     KFLD           INOYY
     C                     KFLD           INOMM
      *
     C           KEY2      KLIST
     C                     KFLD           WTOKU
     C                     KFLD           INOYY
     C                     KFLD           INOMM
     C           KEY4      KLIST
     C                     KFLD           B1NONY
     C                     KFLD           B1NUKE
     C                     KFLD           B1NOHZ
     C                     KFLD           PNOBI   20
      *
     C           *ENTRY    PLIST
     C                     PARM           PNONY   4
     C                     PARM           PNOYM   6
     C**********           PARM           POPTN   1
      *
     C                     Z-ADD0         INOYM
     C                     Z-ADD0         ISEHZ
      *
     C           STP1      TAG
     C                     EXFMTAB#PW621
     C                     SETOF                     010203
     C                     SETOF                     9904
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           D@CUST    IFEQ *BLANK
     C                     SETON                     0499
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     ELSE
     C                     MOVE D@CUST    WTOKU   40
     C                     END
      *
     C*          INONY     IFEQ *BLANK
     C*                    SETON                     0199
     C*                    MOVE ER,1      MSG
     C*                    GOTO STP1
     C*                    END
     C           INONY     IFNE *BLANK
     C                     MOVE INONY     WNONY   40
     C                     ENDIF
      *
     C                     SETOF                     10
    .C****       WNONY     IFNE 9999
     C*******    WNONY     CHAINFGBPL011             10
    .C           WTOKU     IFNE 9999
     C           WTOKU     CHAINGADPL11              10
     C*          *IN10     IFEQ '0'
     C*          B2SKJY    ANDEQ'D'
     C*          B2SKHZ    ANDLE*DATE
     C**                   SETON                     10
     C******8              END
     C           *IN10     IFEQ '1'
     C                     SETON                     0199
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
    .C                     ENDIF
      *
     C           INOYM     IFEQ 0
     C                     SETON                     0299
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     END
      *
     C           INOYY     IFGE 1997
     C           INOMM     ANDGE01
     C           INOMM     ANDLE12
     C                     ELSE
     C                     SETON                     0299
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     END
      *
     C           ISEHZ     IFEQ 0
     C                     SETON                     0399
     C                     MOVE ER,5      MSG
     C                     GOTO STP1
     C                     END
      *
     C           ISEYY     IFGE 1997
     C           ISEMM     ANDGE01
     C           ISEMM     ANDLE12
     C           ISEDD     ANDGE01
     C           ISEDD     ANDLE31
     C                     ELSE
     C                     SETON                     0399
     C                     MOVE ER,6      MSG
     C                     GOTO STP1
     C                     END
      *
     C*          OPTN      IFNE '1'
    .C*          WNONY     ANDEQ9999
     C*                    SETON                     0199
     C*                    MOVE ER,7      MSG
     C*                    GOTO STP1
     C*                    ENDIF
      *
     C*          OPTN      IFNE *BLANK
     C*          OPTN      ANDNE'1'
     C*          OPTN      ANDNE'2'
     C*                    SETON                     0499
     C*                    GOTO STP1
     C*                    END
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP1
     C                     END
      *
     C                     SETON                     U1
     C                     MOVE D@CUST    PNONY
     C********             MOVE INONY     PNONY
     C                     MOVE INOYM     PNOYM
     C*                    MOVE OPTN      POPTN
     C                     Z-ADD*ZERO     @@TOKU  40
      *
     C           KEY1      SETLLAB#PL061
B1   C                     DO   *HIVAL
     C                     SETOF                     30
     C           KEY1      READEAB#PL061                 30
 B2  C           *IN30     IFEQ '0'
  B3 C           B1SKJY    IFEQ 'D'
     C           B1SKHZ    ANDLE*DATE
  X3 C                     ELSE
      *
  B4 C*******    B1NONY    IFEQ WNONY
  B4 C           B1TOKU    IFEQ WTOKU
   4.C           WTOKU     OREQ 9999
   4.C*****      WNONY     OREQ 9999
      *
     C           INONY     IFNE *BLANK
     C           B1NONY    ANDNEWNONY
     C                     ITER
     C                     ENDIF
      *
     C                     SETON                     U2
      *
     C*******    B1NONY    IFNE @@NONY
     C           B1TOKU    IFNE @@TOKU
      * CHECK FORD OR NOT
     C                     MOVE *BLANK    @@F     1
     C                     MOVE B1NONY    @NON4   4
     C           @NON4     CHAINABF9L01              90
     C           *IN90     IFEQ *OFF
     C                     MOVE '1'       @@F
     C                     ELSE
     C                     MOVE *BLANK    @@F
     C                     ENDIF
     C                     ENDIF
      *
     C**********           Z-ADDB1NONY    @@NONY
     C                     Z-ADDB1TOKU    @@TOKU
      *
     C                     MOVE B1TOKU    @TOKU   4
     C                     MOVE B1NONY    @NONY   4
     C                     MOVE B1NKOJ    @NKOJ   1
     C                     MOVE B1NUKE    @NUKE   4
      *
     C                     MOVE B1MHIN    @MHIN  20
     C                     MOVE B1NOHZ    @HIZK   8
     C                     Z-ADD0         @TANK  105
     C                     MOVE *BLANK    @CHEK   1
      *
     C                     CALL 'FBCR10'
     C                     PARM           @TOKU
     C                     PARM           @NONY
     C                     PARM           @NKOJ
     C                     PARM           @NUKE
     C                     PARM           @MHIN
     C                     PARM           @HIZK
     C                     PARM           @TANK
     C                     PARM           @CHEK
      *
  B5 C           @TANK     IFEQ 0
     C                     SETON                     U3
  E5 C                     END
      *
     C                     Z-ADDISEHZ     B1SEHZ
     C                     Z-ADD@TANK     B1TANK
     C                     UPDATAB#PL061
      *
     C                     Z-ADDB1TOKU    #TOKU   40
     C                     Z-ADDB1NONY    #NONY   40
     C                     MOVE B1NKOJ    #NKOJ   1
     C           B1NONY    IFEQ 0541
     C                     MOVELB11       #NUKE     P
     C                     ELSE
     C                     MOVE B1NUKE    #NUKE   4
     C                     ENDIF
     C                     MOVE B1SBAN    #SBAN   4
     C                     MOVE B1MHIN    #MHIN  20
     C                     MOVE B1ODR1    #ODER  10
     C                     Z-ADDB1NOBI    #BIN    20
      *
     C*****      WNONY     IFEQ 0873
     C******     WNONY     OREQ 0870
     C*******    B1NONY    IFEQ 0873
     C*******    B1NONY    OREQ 0870
     C           B1TOKU    IFEQ 0873
     C                     MOVELB1NBAN    #ODR1
     C                     ELSE
     C                     MOVE B1ODR1    #ODR1  10
     C                     END
      *
     C           @@F       IFEQ '1'
     C           B1NOBI    IFEQ 0
     C                     Z-ADD01        PNOBI
     C                     ELSE
     C                     Z-ADDB1NOBI    PNOBI
     C                     END
     C           KEY4      CHAINABF4P01              90
     C           *IN90     IFEQ '0'
     C                     MOVE *BLANK    #ODR1
     C                     MOVELYBPS#     FPS#
     C                     MOVELFNO       #ODR1
     C                     ENDIF
     C                     ENDIF
      * HONDA
     C           B1NONY    IFEQ 0295
     C           B1NONY    OREQ 2020
     C           B1NBAN    IFNE *BLANK
     C                     MOVELB1NB1     #ODR1
     C                     MOVELB1NB2     #ODER     P
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADDB1NOHZ    #NOHZ   80
     C                     Z-ADDB1SYUY    #SYUY   50
     C                     Z-ADDB1SRYO    #SRYO   70
     C                     Z-ADDB1TANK    #TANK   94
     C                     Z-ADDB1TANK    XTANK  105
     C                     MOVE B1CARD    #CARD   4
      *
. B5 C           #NONY     IFEQ 3347
. B5 C           #NONY     OREQ 3348
.    C           #NONY     OREQ 0541
.    C           #NONY     OREQ 3503
.    C           #NONY     OREQ 0437
.    C           #NONY     OREQ 0506
.    C                     MOVE ' '       #ETC    1
. X5 C                     ELSE
.    C                     MOVE '1'       #ETC
. E5 C                     ENDIF
      *
     C                     EXCPTDT
      *
  B5 C           B1NONY    IFEQ 3347
  B5 C           B1NONY    OREQ 3348
     C           B1NONY    OREQ 3931
     C           B1NONY    OREQ 3932
     C           B1NONY    OREQ 3804
     C           B1NONY    OREQ 3805
     C           B1NONY    OREQ 0437
     C           B1NONY    OREQ 0506
      *
  B6 C           B1NONY    IFEQ 3347
  B6 C           B1NONY    OREQ 3348
     C                     MOVE '1406'    #SIRE   4
     C                     MOVE '0'       #SIRK   1
  E6 C                     END
      *
  B6 C           B1NONY    IFEQ 3931
  B6 C           B1NONY    OREQ 3932
     C                     MOVE '1406'    #SIRE
     C                     MOVE '0'       #SIRK
  E6 C                     END
      *
  B6 C           B1NONY    IFEQ 3804
  B6 C           B1NONY    OREQ 3805
     C                     MOVE '1406'    #SIRE
     C                     MOVE '0'       #SIRK
  E6 C                     END
      *
  B6 C           B1NONY    IFEQ 0506
  B6 C           B1NONY    OREQ 0437
     C                     MOVE 'C742'    #SIRE
     C                     MOVE '1'       #SIRK
  E6 C                     END
      *
     C                     Z-ADDB1NOHZ    WNOHZ   60
     C                     MOVELB1NUKE    WNUKE   2
     C                     Z-ADDB1SRYO    WSRYO  100
     C                     MOVELB1MHIN    WMHIN  30
     C                     Z-ADDB1TANK    WTANK  134
     C                     MOVE B1CARD    WCARD   4
     C                     EXCPTDT1
  E5 C                     END
      *
  E4 C                     END
  E3 C                     END
 E2  C                     END
E1   C  N30                END
      *
B1  .C*******    WNONY     IFEQ 9999
B1  .C           WTOKU     IFEQ 9999
    .C                     Z-ADD3411      WTOKU
    .C                     ENDIF
      *
B1   C           WTOKU     IFEQ 3411
      *
     C           KEY2      SETLLAB#PL1D
 B2  C                     DO   *HIVAL
     C                     SETOF                     30
     C           KEY2      READEAB#PL1D                  30
  B3 C           *IN30     IFEQ '0'
  B4 C           BASKJY    IFEQ 'D'
     C**JW       BASKHZ    ANDLE*DATE
  X4 C                     ELSE
      *
  B5 C           BACARD    IFEQ 'MA02'
      *
     C                     MOVE BATOKU    PTOKU   4
     C                     MOVE BANONY    PNONY   4
     C                     MOVE BANKOJ    PNKOJ   1
     C                     MOVE BANUKE    PNUKE   4
     C                     MOVE BAMHIN    $MHIN
     C                     MOVE *BLANK    $SHIN  12
     C                     MOVE *BLANK    $FLG    1
      *
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           $MHIN
     C                     PARM           $SHIN  12
     C                     PARM           $FLG    1
      *
  B6 C           $FLG      IFEQ '*'
     C                     MOVE *BLANK    $MHN3
     C                     MOVE *BLANK    $MHN4
  E6 C                     END
      *
     C                     MOVE BATOKU    @TOKU
     C                     MOVE BANONY    @NONY
     C                     MOVE BANKOJ    @NKOJ
     C                     MOVE BANUKE    @NUKE
     C                     MOVE $MHIN     @MHIN
     C                     MOVE BANOHZ    @HIZK
     C                     Z-ADD0         @TANK
     C                     MOVE *BLANK    @CHEK
      *
     C                     CALL 'FBCR10'
     C                     PARM           @TOKU
     C                     PARM           @NONY
     C                     PARM           @NKOJ
     C                     PARM           @NUKE
     C                     PARM           @MHIN
     C                     PARM           @HIZK
     C                     PARM           @TANK
     C                     PARM           @CHEK
      *
  B6 C           @TANK     IFEQ 0
     C                     SETON                     U3
  E6 C                     END
      *
     C                     Z-ADDBATOKU    #TOKU
     C                     Z-ADDBANONY    #NONY
     C                     MOVE BANKOJ    #NKOJ
     C                     MOVE BANUKE    #NUKE
     C                     MOVE BASBAN    #SBAN
     C                     MOVE BAMHIN    #MHIN
     C                     MOVE BAODRN    #ODR1
     C                     Z-ADDBANOHZ    #NOHZ
     C                     Z-ADDBASYOS    #SYUY
     C                     Z-ADDBASRYO    #SRYO
     C                     Z-ADD@TANK     #TANK
     C                     Z-ADD@TANK     XTANK
     C                     MOVE BACARD    #CARD
.    C                     MOVE ' '       #ETC    1
      *
     C                     EXCPTDT
      *
     C                     MOVE BASIRE    #SIRE
     C                     MOVE BASIRK    #SIRK
     C                     Z-ADDBANOHZ    WNOHZ
     C                     MOVELBANUKE    WNUKE
     C                     Z-ADDBASRYO    WSRYO
     C                     MOVELBAMHIN    WMHIN
     C                     Z-ADD@TANK     WTANK
     C                     MOVE BACARD    WCARD
     C                     EXCPTDT1
      *
  E5 C                     END
  E4 C                     END
  E3 C                     END
 E2  C  N30                END
      *
E1   C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *
     OAB#WP62 E                DT
     O                         #TOKU      4
     O                         #NONY      8
     O                         #NKOJ      9
     O                         #NUKE     13
     O                         #MHIN     33
     O                         #ODR1     43
     O                         #NOHZ     51
     O                         #SYUY     56
     O                         #SRYO     63
     O                         #TANK     72
     O                         #CARD     76
     O                         #ETC      77
     O                         XTANK     87
     O                         #ODER     97
     O                         #BIN      99
     OAB#WP621E                DT1
     O                         WNOHZ      6
     O                         #ODR1     16
     O                         #SIRE     20
     O                         #SIRK     21
     O                         WNUKE     23
     O                         #SBAN     27
     O                         WSRYO     37
     O                         WTANK     50
     O                         WMHIN     80
     O                         WCARD     84
     O                         #NONY     88
     O                         #ETC      89
      *
** ER
E-01 INPUT CUSOTMER CODE.
E-02 NO DATA IN SHIPMENT M/F
E-03 INPUT A/R LIST MONTH DATE
E-04 A/R LIST MONTH DATE IS NOT RIGHT
E-05 INPUT USER PAYMENT DATE
E-06 USER PAYMENT DATE IS NOT RIGHT
E-07 PLS SPECIFY THE DELIVERY CODE UNDER THIS OPTION.
