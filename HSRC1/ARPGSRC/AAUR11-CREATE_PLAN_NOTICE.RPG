     C                     ADD  1         B
     C                     MOVE ZKOT,A    NKOT,B
     C                     Z-ADDZKBM,A    NKBM,B
     C                     MOVE ZHIN,A    NHIN,B
     C                     MOVE ZTKR,A    NTKR,B
     C                     Z-ADDZUKH,A    NUKH,B
