     H            Y.
     F** ABCR06 ********************************
     F* .. A CALCULATION OF TUNNEL KANBAN SHEETS.. *
     F* I-HASADA                86.09.18       *
     F******************************** ABCR06 **
     C           *ENTRY    PLIST
     C                     PARM           ASURI   2
     C                     PARM           AKTSU   90
     C                     PARM           ASSYS   50
     C                     PARM           AKEIS   42
     C                     PARM           AREAD   42
     C                     PARM           ABARA   20
     C                     PARM           ACBKO   20
     C                     PARM           ALOTO   30
     C                     PARM           AMAXH   30
     C                     PARM           AKAIS   40
      *
     C           ASURI     IFEQ 'LR'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C*----------------------------------------------*
     C*     ...トンネルかんばん枚数の計算式...     *
     C*----------------------------------------------*
     C           AKTSU     DIV  ASSYS     WHIAK   90
     C                     MVR            WAMR1   90
     C           WAMR1     IFNE 0
     C                     ADD  1         WHIAK
     C                     END
      *
     C           WHIAK     IFLE 5
     C                     Z-ADD2         WSRYO   10
     C                     ELSE
     C                     Z-ADD0         WSRYO
     C                     END
      *
     C           AKTSU     MULT AKEIS     WTOKE   90H
     C           WTOKE     MULT AREAD     WKOLT   90
      *
     C           WKOLT     DIV  ASSYS     WKOSY   90
     C                     MVR            WAMR1   90
     C           WAMR1     IFNE 0
     C                     ADD  1         WKOSY
     C                     END
      *
     C           WKOSY     ADD  WSRYO     WTOT1   90
      *
     C           ABARA     IFEQ 0
     C                     Z-ADD1         WBARA   20
     C                     ELSE
     C                     Z-ADDABARA     WBARA
     C                     END
      *
     C           ACBKO     IFEQ 0
     C                     Z-ADD1         WCBKO   20
     C                     ELSE
     C                     Z-ADDACBKO     WCBKO
     C                     END
      *
     C           WBARA     SUB  1         WBAAD   60
     C                     ADD  WBAAD     WTOT1
      *
     C           ALOTO     IFEQ 0
     C                     Z-ADD1         WLOTO   20
     C                     ELSE
     C                     Z-ADDALOTO     WLOTO
     C                     END
      *
     C           WLOTO     MULT WCBKO     WTOT2   40
     C                     SUB  1         WTOT2
     C                     ADD  WTOT2     WTOT1
     C           WTOT1     ADD  AMAXH     WTOT1
     C                     Z-ADDWTOT1     AKAIS
      *
     C                     RETRN
