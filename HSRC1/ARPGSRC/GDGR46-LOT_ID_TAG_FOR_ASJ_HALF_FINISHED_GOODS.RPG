     O                                   41 'FOR ASJ HALF'
     O                                   56 ' FINISHED PARTS'
     O        E   04           @HED
     O                                   17 'SELECT INVOICE#:'
     O                         D@INV#    23
     O        E   05           @HED
     O                                    6 'LOC'
     O                                   15 'PART#'
     O                                   27 'LOT'
     O                                   36 '#OF BOX'
     O                                   47 '#OF KAN'
     O                                   57 '#OF TAG'
     O                                   65 'B.BOX'
     O                                   76 'INVOICE#'
     O        E 1              @DTL
