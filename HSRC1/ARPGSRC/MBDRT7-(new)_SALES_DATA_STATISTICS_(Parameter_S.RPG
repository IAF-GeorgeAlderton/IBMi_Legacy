     H            Y.                                    1
     F** MBDRT7 ********************************************
     F* SALES DATA STATISTICS                              *
     F*----------------------------------                  *
     F* JW2  2019.12.10 ADD 5 YEARS REPORT                 *
     F******************************************************
     FMBDPWT7 CF  E                    WORKSTN
      *-----------------------------------------------------
     E                    ERR     1  10 65
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
     C           KEYB21    KLIST
     C                     KFLD           #KCODE  40
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     C                     EXSR $SB100
     C           *IN01     DOWEQ'0'
     C                     EXSR $SB200
     C                     END
     C                     EXSR $SB300
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     C           $SB100    BEGSR
     C                     MOVE *BLANK    DSPSW1  1
      *
     C                     MOVE '1'       DSPSW1
     C           $S100E    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     C           $SB200    BEGSR
      *
     C           *IN01     DOWEQ'0'
     C           DSPSW1    ANDEQ'1'
     C                     EXSR $SB210
     C                     END
      *
     C           $S200E    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     C           $SB210    BEGSR
      *
     C                     EXFMTDSP01
     C                     SETOF                     99
     C                     SETOF                     313233
     C                     SETOF                     343536
     C                     SETOF                     3738
JW1  C                     SETOF                     39
     C                     MOVE *BLANK    MSG
      *----------------*
      * F01: EXIT
      *----------------*
     C           *INKA     IFEQ *ON
     C                     GOTO $S210E
     C                     ENDIF
      *------------------------------*
      * F10: CUSTOMER GROUP MAINT
      *------------------------------*
     C           *INKJ     IFEQ *ON
     C                     CALL 'EDIC53'
     C                     GOTO $S210E
     C                     ENDIF
      *
     C           @TOKU     IFEQ 0
     C                     SETON                     9931
     C                     SETOF                     05
     C                     MOVELERR,05    MSG
     C                     GOTO $S210E
     C                     ENDIF
      *
     C           @YYYY     IFEQ 0
     C                     SETON                     9935
     C                     SETOF                     05
     C                     MOVELERR,01    MSG
     C                     GOTO $S210E
     C                     END
      *
     C           @MMMM     IFGE 1
     C           @MMMM     ANDLE12
     C                     ELSE
     C                     SETON                     9936
     C                     SETOF                     05
     C                     MOVELERR,02    MSG
     C                     GOTO $S210E
     C                     END
     C*
     C           @SIZI     IFNE '1'
     C           @SIZI     ANDNE'2'
     C           @SIZI     ANDNE'3'
JW2  C           @SIZI     ANDNE'4'
     C                     SETON                     9937
     C                     SETOF                     05
     C                     MOVELERR,06    MSG
     C                     GOTO $S210E
     C                     END
     C*
JW1  C           @TYPE     IFNE '1'
JW1  C           @TYPE     ANDNE'2'
JW1  C                     SETON                     9939
JW1  C                     SETOF                     05
JW1  C                     MOVELERR,07    MSG
JW1  C                     GOTO $S210E
JW1  C                     END
      *
     C*
JW   C           *IN05     IFEQ *OFF
.    C                     MOVELERR,08    MSG
.    C                     GOTO $S210E
JW   C                     END
      *----------------*
      * F05: RUN
      *----------------*
     C           *IN05     IFEQ '1'
     C                     EXSR $SB500
      **
     C           P@STS     IFNE ' '
     C                     SETON                     99
     C                     SETON                     313233
     C                     SETON                     343536
     C                     SETON                     37
JW1  C                     SETON                     39
     C                     SETON                     99
     C                     MOVELERR,04    MSG
     C                     GOTO $S210E
     C                     END
      **
     C                     SETON                     01
      **
     C                     END
      *
     C           $S210E    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     C           $SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     C           $S300E    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     C           $SB500    BEGSR
      *
     C                     MOVEL@TOKU     P@TOKU  4
     C                     MOVEL@NONY     P@NONY  4
     C                     MOVEL@NKOJ     P@NKOJ  1
     C                     MOVEL@NUKE     P@NUKE  4
     C                     MOVEL@YYYY     P@YYYY  4
     C                     MOVEL@MMMM     P@MMMM  2
     C                     MOVEL@SIZI     P@SIZI  1
     C                     MOVEL@TYPE     P@TYPE  1
     C                     MOVEL*BLANK    P@STS   1
      * REPORT FOR 6/12/24 MONTHS
JW2  C                     SELEC
 |   C           @SIZI     WHEQ '1'
 |   C           @SIZI     OREQ '2'
JW2  C           @SIZI     OREQ '3'
     C                     CALL 'MBDRT8'
     C                     PARM           P@TOKU
     C                     PARM           P@NONY
     C                     PARM           P@NKOJ
     C                     PARM           P@NUKE
     C                     PARM           P@YYYY
     C                     PARM           P@MMMM
     C                     PARM           P@SIZI
     C                     PARM           P@TYPE
     C                     PARM           P@STS
      * REPORT FOR 5 YEARS
JW2  C           @SIZI     WHEQ '4'
 |   C                     CALL 'MBDRT9'
 |   C                     PARM           P@TOKU
 |   C                     PARM           P@NONY
 |   C                     PARM           P@NKOJ
 |   C                     PARM           P@NUKE
 |   C                     PARM           P@YYYY
 |   C                     PARM           P@MMMM
 |   C                     PARM           P@SIZI
 |   C                     PARM           P@TYPE
 |   C                     PARM           P@STS
JW2  C                     ENDSL
      *
     C           $S500E    ENDSR
