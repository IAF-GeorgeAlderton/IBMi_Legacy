     H            Y.
     F*** FCER60 *****************************
     F* SERVICE PARTS M/F MAINTENANCE      *
     F*                                      *
     F* TCHK1 04/19/07 CHG any               *
     F***************************** FCER60 ***
     FFCEPW60 CF  E                    WORKSTN
     FFCEPL30 UF  E           K        DISK                      A
     FFCEPL31 IF  E           K        DISK
     F            FCEPP301                          KRENAMEFCEL301
     FAGDPL12 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     E                    TBL1    1   3  1   TBL2    7
     E                    ER      1  20 60
     I            DS
     I                                        1   80@DATE
     I                                        1   40@YY
     I                                        5   60@MM
     I                                        7   80@DD
     I            DS
     I                                        1  14 @NHIN
     I                                        1   5 @NHN1
     I                                        6   6 @1
     I                                        7  11 @NHN2
     I                                       12  12 @2
     I                                       13  14 @NHN3
     I            DS
     I                                        1   6 F3LOCN
     I                                        1   1 F3STRK
     I                                        2   3 F3STRT
     I                                        4   5 F3STRR
     I                                        6   6 F3STRD
     I            DS
     I                                        1   6 F3LOCO
     I                                        1   1 F3KTRK
     I                                        2   3 F3KTRT
     I                                        4   5 F3KTRR
     I                                        6   6 F3KTRD
     I            DS
     I                                        1   6 D@LOC
     I                                        1   1 @BAN1
     I                                        2   3 @BAN2
     I                                        4   5 @BAN3
     I                                        6   6 @BAN4
     I            DS
     I                                        1   2 @@02
     I                                        1   1 @@1
     I                                        2   2 @@2
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *****************************************************
      *  MAIN ROUTINE
      *****************************************************
     C           @@ID      DOUEQ'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C           @@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *****************************************************
      *  INITIALIZE
      *****************************************************
     C           *INZSR    BEGSR
      *
     C           K#FCE     KLIST
     C                     KFLD           @NHN1
     C                     KFLD           @NHN2
     C                     KFLD           @NHN3
     C           K#AGD     KLIST
     C                     KFLD           @YY
     C                     KFLD           @MM
     C                     KFLD           @DD
     C           K#FCL     KLIST
     C                     KFLD           @BAN1
     C                     KFLD           @BAN2
     C                     KFLD           @BAN3
     C                     KFLD           @BAN4
      *
     C                     MOVE '01'      @@ID    2
      *
     C                     ENDSR
     C*****************************************************
      *  1ST SCREEN
     C*****************************************************
     C           #SCRN1    BEGSR
      *
     C                     EXFMTDSP01
      *
     C           *INKA     IFEQ *ON
     C                     MOVE '99'      @@ID
     C                     ELSE
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     MOVE '02'      @@ID
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
     C*****************************************************
      *  CHECK
     C*****************************************************
     C           #CHK1     BEGSR
      *
     C                     MOVEA'0000'    *IN,01
TCHK1C                     MOVEA'00'      *IN,11
TCHK1C                     MOVEL*ON       *IN91
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    MSG
     C*
     C                     MOVE *BLANK    @KONM
     C                     Z-ADD1         A       10
     C           @KOSN     LOKUPTBL1,A                   20
     C           *IN20     IFEQ '0'
     C                     SETON                     0199
     C                     MOVELER,01     MSG
     C                     END
     C                     MOVELTBL2,A    @KONM
      *
     C           @NHN1     IFEQ *BLANK
     C           @NHN2     ANDEQ*BLANK
     C           @NHN3     ANDEQ*BLANK
     C                     SETON                     0299
     C                     MOVELER,02     MSG
     C                     ELSE
TCHK1C           K#FCE     CHAINFCEPL01              91
TCHK1C           @KOSN     IFEQ '2'
TCHK1C   91                MOVEL*ON       *IN11
TCHK1C                     END
TCHK1C*          *IN90     IFEQ *ON
TCHK1C*                    SETON                     0299
TCHK1C*                    MOVELER,08     MSG
TCHK1C*                    ENDIF
     C                     ENDIF
      *
     C           @NHN2     IFNE *BLANK
     C                     MOVE '-'       @1
     C                     ELSE
     C                     MOVE *BLANK    @1
     C                     END
     C           @NHN3     IFNE *BLANK
     C                     MOVE '-'       @2
     C                     ELSE
     C                     MOVE *BLANK    @2
     C                     END
      *
     C           K#FCE     CHAINFCEPL30             N90
     C                     SELEC
     C           @KOSN     WHEQ '2'
     C           *IN90     IFEQ *ON
     C           F3GSKD    OREQ 'D'
     C           F3GSDT    ANDLE*DATE
     C                     ELSE
     C                     MOVEA'11'      *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELER,03     MSG
     C                     ENDIF
     C*
     C           @KOSN     WHEQ '1'
     C           *IN90     IFEQ '1'
     C                     MOVEA'11'      *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELER,04     MSG
     C                     ELSE
     C           F3GSKD    IFEQ 'D'
     C           F3GSDT    ANDLE*DATE
     C                     MOVEA'11'      *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELER,05     MSG
     C                     END
     C                     END
      *
     C           @KOSN     WHEQ '0'
     C           *IN90     IFEQ '1'
     C                     MOVEA'11'      *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELER,06     MSG
     C                     ELSE
     C           F3GSKD    IFEQ 'D'
     C           F3GSDT    ANDLE*DATE
     C                     MOVEA'11'      *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELER,07     MSG
     C                     END
     C                     END
     C                     ENDSL
     C*
     C                     MOVE *BLANK    D@NUSE
     C           *IN99     IFEQ *OFF
     C           *IN90     IFEQ *ON
     C           *IN90     OREQ *OFF
     C           F3GSKD    ANDEQ'D'
TCHK1C           *IN91     IFEQ *OFF
TCHK1C                     Z-ADDA2SSYS    @SYOS
TCHK1C                     MOVELA2TEHI    D@TEHI
TCHK1C                     MOVELA2DMEI    D@DMEI
TCHK1C                     MOVELA2SMEI    D@SMEI
TCHK1C                     MOVELA2ZETI    D@ZETI  4
TCHK1C                     Z-ADDA2KASI    D@KASI
TCHK1C                     ELSE
TCHK1C                     Z-ADD*ZERO     @SYOS
TCHK1C                     MOVEL*BLANK    D@TEHI
TCHK1C                     MOVEL*BLANK    D@DMEI
TCHK1C                     MOVEL*BLANK    D@SMEI
TCHK1C                     MOVEL*BLANK    D@ZETI  4
TCHK1C                     Z-ADD*ZERO     D@KASI
TCHK1C                     END
     C                     Z-ADD*DATE     @DAT1
     C                     Z-ADD*DATE     @DAT2
     C                     MOVE *BLANK    D@LOC
     C*          A2GSKD    IFEQ *BLANK
     C*                    MOVE A2STRK    D@LOC1
     C*                    MOVE A2STRT    D@LOC2
     C*                    MOVE A2STRR    D@LOC3
     C*                    MOVE A2STRD    D@LOC4
     C*                    ELSE
     C*                    MOVE *ALL'*'   D@LOC1
     C*                    MOVE *ALL'*'   D@LOC2
     C*                    MOVE *ALL'*'   D@LOC3
     C*                    MOVE *ALL'*'   D@LOC4
     C*                    MOVELER,18     D@NUSE
     C*                    ENDIF
     C                     ELSE
     C                     MOVE F3SMEI    D@SMEI 15
     C                     MOVE F3ZETI    D@ZETI  4
     C                     Z-ADDF3SSYS    @SYOS
     C                     Z-ADDF3SYMD    @DAT1
     C                     Z-ADDF3TYMD    @DAT2
     C                     MOVE F3LOCN    D@LOC
     C                     MOVE F3TEHI    D@TEHI
     C                     MOVE F3DMEI    D@DMEI
     C                     Z-ADDF3KASI    D@KASI
     C*                    MOVE F3PTRK    D@LOC1
     C*                    MOVE F3PTRT    D@LOC2
     C*                    MOVE F3PTRR    D@LOC3
     C*                    MOVE F3PTRD    D@LOC4
     C                     ENDIF
     C                     ENDIF
      *
     C*          D@LOC1    IFEQ *BLANK
     C*          D@LOC2    ANDEQ*BLANK
     C*          D@LOC3    ANDEQ*BLANK
     C*          D@LOC4    ANDEQ*BLANK
TCHK1C           *IN99     IFEQ *OFF
TCHK1C           *IN91     ANDEQ*OFF
TCHK1C           A2GSKD    ANDEQ*BLANK
     C                     MOVE A2STRK    D@LOC1
     C                     MOVE A2STRT    D@LOC2
     C                     MOVE A2STRR    D@LOC3
     C                     MOVE A2STRD    D@LOC4
     C                     ELSE
     C                     MOVE *ALL'*'   D@LOC1
     C                     MOVE *ALL'*'   D@LOC2
     C                     MOVE *ALL'*'   D@LOC3
     C                     MOVE *ALL'*'   D@LOC4
     C                     MOVELER,18     D@NUSE
     C                     ENDIF
     C*****                ENDIF
      *
TCHK1C           *IN99     IFEQ *OFF
TCHK1C           @KOSN     ANDEQ'0'
TCHK1C                     MOVEL*ON       *IN12
TCHK1C                     END
TCHK1C*
     C                     ENDSR
      *****************************************************
      *   2ND SCREEN
      *****************************************************
     C           #SCRN2    BEGSR
      *
     C                     EXFMTDSP02
      *
     C                     SELEC
TCHK1C           *INKA     WHEQ *ON
TCHK1C                     MOVE '99'      @@ID
     C           *INKC     WHEQ '1'
     C                     EXSR #CLR1
     C                     MOVE '01'      @@ID
TCHK1C                     MOVEL*OFF      *IN99
TCHK1C                     MOVEA'0000'    *IN,01
TCHK1C                     MOVEA'0000'    *IN,06
     C                     OTHER
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
     C                     EXSR #CLR1
     C                     MOVE '01'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
     C*****************************************************
      *  CHECK
     C*****************************************************
     C           #CHK2     BEGSR
      *
     C                     MOVEA'0000'    *IN,01
TCHK1C                     MOVEA'0000'    *IN,06
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    MSG
     C*
     C           @KOSN     IFNE '0'
TCHK1C*
TCHK1C           D@DMEI    IFEQ *BLANK
TCHK1C                     SETON                     0699
TCHK1C                     ENDIF
TCHK1C*
TCHK1C           D@SMEI    IFEQ *BLANK
TCHK1C                     SETON                     0799
TCHK1C                     ENDIF
TCHK1C*
TCHK1C           D@TEHI    IFEQ 'G'
TCHK1C           D@TEHI    OREQ 'Z'
TCHK1C           D@TEHI    OREQ 'S'
TCHL1C                     ELSE
TCHK1C                     SETON                     0899
TCHL1C                     END
TCHK1C           *IN91     IFEQ *ON
TCHK1C           D@TEHI    ANDEQ'G'
TCHK1C                     SETON                     0899
TCHK1C                     MOVELER,20     MSG
TCHK1C                     ENDIF
TCHK1C*
TCHK1C           D@KASI    IFEQ *ZERO
TCHK1C                     SETON                     0999
TCHK1C                     ENDIF
TCHK1C*
     C           @SYOS     IFEQ *ZERO
     C                     SETON                     0199
     C                     ENDIF
      *
     C           @BAN1     IFEQ *BLANK
     C           @BAN2     ANDEQ*BLANK
     C           @BAN3     ANDEQ*BLANK
     C           @BAN4     ANDEQ*BLANK
     C                     SETON                     0299
     C                     ENDIF
      *
     C                     MOVE @BAN2     @@02
     C           @@1       IFEQ *BLANK
     C           @@2       ANDNE*BLANK
     C                     MOVE @@2       @@1
     C                     MOVE *BLANK    @@2
     C                     MOVE @@02      @BAN2
     C                     ENDIF
      *
     C           K#FCL     SETLLFCEPL31
     C           *IN90     DOUEQ*ON
     C           K#FCL     READEFCEPL31                  90
     C           *IN90     IFEQ *OFF
     C           F3GSKD    ANDEQ*BLANK
     C           F3BHB1    IFEQ @NHN1
     C           F3BHB2    ANDEQ@NHN2
     C           F3BHB3    ANDEQ@NHN3
     C                     ELSE
     C                     SETON                     0299
TCHK1C           MSG       IFEQ *BLANK
     C                     MOVE ER,19     MSG
TCHK1C                     END
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
TCHK1C           @DAT1     IFEQ *ZERO
TCHK1C                     SETON                     9903
TCHK1C                     ELSE
TCHK1C                     Z-ADD@DAT1     @DATE
TCHK1C           K#AGD     CHAINAGDPL121             90
TCHK1C           *IN90     IFEQ *ON
TCHK1C                     SETON                     9903
TCHK1C                     ENDIF
TCHK1C                     ENDIF
TCHK1C*
TCHK1C           @DAT2     IFEQ *ZERO
TCHK1C                     SETON                     9904
TCHK1C                     ELSE
TCHK1C                     Z-ADD@DAT2     @DATE
TCHK1C           K#AGD     CHAINAGDPL121             90
TCHK1C           *IN90     IFEQ *ON
TCHK1C                     SETON                     9904
TCHK1C                     ENDIF
TCHK1C                     ENDIF
      *
TCHK1C*          @DAT1     IFEQ *ZERO
TCHK1C*                    Z-ADD*DATE     @DAT1
TCHK1C*                    ENDIF
TCHK1C*          @DAT2     IFEQ *ZERO
TCHK1C*                    Z-ADD*DATE     @DAT2
TCHK1C*                    ENDIF
      *
TCHK1C*          @DAT1     IFGE 900000
TCHK1C*          19000000  ADD  @DAT1     W@DAT1
TCHK1C*                    ELSE
TCHK1C*          20000000  ADD  @DAT1     W@DAT1  80
TCHK1C*                    ENDIF
TCHK1C*          @DAT2     IFGE 900000
TCHK1C*          19000000  ADD  @DAT2     W@DAT2
TCHK1C*                    ELSE
TCHK1C*          20000000  ADD  @DAT2     W@DAT2  80
TCHK1C*                    ENDIF
      *
TCHK1C*                    Z-ADDW@DAT1    @DATE
TCHK1C*          K#AGD     CHAINAGDPL121             90
TCHK1C*          *IN90     IFEQ *ON
TCHK1C*                    SETON                     9903
TCHK1C*                    ENDIF
      *
TCHK1C*                    Z-ADDW@DAT2    @DATE
TCHK1C*          K#AGD     CHAINAGDPL121             90
TCHK1C*          *IN90     IFEQ *ON
TCHK1C*                    SETON                     9904
TCHK1C*                    ENDIF
      *
     C                     ENDIF
      *
     C                     ENDSR
     C*****************************************************
     C*  UPDATE
     C*****************************************************
     C           #UPD      BEGSR
     C*
     C           K#FCE     CHAINFCEPL30              90
     C                     Z-ADD*DATE     F3GKDT
     C                     TIME           F3GTIM
     C                     MOVEL#USER     F3GKNM
     C           *IN90     IFEQ *OFF
     C           @KOSN     IFEQ '0'
     C                     MOVE 'D'       F3GSKD
     C                     Z-ADD*DATE     F3GSDT
     C                     ELSE
     C                     MOVE *BLANK    F3GSKD
     C                     Z-ADD*ZERO     F3GSDT
     C                     ENDIF
      *
     C                     Z-ADD*DATE     F3GKDT
     C                     TIME           F3GTIM
     C                     MOVEL#USER     F3GKNM
     C           F3LOCN    IFNE D@LOC
     C                     MOVELF3LOCN    F3LOCO
     C                     MOVELD@LOC     F3LOCN
TCHK1C*          @DAT2     IFGE 900000
TCHK1C*          19000000  ADD  @DAT2     F3TYMD
TCHK1C*                    ELSE
TCHK1C*          20000000  ADD  @DAT2     F3TYMD
TCHK1C*                    ENDIF
TCHK1C                     Z-ADD@DAT2     F3TYMD
     C                     ENDIF
      *
     C           F3SSYS    IFNE @SYOS
     C                     Z-ADDF3SSYS    F3KSYS
     C                     Z-ADD@SYOS     F3SSYS
TCHK1C*          @DAT1     IFGE 900000
TCHK1C*          19000000  ADD  @DAT1     F3SYMD
TCHK1C*                    ELSE
TCHK1C*          20000000  ADD  @DAT1     F3SYMD
TCHK1C*                    ENDIF
TCHK1C                     Z-ADD@DAT1     F3SYMD
     C                     ENDIF
      *
     C                     MOVE D@TEHI    F3TEHI
TCHK1C                     Z-ADDD@KASI    F3KASI
     C                     MOVE D@DMEI    F3DMEI
     C                     MOVELD@SMEI    F3SMEI
     C                     MOVELD@ZETI    F3ZETI
     C                     MOVE D@LOC1    F3PTRK
     C                     MOVE D@LOC2    F3PTRT
     C                     MOVE D@LOC3    F3PTRR
     C                     MOVE D@LOC4    F3PTRD
      *
     C                     UPDATFCEPP301
     C                     ELSE
      *
     C                     CLEARFCEPP301
     C                     Z-ADD*DATE     F3GKDT
     C                     TIME           F3GTIM
     C                     MOVEL#USER     F3GKNM
     C                     MOVE @NHN1     F3BHB1
     C                     MOVE @NHN2     F3BHB2
     C                     MOVE @NHN3     F3BHB3
     C                     MOVELD@LOC     F3LOCN
TCHK1C*          @DAT2     IFGE 900000
TCHK1C*          19000000  ADD  @DAT2     F3TYMD
TCHK1C*                    ELSE
TCHK1C*          20000000  ADD  @DAT2     F3TYMD
TCHK1C*                    ENDIF
TCHK1C                     Z-ADD@DAT2     F3TYMD
      *
     C                     Z-ADD@SYOS     F3SSYS
TCHK1C*          @DAT1     IFGE 900000
TCHK1C*          19000000  ADD  @DAT1     F3SYMD
TCHK1C*                    ELSE
TCHK1C*          20000000  ADD  @DAT1     F3SYMD
TCHK1C*                    ENDIF
TCHK1C                     Z-ADD@DAT1     F3SYMD
      *
     C                     MOVE D@TEHI    F3TEHI
TCHK1C                     Z-ADDD@KASI    F3KASI
     C                     MOVE D@DMEI    F3DMEI
     C                     MOVELD@SMEI    F3SMEI
     C                     MOVELD@ZETI    F3ZETI
     C                     MOVE D@LOC1    F3PTRK
     C                     MOVE D@LOC2    F3PTRT
     C                     MOVE D@LOC3    F3PTRR
     C                     MOVE D@LOC4    F3PTRD
      *
     C                     WRITEFCEPP301
      *
     C                     ENDIF
      *
     C                     ENDSR
     C*****************************************************
     C*  CLEAR FIELDS ON 1ST SCREEN
     C*****************************************************
     C           #CLR1     BEGSR
      *
     C                     MOVE *BLANK    @KOSN
     C                     MOVE *BLANK    @NHN1
     C                     MOVE *BLANK    @NHN2
     C                     MOVE *BLANK    @NHN3
      *
     C                     ENDSR
**  TBL1/TBL2 (UPDATE /NAME)
0-CANCEL
1-CHANGE
2-ADD
**  ERR
E-01 UPDATE INSTRUCTION ISN'T RIGHT
E-02 INPUT INTRAL COMPANY PART NO.
E-03 ADD WAS APPOINTED, BUT IT EXISTS IN M/F
E-04 CHANGE WAS APPOINTED, BUT THERE IS NOT IT IN M/F
E-05 CHANGE WAS APPOINTED, BUT IT'S CANCELLED ALREADY IN M/F
E-06 CANCEL WAS APPOINTED, BUT THERE IS NOT IT IN M/F
E-07 CANCEL WAS APPOINTED, BUT IT'S CANCELLED ALREADY IN M/F
E-08 PART # ERROR.
E-09
E-10
E-11
E-12
E-13
E-14
E-15
E-16
E-17
DISUSE
E-19 THIS LOCATION IS ALREADY OCCUPIED.
E-20 THIS PART IS NOT MASS PRODUCT.
