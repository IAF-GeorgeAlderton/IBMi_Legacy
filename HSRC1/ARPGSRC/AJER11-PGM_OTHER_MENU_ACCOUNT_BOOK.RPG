     O                                   58 'TIME'
     O                         WTIME Y   67
     O                                   80 '.         .'
     O        E 1              HD
     O                                   10 'AJER11-1'
     O                                   58 'DATE'
     O                         UDATE Y   67
     O                                   80 '.         .'
     O        E 1              HD
     O                                   15 'UNIT USE DEPT'
     O                                   42 '** MENU ACCOUNT BOOK '
     O                                   53 'BY PGM NAME'
     O                                   63 'PAGE'
     O                         PAGE  Z   67
     O                                   80 '...........'
     O        E 2              HD
     O                                   16 'PGM NAME'
     O                                   30 'MENU TEXT'
     O                                   71 'USING DEPARTMENT'
     O        E 2              DT1
     O                         MLPGMN    13
     O                         MLTEXT    57
     O                         WUNM      75
