     FEGBPL13 IP  E           K        DISK
     FQPRINT  O   F      80     OF     PRINTER
     E                    TB1     1   3  2   TB2    16   ﾎﾞﾆｭxb
     IEGBPL131
     I                                              MLPGMNL1
     I            DS
     I                                        1  10 MLUSRC
     I                                        1   2 USRC
      *
     C                     TIME           WTIME   60
     C           *IN02     IFEQ '0'
     C                     SETON                     02
     C                     Z-ADD0         RECD    20
     C                     EXCPTHD
     C                     END
      *
     C           *INL1     IFEQ '1'
     C                     SETOF                     01
     C                     Z-ADD1         A       20
     C                     MOVE *BLANK    WUNM   16
     C                     MOVE USRC      WUSRC   2
     C           USRC      LOKUPTB1,A                    01
     C           *IN01     IFEQ '1'
     C                     MOVELTB2,A     WUNM
     C                     END
      *
     C           RECD      IFGT 52
     C                     Z-ADD2         RECD
     C                     EXCPTHD
     C                     EXCPTDT1
     C                     ELSE
      *
     C                     ADD  2         RECD
     C                     EXCPTDT1
     C                     END
     C                     ELSE
      *
     C           USRC      IFNE WUSRC
     C                     MOVE USRC      WUSRC
      *
     C                     SETOF                     01
     C                     Z-ADD1         A
     C                     MOVE *BLANK    WUNM
     C           USRC      LOKUPTB1,A                    01
     C           *IN01     IFEQ '1'
     C                     MOVELTB2,A     WUNM
     C                     END
      *
     C           RECD      IFGT 52
     C                     Z-ADD2         RECD
     C                     EXCPTHD
     C                     EXCPTDT1
     C                     ELSE
      *
     C                     ADD  1         RECD
     C                     EXCPTDT2
     C                     END
     C                     END
     C                     END
      *
     OQPRINT  E   02           HD
     O                                   80 '...........'
