     H            Y.
     F** ABMR37 *********************************************
     F*  SHIPMENT OVERLAP
     F*    HOTTA.               2018.09.14                  *
     F*******************************************************
     FABMPL31 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FABMWP37 O   F    0256            DISK                      A
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I            DS
     I                                        1   80A2GEHZ
     I                                        1   40A2GEYY
     I                                        5   60A2GEMM
     I                                        7   80A2GEDD
      *
     I            DS
     I                                        1   80W@DATE
     I                                        1   40W@DAYY
     I                                        5   60W@DAMM
     I                                        7   80W@DADD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
      *
     I            DS
     I                                        1   8 CTIHZ
     I                                        1   2 CTIMM
     I                                        3   4 CTIDD
     I                                        5   8 CTIYY
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
     I              'A-PICS OVERLAP'      C         FNAM11
     I              'ERROR LIST'          C         FNAM12
      *
     C           *ENTRY    PLIST
     C                     PARM           P@DTYM  60
     C                     PARM           P@FNAM 30
      *
     C                     TIME           WTIME
      *
     C                     MOVE WTIMM     CTIMM
     C                     MOVE WTIDD     CTIDD
     C                     MOVE WTIYY     CTIYY
     C                     MOVEL*BLANK    P@FNAM
     C                     MOVELFNAM11    P@FNAM
     C           P@FNAM    CAT  FNAM12:1  P@FNAM
     C******     FNAM1     CAT  CTIHZ:1   P@FNAM
      *
     C                     EXCPTHD
     C                     Z-ADDP@DTYM    K@DTYM  60
     C           K@DTYM    SETLLABMPL311
     C           K@DTYM    READEABMPL311                 87
     C           *IN87     DOWEQ'0'
     C           S5DUP@    IFEQ '@'
     C                     EXSR #SB001
     C                     ENDIF
     C           K@DTYM    READEABMPL311                 87
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------*
      * FCEPP01                                          *
      *--------------------------------------------------*
     CSR         #SB001    BEGSR
      *
     C                     Z-ADD0         S@BOXD  61
     C           S5SSYS    IFNE 0
     C           S5KTSU    DIV  S5SSYS    S@BOXD
     C                     ENDIF
     C                     Z-ADD0         S@BOXP  73
     C           S5KMAX    IFNE 0
     C           S5KMAA    DIV  S5KMAX    S@BOXP
     C                     ENDIF
      *
     C           KEYFC1    KLIST
     C                     KFLD           S5SHN1
     C                     KFLD           S5SHN2
     C                     KFLD           S5SHN3
     C                     Z-ADD0         WWGEHZ  80
     C           KEYFC1    CHAINFCEPL011             25
     C           *IN25     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     25
     C                     ENDIF
     C           *IN25     IFEQ '0'
     C                     MOVELA2GEHZ    WWGEHZ
     C                     ENDIF
      *
     C                     EXCPTDT
      *
     CSR         ESB001    ENDSR
      *
     OABMWP37 EADD             HD
     O                                      'KANBAN KIND,'
     O                                      'LOCATION,'
     O                                      'PART NO.,'
     O                                      'BOX QTY,'
     O                                      'SET# CHANGE DATE,'
     O                                      'OLD SET#/D,'
     O                                      'NEW SET#/D,'
     O                                      'OLD BOX/DAY,'
     O                                      'NEW BOX/DAY,'
     O                                      'OLD SHIPMENT OVERLAP,'
     O                                      'NEW SHIPMENT OVERLAP,'
     O                                      'OLD KANBAN#,'
     O                                      'NEW KANBAN#,'
     O                                      '+/- RATIO,'
     O                                      'DIFF,'
     O        EADD             DT
     O                         S5KCD1
     O                                      ','
     O                         S5ATK1
     O                                      '-'
     O                         S5ATK2
     O                                      '-'
     O                         S5ATK3
     O                                      '-'
     O                         S5ATK4
     O                                      ','
     O                         S5SHN1
     O                                      '-'
     O                         S5SHN2
     O                                      '-'
     O                         S5SHN3
     O                                      ','
     O                         S5SSYS
     O                                      ','
     O                         WWGEHZ       '    /  /  '
     O                                      ','
     O                         S5KTSU
     O                                      ','
     O                         S5KTSA
     O                                      ','
     O                         S@BOXD       '   0 . '
     O                                      ','
     O                         S5BOXD       '   0 . '
     O                                      ','
     O                         S5DUPH
     O                                      ','
     O                         S5DUP#
     O                                      ','
     O                         S5KMAX
     O                                      ','
     O                         S5KMAA
     O                                      ','
     O                         S@BOXP       '  0 .   '
     O                                      ','
     O                         S5SA  P
     O                                      ','
