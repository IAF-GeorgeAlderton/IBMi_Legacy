     H            Y.
     F** APLR85 **************************************
     F* MULTIPLE PROCESS CONTROL  ONLY CHECK         *
     F*       T.SAKAKI      2016.10.13               *
     F************************************************
     FAPLPP80 IF  E           K        DISK
      *
     I            DS
     I                                        1   80A1SKHZ
     I                                        1   40A1SKYY
     I                                        5   60A1SKMM
     I                                        7   80A1SKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------*
      * PARAMETER                                        *
      *   IN                                               *
      *      PIPGMN : PROGRAM NAME                         *
      *   OUT                                              *
      *      POUSID : USER ID                              *
      *      POKONA : USER NAME                            *
      *      POSTTS : '1' OK                               *
      *               '2' NG = PROCESSING BY OTHER USER    *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           PIPGMN 10
     C                     PARM           POUSID 10
     C                     PARM           POKONA 15
     C                     PARM           POSTTS  1
      *
     C                     TIME           WTIME
      * CHECK
     C                     MOVEL*BLANK    POUSID
     C                     MOVEL*BLANK    POKONA
     C                     MOVEL*BLANK    POSTTS
     C           PIPGMN    CHAINAPLPP801             21
     C           *IN21     IFEQ '0'
     C           A1SKJY    ANDEQ'D'
     C           A1SKHZ    ANDLEWTIHZ
     C                     SETON                     21
     C                     ENDIF
      *
     C           *IN21     IFEQ '0'
     C                     MOVELA1USID    POUSID
     C                     MOVELA1KONA    POKONA
     C                     MOVEL'2'       POSTTS           NG
     C                     ELSE
     C                     MOVEL'1'       POSTTS           OK
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *
