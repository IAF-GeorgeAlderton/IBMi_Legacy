     C                     PARM           P@1NNM 100
     C                     PARM           P@2NNM 100
     C                     PARM           P@NTYM  60
     C                     PARM           P@TNSU 100
      *
     C                     EXCPTODAT
      *
     C           @END      TAG
      *
     OABBWPT1 E                ODAT
     O                                      '="'
     O                         A2BHB1
     O                         A2BHB2
     O                         A2BHB3
     O                                      '"'
     O                                      ','
     O                         P@N2NM
     O                                      ','
     O                         P@N1NM
