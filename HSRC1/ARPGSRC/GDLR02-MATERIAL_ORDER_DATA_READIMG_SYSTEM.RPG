      *------------------*
      * TOTAL DATE CHECK *
      *------------------*
B0   C           WATOHZ    IFNE 0
     C                     GOTO SKP
E0   C                     END
      *
      *-----------*
      * WIRE DATA *
      *-----------*
B0   C           WAPTCD    IFEQ 'W'
     C                     SETOF                     20
     C                     MOVEL*BLANK    ZAIS
     C                     Z-ADD0         ZAIK
     C           KEY2      SETGTIZAPL02
B1   C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY2      REDPEIZAPL021                 10
      *
B2   C           *IN10     IFEQ '0'
B3   C           ZCSKJY    IFEQ 'D'
     C           ZCSKHZ    ANDLE*DATE
     C                     ELSE
B4   C           ZCUKHZ    IFLE *DATE
     C           ZCSTHZ    ANDGT*DATE
     C                     SETON                     20
     C                     MOVELZCZAIS    ZAIS
     C                     Z-ADDZCZAIK    ZAIK
     C                     GOTO JUMP
E4   C                     END
E3   C                     END
E2   C                     END
E1   C  N10                ENDDO
E0   C                     END
      *----------*
      * ROD DATA *
      *----------*
B0   C           WAPTCD    IFEQ 'R'
     C                     SETOF                     20
     C                     MOVEL*BLANK    ZAIS
     C                     Z-ADD0         ZAIK
     C           KEY2      SETGTIZBPL02
B1   C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY2      REDPEIZBPL021                 10
      *
B2   C           *IN10     IFEQ '0'
B3   C           ZDSKJY    IFEQ 'D'
     C           ZDSKHZ    ANDLE*DATE
     C                     ELSE
B4   C           ZDUKHZ    IFLE *DATE
     C           ZDSTHZ    ANDGT*DATE
     C                     SETON                     20
     C                     Z-ADDZDZAIK    ZAIK
     C                     MOVELZDZAIS    ZAIS
     C                     GOTO JUMP
E4   C                     END
E3   C                     END
E2   C                     END
E1   C  N10                ENDDO
E0   C                     END
      *
     C           JUMP      TAG
     C                     MOVEL'IAF-'    ODER1
     C                     MOVELWAODR1    ODER2
     C                     MOVE '-'       ODER2
     C                     MOVELWAODR2    ODER3
     C                     MOVE '-'       ODER3
     C                     MOVELWAODR3    ODER4
      *
     C                     MOVELWAPTCD    CASE1
     C                     MOVE '-'       CASE1
     C                     MOVELWACASE    CASE2
     C                     Z-ADD*DATE     WATOHZ
     C                     UPDATGDLWP011
     C                     ADD  1         MAIS
