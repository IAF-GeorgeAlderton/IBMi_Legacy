     H            Y.
     F** UEXR36B ********************************************
     F*  PROGRAM: EXSUB - GET TTAI MASTER SERIAL#           *
     F*  WRITTEN: JW (SRA) 2020.10.02                       *
     F*-----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UEXR36B'
     F*                    PARM           $NONY   4
     F*                    PARM           $NKOJ   1
     F*                    PARM           $NUKE   4
     F*                    PARM           $NOHZ   8
     F*                    PARM           $NOBN   2
     F*                    PARM           $ODRN  10
     F*                    PARM           $SERL  20
     F*                    PARM           $TTAI  10
     F*                    PARM           $RTN    1
     F*  IN  $NONY   4A  IAF PART
     F*      $NKOJ   1A  SHIP DATE
     F*      $NUKE   4A  SHIP DATE
     F*      $NOHZ   8A  SHIP DATE
     F*      $NOBN   2A  BIN#         M
     F*      $ODRN  10A  PO#
     F*  OUT $SERL  20A  MASTER SERIAL#
     F*      $TTAL  10A  TTAI SERIAL#
     F*      $RTN    1A  RETURN CODE (OK:BLANK, *:ERROR)
     F******************************************************
     FAB#PL7B IF  E           K        DISK
      *===================================================
      * SYSTEM DATE
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      * KEY FIELDS
     I            DS
     I                                        1   80@NOHZ
     I                                        1   40@NOYY
     I                                        5   60@NOMM
     I                                        7   80@NODD
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      *
     C           K#PL7B    SETLLAB#PL7B
      *
     C                     DO   *HIVAL
     C           K#PL7B    READEAB#PL7B                  97
     C   97                LEAVE
      *
     C           EKSKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C           EKLOC1    IFNE ' '
     C                     ITER
     C                     END
      *
     C                     MOVELEKSERL    $SERL
     C                     LEAVE
     C                     ENDDO
      * SET TTAI
     C           $SERL     IFNE *BLANK
     C                     MOVE $SERL     LTR8    8
     C                     MOVE '01'      LTR8
     C                     MOVEL'IF'      LTR10  10
     C                     MOVE LTR8      LTR10
     C                     MOVE LTR10     $TTAI     P
     C                     ENDIF
      *
     C           $SERL     IFEQ *BLANK
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $NOHZ   8
     C                     PARM           $NOBN   2
     C                     PARM           $ODRN  10
     C                     PARM           $SERL  20
     C                     PARM           $TTAI  10
     C                     PARM           $RTN    1
      *
     C           K#PL7B    KLIST
     C                     KFLD           KKNONY  4
     C                     KFLD           KKNKOJ  1
     C                     KFLD           KKNUKE  4
     C                     KFLD           KKNOYY  40
     C                     KFLD           KKNOMM  20
     C                     KFLD           KKNODD  20
     C                     KFLD           KKNOBN  2
     C                     KFLD           KKODRN 10
      * SET KEY
     C                     MOVEL$NONY     KKNONY
     C                     MOVEL$NKOJ     KKNKOJ
     C                     MOVEL$NUKE     KKNUKE
     C                     MOVEL$NOHZ     @NOHZ
     C                     MOVEL@NOYY     KKNOYY
     C                     MOVEL@NOMM     KKNOMM
     C                     MOVEL@NODD     KKNODD
     C                     MOVEL$NOBN     KKNOBN
     C                     MOVEL$ODRN     KKODRN
      *
     C                     MOVE *BLANK    $SERL
     C                     MOVE *BLANK    $TTAI
     C                     MOVE *BLANK    $RTN
      *
     C                     ENDSR
