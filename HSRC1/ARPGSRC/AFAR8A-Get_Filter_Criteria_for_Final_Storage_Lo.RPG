     H            Y.
     F** AFAR8A  ********************************************
     F* 3 BOND SHIP SCAN ERROR INQUIRY                      *
     F*     ..............         2017.12.14               *
     F*******************************************************
     FAFAPW8A CF  E                    WORKSTN
     E                    ER      1   7 60
      *
     I            DS
     I                                        1  12 D1LHN
     I                                        1   5 D1LHN1
     I                                        6  10 D1LHN2
     I                                       11  12 D1LHN3
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
      *
     I            DS
     I                                        1  120D1DE1
     I                                        1   80D1COH1
     I                                        9  120D1DET1
      *
     I            DS
     I                                        1  120D1DE2
     I                                        1   80D1COH2
     I                                        9  120D1DET2
      *
      *
     C           *ENTRY    PLIST
     C                     PARM           P1COH1  8
     C                     PARM           P1COH2  8
     C                     PARM           P1WKCD  6
     C                     PARM           P1LHN  12
     C                     PARM           P1DET1  4
     C                     PARM           P1DET2  4
     C                     PARM           PCMD    2
      *
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * MAINLINE                                           *
      *----------------------------------------------------*
     C                     TIME           SDATE
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INITIALIZATION -                                   *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVEL'01'      DSPSW   2
     C                     MOVE P1COH1    D1COH1
     C                     MOVE P1COH2    D1COH2
     C                     MOVELP1WKCD    D1WKCD
     C                     MOVELP1LHN     D1LHN
     C                     MOVE P1DET1    D1DET1
     C                     MOVE P1DET2    D1DET2
     C                     MOVEL*BLANK    P1COH1
     C                     MOVEL*BLANK    P1COH2
     C                     MOVEL*BLANK    P1WKCD
     C                     MOVEL*BLANK    P1LHN
     C                     MOVEL*BLANK    P1DET1
     C                     MOVEL*BLANK    P1DET2
     C                     MOVEL*BLANK    PCMD
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTAFAPW8A1
     C                     SETOF                     303132
     C                     SETOF                     333435
     C                     SETOF                     363738
     C                     SETOF                     3999
     C                     MOVEL*BLANK    D1ERR
      *
     C           *IN03     IFEQ '1'
     C                     MOVEL'03'      PCMD
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1COH1    IFEQ 0
     C                     MOVELER,3      D1ERR
     C                     SETON                     3299
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1DET1    IFGE 2400
     C                     MOVELER,5      D1ERR
     C                     SETON                     3499
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1COH2    IFNE 0
     C           D1COH1    IFGT D1COH2
     C                     MOVELER,1      D1ERR
     C                     SETON                     323699
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
     C           D1DET2    IFGE 2400
     C                     MOVELER,5      D1ERR
     C                     SETON                     3799
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1DE2     IFNE 0
     C           D1DE2     IFLT D1DE1
     C                     MOVELER,4      D1ERR
     C                     SETON                     323436
     C                     SETON                     3799
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVELD1COH1    P1COH1
     C                     MOVELD1COH2    P1COH2
     C                     MOVELD1WKCD    P1WKCD
     C                     MOVELD1LHN     P1LHN
     C                     MOVELD1DET1    P1DET1
     C                     MOVELD1DET2    P1DET2
     C                     MOVEL'05'      PCMD
     C                     MOVEL'99'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *
** ER
E-01 DATE ERR.(FROM > TO)
E-02 INPUT '1' OR '2'.
E-03 INPUT SCAN DATE.
E-04 RANGE ERR.
E-05 INPUT 00:00 - 23:59.
E-06
E-07
