     C                     ADD  1         LL
     C           #NO,KK    IFEQ *BLANK
     C           #NO,KK    OREQ '0'
     C           #NO,KK    OREQ '1'
     C           #NO,KK    IFEQ '0'
     C           #NO,KK    OREQ '1'
     C           #IN,KK    IFEQ *BLANK
     C                     MOVELER,9      @ERR
     C                     MOVEA'1'       *IN,LL
     C                     SETON                     99
     C                     GOTO @STP2
     C                     END
     C                     END
     C                     ELSE
     C                     MOVELER,10     @ERR
     C                     MOVEA'1'       *IN,LL
     C                     SETON                     99
     C                     GOTO @STP2
     C                     END
     C                     ENDDO
      *
