     C                     MOVEL*BLANK    P9MOJI
     C                     MOVEL*BLANK    P9STS
     C                     EXSR #AS800
     C                     MOVE P9MOJI    S1PRI
      *
     C                     SELEC
     C           CTRX      WHEQ 1
     C                     MOVEL'1'       @45
     C           CTRX      WHEQ 2
     C                     MOVEL'1'       @46
     C           CTRX      WHEQ 3
     C                     MOVEL'1'       @47
     C           CTRX      WHEQ 4
     C                     MOVEL'1'       @48
     C           CTRX      WHEQ 5
     C                     MOVEL'1'       @49
     C           CTRX      WHEQ 6
     C                     MOVEL'1'       @50
     C           CTRX      WHEQ 7
     C                     MOVEL'1'       @61
     C           CTRX      WHEQ 8
     C                     MOVEL'1'       @62
     C           CTRX      WHEQ 9
     C                     MOVEL'1'       @63
     C           CTRX      WHEQ 10
     C                     MOVEL'1'       @64
     C           CTRX      WHEQ 11
     C                     MOVEL'1'       @65
     C           CTRX      WHEQ 12
     C                     MOVEL'1'       @95
     C           CTRX      WHEQ 13
     C                     MOVEL'1'       @67
     C           CTRX      WHEQ 14
     C                     MOVEL'1'       @68
     C           CTRX      WHEQ 15
     C                     MOVEL'1'       @69
     C           CTRX      WHEQ 16
     C                     MOVEL'1'       @70
     C           CTRX      WHEQ 17
     C                     MOVEL'1'       @91
     C           CTRX      WHEQ 18
     C                     MOVEL'1'       @92
     C           CTRX      WHEQ 19
     C                     MOVEL'1'       @93
     C           CTRX      WHEQ 20
     C                     MOVEL'1'       @94
     C                     ENDSL
      *
     CSR         EEDIT9    ENDSR
      *----------------------------------------------------*
      * NEXT DATA                                          *
      *----------------------------------------------------*
     CSR         #NEXT     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXT
     C                     ENDIF
      *
     C                     READ ABTWP231                 81
      *
     CSR         ENEXT     ENDSR
      *----------------------------------------------------*
      * PRV DATA                                           *
      *----------------------------------------------------*
     CSR         #NEXTP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXTP
     C                     ENDIF
      *
     C                     READPABTWP231                 81
      *
     CSR         ENEXTP    ENDSR
     C*----------------------------------------------------------------
      *----------------------------------------------------*
      *数字編集                                          *
      *----------------------------------------------------*
     CSR         #AS800    BEGSR
      *
     C                     CALL 'AGJR48'
     C                     PARM           P1MOJI 15
     C                     PARM           P1KETA  20
     C                     PARM           P1PONT  20
     C                     PARM           P1ZERO  1
     C                     PARM           P1SPCS  1
     C                     PARM           P9MOJI 30
     C                     PARM           P9STS   1
     C           P9MOJI    IFEQ *BLANK
     C                     MOVE '0'       P9MOJI
     C                     ENDIF
      *
     CSR         EAS800    ENDSR
      *----------------------------------------------------*
      * COLOR                                              *
      *----------------------------------------------------*
     CSR         #COLOR    BEGSR
      *
     C                     Z-ADD0         I       30
     C                     SELEC
     C           D         WHEQ 1
     C                     Z-ADD31        I
     C           D         WHEQ 2
     C                     Z-ADD34        I
     C           D         WHEQ 3
     C                     Z-ADD37        I
     C           D         WHEQ 4
     C                     Z-ADD40        I
     C                     ENDSL
      *
     C                     CALL 'ABTR25'
     C                     PARM           W3LPR1
     C                     PARM           W3LPR2
     C                     PARM           W3LPR3
     C                     PARM           PPCNT   30
      *
     C                     Z-ADD0         W@SU    40
      *  KEI + IN
     C           W@K       ADD  W@I       W@KI    40
     C           W@KI      ADD  W@PL      W@KIPL  40
      *
1    C           W@KIPL    IFNE 0
|     *
|     * 'TSL' AND 'INS' ARE ALWAYS IN YELLOW
|2   C           W@P,D     IFEQ 'TSL'
||   C           W@P,D     OREQ 'TSL'
||   C                     ADD  1         I
||   C                     MOVEL'1'       *IN,I
|2   C                     ELSE
||    * GREEN
||    *  KEI > SHRTG
||3  C           W@K       IFGE PPCNT
|||  C                     MOVEL'1'       *IN,I
|||   * YELLOW
||3  C                     ELSE
|||4 C           W@KI      IFGE PPCNT
|||| C                     ADD  1         I
|||| C                     MOVEL'1'       *IN,I
||||  * RED
|||4 C                     ELSE
|||| C                     ADD  2         I
|||| C                     MOVEL'1'       *IN,I
|||4 C                     ENDIF
||3  C                     ENDIF
|2   C                     ENDIF
|     *
|    C                     Z-ADDW@KIPL    W@SU
|    C                     ADD  W@KIPL    WTTL
|    C*
|    C                     MOVE *BLANK    P1MOJI
|    C                     MOVE WTTL      P1MOJI
|    C                     MOVEL'03'      P1KETA
|    C                     MOVEL'00'      P1PONT
|    C                     MOVEL'Y'       P1ZERO
|    C                     MOVEL'Y'       P1SPCS
|    C                     MOVEL*BLANK    P9MOJI
|    C                     MOVEL*BLANK    P9STS
|    C                     EXSR #AS800
|    C                     MOVE P9MOJI    S1TTL
|     *
1    C                     ENDIF
      *
     CSR         ECOLOR    ENDSR
