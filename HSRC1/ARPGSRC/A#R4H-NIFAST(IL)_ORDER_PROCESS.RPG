     H            Y.
     F** AB#R4H ********************************************
     F*  NIFAST ORDER PROCESSING                           *
     F*                                                    *
     F*                                                    *
TCHK1F* TCHK1 12/05/05 Create(copy from AB#R4R             *
TCHK2F* TCHK2 06/08/06 FORMAT CHANGE                       *
TCHK3F* TCHK3 11/21/06 CHG FORMAT                          *
TCHK4F* TCHK4 12/15/14 CHG FORMAT                          *
     F******************************************** AB#R4H **
     FNIFAST  IP  F     800            DISK
     FAB#WNIF O   E                    DISK
      *--------------------------------------------------------
     E                    AY        800  1
     E                    DT4         4  1
     E                    DT2         2  1
     E                    OD         10  1
     E                    A9          9  1
     E                    A9X         9  1
     E                    MHN        15  1
      *--------------------------------------------------------
     INIFAST  AA  01
     I                                        1  12 SEQ
     I                                       13 268 DAT1
     I                                      269 524 DAT2
     I                                      525 780 DAT3
     I            DS
     I                                        1   8 YMD
     I                                        1   4 YY
TCHK2I                                        1   2 YY1
RCHK2I                                        3   4 YY2
     I                                        5   6 MM
     I                                        7   8 DD
     I            DS
     I                                        1  15 AWMHNX
     I                                        1   5 AWMHN1
     I                                        6  10 AWMHN2
     I                                       11  15 AWMHN3
     I            DS
     I                                        1  140W@TIME
     I                                        1   20W@TH
     I                                        3   40W@TM
     I                                        5   60W@TS
     I                                        7  100W@DY
     I                                       11  120W@DM
     I                                       13  140W@DD
      *
     C           *ENTRY    PLIST
     C                     PARM           PID     1
      *
     C                     Z-ADD0203      AWTOKU
     C                     Z-ADD0203      AWNONY
     C                     MOVE '0'       AWNKOJ
     C                     MOVE '00  '    AWNUKE
     C                     MOVE '000000'  AWSBAN
     C                     MOVE '1'       AWBIN#
      *
     C                     MOVEADAT1      AY,1
      *
      * ------
      * HEADER
      * ------
     C           *IN99     IFEQ *OFF
      *
     C                     Z-ADD1         X       30
TCHK2C*          'PO#:'    SCAN DAT1      X              10
TCHK2C* N10      'Po#:'    SCAN DAT1      X              10
TCHK2C* N10      'PO.:'    SCAN DAT1      X              10
TCHK2C* N10      'Po.:'    SCAN DAT1      X              10
TCHK2C* N10                GOTO @END
TCHK2C           'PO#'     SCAN DAT1      X              10
TCHK2C  N10      'Po#'     SCAN DAT1      X              10
TCHK2C  N10      'PO.'     SCAN DAT1      X              10
TCHK2C  N10      'Po.'     SCAN DAT1      X              10
TCHK2C  N10                GOTO @END
     C                     MOVEL*ON       *IN99
     C                     GOTO @END
      *
     C                     END
      *
      * ------
      * DETAIL
      * ------
TCHK3C                     Z-ADD1         X
TCHK3C           'PO'      SCAN DAT1      X              10
TCHK3C  N10      'Po'      SCAN DAT1      X              10
TCHK3C  N10                GOTO @END
TCHK3C*
TCHK3C           AY,1      IFEQ ','
TCHK3C           AY,1      OREQ 'F'
TCHK3C                     GOTO @END
TCHK3C                     END
      *
      * ORDER#
     C                     Z-ADD*ZERO     Y       30
     C                     Z-ADD*ZERO     Z       30
     C                     MOVEL*BLANK    OD
      *
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C           AY,Y      IFEQ ','
     C           AY,Y      OREQ ' '
     C                     LEAVE
     C                     END
     C                     ADD  1         Z
     C                     MOVELAY,Y      OD,Z
     C                     ENDDO
      *
     C                     MOVEAOD        AWORDN
      *
      * PART#
     C                     Z-ADD1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
      *
     C                     MOVEL*BLANK    MHN
     C                     Z-ADDX         Y
     C                     Z-ADD*ZERO     Z
      *
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C           AY,Y      IFEQ ','
     C           AY,Y      OREQ ' '
     C                     LEAVE
     C                     END
     C           AY,Y      IFEQ '-'
     C                     ITER
     C                     END
     C                     ADD  1         Z
     C                     MOVELAY,Y      MHN,Z
     C                     ENDDO
      *
     C                     MOVEAMHN       AWMHNX
      *
      * QTY
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
      *
     C                     Z-ADDX         Y
     C                     MOVEL*BLANK    A9
     C                     Z-ADD*ZERO     Z
      *
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C           AY,Y      IFEQ ','
     C           AY,Y      OREQ ' '
     C                     LEAVE
     C                     END
     C                     ADD  1         Z
     C                     MOVELAY,Y      A9,Z
     C                     ENDDO
      *
     C                     MOVEL*ZERO     A9X
     C                     Z-ADD9         Y
     C                     Z-ADD9         Z
     C                     DO   9
     C           A9,Y      IFNE *BLANK
     C                     MOVELA9,Y      A9X,Z
     C                     SUB  1         Z
     C                     END
     C                     SUB  1         Y
     C           Y         IFEQ *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVE @9C       @9      90
     C                     Z-ADD@9        AWSRYO
      *
      * DATE
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
      *
     C                     Z-ADDX         Y
     C                     Z-ADD*ZERO     Z
     C                     MOVEL*ZERO     YMD
      * MM
     C                     ADD  1         Y
     C                     MOVEAAY,Y      DT2
     C           DT2,2     IFGE '0'
     C           DT2,2     ANDLE'9'
     C                     MOVEADT2       MM
     C                     ELSE
     C                     MOVE '00'      MM
     C                     MOVE DT2,1     MM
     C                     END
      * DD
     C           '/'       LOKUPAY,Y                     10
     C  N10                GOTO @END
     C                     ADD  1         Y
     C                     MOVEAAY,Y      DT2
     C           DT2,2     IFGE '0'
     C           DT2,2     ANDLE'9'
     C                     MOVEADT2       DD
     C                     ELSE
     C                     MOVE '00'      DD
     C                     MOVE DT2,1     DD
     C                     END
      * YY
     C           '/'       LOKUPAY,Y                     10
     C  N10                GOTO @END
     C                     ADD  1         Y
TCHK2C*                    MOVEAAY,Y      YY
TCHK2C                     MOVEAAY,Y      YY2
TCHK2C                     MOVEL20        YY1
     C                     MOVELYMD       AWSHDT
      *
TA    * QTY/BOX
TA   C*                    ADD  1         X
TA   C*          ','       LOKUPAY,X                     10
TA   C* N10                GOTO @END
TA    *
TA   C*                    Z-ADDX         Y
TA   C*                    MOVEL*BLANK    A9
TA   C*                    Z-ADD*ZERO     Z
TA   C*                    DO   *HIVAL
TA   C*                    ADD  1         Y
TA   C*          AY,Y      IFEQ ','
TA   C*          AY,Y      OREQ ' '
TA   C*                    LEAVE
TA   C*                    END
TA   C*                    ADD  1         Z
TA   C*                    MOVELAY,Y      A9,Z
TA   C*                    ENDDO
TA    *
TA   C*                    MOVEL*ZERO     A9X
TA   C*                    Z-ADD9         Y
TA   C*                    Z-ADD9         Z
TA   C*                    DO   9
TA   C*          A9,Y      IFNE *BLANK
TA   C*                    MOVELA9,Y      A9X,Z
TA   C*                    SUB  1         Z
TA   C*                    END
TA   C*                    SUB  1         Y
TA   C*          Y         IFEQ *ZERO
TA   C*                    LEAVE
TA   C*                    END
TA   C*                    ENDDO
TA    *
TA   C*                    MOVEAA9X       @9C     9
TA   C*                    MOVEL@9C       @9      90
TA   C*                    Z-ADD@9        AWSYOS
TA   C                     Z-ADD*ZERO     AWSYOS
      *
      * WRITE
     C                     WRITEAB#WNIF1
     C                     MOVE '1'       PID
      *
     C           @END      TAG
