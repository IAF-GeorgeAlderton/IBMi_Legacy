      *
     C           KEY1      KLIST
     C                     KFLD           PSHN1
     C                     KFLD           PSHN2
     C                     KFLD           PSHN3
      *
     C           KEY2      KLIST
     C                     KFLD           WSHN1
     C                     KFLD           WSHN2
     C                     KFLD           WSHN3
      *
     C                     OPEN GHCWP22
      *
     C                     SETOF                     01
     C           KEY1      CHAINGHCNP211             01
     C           *IN01     IFEQ '1'
     C                     CLOSEGHCWP22
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C                     SETOF                     01
     C           1         CHAINGHCWP22              01
     C           *IN01     IFEQ '0'
      *
     C                     Z-ADD1         A       20
     C           1         DO   15        A
     C           XTKR,A    IFNE *BLANK
     C                     MOVE XKB,A     AKB,A
     C                     MOVE XTKR,A    ATKR,A
     C                     MOVE XSHN,A    ASHN,A
     C                     END
     C                     END
     C                     END
      *
     C                     MOVE *BLANK    OKB
     C                     MOVE *BLANK    OTKR
     C                     MOVE *BLANK    OSHN
      *
     C*----------------------------------------*
     C*     ...更新区分取消　の　場合...     *
     C*----------------------------------------*
     C           PKOSN     IFEQ '0'
     C                     MOVEANKB       OKB
     C                     MOVEANTKR      OTKR
     C                     MOVEANSHN      OSHN
     C                     MOVE *BLANK    NKB
     C                     MOVE *BLANK    NTKR
     C                     MOVE *BLANK    NSHN
     C                     END
      *
     C*----------------------------------------*
     C*     ...更新区分変更　の　場合...     *
     C*----------------------------------------*
     C           PKOSN     IFEQ '1'
     C                     Z-ADD1         A
     C           1         DO   15        A
     C           AKB,A     IFNE *BLANK
     C                     Z-ADD1         B       20
     C           XP1       TAG
      *
     C                     SETOF                     01
     C           ATKR,A    LOKUPNTKR,B                   01
     C           *IN01     IFEQ '1'
     C           OKB,B     IFNE *BLANK
     C           AKB,A     IFNE OKB,B
     C                     ADD  1         B
     C                     GOTO XP1
     C                     END
     C                     END
      *
     C                     MOVE AKB,A     OKB,B
     C                     MOVE ATKR,A    OTKR,B
     C                     MOVE ASHN,A    OSHN,B
     C                     ELSE
      *
     C                     MOVE AKB,A     OKB,A
     C                     MOVE ATKR,A    OTKR,A
     C                     MOVE ASHN,A    OSHN,A
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C*------------------------------------------*
     C*     ...各かんばんマスター　変更...     *
     C*------------------------------------------*
     C                     Z-ADD1         A
     C           1         DO   15        A
      *
     C                     MOVE *BLANK    PZKMS
     C                     Z-ADD*ZERO     PZKMS2
     C                     MOVE *ZERO     PTKBI
      *
     C           PKAIS     IFEQ '2'
     C           USHIN     IFNE NSHN,A
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C                     MOVE OKB,A     WOKANB
     C                     MOVE NKB,A     WNKANB
     C                     MOVE OTKR,A    WOTKR
     C                     MOVE NTKR,A    WNTKR
     C                     Z-ADDNUKH,A    WNUKH
     C                     MOVE OSHN,A    WOHIN
     C                     MOVE NSHN,A    WSHIN
     C                     Z-ADDNSRY,A    CSRYO   90
      *
     C           *IN03     IFEQ '1'
     C                     SETON                     02
     C                     SETOF                     03
     C                     END
      *
     C           NSMI,A    IFEQ '*'
     C           NTKR,A    ANDEQ'------'
     C           NTKR,A    ANDEQ'++++++'
     C                     SETON                     02
     C                     END
      *
     C           OKB,A     IFEQ *BLANK
     C           NKB,A     ANDEQ*BLANK
     C                     ELSE
      *
     C*----------------------------------------------------------*
     C*     ...所番地・有効日－便・かんばん種類が変更前...     *
     C*     ...と　変更後　と　比較してかわらない場合...       *
     C*----------------------------------------------------------*
     C           NKHZ,A    IFEQ 0
     C           *IN02     IFEQ '1'
     C                     SETOF                     02
     C                     EXSR SBSYU
     C                     GOTO STP1
     C                     END
      *
     C                     MOVE NKB,A     WKANB
     C           OKB,A     IFEQ *BLANK
     C                     MOVE NKB,A     WOKANB
     C                     MOVE NTKR,A    WOTKR
     C                     END
      *
     C                     MOVE '10'      WKOSN
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C                     ELSE
      *
     C           NSMI,A    IFEQ '*'
     C                     SETON                     03
     C                     EXSR SBSYU
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C*--------------------------------*
     C*     ...取消　の　場合...     *
     C*--------------------------------*
     C           OTKR,A    IFNE *BLANK
     C           NTKR,A    ANDEQ*BLANK
     C           OSHN,A    IFEQ USHIN
     C                     MOVE OKB,A     WKANB   1
     C                     MOVE OSHN,A    WSHIN
     C                     Z-ADD0         CSRYO
     C                     MOVE '01'      WKOSN
     C                     ELSE
      *
     C                     MOVE OKB,A     WKANB
     C                     MOVE OSHN,A    WSHIN
     C                     MOVE '12'      WKOSN
     C                     END
      *
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C                     END
      *
     C*--------------------------------*
     C*     ...追加　の　場合...     *
     C*--------------------------------*
     C           OTKR,A    IFEQ *BLANK
     C           NTKR,A    ANDNE*BLANK
     C                     MOVE NKB,A     WKANB
     C                     MOVE '02'      WKOSN
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C                     END
      *
     C*----------------------------------*
     C*     ...所番地　の　変更...     *
     C*     ...かんばん種類同じ...     *
     C*----------------------------------*
     C           OKB,A     IFEQ NKB,A
     C           OTKR,A    IFNE NTKR,A
     C           OSHN,A    IFEQ NSHN,A
      *
     C*------------------------------------------*
     C*     ...代表品番がかわらない場合...     *
     C*------------------------------------------*
     C                     MOVE NKB,A     WKANB
     C                     MOVE '04'      WKOSN
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C                     ELSE
      *
     C*----------------------------------------*
     C*     ...代表品番がかわった場合...     *
     C*----------------------------------------*
     C           OSHN,A    IFEQ USHIN
     C                     MOVE OKB,A     WKANB
     C                     MOVE OSHN,A    WSHIN
     C                     Z-ADD0         CSRYO
     C                     MOVE '01'      WKOSN
     C                     EXSR SUBRTN
     C                     ELSE
      *
     C*----------------------------------------------*
     C*     ...１１№　かんばん設定数の減少...     *
     C*----------------------------------------------*
     C                     MOVE OKB,A     WKANB
     C                     MOVE OSHN,A    WSHIN
     C                     MOVE '11'      WKOSN
     C                     EXSR SUBRTN
     C                     END
      *
     C                     MOVE NKB,A     WKANB
     C                     MOVE NSHN,A    WSHIN
     C                     Z-ADDNSRY,A    CSRYO
     C                     MOVE '12'      WKOSN
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C*----------------------------------------------------------*
     C*     ...所番地・有効日－便・かんばん種類が変更前...     *
     C*     ...と　変更後　と　比較してかわらない場合...       *
     C*----------------------------------------------------------*
     C           OTKR,A    IFEQ NTKR,A
     C                     MOVE NKB,A     WKANB
     C                     MOVE '10'      WKOSN
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C                     END
     C                     ELSE
      *
     C*----------------------------------------------*
     C*     ...かんばん種類のみ変更した場合...     *
     C*----------------------------------------------*
     C           OTKR,A    IFEQ NTKR,A
     C                     MOVE OKB,A     WKANB
     C                     MOVE '09'      WKOSN
     C                     EXSR SUBRTN
      *
     C                     MOVE NKB,A     WKANB
     C                     MOVE '13'      WKOSN
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C                     END
      *
     C*----------------------------------*
     C*     ...所番地　の　変更...     *
     C*     ...かんばん種類違う...     *
     C*----------------------------------*
     C           OTKR,A    IFNE NTKR,A
     C                     MOVE OKB,A     WKANB
     C                     MOVE '06'      WKOSN
     C                     EXSR SUBRTN
      *
     C                     MOVE NKB,A     WKANB
     C                     MOVE '13'      WKOSN
     C                     EXSR SUBRTN
     C                     END
     C           STP1      TAG
      *
     C                     END
     C                     END
     C                     END
      *
     C                     CLOSEGHCWP22
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *
     C*------------------------------------*
     C*           サブルーチン           *
     C*     ...修正区分　の　場合...     *
     C*------------------------------------*
     C           SBSYU     BEGSR
     C           OKB,A     IFEQ NKB,A
     C                     MOVE NKB,A     WKANB
     C                     MOVE '07'      WKOSN
     C                     EXSR SUBRTN
     C                     ELSE
      *
     C                     MOVE OKB,A     WKANB
     C                     MOVE '08'      WKOSN
     C                     EXSR SUBRTN
      *
     C                     MOVE NKB,A     WKANB
     C                     MOVE '13'      WKOSN
     C                     EXSR SUBRTN
     C                     END
     C                     ENDSR
      *
      *
     C*----------------------------------------*
     C*            サブルーチン              *
     C*     ...AAVR20 メッキかんばん         *
     C*     ...AAVR21 引取かんばん           *
     C*     ...AAVR23 トンネルかんばん       *
     C*     ...AAVR24 小工程かんばん         *
     C*     ...AAVR26 完成品かんばん         *
     C*     ...AAVR28 半製品かんばん         *
     C*     ...AAVR33 小工程熱処理かんばん   *
     C*     ...AAVR35 指示かんばん           *
     C*     ...AAVR36 購買トンネルかんばん   *
     C*     ...AAVR37 熱処理メッキかんばん   *
     C*     ...AAVR39 樹脂かんばん           *
     C*     ...AAVR43 工程内かんばん         *
     C*     ...AAVR44 焼入かんばん           *
     C*----------------------------------------*
     C           SUBRTN    BEGSR
      *
     C                     MOVE WNUKH     CNUKH
      *
     C           CSRYO     DIV  $KCD      $HGEK   90
     C                     MVR            $HGEK1  90
     C           $HGEK1    IFNE 0
     C                     ADD  1         $HGEK
     C                     END
     C           $HGEK     IFEQ 0
     C                     Z-ADD1         $HGEK
     C                     END
      *
     C           $HGEK     MULT 20        $TGEK   90
     C           $TGEK     IFEQ 0
     C                     Z-ADD1         $TGEK
     C                     END
     C                     MOVE $TGEK     WSRYO
      *
     C*--------------------------------*
     C*  ..平準化確定発注ファイル..  *
     C*--------------------------------*
     C           WKANB     IFEQ '0'
      *
     C                     SETOF                     10
     C           KEY2      CHAINAGAPL311             10
     C           *IN10     IFEQ '0'
     C           CBSKJY    ANDEQ'D'
     C           CBSKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '0'
     C                     MOVE 'H'       PGEKH
     C                     END
      *
     C                     END
      *
     C           WKANB     IFEQ 'A'
     C                     CALL 'AAVR43'  ACALL
     C                     END
      *
     C           WKANB     IFEQ 'B'
     C                     CALL 'AAVR44'  ACALL
     C                     END
      *
     C           WKANB     IFEQ 'C'
     C                     MOVE $HGEK     WSRYO
     C                     CALL 'AAVR20'  CCALL
     C                     END
      *
     C           WKANB     IFEQ 'D'
     C                     MOVE $HGEK     WSRYO
     C                     CALL 'AAVR23'  ACALL
     C                     END
      *
     C           WKANB     IFEQ 'E'
     C                     MOVE $HGEK     WSRYO
     C                     CALL 'AAVR21'  CCALL
     C                     END
      *
     C           WKANB     IFEQ 'F'
     C                     MOVE $HGEK     WSRYO
     C                     CALL 'AAVR35'  ACALL
     C                     END
      *
     C           WKANB     IFEQ 'G'
     C                     CALL 'AAVR39'  ACALL
     C                     END
      *
     C           WKANB     IFEQ '0'
     C                     MOVE $HGEK     WSRYO
     C                     CALL 'AAVR26'  BCALL
     C                     END
      *
     C           WKANB     IFEQ '1'
     C                     CALL 'AAVR24'  ACALL
     C                     END
      *
     C           WKANB     IFEQ '2'
     C                     CALL 'AAVR33'  ACALL
     C                     END
      *
     C           WKANB     IFEQ '4'
     C                     CALL 'AAVR36'  ACALL
     C                     END
      *
     C           WKANB     IFEQ '6'
     C                     MOVE $HGEK     WSRYO
     C                     CALL 'AAVR28'  CCALL
     C                     END
      *
     C           WKANB     IFEQ '7'
     C                     CALL 'AAVR37'  ACALL
     C                     END
      *
     C                     ENDSR
