     H            Y/
     F***************************************************
     F*  ASJ PART RESULT                              *
     F*                                                 *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FAAPTL01 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FAB#PL18 IF  E           K        DISK
     FGDGWP67 O   E                    DISK
      *------------------------------------------------------------
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80STRT
     I                                        1   40A2TAYY
     I                                        5   60A2TAMM
     I                                        7   80A2TADD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C                     EXSR #WRT
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@YM    6
      *
     C           K#KEY     KLIST
     C                     KFLD           L5SHN1
     C                     KFLD           L5SHN2
     C                     KFLD           L5SHN3
     C           K#APP     KLIST
     C                     KFLD           L5SHN1
     C                     KFLD           L5SHN2
     C                     KFLD           L5SHN3
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
      *
     C                     MOVELP@YM      K@YY
     C                     MOVE P@YM      K@MM
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR 2ND SCREEN
      *------------------------------------------------------
     C           #WRT      BEGSR
      *
     C           *IN80     DOUEQ*ON
     C                     READ AAPTL01                  80
     C           *IN80     IFEQ *OFF
     C           L5SKJY    ANDEQ*BLANK
     C           L5STHZ    ANDEQ99999999
     C           L5BMON    ANDEQ8990
     C           L5TKR1    ANDEQ'0'
      *
     C                     CLEARGDGWP671
     C                     MOVE L5SHN1    WPART1
     C                     MOVE L5SHN2    WPART2
     C                     MOVE L5SHN3    WPART3
     C                     MOVE L5TKRO    WLOC
      *  MONTHLY SETTING
     C           K#KEY     CHAINFCEPL01              90
     C           *IN90     IFEQ *OFF
     C           A2SSYS    ANDNE*ZERO
     C                     Z-ADDA2GEKN    WSETQ
     C                     Z-ADDA2SSYS    WQBOX
     C                     Z-ADDSTRT      WQSTDT
     C                     ENDIF
      *
     C* ACTUAL
     C           K#APP     SETLLAB#PL18
     C           *IN90     DOUEQ*ON
     C           K#APP     READEAB#PL18                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ' '
     C                     ADD  BASRYO    WACTQ
     C                     ENDIF
     C                     ENDDO
     C                     WRITEGDGWP671
     C           K#KEY     SETGTAAPTL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
