TCH67F*    TCH 07/28/05   ASJ COPIED FROM AB#R4Q
     F******************************* AB#R2E **
     FASJ     IP  F     800            DISK
     FAB#WASJ O   E                    DISK
      *--------------------------------------------------------
     E                    AY        800  1
     E                    DAT       500  8 0
     E                    QTY       500  9 0
     E                    ORD       500  8
     E                    A2          2  1
     E                    A9          9  1
     E                    A9X         9  1
     E                    AX         17  1
      *--------------------------------------------------------
     IASJ     AA  01
     I                                        1  12 SEQ
     I                                       13 268 DAT1
     I                                      269 524 DAT2
     I                                      525 780 DAT3
     I            DS
     I                                        1   8 YMD
     I                                        1   2 W20
     I                                        3   4 YY
     I                                        5   6 MM
     I                                        7   8 DD
     I            DS
     I                                        1   6 AWMHNX
     I                                        1   1 AW1
     I                                        3   6 AW2
     I            DS
     I                                        1  17 AWPART
     I                                        1   5 AWMHN1
     I                                        7  11 AWMHN2
     I                                       12  16 AWMHN3
      *
     C           *ENTRY    PLIST
     C                     PARM           PID     1
     C                     PARM           #BIN    1
      *
     C                     MOVE '0'       *IN98
     C                     Z-ADD8990      AWTOKU
     C                     Z-ADD8990      AWNONY
     C                     MOVE '0'       AWNKOJ
     C                     MOVE '00  '    AWNUKE
     C                     MOVE '000000'  AWSBAN
     C           #BIN      IFEQ '1'
     C                     MOVE '1'       AWBIN#
     C                     ELSE
     C                     MOVE '2'       AWBIN#
     C                     ENDIF
      *
     C                     MOVE '20'      W20
      *
     C                     MOVEADAT1      AY,1
     C*                    MOVEADAT2      AY,257
     C*                    MOVEADAT3      AY,513
      * ++++++++++++
      * HEADER
      * ++++++++++++
 B0  C           *IN99     IFEQ *OFF
      *
     C                     Z-ADD1         X       30
     C           'ORDER N' SCAN DAT1      X              10
     C  N10      'Order n' SCAN DAT1      X              10
 B1  C           *IN10     IFEQ *OFF
     C                     GOTO @END
 E1  C                     ENDIF
 E0  C                     ENDIF
      * ++++++++++++
      * DETAIL
      * ++++++++++++
     C                     MOVE *ON       *IN99
      * ------------
      * ORDER#
      * ------------
 B0  C           *IN98     IFEQ '0'
     C                     Z-ADD0         W
     C           'IAF-'    SCAN DAT1      X              10
     C  N10      'IAF-'    SCAN DAT1      X              10
 B1  C           *IN10     IFEQ *OFF
     C                     GOTO @END
     C                     ELSE
     C                     ADD  4         X
B2   C           X         DO   15        G       30
B3   C           AY,G      IFEQ ','
     C                     LEAVE
E3   C                     ENDIF
     C                     ADD  1         W
     C                     MOVE AY,G      AX,W
E2   C                     ENDDO
     C                     MOVEAAX        AWORDN
 E1  C                     ENDIF
 E0  C                     ENDIF
      *
      * ------------
      * PART#
      * ------------
      *
     C                     CLEARAX
     C                     Z-ADD0         W
     C                     ADD  1         G
B0   C           G         DO   45        Y       30
B1   C           AY,Y      IFEQ ','
     C                     LEAVE
E1   C                     ENDIF
     C                     ADD  1         W
     C                     MOVE AY,Y      AX,W
E0   C                     ENDDO
     C                     MOVEAAX        AWPART
      *
      * ------------
      * QTY/BOX
      * ------------
      *
     C                     CLEARA9
     C                     Z-ADD0         W
     C                     ADD  1         Y
B0   C           Y         DO   65        K       30
B1   C           AY,K      IFEQ ','
     C                     LEAVE
E1   C                     ENDIF
     C                     ADD  1         W
     C                     MOVE AY,K      A9,W
E0   C                     ENDDO
      *
     C                     MOVE '0'       A9X
     C                     Z-ADD9         W
     C                     Z-ADD9         V       30
B0   C                     DO   9
B1   C           A9,W      IFNE *BLANK
     C                     MOVE A9,W      A9X,V
     C                     SUB  1         V
E1   C                     ENDIF
     C                     SUB  1         W
B1   C           W         IFEQ *ZERO
     C                     LEAVE
E1   C                     ENDIF
E0   C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVE @9C       @9      90
     C                     Z-ADD@9        AWSYOS
      * SKIP
     C           ','       LOKUPAY,K                     10
     C                     ADD  1         K
     C   10      ','       LOKUPAY,K                     10
     C                     ADD  1         K
     C   10      ','       LOKUPAY,K                     10
      * ------------
      * QTY
      * ------------
      *
     C                     Z-ADD0         Y
      *
     C           K         ADD  1         Z       30
     C                     Z-ADD*ZERO     W       30
     C                     MOVE *BLANK    A9
B0   C           Z         DO   90        Y
B1   C           AY,Y      IFNE ','
     C                     LEAVE
E1   C                     ENDIF
E0   C                     ENDDO
      *
B0   C           Y         DO   70        G       30
B1   C           AY,G      IFEQ ','
     C                     LEAVE
E1   C                     ENDIF
     C                     ADD  1         W
     C                     MOVE AY,G      A9,W
E0   C                     ENDDO
      *
     C                     MOVE '0'       A9X
     C                     Z-ADD9         W
     C                     Z-ADD9         V       30
B0   C                     DO   9
B1   C           A9,W      IFNE *BLANK
     C                     MOVE A9,W      A9X,V
     C                     SUB  1         V
E1   C                     ENDIF
     C                     SUB  1         W
B1   C           W         IFEQ *ZERO
     C                     LEAVE
E1   C                     ENDIF
E0   C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVE @9C       @9      90
     C                     Z-ADD@9        AWSRYO
      *
      * SKIP
     C           ','       LOKUPAY,K                     10
     C                     ADD  1         K
     C   10      ','       LOKUPAY,K                     10
     C                     ADD  1         K
     C   10      ','       LOKUPAY,K                     10
     C                     ADD  1         K
     C   10      ','       LOKUPAY,K                     10
      * ------------
      * SHIP DATE
      * ------------
      *MM
     C           '/'       SCAN DAT1      X              10
 B0  C           *IN10     IFEQ *ON
     C           X         SUB  2         L2      30
     C           X         SUB  1         L3      30
     C           X         ADD  1         X1      30
     C           X         ADD  2         X2      30
     C           X         ADD  4         X4      30
     C           X         ADD  5         X5      30
     C                     MOVELAY,L2     MM      2
     C                     MOVE AY,L3     MM      2
     C                     MOVELAY,X1     DD      2
     C                     MOVE AY,X2     DD      2
     C                     MOVELAY,X4     YY      2
     C                     MOVE AY,X5     YY      2
 E0  C                     ENDIF
      *
     C                     MOVE YMD       AWSHDT
      * ------------
      * WRITE
      * ------------
      *
     C           AWSRYO    IFNE 0
     C                     WRITEAB#WASJ1
     C                     MOVE '1'       PID
     C                     CLEARAB#WASJ1
     C                     ENDIF
