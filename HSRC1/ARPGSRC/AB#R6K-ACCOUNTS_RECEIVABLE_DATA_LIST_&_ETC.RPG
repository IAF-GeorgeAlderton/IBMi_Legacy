     C**         X         IFNE 16
JW2  C           X         IFNE 17
     C                     EXSR #DATX
     C                     ELSE
     C                     EXSR #DATX1
     C                     ENDIF
      *
     C                     Z-ADD@DATE     DAT,X
     C                     MOVEL@TIME     TIM,X
JW2   * SET INDICATOR
 .   C           DAT,X     IFEQ TODAY
 .   C           X         ADD  20        IY
 .   C                     MOVE *ON       *IN,IY
JW2  C                     ENDIF
      *
