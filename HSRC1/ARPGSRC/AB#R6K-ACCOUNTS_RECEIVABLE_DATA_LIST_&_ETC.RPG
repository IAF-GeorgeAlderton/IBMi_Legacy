     C                     Z-ADDCUST      Y       20
     C           NAM,Y     IFEQ *BLANK
     C           DAT,Y     OREQ *ZERO
     C                     SETON                     6199
     C                     END
     C                     END
      *
     C           SLCT      IFLT '1'
     C           SLCT      ORGT '5'
     C                     SETON                     6399
