TCHK4C                     Z-ADDTIM,Y     P@TIME
     C                     MOVELSLCT      P@SLCT
      * NOT FORD
     C           CUST      IFNE 30
     C           SLCT      IFNE '2'
     C           SLCT      ANDNE'4'
     C**                   CALL 'AB#R6H'  P#CALL
JW2  C                     MOVELP@DATE    X@DATE
"    C                     MOVELP@TIME    X@TIME
"    C                     CALL 'AB#C6S'  X#CALL           OUT TO CSV
     C                     ENDIF
     C           SLCT      IFNE '1'
