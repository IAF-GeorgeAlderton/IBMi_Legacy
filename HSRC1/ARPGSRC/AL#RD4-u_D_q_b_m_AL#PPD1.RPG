     FAL#WPD9 IF  E           K        DISK
     FAL#PPD1 O   E                    DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     READ AL#WPD91                 22
     C           *IN22     DOWEQ'0'
     C           W9SEL     IFEQ '1'
     C                     EXSR #SB500
     C                     ENDIF
     C                     READ AL#WPD91                 22
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AL#PPD1
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C                     CLEARAL#PPD11
     C                     Z-ADDSDATE     CDKOHZ
     C                     Z-ADDSTIME     CDKOTI
     C                     MOVELW#USER    CDKOME
     C                     MOVELW9DATA    CDDATA
     C                     Z-ADDW9FIXD    CDFIXD
     C                     Z-ADDW9FIXT    CDFIXT
     C                     Z-ADDW9TIMS    CDTIMS
     C                     MOVELW9TRKB    CDTRKB
     C                     MOVELW9IAFB    CDIAFB
     C                     Z-ADDSDATE     CDCRHZ
     C                     Z-ADDSTIME     CDCRTI
     C                     Z-ADD0         CDNKHZ
     C                     Z-ADD0         CDNKTI
     C                     WRITEAL#PPD11
      *
     CSR         ESB500    ENDSR
