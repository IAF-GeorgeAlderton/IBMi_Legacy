     H            Y.
     F** AB#R1N ****************************************************************
     F*  ORDER CHANGE HISTORY (2 LINES)                                        *
     F*                                                                        *
     F*  JW    2018.03.09                                                      *
JW1  F*  JW    2021.04.20 ADD INVOICE# IN THE 2ND LINE                         *
     F************************ AB#R40 ******************************************
     FAB#PW1N CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FAB#HL10 IF  E           K        DISK
     FAB#WHP10UF  E           K        DISK                      A
JW1  FAB#PL13 IF  E           K        DISK
     F****************************************************************
     E**                  CMD     1   2 78
     E                    ERR     1   2 78
     E****************************************************************
     I@INFDS      DS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   80BANOHZ
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I            DS
     I                                        1   80W@NOHZ
     I                                        1   40W@NOYY
     I                                        5   60W@NOMM
     I                                        7   80W@NODD
     I            DS
     I                                        1  30 DAMANI
     I                                        1   8 WMANI2
     I                                       10  16 WMANI3
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80AHYMD
     I                                        1   40AHNOYY
     I                                        5   60AHNOMM
     I                                        7   80AHNODD
     I            DS
     I                                        1  20 AHMHIN
     I                                        1   5 AHMHN1
     I                                        6  10 AHMHN2
     I                                       11  15 AHMHN3
     I                                       16  20 AHMHN4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I**************************************************************
      *
     C           *ENTRY    PLIST
     C                     PARM           P@SDAT  8
     C                     PARM           P@EDAT  8
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
      *
     C                     Z-ADD*DATE     D@FROM
     C                     Z-ADD*DATE     D@TO
      *
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C           @@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------------
     C           *INZSR    BEGSR
      *------------------------------------------------------------
     C           K#HL      KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
      *
JW1  C           K#PL13    KLIST
 .   C                     KFLD           K#NONY  40
 .   C                     KFLD           K#NOYY  40
 .   C                     KFLD           K#NOMM  20
 .   C                     KFLD           K#NODD  20
 .   C                     KFLD           K#NUKE  4
 .   C                     KFLD           K#MHN1  5
 .   C                     KFLD           K#MHN2  5
 .   C                     KFLD           K#MHN3  5
 .   C                     KFLD           K#MHN4  5
 .   C                     KFLD           K#ODRN 10
JW1  C                     KFLD           K#NOBN  20
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     MOVE '01'      @@ID    2
      *
     C           P@HIN1    IFNE *BLANK
     C                     MOVELP@SDAT    D@FROM
     C                     MOVELP@EDAT    D@TO
     C                     EXSR #SET1
     C           RRN1      IFGT *ZERO
     C                     MOVE '02'      @@ID
     C                     ELSE
     C                     MOVE '99'      @@ID
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------------------
     C           #SCRN1    BEGSR
      *----------------------------------------------------------------
     C**                   MOVE CMD,1     D@CMD
     C**                   WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
      * F3:END
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
      * ENTER KEY
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C           RRN1      IFGT *ZERO
     C                     MOVE '02'      @@ID
     C                     ELSE
     C                     MOVEA'111'     *IN,61
     C                     MOVE ERR,1     D@MSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *----------------------------------------------------------------
     C           #CLR      BEGSR
      *----------------------------------------------------------------
     C                     MOVE *BLANK    D@MSG
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *OFF      *IN99
      *
     C                     ENDSR
      *----------------------------------------------------------------
     C           #CHK1     BEGSR
      *----------------------------------------------------------------
     C                     EXSR #CLR
      *
     C           D@FROM    IFEQ *ZERO
     C           D@TO      ANDEQ*ZERO
     C  N99                MOVE ERR,2     D@MSG
     C                     SETON                     626399
     C                     ENDIF
      *
     C           D@TO      IFLT D@FROM
     C  N99                MOVE ERR,2     D@MSG
     C                     SETON                     626399
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------------------
     C           #SET1     BEGSR
      *----------------------------------------------------------------
      * CLEAR SUB FILE
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1
      *
      * CLEAR AB#WHP10
     C           *LOVAL    SETLLAB#WHP10
     C                     DO   *HIVAL
     C                     READ AB#WHP10                 98
     C   98                LEAVE
     C                     DELETAB#HP10A
     C                     ENDDO
      *
     C                     Z-ADDD@FROM    K@YMD
     C           K#HL      SETLLAB#HL10
     C           *IN80     DOUEQ*ON
     C                     READ AB#HL10                  80
     C           *IN80     IFEQ *OFF
     C           AHYMD     IFGT D@TO
     C                     LEAVE
     C                     ENDIF
     C*
     C           P@HIN1    IFNE *BLANK
     C           P@HIN1    IFEQ AHSHN1
     C           P@HIN2    ANDEQAHSHN2
     C           P@HIN3    ANDEQAHSHN3
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C                     ENDIF
JW1   * GET INVOICE#
 .   C                     MOVE *BLANK    AHINVN
 .   C                     Z-ADDAHNONY    K#NONY  40
 .   C                     Z-ADDAHNOYY    K#NOYY  40
 .   C                     Z-ADDAHNOMM    K#NOMM  20
 .   C                     Z-ADDAHNODD    K#NODD  20
 .   C                     MOVELAHNUKE    K#NUKE  4
 .   C                     MOVELAHMHN1    K#MHN1  5
 .   C                     MOVELAHMHN2    K#MHN2  5
 .   C                     MOVELAHMHN3    K#MHN3  5
 .   C                     MOVELAHMHN4    K#MHN4  5
 .   C                     MOVELAHODRN    K#ODRN 10
 .   C                     Z-ADDAHNOBN    K#NOBN  20
 .   C           K#PL13    SETLLAB#PL13
 .   C                     DO   *HIVAL
 .   C           K#PL13    READEAB#PL13                  97
 .   C   97                LEAVE
 .    *
 .   C**         BASKJY    IFEQ 'D'
 .   C**                   ITER
 .   C**                   ENDIF
 .    *
 .   C                     MOVELBAINVN    AHINVN
 .   C                     LEAVE
JW1  C                     ENDDO
      *
     C                     WRITEAB#HP10A
     C                     ENDIF
     C*
     C                     ENDDO
     C*
     C           *LOVAL    SETLLAB#WHP10
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AB#WHP10                 80
     C   80                LEAVE
      *
     C                     MOVE AHNONY    S@NONY
     C                     MOVE AHNUKE    S@NUKE
     C                     Z-ADDAHYMD     S@SHDT
     C                     Z-ADDAHNOBN    S@BIN
     C                     MOVELAHODRN    S@ODRN
     C                     Z-ADDAHQTY1    S@QTY1
     C                     Z-ADDAHQTY2    S@QTY2
     C                     Z-ADDAHKYMD    S@CHDT
     C                     MOVE AHSHN1    S@PRT1
     C                     MOVE AHSHN2    S@PRT2
     C                     MOVE AHSHN3    S@PRT3
      *
     C**                   Z-ADDAHKYMD    S@KYMD
     C                     Z-ADDAHKTIM    S@KTIM
     C                     MOVELAHKMID    S@KUSR
     C**                   MOVE AHKMID    S@KWS
     C**                   MOVELAHKPGM    S@KPGM
      *
JW1  C                     MOVELAHINVN    S@INVN
 .   C                     MOVELAHMHN1    S@MHN1
 .   C                     MOVELAHMHN2    S@MHN2
 .   C                     MOVELAHMHN3    S@MHN3
 .    * GET SBAN
 .   C                     MOVELAHNONY    $NONY
 .   C                     MOVELAHNKOJ    $NKOJ
 .   C                     MOVELAHNUKE    $NUKE
 .   C                     MOVELAHMHIN    $MHIN
 .   C                     MOVELAHYMD     $NOHZ
 .   C                     CALL 'UTLR33A'
 .   C                     PARM           $NONY   4
 .   C                     PARM           $NKOJ   1
 .   C                     PARM           $NUKE   4
 .   C                     PARM           $MHIN  20
 .   C                     PARM           $NOHZ   8
 .   C                     PARM           $SBAN   6
JW1  C                     MOVEL$SBAN     S@SBAN
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C*
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------------------
     C           #SCRN2    BEGSR
      *----------------------------------------------------------------
      *
     C**                   MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
      * F3:END
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
      * F12:BACK
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      @@ID
     C           P@HIN1    IFNE *BLANK
     C                     MOVE '99'      @@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
** ERR
 NO DATA.
 DATE ERROR.
