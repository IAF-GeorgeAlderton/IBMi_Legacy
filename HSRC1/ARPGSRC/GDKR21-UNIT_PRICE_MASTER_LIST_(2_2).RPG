      *** GDKR21 *************************************
      *        UNIT PRICE MASTER LIST (2/2)          *
      *                          LIST-UP             *
      *  G.B.C                       2000/11/15      *
      ************************************************
     H            Y/                                    1
     F*
     FGDKWP21 IP  F     128            DISK
      *
      *        DETAIL CODE MANAGEMENT RECORD .LAYOUT ..LOGICAL FILE .. *
     FFGBPL01 IF  E           K        DISK
      *
      *
     FQPRINT  O   F     132     OF     PRINTER
     E*================================================================
     E                    PT      1  10  1   PTN    30
     I*================================================================
     IGDKWP21 AA  01
     I                                        1   4 D1VEND
     I                                        5   5 D1TYPE
     I                                        6   9 ISVENDL3
     I                                       10  29 ISHIN L1
     I                                       30  59 ISNAME
     I                                       60  60 ISTYPEL2
     I                                       61  680ISSTHZ
     I                                       69  760ISENHZ
     I                                       77  905ISTKP1
     I                                       91 1045ISTKP2
     I                                      105 107 ISKIGO
     I                                      108 1125ISRATE
     I            DS
     I                                        1  20 D1HIN
     I                                        1   5 D1HIN1
     I                                        6  10 D1HIN2
     I                                       11  12 D1HIN3
     I                                        1   2 D1KAT1
     I                                        3   6 D1KAT2
     I                                        7   7 D1KAT3
     I                                        8   8 D1KAT4
     I            DS
     I                                        1  14 WWHIN
     I                                        1   5 WWHIN1
     I                                        6   6 WWH1
     I                                        7  11 WWHIN2
     I                                       12  12 WWH2
     I                                       13  14 WWHIN3
     I            DS
     I                                        1  14 WWKATA
     I                                        1   2 WWKAT1
     I                                        3   3 WWKA1
     I                                        4   7 WWKAT2
     I                                        8   8 WWKA2
     I                                        9   9 WWKAT3
     I                                       10  10 WWKA3
     I                                       11  11 WWKAT4
     C*================================================================
     C*           PARM LIST                                          *
     C*================================================================
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C*================================================================
     C*           KEY LIST                                           *
     C*================================================================
     C*================================================================
     C*           MAIN ROUTINE                                       *
     C*================================================================
     C  N10                TIME           WTIME   60
     C  N10                SETON                     10
     C   L3                EXSR #L3                        VENDOR
     C   L2                EXSR #L2                        PART TYPE
     C   L1                EXSR #L1                        PART NO.
     C*
     C   OF                SETON                     11
     C   OF                EXCPT$HED
     C   OF                SETOF                     OF
     C   11                EXCPT$SPACE
     C                     EXCPT$LIST
     C                     SETOF                     11
     C*================================================================
     C*  L3  < VENDOR >
     C*================================================================
     C           #L3       BEGSR
     C*
     C                     MOVE *BLANK    L@VDNM 30
     C                     MOVELISVEND    B2CODE
     C           B2CODE    CHAINFGBPL011             90
     C  N90                MOVELB2SMEI    L@VDNM
     C*
     C                     ENDSR
     C*================================================================
     C*  L2  < PART TYPE >
     C*================================================================
     C           #L2       BEGSR
     C*
     C                     MOVE *BLANK    L@PTNM 30
     C                     Z-ADD1         J       20
     C           ISTYPE    LOKUPPT,J                     90
     C   90                MOVELPTN,J     L@PTNM
     C*
     C                     SETON                     OF
     C*
     C                     ENDSR
     C*================================================================
     C*  L1  < PART NO.>
     C*================================================================
     C           #L1       BEGSR
     C*
     C                     SETON                     11
     C                     MOVELISHIN     D1HIN
     C                     MOVELISHIN     L@HIN  20
     C*
S1   C           ISTYPE    IFEQ '0'                        FNINSHED PARTS
     C           ISTYPE    OREQ '3'                        WASHER
     C           ISTYPE    OREQ '6'                        HALF-FINISHED PARTS
     C                     MOVE *BLANK    L@HIN
     C                     MOVE *BLANK    WWHIN
     C                     MOVE D1HIN1    WWHIN1
     C                     MOVE D1HIN2    WWHIN2
     C                     MOVE D1HIN3    WWHIN3
     C                     MOVE '-'       WWH1
 S2  C           WWHIN3    IFNE *BLANK
     C                     MOVE '-'       WWH2
 E2  C                     ENDIF
     C                     MOVELWWHIN     L@HIN
E1   C                     ENDIF
     C*
S1   C           ISTYPE    IFEQ 'K'                        DIE
     C                     MOVE *BLANK    L@HIN
     C                     MOVE *BLANK    WWKATA
     C                     MOVE D1KAT1    WWKAT1
     C                     MOVE D1KAT2    WWKAT2
     C                     MOVE D1KAT3    WWKAT3
     C                     MOVE D1KAT4    WWKAT4
     C                     MOVE '-'       WWKA1
     C                     MOVE '-'       WWKA2
     C                     MOVE '-'       WWKA3
 S2  C           WWKAT4    IFEQ *BLANK
     C                     MOVE ' '       WWKA3
  S3 C           WWKAT3    IFEQ *BLANK
     C                     MOVE ' '       WWKA2
  E3 C                     ENDIF
 E2  C                     ENDIF
     C                     MOVELWWKATA    L@HIN
E1   C                     ENDIF
     C*
     C                     ENDSR
     C*================================================================
     C*================================================================
     O*  PRINT FILE
     O*================================================================
     OQPRINT  E   02           $HED
     O*                                 131 '+-------------------+'
     O                                  131 '                     '
     O        E   03           $HED
     O*                                 131 '|IN CHARGE|PUBLISHER|'
     O                                  131 '                     '
     O        E   04           $HED
     O                                   89 'TIME'
     O                         WTIME     98 '  :  :  '
     O*                                 131 '|         |         |'
     O*                        WNS      130
     O        E   05           $HED
     O                                   10 'GCKR21-1'
     O                                   55 '** IMPORT UNIT '
     O                                 +  0 'PRICE MASTER LIST **'
     O                                   89 'DATE'
     O                         UDATE Y   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O*                                 131 '+-------------------+'
     O*
     O        E   07           $HED
     O                                   10 'VENDOR   '
     O                         ISVEND    16
     O                                   18 ':'
     O                         L@VDNM    49
     O        E   08           $HED
     O                                   10 'PART TYPE'
     O                         ISTYPE    16
     O                                   18 ':'
     O                         L@PTNM    49
     O        E   10           $HED
     O                                    9 'PART NO.'
     O                                   41 'UNIT PRICE BY SEA'
     O                                   62 'UNIT PRICE BY AIR'
     O                                   76 'START DATE'
     O                                   88 'END DATE'
     O*          1         2         3         4         5         6
     O* 12345678901234567890123456789012345678901234567890123456789012
     O*  PART NO.               UNIT PRICE BY SEA    UNIT PRICE BY AIR
     O*  12345678901234567890   123,456,789.00000    123,456,789.00000
     O*          7         8         9
     O* 12345678901234567890123456789012345678901234567890123456789012
     O*AIR    START DATE    END DATE
     O*000    9999/99/99    9999/99/99
     O        E 1              $SPACE
     O                                   21 ' '
     O*
     O        E 1              $LIST
     O                 11      L@HIN     21
     O                         ISTKP11   41
     O                         ISTKP21   62
     O                         ISSTHZ    76 '    /  /  '
     O                         ISENHZ    90 '    /  /  '
     O*================================================================
**  PT
0FINISHED PARTS
6HALF-FINESHED PARTS
3WASHER
MMACHINERY
WWIRE
SINDIRECT MATERIAL
RWIRE ROD
PMACHINERY PARTS
KDIE
ZALL
