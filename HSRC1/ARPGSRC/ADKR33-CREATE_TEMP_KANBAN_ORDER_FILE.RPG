     C                     Z-ADDW2BMON    D3BMON
     C                     MOVELW2ZENO    D3ZENO
     C                     MOVELW2BLOK    D3BLOK
     C                     Z-ADDW2CODE    D3CODE
     C                     MOVELW2TYPE    D3TYPE
     C                     MOVELW2MEK1    D3MEK1
     C                     MOVELW2MEK2    D3MEK2
     C                     MOVELW2MEK3    D3MEK3
     C                     Z-ADDW2MKLT    D3MKLT
     C                     MOVELW2COLR    D3COLR
     C                     Z-ADDW2SIZE    D3SIZE
