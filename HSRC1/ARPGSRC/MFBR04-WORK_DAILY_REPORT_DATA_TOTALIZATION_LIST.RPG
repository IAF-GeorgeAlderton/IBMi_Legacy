      * 工場 *
     C                     MOVE @KJYU     KJYU    40
     C           KJYU      CABEQ9999      STEP01
     C           KJYU      CHAINMFEPL401             01
     C           *IN,01    IFEQ '0'
     C           MHSKJY    ANDEQ'D'
     C           MHSKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,01
