     C                     SETON                     99
     C                     GOTO LOP1
     C                     END
     C           STEP01    TAG
      * 集計期間 *
     C                     MOVE @HIZ1     HIZ1    80
     C                     MOVE @HIZ2     HIZ2    80
     C           HI1Y      IFLT 1988
     C                     MOVE ER,2      MSG
     C                     SETON                     0299
     C                     GOTO LOP1
     C                     END
     C           HI1M      IFGE 1
     C           HI1M      ANDLE12
     C                     ELSE
     C                     MOVE ER,3      MSG
     C                     SETON                     0299
     C                     GOTO LOP1
     C                     END
     C           HI1D      IFGE 1
     C           HI1D      ANDLE31
     C                     ELSE
     C                     MOVE ER,4      MSG
     C                     SETON                     0299
     C                     GOTO LOP1
     C                     END
      *
     C           HI2Y      IFLT 1988
     C                     MOVE ER,2      MSG
