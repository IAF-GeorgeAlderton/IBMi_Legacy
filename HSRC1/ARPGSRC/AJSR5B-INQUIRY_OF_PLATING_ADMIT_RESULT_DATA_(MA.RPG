     O                                      ','
     O                         J1ZETI
     O                                      ','
     O                         J1THAI
     O                                      ','
     O                         J1PAG1
     O                                      ','
     O                         J1PAG2
     O                                      ','
     O                         J1PAG3
     O                                      ','
     O                         J1PAG4
     O                                      ','
     O                         J12JKA
     O                                      ','
     O                         J1TASY
     O                                      ','
     O                         J1SYKO
     O                                      ','
     O                         J1HKBR
     O                                      ','
      *
     O                         J1MKSU       '0 . '
     O                                      ','
     O                         J1IROK
     O                                      ','
     O                         J1SYUY
     O                                      ','
     O                         J1HKFA
     O                                      ','
     O                         J1TANJ
     O                                      ','
     O                         J1WKHZ
     O                                      ','
     O                         J1WKTM
     O                                      ','
