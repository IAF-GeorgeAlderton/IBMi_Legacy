     H            Y.
      ** AJSR5B *******************************************************
      * INQUIRY OF PLATING ADMIT RESULT DATA. (MACHINE NO)*
      * PROGRAM ID.  : AJSR5C. <RPG>
      * CREATE DATE. : 2015/07/07
      * AUTHOR.      : KIRI
      ******************************************************* AJSR5B **
      *
      *  PLATING  ADMIT RESULTS FILES.     *
     FAJSPL15 IF  E           K        DISK
      *
      *  WORKER CD MASTER FILES.           *
     FAJSPLCD IF  E           K        DISK
      *
     FAJSWP5B O   F    1024            DISK
      *================================================================
     I            DS
     I                                        1  120SHIZT
     I                                        1   80SHIZ
     I                                        1   40SYY
     I                                        5   60SMM
     I                                        7   80SDD
     I                                        9  120STIM
     I                                        9  100STIMH
     I                                       11  120STIMM
     I            DS
     I                                        1  120EHIZT
     I                                        1   80EHIZ
     I                                        1   40EYY
     I                                        5   60EMM
     I                                        7   80EDD
     I                                        9  120ETIM
     I                                        9  100ETIMH
     I                                       11  120ETIMM
     I            DS
     I                                        1  14 HIN
     I                                        1   5 J1HIN1
     I                                        6   6 HINA
     I                                        7  11 J1HIN2
     I                                       12  12 HINB
     I                                       13  14 J1HIN3
     I            DS
     I                                        1   80J1SKHZ
     I                                        1   40J1SKYY
     I                                        5   60J1SKMM
     I                                        7   80J1SKDD
     I            DS
     I                                        1  120J1WKHT
     I                                        1   80J1WKHZ
     I                                        1   40J1WINY
     I                                        5   60J1WINM
     I                                        7   80J1WIND
     I                                        9  120J1WKTM
     I                                        9  100J1WINJ
     I                                       11  120J1WINF
     I            DS
     I                                        1   80J1KEHZ
     I                                        1   40J1KEIY
     I                                        5   60J1KEIM
     I                                        7   80J1KEID
     I            DS
     I                                        1   40J1KETM
     I                                        1   20J1KEIJ
     I                                        3   40J1KEIF
      *================================================================
     C           *ENTRY    PLIST
     C                     PARM           P@MACH  2        機番
     C                     PARM           P@SHZ   80       開始日付
     C                     PARM           P@STM   40           時刻
     C                     PARM           P@EHZ   80       終了日付
     C                     PARM           P@ETM   40           時刻
     C*
     C                     EXSR #MAIN
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      *===============================================================
     C           #MAIN     BEGSR
     C                     MOVEA*ALL'0'   *IN
      *
     C                     MOVELP@MACH    MACH    2
     C                     Z-ADDP@SHZ     SHIZ
     C                     Z-ADDP@STM     STIM
     C                     Z-ADDP@EHZ     EHIZ
     C                     Z-ADDP@ETM     ETIM
      *
     C           KEY1      KLIST
     C                     KFLD           MACH
     C                     KFLD           SYY
     C                     KFLD           SMM
     C                     KFLD           SDD
     C                     KFLD           STIMH
     C                     KFLD           STIMM
      *
      *
     C           KEY1      SETLLAJSPL15
      *-------------------------
     C                     DO   *HIVAL
     C           MACH      READEAJSPL15                  90
     C   90                LEAVE
      *
     C           J1SKJY    IFEQ 'D'
     C           J1SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C*
     C           J1WKHT    IFGT EHIZT
     C                     LEAVE
     C                     ENDIF
     C*
     C                     MOVEL'-'       HINA
     C                     MOVEL'-'       HINB
     C           J1HIN3    IFEQ *BLANK
     C                     MOVEL' '       HINB
     C           J1HIN2    IFEQ *BLANK
     C                     MOVEL' '       HINA
     C                     ENDIF
     C                     ENDIF
     C*
     C                     MOVE *BLANK    #TOCM  20
     C           J1TOCD    CHAINAJSPLCD1             91
     C           JASKJY    IFEQ ' '
     C           *IN91     ANDEQ*OFF
     C                     MOVE JAWKNM    #TOCM
     C                     ENDIF
      *
     C  N10                EXCPT$HED
     C                     EXCPT$DATA
     C                     SETON                     10
     C                     ENDDO
      *-------------------------
      *
     C                     ENDSR
      *===============================================================
     OAJSWP5B E                $HED
     O                                      'MACHINE NO,'
     O                                      'ADMIT DATE FROM,'
     O                                      'ADMIT TIME FROM,'
     O                                      'ADMIT DATE TO,'
     O                                      'ADMIT TIME TO,'
      *
     O                                      'PART NO,'
     O                                      'MGT INST,'
     O                                      'ID NUMBER,'
     O                                      'SHIP ORDER NO,'
     O                                      'PAGE NO 1,2,3,4,'
     O                                      '2 PROCESSING,'
     O                                      'BESIDES OBJECT,'
     O                                      'OUTGOING EFFECTIVE,'
     O                                      'BAR CODE BOX TYPE,'
      *
     O                                      'PLATING COEFFICIENT,'
     O                                      'COLOR,'
     O                                      'ACCOM QTY,'
     O                                      'M/F BOX TYPE,'
     O                                      'COMPLETION UNIT WEIGHT,'
     O                                      'ADMIT DATE,'
     O                                      'ADMIT TIME,'
     O                                      'BEFORE ADMIT WEIGHT,'
      *
     O                                      'PLATING MCH NO,'
     O                                      'WEIGHING DATE,'
     O                                      'WEIGHING TIME,'
     O                                      'WEIGHING WEIGHT,'
     O                                      'MATERIAL BARCODE 1,'
     O                                      'MATERIAL BARCODE 2,'
     O                                      'LOADING WORKER CD,'
     O                                      'LOADING WORKER NAME'
      *************************
     O        E                $DATA
     O                         MACH
     O                                      ','
     O                         SHIZ
     O                                      ','
     O                         STIM
     O                                      ','
     O                         EHIZ
     O                                      ','
     O                         ETIM
     O                                      ','
      *
     O                         HIN
     O                                      ','
