     C           *ENTRY    PLIST
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P9STS   1
      *
     C                     MOVEL'0'       P9STS
     C                     EXSR #SB200
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------*
      *かんばんＭ検索       *
      *---------------------------*
     CSR         #SB200    BEGSR
      *
     C           KEYA31    KLIST
     C                     KFLD           #K1HB5  5
     C                     KFLD           #K2HB5  5
     C                     KFLD           #K3HB2  2
      *
     C                     MOVELP1SHN1    #K1HB5
     C                     MOVELP1SHN2    #K2HB5
     C                     MOVELP1SHN3    #K3HB2
      *メッキ
     C           KEYA31    SETGTAAFTL061
     C           KEYA31    REDPEAAFTL061                 82
     C           *IN82     DOWEQ'0'
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLE*DATE
     C                     ELSE
     C           A3STHZ    IFEQ 99999999
     C***        A3KMAX    IFEQ 999
     C           A3KMAX    IFEQ 99999
     C                     MOVEL'1'       P9STS
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYA31    REDPEAAFTL061                 82
     C                     ENDDO
      *引取
     C           KEYA31    SETGTAAHTL061
     C           KEYA31    REDPEAAHTL061                 82
     C           *IN82     DOWEQ'0'
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    ANDLE*DATE
     C                     ELSE
     C           L6STHZ    IFEQ 99999999
     C*****      L6KMAX    IFEQ 999
     C           L6KMAX    IFEQ 99999
     C                     MOVEL'1'       P9STS
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYA31    REDPEAAHTL061                 82
     C                     ENDDO
      *完成品
     C           KEYA31    SETGTAAPTL011
     C           KEYA31    REDPEAAPTL011                 82
     C           *IN82     DOWEQ'0'
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    ANDLE*DATE
     C                     ELSE
     C           L5STHZ    IFEQ 99999999
     C*****      L5KMAX    IFEQ 999
     C           L5KMAX    IFEQ 99999
     C                     MOVEL'1'       P9STS
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYA31    REDPEAAPTL011                 82
     C                     ENDDO
      *半製品
     C           KEYA31    SETGTAANPL061
     C           KEYA31    REDPEAANPL061                 82
     C           *IN82     DOWEQ'0'
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    ANDLE*DATE
     C                     ELSE
     C           L7STHZ    IFEQ 99999999
     C*****      L7KMAX    IFEQ 999
     C           L7KMAX    IFEQ 99999
     C                     MOVEL'1'       P9STS
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYA31    REDPEAANPL061                 82
     C                     ENDDO
      *工程内
     C           KEYM61    KLIST
     C                     KFLD           #KNKOJ  40
     C                     KFLD           #K1HB5  5
     C                     KFLD           #K2HB5  5
     C                     KFLD           #K3HB2  2
     C                     Z-ADD0111      #KNKOJ
     C           KEYM61    SETGTABHPL021
     C           KEYM61    REDPEABHPL021                 82
     C           *IN82     DOWEQ'0'
     C           M6SKJY    IFEQ 'D'
     C           M6SKHZ    ANDLE*DATE
     C                     ELSE
     C           M6STHZ    IFEQ 99999999
     C           M6KMAX    IFEQ 99999
     C                     MOVEL'1'       P9STS
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYM61    REDPEABHPL021                 82
     C                     ENDDO
      *焼入れ
     C           KEYA31    SETGTADHTL051
     C           KEYA31    REDPEADHTL051                 82
     C           *IN82     DOWEQ'0'
     C           J6SKJY    IFEQ 'D'
     C           J6SKHZ    ANDLE*DATE
     C                     ELSE
     C           J6STHZ    IFEQ 99999999
     C*****      J6KMAX    IFEQ 999
