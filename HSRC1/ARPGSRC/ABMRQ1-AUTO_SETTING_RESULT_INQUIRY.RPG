     H            Y.
     F** ABMRQ1 *********************************************
     F* AUTO SETTING RESULT INQUIRY
     F*   SAKAKI.          2020.01.06                       *
     F*******************************************************
     FABMPL31 IF  E           K        DISK
     FABMWPQ1 UF  E           K        DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  14 SDATE
     I                                        1   6 STIME
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
      *
     C           *ENTRY    PLIST
     C                     PARM           P1CR1   6
     C                     PARM           P1CR2   6
     C                     PARM           PCMD    2
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
      *
     C                     Z-ADD0         WKYM1   60
     C                     Z-ADD0         WKYM2   60
     C                     MOVE P1CR1     WKYM1
     C                     MOVE P1CR2     WKYM2
     C           KEY31     KLIST
     C                     KFLD           WKYM1
     C           KEY31     SETLLABMPL311
     C                     READ ABMPL311                 81
     C           *IN81     DOWEQ'0'
     C           S5NTYM    ANDLEWKYM2
     C           S5SKJY    IFEQ 'D'
     C           S5SKHZ    ANDLE*DATE
     C                     ELSE
     C           S5SA      IFNE 0
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     READ ABMPL311                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYW1     KLIST
     C                     KFLD           S5NTYM
     C                     Z-ADD0         S6SA    90
     C           S5KLOA    MULT S5SA      S6SA    90
     C           KEYW1     CHAINABMWPQ11             25
     C           *IN25     IFEQ '0'
     C                     SELEC
     C           S5KCD1    WHEQ 'A'
     C                     ADD  S6SA      W1SAA
     C                     ADD  1         W1CTA
     C           S5KCD1    WHEQ 'B'
     C                     ADD  S6SA      W1SAB
     C                     ADD  1         W1CTB
     C           S5KCD1    WHEQ 'C'
     C           S5PICS    IFEQ '0'
     C                     ADD  S5SA      W1SAC0
     C                     ADD  1         W1CTC0
     C                     ELSE
     C                     ADD  S5SA      W1SAC1
     C                     ADD  1         W1CTC1
     C                     ENDIF
     C           S5KCD1    WHEQ 'E'
     C                     ADD  S5SA      W1SAE
     C                     ADD  1         W1CTE
     C           S5KCD1    WHEQ '0'
     C                     ADD  S5SA      W1SA0
     C                     ADD  1         W1CT0
     C           S5KCD1    WHEQ '6'
     C                     ADD  S6SA      W1SA6
     C                     ADD  1         W1CT6
     C           S5KCD1    WHEQ '3'
     C           S5ATOB    IFEQ '8990'
     C           S5NTYM    ANDGE201911
     C                     ADD  S5SA      W1SA3
     C                     ADD  1         W1CT3
     C                     ENDIF
     C                     ENDSL
     C           S5KCD1    IFEQ '6'
     C           S5KCD1    OREQ 'A'
     C           S5KCD1    OREQ 'B'
     C                     ADD  S6SA      W1SA
     C                     ELSE
     C                     ADD  S5SA      W1SA
     C                     ENDIF
     C                     ADD  1         W1CT
     C                     UPDATABMWPQ11
     C                     ELSE
     C                     CLEARABMWPQ11
     C                     Z-ADDS5NTYM    W1NTYM
     C                     SELEC
     C           S5KCD1    WHEQ 'A'
     C                     Z-ADDS6SA      W1SAA
     C                     Z-ADD1         W1CTA
     C           S5KCD1    WHEQ 'B'
     C                     Z-ADDS6SA      W1SAB
     C                     Z-ADD1         W1CTB
     C           S5KCD1    WHEQ 'C'
     C           S5PICS    IFEQ '0'
     C                     Z-ADDS5SA      W1SAC0
     C                     Z-ADD1         W1CTC0
     C                     ELSE
     C                     Z-ADDS5SA      W1SAC1
     C                     Z-ADD1         W1CTC1
     C                     ENDIF
     C           S5KCD1    WHEQ 'E'
     C                     Z-ADDS5SA      W1SAE
     C                     Z-ADD1         W1CTE
     C           S5KCD1    WHEQ '0'
     C                     Z-ADDS5SA      W1SA0
     C                     Z-ADD1         W1CT0
     C           S5KCD1    WHEQ '6'
     C                     Z-ADDS6SA      W1SA6
     C                     Z-ADD1         W1CT6
     C           S5KCD1    WHEQ '3'
     C           S5ATOB    IFEQ '8990'
     C           S5NTYM    ANDGE201911
     C                     Z-ADDS5SA      W1SA3
     C                     Z-ADD1         W1CT3
     C                     ENDIF
     C                     ENDSL
     C           S5KCD1    IFEQ '6'
     C           S5KCD1    OREQ 'A'
     C           S5KCD1    OREQ 'B'
     C                     Z-ADDS6SA      W1SA
     C                     ELSE
     C                     Z-ADDS5SA      W1SA
     C                     ENDIF
     C                     Z-ADD1         W1CT
     C                     WRITEABMWPQ11
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
