     H            Y.
     F** VVVR94  **********************************************************
     F*  DELETE GARBAGE FROM VVVPP50C                                     *
     F*  J.WATANABE   2024.06.10                                          *
     F*********************************************************************
     FVVVPP50CIF  E           K        DISK
     FVVVPP50DO   E                    DISK
      *****************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1  10 WKFILE
     I                                        2   5 @CAT
     I           SDS
     I                                        1   8 #PGM
      *****************************************************
     C                     TIME           SDATE
     C                     MOVE *BLANK    SVFILE 10
     C                     MOVE *BLANK    SVLIB  10
     C                     MOVE *BLANK    SVCATG  5
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         @CNT    50
      *
     C                     DO   *HIVAL
     C                     READ VVVPP50C                 98
     C   98                LEAVE
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELMLFILE    SVFILE
     C                     MOVELMLLIB     SVLIB
     C                     MOVELXXCATG    SVCATG
     C                     ENDIF
      * BREAK?
     C           MLFILE    IFNE SVFILE
     C                     EXSR #BRK
     C                     ENDIF
      * PROCESS
     C                     ADD  1         @CNT
     C                     ENDDO
      * LAST BREAK
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
     C*****************************************************
     C* BREAK
     C*****************************************************
     C           #BRK      BEGSR
      *
     C                     Z-ADDTODAY     V5CRHZ
     C                     Z-ADDNOW       V5CRTM
     C                     MOVEL#PGM      V5CRPG
     C                     MOVELSVLIB     V5LIB
     C                     MOVELSVFILE    V5FILE
     C                     MOVEL@CNT      V5M#
     C                     MOVELSVCATG    V5SEU
     C                     WRITEVVVPP501
      * RESET
     C                     Z-ADD0         @CNT
     C                     MOVELMLFILE    SVFILE
     C                     MOVELMLLIB     SVLIB
     C                     MOVELXXCATG    SVCATG
      *
     C                     ENDSR
