     H            Y.                                    1
     H***ALCR62*****************************************************************
     H*  STORE IN LOCATION DOWNLOAD TO CSV                                     *
     H*  J.WATANABE    2019.04.04                                              *
     H**************************************************************************
     FALCPW60 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                        RRN2  KSFILE SFL02
     F                                              KINFDS @INFDS
     FALDPL35AIF  E           K        DISK
     FALDPL35BIF  E           K        DISK
     F            ALDPP351                          KRENAMEALDP35B1
     FAGDPL12 IF  E           K        DISK
     FALBPL30 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FALCWP60 UF  E           K        DISK                      A    UC
      **************************************************************************
     E                    ERR     1  10 70
     E                    CMD     1   1 70
     E                    MSG     1  11 40
     E**                  LOC     1  19 15   LON    15
      **************************************************************************
     I@INFDS      DS
     I                                     *STATUS  @STTS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60WSSTM6
     I                                        1   40WSSTM4
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  140WSSDAT
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I* SCANNED FROM DATE
     I            DS
     I                                        1   80XFDAT
     I                                        1   40XFYY
     I                                        5   60XFMM
     I                                        7   80XFDD
     I            DS
     I                                        1   80WFDAT
     I                                        1   40WFYY
     I                                        5   60WFMM
     I                                        7   80WFDD
     I*         FROM DATE -1 DAYS
     I            DS
     I                                        1   80F8KAHZ
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I* SCANNED TO DATE
     I            DS
     I                                        1   80XTDAT
     I                                        1   40XTYY
     I                                        5   60XTMM
     I                                        7   80XTDD
     I            DS
     I                                        1   80WTDAT
     I                                        1   40WTYY
     I                                        5   60WTMM
     I                                        7   80WTDD
     I* SCANNED RESULT DATE
     I            DS
     I                                        1   80A9CODT
     I                                        1   40A9DTYY
     I                                        5   80A9DTMD
     I* SCANNED RESULT TIME
     I            DS
     I                                        1   60A9COTM
     I                                        1   20A9TIHH
     I                                        3   40A9TIMM
     I                                        5   60A9TISS
     I            DS
     I                                        1   5 W8TIME
     I                                        1   2 W8TIHH
     I                                        3   3 W8@DY1
     I                                        4   5 W8TIMM
     I* PART#
     I            DS
     I                                        1  15 W@PART
     I                                        1   5 W@PRT1
     I                                        6   6 W@PRTA
     I                                        7  11 W@PRT2
     I                                       12  12 W@PRTB
     I                                       13  14 W@PRT3
     I* PART#
     I            DS
     I                                        1  14 A9LHIN
     I                                        1   5 A9LHN1
     I                                        6   6 A9H1
     I                                        7  11 A9LHN2
     I                                       12  12 A9H2
     I                                       13  14 A9LHN3
     I* LOCATION
     I            DS
     I                                        1   9 A9LOC
     I                                        1   1 A9ABN1
     I                                        2   2 A9LH1
     I                                        3   4 A9ABN2
     I                                        5   5 A9LH2
     I                                        6   7 A9ABN3
     I                                        8   8 A9LH3
     I                                        9   9 A9ABN4
     C**************************************************************************
     C*                    MAIN ROUTINE
     C**************************************************************************
     C                     EXSR #INIT
      *
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'10'      #DSP01
     C           @@ID      CASEQ'20'      #SFL01
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C*************************************************************************
     C*     1ST SCREEN(SCAN DATE)
     C**************************************************************************
     C           #DSP01    BEGSR
      *
     C                     SETOF                     4748
     C**                   WRITEDSP99
     C                     EXFMTDSP01
     C                     MOVE *BLANK    XMSG
     C                     SETOF                     313233
     C                     SETOF                     343536
      *
     C                     SELEC
      * <F1: END>
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
      * <ENTR>
     C                     EXSR #CHK1
      * <F5: DOWNLOAD>
     C           *IN85     IFEQ *OFF
     C                     EXSR #DOWN
     C                     MOVEL'10'      @@ID
     C                     GOTO XDSP01
     C                     ENDIF
      * <ENTR>
     C           *IN85     IFEQ *OFF
     C                     EXSR #SET2
     C                     ENDIF
      *
     C           *IN85     IFEQ *ON
     C                     MOVEL'10'      @@ID
     C                     ELSE
     C                     MOVEL'20'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C           XDSP01    ENDSR
     C*************************************************************************
     C*     1ST SCREEN CHECK
     C**************************************************************************
     C           #CHK1     BEGSR
     C*
     C                     SETOF                     85
     C                     TIME           WSDT
     C* FROM DATE
     C           XFDAT     IFEQ 0
     C           XFDAT     ORGT WSSDAT
     C  N85                MOVELERR,1     XMSG
     C                     SETON                     3185
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     Z-ADDXFDAT     WFDAT
      * TO DATE
     C           XTDAT     IFEQ *ZERO
     C                     Z-ADDWFDAT     WTDAT
     C                     ELSE
     C                     Z-ADDXTDAT     WTDAT
     C                     ENDIF
     C*
     C           WFDD      IFEQ *ZERO
     C                     Z-ADD01        WFDD
     C                     ENDIF
      *
     C           WTDD      IFEQ *ZERO
     C           K#AGDA    KLIST
     C                     KFLD           WTYY
     C                     KFLD           WTMM
     C           K#AGDA    SETGTAGDPL12
     C           K#AGDA    REDPEAGDPL12                  98
     C           *IN98     IFEQ *OFF
     C                     Z-ADDF8KADD    WTDD
     C                     ELSE
     C                     Z-ADD31        WTDD
     C                     ENDIF
     C                     ENDIF
     C*
     C           WFDAT     IFGT WTDAT
     C  N85                MOVELERR,2     XMSG
     C                     SETON                     313285
     C                     GOTO XCHK1
     C                     ENDIF
     C*
     C           XTDAT     IFEQ 0
     C           XFDAT     ANDNE0
     C                     Z-ADD99999999  XTDAT
     C                     Z-ADD99999999  WTDAT
     C                     ENDIF
     C* PART
     C           XSHN1     IFNE *BLANK
     C           XSHN2     ORNE *BLANK
     C           XSHN3     ORNE *BLANK
     C           K#PL01    KLIST
     C                     KFLD           XSHN1
     C                     KFLD           XSHN2
     C                     KFLD           XSHN3
     C           K#PL01    CHAINFCEPL01              99
     C           *IN99     IFEQ *ON
     C  N85                MOVELERR,5     XMSG
     C                     SETON                     3385
     C                     GOTO XCHK1
     C                     ENDIF
     C                     ENDIF
      * LOCATION
     C**         XLOC1     IFEQ *BLANK
     C**         XLOC2     ORNE *BLANK
     C**         XLOC3     ORNE *BLANK
     C**         XLOC4     ORNE *BLANK
     C**                   GOTO XCHK1
     C**                   ENDIF
      * SECTION
     C           XSEC      IFNE 'CV'
     C           XSEC      ANDNE'OQ'
     C           XSEC      ANDNE*BLANK
     C  N85                MOVELERR,7     XMSG
     C                     SETON                     3585
     C                     GOTO XCHK1
     C                     ENDIF
      * OK/NG
     C           XOK       IFNE 'OK'
     C           XOK       ANDNE'NG'
     C           XOK       ANDNE*BLANK
     C  N85                MOVELERR,8     XMSG
     C                     SETON                     3685
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           XCHK1     ENDSR
     C*************************************************************************
     C*  <F5>  DOWNLOAD CSV
     C**************************************************************************
     C           #DOWN     BEGSR
      *
     C                     CALL 'ALCC61'
     C                     PARM           X
     C                     PARM           Y
      *
     C                     ENDSR
     C*************************************************************************
     C*     2ND SCREEN SET
     C**************************************************************************
     C           #SET2     BEGSR
     C*
     C                     MOVEL*ON       *IN41
     C                     WRITECTL01
     C                     MOVEL*OFF      *IN41
     C                     MOVEL*OFF      *IN42
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         S1CVOK
     C                     Z-ADD0         S1CVNG
     C                     Z-ADD0         S1OQOK
     C                     Z-ADD0         S1OQNG
     C                     Z-ADD0         C1CVOK
     C                     Z-ADD0         C1CVNG
     C                     Z-ADD0         C1OQOK
     C                     Z-ADD0         C1OQNG
      *
     C* CLEAR WORK FILE (ALCWP60)
     C                     CLOSEALCWP60
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
     C                     Z-ADD70        P@LEN
     C                     MOVELCMD,1     P@CMD
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN ALCWP60
      *
     C           K#L35A    KLIST
     C                     KFLD           K@DATE  80
     C                     KFLD           K@TIME  60
     C                     Z-ADDXFDAT     K@DATE
     C                     Z-ADD0         K@TIME
      * READ ALDPL35A
     C           K#L35A    SETLLALDPL35A
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ALDPL35A                 97
     C   97                LEAVE
      * END ?
     C           A9CODT    IFGT XTDAT
     C                     LEAVE
     C                     ENDIF
      *
     C           A9SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * PART
     C           XSHN1     IFNE *BLANK
     C           XSHN2     ORNE *BLANK
     C           XSHN3     ORNE *BLANK
      *
     C           XSHN1     IFNE A9LHN1
     C           XSHN2     ORNE A9LHN2
     C           XSHN3     ORNE A9LHN3
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      * LOCATION
     C           XLOC1     IFNE *BLANK
     C           XLOC2     ORNE *BLANK
     C           XLOC3     ORNE *BLANK
     C           XLOC4     ORNE *BLANK
      *
     C           XLOC1     IFNE A9ABN1
     C           XLOC2     ORNE A9ABN2
     C           XLOC3     ORNE A9ABN3
     C           XLOC4     ORNE A9ABN4
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      * SECTION
     C           XSEC      IFNE *BLANK
      *
     C           XSEC      IFEQ 'CV'
     C           A9SECT    ANDNE'1'
     C           XSEC      OREQ 'OQ'
     C           A9SECT    ANDNE'2'
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      * OK/NG
     C           XOK       IFNE *BLANK
     C           XOK       IFNE A9OKNG
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      *
     C**         A9USER    IFNE 'HT'
     C**                   ITER
     C**                   ENDIF
     C*
     C           A9WOKR    CHAINALCWP60              96
     C           *IN96     IFEQ *ON
     C                     CLEARALCWP601
     C                     ENDIF
      *
     C                     MOVELA9WOKR    NUM60   60
     C           NUM60     CHAINALBPL30              95
     C           *IN95     IFEQ *ON
     C                     MOVE *BLANK    ALWKNM
     C                     ENDIF
      *
     C                     MOVELA9WOKR    W60TMC
     C                     MOVELALWKNM    W60TMN
      *
     C                     SELEC
     C           A9SECT    WHEQ '1'
     C           A9OKNG    ANDEQ'OK'
     C                     ADD  1         W60CVO
     C           A9SECT    WHEQ '1'
     C           A9OKNG    ANDEQ'NG'
     C                     ADD  1         W60CVN
     C           A9SECT    WHEQ '2'
     C           A9OKNG    ANDEQ'OK'
     C                     ADD  1         W60OQO
     C           A9SECT    WHEQ '2'
     C           A9OKNG    ANDEQ'NG'
     C                     ADD  1         W60OQN
      *
     C                     OTHER
     C           A9USER    IFEQ 'HT'
     C           A9OKNG    IFEQ 'OK'
     C                     ADD  1         W60OQO
     C                     ELSE
     C                     ADD  1         W60OQN
     C                     ENDIF
      *
     C                     ELSE
     C           A9OKNG    IFEQ 'OK'
     C                     ADD  1         W60CVO
     C                     ELSE
     C                     ADD  1         W60CVN
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
     C*
     C  N96                UPDATALCWP601
     C   96                WRITEALCWP601
     C*
     C                     ENDDO
     C*
     C           *LOVAL    SETLLALCWP60
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ALCWP60                  94
     C   94                LEAVE
     C*
     C                     CLEARSFL01
     C                     MOVELW60TMC    S1TMC
     C                     MOVELW60TMN    S1TMNM
     C                     MOVELW60TMC    H1TMC
     C                     MOVEL'0'       H1SEL
      *
     C                     Z-ADDW60CVO    S1CVOK
     C                     Z-ADDW60CVN    S1CVNG
     C                     Z-ADDW60OQO    S1OQOK
     C                     Z-ADDW60OQN    S1OQNG
     C                     ADD  W60CVO    C1CVOK
     C                     ADD  W60CVN    C1CVNG
     C                     ADD  W60OQO    C1OQOK
     C                     ADD  W60OQN    C1OQNG
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C*
     C                     ENDDO
     C*
     C           RRN1      IFEQ *ZERO
     C  N85                MOVELERR,3     XMSG
     C                     SETON                     313285
     C                     ENDIF
     C*
     C                     ENDSR
     C*************************************************************************
     C*     2ND SCREEN
     C**************************************************************************
     C           #SFL01    BEGSR
      *
     C                     Z-ADD1         W#RNP2  40
      *
     C                     DO   *HIVAL
     C*
     C                     MOVEL*OFF      *IN47
     C                     MOVEL*ON       *IN48
     C                     WRITEDSP99
     C                     Z-ADDW#RNP2    #RCN02
     C                     EXFMTCTL01
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP2
     C                     ENDIF
     C*
     C                     MOVEL*BLANK    XMSG
     C                     MOVEL*OFF      *IN85
     C* F1: END
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      @@ID
     C                     LEAVE
     C* F12: BACK
     C           *INKL     WHEQ *ON
     C                     MOVEL'10'      @@ID
     C                     LEAVE
     C* ENTR
     C                     OTHER
     C                     EXSR #CHK2
     C           *INKA     IFEQ *ON
     C                     MOVEL'99'      @@ID
     C                     LEAVE
     C                     ENDIF
     C                     ENDSL
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C**************************************************************************
     C*     2ND SCREEN CHECK
     C**************************************************************************
     C           #CHK2     BEGSR
     C*
     C                     SETOF                     85
     C                     Z-ADD0         RRN1
     C*
     C                     DO   *HIVAL
     C*
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL01                93
     C   93                LEAVE
     C*
     C           S1SEL     IFNE 'X'
     C           S1SEL     ANDNE' '
     C  N85                MOVELERR,4     XMSG
     C                     SETON                     52  85
     C                     MOVE *ON       H1SEL
     C                     UPDATSFL01
     C                     ITER
     C                     ENDIF
     C*
     C           S1SEL     IFEQ 'X'
     C                     MOVEL*ON       *IN52
     C                     MOVEL*BLANK    S1SEL
     C                     MOVE *OFF      H1SEL
     C                     UPDATSFL01
     C                     MOVEL*OFF      *IN52
     C                     EXSR #SET3
     C                     EXSR #FMT3
      * F1: END
     C           *INKA     IFEQ *ON
     C                     MOVEL'99'      @@ID
     C                     LEAVE
     C                     ENDIF
      *
     C                     ELSE
     C                     MOVEL*OFF      *IN52
     C                     MOVEL*BLANK    S1SEL
     C                     MOVEL*OFF      H1SEL
     C                     UPDATSFL01
     C                     ENDIF
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*************************************************************************
     C*     3RD SCREEN SET
     C**************************************************************************
     C           #SET3     BEGSR
     C*
     C                     MOVEL*ON       *IN61
     C                     WRITECTL02
     C                     MOVEL*OFF      *IN61
     C                     MOVEL*OFF      *IN62
     C                     Z-ADD0         RRN2    40
     C*
     C                     MOVEL*ON       *IN63
     C*
     C                     MOVELS1TMC     C2TMC
     C                     MOVELS1TMNM    C2TMNM
     C                     Z-ADDS1CVOK    C2CVOK
     C                     Z-ADDS1CVNG    C2CVNG
     C                     Z-ADDS1OQOK    C2OQOK
     C                     Z-ADDS1OQNG    C2OQNG
     C* READ ALDPL35B
     C           K#L35B    KLIST
     C                     KFLD           H1TMC
     C                     KFLD           WFDAT
     C                     KFLD           K@TIME
     C                     Z-ADD0         K@TIME
     C           K#L35B    SETLLALDPL35B
     C*
     C                     DO   *HIVAL
     C*
     C           H1TMC     READEALDPL35B                 97
     C   97                LEAVE
     C           A9CODT    IFGT WTDAT
     C                     LEAVE
     C                     ENDIF
     C*
     C           A9SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * PART
     C           XSHN1     IFNE *BLANK
     C           XSHN2     ORNE *BLANK
     C           XSHN3     ORNE *BLANK
      *
     C           XSHN1     IFNE A9LHN1
     C           XSHN2     ORNE A9LHN2
     C           XSHN3     ORNE A9LHN3
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      * LOCATION
     C           XLOC1     IFNE *BLANK
     C           XLOC2     ORNE *BLANK
     C           XLOC3     ORNE *BLANK
     C           XLOC4     ORNE *BLANK
      *
     C           XLOC1     IFNE A9ABN1
     C           XLOC2     ORNE A9ABN2
     C           XLOC3     ORNE A9ABN3
     C           XLOC4     ORNE A9ABN4
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      * SECTION
     C           XSEC      IFNE *BLANK
      *
     C           XSEC      IFEQ 'CV'
     C           A9SECT    ANDNE'1'
     C           XSEC      OREQ 'OQ'
     C           A9SECT    ANDNE'2'
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      * OK/NG
     C           XOK       IFNE *BLANK
     C           XOK       IFNE A9OKNG
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      *
     C                     CLEARSFL02
     C                     Z-ADDA9DTMD    S2DATE
     C                     MOVELA9TIHH    W8TIHH
     C                     MOVEL':'       W8@DY1
     C                     MOVELA9TIMM    W8TIMM
     C                     MOVELW8TIME    S2TIME
      * SECTION
     C                     SELEC
     C           A9SECT    WHEQ '1'
     C                     MOVEL'CV'      S2SECT
     C           A9SECT    WHEQ '2'
     C                     MOVEL'OQ'      S2SECT
     C                     OTHER
     C           A9USER    IFEQ 'HT'
     C                     MOVEL'OQ'      S2SECT
     C                     ELSE
     C                     MOVEL'CV'      S2SECT
     C                     ENDIF
     C                     ENDSL
      * ON/KG
     C                     MOVELA9OKNG    S2OKNG
      * PART
     C           A9LHN2    IFNE *BLANK
     C                     MOVE '-'       A9H1
     C                     ELSE
     C                     MOVE *BLANK    A9H1
     C                     ENDIF
      *
     C           A9LHN3    IFNE *BLANK
     C                     MOVE '-'       A9H2
     C                     ELSE
     C                     MOVE *BLANK    A9H2
     C                     ENDIF
      *
     C                     MOVELA9LHIN    S2HIN1    P
     C                     MOVELA9LBAR    S2LBAR    P
     C                     MOVELA9ABAR    S2ABAR    P
      * LOCATION
     C                     MOVE '-'       A9LH1
     C                     MOVE '-'       A9LH2
     C                     MOVE '-'       A9LH3
     C                     MOVELA9LOC     S2LOC     P
      *
     C                     ADD  1         RRN2
      * INDICATE RED
     C           A9OKNG    IFEQ 'NG'
     C                     MOVE *ON       *IN55
     C                     MOVE *ON       IND55
     C                     ELSE
     C                     MOVE *OFF      *IN55
     C                     MOVE *OFF      IND55
     C                     ENDIF
      * SET ERROR MSG
     C                     MOVE *BLANK    S2EHED
     C                     MOVE *BLANK    S2EMSG
     C           A9OKNG    IFEQ 'NG'
     C                     MOVELMSG,11    S2EHED
     C                     SELEC
     C           A9ERCD    WHEQ '01'
     C                     MOVELMSG,1     S2EMSG
     C           A9ERCD    WHEQ '02'
     C                     MOVELMSG,2     S2EMSG
     C           A9ERCD    WHEQ '03'
     C                     MOVELMSG,3     S2EMSG
     C           A9ERCD    WHEQ '04'
     C                     MOVELMSG,4     S2EMSG
     C           A9ERCD    WHEQ '05'
     C                     MOVELMSG,5     S2EMSG
     C           A9ERCD    WHEQ '06'
     C                     MOVELMSG,6     S2EMSG
     C           A9ERCD    WHEQ '07'
     C                     MOVELMSG,7     S2EMSG
     C           A9ERCD    WHEQ '08'
     C                     MOVELMSG,8     S2EMSG
     C           A9ERCD    WHEQ '09'
     C                     MOVELMSG,9     S2EMSG
     C           A9ERCD    WHEQ '10'
     C                     MOVELMSG,10    S2EMSG
     C                     ENDSL
     C                     ENDIF
      *
     C                     WRITESFL02
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*************************************************************************
     C*     3RD SCREEN(TM,DATE DETAIL)
     C**************************************************************************
