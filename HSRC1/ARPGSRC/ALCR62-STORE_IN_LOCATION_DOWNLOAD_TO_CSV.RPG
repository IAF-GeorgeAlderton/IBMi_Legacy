     C*
     C                     Z-ADD1         W#RNP3  40
     C                     MOVEL*OFF      *IN85
     C*
     C                     DO   *HIVAL
     C*
     C                     SETON                     4748
     C                     WRITEDSP99
     C                     Z-ADDW#RNP3    #RCN03
     C                     EXFMTCTL02
     C   KA
     COR KL                LEAVE
     C*
     C**NKJ                MOVELN#MOD3    *IN63
     C*
