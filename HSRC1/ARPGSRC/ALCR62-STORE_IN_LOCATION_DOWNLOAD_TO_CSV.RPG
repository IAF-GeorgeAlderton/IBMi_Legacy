     C                     ENDSR
     C**************************************************************************
     C*         INITIALIZE
     C**************************************************************************
     C           #INIT     BEGSR
      *
     C                     TIME           WSDT
     C*
     C                     Z-ADD*ZERO     XFYY
     C                     Z-ADD*ZERO     XFMM
     C                     Z-ADD*ZERO     XFDD
     C                     Z-ADD*ZERO     XTYY
     C                     Z-ADD*ZERO     XTMM
     C                     Z-ADD*ZERO     XTDD
