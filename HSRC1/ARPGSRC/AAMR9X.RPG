     C                     TIME           @TIME
      *-------------------------
     C                     DO   *HIVAL
     C                     READ AAMWP99                  90
     C   90                LEAVE
     C           W1UPDF    IFNE ' '                        UPDATE FLAG
     C                     ITER
     C                     ENDIF
     C*
     C                     EXSR #AAMP
     C* **
     C           @@UPD     IFEQ '*'
     C                     EXSR #UPDAT
     C*
     C                     MOVE '1'       W1UPDF           UPDATE FLAG
     C                     UPDATAAMWP991
     C                     ENDIF
     C* **
     C                     ENDDO
      *-------------------------
     C                     SETON                     LR
     C                     RETRN
      *
      *================================================================
      * INTRA COMPANY KANBAN CHANGE M/F
      *================================================================
     C           #AAMP     BEGSR
      *
     C           KEY01     KLIST
     C                     KFLD           W1HIN1
     C                     KFLD           W1HIN2
     C                     KFLD           W1HIN3
      *
     C                     MOVE ' '       @@UPD   1
      *
     C           KEY01     CHAINAAMPL11              91
     C           *IN91     IFEQ *OFF
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE@SYSHZ
     C                     SETON                     91
     C                     ENDIF
     C   91                GOTO @SKIP
      *
     C                     Z-ADD1         Z       20
     C           'RL '     LOKUPKKO,Z                    50:EQ
     C  N50                GOTO @SKIP
      *      =済=
     C           'KW '     LOKUPKKO                      50:EQ
     C   50                GOTO @SKIP
      *
     C                     MOVE '*'       @@UPD
      *
     C           @SKIP     ENDSR
      *================================================================
      *================================================================
      * INTRA COMPANY KANBAN CHANGE M/F更新
      *================================================================
     C           #UPDAT    BEGSR
      * 新→旧
     C                     MOVEAKKO       KQK              工程
     C                     MOVEAKBM       KQB              部門
     C                     MOVEAKHB       KQH              工程品番
     C                     MOVEAKKB       KQN              機番
     C                     MOVEAKNB       KQT              所番地
     C                     MOVEAKTY       KQS              かんばん種類
      *
     C                     MOVEAKHZ       $HZ              切替日
     C                     MOVEAKSU       $SU              設定数
     C                     MOVEAKMN       $MN              更新日
     C                     MOVEAKCG       $CG              修正区分
      *
      *  'RL 'の直前に
      *        Z='RL 'の場所
      *-------------------------
     C           Z         DO   15        X
     C                     MOVE KKO,X     $KKO    3        工程
     C                     Z-ADDKBM,X     $KBM    40       部門
     C                     MOVE KHB,X     $KHB   12        工程品番
     C                     MOVE KKB,X     $KKB    3        機番
     C                     MOVE KNB,X     $KNB    6        所番地
     C                     MOVE KTY,X     $KTY    1        かんばん種類
     C*
     C           Z         IFEQ X
     C                     MOVE W1PROC    KKO,X            工程
     C                     Z-ADDW1DEPT    KBM,X            部門
     C                     MOVE KHB,X     KHB,X            工程品番
     C                     MOVE W1MCN#    KKB,X            機番
     C                     MOVE W1LOCA    KNB,X            所番地
     C                     MOVE W1KTYP    KTY,X            かんばん種類
     C                     Z-ADDW1DATB    KHZ,X            切替日
     C                     ELSE
     C           X         SUB  1         Y       20
     C                     MOVE KQK,Y     KKO,X            工程
     C                     Z-ADDKQB,Y     KBM,X            部門
     C                     MOVE KQH,Y     KHB,X            工程品番
     C                     MOVE KQN,Y     KKB,X            機番
     C                     MOVE KQT,Y     KNB,X            所番地
     C                     MOVE KQS,Y     KTY,X            かんばん種類
     C                     Z-ADD$HZ,Y     KHZ,X            切替日
     C                     Z-ADD$SU,Y     KSU,X            設定数
     C                     MOVE $MN,Y     KMN,X            更新日
     C                     MOVE $CG,Y     KCG,X            修正区分
     C                     ENDIF
     C**
     C                     ENDDO
      *-------------------------
     C                     Z-ADD@SYSHZ    CKKOHZ
     C                     Z-ADD@SYSTM    CKKOTM
     C                     MOVELW$PGM     CKKOME
     C                     UPDATAAMPL111
      *
      *-------------------------
      * < PROCESS M/F > 1PROCESS .1RECORD
      *-------------------------
      *
     C           KEY02     KLIST
     C                     KFLD           CKHIN1
     C                     KFLD           CKHIN2
     C                     KFLD           CKHIN3
     C                     KFLD           K$KSEQ  20
     C                     KFLD           K$HKBN  1
     C                     MOVE *BLANK    K$HKBN
      *
      *-------------------------
     C                     EXSR #FCE
      *-------------------------
     C           1         DO   15        X       20
     C           KKO,X     IFEQ *BLANK                     工程
     C                     LEAVE
     C                     ENDIF
     C*
     C                     Z-ADDX         K$KSEQ
     C           KEY02     CHAINGHCPL21              92
     C*
     C   92                MOVELCKHIN1    M7JHN1
     C   92                MOVELCKHIN2    M7JHN2
     C   92                MOVELCKHIN3    M7JHN3
     C   92                Z-ADDK$KSEQ    M7KSEQ
     C   92                MOVE ' '       M7HKBN
     C   92                Z-ADD1         M7KOSU
     C*
     C                     Z-ADDWGEKN     M7SETI
     C*
     C                     MOVE KHB,X     M7MHN            工程品番
     C                     MOVE KKO,X     M7MKTE           工程
     C                     Z-ADDKBM,X     M7MBMN           部門
     C                     MOVE KNB,X     M7MBN            所番地
     C                     MOVE KKB,X     M7MSNO           機番
     C                     Z-ADDKSU,X     M7SRYO           設定数
     C  N92                UPDATGHCPL211
     C   92                WRITEGHCPL211
     C*
     C                     ENDDO
      *-------------------------
     C*
     C                     ENDSR
      *================================================================
      * PART MASTER
      *================================================================
     C           #FCE      BEGSR
      *
      *
     C           KEY01     CHAINFCEPL01              91
     C           *IN91     IFEQ *OFF
     C           A2GSKD    ANDEQ*BLANK
     C                     Z-ADDA2GEKN    WGEKN   90
     C                     ENDIF
      *
      *
     C                     ENDSR
