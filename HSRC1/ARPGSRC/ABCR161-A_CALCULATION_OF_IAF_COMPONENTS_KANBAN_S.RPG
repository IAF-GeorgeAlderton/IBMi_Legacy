     H            Y.
     F*** ABCR16 *******************************
     F* A CALCULATION OF IAF COMPONENTS KANBAN SHEETS *
     F* S.YAMAGAMI 92.05.28                    *
     F*
     F* TCHK  09/12/11 CREATE(COPY FROM ABCR16)
     F* TCHK1 09/16/11 COMMENT OUT
     F* TCHK2 12/11/13 CHG ZERO DIVIDE
     F* T.SAKAKI 02/04/15 ADD LOGIC
     F*----------+-----+----------+-----------------------------------*
     F*2021.02.22|DCS. |T.MITSUI  | CHANGE WITH THE NUMBER OF FIGURES *
     F*          |     |          |          EXPANSION OF THE "KANBAN"*
     F*****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PARM1   2        SETON LR ﾍｭcﾆg
     C                     PARM           PMAIS   50       f]ﾌﾞ]ubﾇc
     C                     PARM           PKTSU   90       fhmbﾍajﾒﾇc
     C                     PARM           PSYOS   60       ﾆｬcﾑcﾇc
     C                     PARM           PLTIM   31       ﾒｰnﾞjbw
     C                     PARM           PROTO   20       ﾜｮn
     C                     PARM           PKISU   32       ﾌﾞ[lgibﾇc
     C                     PARM           PUZAR   30       kｭcﾈbubﾇc
     C                     PARM           PHITO   30       anﾃcmbﾍgnﾒ
      *
     C                     MOVE PKTSU     WKTSU   90
     C                     MOVE PSYOS     WSYOS   60
     C                     MOVE PLTIM     WLTIM   31
     C                     MOVE PROTO     WROTO   20
     C                     MOVE PKISU     WKISU   32
     C                     MOVE PUZAR     WUZAR   30
TCHK C                     Z-ADD0         WWMAIS  50
     C*
     C           PARM1     IFEQ 'LR'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C*~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~|
     C*             かんばん枚数計算式                |
     C*_________________________________________________|
     C*
     C*日当箱数
     C*
     C                     Z-ADD0         WHAKO   93
TCHK2C           WSYOS     IFNE *ZERO
     C           WKTSU     DIV  WSYOS     WHAKO
TCHK2C                     END
     C*
     C*少量品補数
     C*
     C                     Z-ADD0         WHOSU   21
     C*
     C*通常かんばん計算式
     C                     Z-ADD0         WMAIS
     C           WROTO     IFEQ 0
     C*
     C           WHAKO     MULT WLTIM     @1      93
TCHK C           @1        MULT WKISU     WMAIS   71
     C*
     C*ロットかんばん計算式
     C                     ELSE
     C           WHAKO     MULT WLTIM     @1
     C           @1        MULT WKISU     @2      93
     C           @2        ADD  WROTO     @4      93
     C           @4        SUB  1         @5      93
     C           @5        DIV  WROTO     WMAIS
     C                     END
     C*
     C           WMAIS     ADD  0.9       WWMAIS
     C*****                MOVE WWMAIS    PMAIS
     C                     Z-ADDWWMAIS    PMAIS
     C* f]ﾌﾞ]ubﾇc < ﾍgnﾒﾇc ﾉng
TCHK1C*          PMAIS     IFLT PHITO
TCHK1C*                    Z-ADDPHITO     PMAIS
TCHK1C*                    END
     C* 2 TO 3
     C           PMAIS     IFEQ 2
     C                     ADD  1         PMAIS
     C                     END
     C* ﾅbmbf]ﾌﾞ]ubﾇc = 2
     C           PMAIS     IFLT 2
     C                     Z-ADD2         PMAIS
     C                     END
     C* kｭcﾈbubﾇc
     C           WUZAR     IFNE 0
     C                     ADD  WUZAR     PMAIS
     C                     END
     C*
     C                     RETRN
