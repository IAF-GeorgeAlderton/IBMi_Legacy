     H            Y.
     F** UEXR49B  **************************************************************
     F*  PROGRAM    : UPDATE AB#PP78L (PACKING LIST LOG)                       *
     F*  WRITTEN    : 2023.09.07                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
      **************************************************************************
      *  CALLING SEQ.
      *                    CALL 'UEXR49B'
      *                    PARM           $PL#    9
      *                    PARM           $PRC    1
      *                    PARM           $PGM   10
      *   IN  $PL#    9A  PACKING LIST#
      *       $PRC    1A  PROCESS TYPE (P:PL, L:LABEL, S:POSTING, A:ASN)
      *       $PGM   10A  PROGRAM NAME
     F**************************************************************************
     FAB#PL79 IF  E           K        DISK
     FAB#PP78LO   E                    DISK
      *
     I           SDS
     I                                        1   8 #PGM
      *************************************************************************
      * MAIN ROUTINE
      *************************************************************************
     C           *ENTRY    PLIST
     C                     PARM           $PL#    9
     C                     PARM           $PRC    1
     C                     PARM           $PGM   10
      *
     C           $PL#      CHAINAB#PL79              99
     C           *IN99     IFEQ *ON
     C           *IN99     OREQ *OFF
     C           P8SKJY    ANDEQ'D'
     C                     GOTO PEND
     C                     ENDIF
      *
     C                     MOVEL$PGM      P8KOPG
     C                     MOVEL#PGM      P8FLD4
      *
     C                     SELEC
     C           $PRC      WHEQ 'P'
     C                     MOVEL$PGM      P8PLPG
     C           $PRC      WHEQ 'L'
     C                     MOVEL$PGM      P8LPPG
     C           $PRC      WHEQ 'S'
     C                     MOVEL$PGM      P8SPPG
     C           $PRC      WHEQ 'A'
     C                     MOVEL$PGM      P8SPPG
     C                     MOVEL$PGM      P8ASPG
     C                     ENDSL
      *
     C                     WRITEAB#PP78R
      *
     C           PEND      TAG
     C                     MOVE *ON       *INLR
     C                     RETRN
