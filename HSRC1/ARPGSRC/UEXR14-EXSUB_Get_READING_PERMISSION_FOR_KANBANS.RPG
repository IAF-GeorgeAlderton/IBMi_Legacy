     H            Y.                                    1
     F** UEXR14 **********************************
     F* GET READING PERMISSION FOR KANBANS       *
     F*     T.SAKAKI             2019.11.17      *
     F* CHANGES(20199) T.TODA    2021.06.28      *
     F********************************************
     FABHPL31 UF  E           K        DISK
     FADHPL31 UF  E           K        DISK
     FAAFPL31 UF  E           K        DISK
      *
LOG  FUEXPP14 O   E                    DISK
      *
     I            DS
     I                                        1  140W1DTTM
     I                                        1   80W1KHDT
     I                                        9  140W1KHTM
     I            DS
     I                                        1  140W2DTTM
     I                                        1   80W2KHDT
     I                                        9  140W2KHTM
     I            DS
     I                                        1  140W3DTTM
     I                                        1   80W3KHDT
     I                                        9  140W3KHTM
      *
     I            DS
     I                                        1  12 K1SHIN
     I                                        1   5 K1PRT1
     I                                        6  10 K1PRT2
     I                                       11  12 K1PRT3
      *
     I            DS
     I                                        1   6 K1MTKA
     I                                        1   1 K1MTK1
     I                                        2   3 K1MTK2
     I                                        4   5 K1MTK3
     I                                        6   6 K1MTK4
     I            DS
     I                                        1   6 W2MTKA
     I                                        1   1 W2MTK1
     I                                        2   3 W2MTK2
     I                                        4   5 W2MTK3
     I                                        6   6 W2MTK4
     I            DS
     I                                        1   6 K1ATKA
     I                                        1   1 K1ATK1
     I                                        2   3 K1ATK2
     I                                        4   5 K1ATK3
     I                                        6   6 K1ATK4
     I            DS
     I                                        1   6 W2ATKA
     I                                        1   1 W2ATK1
     I                                        2   3 W2ATK2
     I                                        4   5 W2ATK3
     I                                        6   6 W2ATK4
     I*
     IW@DATA      DS
     I                                        1 256 W@QR1
     I                                      257 512 W@QR2
     I*
     I            DS
     I                                        1  140WSDT
     I                                        1   60WTIME
     I                                        7  140WDATE
     I           SDS
     I                                     *PROGRAM #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I                                      264 269 #JBNO
      *
     I              '0123456789'          C         DIGITS
      ***********************************************
      * ENTRY LIST
      ***********************************************
     C           *ENTRY    PLIST
     C                     PARM           P1QR1 256
     C                     PARM           P1QR2 256
     C                     PARM           P1RDPM  1
      ***********************************************
      * MAIN
      ***********************************************
     C                     MOVEL'Y'       P1RDPM
     C                     MOVEL*BLANK    WCHK    1
     C                     Z-ADD0         W2DTTM
     C                     MOVEL*BLANK    K1LOT#  3
     C                     MOVEL*BLANK    K1PAGE  5
      **
     C                     MOVELP1QR1     W@QR1 256
     C                     MOVELP1QR2     W@QR2 256
      * COMMON
     C           3         SUBSTW@QR1:1   W@QKBN  3
     C           1         SUBSTW@QR1:4   W@HKKB  1
     C           1         SUBSTW@QR1:5   W@HKK1  1
     C           5         SUBSTW@QR1:11  K1KMAX  5
     C           5         SUBSTW@QR1:91  K1PAGE
      *
     ** NO NEED TO CHECK A-PICS & TEMPORARY KANBAN
S1   C           W@QKBN    IFNE 'C01'
     C           W@HKKB    ANDNE'R'
      *
     C                     SELEC
      *-PRODUCTION KANBAN--------
     C           W@HKK1    WHEQ 'A'
     C           W@HKK1    OREQ 'Y'
     C           1         SUBSTW@QR1:53  K1ATK1
      *
     C           K1ATK1    IFEQ ' '
     C                     MOVEL'1'       K1ATK1
     C                     ENDIF
      *
     C           2         SUBSTW@QR1:54  K1ATK2
     C           2         SUBSTW@QR1:56  K1ATK3
     C           1         SUBSTW@QR1:58  K1ATK4
      *
     C           K1ATK4    IFEQ ' '
     C                     MOVEL'0'       K1ATK4
     C                     ENDIF
      *
     C           12        SUBSTW@QR1:34  K1SHIN
     C           8         SUBSTW@QR2:76  W@KHDT  8
     C           6         SUBSTW@QR2:84  W@KHTM  6
      *
     C           1         SUBSTW@QR1:79  K1MTK1
     C           K1MTK1    IFEQ ' '
     C                     MOVEL'1'       K1MTK1
     C                     ENDIF
     C           2         SUBSTW@QR1:80  K1MTK2
     C           2         SUBSTW@QR1:82  K1MTK3
     C           1         SUBSTW@QR1:84  K1MTK4
     C           K1MTK4    IFEQ ' '
     C                     MOVEL'0'       K1MTK4
     C                     ENDIF
      *--------------------------
      *-HEAT TREATMENT KANBAN----
     C           W@HKK1    WHEQ 'B'
     C           1         SUBSTW@QR1:53  K1ATK1
     C           2         SUBSTW@QR1:54  K1ATK2
     C           2         SUBSTW@QR1:56  K1ATK3
     C           1         SUBSTW@QR1:58  K1ATK4
     C           12        SUBSTW@QR1:34  K1SHIN
      *
      *  OLD/NEW CHECK
     C           1         SUBSTW@QR1:211 ONCHK   1
      * NEW '0'
     C           ONCHK     IFEQ '0'
     C           8         SUBSTW@QR1:188 W@KHDT
     C           6         SUBSTW@QR1:196 W@KHTM
      * OLD ' '
     C                     ELSE
     C           8         SUBSTW@QR1:187 W@KHDT
     C           6         SUBSTW@QR1:195 W@KHTM
     C                     ENDIF
      *
     C           1         SUBSTW@QR1:79  K1MTK1
     C           K1MTK1    IFEQ ' '
     C                     MOVEL'1'       K1MTK1
     C                     ENDIF
     C           2         SUBSTW@QR1:80  K1MTK2
     C           2         SUBSTW@QR1:82  K1MTK3
     C           1         SUBSTW@QR1:84  K1MTK4
     C           K1MTK4    IFEQ ' '
     C                     MOVEL'0'       K1MTK4
     C                     ENDIF
      *
      *-PLATING KANBAN ----
     C           W@HKK1    WHEQ 'C'
     C           W@QKBN    ANDEQ'B01'
     C           1         SUBSTW@QR1:42  K1ATK1
     C           2         SUBSTW@QR1:43  K1ATK2
     C           2         SUBSTW@QR1:45  K1ATK3
     C           1         SUBSTW@QR1:47  K1ATK4
     C           12        SUBSTW@QR1:30  K1SHIN
     C           8         SUBSTW@QR1:140 W@KHDT
     C           6         SUBSTW@QR1:148 W@KHTM
     C           3         SUBSTW@QR1:53  K1LOT#
      *
     C           1         SUBSTW@QR1:65  K1MTK1
     C           K1MTK1    IFEQ ' '
     C                     MOVEL'1'       K1MTK1
     C                     ENDIF
     C           2         SUBSTW@QR1:66  K1MTK2
     C           2         SUBSTW@QR1:68  K1MTK3
     C           1         SUBSTW@QR1:70  K1MTK4
     C           K1MTK4    IFEQ ' '
     C                     MOVEL'0'       K1MTK4
     C                     ENDIF
      *
     C                     ENDSL
      *--------------------------
      *
     C           W@KHDT    IFNE *BLANK
     C           DIGITS    CHECKW@KHDT                   33
     C           *IN33     IFEQ *ON
     C                     MOVEL*BLANK    W@KHDT
     C                     ENDIF
     C                     ENDIF
      *
     C           W@KHTM    IFNE *BLANK
     C           DIGITS    CHECKW@KHTM                   33
     C           *IN33     IFEQ *ON
     C                     MOVEL*BLANK    W@KHTM
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVE W@KHDT    K1KHDT  80
     C                     MOVE W@KHTM    K1KHTM  60
      *
     C                     Z-ADDK1KHDT    W1KHDT
     C                     Z-ADDK1KHTM    W1KHTM
      *
      * ADDED ISSUE DATE TO QR DATA LAYOUT ON 11/21/2019
     C           W1KHDT    IFLT 20191121
     C                     Z-ADD0         K1KHDT
     C                     Z-ADD0         K1KHTM
     C                     Z-ADD0         W1KHDT
     C                     Z-ADD0         W1KHTM
     C                     ENDIF
      *
      *  CHECK CURRENT KANBAN
     C                     EXSR #SB100
      *  UPDATE
     C           WCHK      IFEQ '1'
     C                     EXSR #SB200
     C                     ENDIF
      *  ERROR
     C           WCHK      IFEQ '9'
     C                     MOVEL'N'       P1RDPM
      ***
     C                     CLEARUEXPP141
     C                     MOVEL'NG'      L1OKNG
     C                     EXSR #SB300
      ***
     C                     ENDIF
      *
E1   C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      ****************************************************
      *  CHECK CURRENT KANBAN BY ISSUE DATE
      ****************************************************
     CSR         #SB100    BEGSR
      *
     C           KEY1      KLIST
     C                     KFLD           K1ATK1  1
     C                     KFLD           K1ATK2  2
     C                     KFLD           K1ATK3  2
     C                     KFLD           K1ATK4  1
     C                     KFLD           K1SHIN 12
      *
     C                     SELEC
      *--------------------------
      * PRODUCTION
      *--------------------------
     C           W@HKK1    WHEQ 'A'
     C           W@HKK1    OREQ 'Y'
     C           KEY1      SETGTABHPL31
     C                     DO   *HIVAL
     C           KEY1      REDPEABHPL31                  80
     C   80                LEAVE
     C*
     C           M0SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C*
     C           M0TYPE    IFEQ *BLANK
     C           M0TYPE    OREQ 'A'
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C*
     C           M0RECD    IFNE '      SN'
     C                     ITER
     C                     ENDIF
     C*
     C           M0RDPM    IFEQ 'Y'
     C                     Z-ADDM0KHDT    W2KHDT
     C                     Z-ADDM0KHTM    W2KHTM
     C                     MOVELM0ATK1    W2ATK1
     C                     MOVELM0ATK2    W2ATK2
     C                     MOVELM0ATK3    W2ATK3
     C                     MOVELM0ATK4    W2ATK4
     C                     MOVELM0MTK1    W2MTK1
     C                     MOVELM0MTK2    W2MTK2
     C                     MOVELM0MTK3    W2MTK3
     C                     MOVELM0MTK4    W2MTK4
     C           5         SUBSTM0QR:11   W2KMAX  5
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *--------------------------
      * HEAT TREATMENT
      *--------------------------
     C           W@HKK1    WHEQ 'B'
     C           KEY1      SETGTADHPL31
     C                     DO   *HIVAL
     C           KEY1      REDPEADHPL31                  80
     C   80                LEAVE
     C*
     C           J3SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C*
     C           J3HKB2    IFEQ *BLANK
     C           J3HKB2    OREQ 'A'
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C*
     C           J3RDPM    IFEQ 'Y'
     C                     Z-ADDJ3HKDT    W2KHDT
     C                     Z-ADDJ3HKTM    W2KHTM
     C                     MOVELJ3ATK1    W2ATK1
     C                     MOVELJ3ATK2    W2ATK2
     C                     MOVELJ3ATK3    W2ATK3
     C                     MOVELJ3ATK4    W2ATK4
     C                     MOVELJ3MTK1    W2MTK1
     C                     MOVELJ3MTK2    W2MTK2
     C                     MOVELJ3MTK3    W2MTK3
     C                     MOVELJ3MTK4    W2MTK4
     C           5         SUBSTJ3QR:11   W2KMAX  5
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *--------------------------
      * PLASTIC
      *--------------------------
     C           W@HKK1    WHEQ 'C'
     C           W@QKBN    ANDEQ'B01'
     C           KEY1      SETGTAAFPL31
     C                     DO   *HIVAL
     C           KEY1      REDPEAAFPL31                  80
     C   80                LEAVE
     C*
     C           A0SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C*
     C           A0HKB2    IFNE 'A'
     C                     ITER
     C                     ENDIF
     C*
     C           A0RDPM    IFEQ 'Y'
     C                     Z-ADDA0HKDT    W2KHDT
     C                     Z-ADDA0HKTM    W2KHTM
     C                     MOVELA0ATK1    W2ATK1
     C                     MOVELA0ATK2    W2ATK2
     C                     MOVELA0ATK3    W2ATK3
     C                     MOVELA0ATK4    W2ATK4
     C                     MOVELA0MTK1    W2MTK1
     C                     MOVELA0MTK2    W2MTK2
     C                     MOVELA0MTK3    W2MTK3
     C                     MOVELA0MTK4    W2MTK4
     C           5         SUBSTA0QR:11   W2KMAX  5
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSL
     C* FOUND
      * IF IT IS NOT FOUND, THEN UPDATE
1    C           *IN80     IFEQ *ON
|    C                     MOVEL'1'       WCHK
|    C* FOUND
1    C                     ELSE
|     *---------
|     * CHECK 5 DAYS LATER
|     *---------
|    C                     Z-ADD0         W3KHDT
|    C                     Z-ADD235959    W3KHTM
|    C                     MOVE W2KHDT    PDATE
|    C                     MOVEL'+'       PPORM
|    C                     MOVEL'0005'    PDAYS
|    C                     CALL 'DATR1A'
|    C                     PARM           PDATE   8
|    C                     PARM           PPORM   1        + OR -
|    C                     PARM           PDAYS   4
|    C                     PARM           PRDAT   8
|    C                     PARM           PRTN    1
|    C           PRTN      IFEQ '0'
|    C                     MOVE PRDAT     W3KHDT
|    C                     ENDIF
|     *
|    C* IF KANBAN READ IS SAME AS CURRENT KANBAN
|2   C           W1DTTM    IFEQ W2DTTM
||   C                     MOVEL'0'       WCHK
|2   C                     ENDIF
|    C*
|    C* KANBAN READ GREATER THAN CURRENT KANBAN    *UPDATE
|2   C           W1DTTM    IFGT W2DTTM
||   C                     MOVEL'1'       WCHK
||   C*
||   C* KANBAN READ <= 5 DAYS LATER OF CURRENT KANBAN  *NO UPDATE
||3  C           W1DTTM    IFLE W3DTTM
|||  C           K1MTKA    ANDEQW2MTKA
|||  C           K1ATKA    ANDEQW2ATKA
|||4 C           K1KMAX    IFEQ *BLANK
|||4 C           W2KMAX    OREQ *BLANK
|||| C                     MOVEL'0'       WCHK
|||4 C                     ELSE
||||5C           K1KMAX    IFEQ W2KMAX
|||||C                     MOVEL'0'       WCHK
||||5C                     ENDIF
|||4 C                     ENDIF
|||  C*
||3  C                     ENDIF
||   C*
|2   C                     ENDIF
|    C*
|    C* "ERROR"  KANBAN READ LESS THAN CURRENT KANBAN
|2   C           W1DTTM    IFLT W2DTTM
||   C                     MOVEL'9'       WCHK
|2   C                     ENDIF
|     *
1    C                     ENDIF
      *
     CSR         ESB100    ENDSR
      ****************************************************
      *  UPDATE
      ****************************************************
     CSR         #SB200    BEGSR
     C*
     C           KEY2      KLIST
     C                     KFLD           K1ATK1
     C                     KFLD           K1ATK2
     C                     KFLD           K1ATK3
     C                     KFLD           K1ATK4
     C                     KFLD           K1SHIN
     C                     KFLD           K1KHDT  80
     C                     KFLD           K1KHTM  60
      *
     C                     MOVEL*BLANK    UGET    1
      *
     C                     SELEC
      *----------------
      * PRODUCTION
      *----------------
     C           W@HKK1    WHEQ 'A'
     C           W@HKK1    OREQ 'Y'
     C           KEY2      SETGTABHPL31
     C                     DO   *HIVAL
     C           KEY2      REDPEABHPL31                  80
     C   80                LEAVE
     C*
     C           M0SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C*
     C           M0TYPE    IFEQ *BLANK                     NORMAL
     C           M0TYPE    OREQ 'A'                        RE-ISSUE
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C*
     C           M0RECD    IFNE '      SN'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVEL'Y'       M0RDPM
     C                     UPDATABHPL311
     C                     MOVEL'1'       UGET
      *
     C                     ENDDO
      *----------------
      * HEAT TREATMENT
      *----------------
     C           W@HKK1    WHEQ 'B'
     C           KEY2      SETGTADHPL31
     C                     DO   *HIVAL
     C           KEY2      REDPEADHPL31                  80
     C   80                LEAVE
      *
     C           J3SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C*
     C           J3HKB2    IFEQ *BLANK                     NORMAL
     C           J3HKB2    OREQ 'A'                        RE-ISSUE
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C*
     C                     MOVEL'Y'       J3RDPM
     C                     UPDATADHPL311
     C                     MOVEL'1'       UGET
      *
     C                     ENDDO
      *----------------
      * PLASTIC
      *----------------
     C           W@HKK1    WHEQ 'C'
     C           W@QKBN    ANDEQ'B01'
     C           KEY2      SETGTAAFPL31
     C                     DO   *HIVAL
     C           KEY2      REDPEAAFPL31                  80
     C   80                LEAVE
     C*
     C           A0SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C           A0HKB2    IFNE 'A'                        RE-ISSUE
     C                     ITER
     C                     ENDIF
      *
     C                     MOVEL'Y'       A0RDPM
     C                     UPDATAAFPL311
     C                     MOVEL'1'       UGET
      *
     C                     ENDDO
      *----------------
     C                     ENDSL
      ***
     C           UGET      IFEQ '1'
     C                     CLEARUEXPP141
     C                     MOVEL'OK'      L1OKNG
     C                     EXSR #SB300
     C                     ENDIF
      ***
      *
     CSR         ESB200    ENDSR
      ****************************************************
      *  WRITE LOG
      ****************************************************
     CSR         #SB300    BEGSR
     C*
     C                     TIME           WSDT
     C                     Z-ADDWDATE     L1CRDT
     C                     Z-ADDWTIME     L1CRTM
     C                     MOVEL#USER     L1CRUS
     C                     MOVEL#WSID     L1CRWS
     C*
     C                     MOVELK1LOT#    L1LOT#
     C                     MOVELK1PAGE    L1PAGE
     C*
     C                     MOVELK1ATK1    L1ATK1
     C                     MOVELK1ATK2    L1ATK2
     C                     MOVELK1ATK3    L1ATK3
     C                     MOVELK1ATK4    L1ATK4
     C                     MOVELK1PRT1    L1PRT1
     C                     MOVELK1PRT2    L1PRT2
     C                     MOVELK1PRT3    L1PRT3
      *
     C                     Z-ADDW2KHDT    L1NDAT
     C                     Z-ADDW2KHTM    L1NTIM
     C                     Z-ADDW1KHDT    L1ODAT
     C                     Z-ADDW1KHTM    L1OTIM
      *
     C                     MOVELW@DATA    L1DATA
      *
     C                     WRITEUEXPP141
     C*
     CSR         ESB300    ENDSR
