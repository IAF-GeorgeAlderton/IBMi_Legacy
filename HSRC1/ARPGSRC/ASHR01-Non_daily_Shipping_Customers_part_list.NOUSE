     C*-----------------------------------------------------
     C*  Main control routine
     C*-----------------------------------------------------
     C*
     C                     DO   *HIVAL
     C*
     C                     EXFMTFMT010
     C   KA                LEAVE
     C*
     C                     SELEC
     C           F1PRT     WHEQ '1'
     C                     MOVEL'LANPRT02'W#OUTQ  8
     C           F1PRT     WHEQ '2'
     C                     MOVEL'LANPRT07'W#OUTQ
     C           F1PRT     WHEQ '3'
     C                     MOVEL'LANPRT08'W#OUTQ
     C           F1PRT     WHEQ '4'
     C                     MOVEL'LANPRT03'W#OUTQ
     C           F1PRT     WHEQ '5'
     C                     MOVEL'QPRINTA 'W#OUTQ
     C           F1PRT     WHEQ '6'
     C                     MOVEL'LANPRT09'W#OUTQ
TCHK2C           F1PRT     WHEQ '7'
TCHK2C                     MOVEL'LANPRT10'W#OUTQ
TCHK2C           F1PRT     WHEQ '8'
TCHK2C                     MOVEL'LANPRT05'W#OUTQ
TCHK2C           F1PRT     WHEQ '9'
TCHK2C                     MOVEL'QDKT    'W#OUTQ
     C                     OTHER
     C                     MOVELERR,1     EMSG
     C                     MOVEL*ON       *IN31
     C                     ITER
     C                     ENDSL
     C*
     C           *INKE     IFEQ *ON
     C                     EXSR @PRINT
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
      *  Initialize
      *-----------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      *
     C                     TIME           W@TIME
      *
     C                     MOVE *ALL'-'   @LINE 132
      *
     C                     ENDSR
     C*-----------------------------------------------------
     C*  Print
     C*-----------------------------------------------------
     C           @PRINT    BEGSR
     C*
     C                     EXSR @P@INT
     C                     MOVEL*OFF      W#1ST   1
     C           *LOVAL    SETLLMBEPL03
     C*
     C                     DO   *HIVAL
     C*
     C                     READ MBEPL03                  95
     C   95                LEAVE
     C           F2SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C*
     C           K#GADP    KLIST
     C                     KFLD           F2TOKU
     C                     KFLD           F2NONY
     C                     KFLD           F2NKOJ
     C                     KFLD           F2NUKE
     C           K#GADP    CHAINGADPL11              94
     C           *IN94     IFEQ *ON
     C           B5SKJY    ORNE *BLANK
     C                     CLEARGADPL111
     C                     END
     C           B5HIZK    IFEQ 1
     C                     ITER
     C                     END
     C*
     C           W#1ST     IFEQ *OFF
     C                     EXCPT@HED
     C                     MOVEL*OFF      *INOF
     C                     MOVEL*ON       W#1ST
     C                     END
     C*
     C           F2MHN2    IFNE *BLANK
     C                     MOVEL'-'       W#MHNA
     C                     ELSE
     C                     MOVEL*BLANK    W#MHNA
     C                     END
     C           F2MHN3    IFNE *BLANK
     C                     MOVEL'-'       W#MHNB
     C                     ELSE
     C                     MOVEL*BLANK    W#MHNB
     C                     END
     C           F2MHN4    IFNE *BLANK
     C                     MOVEL'-'       W#MHNC
     C                     ELSE
     C                     MOVEL*BLANK    W#MHNC
     C                     END
      *
     C           F2SHN2    IFNE *BLANK
     C                     MOVEL'-'       W#SHNA
     C                     ELSE
     C                     MOVEL*BLANK    W#SHNA
     C                     END
     C           F2SHN3    IFNE *BLANK
     C                     MOVEL'-'       W#SHNB
     C                     ELSE
     C                     MOVEL*BLANK    W#SHNB
     C                     END
     C* print detail
     C           *INOF     IFEQ *ON
     C                     EXCPT@HED
     C                     MOVEL*OFF      *INOF
     C                     END
     C*
     C                     EXCPT@DTL
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*-----------------------------------------------------
     C*  Clear fields for Print
     C*-----------------------------------------------------
     C           @P@INT    BEGSR
     C*
     C                     MOVEACMD,1     ARX
     C                     MOVEAW#OUTQ    ARX,27
     C                     MOVEAARX       P@CMD     P
     C                     Z-ADD105       P@LEN
     C                     CALL 'QCMDEXC' P#CMD
     C*
     C                     OPEN QPRINT
     C*
     C                     ENDSR
     C*-----------------------------------------------------
     OQPRINT  E   02           @HED
