     H            Y/
     F***************************************************
     F*  MEMO ENTRY                                     *
     F*                                                 *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FAZAPW31 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FFCEPL01 IF  E           K        DISK
     FAZAPP51 UF  E           K        DISK                      A
      *------------------------------------------------------------
     E                    CMD     1   2 78
     E                    ERR     1   1 78
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   60D@YYMM
     I                                        1   40D@YY
     I                                        5   60D@MM
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C           W@ID      CASEQ'03'      #SCRN3
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#AZ5     KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C           K#AZS     KLIST
     C                     KFLD           S@PRT1
     C                     KFLD           S@PRT2
     C                     KFLD           S@PRT3
      *
     C                     MOVEL'01'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE *OFF      *IN50
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKI     WHEQ *ON
     C                     EXSR #SET3
     C           RRN1      IFEQ *ZERO
     C                     MOVE ERR,1     D@MSG
     C                     ELSE
     C                     MOVEL'03'      W@ID
     C                     ENDIF
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     MOVEL'02'      W@ID
     C                     EXSR #SET
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C           K#AZ5     CHAINFCEPL01              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR 2ND SCREEN
      *------------------------------------------------------
     C           #SET      BEGSR
      *
     C           K#AZ5     CHAINAZAPP51             N90
     C           *IN90     IFEQ *ON
     C                     MOVE *BLANK    D@MEMO
     C                     ELSE
     C                     MOVELZ5MEMO    D@MEMO
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ST SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVE *ON       *IN50
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     WRITEDSP01
     C                     EXFMTDSP02
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
     C                     MOVE '01'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK - 2ND SCREEN
      *------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     EXSR #CLR
      *
     C                     ENDSR
      *------------------------------------------------------
      *  UPDATE
      *------------------------------------------------------
     C           #UPD      BEGSR
      *
     C           K#AZ5     CHAINAZAPP51              90
     C   90                CLEARAZAPP511
      *
     C                     Z-ADD*DATE     Z5UPDT
     C                     TIME           Z5UPTM
     C                     MOVEL#WSID     Z5UPWS
     C                     MOVEL#USER     Z5USER
     C                     MOVEL#PGM      Z5UPGM
     C                     MOVELD@PRT1    Z5PRT1
     C                     MOVELD@PRT2    Z5PRT2
     C                     MOVELD@PRT3    Z5PRT3
     C                     MOVELD@MEMO    Z5MEMO
     C   90                WRITEAZAPP511
     C  N90                UPDATAZAPP511
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SET
      *------------------------------------------------------
     C           #SET3     BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
     C           *LOVAL    SETLLAZAPP51
     C           *IN90     DOUEQ*ON
     C                     READ AZAPP51                  90
     C           *IN90     IFEQ *OFF
     C           Z5UPGM    ANDNE'AZAR30'
     C                     MOVE Z5PRT1    S@PRT1
     C                     MOVE Z5PRT2    S@PRT2
     C                     MOVE Z5PRT3    S@PRT3
     C                     MOVE Z5MEMO    S@MEMO
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   3RD SCREEN
      *------------------------------------------------------
     C           #SCRN3    BEGSR
      *
     C                     MOVE *ON       *IN50
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
      *
     C           *INKE     WHEQ *ON
     C                     EXSR #UPD3
     C                     MOVE '01'      W@ID
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   UPDATE
      *------------------------------------------------------
     C           #UPD3     BEGSR
      *
     C                     Z-ADD*ZERO     RRN1
     C           *IN90     DOUEQ*ON
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           K#AZS     CHAINAZAPP51              91
     C           *IN91     IFEQ *OFF
     C           Z5MEMO    ANDNES@MEMO
     C                     Z-ADD*DATE     Z5UPDT
     C                     TIME           Z5UPTM
     C                     MOVEL#WSID     Z5UPWS
     C                     MOVEL#USER     Z5USER
     C                     MOVEL#PGM      Z5UPGM
     C                     MOVELS@MEMO    Z5MEMO
     C                     UPDATAZAPP511
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
**  CMD
F3: EXIT     ENTER: NEXT     F9: VIEW/EDIT
F3: EXIT     F5: UPDATE    F12: PREV
**  ERR
NO DATA !!!
