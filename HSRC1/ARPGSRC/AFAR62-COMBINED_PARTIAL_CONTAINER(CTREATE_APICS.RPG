     C           *IN91     IFEQ *OFF
     C                     Z-ADD9997      @@TOKU
     C                     ENDIF
     C                     ENDIF
      ** COMMON MASTER
     C           *IN91     IFEQ *ON
     C                     Z-ADD3656      K@TOKU
     C           K#FAA     CHAINFAAPL04              91
     C           *IN91     IFEQ *OFF
     C                     Z-ADD9997      @@TOKU
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN91     IFEQ *ON
     C                     Z-ADD3656      K@NONY
     C           KEY3X     CHAINMBDPL01              91
     C           *IN91     IFEQ *OFF
     C                     Z-ADD9997      @@TOKU
     C                     ENDIF
     C                     ENDIF
      ** COMMON MASTER
     C           *IN91     IFEQ *ON
     C                     Z-ADD3656      K@TOKU
     C           K#FAA     CHAINFAAPL04              91
     C           *IN91     IFEQ *OFF
     C                     Z-ADD9997      @@TOKU
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN91     IFEQ *ON
     C                     Z-ADD3712      K@NONY
     C           KEY3X     CHAINMBDPL01              91
     C           *IN91     IFEQ *OFF
     C                     Z-ADD9997      @@TOKU
     C                     ENDIF
     C                     ENDIF
