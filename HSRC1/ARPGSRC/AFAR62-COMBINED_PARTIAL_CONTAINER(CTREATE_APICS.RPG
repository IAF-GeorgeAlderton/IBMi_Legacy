     C           #AUP      BEGSR
      *
     C                     CLEARAU#PP111
      *
     C                     Z-ADD*DATE     CQKOHZ
     C                     TIME           CQKOTI
     C                     MOVEL#USER     CQKOME
     C                     MOVE AAPRT1    CQSHN1
     C                     MOVE AAPRT2    CQSHN2
     C                     MOVE AAPRT3    CQSHN3
      *
     C           K#AGA     CHAINFCEPL011             06
     C           A2DATE    IFLT *DATE
     C                     Z-ADDA2SSYS    CQSYUY
     C                     ELSE
     C                     Z-ADDA2KSYS    CQSYUY
     C                     ENDIF
      *
     C           AACOPY    MULT CQSYUY    CQSRYO
     C                     Z-SUBCQSRYO    CQSRYO
     C                     Z-ADD@NXDY     CQTHHZ
     C                     TIME           CQTHTI
     C                     Z-ADD*DATE     CQNOHZ
     C                     Z-ADD*ZERO     CQNOBB
     C                     MOVE 'G'       CQTHAI
     C                     MOVE 'K'       CQSKKB
     C                     Z-SUBAACOPY    CQHAKO
      *
     C                     MOVE '4'       CQDTSO
     C                     MOVE '32'      CQGYOM
     C                     Z-ADD*DATE     CQURHZ
     C                     TIME           CQURTI
     C                     MOVE 'B'       CQBNKA
     C                     MOVE AAPRT3    CQHBSB
     C           1         CHAINAUDPPNO1             30
      *
     C           *IN30     IFEQ '1'
     C                     Z-ADDUMONTH    ACTUKI
     C                     Z-ADD8500001   ACRENO
     C                     Z-ADD8500001   CQJTNO
     C                     WRITEAUDPPNO1
     C                     ELSE
      *
     C           ACTUKI    IFNE UMONTH
     C                     Z-ADDUMONTH    ACTUKI
     C                     Z-ADD8500001   ACRENO
     C                     Z-ADD8500001   CQJTNO
     C                     UPDATAUDPPNO1
     C                     ELSE
     C           ACRENO    ADD  1         ACRENO
     C                     Z-ADDACRENO    CQJTNO
     C                     UPDATAUDPPNO1
     C                     END
     C                     END
      *
     C                     WRITEAU#PP111
     C                     WRITEIU#PP111
      *
     C                     ENDSR
