     C                     ELSE
     C                     MOVE AACOPY    @COPY
     C                     ENDIF
     C           AAUPFG    IFEQ '1'
     C                     MOVE 'T'       @KANRI  1
     C                     ELSE
     C                     MOVE 'A'       @KANRI
     C                     ENDIF
      * CUSTOMER CHECK
     C                     Z-ADD*ZERO     @@TOKU
      * TMMWV
     C                     Z-ADD3931      K@NONY
     C           KEY3X     CHAINMBDPL01              91
     C           *IN91     IFEQ *OFF
     C                     Z-ADD9998      @@TOKU  40
     C                     ENDIF
      ** COMMON MASTER
     C           *IN91     IFEQ *ON
