     C           *IN11     IFEQ '0'
     C                     MOVELB2SMEI    BLK18  18 P
     C                     ENDIF
     C                     ENDIF
     C* KANBAN CODE BREAKE?
B1   C           AAKCD     IFNE WAKCD
     C*
     C                     EXCPTBLK
     C                     ADD  1         OSEQ#2
     C                     Z-ADD1         OSEQ#1
     C                     MOVE AAKCD     WAKCD
     C*
     C** NIJI-KAKO-KUBUN
B2   C           AAKCD     IFEQ 'C'
     C                     MOVE '0'       D17     1
     C*
X2   C                     ELSE
     C                     MOVE 'A'       D17
     C           ZETI      CHAINFCETL11              91
B3   C           *IN91     IFEQ '0'
     C*
B4   C           AADATE    IFGE A2DATE
     C                     MOVE A2STRK    KATK1
     C                     MOVE A2STRT    KATK2
     C                     MOVE A2STRR    KATK3
     C                     MOVE A2STRD    KATK4
     C*
X4   C                     ELSE
     C                     MOVE A2KTRK    KATK1
     C                     MOVE A2KTRT    KATK2
     C                     MOVE A2KTRR    KATK3
     C                     MOVE A2KTRD    KATK4
E4   C                     END
     C*
     C*
     C           KEY1      SETLLAAHPL03
     C           #READ1    TAG
     C           KEY1      READEAAHPL03                  92
B4   C           *IN92     IFEQ '0'
B5   C           AADATE    IFLT W6DATE
     C                     GOTO #READ1
E5   C                     END
     C*
     C           L6JOK1    LOKUPTAB1      TAB2           93
B5   C           *IN93     IFEQ '1'
     C                     MOVELTAB2      D17
     C*
E5   C                     END
     C*
E4   C                     END
     C*
E3   C                     END
E2   C                     END
     C*
     C                     EXCPTDT
     C                     ADD  1         OSEQ#2
     C*
     C* WRITE SAME KANBAN CODE DATA
X1   C                     ELSE
     C                     ADD  1         OSEQ#1
     C** NIJI-KAKO-KUBUN
B2   C           AAKCD     IFEQ 'C'
     C                     MOVE '0'       D17
     C*
     C                     ELSE
     C                     MOVE 'A'       D17
     C           ZETI      CHAINFCETL11              91
B3   C           *IN91     IFEQ '0'
     C*
B4   C           AADATE    IFGE A2DATE
     C                     MOVE A2STRK    KATK1
     C                     MOVE A2STRT    KATK2
     C                     MOVE A2STRR    KATK3
     C                     MOVE A2STRD    KATK4
     C*
     C                     ELSE
     C                     MOVE A2KTRK    KATK1
     C                     MOVE A2KTRT    KATK2
     C                     MOVE A2KTRR    KATK3
     C                     MOVE A2KTRD    KATK4
E4   C                     END
     C*
     C           KEY1      SETLLAAHPL03
     C           #READ2    TAG
     C           KEY1      READEAAHPL03                  92
B4   C           *IN92     IFEQ '0'
B5   C           AADATE    IFLT W6DATE
     C                     GOTO #READ2
E5   C                     END
     C*
     C           L6JOK1    LOKUPTAB1      TAB2           93
B5   C           *IN93     IFEQ '1'
     C                     MOVELTAB2      D17
E5   C                     END
     C*
E4   C                     END
     C*
E3   C                     END
E2   C                     END
     C*
     C                     EXCPTDT
     C                     ADD  1         OSEQ#2
E1   C                     END
     C*
     C                     MOVE 1         AAFLAG
     C                     UPDATAFAPP601
      * WRITE AU#PP11
     C           K#AGA     CHAINAGAPL311             50
     C           *IN50     IFEQ *OFF
     C           CBSKJY    ANDEQ*BLANK
     C                     EXSR #AUP
     C                     ENDIF
      * INVENTORY UPDATE
     C                     EXSR #INV
      *
