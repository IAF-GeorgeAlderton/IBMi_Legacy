     C           @INT      BEGSR
     C* NEXT WORKING DAY
     C                     Z-ADD*YEAR     K@YY
     C                     Z-ADD*MONTH    K@MM
     C                     Z-ADD*DAY      K@DD
     C                     Z-ADD*ZERO     X       20
     C           K#AGD     SETGTAGDPL12
     C           *IN91     DOUEQ*ON
     C                     READ AGDPL12                  91
     C           *IN91     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     ADD  1         X
     C           X         IFEQ 3
     C                     Z-ADDF8YMD     @NXDY   80
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD*ZERO     OSEQ#1  40
     C                     Z-ADD*ZERO     OSEQ#2  40
     C                     MOVE *BLANK    PRCD
     C                     MOVE '0'       WAPFG   1        APICS KANBAN
     C*
     C           WAPFG     SETLLAFAPP601
     C           *IN90     DOUEQ*ON
     C           WAPFG     READEAFAPP601                 90
     C           *IN90     IFEQ '1'
     C                     MOVE '1'       PRCD
     C*
     C* WRITE HEADER & BLOCK RECORD
     C                     ELSE
     C           AASKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
     C*
     C                     EXCPTHED
     C*
     C                     EXCPTBLK
     C                     ADD  1         OSEQ#2
     C                     MOVE AAKCD     WAKCD   1
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @MAIN
     C**************************************************************************
     C           @MAIN     BEGSR
     C*
     C           *IN90     DOWEQ'0'
     C           AASKJY    IFEQ *BLANK
      *
     C                     MOVE '000'     @COPY   3
     C           AACOPY    IFEQ *ZERO
