     H            Y.
      ** ALHR90 ********************************************
      *  LOQ INPROCESS DATA INQUIRY *TEMP                  *
      *                                                    *
      ******************************************************
     FALHPL03 IF  E           K        DISK
     FAAHTL06 IF  E           K        DISK
     FALHWP90 O   F     128            DISK
      *
     I            DS
     I                                        1  15 A1KAN
     I                                        1   1 A1KANR
     I                                        2   5 A1ZETI
     I                                        6   8 A1TEHI
     I                                        9  100A1PAGE
      *********************************************
      * KEY LIST
      *********************************************
     C           KEY1      KLIST
     C                     KFLD           K1Y     40
     C                     KFLD           K1M     20
     C                     KFLD           K1D     20
      *
     C           KEY2      KLIST
     C                     KFLD           A1SHN1  5
     C                     KFLD           A1SHN2  5
     C                     KFLD           A1SHN3  2
      *
      *********************************************
      * MAIN
      *********************************************
     C                     Z-ADD2020      K1Y
     C                     Z-ADD1         K1M
     C                     Z-ADD1         K1D
     C                     EXCPTOHED
      *
     C           KEY1      SETLLALHPL03
     C                     DO   *HIVAL
     C                     READ ALHPL03                  80
     C   80                LEAVE
      *
     C           A1SKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C           A1KAN     IFEQ *BLANK
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADD0         WLOT    20
     C                     Z-ADD0         WLOT2   20
     C                     Z-ADD0         SLOT    20
      *
     C           KEY2      SETGTAAHTL06
     C                     DO   *HIVAL
     C           KEY2      REDPEAAHTL06                  81
     C   81                LEAVE
     C           *IN81     IFEQ *OFF
     C           L6SKJY    ANDEQ*BLANK
     C           L6STYY    ANDEQ9999
     C                     Z-ADDL6LOTO    WLOT    20
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           WLOT      DIV  2         WLOT2   20
     C                     Z-ADD0         B       20
     C                     Z-ADD0         W1PAGE  20
      *
     C           A1KANR    IFEQ 'A'
      *
     C           A1PAGE    IFLE WLOT2
     C           1         DO   WLOT2     B
     C                     Z-ADDB         W1PAGE  20
     C                     EXCPTODAT
     C                     ENDDO
      *
     C                     ELSE
     C           WLOT2     ADD  1         SLOT    20
     C           SLOT      DO   WLOT      B
     C                     Z-ADDB         W1PAGE
     C                     EXCPTODAT
     C                     ENDDO
     C                     ENDIF
      *
     C                     ELSE
     C                     Z-ADDA1PAGE    W1PAGE
     C                     EXCPTODAT
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      ******************************************************
     OALHWP90 E                OHED
 1   O                                      'SCAN DATE,'
 2   O                                      'TIME,'
 3   O                                      'PART #,'
 4   O                                      'MACHINE #,'
 6   O                                      'CHARGE #,'
 7   O                                      'TREATMENT SEQ#,'
 8   O                                      'BARCODE,'
 9   O                                      'ABSO #,'
10   O                                      'LOT #,'
11   O                                      'PAGE #,'
      *
     OALHWP90 E                ODAT
      *
     O                         A1SCYY
     O                         A1SCMM
     O                         A1SCDD
     O                                      ','
     O                         A1SCTM
     O                                      ','
     O                         A1SHN1
     O                                      '-'
     O                         A1SHN2
     O                                      '-'
     O                         A1SHN3
     O                                      ',="'
     O                         A1OQNO
     O                                      '",="'
     O                         A1CHG#
     O                                      '",="'
     O                         A1TSQ#
     O                                      '",'
     O                         A1KAN
     O                                      ',="'
     O                         A1ZETI
     O                                      '",="'
     O                         A1TEHI
     O                                      '",="'
     O                         W1PAGE
     O                                      '",'
