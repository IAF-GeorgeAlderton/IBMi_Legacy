     H            Y.
      ** AB#R1R *******************************************
      *  EDI(824) MESSAGE LIST - GENTRAN AS400            *
      *  JW       2019.05.16                              *
      *  JW       2019.08.13 ADD PISTON                   *
      *****************************************************
     FAB#PL6M IF  E           K        DISK
     FAB#EP60SIF  E           K        DISK
     FAB#EL61SIF  E           K        DISK
     F            AB#E60S1                          KRENAMEAB#E61S1
     FQPRINT  O   F     132     OF     PRINTER
      *---------------------------------------------------------
     E                    NAM     1  15 12
     E                    MSG     1   1 60
     E                    FR         60  1
     E                    TO         60  1
      *
     I            DS
     I                                        1  99 M6DTER
     I                                        1   2 M6D1
     I                                        3   4 M6D2
     I                                        5   6 M6D3
     I            DS
     I                                        1  60 M6FSER
     I                                        1   3 M6FS1
     I            DS
     I                                        1  80 M6ADER
     I                                        1   8 M6AD1
     I                                        9  16 M6AD2
     I            DS
     I                                        1  20 WKMHIN
     I                                        1   5 WKMHN1
     I                                        6  10 WKMHN2
     I                                       11  15 WKMHN3
     I                                       16  20 WKMHN4
     I            DS
     I                                        1  18 WKSERL
     I                                        1   4 WKSER1
     I                                        5   5 WKSER2
     I                                        6  10 WKSERZ
     I                                       11  18 WKSER3
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      **********************************************************
      * MAIN ROUTINE
      **********************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ AB#PL6M                  95
     C   95                LEAVE
      * DENSO --------------------------------------------
     C                     MOVELM6PTRN    @PTN6   6
     C                     SELEC
     C           $GROUP    WHEQ 'DENSO   '
     C           @PTN6     IFEQ 'DMMIM1'
     C           @PTN6     OREQ 'GNC_N1'
     C           @PTN6     OREQ 'DMNCN1'
     C           @PTN6     OREQ 'DNMXT1'
     C           @PTN6     OREQ 'DNMXS1'
     C           @PTN6     OREQ 'DNMXM1'
     C           @PTN6     OREQ 'DMARA1'
     C           @PTN6     OREQ 'DMCNP1'
     C           @PTN6     OREQ 'DMTNA1'
     C                     MOVE 'Y'       @DENSO  1
     C           $RTN      IFEQ *BLANK
     C                     MOVE 'Y'       $RTN
     C                     ENDIF
     C                     EXSR #OUT
     C                     ELSE
     C                     ITER
     C                     ENDIF
      * SUBARU --------------------------------------------
     C           $GROUP    WHEQ 'SUBARU  '
     C           @PTN6     IFEQ 'SUBARU'
     C                     MOVE 'Y'       @SUBA   1
     C           $RTN      IFEQ *BLANK
     C                     MOVE 'Y'       $RTN
     C                     ENDIF
     C                     EXSR #OUT
     C                     ELSE
     C                     ITER
     C                     ENDIF
      * PISTON --------------------------------------------
     C           $GROUP    WHEQ 'PISTON  '
     C           @PTN6     IFEQ 'PA1   '
     C           @PTN6     OREQ 'PA4   '
     C           @PTN6     OREQ 'PA6   '
     C           @PTN6     OREQ 'PA7   '
     C                     MOVE 'Y'       @PIST   1
     C           $RTN      IFEQ *BLANK
     C                     MOVE 'Y'       $RTN
     C                     ENDIF
     C                     EXSR #OUT
     C                     ELSE
     C                     ITER
     C                     ENDIF
      *----
     C                     ENDSL
     C                     ENDDO
      * PRINT FOOT
     C           SEQ#      IFGT 0
     C                     EXCPT@FOT1
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------------------
      *  OUT PROCESS
      *-----------------------------------------------------------
     C           #OUT      BEGSR
      *
      * READ AB#EP60
     C           @DENSO    IFEQ 'Y'
     C           @SUBA     OREQ 'Y'
     C                     EXSR #EP60S
     C                     ENDIF
      *
     C           @PIST     IFEQ 'Y'
     C                     EXSR #EL61S
     C                     ENDIF
      *
      * SET CUSTOMER NAME
     C                     SELEC
     C           @PTN6     WHEQ 'DMMIM1'
     C                     Z-ADD1         IX      20
     C           @PTN6     WHEQ 'GNC_N1'
     C                     Z-ADD2         IX
     C           @PTN6     WHEQ 'DNMXT1'
     C                     Z-ADD3         IX
     C           @PTN6     WHEQ 'DNMXS1'
     C                     Z-ADD4         IX
     C           @PTN6     WHEQ 'DNMXM1'
     C                     Z-ADD9         IX
     C           @PTN6     WHEQ 'DMARA1'
     C                     Z-ADD5         IX
     C           @PTN6     WHEQ 'DMCNP1'
     C                     Z-ADD6         IX
     C           @PTN6     WHEQ 'DMTNA1'
     C                     Z-ADD7         IX
     C           @PTN6     WHEQ 'SUBARU'
     C                     Z-ADD8         IX
     C           @PTN6     WHEQ 'PA1   '
     C                     Z-ADD10        IX
     C           @PTN6     WHEQ 'PA4   '
     C                     Z-ADD11        IX
     C           @PTN6     WHEQ 'PA6   '
     C                     Z-ADD12        IX
     C           @PTN6     WHEQ 'PA7   '
     C                     Z-ADD13        IX
     C                     OTHER
     C                     Z-ADD7         IX
     C                     ENDSL
      * SET ERROR MSG
     C                     MOVELNAM,IX    ##NAM
     C                     MOVELM6ADER    XMSG1A 60
     C                     MOVELM6DTER    XMSG1B 60
     C                     MOVELM6FSER    XMSG1C 60
      *
     C           M6ADER    IFEQ *BLANK
     C                     MOVELM6DTER    XMSG1A
     C                     MOVELM6FSER    XMSG1B
     C                     MOVE *BLANK    XMSG1C
     C                     ELSE
     C                     MOVELM6ADER    XMSG1A
     C                     MOVELM6DTER    XMSG1B
     C                     MOVELM6FSER    XMSG1C
     C                     ENDIF
      * SUPPRESS 0
     C                     MOVEAXMSG1B    FR
     C                     EXSR #SUPP0
     C                     MOVEATO        XMSG1B
      *
     C           @PTN6     IFEQ 'SUBARU'
     C                     MOVE *BLANK    @@ORDN 10
     C                     ELSE
     C                     MOVELE1ORDN    @@ORDN
     C                     ENDIF
      *
     C           M6ACKC    IFEQ 'IA'
     C           XMSG1A    ANDEQ*BLANK
     C                     MOVELMSG,1     XMSG1A
     C                     ENDIF
      *
     C                     EXSR #PRINT
      *
     C           M6ACKC    IFEQ 'TR'
     C           M6ACKC    OREQ 'IR'
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *  READ AB#EP60S
      *-----------------------------------------------------------
     C           #EP60S    BEGSR
      *
     C                     MOVE 'N'       RFLG    1
     C                     MOVELM6SHID    K#SHID 10
     C**JW       K#SHID    CHAINAB#EP60S             99
     C**         *IN99     IFEQ *ON
     C**                   Z-ADD0         E1NOHZ
     C**                   Z-ADD0         E1NBIN
     C**                   MOVE *BLANK    E1ORDN
     C**                   MOVE *BLANK    E1NUKE
     C**                   ENDIF
      *
JW   C           K#SHID    SETLLAB#EP60S
 .   C                     DO   *HIVAL
 .   C           K#SHID    READEAB#EP60S                 99
 .   C   99                LEAVE
 .   C                     MOVE 'Y'       RFLG
 .   C                     ENDDO
 .    *
 .   C           RFLG      IFEQ 'N'
 .   C                     Z-ADD0         E1NOHZ
 .   C                     Z-ADD0         E1NBIN
 .   C                     MOVE *BLANK    E1ORDN
 .   C                     MOVE *BLANK    E1NUKE
JW   C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *  READ AB#EL61S
      *-----------------------------------------------------------
     C           #EL61S    BEGSR
      *
     C                     SELEC
     C           M6PTRN    WHEQ 'PA1   '
     C                     MOVEL'7448'    K#PRTN    P
     C           M6PTRN    WHEQ 'PA4   '
     C                     MOVEL'7450'    K#PRTN    P
     C           M6PTRN    WHEQ 'PA6   '
     C                     MOVEL'7451'    K#PRTN    P
     C           M6PTRN    WHEQ 'PA7   '
     C                     MOVEL'7452'    K#PRTN    P
     C                     OTHER
     C                     MOVE *BLANK    K#PRTN    P
     C                     ENDSL
      *
     C                     MOVE 'N'       RFLG
     C                     MOVELM6SHID    K#INVN    P
     C**JW       K#61      CHAINAB#EL61S             99
     C**         *IN99     IFEQ *ON
     C**                   Z-ADD0         E1NOHZ
     C**                   Z-ADD0         E1NBIN
     C**                   MOVE *BLANK    E1ORDN
     C**                   MOVE *BLANK    E1NUKE
     C**                   ENDIF
      *
JW   C           K#61      SETLLAB#EL61S
 .   C                     DO   *HIVAL
 .   C           K#61      READEAB#EL61S                 99
 .   C   99                LEAVE
 .   C                     MOVE 'Y'       RFLG
 .   C                     ENDDO
 .    *
 .   C           RFLG      IFEQ 'N'
 .   C                     Z-ADD0         E1NOHZ
 .   C                     Z-ADD0         E1NBIN
 .   C                     MOVE *BLANK    E1ORDN
 .   C                     MOVE *BLANK    E1NUKE
JW   C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *  SUPPRESS 0
      *-----------------------------------------------------------
     C           #SUPP0    BEGSR
      *
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         IZ      20
     C                     MOVEA*BLANK    TO
      *
     C           1         DO   60        IY      20
     C           FIRST     IFEQ 'Y'
     C           FR,IY     ANDEQ'0'
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         IZ
     C                     MOVE FR,IY     TO,IZ
     C                     MOVE 'N'       FIRST
      *
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *  PRINT
      *-----------------------------------------------------------
     C           #PRINT    BEGSR
      *
     C           LINE#     IFGE 60
     C                     EXCPT@HDR1
     C                     Z-ADD4         LINE#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL1
     C                     ADD  1         LINE#
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL1B
     C                     ADD  1         LINE#
      *
     C           XMSG1C    IFNE *BLANK
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL1C
     C                     ADD  1         LINE#
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *  INITIALIZE
      *-----------------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $GROUP  8
     C                     PARM           $RTN    1
      *
     C           K#61      KLIST
     C                     KFLD           K#PRTN 10
     C                     KFLD           K#INVN 16
      *
     C                     MOVE *BLANK    $RTN
      *
     C                     MOVE *ALL'-'   @LINE 132
     C                     TIME           @SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LINE#   20
     C                     MOVE *BLANK    XMSG1A 60
     C                     MOVE *BLANK    XMSG1B 60
     C                     MOVE *BLANK    XMSG1C 60
     C                     MOVE *BLANK    ##NAM  12
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR1
     O                         #PGM       8
     O                                   17 'QPRINT '
     O                         #USER     29
     O                                   52 '** EDI(824) MESSAGE '
     O                                   72 '**                  '
     O                         TODAY     97 '    /  /  '
     O                         NOW      107 '  :  :  '
     O                                  113 'PAGE'
     O                         PAGE  Z  117
     O        E   03           @HDR1
     O                                    5 'DELV#'
     O                                   13 'PARTNER'
     O                                   27 'ASN_DATE'
     O                                   34 'TIME'
     O                                   53 'SHP_ID'
     O                                   66 'ACK'
     O                                   71 'MSG'
     O        E   04           @HDR1
     O                                    2 '**'
     O                                   10 'NAME'
     O                                   27 'SHP_DATE'
     O                                   34 'BIN#'
     O                                   56 'MANIFEST#'
     O        E 1              @DTL1
     O                         @LINE    132
      *
     O        E 1              @DTL1
     O                         E1NONY     4
     O                         M6PTRN  +  2
     O                         M6ASND  +  3 '    /  /  '
     O                         M6ASNT  +  1 '0 :  '
     O                         M6SUPP  +  1
     O                         M6SHID  +  1
     O                         M6ACKC  +  1
     O                         XMSG1A   128
      *
     O        E 1              @DTL1B
     O                                    2 '**'
     O                         ##NAM     18
     O                         E1NOHZ    29 '    /  /  '
     O                                   34 'BIN:'
     O                         E1NBIN    36
     O                                   43 'DOCK:'
     O                         E1NUKE    47
     O                         @@ORDN    57
     O                         XMSG1B   128
      *
     O        E 1              @DTL1C
     O                         XMSG1C   128
      *
     O        E 1              @FOT1
     O                         @LINE    132
