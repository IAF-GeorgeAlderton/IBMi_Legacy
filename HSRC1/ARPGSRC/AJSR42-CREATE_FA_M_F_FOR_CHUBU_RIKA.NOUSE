     C*                    ELSE
     C*                    MOVE '2'       J1MKSK           使用区分
     C*                    END
     C************************************
     C*その他の内容をＦＡマスターに入力*
     C************************************
     C*                    Z-ADD0         J1KANS
     C*                    Z-ADD0         J1HHAK
     C*                    MOVE *BLANK    J1NOP
     C*
     C*                    MOVE *BLANK    J1MSNS
     C*                    MOVE *BLANK    J1MSZK
     C**************************
     C*トンネルかんばんＥＮＤ*
     C**************************
     C*          O4UPKB    IFEQ '0'
     C*                    WRITEAJSPL011
     C*          OUTKEN    ADD  1         OUTKEN
     C* ADD FOR PC DKT *
     C*                    EXCPTME3
     C*                    EXCPTME5
     C*          *INOE     IFEQ '1'
     C*                    SETOF                     OE
     C*                    EXCPTHD2
     C*                    END
     C*                    EXCPTCHG
     C*
     C*                    ELSE
     C*                    Z-ADDO4MKJI    J1MKJI
     C*                    MOVE O4SYKB    J1MKSK
     C*                    UPDATAJSPL011
