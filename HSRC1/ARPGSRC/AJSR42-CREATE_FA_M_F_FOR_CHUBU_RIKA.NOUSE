     C**********************************
     C*        １回のみの処理        *
     C**********************************
     C           *IN03     IFEQ '0'
     C                     SETON                     03
     C                     TIME           WTIME   60
     C                     EXCPTHD
     C                     EXCPTHD2
     C                     END
      *
     C** KOM *********************************
     C*構成品メッキかんばんマスターの読込み*
     C****************************************
     C*          1         SETLLAJSWP49
     C*                    SETOF                     30
     C*          KMLOOP    TAG
     C*                    READ AJSWP49                  30
     C*          *IN30     IFEQ '1'
     C*                    GOTO KOMEND
     C*                    ELSE
     C*          E1SKJY    IFEQ 'D'
     C*          E1SKHZ    IFLE *DATE
     C*                    GOTO KMLOOP
     C*                    END
     C*                    END
     C*                    END
     C*件数のカウント*
     C*          ALLKEN    ADD  1         ALLKEN  70
     C*ＦＡマスターＵＰＤＡＴの為のみのＣＨＡＩＮ(SUB) *
     C*                    SETOF                     95
     C*          E1UPKB    IFEQ '1'
     C*                    MOVE '*'       UP      1
     C*                    MOVE E1SHN1    CHKEY1  5        社内品番１
     C*                    MOVE E1SHN2    CHKEY2  5        社内品番２
     C*                    MOVE E1SHN3    CHKEY3  2        社内品番３
     C*                    MOVE E1SHN1    J1SHN1
     C*                    MOVE E1SHN2    J1SHN2
     C*                    MOVE E1SHN3    J1SHN3
     C*                    EXSR CHSUB
     C*          *IN95     IFEQ '1'
     C*                    MOVELMSG,7     PMSG
     C*                    EXCPTME
     C*                    EXSR PAGCHG
     C*                    GOTO KMLOOP
     C*                    END
     C*                    ELSE
     C*                    MOVE ' '       UP
     C*                    END
     C*ＦＡＭフィールドクリアーと旧変数格納(SUB) *
     C*                    EXSR CLRSUB
     C*構成品メッキかんばんマスターの内容をＦＡマスターに入力*
     C*                    MOVE E1SHN1    J1SHN1           社内品番１
     C*                    MOVE E1SHN2    J1SHN2           社内品番２
     C*                    MOVE E1SHN3    J1SHN3           社内品番３
     C*                    Z-ADDE1ATOB    J121CD           二次１加工先
     C*                    MOVE E1JOK1    J121M1           二次１ＢＺ１１
     C*                    MOVE E1JOK2    J121M2           二次１ＢＺ１２
     C*                    MOVE E1JOK3    J1NS11           荷姿条件１１
     C*                    MOVE E1JOK4    J1NS21           荷姿条件２１
     C*                    MOVE E1JOK5    J1NS22           荷姿条件２２
     C*                    MOVE E1JOK6    J1NS23           荷姿条件２３
     C*                    MOVE E1KCD1    J1KDAI           かんばん大
     C*                    MOVE E1KCD2    J1KSYO           かんばん小
     C*                    Z-ADDE1BARA    J1BAB1           バレルＡ
     C*                    Z-ADDE1BARB    J1BAB2           バレルＢ
     C*                    MOVELE1RAIN    J1MKBN           メッキ機番
     C*          J1MKBN    IFEQ *BLANK
     C*                    MOVE '??'      J1MKBN
     C*                    END
     C*                    MOVE E1MEK1    J1MEK1           メッキ処理１
     C*                    MOVE E1MEK2    J1MEK2           メッキ処理２
     C*                    MOVE E1MEK3    J1MEK3           メッキ処理３
     C*メッキ膜厚*
     C*                    SETOF                     16
     C*          E1MK21    LOKUPKZ                       16cﾇﾆﾞf kｩｮh
     C*          *IN16     IFEQ '1'
     C*                    MOVE E1MK21    MK1SUK
     C*                    ELSE
     C*                    MOVE '0'       MK1SUK
     C*                    END
     C*                    SETOF                     16
     C*          E1MK22    LOKUPKZ                       16cﾇﾆﾞf kｩｮh
     C*          *IN16     IFEQ '1'
     C*                    MOVE E1MK22    MK2SUK
     C*                    ELSE
     C*                    MOVE '0'       MK2SUK
     C*                    END
     C*                    Z-ADDKMAKU     J1MSMA           電・メッキ膜厚
     C*
     C*          E1MK14    IFEQ '.'
     C*                    MOVE *BLANK    J1MSCK
     C*                    ELSE
     C*                    MOVE E1MK14    J1MSCK           電・着色区分
     C*                    END
     C*
     C*                    MOVE *BLANK    J1MSAK           電・あき
     C****************************************
     C*構成品部品マスターのデータ入力(SUB) *
     C****************************************
     C*                    MOVE E1SHN1    BUHK1K  5
     C*                    MOVE E1SHN2    BUHK2K  5
     C*                    MOVE E1SHN3    BUHK3K  2
     C*                    SETOF                     99
     C*                    Z-ADD0         ER      10
     C*                    EXSR BUHINK
     C*          *IN99     IFEQ '1'
     C*                    MOVELMSG,ER    PMSG   42
     C*                    EXCPTME
     C*                    EXSR PAGCHG
     C*          ER        IFEQ 1                          1=BUHIN NOT
     C*          ER        OREQ 2                          2=BUHIN DEL
     C*          ERRKEN    ADD  1         ERRKEN  70
     C*                    GOTO KMLOOP
     C*                    ELSE
     C*          ERRKEI    ADD  1         ERRKEI  70
     C*                    END
     C*                    END
     C****************************************
     C*メッキ売掛金マスターの単重入力(SUB) *
     C****************************************
     C*                    MOVE E1SHN1    TAHIN1  5
     C*                    MOVE E1SHN2    TAHIN2  5
     C*                    MOVE E1SHN3    TAHIN3  2
     C*                    EXSR TANJYU
     C*          J1TANJ    IFEQ 0
     C*                    MOVE MSG,6     PMSG
     C*                    EXCPTME
     C*                    EXSR PAGCHG
     C*                    END
     C**************************************
     C*工程マスターで焼入れ有無入力(SUB) *
     C**************************************
     C*                    MOVE E1SHN1    KOTK1   5
     C*  NOT               MOVE E1SHN2    KOTK2   5
     C*                    MOVE E1SHN3    KOTK3   2
     C*    RUN !!!!!       SETOF                     99
     C*                    EXSR KOTEI
     C*          *IN99     IFEQ '1'
     C*                    MOVELMSG,ER    PMSG
     C*                    EXCPTME
     C*                    EXSR PAGCHG
     C*                    END
     C*                    Z-ADD0         J1MSNT
     C*************************
     C*メッキ係数の計算(SUB)*
     C*************************
     C*                    SETOF                     96
     C*                    EXSR MEKKI
     C*
     C*          *IN96     IFEQ '1'
     C*                    Z-ADD0         J1MKRI           理論値
     C*                    ELSE
     C*                    Z-ADDK         J1MKRI           理論値
     C*                    END
     C*理論値＝実践値*
     C*                    Z-ADDJ1MKRI    J1MKJI           実践値
     C*メッキ係数使用区分の入力*
     C*０＝無　１＝理　２＝実*
     C*          J1MKJI    IFEQ 0
     C*                    MOVE '0'       J1MKSK           使用区分
     C*                    ELSE
     C*                    MOVE '2'       J1MKSK           使用区分
     C*                    END
     C************************************
     C*その他の内容をＦＡマスターに入力*
     C************************************
     C*                    Z-ADD0         J1KANS
     C*                    Z-ADD0         J1HHAK
     C*                    MOVE *BLANK    J1NOP
     C*
     C*                    MOVE *BLANK    J1MSNS
     C*                    MOVE *BLANK    J1MSZK
     C*更新日・者
     C*                    Z-ADD*YEAR     J1KOYY
     C*                    Z-ADDUMONTH    J1KOMM
     C*                    Z-ADDUDAY      J1KODD
     C*                    Z-ADDUJI       J1KOHH
     C*                    Z-ADDUFUN      J1KOSS
     C*                    MOVEL'AJSR42'  J1KOME
     C******************************
     C*   ＦＡマスターに書出し   *
     C******************************
     C*          E1UPKB    IFEQ '0'
     C*                    WRITEAJSPL011
     C*          OUTKEN    ADD  1         OUTKEN  70
     C* ADD FOR PC DKT *
     C*                    EXCPTME3
     C*                    EXCPTME5
     C*          *INOE     IFEQ '1'
     C*                    SETOF                     OE
     C*                    EXCPTHD2
     C*                    END
     C*                    EXCPTCHG
     C*
     C*                    ELSE
     C*                    Z-ADDE1MKJI    J1MKJI
     C*                    MOVE E1SYKB    J1MKSK
     C*                    UPDATAJSPL011
     C*          UPKEN     ADD  1         UPKEN   70
     C* ＦＡＭの変更有りかのチェック(MKSUB) *
     C*                    EXSR MKSUB
     C*                    END
     C*
     C*                    GOTO KMLOOP
     C*          KOMEND    TAG
     C** KOT ***********************************
     C*構成品トンネルかんばんマスターの読込み*
     C******************************************
     C*          1         SETLLAJSWP4A
     C*                    SETOF                     30
     C*          KTLOOP    TAG
     C*                    READ AJSWP4A                  30
     C*          *IN30     IFEQ '1'
     C*                    GOTO KOTEND
     C*                    ELSE
     C*          E2SKJY    IFEQ 'D'
     C*          E2SKHZ    IFLE *DATE
     C*                    GOTO KTLOOP
     C*                    END
     C*                    END
     C*                    END
     C*件数のカウント*
     C*          ALLKEN    ADD  1         ALLKEN  70
     C*ＦＡマスターＵＰＤＡＴの為のみのＣＨＡＩＮ(SUB) *
     C*                    SETOF                     95
     C*          E2UPKB    IFEQ '1'
     C*                    MOVE '*'       UP      1
     C*                    MOVE E2SHN1    CHKEY1  5        社内品番１
     C*                    MOVE E2SHN2    CHKEY2  5        社内品番２
     C*                    MOVE E2SHN3    CHKEY3  2        社内品番３
     C*                    MOVE E2SHN1    J1SHN1
     C*                    MOVE E2SHN2    J1SHN2
     C*                    MOVE E2SHN3    J1SHN3
     C*                    EXSR CHSUB
     C*          *IN95     IFEQ '1'
     C*                    MOVELMSG,7     PMSG
     C*                    EXCPTME
     C*                    EXSR PAGCHG
     C*                    GOTO KTLOOP
     C*                    END
     C*                    ELSE
     C*                    MOVE ' '       UP
     C*                    END
     C*ＦＡＭフィールドクリアーと旧変数格納(SUB) *
     C*                    EXSR CLRSUB
     C*構成品トンネルかんばんマスターの内容をＦＡマスターに入力*
     C*                    MOVE E2SHN1    J1SHN1           社内品番１
     C*                    MOVE E2SHN2    J1SHN2           社内品番２
