     C*                    MOVE '0'       MK1SUU
     C*                    END
     C*                    SETOF                     16
     C*          C2MK22    LOKUPKZ                       16cﾇﾆﾞf kｩｮh
     C*          *IN16     IFEQ '1'
     C*                    MOVE C2MK22    MK2SUU
     C*                    ELSE
     C*                    MOVE '0'       MK2SUU
     C*                    END
