     C           *IN98     IFEQ '1'
     C                     GOTO EXT
     C                     ENDIF
      *
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    ANDLE*DATE
     C                     GOTO EXT
     C                     ENDIF
      *
     C           L6UKHZ    IFGT *DATE
     C                     GOTO EXT
     C                     ENDIF
      *
     C           L6STHZ    IFLT *DATE
     C                     GOTO EXT
     C                     ENDIF
      *
     C*                    MOVE 'E'       J1KDAI
     C*                    MOVE 'Z'       J1KSYO
%0002C                     MOVE 'C'       J1KDAI
%0002C                     MOVE 'A'       J1KSYO
     C                     SETON                     98
