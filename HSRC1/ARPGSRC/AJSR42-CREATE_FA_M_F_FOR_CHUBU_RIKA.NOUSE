     C*                    END
     C*
     C*                    GOTO TOLOOP
     C*          TONEND    TAG
     C** ARRS **************************
     C*   ＡＲＲＳマスターの読込み   *
     C**********************************
     C*          1         SETLLAJSWP46
     C*                    SETOF                     30
     C*          ARSLOP    TAG
     C*                    READ AJSWP46                  30
     C*          *IN30     IFEQ '1'
     C*                    GOTO ARSEND
     C*                    ELSE
     C*          OBSKJY    IFEQ 'D'
     C*          OBSKHZ    IFLE *DATE
     C*                    GOTO ARSLOP
     C*                    END
     C*                    END
     C*                    END
     C*件数のカウント*
     C*          ALLKEN    ADD  1         ALLKEN  70
     C*ＦＡマスターＵＰＤＡＴの為のみのＣＨＡＩＮ(SUB) *
     C*                    SETOF                     95
     C*          OBUPKB    IFEQ '1'
     C*                    MOVE '*'       UP      1
     C*                    MOVE OBHIN1    CHKEY1  5        社内品番１
     C*                    MOVE OBHIN2    CHKEY2  5        社内品番２
     C*                    MOVE OBHIN3    CHKEY3  2        社内品番３
     C*                    MOVE OBHIN1    J1SHN1
     C*                    MOVE OBHIN2    J1SHN2
     C*                    MOVE OBHIN3    J1SHN3
     C*                    EXSR CHSUB
     C*          *IN95     IFEQ '1'
     C*                    MOVELMSG,7     PMSG
     C*                    EXCPTME
     C*                    EXSR PAGCHG
     C*                    GOTO ARSLOP
     C*                    END
     C*                    ELSE
     C*                    MOVE ' '       UP
     C*                    END
     C*ＦＡＭフィールドクリアーと旧変数格納(SUB) *
     C*                    EXSR CLRSUB
     C*ＡＲＲＳマスターの内容をＦＡマスターに入力*
     C*                    MOVE OBHIN1    J1SHN1           社内品番１
     C*                    MOVE OBHIN2    J1SHN2           社内品番２
     C*                    MOVE OBHIN3    J1SHN3           社内品番３
     C**********************************
     C*部品マスターのデータ入力(SUB) *
     C**********************************
     C*                    MOVE OBHIN1    BUHK1   5
     C*                    MOVE OBHIN2    BUHK2   5
     C*                    MOVE OBHIN3    BUHK3   2
     C*                    SETOF                     99
     C*                    Z-ADD0         ER      10
     C*                    EXSR BUHIN
     C*          *IN99     IFEQ '1'
     C*                    MOVELMSG,ER    PMSG   42
     C*                    EXCPTME
     C*                    EXSR PAGCHG
     C*          ER        IFEQ 1                          1=BUHIN NOT
     C*          ER        OREQ 2                          2=BUHIN DEL
     C*          ERRKEN    ADD  1         ERRKEN  70
     C*                    GOTO ARSLOP
     C*                    ELSE
     C*          ERRKEI    ADD  1         ERRKEI  70
     C*                    END
     C*                    END
     C****************************************
     C*メッキ売掛金マスターの単重入力(SUB) *
     C****************************************
     C*                    MOVE OBHIN1    TAHIN1  5
     C*                    MOVE OBHIN2    TAHIN2  5
     C*                    MOVE OBHIN3    TAHIN3  2
     C*                    EXSR TANJYU
     C*          J1TANJ    IFEQ 0
     C*                    MOVE MSG,6     PMSG
     C*                    EXCPTME
     C*                    EXSR PAGCHG
     C*                    END
     C**************************************
