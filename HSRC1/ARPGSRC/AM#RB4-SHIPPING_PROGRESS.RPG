     H            Y.
     F** AM#RB4  *******************************************
     F* SHIPPING PROGRESS                                  *
     F*      ITS.        2015.06.23                        *
     F******************************************************
     FAM#WPB3 IF  E           K        DISK
     FAM#WPB1 UF  E           K        DISK                      A
     E                    WCD        99 10
      *
     I            DS
     I                                        1  140W3AST
     I                                        1   80W3ASTD
     I                                        9  140W3ASTT
      *
     I            DS
     I                                        1  140W3AED
     I                                        1   80W3AEDD
     I                                        9  140W3AEDT
      *
     I            DS
     I                                        1  140W4AST
     I                                        1   80W4ASTD
     I                                        9  140W4ASTT
      *
     I            DS
     I                                        1  140W4AED
     I                                        1   80W4AEDD
     I                                        9  140W4AEDT
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      *
     C                     READ AM#WPB31                 81
     C           *IN81     DOWEQ'0'
     C                     EXSR #SB500
     C                     READ AM#WPB31                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AM#WP64
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C           KEY33     KLIST
     C                     KFLD           W3SHID
     C                     KFLD           W3SHIT
     C                     KFLD           W3SURT
     C                     KFLD           W3TRKB
      *
     C           KEY33     CHAINAM#WPB11             24
     C           *IN24     IFEQ '0'
     C                     ADD  1         W1KPLT
     C           W3BOX     IFEQ W3SUMI
     C                     ADD  1         W1COMP
     C                     ELSE
     C                     ENDIF
     C                     UPDATAM#WPB11
     C                     ELSE
     C                     CLEARAM#WPB11
     C                     MOVELW3SHID    W1SHID
     C                     MOVELW3SHIT    W1SHIT
     C                     MOVELW3SURT    W1SURT
     C                     MOVELW3TRKB    W1TRKB
     C                     Z-ADD1         W1KPLT
     C           W3BOX     IFEQ W3SUMI
     C                     Z-ADD1         W1COMP
     C                     ELSE
     C                     ENDIF
     C                     WRITEAM#WPB11
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
