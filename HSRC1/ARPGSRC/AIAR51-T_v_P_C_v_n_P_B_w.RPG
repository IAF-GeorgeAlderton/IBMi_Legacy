     C                     TIME           HHMMSS  60
     C                     MOVE HHMMSS    STIME
     C*----------------------*
     C*   INZ                *
     C*----------------------*
     C           *ENTRY    PLIST
     C                     PARM           PSTS    1
     C                     PARM           PLOCAT  4        ﾜiｰﾆｭ]
     C                     PARM           PSYSTM  2        ﾆﾇmwhﾎﾞ]
     C                     PARM           PKFLG  20        ﾆｰi]ﾇﾃｰnﾞ
     C                     PARM           PFILE  10        ﾎｦbﾓxb
     C                     PARM           PSFLG   1        cﾎ cw
     C                     PARM           PUALL 116        ﾌﾟ[xｰj
      *
     C                     MOVE PUALL     UALL
      *
     C                     CLEARPSTS
     C                     CLEARPKFLG
     C                     CLEARPFILE
     C                     CLEARPSFLG
      *
     C*----------------------*
     C*   mﾞｰjdﾒa DJOBNO     *
     C*----------------------*
     C           *NAMVAR   DEFN AIADS1    DJOBN   50
      *
     C*---------------------------------*
     C*   RQﾛﾃｰnﾞ､ATﾛﾃｰnﾞを　読む     *
     C*---------------------------------*
     C           STP1      TAG
     C                     Z-ADD0         X       20
     C                     DO   *HIVAL
     C                     READ INPUT                    03
     C                     ADD  1         X
     C           X         IFEQ 1
     C                     MOVELRDATA     ADATA
     C                     MOVELRDATA     CDATA
     C                     END
     C  N03                ENDDO
      *
     C*------------------------------------*
     C*  時間　の　設定                  *
     C*   ﾜｰfﾓmﾞｰjdﾒa xｮﾈｰﾆﾞﾃｰnﾞ '00'      *
     C*               ﾎｦbﾓxb     ﾎﾞ[]h     *
     C*   JOBLOGﾎｦbﾓ  ﾒjｰ]ﾃｰnﾞ   ﾎﾞ[]h     *
     C*------------------------------------*
     C                     TIME           WTIME
     C                     MOVE AMESG     UMESG
     C                     MOVE AKUBN     UKUBN
     C                     MOVE ABLOK     UBLOK
     C                     MOVE AKANB     UKANB
     C                     MOVE *BLANK    PFILE
     C                     MOVE *BLANK    D6RETN
      *
     C*------------------------------------------------*
     C*  ＲＱ、ＨＤ、ＥＥ通信ファイルの内容チェック  *
     C*                                                *
     C*------------------------------------------------*
     C                     SETOF                     03
     C                     TESTN          CBMON      03
     C           *IN03     IFEQ '0'
     C                     MOVE '1'       *IN01
     C                     Z-ADDUJOBN     D6JBNO
     C                     MOVE '40'      D6ERCD
     C                     EXSR SUBJOB
     C                     MOVE 'E'       PSTS
     C                     GOTO STPEND
     C                     END
      *
     C                     SETOF                     03
     C                     TESTN          CNOHZ      03
     C           *IN03     IFEQ '0'
     C                     MOVE '1'       *IN01
     C                     Z-ADDUJOBN     D6JBNO
     C                     MOVE '40'      D6ERCD
     C                     EXSR SUBJOB
     C                     MOVE 'E'       PSTS
     C                     GOTO STPEND
     C                     END
      *
     C                     SETOF                     03
     C                     TESTN          CNBIN      03
     C           *IN03     IFEQ '0'
     C                     MOVE '1'       *IN01
%0001C                     Z-ADD88888     D6JBNO
     C                     MOVE '40'      D6ERCD
     C                     EXSR SUBJOB
     C                     MOVE 'E'       PSTS
     C                     GOTO STPEND
     C                     END
      *
     C*--------------------------------------------*
     C*  ＲＥＣ．ＩＤ　レコード区分　ＡＴ以外    *
     C*   mﾞｰjdﾒa  JOBNO + 1 = JOBNO               *
     C*--------------------------------------------*
     C           ARECD     IFNE 'AT'
     C           *LOCK     IN   *NAMVAR
     C                     ADD  1         DJOBN
     C                     Z-ADDDJOBN     UJOBN
     C                     OUT  *NAMVAR
     C                     END
      *
     C*------------------------------------------------*
     C*  ＲＥＣ．ＩＤ　工場コード                    *
     C*   0111の　チェック                           *
     C*------------------------------------------------*
     C                     SETOF                     03
     C                     Z-ADD1         A       20
     C           ABMON     LOKUPHKJ,A                    03
     C           *IN03     IFEQ '0'
     C                     MOVE '1'       *IN01
     C                     Z-ADDUJOBN     D6JBNO
     C                     MOVE '25'      D6ERCD
     C                     EXSR SUBJOB
     C                     MOVE 'E'       PSTS
     C                     GOTO STPEND
     C                     END
      *
     C*-----------------------------------*
     C*  ＲＥＣ．ＩＤ　レコード区分     *
     C*  ＲＱ・ＡＴ　？                 *
     C*-----------------------------------*
     C           ARECD     IFNE 'RQ'
     C                     MOVE '1'       *IN01
     C                     Z-ADDUJOBN     D6JBNO
     C                     MOVE '24'      D6ERCD
     C                     MOVE AKFLG     PKFLG
     C                     EXSR SUBJOB                     RQ WRITE LOG
     C                     MOVE 'HD'      ARECD
     C                     MOVE '24'      AMESG
     C                     MOVE ADATA     SDATA 256
     C                     EXSR SUBJOB
     C                     EXCPTDAT                        HD WRITE LOG
     C                     MOVE '*'       PSFLG
     C                     GOTO STPEND
     C                     END
      *
     C*-------------------------------------*
     C*  ＲＥＣ．ＩＤ　データグループ     *
     C*  ０Ａ・ＡＡ・ＡＢ・ＡＣ　？       *
     C*-------------------------------------*
     C           AGRUP     IFNE '0A'
     C           AGRUP     ANDNE'AA'
     C           AGRUP     ANDNE'AB'
     C           AGRUP     ANDNE'AC'
     C                     MOVE '1'       *IN01
     C                     Z-ADDUJOBN     D6JBNO
     C                     MOVE '03'      D6ERCD
     C                     MOVE AKFLG     PKFLG
     C                     EXSR SUBJOB                     RQ WRITE LOG
     C           ARECD     IFEQ 'RQ'
     C                     MOVE 'HD'      ARECD
     C                     MOVE '03'      AMESG
     C                     MOVE ADATA     SDATA
     C                     EXSR SUBJOB                     HD WRITE LOG
     C                     EXCPTDAT
     C                     END
     C                     MOVE '*'       PSFLG
     C                     GOTO STPEND
     C                     END
      *
     C*----------------------------------------------------*
     C*  ＲＱレコード　の　処理     *                    *
     C*-------------------------------*                    *
     C*----------------------------------------------------*
     C*  ＲＱレコード　データグループ                    *
     C*  0A --> データ転送コントロールファイルに有るか？ *
     C*  AA --> 時刻別計算便マスターに有るか？           *
     C*  AB --> 工程内かんばんデータに有るか？           *
     C*  AC --> 焼入かんばんデータに有るか？             *
     C*----------------------------------------------------*
     C*------------------------------*                     *
     C*  各かんばんマスターデータ  *                     *
     C*------------------------------*                     *
     C           AGRUP     IFEQ '0A'                       *
     C           KEY1      KLIST                           *
     C                     KFLD           ABMON            *
     C                     KFLD           AGRUP            *
     C                     SETOF                     03    *
     C           KEY1      CHAINAALPL111             03    *
     C           *IN03     IFEQ '1'                        *
     C                     MOVE '1'       *IN01            *
     C                     Z-ADDUJOBN     D6JBNO           *
     C                     MOVE '01'      D6ERCD           *
     C                     MOVE AKFLG     PKFLG
     C                     EXSR SUBJOB                     RQ WRITE LOG
     C                     MOVE 'HD'      ARECD            *
     C                     MOVE '01'      AMESG            *
     C                     MOVE ADATA     SDATA            *
     C                     EXSR SUBJOB                     HD WRITE LOG
     C                     EXCPTDAT                        *
     C                     MOVE '*'       PSFLG
     C                     GOTO STPEND                     *
     C                     ELSE                            *
     C                     UPDATAALPL111                   *
     C                     END                             *
     C                     ELSE                            *
      *
     C*--------------------*                               *
     C*  生産指示データ  *                               *
     C*--------------------*                               *
     C           AGRUP     IFEQ 'AA'                       *
     C                     SETOF                     03    *
     C           ABMON     CHAINAAIPL111             03    *
     C           *IN03     IFEQ '1'                        *
     C                     MOVE '1'       *IN01            *
     C                     Z-ADDUJOBN     D6JBNO           *
     C                     MOVE '02'      D6ERCD           *
     C                     MOVE AKFLG     PKFLG
     C                     EXSR SUBJOB                     RQ WRITE LOG
     C                     MOVE 'HD'      ARECD            *
     C                     MOVE '02'      AMESG            *
     C                     MOVE ADATA     SDATA            *
     C                     EXSR SUBJOB                     *
     C                     EXCPTDAT                        HD WRITE LOG
     C                     MOVE '*'       PSFLG
     C                     GOTO STPEND                     *
     C                     ELSE                            *
     C                     UPDATAAIPL111                   *
     C                     END                             *
     C                     ELSE                            *
      *
     C*--------------------------*                         *
     C*  工程内かんばんデータ  *                         *
     C*  焼入かんばんデータ    *                         *
     C*--------------------------*                         *
     C                     SETOF                     03    *
     C                     MOVE *BLANK    XFILE            *
     C           AGRUP     IFEQ 'AB'                       *
     C                     MOVE 'AADT'    XFIL1            *
     C                     MOVE ABMON     XFIL2            *
     C                     ELSE                            *
     C           AGRUP     IFEQ 'AC'                       *
     C                     MOVE 'AAET'    XFIL1            *
     C                     MOVE ABMON     XFIL2            *
     C                     END                             *
     C                     END                             *
     C           XFILE     CHAINAAIPP211             03    *
     C           *IN03     IFEQ '1'                        *
     C                     MOVE '1'       *IN01            *
     C                     Z-ADDUJOBN     D6JBNO           *
     C                     MOVE '34'      D6ERCD           *
     C                     MOVE AKFLG     PKFLG
     C                     EXSR SUBJOB                     RQ WRITE LOG
     C                     MOVE 'HD'      ARECD            *
     C                     MOVE '34'      AMESG            *
     C                     MOVE ADATA     SDATA            *
     C                     EXSR SUBJOB                     HD WRITE LOG
     C                     EXCPTDAT                        *
     C                     MOVE '*'       PSFLG
     C                     GOTO STPEND                     *
     C                     ELSE                            *
     C                     UPDATAAIPP211                   *
JW1  C                     EXSR #LOG
     C                     END                             *
     C                     END                             *
     C                     END                             *
      *
     C*---------------------------------------------*      *
     C*  ローカルデータエリア　レコード種別       *      *
     C*  ブランク・ＡＴ？                         *      *
     C*---------------------------------------------*      *
     C           URECD     IFNE *BLANK                     *
     C           URECD     IFNE 'AT'                       *
      *
     C*---------------------------------------------*      *
     C*  ローカルデータエリア　レコード種別       *      *
     C*  ＥＥ？                                   *      *
     C*---------------------------------------------*      *
     C           URECD     IFEQ 'EE'                       *
      *
     C*----------------------------------------------*     *
     C*  ＩＦ文　比較                              *     *
     C*  現時刻　・　ローカルデータエリア          *     *
     C*  －５分　・　転送時刻                      *     *
     C*----------------------------------------------*     *
     C                     TIME           CTIME            *
     C           CMM       IFLE 09                         *
     C                     SUB  10        CMM              *
     C                     ADD  60        CMM              *
     C           CHH       IFEQ 0                          *
     C                     Z-ADD23        CHH              *
     C                     ELSE                            *
     C                     SUB  1         CHH              *
     C                     END                             *
     C                     ELSE                            *
     C                     SUB  10        CMM              *
     C                     END                             *
     C           UHH       IFGT CHH                        *
     C                     ADD  UHH       CHH              *
     C                     ADD  1         CHH              *
     C                     END                             *
     C           CTIME     IFGE UTIME                      *
     C                     MOVE '30'      D6ERCD           *
     C                     GOTO STP5                       *
     C                     END                             *
      *
     C*----------------------------------------------------*
     C*  ＡＴレコードの前に                              *
     C*  ＲＱレコードを受信した場合　データ送信          *
     C*----------------------------------------------------*
     C           ABMON     IFEQ 0111                       *
     C           U0111     ANDEQ'EE'                       *
     C                     MOVE '33'      D6ERCD           *
     C                     GOTO STP5                       *
     C                     END                             *
      *
     C*---------------------------------*                  *
     C*  ＨＤレコード項目セット       *                  *
     C*---------------------------------*                  *
     C                     MOVE '1'       *IN01            *
     C                     Z-ADDUJOBN     D6JBNO           *
     C                     MOVE '04'      D6ERCD           *
     C                     MOVE AKFLG     PKFLG
     C                     EXSR SUBJOB                     RQ WRITE LOG
     C                     MOVE 'HD'      ARECD            *
     C                     MOVE '04'      AMESG            *
     C                     MOVE ADATA     SDATA            *
     C                     EXSR SUBJOB                     HD WRITE LOG
     C                     EXCPTDAT                        *
     C                     MOVE '*'       PSFLG
     C                     GOTO STPEND                     *
     C                     END                             *
     C                     MOVE '29'      D6ERCD           *
     C                     GOTO STP5                       *
     C                     END                             *
     C                     END                             *
     C                     MOVE '00'      D6ERCD           *
     C           STP5      TAG                             *
     C                     MOVE 'RQ'      URECD            *
     C                     Z-ADDABMON     UBMON            *
     C                     MOVE AGRUP     UGRUP            *
     C                     TIME           UTIME            *
     C                     Z-ADDANOHZ     UNOHZ            *
     C                     Z-ADDANBIN     UNBIN            *
     C                     MOVE AKUBN     UKUBN            *
     C                     Z-ADDUJOBN     D6JBNO           *
     C                     MOVE AKFLG     PKFLG
     C                     EXSR SRQ                        *
     C                     EXSR SUBJOB                     RQ WRITE LOG
      *
     C*--------------------------*                         *
     C*  生産指示データか？    *                         *
     C*--------------------------*                         *
     C           AGRUP     IFEQ 'AA'                       *
      *
     C*------------*                                       *
     C*  再生    *                                       *
     C*------------*                                       *
     C           AKUBN     IFEQ 'R'                        *
      *
     C*----------------------------------------------------*
     C*  ＲＱレコードの納入日が時刻別計算便マスターの    *
     C*  前日便の日付・当日便の日付のどちらかが？        *
     C*----------------------------------------------------*
     C           ANOHZ     IFNE CDZNH8                     *
     C           ANOHZ     IFNE CDTOH8                     *
     C                     MOVE '15'      AMESG            *
     C                     MOVE '15'      D6ERCD           *
     C                     GOTO STP10                      *
     C                     END                             *
     C                     END                             *
      *
     C*----------------------------------------------------*
     C*  ＲＱレコードの納入日便が時刻別計算便マスターの  *
     C*  引取サイクルの便と等しく小さいか？              *
     C*----------------------------------------------------*
     C           ANBIN     IFLE CDCIBI                     *
     C                     GOTO STP11                      *
     C                     END                             *
     C                     MOVE '16'      AMESG            *
     C                     MOVE '16'      D6ERCD           *
     C           STP10     TAG                             *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     MOVE 'AT'      URECD            *
     C                     TIME           UTIME            *
     C                     Z-ADDUJOBN     D6JBNO           *
     C                     MOVE ADATA     SDATA            *
     C                     MOVE AKFLG     PKFLG
     C                     EXSR SAT                        *
     C                     EXSR SUBJOB                     HD WRITE LOG
     C                     EXCPTDAT                        *
     C                     MOVE '*'       PSFLG
     C                     GOTO STPEND                     *
      *
     C*----------------------------------------------------*
     C*  ＲＱレコードの転送日付は、前日便の日付・        *
     C*  当日便の日付か？                                *
     C*----------------------------------------------------*
     C           STP11     TAG                             *
     C                     Z-ADDANBIN     F       20       *
   #@C           ANOHZ     IFEQ CDZNH8                     *
     C                     SETOF                     03    *
     C                     Z-ADD1         B                *
     C           F         LOKUPHCB,B                    03*
     C           *IN03     IFEQ '0'                        *
     C                     MOVE '16'      AMESG            *
     C                     MOVE '16'      D6ERCD           *
     C                     GOTO STP13                      *
     C                     END                             *
      *
