     C           STP13     TAG                             *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     MOVE 'AT'      URECD            *
     C                     TIME           UTIME            *
     C                     Z-ADDUJOBN     D6JBNO           *
     C                     MOVE ADATA     SDATA            *
     C                     MOVE AKFLG     PKFLG
     C                     EXSR SAT                        *
     C                     EXSR SUBJOB                     HD WRITE LOG
     C                     EXCPTDAT                        *
     C                     MOVE '*'       PSFLG
     C                     GOTO STPEND                     *
     C           STP12     TAG                             *
      *
     C*----------------------------------------------------*
     C*  時刻別計算便マスターにＪＯＢＮＯ更新            *
     C*----------------------------------------------------*
     C                     SETOF                     03    *
     C           ABMON     CHAINAAIPL111             03    *
     C           *IN03     IFEQ '0'                        *
     C                     Z-ADDUJOBN     CDJOBN           *
     C                     UPDATAAIPL111                   *
     C                     END                             *
