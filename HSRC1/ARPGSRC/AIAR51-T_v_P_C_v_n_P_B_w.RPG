     C*---------------------------------*                  *
     C*  ＨＤレコード項目セット       *                  *
     C*---------------------------------*                  *
     C           STP16     TAG                             *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     Z-ADD*DATE     ANOHZ            *
     C                     MOVE 'AT'      URECD            *
     C                     TIME           UTIME            *
     C                     Z-ADDUJOBN     D6JBNO           *
     C                     MOVE ADATA     SDATA            *
     C                     MOVE AKFLG     PKFLG
     C                     EXSR SAT                        *
     C                     EXSR SUBJOB                     HD WRITE LOG
     C                     EXCPTDAT                        *
     C                     MOVE '*'       PSFLG
     C                     GOTO STPEND                     *
     C*---------------------------------*                  *
     C*  PRG END                      *                  *
     C*---------------------------------*                  *
     C           STPEND    TAG                             *
     C                     MOVE UALL      PUALL
     C                     SETON                     LR
     C                     RETRN
      *
     C*----------------------------------------------------*
     C*  サブルーチン                                    *
     C*  ＪＯＢＬＯＧファイル　ＷＲＩＴＥ (AIAPP60)      *
     C*----------------------------------------------------*
     C           SUBJOB    BEGSR                           *
     C                     TIME           LDATE
     C                     MOVE *BLANK    D6SKJY           *
     C                     Z-ADD0         D6SKYY           *
     C                     Z-ADD0         D6SKMM           *
     C                     Z-ADD0         D6SKDD           *
     C                     Z-ADDLDAY      D6KOHZ           *
     C                     Z-ADDLTIME     D6KOTM           *
     C                     MOVE *BLANK    D6KOME
     C                     MOVELW$WSID    D6KOME
     C                     MOVE *BLANK    D6KOPG
     C                     MOVEL'AIAR51'  D6KOPG
     C                     MOVE *BLANK    D6DATA           *
     C                     MOVELAALLD     D6DATA           *
     C                     MOVE ABMON     D6BUCD           *
     C                     Z-ADDLDAY      D6TUHZ           *
     C                     Z-ADDLTIME     D6TIME           *
     C                     MOVE PLOCAT    D6LOCA           *
     C                     MOVE PSYSTM    D6PCCD           *
     C                     MOVE PKFLG     D6SCSY           *
     C                     WRITEAIAPP601                   *
     C                     ENDSR                           *
      *
     C*----------------------------------------------------*
     C*  サブルーチン                                    *
     C*  ファイル　の　チェック                          *
     C*----------------------------------------------------*
     C           SUBCHK    BEGSR                           *
     C                     MOVE *BLANK    WCHK    1        *
     C                     CALL 'AIACCC'                   *
     C                     PARM           PFILE            *
     C                     PARM           WCHK             *
     C           WCHK      IFEQ '1'                        *
     C                     MOVE '1'       *IN01            *
     C                     MOVE 'HD'      ARECD            *
     C                     MOVE '32'      AMESG            *
     C                     MOVE 'AT'      URECD            *
     C                     TIME           UTIME            *
     C                     Z-ADDUJOBN     D6JBNO           *
     C                     MOVE '32'      D6ERCD           *
     C                     MOVE ADATA     SDATA            *
     C                     MOVE AKFLG     PKFLG
     C                     EXSR SAT                        *
     C                     EXSR SUBJOB                     HD WRITE LOG
     C                     EXCPTDAT                        *
     C                     END                             *
     C                     ENDSR                           *
      *
     C*----------------------------------------------------*
     C*  サブルーチン　　ＡＴ                            *
     C*  ローカルデータエリア　工場別レコード区分変更    *
     C*----------------------------------------------------*
     C           SAT       BEGSR                           *
     C           ABMON     IFEQ 0111                       *
     C                     MOVE 'AT'      U0111            *
     C                     END                             *
     C                     ENDSR                           *
      *
     C*----------------------------------------------------*
     C*  サブルーチン　　ＲＱ                            *
     C*  ローカルデータエリア　工場別レコード区分変更    *
     C*----------------------------------------------------*
     C           SRQ       BEGSR                           *
     C           ABMON     IFEQ 0111                       *
     C                     MOVE 'RQ'      U0111            *
     C                     END                             *
     C                     ENDSR                           *
      *************************
JW1   * OUTPUT LOG RECORD
 .    *************************
 .   C           #LOG      BEGSR
 .    *
     C                     TIME           SDATE
     C                     Z-ADDTODAY     AILGDT
     C                     Z-ADDNOW       AILGTM
     C                     MOVELW$USER    AILGUS
     C                     MOVELW$PGM     AILGPG
     C                     MOVELW$WSID    AILGWS
     C                     MOVELW$JBNO    AILGJB
     C                     MOVEL'UPD'     AILGFC    P
 .    *
 .   C                     WRITEAAIPP221
 .    *
JW1  C                     ENDSR
     C*----------------------------------------------------*
      *
     OOUTPUT  E                DAT
     O                         SDATA    256
** HKJ
0111
