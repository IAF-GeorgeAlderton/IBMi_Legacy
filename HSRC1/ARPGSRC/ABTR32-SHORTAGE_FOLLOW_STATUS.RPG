     H            Y.
     F** ABTR32 *********************************************
     F* SHORTAGE FOLLOW STATUS
     F*   SAKAKI.         2020.04.03                        *
     F*   JW1    2021.02.10 ADD PT DEPT (P1KBN=7)           *
     F*******************************************************
     FABTWP31 IF  E           K        DISK
     FABTWP32 IF  E           K        DISK                      A
     E                    OKB        15  3               KIBAN (MACHINE)
     E                    OKO        15  3               KOTEI (PROCESS)
JW1  E                    BMN        15  4               BUMON (DEPT.  )
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  140SDATE
     I                                        1   60STIME
      *
     I            DS
     I                                        1  12 W1SHIN
     I                                        1   5 W1LPR1
     I                                        6  10 W1LPR2
     I                                       11  12 W1LPR3
      *
     I            DS
     I                                        1  20 X1SRT#
     I                                        4   4 X1SRT4
     I                                        4   5 X1SRT5
      *
     I            DS
     I                                        1   3 W1SRTN
     I                                        1   1 W1SRT#
     I                                        2   3 W1SRT0
     I            DS
     I                                        1   6 WKLOCA
     I                                        1   1 WKLOC1
     I                                        2   3 WKLOC2
     I                                        4   5 WKLOC3
     I                                        6   6 WKLOC4
      *
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *----------------------------------------------------*
      * ENTRY                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1KBN   1
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     TIME           WTIME
      *
     C                     MOVEL'1'       OPNCLS
     C                     READ ABTWP31                  20
     C           *IN20     DOWEQ'0'
     C                     EXSR #SB500
     C                     READ ABTWP31                  20
     C                     ENDDO
      *
     C           OPNCLS    IFEQ '0'
     C                     MOVE '9'       OPNCLS
     C                     CALL 'AAMRSB'
      * INPUT PARAMETER
     C                     PARM           A2BHB1  5
     C                     PARM           A2BHB2  5
     C                     PARM           A2BHB3  2
     C                     PARM           OPNCLS  1
      * OUTPUT PARAMETER
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARABTWP321
     C                     Z-ADDW1TOKU    W2TOKU
     C                     Z-ADDW1NONY    W2NONY
     C                     MOVELW1NKOJ    W2NKOJ
     C                     MOVELW1NUKE    W2NUKE
     C                     Z-ADDW1NODT    W2NODT
     C                     MOVELW1NOBN    W2NOBN
     C           KEYM1     KLIST
     C                     KFLD           K@NONY  4
     C                     KFLD           K@BIN   2
     C                     MOVELW1NONY    K@NONY
     C                     MOVE W1NOBN    K@BIN
     C                     MOVELW1NOTM    W2NOTM
     C                     MOVELW1ODRN    W2ODRN
     C                     MOVELW1MHN1    W2MHN1
     C                     MOVELW1MHN2    W2MHN2
     C                     MOVELW1MHN3    W2MHN3
     C                     MOVELW1MHN4    W2MHN4
     C                     MOVELW1LOC     WKLOCA
     C                     MOVELW1LZET    W2LZET
     C                     MOVELW1LOC1    W2LOC1
     C                     MOVELW1LOC2    W2LOC2
     C                     MOVELW1LOC3    W2LOC3
     C                     MOVELW1LOC4    W2LOC4
     C                     MOVELW1LPR1    W2LPR1
     C                     MOVELW1LPR2    W2LPR2
     C                     MOVELW1LPR3    W2LPR3
     C                     Z-ADDW1CNT     W2CNT
     C                     Z-ADDW1ALD3    W2ALD3
     C                     Z-ADDW1ADA1    W2ADA1
     C                     Z-ADDW1NYKO    W2NYKO
     C                     Z-ADDW1SRT     W2SRT
     C                     Z-ADDW1OUK     W2OUK
     C                     Z-ADDW1BZK     W2BZK
     C                     Z-ADDW1DSK     W2DSK
     C                     Z-ADDW1JCK     W2JCK
     C                     Z-ADDW1SBK     W2SBK
     C                     Z-ADDW1LOQK    W2LOQK
     C                     Z-ADDW1OUI     W2OUI
     C                     Z-ADDW1BZI     W2BZI
     C                     Z-ADDW1DSI     W2DSI
     C                     Z-ADDW1JCI     W2JCI
     C                     Z-ADDW1SBI     W2SBI
     C                     Z-ADDW1LOQI    W2LOQI
     C                     Z-ADDW1PLOU    W2PLOU
     C                     Z-ADDW1PLBZ    W2PLBZ
     C                     Z-ADDW1PLDS    W2PLDS
     C                     Z-ADDW1PLJC    W2PLJC
     C                     Z-ADDW1PLSB    W2PLSB
     C                     Z-ADDW1PLLO    W2PLLO
     C                     Z-ADDW1PRE     W2PRE
     C                     Z-ADDW1CVS     W2CVS
     C                     Z-ADDW1ALL     W2ALL
      * SRT
     C                     Z-ADDW1SRT     W2SRTD
      * S.T.AFTER
      * S.T.PROCESSING
      * S.T.BEFORE
     C                     SELEC
      * P1KBN=2, BZ
     C           P1KBN     WHEQ '2'
     C           W1BZK     IFGE 0
     C                     Z-ADDW1BZK     W2STKD
     C                     ENDIF
     C           W1BZI     IFGE 0
     C                     Z-ADDW1BZI     W2STID
     C                     ENDIF
     C           W1PLBZ    IFGE 0
     C                     Z-ADDW1PLBZ    W2STPD
     C                     ENDIF
      * P1KBN=5
     C           P1KBN     WHEQ '5'
     C           W1DSK     IFGE 0
     C                     Z-ADDW1DSK     W2STKD
     C                     ENDIF
     C           W1DSI     IFGE 0
     C                     Z-ADDW1DSI     W2STID
     C                     ENDIF
     C           W1PLDS    IFGE 0
     C                     Z-ADDW1PLDS    W2STPD
     C                     ENDIF
      * P1KBN=6
     C           P1KBN     WHEQ '6'
     C           W1JCK     IFGE 0
     C                     Z-ADDW1JCK     W2STKD
     C                     ENDIF
     C           W1JCI     IFGE 0
     C                     Z-ADDW1JCI     W2STID
     C                     ENDIF
     C           W1PLJC    IFGE 0
     C                     Z-ADDW1PLJC    W2STPD
     C                     ENDIF
      *
JW1   * PT IN - PROCESS - OUT
 .   C           P1KBN     IFEQ '7'
 .   C                     Z-ADD0         W2STKD           ST LOADED
 .   C                     Z-ADD0         W2STID           ST LOADING
 .   C                     Z-ADD0         W2STPD           ST PRE-LOAD
 .   C                     ENDIF
      *
     C                     ENDSL
      * SB AFTER
     C           W1SBK     IFGE 0
     C                     Z-ADDW1SBK     W2SBKD
     C                     ENDIF
      * H.T.PROCESSING
     C           W1LOQK    IFGE 0
     C                     Z-ADDW1LOQK    W2HTKD
     C                     ENDIF
      * SB  PROCESSING
     C           W1SBI     IFGE 0
     C                     Z-ADDW1SBI     W2SBID
     C                     ENDIF
      * H.T.PROCESSING
     C           W1LOQI    IFGE 0
     C                     Z-ADDW1LOQI    W2HTID
     C                     ENDIF
      * SB BEFORE
     C           W1PLSB    IFGE 0
     C                     Z-ADDW1PLSB    W2SBPD
     C                     ENDIF
      * H.T. BEFORE
     C           W1PLLO    IFGE 0
     C                     Z-ADDW1PLLO    W2HTPD
     C                     ENDIF
      * CV AFTER LOAD
     C           W1PRE     IFGE 0
     C                     Z-ADDW1PRE     W2PRED
     C                     ENDIF
      *
     C                     Z-ADDW1TUHT    W2TUHT
     C                     Z-ADDW1TUHK    W2TUHK
     C                     MOVELW1DKBN    W2DKBN
     C                     MOVEL'0'       W@F     1
      * STOCK < ORDER QTY.
JW1  C           P1KBN     IFEQ '7'
 .   C           W2TUHK    ANDGEW2CNT
 .   C                     MOVELW1LPR1    $SHN1
 .   C                     MOVELW1LPR2    $SHN2
 .   C                     MOVELW1LPR3    $SHN3
 .   C                     CALL 'UEXR41A'
 .   C                     PARM           $SHN1   5
 .   C                     PARM           $SHN2   5
 .   C                     PARM           $SHN3   2
 .   C                     PARM           $BOX    4
 .   C                     MOVEL$BOX      @BOX    40
 .   C           W2TUHK    IFLT @BOX
 .   C                     MOVE 'Y'       @FLG    1        INV >  BOX
 .   C                     ELSE
 .   C                     MOVE 'N'       @FLG             INV <= BOX
 .   C                     ENDIF
JW1  C                     ENDIF
      *
     C           W2TUHK    IFLT W2CNT
JW1  C           @FLG      OREQ 'Y'
     C                     SELEC
     C* P1KBN=1, SRT
     C           P1KBN     WHEQ '1'
     C           W2SRTD    ANDGT0
     C                     MOVEL'1'       W@F
     C* P1KBN=2, BZ/DS
     C* P1KBN=5
     C           P1KBN     WHEQ '2'
     C           P1KBN     OREQ '5'
     C*
     C                     Z-ADD0         WTTL    40
     C           W1PLAS    IFEQ '*'
     C           W2SRTD    ADD  W2PLJC    WTTL
     C                     ADD  W2JCI     WTTL
     C                     ADD  W2JCK     WTTL
     C                     ADD  W2PLOU    WTTL
     C                     ADD  W2OUK     WTTL
     C                     ADD  W2OUI     WTTL
     C                     MOVELWKLOC1    W2LOC1
     C                     MOVELWKLOC2    W2LOC2
     C                     MOVELWKLOC3    W2LOC3
     C                     MOVELWKLOC4    W2LOC4
     C                     ELSE
     C                     Z-ADDW2SRTD    WTTL    40
     C                     ENDIF
     C*
     C           WTTL      IFLT W2CNT
     C           W2STKD    IFGT 0
     C           W2STID    ORGT 0
     C           W2STPD    ORGT 0
     C                     MOVEL'1'       W@F
     C                     ENDIF
     C                     ENDIF
     C* SB
     C           P1KBN     WHEQ '3'
     C           W2SRTD    IFLT W2CNT
     C           W2SBKD    IFGT 0
     C           W2SBID    ORGT 0
     C           W2SBPD    ORGT 0
     C                     MOVEL'1'       W@F
     C                     ENDIF
     C                     ENDIF
     C* H.T.
     C           P1KBN     WHEQ '4'
     C           W2SRTD    IFLT W2CNT
     C           W2HTKD    IFGT 0
     C           W2HTID    ORGT 0
     C           W2HTPD    ORGT 0
     C                     MOVEL'1'       W@F
     C                     ENDIF
     C                     ENDIF
     C* JC
     C           P1KBN     WHEQ '6'
     C           W2SRTD    IFLT W2CNT
     C           W2STKD    IFGT 0
     C           W2STID    ORGT 0
     C           W2STPD    ORGT 0
     C                     MOVEL'1'       W@F
     C                     ENDIF
     C                     ENDIF
JW1   * PT
 .   C           P1KBN     WHEQ '7'
JW1  C                     MOVEL'1'       W@F
      *
     C                     ENDSL
      *
     C                     ENDIF
      *
     C           KEY01     KLIST
     C                     KFLD           W2NODT
     C                     KFLD           W2NOTM
     C                     KFLD           W2TOKU
     C                     KFLD           W2NONY
     C                     KFLD           W2NKOJ
     C                     KFLD           W2NUKE
     C                     KFLD           W2LPR1
     C                     KFLD           W2LPR2
     C                     KFLD           W2LPR3
     C           KEY01     SETLLABTWP32                  50
      *
     C  N50      W@F       IFEQ '1'
     C                     EXSR #SB510
      *
JW1  C           P1KBN     IFEQ '7'
 .   C           W2PROC    ANDEQ*BLANK
 .   C                     GOTO ESB500
JW1  C                     ENDIF
      *
     C                     WRITEABTWP321
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB510    BEGSR
      *
     C                     MOVEA*BLANK    OKB
     C                     MOVEA*BLANK    OKO
JW1  C                     MOVEA*BLANK    BMN
     C                     CALL 'AAMRSB'
      * INPUT PARAMETER
     C                     PARM           W1LPR1
     C                     PARM           W1LPR2
     C                     PARM           W1LPR3
     C                     PARM           OPNCLS  1
      * OUTPUT PARAMETER
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     MOVEL'0'       OPNCLS
     C                     MOVEAPKBN      OKB
     C                     MOVEAPKOT      OKO
JW1  C                     MOVEAPBMN      BMN
      *
     C           P1KBN     IFEQ '1'
     C                     CALL 'UTLR57'
     C                     PARM           W1SHIN
     C                     PARM           X1SRTN 20
     C                     PARM           X1SRT# 20
     C                     PARM           X1RTN   1
     C                     MOVELX1SRTN    W2PROC
     C                     MOVELX1SRT#    W2MSN#
     C*
     C           W2MSN#    IFEQ *BLANK
     C           W2PROC    IFEQ 'SOR'
     C                     MOVEL*BLANK    W2MSN#
     C                     MOVEL'SORT'    W2MSN#
     C                     ELSE
     C                     MOVEL*BLANK    W2MSN#
     C                     MOVEL'QD INSP' W2MSN#
     C                     ENDIF
     C                     ENDIF
     C*
     C                     ENDIF
     C*
     C                     MOVEL*BLANK    WKOT1   3
     C                     MOVEL*BLANK    WKOT2   3
     C                     MOVEL*BLANK    WKOT3   3
     C                     SELEC
     C           P1KBN     WHEQ '1'
      *
     C           P1KBN     WHEQ '2'
     C                     MOVEL'BZ '     WKOT1   3
     C                     EXSR #SB511
     C           P1KBN     WHEQ '3'
     C                     MOVEL'SB '     WKOT1   3
     C                     EXSR #SB511
     C           P1KBN     WHEQ '4'
     C                     MOVEL'LOQ'     WKOT1   3
     C                     EXSR #SB511
     C           P1KBN     WHEQ '5'
     C                     MOVEL'DS '     WKOT1   3
     C                     EXSR #SB511
     C           P1KBN     WHEQ '6'
     C                     MOVEL'JC '     WKOT1   3
     C                     EXSR #SB511
      *
JW1  C           P1KBN     WHEQ '7'
 .   C                     MOVEL'PT '     WKOT1   3
JW1  C                     EXSR #SB511
      *
     C                     ENDSL
      *
     CSR         ESB510    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB511    BEGSR
      *
JW1  C           P1KBN     IFNE '7'
     C                     Z-ADD1         X       30
     C           X         DOWLE15
     C           OKO,X     IFEQ WKOT1
     C**         OKO,X     OREQ WKOT2
     C**         OKO,X     OREQ WKOT3
     C                     MOVELOKO,X     W2PROC
     C                     MOVELOKB,X     W2MSN#
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
JW1  C                     ENDIF
      * KRO(JC)
     C           P1KBN     IFEQ '6'
     C           W2PROC    IFEQ *BLANK
     C                     Z-ADD1         X       30
     C           X         DOWLE15
     C           OKO,X     IFEQ 'KRO'
     C           OKB,X     IFEQ 'JC2'
     C           OKB,X     OREQ 'JC4'
     C                     MOVELOKO,X     W2PROC
     C                     MOVELOKB,X     W2MSN#
     C                     ENDIF
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
     C                     ENDIF
     C                     ENDIF
JW1   * PT/BPT
 .   C           P1KBN     IFEQ '7'
 .   C           W2PROC    IFEQ *BLANK
 .   C                     Z-ADD1         X       30
 .   C           X         DOWLE15
 .   C           OKO,X     IFEQ 'KN '
 .   C           OKO,X     OREQ 'HN '
 .   C           BMN,X     IFEQ '8990'
 .   C                     MOVELOKO,X     W2PROC
 .   C                     MOVELOKB,X     W2MSN#
 .   C                     LEAVE
 .   C                     ENDIF
 .   C                     ENDIF
 .   C                     ADD  1         X
 .   C                     ENDDO
 .   C                     ENDIF
      *
     C           W2PROC    IFNE *BLANK
     C           W2MSN#    ANDEQ*BLANK
     C                     MOVEL'PT      'W2MSN#
     C                     ENDIF
      *
JW1  C                     ENDIF
      *
     CSR         ESB511    ENDSR
