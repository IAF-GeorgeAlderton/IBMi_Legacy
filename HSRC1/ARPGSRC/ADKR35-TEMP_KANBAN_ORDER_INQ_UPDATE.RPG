     H            Y.
     F** ADKR35 **********************************
     F*臨時かんばん照会・更新
     F*    KATOGI.         2015.12.16            *
     F********************************************
     FADKWP36 IF  E           K        DISK
     FADKPP31 UF  E           K        DISK
     FADAPL64 UF  E           K        DISK
      *
     I            DS
     I                                        1   80W6APHZ
     I                                        1   40W6APYY
     I                                        5   60W6APMM
     I                                        7   80W6APDD
      *
     I            DS
     I                                        1   80DASKHZ
     I                                        1   40DASKYY
     I                                        5   60DASKMM
     I                                        7   80DASKDD
      *
     I            DS
     I                                        1  140WDATE
     I                                        1   60STIME
     I                                        1   20STIHH
     I                                        3   40STIMM
     I                                        5   60STISS
     I                                        7  140SDATE
     I                                        7  100SDAYY
     I                                       11  120SDAMM
     I                                       13  140SDADD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C                     TIME           WDATE
      *
     C                     READ ADKWP361                 80
     C           *IN80     DOWEQ'0'
     C           W6CHNG    IFNE W6MAIS
     C                     EXSR #SB500
     C                     EXSR #SB550
     C                     ENDIF
     C                     READ ADKWP361                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------*
      *                                      *
      *--------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYW      KLIST
     C                     KFLD           W6APHZ
     C                     KFLD           W6APBN
     C                     KFLD           W6SHN1
     C                     KFLD           W6SHN2
     C                     KFLD           W6SHN3
      *
     C           KEYW      CHAINADKPP311             22
     C           *IN22     IFEQ '0'
     C           D3EFLG    IFEQ *BLANK
     C                     Z-ADDSDATE     D3KOHZ
     C                     Z-ADDSTIME     D3KOTI
     C                     MOVELW#PGM     D3KOME
     C                     Z-ADDW6CHNG    D3MAIS
     C           D3MAIS    IFEQ 0
     C                     MOVEL'D'       D3SKJY
     C                     Z-ADDSDATE     D3SKHZ
     C                     ENDIF
     C                     UPDATADKPP311
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
      *--------------------------------------*
      * ADAPP60                              *
      *--------------------------------------*
     CSR         #SB550    BEGSR
      *
     C           KEYADA    KLIST
     C                     KFLD           W6APYY
     C                     KFLD           W6APMM
     C                     KFLD           W6APDD
     C                     KFLD           W6SHN1
     C                     KFLD           W6SHN2
     C                     KFLD           W6SHN3
      *マイナスしかしない
     C           W6MAIS    SUB  W6CHNG    WKSA    30
     C           WKSA      DIV  W6BARL    WKKAI   30
     C           KEYADA    SETLLADAPL641
     C           KEYADA    READEADAPL641                 22
     C           *IN22     DOWEQ'0'
     C           WKKAI     ANDGE1
     C           DASKJY    IFEQ 'D'
     C           DASKHZ    ANDLESDATE
     C                     ELSE
     C                     SUB  1         WKKAI
     C                     MOVEL'D'       DASKJY
     C                     Z-ADDSDAYY     DASKYY
     C                     Z-ADDSDAMM     DASKMM
     C                     Z-ADDSDADD     DASKDD
     C                     UPDATADAPL641
     C                     ENDIF
     C           KEYADA    READEADAPL641                 22
     C                     ENDDO
      *
     CSR         ESB550    ENDSR
