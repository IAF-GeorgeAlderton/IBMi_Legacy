     H            Y.                                                      EER050
     F** GBFR12 ********************************************
     F* MATERIAL PRIMITIVE COST M/F UPDATE  < SALES UNIT PRICE ESTIMATE> *
     F*            M-OKUDA          1985.11.05             *
     F******************************************************
     FGBFPL11 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FGBFPR12 O   E                    PRINTER
     E                    MD      1   1 14               vjﾞﾆ
     I            DS
     I                                        1   80UHIZK
     I                                        1   40UYY
     I                                        5   80UMD
     I            DS
     I                                        1   80MDYY
     I                                        1   40AMD
     I                                        5   80AYY
     I            DS
     I                                        1   60UTIME
     I                                        1   20UJI
     I                                        3   40UFN
     I                                        5   60UBI
     C******************************************************
     C* M-NO               ﾌﾟ[x-j- ﾉ cinﾒ                  *
     C******************************************************
     C           *ENTRY    PLIST
     C                     PARM           USER   10
     C                     PARM           PTOKU   4
     C                     PARM           PTKOJ   1
     C                     MOVE PTOKU     UTOKU   40
     C                     MOVE *BLANK    TMEIG  16
     C                     MOVE MD,1      HD     14
     C                     Z-ADD*DATE     UHIZK
     C                     Z-ADDUYY       AYY
     C                     Z-ADDUMD       AMD
     C                     SETOF                     04
     C           UTOKU     CHAINFGBPL011             04
     C           *IN04     IFEQ '0'
     C           B2SKJY    IFNE 'D'
     C                     MOVELB2SMEI    TMEIG
     C                     END
     C                     END
     C                     WRITEGBFPR121
     C                     Z-ADD0         P       20
     C******************************************************
     C* M-NO               mﾞ-jﾈln & ﾑvﾃv                  *
     C******************************************************
     C                     SETOF                     05
     C           MKEY      KLIST
     C                     KFLD           UTOKU
     C                     KFLD           PTKOJ
     C                     KFLD           H3ZCOD
     C           MKEY      SETLLGBFPL111
     C           STEP01    TAG
     C                     READ GBFPL11                  05
     C           *IN05     CABEQ'1'       END
     C           H3SKJY    CABEQ'D'       STEP01
     C           H3TOKU    CABNEUTOKU     END
     C           H3TKOJ    CABNEPTKOJ     END
     C                     WRITEGBFPR122
     C           P         ADD  1         P
     C           P         IFGT 50
     C                     WRITEGBFPR121
     C                     Z-ADD0         P
     C                     END
     C                     GOTO STEP01
     C           END       TAG
     C                     SETON                     LR
