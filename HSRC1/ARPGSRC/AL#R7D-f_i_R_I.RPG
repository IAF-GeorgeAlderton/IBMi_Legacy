     H            Y.
     F** AL#R7D **************************************
     F*かんばん仕分け枚数を計算する
     F*        ITS.         2015.05.27               *
     F************************************************
     FAL#WP71 IF  E           K        DISK
     FAL#WP7C IF  E           K        DISK                      A
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
      *
     C           *LOVAL    SETLLAL#WP711
     C                     READ AL#WP711                 22
     C           *IN22     DOWEQ'0'
     C           W1PPUL    IFEQ *BLANK
     C           W1SECT    IFNE *BLANK
     C                     EXSR #SB400
     C                     ENDIF
     C                     ENDIF
     C                     READ AL#WP711                 22
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      * AL#WP71
      *-----------------------------------------------------
     CSR         #SB400    BEGSR
      *
     C           KEY7C     KLIST
     C                     KFLD           K1NAMC  5
     C                     KFLD           W1SECT
     C                     MOVEL*BLANK    K1NAMC  5
     C           KEY7C     CHAINAL#WP7C1             23
     C           *IN23     IFEQ '1'
     C                     CALL 'AL#R7C'
     C                     PARM           K1NAMC  5
     C                     PARM           W1SECT  2
     C                     PARM           P9MAIS  30
     C*******              MOVELW1NAMC    WCNAMC
     C                     MOVEL*BLANK    WCNAMC
     C                     MOVELW1SECT    WCSECT
     C                     Z-ADDP9MAIS    WCMAIS
     C                     WRITEAL#WP7C1
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
