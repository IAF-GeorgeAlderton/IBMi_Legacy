     H            Y.
     F** ABMRI4 *********************************************
     F* ST ONEWAY ADD     KAIZEN SHEETS #21061
     F*    Y.MAEDA              2021.09.24                  *
     F*******************************************************
     FABMWP32 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FAGAPL41 IF  E           K        DISK
     FABMPRI4 O   E             55     PRINTER
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I            DS
     I                                        1   80A2GEHZ
     I                                        1   40A2GEYY
     I                                        5   60A2GEMM
     I                                        7   80A2GEDD
      *
     I            DS
     I                                        1   80W@DATE
     I                                        1   40W@DAYY
     I                                        5   60W@DAMM
     I                                        7   80W@DADD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
     C           KEYHIN    KLIST
     C                     KFLD           W0SHN1
     C                     KFLD           W0SHN2
     C                     KFLD           W0SHN3
      *
     C           *ENTRY    PLIST
     C                     PARM           P@KCD1  1
     C                     PARM           P@FNAM 30
      *
     C                     TIME           WTIME
      *
     C                     MOVEL' '       WSTONE  1
     C           P@KCD1    IFEQ 'T'
     C                     MOVELP@KCD1    WSTONE
     C                     MOVEL'C'       P@KCD1
     C                     END
      *
     C                     Z-ADDUDATE     @HYMD
     C                     MOVELP@FNAM    @TITL
     C                     SETON                     55
     C           *HIVAL    SETGTABMWP321
     C                     READPABMWP321                 87
     C           *IN87     DOWEQ'0'
      *CHECK ST OR ST ONEWAY
     C                     MOVEL' '       TURUBE  1
     C                     SETOF                     71
     C           KEYHIN    CHAINAGAPL41              71
     C           *IN71     IFEQ '0'
     C           CBSKJY    ANDEQ'D'
     C                     SETON                     71
     C                     END
     C           *IN71     IFEQ '0'
     C                     MOVEL'*'       TURUBE
     C                     END
      *
      *@PRT   1:PRINT   BLANK:NOT PRINT
     C                     MOVEL'1'       @PRT    1
     C           WSTONE    IFEQ 'T'
     C           TURUBE    ANDNE'*'
     C                     MOVEL' '       @PRT    1
     C                     END
     C           WSTONE    IFEQ ' '
     C           TURUBE    ANDEQ'*'
     C                     MOVEL' '       @PRT    1
     C                     END
      *
     C           W0KCD1    IFEQ P@KCD1
     C           W0DUP@    ANDEQ*BLANK
     C           W0KMAX    ANDNEW0KMAA
     C           @PRT      ANDEQ'1'
     C           *IN55     IFEQ '1'
     C                     WRITEABMPRI41
     C                     SETOF                     55
     C                     ENDIF
     C                     EXSR #SB001
     C                     ENDIF
     C                     READPABMWP321                 87
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------*
      * FCEPP01                                          *
      *--------------------------------------------------*
     CSR         #SB001    BEGSR
      *
     C           KEYFC1    KLIST
     C                     KFLD           W0SHN1
     C                     KFLD           W0SHN2
     C                     KFLD           W0SHN3
     C                     Z-ADD0         P2GEHZ  80
     C           KEYFC1    CHAINFCEPL011             25
     C           *IN25     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     25
     C                     ENDIF
     C           *IN25     IFEQ '0'
     C                     MOVELA2GEHZ    P2GEHZ
     C                     ENDIF
      *
     C                     MOVELW0KCD1    P2KCD1
     C                     MOVELW0ATK1    P2ATK1
     C                     MOVELW0ATK2    P2ATK2
     C                     MOVELW0ATK3    P2ATK3
     C                     MOVELW0ATK4    P2ATK4
     C                     MOVEL*BLANK    P2SHIN
     C           W0SHN1    CAT  '-':0     P2SHIN
     C           P2SHIN    CAT  W0SHN2:0  P2SHIN
     C           P2SHIN    CAT  '-':0     P2SHIN
     C           P2SHIN    CAT  W0SHN3:0  P2SHIN
     C                     Z-ADDW0SSYS    P2SSYS
     C                     Z-ADDW0KTSU    P2KTSU
     C                     Z-ADDW0KTSA    P2KTSA
     C                     Z-ADDW0BOXM    P2BOXM
     C                     Z-ADDW0BOXD    P2BOXD
     C******               Z-ADDW0AUAJ    P2AUAJ
     C******               Z-ADDW0AUAA    P2AUAA
     C                     Z-ADDW0KMAX    P2KMAX
     C                     Z-ADDW0KMAA    P2KMAA
     C                     Z-ADDW0BOXP    P2BOXP
     C                     Z-ADDW0SA      P2SA
      *
     C                     WRITEABMPRI42
      *
     CSR         ESB001    ENDSR
