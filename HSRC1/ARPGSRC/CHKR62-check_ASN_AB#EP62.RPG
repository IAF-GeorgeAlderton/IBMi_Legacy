     H            Y.
     F** CHKR62  ***************************************************************
     F*  PROGRAM    : CHECK ASN                                                *
     F*  WRITTEN    : 2020.08.19                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#EL63SIF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     E                    MSG     1   3 30
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           TGDATE    SETLLAB#EL63S
     C                     DO   *HIVAL
     C                     READ AB#EL63S                 98
     C   98                LEAVE
      * SELECT
     C           E3PRTN    IFNE '7448'
     C           E3PRTN    ANDNE'7449'
     C           E3PRTN    ANDNE'7450'
     C           E3PRTN    ANDNE'7451'
     C           E3PRTN    ANDNE'7452'
     C                     ITER
     C                     ENDIF
      * SELECT
     C           E3ORDN    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      * PRINT
     C                     MOVELMSG,1     XMSG
     C                     EXSR #PRINT
      *
     C                     ENDDO
      *
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C                     MOVE *BLANK    $RTN
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     MOVE *BLANK    XMSG   30
      * 7 DAYS BACK
     C                     MOVELTODAY     $DT8
     C                     MOVEL'-'       $SIGN
     C                     MOVEL'0007'    $DAYS
     C                     MOVEL'N'       $IAF
     C                     CALL 'UTLR10'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTNX   1
     C                     MOVEL$TGT8     TGDATE  80
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** CHECK ASN **     '
     O                                   60 '                    '
     O                                   80 '                    '
     O                                   89 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                                  106 'P.'
     O                         PAGE  Z  110
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   14 'CRT_DATE'
     O                                   24 'PARTNER'
     O                                   35 'SHIP ID'
     O                                   45 'ORDER#'
     O                                   59 'USER PART'
     O                                   80 'MANIFEST#'
     O                                  100 'SHIP QTY'
     O                                  117 '** ERROR MSG **'
     O        E 1              @DTL
     O                         SEQ#  1 +000
     O                         E3CRDT  +001 '    /  /  '
     O                         E3PRTN  +001
     O                         E3SHID  +001
     O                         E3ORDN  +001
     O                         E3MHIN  +001
     O                         E3MAN#  +001
     O                         E3SRYO1 +000
     O                         XMSG    +002
** MSG (30A).......2.........3
PISTON SHOULD HAVE PO#


