     H            Y.
      ** EJRR12 *******************************************************
      * R861FORD (RCV ADVC) CREATE EB#EP80                            *
      * J.WATANABE   2016.12.16                                       *
      *****************************************************************
     FEJRWP12 IF  F     184            DISK
     FEJGPL00 IF  E           K        DISK
     FEB#EP80 O   E                    DISK
      *****************************************************************
     E                    TB1       184  1
     E                    TB2        60  1
     E                    TB3        10  1
     IEJRWP12 AA  01
     I                                        1 184 #DATA
     I                                        1   1 @KUBN
     I                                        2   7 @RCID
     I                                        8  18 @PRTN
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *================================================================
      *  MAIN
      *================================================================
     C                     EXSR #INIT
     C                     MOVEL'FORD861' K1RCID
      *----------------------------------------
     C                     DO   *HIVAL
     C                     READ EJRWP12                  90
     C   90                LEAVE
     C                     MOVEA#DATA     TB1
     C                     MOVEL@KUBN     K2RTYP
      *
     C                     SELEC
      * HEADER
     C           @KUBN     WHEQ 'H'
     C                     EXSR #HDSET
      * DETAIL
     C           @KUBN     WHEQ 'D'
     C                     EXSR #DTSET
      *
     C                     ENDSL
      *
     C                     ENDDO
      *----------------------------------------
      *
     C                     SETON                     LR
     C                     RETRN
      *================================================================
      *  GET HEADER
      *================================================================
     C           #HDSET    BEGSR
     C                     MOVEL'OT01'    K3AFIL
     C* CLEAR
     C                     CLEAREB#EP801
      * RPRTNR C   PARTNER
     C                     MOVEL'RPRTNR'  K4AFLD
     C                     EXSR #GET
     C                     MOVEL@AN       RPRTNR
      * RREFE AN   REFERENCE NUMBER
     C                     MOVEL'RREFE '  K4AFLD
     C                     EXSR #GET
     C                     MOVEL@AN       RREFE
      * RDATE DT   CREATION DATE
     C                     MOVEL'RDATE '  K4AFLD
     C                     EXSR #GET
     C                     MOVEL@DATE8    RDATE
      * RREPK AN  REF# QUA  PK
     C                     MOVEL'RREPK '  K4AFLD
     C                     EXSR #GET
     C                     MOVEL@AN       RREPK
      * RREF2 ID  REF#      PK
     C                     MOVEL'RREF2 '  K4AFLD
     C                     EXSR #GET
     C                     MOVEL@AN       RREF2
      * RRESI AN  REF# QUA  SI
     C                     MOVEL'RRESI '  K4AFLD
     C                     EXSR #GET
     C                     MOVEL@AN       RRESI
      * RREF3 ID  REF#      SI
     C                     MOVEL'RREF3 '  K4AFLD
     C                     EXSR #GET
     C                     MOVEL@AN       RREF3
      * RDTM1 ID  DATE/TIME QUA
     C                     MOVEL'RDTM1 '  K4AFLD
     C                     EXSR #GET
     C                     MOVEL@AN       RDTM1
      * RDTM2 DT  DATE
     C                     MOVEL'RDTM2 '  K4AFLD
     C                     EXSR #GET
     C                     MOVEL@DATE8    RDTM2
      * RN101 ID  ENT ID    SHIP FROM
     C                     MOVEL'RN101 '  K4AFLD
     C                     EXSR #GET
     C                     MOVEL@AN       RN101
      * RN104 AN ID CODE   SHIP FROM
     C                     MOVEL'RN104 '  K4AFLD
     C                     EXSR #GET
     C                     MOVEL@AN       RN104
      * RN201 ID  ENT ID CO SHIP TO
     C                     MOVEL'RN201 '  K4AFLD
     C                     EXSR #GET
     C                     MOVEL@AN       RN201
      * RN204 AN ID CODE   SHIP TO
     C                     MOVEL'RN204 '  K4AFLD
     C                     EXSR #GET
     C                     MOVEL@AN       RN204
      *
     C           EHDSET    ENDSR
      *================================================================
      *  GET DETAIL
      *================================================================
     C           #DTSET    BEGSR
      *
      * RRQTY  R   QTY UNITS RCV
     C                     MOVEL'RRQTY '  K4AFLD
     C                     EXSR #GET
     C                     Z-ADD@NUM      RRQTY
      * RRTND  R   QTY UNITS RETURN
     C                     MOVEL'RRTND '  K4AFLD
     C                     EXSR #GET
     C                     Z-ADD@NUM      RRTND
      * RQQTY  R   QTY IN QUESTION
     C                     MOVEL'RQQTY '  K4AFLD
     C                     EXSR #GET
     C                     Z-ADD@NUM      RQQTY
      * RRCD8  ID  RCV CONDITION
     C                     MOVEL'RRCD8 '  K4AFLD
     C                     EXSR #GET
     C                     MOVEL@AN       RRCD8
      * RRCD9  R   # OF UNITS SHIP
     C                     MOVEL'RRCD9 '  K4AFLD
     C                     EXSR #GET
     C                     Z-ADD@NUM      RRCD9
      * RPART  AN  PRODUCT/SERVICE ID
     C                     MOVEL'RPART '  K4AFLD
     C                     EXSR #GET
     C                     MOVEL@AN       RPART
      * WRITE
     C                     WRITEEB#EP801
      *
     C           EDTSET    ENDSR
      *================================================================
      *  GET VALUE FROM
      *================================================================
     C           #GET      BEGSR
      *
     C                     MOVE '+'       SIGN    1
     C                     MOVEA*BLANK    TB2
     C                     MOVEA*ALL'0'   TB3
     C                     MOVE *BLANK    @AN    60
     C                     Z-ADD0         @NUM   100
     C                     Z-ADD0         @DATE6  60
     C                     Z-ADD0         @DATE8  80
      *
     C           K@EJG0    CHAINEJGPL00              98
     C           *IN98     IFEQ *OFF
      *
     C                     SELEC
      * CONSTANT ----------------------------------
     C           E0FTYP    WHEQ 'C '
     C                     MOVELE0VAL1    @AN
      * CHARACTER ---------------------------------
     C           E0FTYP    WHEQ 'AN'
     C           E0FTYP    OREQ 'ID'
     C           E0POS1    SUB  1         IX
     C           1         DO   E0LNG     IY
     C                     ADD  1         IX
     C                     MOVELTB1,IX    TB2,IY
     C                     ENDDO
     C                     MOVEATB2       @AN
      * NUMERIC -----------------------------------
     C           E0FTYP    WHEQ 'DT'
     C           E0FTYP    OREQ 'TM'
     C           E0FTYP    OREQ 'R '
     C           E0POS2    ADD  1         IX
     C                     Z-ADD11        IY
     C                     DO   E0LNG
     C                     SUB  1         IX
     C           IX        IFLT E0POS1
     C                     LEAVE
     C                     ENDIF
     C                     SUB  1         IY
     C           IY        IFLE 0
     C                     LEAVE
     C                     ENDIF
     C           TB1,IX    IFEQ '-'
     C                     MOVE '-'       SIGN
     C                     ENDIF
     C           TB1,IX    IFEQ *BLANK
     C           TB1,IX    OREQ '+'
     C           TB1,IX    OREQ '-'
     C                     MOVE '0'       TB3,IY
     C                     ELSE
     C                     MOVELTB1,IX    TB3,IY
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEATB3       LTR10  10
     C                     MOVELLTR10     @NUM
     C                     Z-ADD@NUM      @DATE6
     C           @DATE6    ADD  20000000  @DATE8
     C           SIGN      IFEQ '-'
     C                     MULT -1        @NUM
     C                     ENDIF
      *    ----------------------------------------
     C                     ENDSL
      *
     C                     ENDIF
     C                     ENDSR
      *================================================================
      *  INITIAL SET
      *================================================================
     C           #INIT     BEGSR
      *
     C           K@EJG0    KLIST
     C                     KFLD           K1RCID
     C                     KFLD           K2RTYP
     C                     KFLD           K3AFIL
     C                     KFLD           K4AFLD
      *
     C           *LIKE     DEFN E0RCID    K1RCID
     C           *LIKE     DEFN E0RTYP    K2RTYP
     C           *LIKE     DEFN E0AFIL    K3AFIL
     C           *LIKE     DEFN E0AFLD    K4AFLD
      *
     C                     Z-ADD*DATE     @DATE   80
     C                     TIME           @TIME   60
     C                     TIME           WTIME
     C                     Z-ADD0         IX      30
     C                     Z-ADD0         IY      30
      *
     C                     ENDSR
