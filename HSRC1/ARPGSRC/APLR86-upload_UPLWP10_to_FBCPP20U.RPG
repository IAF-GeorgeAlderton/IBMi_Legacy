     H            Y.
     F** APLR86 **************************************
     F*  UPLOAD UPLWP10 TO FBCPP20U                  *
     F*  JW     2021.05.11                           *
     F************************************************
     FUPLWP10 IF  E                    DISK
     FFBCPP20UO   E                    DISK
      *
     I            DS
     I                                        1  20 @HIN
     I                                        1   5 @HIN1
     I                                        6  10 @HIN2
     I                                       11  15 @HIN3
     I                                       16  20 @HIN4
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                     *PROGRAM #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I                                      264 269 #JOB#
      *----------------------------------------------------*
      *----------------------------------------------------*
      *
     C                     TIME           SDATE            SYSTEM DATE
      * READ
     C                     DO   *HIVAL
     C                     READ UPLWP10                  98
     C   98                LEAVE
      *
     C                     CLEARFBCPP2U1
      *
     C                     Z-ADDTODAY     F2KYMD
     C                     Z-ADDNOW       F2KTIM
      * TOKU
     C                     MOVELU1FLD4    LTR4    4
     C                     MOVE LTR4      LTR1    1
     C                     MOVELLTR4      LTR3    3
     C           LTR1      IFEQ ' '
     C                     MOVEL'0'       F2TOKU
     C                     MOVE LTR3      F2TOKU
     C                     ELSE
     C                     MOVELLTR4      F2TOKU
     C                     ENDIF
      * NONY
     C                     MOVELU1FLD5    LTR4
     C                     MOVE LTR4      LTR1
     C                     MOVELLTR4      LTR3
     C           LTR1      IFEQ ' '
     C                     MOVEL'0'       F2NONY
     C                     MOVE LTR3      F2NONY
     C                     ELSE
     C                     MOVELLTR4      F2NONY
     C                     ENDIF
      *
     C           U1FLD6    IFNE ' '
     C           U1FLD6    ANDNE'-'
     C                     MOVELU1FLD6    F2NKOJ
     C                     ENDIF
      *
     C           U1FLD7    IFNE ' '
     C           U1FLD7    ANDNE'-'
     C                     MOVELU1FLD7    F2NUKE
     C                     ENDIF
      *
     C                     MOVELU1FLD2    @HIN
     C                     MOVEL@HIN1     F2MHN1
     C                     MOVEL@HIN2     F2MHN2
     C                     MOVEL@HIN3     F2MHN3
     C                     MOVEL@HIN4     F2MHN4
      *
     C                     MOVELU1FLD3    @HIN
     C                     MOVEL@HIN1     F2SHN1
     C                     MOVEL@HIN2     F2SHN2
     C                     MOVEL@HIN3     F2SHN3
      *
     C                     MOVELU1FLD1    F2SLSP
     C                     Z-ADD202104    F2STYM
     C                     Z-ADD202203    F2ENYM
      *
     C           U1FLD8    IFNE ' '
     C           U1FLD8    ANDNE'-'
     C                     MOVELU1FLD8    F2RMK1
     C                     ENDIF
      *
     C                     MOVELU1FLD9    $IN       P
     C                     CALL 'UTLR60'
     C                     PARM           $IN    17
     C                     PARM           $TRUE  156
     C                     PARM           $RTN    1
     C                     Z-ADD$TRUE     F2UPRC
      *
     C                     MOVEL#USER     F2KOME
      *
     C                     WRITEFBCPP2U1
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
