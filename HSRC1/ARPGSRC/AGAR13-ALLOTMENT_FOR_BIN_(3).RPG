     C           I         DO   24        K       50
     C           CDBI,K    IFNE 0
     C           CDDT,K    ANDNE'*'
     C                     ADD  1         J
     C                     Z-ADDCDBI,K    BIN,J
     C                     Z-ADD1         L       50
     C           BIN,J     IFGE 1
     C           BIN,J     ANDLE24
     C                     Z-ADDBIN,J     L
     C                     END
     C                     Z-ADDK         KX      20
     C                     Z-ADDCBHK,L    HAK,J
     C                     MOVEL'0'       FLG,J
     C                     Z-ADD0         TIM,J
     C           KX        LOKUPTAB3      TAB4           10
