      *
     C           @AAA      TAG
     C           XXX       ADD  1         X
      *
     C*  AGAPL31 (UPD)
     C*
     C                     Z-ADDWHSRYO    CBHASU
     C                     DO   CDCIBI    I
     C           BIN,I     IFNE 0
     C                     Z-ADDBIN,I     J
     C           FLG,I     IFEQ '0'
     C                     Z-ADDHAK,I     CBHK,J
     C                     END
     C           FLG,I     IFEQ '1'
     C                     Z-ADDHAK,I     CBHN,J
     C                     END
     C                     ELSE
     C           HAK,I     MULT CBSYUY    ANS    110
     C                     ADD  ANS       CBHASU
     C                     END
     C                     END
      *
     C*  AGANP11 (ADD & UPD)
     C*
     C                     DO   CDCIBI    I
     C           BIN,I     IFNE 0
     C                     Z-ADDBIN,I     J
     C           FLG,I     IFEQ '2'
     C                     Z-ADDHAK,I     CBHX,J
     C                     END
     C                     ELSE
     C           HAK,I     MULT CBSYUY    ANS
     C                     ADD  ANS       CBHASU
     C                     END
     C                     END
     C   30                WRITEAGANP111
     C  N30                UPDATAGANP111
     C                     UPDATAGAPL311
