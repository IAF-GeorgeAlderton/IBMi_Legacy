     C                     Z-ADDCDBI,K    BIN,J
     C                     Z-ADD1         L
     C           BIN,J     IFGE 1
     C           BIN,J     ANDLE24
     C                     Z-ADDBIN,J     L
     C                     END
     C           K         SUB  24        KX
     C                     Z-ADDCBHN,L    HAK,J
     C                     MOVEL'1'       FLG,J
     C                     Z-ADD0         TIM,J
     C           KX        LOKUPTAB3      TAB4           10
     C   10                Z-ADDTAB4      TIM,J
     C                     END
     C           J         COMP CDCIBI               10  10
     C  N10                END
     C                     END
      *
