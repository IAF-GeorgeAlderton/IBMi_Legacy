     C           CBSYUY    MULT WBARL     WBSRYO  90       ﾌﾞﾛﾓﾇc
     C           WHSRYO    IFGE WBSRYO
     C                     Z-ADD0         WBLSRY  30       ﾌｮkｬcﾌﾞﾛﾓﾇc
     C                     Z-ADD0         WBHSRY  70       ﾌﾞﾛﾓﾅﾞ]ﾇc
     C           WBSRYO    IFNE 0
     C           WHSRYO    DIV  WBSRYO    WBLSRY
     C                     MVR            WBHSRY
