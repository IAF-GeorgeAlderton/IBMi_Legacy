     C*----------------------------------------------------*
     C*  @OUT SUB-ROUTINE #1 CREATE ASJ WASHER ORDER KANBAN
     C*----------------------------------------------------*
     C           @OUTS1    BEGSR
     C*
     C                     Z-ADD*ZERO     W@CNT   40
     C*
     C                     DO   *HIVAL
     C*
     C                     ADD  1         W@CNT
     C           W@CNT     IFGT W6KAN#
     C                     LEAVE
     C                     END
     C*
     C           W@LT#2    IFEQ 999
     C                     Z-ADD1         Y       20
     C           W@LT#1    LOKUPLT1,Y                    94
     C           *IN94     IFEQ *ON
     C                     ADD  1         Y
     C           Y         IFGT 25
     C                     MOVELLT1,1     W@LT#1
     C                     ELSE
     C                     MOVELLT1,Y     W@LT#1
     C                     END
     C                     Z-ADD*ZERO     W@LT#2
     C                     END
     C                     END
     C*
     C                     ADD  1         W@LT#2
