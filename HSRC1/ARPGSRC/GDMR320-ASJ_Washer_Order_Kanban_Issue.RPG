     C                     END
     C                     MOVELW6PRT2    W@PRT2
     C           W6PRT3    IFNE *BLANK
     C                     MOVEL'-'       W@PRTB
     C                     END
     C                     MOVELW6PRT3    W@PRT3
     C*
