     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     MOVEL*ON       *IN88
     C                     MOVEL*OFF      *INOF
     C                     ENDIF
     C*
     C                     EXCPT@DTL
     C*
     C           K#KEY     KLIST
     C                     KFLD           W6PRT1
     C                     KFLD           W6PRT2
     C                     KFLD           W6PRT3
     C           K#KEY     CHAINGDMPL50              95
