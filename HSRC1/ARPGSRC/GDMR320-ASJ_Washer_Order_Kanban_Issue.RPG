     C                     Z-ADD*ZERO     M5SKDT
     C                     Z-ADD*ZERO     M5SKTM
     C                     MOVEL*BLANK    M5SKID
     C                     MOVEL*BLANK    M5SKWS
     C                     MOVEL*BLANK    M5SKPG
     C                     END
     C                     TIME           WWTIME
     C                     Z-ADD@@YMD     M5KODT
     C                     Z-ADDWTIM4     M5KOTM
     C                     MOVEL#USER     M5KOID
     C                     MOVEL#WSID     M5KOWS
     C                     MOVEL#PGM      M5KOPG
     C                     MOVELW6PRT1    M5PRT1
     C                     MOVELW6PRT2    M5PRT2
     C                     MOVELW6PRT3    M5PRT3
