     C                     Z-ADDW@LT#2    M5LOT2
     C                     Z-ADD@@YMD     M5CRDT
     C                     Z-ADDWTIM4     M5CRTM
     C   95                WRITEGDMPP501
     C  N95                UPDATGDMPP501
     C*
     C                     ENDDO
     C*
     C           D@INV#    IFEQ '999999'
