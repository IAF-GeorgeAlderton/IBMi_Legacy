      *
     C                     EXSR @SCRN1
      *
     C                     DO   *HIVAL
     C*
     C                     WRITEDSP99
     C                     EXFMTCTL01
     C*
     C                     SELEC
     C* F1
     C           *INKA     WHEQ *ON
     C                     LEAVE
     C* F12
     C           *INKL     WHEQ *ON
     C                     MOVEL*BLANK    D@MSG
     C                     LEAVE
     C* F5
     C           *INKE     WHEQ *ON
