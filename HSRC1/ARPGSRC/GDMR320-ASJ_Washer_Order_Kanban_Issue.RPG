TCHK2C*
TCHK2C           D@INV#    IFEQ *BLANK
TCHK2C           D@INV#    ORLE D@INVP
TCHK2C                     MOVEL*ON       *IN41
TCHK2C                     MOVELERR,3     D@MSG
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C*
TCHK2C                     MOVELD@INV#    W@A002
TCHK2C           W@A002    IFEQ 'US'
TCHK2C           D@INV#    OREQ '999999'
TCHK2C                     ELSE
TCHK2C                     MOVEL*ON       *IN41
TCHK2C                     MOVELERR,3     D@MSG
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C*
