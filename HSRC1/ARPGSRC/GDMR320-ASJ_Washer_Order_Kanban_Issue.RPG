TCHK2C                     EXSR @SET0
TCHK2C                     Z-ADD1         W#RNP0  40
     C*
     C                     DO   *HIVAL
     C*
     C                     MOVEL*ON       *IN42
     C                     WRITEDSP99
TCHK2C                     Z-ADDW#RNP0    #RCNO
TCHK2C                     EXFMTCTL00
     C   KA                LEAVE
TCHK2C*
TCHK2C           @@REC     IFNE *ZERO
TCHK2C                     Z-ADD@@REC     W#RNP0
TCHK2C                     END
TCHK2C*
     C                     MOVEL*OFF      *IN41
     C                     MOVEL*BLANK    D@MSG
     C*
TCHK2C                     EXSR @CHK0
TCHK2C           *IN41     IFEQ *ON
TCHK2C                     ITER
TCHK2C                     END
     C*
     C                     EXSR @SUM
     C                     MOVEL*OFF      *IN42
     C                     EXSR @SCRN
     C*
     C   KA                LEAVE
     C*
     C                     ENDDO
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
     C*
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @@RRN   40
     C*
     C                     TIME           WWTIME
     C*
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
     C           P#BRC     PLIST
     C                     PARM           PMAREA100
     C                     PARM           PMBYTE  3
     C                     PARM           PMCHK   1
     C                     PARM           PMRTCD  1
     C*
     C                     MOVEL#PGM      K#PGM   8 P
TCHK2C                     MOVEL*BLANK    W@INVP  6
TCHK2C                     MOVEL*BLANK    W@INV#  6
TCHK2C*
     C           K#PGM     CHAINAB#PPCT              99
     C           *IN99     IFEQ *ON
TCHK2C                     MOVEL*BLANK    W@INVP
     C                     ELSE
TCHK2C                     MOVELCTCHR1    W@INVP
     C                     END
     C*
TCHK2C           W@INVP    SETGTGDMPL72
     C                     READ GDMPL72                  99
     C           *IN99     IFEQ *OFF
TCHK2C                     MOVELIEINVO    W@INV#
     C                     END
TCHK2C*
TCHK2C                     CLEARINV
TCHK2C                     Z-ADD*ZERO     Z       30
TCHK2C                     MOVEL*BLANK    W@A006  6
TCHK2C           *LOVAL    SETLLGDMPL72
TCHK2C*
TCHK2C                     DO   *HIVAL
TCHK2C                     READ GDMPL72                  98
TCHK2C   98                LEAVE
TCHK2C           IESKJY    IFNE *BLANK
TCHK2C                     ITER
TCHK2C                     END
TCHK2C                     MOVELIEINVO    W@A002  2
%0002C           W@A002    IFEQ 'CA'
%0002C                     ITER
%0002C                     END
TCHK2C           W@A002    IFEQ 'US'
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C           IEINVO    IFNE W@A006
TCHK2C                     ADD  1         Z
TCHK2C                     MOVELIEINVO    INV,Z
TCHK2C                     MOVELIEINVO    W@A006
TCHK2C                     END
TCHK2C                     ENDDO
     C* DUMMY READ
