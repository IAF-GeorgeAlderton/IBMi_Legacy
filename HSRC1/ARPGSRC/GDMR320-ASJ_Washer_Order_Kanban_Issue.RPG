     C                     MOVELLT1,1     W@LT#1  1
     C                     Z-ADD*ZERO     W@LT#2  30
     C                     ELSE
     C                     MOVELM5LOT1    W@LT#1
     C                     Z-ADDM5LOT2    W@LT#2
     C                     END
     C*
     C                     EXSR @OUTS1
     C*
     C           *IN95     IFEQ *ON
