TCHK2C           @SET0     BEGSR
TCHK2C*
TCHK2C                     Z-ADD*ZERO     RRN0    40
TCHK2C                     MOVE *ON       *IN31
TCHK2C                     WRITECTL00
TCHK2C                     MOVE *OFF      *IN31
TCHK2C*
TCHK2C                     MOVELW@INVP    D@INVP
TCHK2C                     MOVELW@INV#    D@INV#
TCHK2C                     MOVELW@INV#    D@INV2
TCHK2C                     MOVEL'CA'      D@INV2
TCHK2C*
TCHK2C                     Z-ADD*ZERO     Z
TCHK2C*
TCHK2C                     DO   *HIVAL
TCHK2C*
     C                     ADD  1         Z
%0001C***        Z         IFGT 100
     C           Z         IFGT 500
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C           INV,Z     IFEQ *BLANK
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C*
TCHK2C                     CLEARSFL00
TCHK2C*
TCHK2C                     MOVELINV,Z     S@INVO
TCHK2C*
TCHK2C                     ADD  1         RRN0
TCHK2C                     WRITESFL00
TCHK2C*
TCHK2C                     ENDDO
TCHK2C*
TCHK2C           RRN0      IFEQ *ZERO
TCHK2C                     CLEARSFL00
TCHK2C                     Z-ADD1         RRN0
TCHK2C                     MOVEL*ON       *IN33
TCHK2C                     WRITESFL00
TCHK2C                     MOVEL*OFF      *IN33
TCHK2C                     END
TCHK2C*
TCHK2C                     ENDSR
