     C                     WRITECTL01
     C                     MOVE *OFF      *IN51
     C                     Z-ADD*ZERO     C1KAN#
      *
     C           *LOVAL    SETLLGDMWP60
      *
     C                     DO   *HIVAL
     C*
     C                     READ GDMWP60                  91
     C   91                LEAVE
     C           W6ODER    IFNE *ZERO
     C           W6ITEM    ANDNE*ZERO
     C           W6PARE    ANDNE*BLANK
     C           W6INVO    ANDNE*BLANK
     C                     ITER
     C                     END
     C           W6INB#    IFEQ *ZERO
     C           W6KAN#    ANDEQ*ZERO
     C           W6BAL#    ANDEQ*ZERO
     C           W6ADJ#    ANDEQ*ZERO
     C                     ITER
     C                     END
     C*
     C                     CLEARSFL01
     C*
     C                     MOVELW6LOC2    W#LOC1
     C                     MOVEL'-'       W#LOCA
     C                     MOVELW6LOC3    W#LOC2
     C                     MOVELW#LOC     S1LOC
     C                     MOVEL*BLANK    W@PRT
     C                     MOVELW6PRT1    W@PRT1
     C           W6PRT2    IFNE *BLANK
     C                     MOVEL'-'       W@PRTA
     C                     END
     C                     MOVELW6PRT2    W@PRT2
     C           W6PRT3    IFNE *BLANK
     C                     MOVEL'-'       W@PRTB
     C                     END
     C                     MOVELW6PRT3    W@PRT3
     C                     MOVELW@PRT     S1PART
     C                     Z-ADDW6LOTS    S1LOT
     C                     Z-ADDW6ADJ#    S1ADJS
     C                     Z-ADDW6INB#    S1BOXS
     C                     Z-ADDW6KAN#    S1KAN#
     C                     Z-ADDW6BAL#    S1BBOX
     C                     MOVELW6INVO    S1INVO
     C*
     C                     ADD  W6KAN#    C1KAN#
     C*
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C*
     C                     ENDDO
     C*
     C           RRN1      IFEQ *ZERO
     C                     CLEARSFL01
     C                     Z-ADD1         RRN1
     C                     WRITESFL01
     C                     MOVELERR,1     D@MSG
     C                     END
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  WORK SUMMARY FILE ---> ASJ WASHER ORDER KANBAN
     C*----------------------------------------------------*
     C           @OUT      BEGSR
     C*
     C                     CLOSEGDMPL60
     C                     MOVELCMD,2     P@CMD     P
     C                     Z-ADD75        P@LEN
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN GDMPL60
     C*
     C           *LOVAL    SETLLGDMWP60
     C*
     C                     DO   *HIVAL
     C*
     C                     READ GDMWP60                  98
     C   98                LEAVE
     C*
     C           W6ODER    IFNE *ZERO
     C           W6ITEM    ANDNE*ZERO
     C           W6PARE    ANDNE*BLANK
     C           W6INVO    ANDNE*BLANK
     C                     EXSR @OUTS2
     C                     ITER
     C                     END
     C           W6INB#    IFEQ *ZERO
     C           W6KAN#    ANDEQ*ZERO
     C           W6BAL#    ANDEQ*ZERO
     C                     ITER
     C                     END
     C*
     C           W6BAL#    IFNE *ZERO
     C                     CLEARGDMPP601
     C                     TIME           WWTIME
     C                     Z-ADD@@YMD     M6KODT
     C                     Z-ADDWTIM4     M6KOTM
     C                     MOVEL#USER     M6KOID
     C                     MOVEL#WSID     M6KOWS
     C                     MOVEL#PGM      M6KOPG
     C                     MOVELW6PRT1    M6PRT1
     C                     MOVELW6PRT2    M6PRT2
     C                     MOVELW6PRT3    M6PRT3
     C                     Z-ADDW6BAL#    M6ADJ#
     C                     WRITEGDMPP601
     C                     END
     C*
     C           W6KAN#    IFEQ *ZERO
     C                     ITER
     C                     END
     C*
     C                     MOVELW6LOC2    W#LOC1
     C                     MOVEL'-'       W#LOCA
     C                     MOVELW6LOC3    W#LOC2
     C                     MOVEL*BLANK    W@PRT
     C                     MOVELW6PRT1    W@PRT1
