     C           @SUM      BEGSR
      *
     C                     CLOSEGDMWP60
     C                     MOVELCMD,1     P@CMD     P
     C                     Z-ADD75        P@LEN
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN GDMWP60
     C*
TCHK2C                     CLEARINV
TCHK2C                     Z-ADD*ZERO     RRN0
TCHK2C                     Z-ADD*ZERO     Z
TCHK2C                     DO   *HIVAL
TCHK2C                     ADD  1         RRN0
TCHK2C           RRN0      CHAINSFL00                98
TCHK2C   98                LEAVE
TCHK2C           S@SLCT    IFNE *BLANK
TCHK2C                     ADD  1         Z
TCHK2C                     MOVELS@INVO    INV,Z
TCHK2C                     END
TCHK2C                     ENDDO
TCHK2C*
     C           *LOVAL    SETLLGDMPL10
     C*
     C                     DO   *HIVAL
     C*
     C                     READ GDMPL10                  98
     C   98                LEAVE
     C                     CLEARGDMWP601
     C           M1SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           M1CHGD    IFLE @@YMD
     C                     Z-ADDM1LOTN    W6LOTS
     C                     MOVELM1BOXN    W6BOX
     C                     MOVELM1PRCN    W6PRC
     C                     ELSE
     C                     Z-ADDM1LOTO    W6LOTS
     C                     MOVELM1BOXO    W6BOX
     C                     MOVELM1PRCO    W6PRC
     C                     END
     C           W6LOTS    IFEQ *ZERO
     C                     ITER
     C                     END
     C*
     C                     MOVELM1PRT1    W6PRT1
     C                     MOVELM1PRT2    W6PRT2
     C                     MOVELM1PRT3    W6PRT3
     C*
     C           K#HIN     KLIST
     C                     KFLD           M1PRT1
     C                     KFLD           M1PRT2
     C                     KFLD           M1PRT3
     C*
     C           K#HIN     SETGTAKBPL07
     C                     DO   *HIVAL
     C           K#HIN     REDPEAKBPL07                  97
     C   97                LEAVE
     C           L1SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           L1UKHZ    IFGT @@YMD
     C                     ITER
     C                     END
     C           L1STHZ    IFLE @@YMD
     C                     ITER
     C                     END
     C           L1BMON    IFNE 8990
     C                     ITER
     C                     END
     C                     LEAVE
     C                     ENDDO
     C           *IN97     IFEQ *ON
     C                     ITER
     C                     END
     C                     MOVELL1TKR1    W6LOC1
     C                     MOVELL1TKR2    W6LOC2
     C                     MOVELL1TKR3    W6LOC3
     C                     MOVELL1TKR4    W6LOC4
     C                     MOVELL1ZETI    W6ZETI
     C                     Z-ADDL1SYOS    W6SYOS
     C*
     C           K#HIN     CHAINGDMPL60              97
     C           *IN97     IFEQ *OFF
     C           M6SKJY    ANDEQ*BLANK
     C                     Z-ADDM6ADJ#    W6ADJ#
     C                     ELSE
     C                     Z-ADD*ZERO     W6ADJ#
     C                     END
     C*
     C                     Z-ADD*ZERO     WTINB#  40
     C                     Z-ADD999999    WTODER  60
     C                     MOVEL*BLANK    WTINVO  6
     C                     MOVE D@INV#    XINV2   40
     C*
     C           K#HIN     SETLLGDMPL71
     C                     DO   *HIVAL
     C           K#HIN     READEGDMPL71             N    97
     C   97                LEAVE
     C           IESKJY    IFNE *BLANK
     C                     ITER
     C                     END
TCHK2C                     MOVELIEINVO    W@A002
     C** US  OR  CA  (SHIP)
     C           W@A002    IFEQ 'US'
     C           W@A002    OREQ 'CA'
     C*
TCHK2C           D@INV#    IFEQ '999999'
TCHK2C                     ITER
TCHK2C                     END
     C*
     C**         IEINVO    IFGT D@INV#
     C                     MOVE IEINVO    XINV1   40
     C           XINV1     IFGT XINV2
     C                     ITER
     C                     END
     C*
     C** EXCEPT US AND CA  (UA)
TCHK2C                     ELSE
TCHK2C           IEINVO    LOKUPINV                      90
TCHK2C           *IN90     IFEQ *OFF
TCHK2C                     ITER
TCHK2C                     END
TCHK2C                     END
     C                     Z-ADDIESBOX    W6INB#
     C                     Z-ADDIEODER    W6ODER
     C                     Z-ADDIEITEM    W6ITEM
     C                     Z-ADDIEIKBN    W6IKBN
     C                     MOVELIEPARE    W6PARE
     C                     MOVELIEINVO    W6INVO
     C*
     C                     ADD  IESBOX    WTINB#
     C           IEODER    IFLT WTODER
     C                     Z-ADDIEODER    WTODER
     C                     END
     C           IEINVO    IFGT WTINVO
     C                     MOVELIEINVO    WTINVO
     C                     END
     C                     WRITEGDMWP601
     C                     ENDDO
     C*
     C                     Z-ADDWTINB#    W6INB#
     C                     Z-ADDWTODER    W6ODER
     C                     Z-ADD*ZERO     W6ITEM
     C                     Z-ADD*ZERO     W6IKBN
     C                     MOVEL*BLANK    W6PARE
     C                     MOVELWTINVO    W6INVO
     C           W6ADJ#    ADD  W6INB#    W@TTL5  50
     C           W@TTL5    IFGE W6LOTS
     C           W@TTL5    DIV  W6LOTS    W6KAN#
     C                     MVR            W6BAL#
     C                     ELSE
     C                     Z-ADDW@TTL5    W6BAL#
     C                     END
     C*
     C           W6KAN#    IFEQ *ZERO
     C                     MOVEL'1'       W6GRP#
     C                     END
     C*
     C                     WRITEGDMWP601
     C*
     C                     ENDDO
     C*
     C                     ENDSR
