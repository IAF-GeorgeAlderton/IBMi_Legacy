     H            Y.
      *
     FFCEPL07 IF  E           K        DISK
     FCABPL01 IF  E           K        DISK
      *
     E                    OBM        15  4               部門
     E                    OKB        15  3               機番
     E                    OTK        15  6               所番地
     E                    OSH        15  1               かんばん種類
     E                    OKO        15  3               工程
     E                    OHB        15 12               品番
      *
     C           *ENTRY    PLIST
     C                     PARM           P@BARC 20
     C                     PARM           P@KOTE  3
     C                     PARM           P@BMON  4
     C                     PARM           P@KIBN  3
     C                     PARM           P@RTN   1
      *
     C                     MOVE *BLANK    P@RTN   1
      *
     C* * *                MOVE 'JC '     P@KOTE  3
     C* * *                MOVE '8990'    P@BMON  4
     C* * *                MOVE *BLANK    P@KIBN  3
      *
      * 90105A0359
      * A404000204M50C
     C* * *                MOVEL'A4040002'P@BARC
     C* * *                CAT  '04M50C':0P@BARC
      *
     C                     CALL 'BARR81'
     C                     PARM           P@BARC 20
     C                     PARM           P@KRKB  1
     C                     PARM           P@ZETI  4
     C                     PARM           P@TEHI  3
     C                     PARM           P@PAGN  2
     C                     PARM           P@BCKA  1
     C                     PARM           P@BCTK  1
     C                     PARM           P@BCYK  1
     C                     PARM           P@BCHK  1
     C                     PARM           P@BCKD  1
      *
     C           P@ZETI    CHAINFCEPL07              77
     C           *IN77     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C                     SETON                     77
     C                     END
     C   77                GOTO @END
      *
     C           KEY       KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
      *
     C           KEY       CHAINCABPL01              88
     C           *IN88     IFEQ '0'
     C           C3SKJY    ANDEQ'D'
     C                     SETON                     88
     C                     END
     C  N88                GOTO @END
      *
     C                     CALL 'AAMRSC'
      * IN
     C                     PARM A2BHB1    INHIN1  5
     C                     PARM A2BHB2    INHIN2  5
     C                     PARM A2BHB3    INHIN3  2
      * OUT
     C                     PARM *BLANK    OUTBMN 60
     C                     PARM *BLANK    OUTKBN 45
     C                     PARM *BLANK    OUTTKR 90
     C                     PARM *BLANK    OUTSHR 15
     C                     PARM *BLANK    OUTKOT 45
     C                     PARM *BLANK    OUTHBN180
     C                     PARM *BLANK    STATUS  1
      *
     C           STATUS    IFNE '1'
     C                     GOTO @END
     C                     END
      *
     C                     MOVEAOUTBMN    OBM
     C                     MOVEAOUTKBN    OKB
     C                     MOVEAOUTTKR    OTK
     C                     MOVEAOUTSHR    OSH
     C                     MOVEAOUTKOT    OKO
     C                     MOVEAOUTHBN    OHB
      *
     C                     MOVE *BLANK    W@FLG   1
     C                     Z-ADD0         W@CNT   30
     C                     Z-ADD0         @Z      30
     C           1         DO   15        @X      30
     C           16        SUB  @X        @Z
     C           OKO,@Z    IFEQ *BLANK
     C                     ITER
     C                     END
     C           OSH,@Z    IFNE *BLANK
     C                     ADD  1         W@CNT
     C                     END
     C           W@CNT     IFGE 2
     C                     LEAVE
     C                     END
      *
     C           P@KOTE    IFNE *BLANK
     C           P@KOTE    ANDNEOKO,@Z
     C                     ITER
     C                     END
      *
     C           P@BMON    IFNE *BLANK
     C           P@BMON    ANDNEOBM,@Z
     C                     ITER
     C                     END
      *
     C                     MOVE '*'       P@RTN
      *
     C                     LEAVE
      *
     C                     ENDDO
      *
     C           @END      TAG
      *
     C                     SETON                     LR
     C                     RETRN
      *
