     H            Y/
     F** ABFR09 *****************************************
     F* ADD WORK FORD ACCUMULATE QTY(ABFAP99) TO ABFAP01*
     F* FORD all plant                                  *
     F*                                                 *
     F* J.WATANABE 2017.01.03                           *
     F***************************************************
     FABFAP99 IF  E           K        DISK
     FABFAP01 UF  E           K        DISK                      A
      *------------------------------------------------------------
     IABFAP99R    01
     I              CFDLCD                          C9DLCD
     I              CFDLDY                          C9DLDY
     I              CFDLDM                          C9DLDM
     I              CFDLDD                          C9DLDD
     I              CFUPDY                          C9UPDY
     I              CFUPDM                          C9UPDM
     I              CFUPDD                          C9UPDD
     I              CFUPTH                          C9UPTH
     I              CFUPTM                          C9UPTM
     I              CFUPNM                          C9UPNM
     I              CFDOCK                          C9DOCK
     I              CFDOC2                          C9DOC2
     I              CFPART                          C9PART
     I              CFPOR#                          C9POR#
     I              CFSIDT                          C9SIDT
     I              CFHSDT                          C9HSDT
     I              CFREF#                          C9REF#
     I              CFCDAT                          C9CDAT
     I              CFCAMT                          C9CAMT
     I              CFLDAT                          C9LDAT
      * THE FOLLOWING TWO AREA IS USED FOR PRIOR CUM
     I              CFTAMT                          C9TAMT
     I              CFTDAT                          C9TDAT
     I              CFCAMN                          C9CAMN
      *
     I            DS
     I                                        1  140W@TIME
     I                                        1   20W@H
     I                                        3   40W@M
     I                                        5   60W@S
     I                                        7  140W@YMD
     I                                        7  140@DATE8
     I                                        9  140@DATE6
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *==================================================
      *
     C                     EXSR #INT
      * CLEAR ABFAP01
     C                     EXSR #CLR
      * UPDATE ABFAP01 BY AP99
     C                     MOVE *OFF      *IN98
     C           *IN98     DOWEQ*OFF
     C                     READ ABFAP99                  98
     C           *IN98     IFEQ *OFF
     C                     MOVELC9DOCK    KFDOCK
     C                     MOVELC9DOC2    KFDOC2
     C                     MOVELC9PART    KFPART
     C           KEY1      CHAINABFAP01R             97
     C           *IN97     IFEQ *OFF
     C                     EXSR #UPD
     C                     ELSE
     C                     EXSR #WRT
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
      *==================================================
      *  CLEAR ABFAP01
      *==================================================
     C           #CLR      BEGSR
     C                     MOVE *OFF      *IN96
     C           *LOVAL    SETLLABFAP01R
     C           *IN96     DOWEQ*OFF
     C                     READ ABFAP01R                 96
     C           *IN96     IFEQ *OFF
     C                     Z-ADD0         CFCAMN
     C                     Z-ADD0         CFCAMT
     C                     Z-ADD*YEAR     CFUPDY
     C                     Z-ADD*MONTH    CFUPDM
     C                     Z-ADD*DAY      CFUPDD
     C                     Z-ADDW@H       CFUPTH
     C                     Z-ADDW@M       CFUPTM
     C                     MOVEL#USER     CFUPNM
     C                     UPDATABFAP01R
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *==================================================
      *  UPDATE
      *==================================================
     C           #UPD      BEGSR
     C                     Z-ADDC9TAMT    CFCAMN
     C                     Z-ADDC9TAMT    CFCAMT
     C                     Z-ADD@DATE8    CFSIDT
     C                     Z-ADD@DATE6    CFCDAT
     C                     Z-ADD@DATE8    CFHSDT
     C                     UPDATABFAP01R
     C                     ENDSR
      *==================================================
      *  WRITE
      *==================================================
     C           #WRT      BEGSR
     C                     CLEARABFAP01R
     C                     MOVELC9DOCK    CFDOCK
     C                     MOVELC9DOC2    CFDOC2
     C                     MOVELC9PART    CFPART
      *
     C                     Z-ADDC9TAMT    CFCAMN
     C                     Z-ADDC9TAMT    CFCAMT
     C                     Z-ADD@DATE8    CFSIDT
     C                     Z-ADD@DATE6    CFCDAT
     C                     Z-ADD@DATE8    CFHSDT
     C*
     C                     WRITEABFAP01R
     C                     ENDSR
     C*=====================================================
     C* Initial SET
     C*=====================================================
     C           #INT      BEGSR
     C*
     C           KEY1      KLIST
     C                     KFLD           KFDOCK
     C                     KFLD           KFDOC2
     C                     KFLD           KFPART
     C*
     C           *LIKE     DEFN CFDOCK    KFDOCK
     C           *LIKE     DEFN CFDOC2    KFDOC2
     C           *LIKE     DEFN CFPART    KFPART
     C*
     C                     TIME           W@TIME
     C*
     C                     ENDSR
