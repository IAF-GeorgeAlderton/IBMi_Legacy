     H            Y.
     F***CHKR37C ***************************************************************
     F*  PROGRAM    : CHECK DUPLICATE ORDERS (AB#PP10) FOR HONDA               *
     F*             : RUN IN FCKC00 (10:10AM BY JOBSCDE)                       *
     F*  WRITTEN    : 2022.12.12                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#PL10CIF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1  20 BAMHIN
     I                                        1   5 BAMHN1
     I                                        6  10 BAMHN2
     I                                       11  15 BAMHN3
     I                                       16  20 BAMHN4
     I            DS
     I                                        1  20 SVMHIN
     I                                        1   5 SVMHN1
     I                                        6  10 SVMHN2
     I                                       11  15 SVMHN3
     I                                       16  20 SVMHN4
     I            DS
     I                                        1  23 XMHIN
     I                                        1   5 XMHN1
     I                                        6   6 P1
     I                                        7  11 XMHN2
     I                                       12  12 P2
     I                                       13  17 XMHN3
     I                                       18  18 P3
     I                                       19  23 XMHN4
     I            DS
     I                                        1   80TGDAT
     I                                        1   40K#NOYY
     I                                        5   60K#NOMM
     I                                        7   80K#NODD
     I            DS
     I                                        1   80BANOHZ
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           K#NOHZ    SETLLAB#PL10C
     C                     DO   *HIVAL
     C                     READ AB#PL10C                 98
     C   98                LEAVE
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * CHECK HONDA
     C           BATOKU    IFNE 0294
     C           BATOKU    ANDNE0295
     C           BATOKU    ANDNE0296
     C           BATOKU    ANDNE0390
     C           BATOKU    ANDNE0391
     C           BATOKU    ANDNE0400
     C           BATOKU    ANDNE1602
     C           BATOKU    ANDNE3135
     C                     ITER
     C                     ENDIF
      * DUPLICATE
     C           BANOHZ    IFEQ SVNOHZ
     C           BAODRN    ANDEQSVODRN
     C           BAMHIN    ANDEQSVMHIN
     C           BANONY    ANDEQSVNONY
     C           BAIAF#    ANDNESVIAF#
     C                     EXSR #PRINT
     C                     ENDIF
     C                     Z-ADDBANOHZ    SVNOHZ
     C                     MOVELBAODRN    SVODRN
     C                     MOVELBAMHIN    SVMHIN
     C                     Z-ADDBANONY    SVNONY
     C                     Z-ADDBAIAF#    SVIAF#
      *
     C                     ENDDO
      *
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      * PYHEN
     C                     MOVELSVMHN1    XMHN1
     C                     MOVELSVMHN2    XMHN2
     C                     MOVELSVMHN3    XMHN3
     C                     MOVELSVMHN4    XMHN4
     C                     SELEC
     C           SVMHN4    WHNE *BLANK
     C                     MOVE '-'       P1
     C                     MOVE '-'       P2
     C                     MOVE '-'       P3
     C           SVMHN3    WHNE *BLANK
     C                     MOVE '-'       P1
     C                     MOVE '-'       P2
     C                     MOVE ' '       P3
     C           SVMHN2    WHNE *BLANK
     C                     MOVE '-'       P1
     C                     MOVE ' '       P2
     C                     MOVE ' '       P3
     C                     ENDSL
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $DATE   8
     C                     PARM           $RTN    1
      *
     C           K#NOHZ    KLIST
     C                     KFLD           K#NOYY
     C                     KFLD           K#NOMM
     C                     KFLD           K#NODD
      *
     C                     MOVE *BLANK    $RTN
     C                     TIME           SDATE
      *
     C           $DATE     IFEQ *BLANK
     C           $DATE     OREQ *ZEROS
     C                     Z-ADDTODAY     TGDAT
     C                     ELSE
     C                     MOVEL$DATE     TGDAT
     C                     ENDIF
      *
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     Z-ADD0         SVNOHZ  80
     C                     MOVE *BLANK    SVODRN 10
     C                     MOVE *BLANK    SVMHIN 20
     C                     Z-ADD0         SVNONY  40
     C                     Z-ADD0         SVIAF# 100
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** DUPLICATE ORDER ('
     O                                   60 'HONDA) (AB#PP10) ** '
     O                                   79 'DATE'
     O                         TODAY     82 '    .  .  '
     O                         NOW       92 '  :  :  '
     O                                   95 'P.'
     O                         PAGE  Z   99
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   11 'DELV'
     O                                   22 'SHIP_DATE'
     O                                   34 'USER_PART'
     O                                   55 'ORDER#'
     O        E 1              @DTL
     O                         SEQ#    +001
     O                         SVNONY  +002
     O                         SVNOHZ  +002 '    /  /  '
     O                         XMHIN   +002
     O                         SVODRN  +001
