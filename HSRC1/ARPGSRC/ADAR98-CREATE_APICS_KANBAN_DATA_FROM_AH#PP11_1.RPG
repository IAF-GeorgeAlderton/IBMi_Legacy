     C                     ENDSR
      *-------------------------------------------------------
      * FIELD SET
      *-------------------------------------------------------
     C           #FLD      BEGSR
      *
     C           K#PRT     CHAINAAMPL111             11
     C                     Z-ADD0         Y       20
     C           1         DO   15        X       20
     C           CKHZ,X    IFGT YMD8
     C           CKQK,X    IFNE *BLANK
     C                     ADD  1         Y
     C                     MOVE CKQK,X    HKT,Y
     C                     END
     C                     ELSE
      *
     C           CKKO,X    IFNE *BLANK
     C                     ADD  1         Y
     C                     MOVE CKKO,X    HKT,Y
     C                     END
     C                     END
     C                     END
      *
     C                     Z-ADD16        X
     C                     Z-ADD1         Y
     C           1         DO   15        Y
     C           X         SUB  Y         Z       20
      *
     C           CKHZ,Z    IFGT YMD8
     C           CKQK,Z    CABEQ*BLANK    STEP21
     C           CKQT,Z    IFEQ '++++++'
     C           CKQT,Z    OREQ '------'
     C                     GOTO STEP21
     C                     END
      *
     C           *IN15     IFEQ '0'
     C           MPLC      IFEQ *BLANK
     C                     SETON                     15
     C                     MOVE CKQT,Z    MPLC
     C                     MOVE CKQR,Z    MTYP    1
     C                     END
     C                     GOTO STEP21
     C                     ELSE
      *
     C           PLC       IFEQ *BLANK
     C                     MOVE CKQT,Z    PLC
     C                     MOVE CKQN,Z    CFKBAN
     C                     GOTO STEP22
     C                     END
     C                     GOTO STEP21
     C                     END
     C                     ELSE
      *
     C           CKKO,Z    CABEQ*BLANK    STEP21
     C           CKNB,Z    IFEQ '++++++'
     C           CKNB,Z    OREQ '------'
     C                     GOTO STEP21
     C                     END
     C           *IN15     IFEQ '0'
     C           MPLC      IFEQ *BLANK
     C                     SETON                     15
     C                     MOVE CKNB,Z    MPLC
     C                     MOVE CKKR,Z    MTYP
     C                     END
     C                     GOTO STEP21
     C                     ELSE
      *
     C           PLC       IFEQ *BLANK
     C                     MOVE CKNB,Z    PLC
     C                     MOVE CKKB,Z    CFKBAN
     C                     GOTO STEP22
     C                     END
     C                     GOTO STEP21
     C                     END
     C                     END
     C           STEP21    TAG
     C                     END
      *
     C           STEP22    TAG
      *
     C                     MOVE '5'       WTSKB   1        jbﾆｭchﾎﾞ]
     C                     MOVE '0'       WSKKB   1        ﾆｬｮfﾏcﾃchﾎﾞ]
