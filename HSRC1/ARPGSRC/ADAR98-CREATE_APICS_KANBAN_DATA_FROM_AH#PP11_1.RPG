      *
     C*----------------------------*
      * LOCATION MASTER
     C*----------------------------*
     C           KEY4      SETLLAAJPL111
      *
     C                     READ AAJPL111                 11
     C           *IN11     IFEQ '1'
     C                     MOVE *BLANK    CJBLK1
     C                     MOVE *BLANK    CJBLK2
     C                     Z-ADD0         CJBLK3
     C                     ELSE
      *
     C           PLC       IFNE CJBANC
     C                     MOVE *BLANK    CJBLK1
     C                     MOVE *BLANK    CJBLK2
     C                     Z-ADD0         CJBLK3
     C                     END
     C                     END
      *
     C                     MOVE CJBLK3    WFZSEQ
     C*--------------------------------*
      *  PLATING KANBAN MASTER
     C*--------------------------------*
     C                     MOVE *BLANK    WNJKB   1        2ﾆﾞfﾃchﾎﾞ]
      *
     C                     SELEC
      *
     C           MTYP      WHEQ 'C'
     C           MKKEY     SETGTAAFPL031
      *
     C           *IN13     DOUEQ*ON
     C           MKKEY     REDPEAAFPL031                 13
     C           *IN13     IFEQ '0'
     C           A3SKJY    ANDEQ*BLANK
      *
     C           A3UKHB    IFLE D@DATE
     C           A3STHB    ANDGTD@DATE
     C                     SETON                     13
      *
     C           CFKDAI    IFEQ A3KCD1
     C                     MOVE '0'       WNJKB
     C                     ELSE
     C                     MOVE 'A'       WNJKB
     C                     END
      *
     C                     END
     C                     END
     C  N13                END
      *
     C*----------------------------------*
      *  TUNNEL KANBAN MASTER
     C*----------------------------------*
     C           MTYP      WHEQ 'D'
     C           MKKEY     SETGTAAGPL031
      *
     C           *IN13     DOUEQ*ON
     C           MKKEY     REDPEAAGPL031                 13
     C           *IN13     IFEQ '0'
     C           O4SKJY    ANDEQ*BLANK
      *
     C           O4UKHB    IFLE D@DATE
     C           O4STHB    ANDGTD@DATE
     C                     SETON                     13
      *
     C                     SETOF                     12
     C                     Z-ADD1         A       20
     C                     MOVE 'A'       WNJKB            2ﾆﾞfﾃchﾎﾞ]
     C           1         DO   6         A
     C           HTJK,A    IFNE *BLANK
     C                     SETON                     12
     C                     END
     C  N12                END
     C           *IN12     IFEQ '0'
     C                     MOVE '0'       WNJKB            2ﾆﾞfﾃchﾎﾞ]
     C                     END
      *
     C           WNJKB     IFEQ 'A'
     C                     SETOF                     14
     C                     Z-ADD1         A
     C           1         DO   6         A
     C           HTJK,A    IFNE *BLANK
     C                     SETOF                     14
     C                     Z-ADD1         B       20
     C           HTJK,A    LOKUPTB1,B                    14
     C           *IN14     IFEQ '1'
     C                     MOVE TB2,B     WNJKB
     C                     END
     C                     END
     C  N14                END
     C                     END
      *
     C                     END
     C                     END
     C  N13                END
      *
     C*------------------------------*
      * WITHDRAWAL KANBAN MASTER
     C*------------------------------*
     C           MTYP      WHEQ 'E'
     C           MKKEY     SETGTAAHPL031
      *
     C           *IN13     DOUEQ*ON
     C           MKKEY     REDPEAAHPL031                 13
     C           *IN13     IFEQ '0'
     C           L6SKJY    ANDEQ*BLANK
      *
     C           L6UKHB    IFLE D@DATE
     C           L6STHB    ANDGTD@DATE
     C                     SETON                     13
      *
     C                     SETOF                     12
     C                     Z-ADD1         A
     C                     MOVE 'A'       WNJKB            2ﾆﾞfﾃchﾎﾞ]
     C           1         DO   3         A
     C           HHJK,A    IFNE *BLANK
     C                     SETON                     12
     C                     END
     C  N12                END
     C           *IN12     IFEQ '0'
     C                     MOVE '0'       WNJKB            2ﾆﾞfﾃchﾎﾞ]
     C                     END
      *
     C           WNJKB     IFEQ 'A'
     C                     SETOF                     14
     C                     Z-ADD1         A
     C           1         DO   3         A
     C           HHJK,A    IFNE *BLANK
     C                     SETOF                     14
     C                     Z-ADD1         B
     C           HHJK,A    LOKUPTB1,B                    14
     C           *IN14     IFEQ '1'
     C                     MOVE TB2,B     WNJKB
     C                     END
     C                     END
     C  N14                END
     C                     END
      *
     C                     END
     C                     END
     C  N13                END
      *
     C*--------------------------------*
      * FINISHED GOOD KANBAN MASTER
     C*--------------------------------*
     C           MTYP      WHEQ '0'
     C           MKKEY     SETGTAAPPL031
      *
     C           *IN13     DOUEQ*ON
     C           MKKEY     REDPEAAPPL031                 13
     C           *IN13     IFEQ '0'
     C           L5SKJY    ANDEQ*BLANK
      *
     C           L5UKHB    IFLE D@DATE
     C           L5STHB    ANDGTD@DATE
     C                     SETON                     13
      *
     C                     SETOF                     12
     C                     Z-ADD1         A
     C                     MOVE 'A'       WNJKB            2ﾆﾞfﾃchﾎﾞ]
     C           1         DO   6         A
     C           HPJK,A    IFNE *BLANK
     C                     SETON                     12
     C                     END
     C  N12                END
     C           *IN12     IFEQ '0'
     C                     MOVE '0'       WNJKB            2ﾆﾞfﾃchﾎﾞ]
     C                     END
      *
     C           WNJKB     IFEQ 'A'
     C                     SETOF                     14
     C                     Z-ADD1         A
     C           1         DO   6         A
     C           HPJK,A    IFNE *BLANK
     C                     SETOF                     14
     C                     Z-ADD1         B
     C           HPJK,A    LOKUPTB1,B                    14
     C           *IN14     IFEQ '1'
     C                     MOVE TB2,B     WNJKB
     C                     END
     C                     END
     C  N14                END
     C                     END
      *
     C                     END
     C                     END
     C  N13                END
      *
     C                     ENDSL
     C*----------------------*
      * PART MASTER
     C*----------------------*
     C                     MOVE *BLANK    WSYOT   1        ﾌﾃﾆｬ
     C           K#PRT     CHAINFCEPL011             12
     C           *IN12     IFEQ '0'
     C           A2GSKD    ANDEQ*BLANK
      *
     C           A2SYHZ    IFGT D@DATE
     C                     MOVE A2KSYT    WSYOT            ﾌﾃﾆｬ
     C                     ELSE
     C                     MOVE A2SSYT    WSYOT            ﾌﾃﾆｬ
     C                     END
     C                     END
      *
     C                     ENDSR
