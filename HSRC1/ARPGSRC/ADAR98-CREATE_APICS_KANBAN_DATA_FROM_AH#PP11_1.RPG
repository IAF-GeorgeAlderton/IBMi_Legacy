     C                     MOVE CFKAMM    WFKAMM
     C                     MOVE CFKADD    WFKADD
     C                     MOVE CFKABB    WFKABB
     C                     MOVE CFBMON    WFBMON
     C                     MOVE CFTBMN    WFTBMN
     C                     MOVE CFMBMN    WFMBMN
     C                     MOVE CFTOKU    WFTOKU
