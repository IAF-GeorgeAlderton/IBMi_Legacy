     C*   ARS CHECK
     C*------------------------------------------*
     C                     SETOF                     11
     C           'ARS'     LOKUPHKT                      11
     C           *IN11     IFEQ '1'
      *
     C*----------------------------------*
      *  INVENTORY BASE FILE
     C*----------------------------------*
     C                     MOVE *BLANK    $ARS    1
     C           K#PRT     SETLLOACPL011
      *
     C           *IN95     DOUEQ*ON
     C           K#PRT     READEOACPL011                 95
     C           *IN95     IFEQ '0'
     C           OASKJY    ANDEQ*BLANK
      *
     C           OAUKHZ    IFLE D@DATE
     C           OASTHZ    ANDGTD@DATE
     C                     SETON                     95
     C                     MOVE '*'       $ARS
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C*--------------------------*
      *  ARRS MASTER FILE
     C*--------------------------*
     C           $ARS      IFEQ '*'
     C           K#PRT     CHAINOABPL011             11
     C           *IN11     IFEQ '0'
     C           OBSKJY    ANDEQ*BLANK
     C                     MOVE '0'       WTSKB            jbﾆｭchﾎﾞ]
     C                     Z-ADDD@DATE    $KYMD
     C           OBAPHB    IFGT $KBHB
     C                     MOVE OBKKBN    WSKKB            ﾆｬｮfﾏcﾃchﾎﾞ]
     C                     ELSE
     C                     MOVE OBSKBN    WSKKB            ﾆｬｮfﾏcﾃchﾎﾞ]
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
