     C                     MOVE '1'       P@END
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #WRT
     C                     MOVE *BLANK    P@END
     C                     MOVE D@DATE    P@DATE
     C                     MOVE D@BIN     P@BIN
     C                     MOVEL'99'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C           D@DATE    IFEQ *ZERO
     C                     MOVE *ON       *IN61
     C                     MOVE *ON       *IN99
     C                     ENDIF
     C           D@BIN     IFEQ *ZERO
     C                     MOVE *ON       *IN62
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     Z-ADDD@DATE    K@YMD
     C           K#KEY     CHAINAH#TL11              90
     C           *IN90     IFEQ *ON
     C                     MOVEA'11'      *IN,61
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     Z-ADDD@DATE    YMD6
     C                     Z-ADDD@BIN     BB8
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      *   WRITE RECORDS
      *------------------------------------------------------
     C           #WRT      BEGSR
      *
      *
     C           K#KEY     SETLLAH#TL11
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAH#TL11                  90
     C           *IN90     IFEQ *OFF
     C***        CFSKJY    ANDEQ*BLANK
      *
     C                     EXSR #FLD
     C                     MOVE CFMAIS    WFMAIS
     C                     MOVE CFHTYY    WFHTYY
     C                     MOVE CFHTMM    WFHTMM
     C                     MOVE CFHTDD    WFHTDD
     C                     MOVE CFHTBB    WFHTBB
