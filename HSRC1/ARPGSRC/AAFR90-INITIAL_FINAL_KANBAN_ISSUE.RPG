      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#FC1     KLIST
     C                     KFLD           S@PRT1
     C                     KFLD           S@PRT2
     C                     KFLD           S@PRT3
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @@RRN   40
     C                     MOVE '01'      W@ID    2
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1
     C                     Z-ADD*ZERO     @@RRN
      *
     C                     EXSR #SET
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR 1ST SCREEN
      *------------------------------------------------------
     C           #SET      BEGSR
      *
     C                     Z-ADD@@RRN     RRN1
     C                     DO   68
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDDO
      *
     C                     Z-ADDRRN1      #RCNO
     C                     Z-ADDRRN1      @@RRN
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCNO
      *
     C                     SELEC
      * F3
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * ROLL UP
     C           *IN38     WHEQ *ON
     C                     EXSR #CHK1
     C                     EXSR #SET
     C                     OTHER
     C                     EXSR #CHK1
      * F5
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
      *
     C                     EXSR #OUT
     C                     MOVEL'99'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,61
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
      *
     C                     Z-ADD*ZERO     W@RRN   40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         W@RRN
     C           W@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C                     MOVEA'00000000'*IN,61
      *
     C           S@PART    IFNE *BLANK
     C           K#FC1     CHAINAAMPL11              95
     C           *IN95     IFEQ *ON
     C  N99                MOVE MSG,2     D@MSG
     C  N99                Z-ADD@@RRN     #RCNO
     C                     SETON                     6199
     C                     ELSE
      *
     C                     Z-ADD*ZERO     B       20
     C           1         DO   15        K       20
     C           NKOT,K    IFNE *BLANK
     C                     ADD  1         B
     C           B         IFGT 6
     C  N99                MOVE MSG,1     D@MSG
     C  N99                Z-ADD@@RRN     #RCNO
     C                     SETON                     6199
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C                     MOVEANKOT      H@PRC
     C                     MOVEANTOK      H@LOC
     C                     MOVEANKBN      H@MCN
     C                     MOVEAKKOT      Q@PRC
     C                     MOVEAKTOK      Q@LOC
     C                     MOVEAKKBN      Q@MCN
     C                     ENDIF
     C                     ENDIF
      *
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   WRITE
      *------------------------------------------------------
     C           #OUT      BEGSR
      *
     C                     Z-ADD*ZERO     W@RRN   40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         W@RRN
     C           W@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
      *
     C           S@PART    IFNE *BLANK
     C                     MOVE *BLANK    W@PART
     C                     MOVE S@PRT1    W@PRT1
     C                     MOVE S@PRT2    W@PRT2
     C                     MOVE S@PRT3    W@PRT3
     C           S@PRT2    IFNE *BLANK
     C                     MOVE '-'       W@1
     C                     ENDIF
     C           S@PRT3    IFNE *BLANK
     C                     MOVE '-'       W@2
     C                     ENDIF
      *
     C           W@PART    CHAINAAFWP9A              95
     C           W@PART    CHAINAAFWP9B              95
     C           *IN95     IFEQ *ON
     C                     CLEARAAFWP9A1
     C                     Z-ADD*YEAR     IPKOYY
     C                     Z-ADD*MONTH    IPKOMM
     C                     Z-ADD*DAY      IPKODD
     C                     MOVELW@PART    IPPART
      * INITIAL
     C                     MOVEAH@PRC     FPRC
     C           'LAN'     LOKUPFPRC                     96
     C           *IN96     IFEQ *ON
     C                     MOVE '*'       IPLANP
     C                     ENDIF
     C                     MOVEAH@MCN     FMCN
      *
     C                     MOVEAH@LOC     @LOC
     C           1         DO   6         X       20
     C           @LOC,X    IFNE *BLANK
     C                     MOVE *BLANK    W@LOC
     C                     MOVE @LOC,X    @@LOC
     C                     MOVE @@LOC1    W@LOC1
     C                     MOVE @@LOC2    W@LOC2
     C                     MOVE '-'       W@L1
     C           @@LOC0    IFEQ '0'
     C                     MOVE '-'       W@L2
     C                     MOVE @@LOC3    W@LOC3
     C                     ENDIF
     C                     MOVE W@LOC     FLOC,X
     C                     ENDIF
     C                     ENDDO
      * INITAIL
     C                     WRITEAAFWP9A1
      * FINAL
     C           Q@PRC     IFNE *BLANK
     C                     MOVEAQ@PRC     FPRC
     C                     ELSE
     C                     MOVEAH@PRC     FPRC
     C                     ENDIF
      *
     C           'LAN'     LOKUPFPRC                     96
     C           *IN96     IFEQ *ON
     C                     MOVE '*'       IPLANP
     C                     ENDIF
      *
     C           Q@MCN     IFNE *BLANK
     C                     MOVEAQ@MCN     FMCN
     C                     ELSE
     C                     MOVEAH@MCN     FMCN
     C                     ENDIF
      *
     C                     MOVE *BLANK    FLOC
     C           Q@LOC     IFNE *BLANK
     C                     MOVEAQ@LOC     @LOC
     C                     ELSE
     C                     MOVEAH@LOC     @LOC
     C                     ENDIF
      *
     C           1         DO   6         X       20
     C           @LOC,X    IFNE *BLANK
     C                     MOVE *BLANK    W@LOC
     C                     MOVE @LOC,X    @@LOC
     C                     MOVE @@LOC1    W@LOC1
     C                     MOVE @@LOC2    W@LOC2
     C                     MOVE '-'       W@L1
     C           @@LOC0    IFEQ '0'
     C                     MOVE '-'       W@L2
     C                     MOVE @@LOC3    W@LOC3
     C                     ENDIF
     C                     MOVE W@LOC     FLOC,X
     C                     ENDIF
     C                     ENDDO
     C                     WRITEAAFWP9B1
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
