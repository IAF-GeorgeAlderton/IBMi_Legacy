     I            DS
     I                                        1   40HHMM1
     I                                        1   20HH1
     I                                        3   40MM1
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  140SDATE
     I                                        1   60STIME
     I                                        7  100SDATEY
     I                                       11  120SDATEM
     I                                       12  140SDATED
     I                                        1   20STIMEH
     I                                        3   40STIMEM
     I                                        5   60STIMES
      *
     I            DS
     I                                        1  100WKDB
     I                                        1   80WKDATE
     I                                        9  100WKBIN
      *
     I            DS
     I                                        1   60HMS
     I                                        1   20HH
     I                                        3   40MM
     I                                        5   60SS
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           F04     4
      *
     C                     TIME           WTIME
     C                     Z-ADD0         HMS
     C                     MOVELF04       HMS
     C                     Z-ADD1         I       50
     C                     Z-ADD1         Z       30
      *
     C                     Z-ADD0         WKTOHZ  80
     C                     Z-ADD0         WKYOHZ  80
     C                     Z-ADD0         WKCIBI  20
     C                     MOVELF04       HHMM1
     C           0111      CHAINAAIPL111             44
     C           *IN44     IFEQ '0'
     C                     Z-ADDCDTOHZ    WKTOHZ
     C                     Z-ADDCDYOHZ    WKYOHZ
     C                     Z-ADDCDCIBI    WKCIBI
     C                     MOVE CDBI,HH1  I
     C                     ENDIF
      *
     C                     READ AGIWP311                 80
     C           *IN80     DOWEQ'0'
     C           W#HAKO    IFNE 0
     C                     EXSR #SB500
     C                     EXSR #SB510
     C                     ENDIF
     C                     READ AGIWP311                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYC#     KLIST
     C                     KFLD           W#SHN1
     C                     KFLD           W#SHN2
     C                     KFLD           W#SHN3
     C                     KFLD           W#APHZ
     C                     KFLD           W#APBB
     C                     KFLD           KKCRHZ  80
     C                     KFLD           KKCRBB  20
     C                     Z-ADDWKTOHZ    KKCRHZ
     C                     Z-ADDI         KKCRBB
     C           KEYC#     CHAINAGIPP311             42
     C           *IN42     IFEQ '0'
     C                     ADD  W#HAKO    C#HAKO
     C                     UPDATAGIPP311
     C                     ELSE
     C                     CLEARAGIPP311
     C                     Z-ADDSDATE     C#KOHZ
     C                     Z-ADDSTIME     C#KOTI
     C                     MOVELW#USER    C#KOME
     C                     Z-ADDWKTOHZ    C#CRHZ
     C                     Z-ADDI         C#CRBB
     C                     MOVELW#SHN1    C#SHN1
     C                     MOVELW#SHN2    C#SHN2
     C                     MOVELW#SHN3    C#SHN3
     C                     Z-ADDW#APHZ    C#APHZ
     C                     Z-ADDW#APBB    C#APBB
     C                     Z-ADDW#HAKO    C#HAKO
     C                     MOVELW#SITE    C#SITE
     C                     WRITEAGIPP311
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB510    BEGSR
      *
     C                     CLEARAGIPP611
