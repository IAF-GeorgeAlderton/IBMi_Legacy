      *****************************************************************
     FCHKWPV1 IP  E                    DISK
     C           *ENTRY    PLIST
     C                     PARM           P@FLG   1
     C           *IN77     IFEQ '0'
     C                     MOVE *BLANK    P@FLG
     C                     SETON                     77
     C                     END
      *
     C           CSUSED    IFGE 70
     C                     MOVE '*'       P@FLG
     C                     END
      *
     C           CSSTAT    IFNE 'ACTIVE'
     C                     MOVE '*'       P@FLG
     C                     END
      *
