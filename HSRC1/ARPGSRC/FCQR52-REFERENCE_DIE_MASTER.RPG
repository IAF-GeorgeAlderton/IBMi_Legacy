     C*  EXFMT  (fﾞx] 2)                                   *
     C******************************************************
     C                     SETOF                     4849
      *型構成マスター存在チェック
     C                     EXSR #REDW1
      *
     C           KEY1      SETLLGCQPL311
     C                     Z-ADD0         I       50
     C                     Z-ADD0         P       50
     C                     Z-ADD0         J       50
     C                     Z-ADD0         K       50
     C                     DO   *HIVAL
     C           KEY1      READEGCQPL311                 40
     C           *IN,40    IFEQ '0'
     C           DFSKJY    IFEQ 'D'
     C           DFSKHZ    ANDLE*DATE
     C                     GOTO @END
     C                     END
      *型構成マスター存在チェック
     C                     EXSR #REDW2
      ***新システムＲＥＡＤ***
     C                     MOVE *BLANK    SW      1
     C                     MOVEL*BLANK    #BAN
      *
     C                     SETOF                     51
     C           KEY2      SETLLGCQTL131
     C                     MOVE *BLANK    SW
     C                     DO   *HIVAL
     C           KEY2      READEGCQTL131                 51
     C           *IN,51    IFEQ '0'
     C           T6SKJY    IFEQ 'D'
     C           T6SKHZ    ANDLE*DATE
     C                     ELSE
     C           KOJO      IFEQ T6TKR1
     C                     MOVEL'*'       SW
     C                     MOVEA'1'       *IN,51
     C                     MOVELT6TKR1    #BAN1
     C                     MOVELT6TKR2    #BAN2
     C                     MOVELT6TKR3    #BAN3
     C                     MOVELT6TKR4    #BAN4
     C                     MOVELT6TKR5    #BAN5
     C                     END
     C                     END
     C                     END
     C  N51                END
      *
     C           SW        CABEQ*BLANK    @END
      *
     C                     MOVE *BLANK    KOT
     C                     Z-ADD0         KBM
      *
     C           KEY1      CHAINAAMPL111             70
     C           *IN,70    IFEQ '0'
     C           CKSKJY    IFEQ 'D'
     C           CKSKHZ    ANDLE*DATE
     C                     GOTO @END
     C                     END
      *
     C                     Z-ADD1         A       20
     C                     Z-ADD0         B       20
     C                     DO   15        A
     C                     MOVELKHZ,A     WHZ     80
     C           *DATE     IFLT WHZ
     C           QKO,A     IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE QKO,A     KOT,B
     C                     Z-ADDQBM,A     KBM,B
     C                     END
     C                     ELSE
     C           NKO,A     IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE NKO,A     KOT,B
     C                     Z-ADDNBM,A     KBM,B
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C                     DO   15        Q       20
     C           DFKOTI    IFEQ KOT,Q
     C           KOJO      IFEQ '0'
     C           KBM,Q     IFEQ #KOJO1
     C           KBM,Q     OREQ #KOJO2
     C           KBM,Q     OREQ #KOJO3
     C           KBM,Q     OREQ #KOJO4
     C                     ELSE
     C                     MOVE *BLANK    #BAN
     C                     END
     C                     END
      *
     C*          KOJO      IFEQ '1'
     C*          KBM,Q     IFNE #KOJO1
     C*                    MOVE *BLANK    #BAN
     C*                    END
     C*                    END
      *
     C*          KOJO      IFEQ '2'
     C*          KBM,Q     IFNE #KOJO1
     C*                    MOVE *BLANK    #BAN
     C*                    END
     C*                    END
      *
     C*          KOJO      IFEQ '3'
     C*          KBM,Q     IFEQ #KOJO1
     C*          KBM,Q     OREQ #KOJO2
     C*          KBM,Q     OREQ #KOJO3
     C*          KBM,Q     OREQ #KOJO4
     C*          KBM,Q     OREQ #KOJO5
     C*                    ELSE
     C*                    MOVE *BLANK    #BAN
     C*                    END
     C*                    END
      *
     C*          KOJO      IFEQ '4'
     C*          KBM,Q     IFNE #KOJO1
     C*                    MOVE *BLANK    #BAN
     C*                    END
     C*                    END
      *
     C*          KOJO      IFEQ '5'
     C*          KBM,Q     IFNE #KOJO1
     C*                    MOVE *BLANK    #BAN
     C*                    END
     C*                    END
      *
     C           KOJO      IFEQ '6'
     C           KBM,Q     IFNE #KOJO1
     C                     MOVE *BLANK    #BAN
     C                     END
     C                     END
      *
     C                     END
     C                     END
      *
     C                     ADD  1         I
     C                     ADD  1         P
     C                     ADD  1         J
     C           I         IFEQ 1
     C                     Z-ADD0         CN
     C                     MOVE *BLANK    KO
     C                     MOVE *BLANK    NO
     C                     Z-ADD0         NO@
     C                     MOVE *BLANK    KA
     C                     MOVE *BLANK    NM
     C                     Z-ADD0         KS
     C                     MOVE *BLANK    BN
     C                     MOVE *BLANK    TX
     C                     END
      *
     C                     Z-ADDJ         CN,I
     C                     MOVELDFKOTI    KO,I
     C                     MOVELDFKSEI    NO,I
     C                     Z-ADDDFKSEI    NO@,I
     C                     MOVE '-'       ##AID1
     C                     MOVELDFKATA    KA,I
     C           ATM1      CHAINFCQPL211             60
     C  N60                MOVELO9KANM    NM,I
     C                     Z-ADDDFKOSU    KS,I
     C           *IN48     IFEQ '1'
     C                     MOVEL'*'       TX,I
     C                     END
     C           #BAN2     IFNE *BLANK
     C                     MOVEL'-'       #BANA
     C                     END
      *
     C           #BAN3     IFNE *BLANK
     C                     MOVEL'-'       #BANB
     C                     END
      *
     C           #BAN4     IFNE *BLANK
     C                     MOVEL'-'       #BANC
     C                     END
      *
     C           #BAN5     IFNE *BLANK
     C                     MOVEL'-'       #BAND
     C                     END
      *
     C                     MOVEL#BAN      BN,I
      *
     C                     END
     C           @END      TAG
     C           I         CABEQ15        STP2
     C  N40                END
      *
     C           STP2      TAG
     C           P         IFEQ 0
     C                     Z-ADD0         CN
     C                     MOVE *BLANK    KO
     C                     MOVE *BLANK    NO
     C                     MOVE *BLANK    NO@
     C                     MOVE *BLANK    KA
     C                     MOVEL'NO DATA' KA,1
     C                     MOVE *BLANK    NM
     C                     Z-ADD0         KS
     C                     MOVE *BLANK    BN
     C                     MOVE *BLANK    TX
     C                     ELSE
     C                     MOVEA'00000'   *IN,01
     C                     MOVEA'00000'   *IN,06
     C                     MOVEA'00000'   *IN,11
     C                     MOVEA'00000'   *IN,21
     C                     MOVEA'00000'   *IN,26
     C                     MOVEA'00000'   *IN,31
     C                     DO   14        X       20
     C           X         ADD  1         Y       20
     C           KO,X      IFEQ KO,Y
     C                     MOVEA'1'       *IN,Y
     C                     END
     C           NO,X      IFEQ NO,Y
     C           Y         ADD  20        Z       20
     C                     MOVEA'1'       *IN,Z
     C                     END
     C                     END
     C                     END
      *
     C                     MOVEA'00'      *IN,81
     C                     EXFMTFCQPW521
     C                     MOVEA'0'       *IN,44
     C                     MOVEA'0'       *IN,66
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    ERR
      *  ﾜｰﾓ aｮﾎﾟ
     C           *IN,81    IFEQ '1'
     C                     EXSR ROLLUP
     C           *IN,44    IFEQ '1'
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,2     ERR
     C                     END
     C                     GOTO STP2
     C                     END
      *  ﾜｰﾓ jﾞc]
     C           *IN,82    IFEQ '1'
     C                     EXSR ROLLDW
     C           *IN,44    IFEQ '1'
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,3     ERR
     C                     END
     C                     GOTO STP2
     C                     END
      *
     C           *INKA     IFEQ '1'
     C                     MOVEL'1'       XXX
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           KBN       IFEQ '2'
     C           *INKB     IFEQ '1'
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,1     ERR
     C                     GOTO STP2
     C                     END
     C                     END
      *
     C           *INKC     IFEQ '1'
