     F* *IN12=1(NOT READ ABF9P01)                                *
     F* *IN74=1(TO BE WRITTEN DATA EXSIST)                       *
     F* *IN75=0(FIRST FST RECORD)                                *
     F* *IN76=0(FIRST LIN RECORD)                                *
     F* *IN77=1(NEW DOCK ERROR,PRINT FORD PLANT CODE)            *
     F* *IN90=1(NOT READ ABFPP10)                                *
     F* *IN91=1(NOT READ ABFPP30)                                *
     F* *IN99=1(WEEKLY DATA)                                     *
     F************************************************** ABAR2G **
