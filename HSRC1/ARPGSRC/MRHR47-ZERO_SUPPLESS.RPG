     H            Y.
     F** MRHR47 *********************************************
     F*数字を頭ゼロ消去する２                             *
     F*       A.SHIBATA            2015.11.11               *
     F*******************************************************
     E                    SUU        11  1
     E                    SUU2       11  1
      *
     I* FOR文字編集
     I            DS
     I                                        1  11 SUU
     I                                        1  11 @@SUJI
     I            DS
     I                                        1  11 SUU2
     I                                        1  11 @OMOJI
      *
     I              '00000000000'         C         AZERO
     I              '          0'         C         AZERO1
      *----------------------------------------------------*
      *   PARAMETER  TRANCFER                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           INSUJI 110
     C                     PARM           OTMOJI 11
     C                     PARM           CHKFLG  1
     C*
     C                     MOVELINSUJI    @@SUJI
     C           1         DO   11        ZZ      20
     C           SUU,ZZ    IFNE '0'
     C           SUU,ZZ    ANDNE'1'
     C           SUU,ZZ    ANDNE'2'
     C           SUU,ZZ    ANDNE'3'
     C           SUU,ZZ    ANDNE'4'
     C           SUU,ZZ    ANDNE'5'
     C           SUU,ZZ    ANDNE'6'
     C           SUU,ZZ    ANDNE'7'
     C           SUU,ZZ    ANDNE'8'
     C           SUU,ZZ    ANDNE'9'
     C                     MOVEL'1'       CHKFLG
     C                     LEAVE
     C                     ENDIF
     C*
     C           SUU,ZZ    IFNE '0'
     C                     Z-ADDZZ        XX      20
     C                     LEAVE
     C                     ENDIF
     C*
     C                     ENDDO
     C*
     C           XX        IFNE 0
     C           CHKFLG    ANDEQ' '
     C*
     C           XX        DO   11        X       20
     C                     MOVE SUU,X     SUU2,X
     C                     ENDDO
     C*
     C                     ELSE
     C                     MOVE *BLANK    @OMOJI
     C*
     C                     END
     C*
     C                     MOVE @OMOJI    OTMOJI
     C*
     C           @@SUJI    IFEQ AZERO
     C                     MOVE AZERO1    OTMOJI
     C                     ENDIF
     C*
     C                     SETON                     LR
     C                     RETRN
