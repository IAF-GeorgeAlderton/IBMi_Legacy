     H            Y.
     FCHKWPU0 IP  F     256            DISK
     FCHKWPU1 O   E                    DISK
     ICHKWPU0 AA
     I                                        3   3 ISCHK
      *
     I                                        3  12 ISUBS
     I                                        5  14 IJOB
     I                                       18  27 IUSER
     I                                       30  35 IJOBN
     I                                       51  53 ITYPE
     I                                       61  62 IPTY
     I                                       94  96 ICPU1
     I                                       98  98 ICPU2
      *
     I                                       71  71 ICHK1
     I                                       97  97 ICHK2
      *
     I                                      117 120 ISTAT
     C           ICHK1     IFEQ '.'
     C           ICHK2     ANDEQ'.'
      *
     C                     Z-ADD0         CSCPUP
     C           ICPU1     IFNE *BLANK
     C                     MOVELICPU1     CSCPUP
     C                     END
     C                     MOVE ICPU2     CSCPUP
      *
     C           ISCHK     IFNE *BLANK
     C                     EXSR #SBS
     C                     ELSE
     C                     EXSR #JOB
     C                     END
      *
     C                     END
      *
     C           #SBS      BEGSR
     C                     MOVE ISUBS     CSSBYS
     C                     MOVE *BLANK    CSJOB
     C                     MOVE IUSER     CSUSER
     C                     MOVE IJOBN     CSJOBN
     C                     MOVE ISTAT     CSSTAT
     C                     MOVE ITYPE     CSTYPE
     C                     MOVE IPTY      CSPTY
     C                     WRITECHKWPU11
     C                     ENDSR
      *---------------------------------------------------------
     C           #JOB      BEGSR
     C* * *                MOVE ISUBS     CSSBYS
     C                     MOVE IJOB      CSJOB
     C                     MOVE IUSER     CSUSER
     C                     MOVE IJOBN     CSJOBN
     C                     MOVE ISTAT     CSSTAT
     C                     MOVE ITYPE     CSTYPE
     C                     MOVE IPTY      CSPTY
     C                     WRITECHKWPU11
     C           EJOB      ENDSR
