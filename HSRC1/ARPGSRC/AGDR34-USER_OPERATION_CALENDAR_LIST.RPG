     C           @SUB      TAG
     C           @RIK1     IFGT @RIK2
     C                     SETON                     LRU1
     C                     RETRN
     C                     END
     C*
     C                     MOVE *BLANK    SW      1
     C           KEY       SETLLAGDPL311
     C                     Z-ADD0         YB
     C                     MOVE *BLANK    HYK
     C                     MOVE *BLANK    YTO
     C                     MOVE *BLANK    RIN
     C                     Z-ADD0         @KADO   31
     C                     Z-ADD0         @JUN1   31
     C                     Z-ADD0         @JUN2   31
     C                     Z-ADD0         @JUN3   31
     C                     Z-ADD0         TCODE   40
     C                     MOVE *BLANK    TNOKJ   1
     C                     MOVE *BLANK    TKMEI  16
     C                     MOVE F8TOKU    TCODE
     C                     MOVELB2SMEI    TKMEI
     C                     MOVE F8KOJO    TNOKJ
     C*
     C                     DO   *HIVAL
     C           KEY       READEAGDPL311                 30
     C           *IN,30    IFEQ '0'
     C*---------------
     C*  fnﾞcﾍﾞ ibﾅ]
     C*---------------
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
     C           F8RIKB    IFEQ *BLANK
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     Z-ADD1         @DD     21
     C                     ELSE
     C                     Z-ADD0.5       @DD
     C                     END
     C                     ADD  @DD       @KADO
     C*---------------
     C*  ﾆﾞｬ] kｩｮh
     C*---------------
     C           F8KADD    IFGE 01
     C           F8KADD    ANDLE10
     C                     ADD  @DD       @JUN1
     C                     END
     C           F8KADD    IFGE 11
     C           F8KADD    ANDLE20
     C                     ADD  @DD       @JUN2
     C                     END
     C           F8KADD    IFGE 21
     C           F8KADD    ANDLE31
     C                     ADD  @DD       @JUN3
     C                     END
     C                     END
     C                     END
     C*---------------
     C*  ﾑcﾍﾞﾉ i]ﾅh
     C*---------------
     C           SW        IFEQ *BLANK
     C                     TIME           WTIME   60
     C                     Z-ADD1         P       50
     C                     MOVE '*'       SW
     C                     Z-ADD1         X       10
     C           F8YOBI    LOKUPHZ1,X                    20
     C           *IN20     IFEQ '1'
     C                     Z-ADDHZ2,X     P
     C                     END
     C                     END
     C*
     C           F8KADD    IFNE 0
     C                     Z-ADDF8KADD    YB,P
     C                     MOVE *BLANK    M       1
     C           F8HIRU    IFNE *BLANK
     C           F8YORU    ANDNE*BLANK
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     MOVE '1'       M
     C                     END
     C                     END
     C*
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ*BLANK
     C                     MOVE '2'       M
     C                     END
     C           F8YORU    IFEQ '*'
     C           F8HIRU    ANDEQ*BLANK
     C                     MOVE '3'       M
     C                     END
     C                     Z-ADD1         E       20
     C           M         LOKUPKY1,E                    20
     C           *IN20     IFEQ '1'
     C                     MOVE *BLANK    HYK,P
     C                     MOVELKY2,E     HYK,P
     C                     END
     C*
     C           F8MAEY    IFNE *BLANK
     C           F8MAEY    IFEQ 'S'
     C                     MOVE '1'       N       1
     C                     END
     C           F8MAEY    IFEQ 'E'
     C                     MOVE '3'       N
     C                     END
     C           F8MAEY    IFEQ 'M'
     C                     MOVE '2'       N
     C                     END
     C                     Z-ADD1         E
     C           N         LOKUPKI1,E                    20
     C           *IN20     IFEQ '1'
     C                     MOVELKI2,E     YTO,P
     C                     END
     C                     END
     C*
     C           F8RIKB    IFEQ 'R'
     C                     MOVE 'UNWORK'  RIN,P
     C                     END
     C*
     C                     ADD  1         P
     C                     END
     C                     END
     C  N30                END
