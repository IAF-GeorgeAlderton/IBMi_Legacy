     C                     KFLD           @NOKJ
     C                     KFLD           @YY
     C                     KFLD           @MM
     C*---------------
     C*  ﾆｭg ﾈｮmb
     C*---------------
     C           LAB1      TAG
     C                     Z-ADD0         @TOKU
     C                     MOVE *BLANK    @NOKJ
     C                     Z-ADD0         @RIK1
     C                     Z-ADD0         @RIK2
     C                     Z-ADD0         TCODE   40
     C                     MOVE *BLANK    TKMEI  16
     C                     MOVE *BLANK    TNOKJ   1
     C*---------------
     C*  AGDPW341 ﾍｭcﾆﾞ
     C*---------------
     C           LAB2      TAG
     C                     EXFMTAGDPW341
     C                     SETOF                     010203
     C                     SETOF                     049099
     C*---------------
     C*  CMD-1 kｩｮh
     C*---------------
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C*---------------
     C*  CMD-2 kｩｮh
     C*---------------
     C           *INKB     IFEQ '1'
     C                     SETON                     U1LR
     C                     RETRN
     C                     END
     C*---------------
     C*  nhbﾅg kｩｮh
     C*---------------
     C           @TOKU     IFEQ 0
     C                     SETON                     0199
     C                     MOVE ER,1      @ERR
     C                     GOTO LAB2
     C                     END
     C           @TOKU     CHAINFGBPL01              90
     C           *IN90     IFEQ '1'
     C                     SETON                     0199
     C                     MOVE ER,2      @ERR
     C                     GOTO LAB2
     C                     END
     C*---------------
     C*  ﾒﾇngf] kｩｮh
     C*---------------
     C           @RIK1     IFEQ 0
     C           @RIK2     OREQ 0
     C                     SETON                     030499
     C                     MOVE ER,3      @ERR
     C                     GOTO LAB2
     C                     END
     C*
     C           RK1       IFGE 1991
     C           RK2       ANDGE1
     C           RK2       ANDLE12
     C                     ELSE
     C                     SETON                     0399
     C                     MOVE ER,4      @ERR
     C                     GOTO LAB2
     C                     END
     C*
     C           RK3       IFGE 1991
     C           RK4       ANDGE1
     C           RK4       ANDLE12
     C                     ELSE
     C                     SETON                     0499
     C                     MOVE ER,4      @ERR
     C                     GOTO LAB2
     C                     END
     C*
     C           @RIK1     IFGT @RIK2
     C                     SETON                     030499
     C                     MOVE ER,4      @ERR
     C                     GOTO LAB2
     C                     END
     C*---------------
     C*  mﾞｰj kｩｮh
     C*---------------
     C                     Z-ADDRK1       @YM
     C           @STP1     TAG
     C                     SETOF                     50
     C           KEY2      CHAINAGDPL311             50
     C           *IN50     IFEQ '1'
     C           @MM       IFEQ 12
     C                     ADD  1         @YY
     C                     Z-ADD1         @MM
     C                     ELSE
     C                     ADD  1         @MM
     C                     END
     C           @YM       IFLE @RIK2
     C                     GOTO @STP1
     C                     END
     C*
     C                     SETON                     010203
     C                     SETON                     0499
     C                     MOVE ER,5      @ERR
     C                     GOTO LAB2
     C                     END
