     H            Y/                                    1
     H** EDIR62 *******************************************************
     H*  ORDER ENTRY TYPE ANALYSIS                                    *
     H*  J.WATANABE  2019.03.25                                       *
     H*****************************************************************
     FEDIPW62 CF  E                    WORKSTN
     FAB#PLA1 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FRGAPL11 IF  E           K        DISK
     FEDIWP62 IF  E           K        DISK                      A    UC
     FEDIWP63 O   E                    DISK
     FQPRINT  O   F     198     OF     PRINTER
      *================================================================
     E                    MSG     1   8 60
      *
     I            DS
     I                                        1  17 @MHIN
     I                                        1   5 BAMHN1
     I                                        6   6 @MH1
     I                                        7  11 BAMHN2
     I                                       12  12 @MH2
     I                                       13  17 BAMHN3
      *
     I            DS
     I                                        1  14 @SHIN
     I                                        1   5 BASHN1
     I                                        6   6 @SH1
     I                                        7  11 BASHN2
     I                                       12  12 @SH2
     I                                       13  14 BASHN3
      *
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                     *PROGRAM #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I                                      264 269 #JBNO
     C*===============================================================
     C*  START  PROGRAM
     C*===============================================================
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
      *
     C                     EXFMTDSP01
     C                     SETOF                     414243
     C                     SETOF                     85
     C                     MOVE *BLANK    XMSG
     C* F1: END
     C           *INKA     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C                     EXSR #CHK1
      * F7: OUTPUT
     C           *IN85     IFEQ *OFF
     C           *INKG     ANDEQ*ON
     C                     EXSR #OUT
      * ERROR: NO DATA
     C           SEQ#      IFEQ 0
     C                     MOVELMSG,6     XMSG
     C                     ITER
     C                     ELSE
     C                     EXSR #PRINT
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      * ENTER:
     C           *IN85     IFEQ *OFF
     C           *INKG     ANDEQ*OFF
     C                     MOVELMSG,5     XMSG
     C                     ITER
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   CHECK ENTRY
     C*===============================================================
     C           #CHK1     BEGSR
     C                     MOVE *OFF      *IN85
      * CHECK FROM DATE
     C           XFROM     IFEQ *BLANK
     C                     MOVELMSG,1     XMSG
     C                     MOVE *ON       *IN41
     C                     MOVE *ON       *IN85
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     MOVELXFROM     @FROM   80
     C                     MOVE '01'      @FROM
      * CHECK TO DATE
     C           XTO       IFEQ *BLANK
     C                     MOVELMSG,2     XMSG
     C                     MOVE *ON       *IN42
     C                     MOVE *ON       *IN85
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     MOVELXTO       @TO     80
     C                     MOVE '31'      @TO
      * CHECK FROM > TO
     C           XFROM     IFGT XTO
     C                     MOVE *ON       *IN41
     C                     MOVELMSG,8     XMSG
     C                     MOVE *ON       *IN85
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           XCHK1     ENDSR
     C*===============================================================
     C* OUTPUT EDIWP62 (WORK)
     C*===============================================================
     C           #OUT      BEGSR
      *
     C                     OPEN EDIWP62
     C                     Z-ADD0         SEQ#
      * BY DATE ------------------------
     C           @FROM     SETLLAB#PLA1
      *
     C                     DO   *HIVAL
     C                     READ AB#PLA1                  98
     C   98                LEAVE
      * END
     C           BACRHZ    IFGT @TO
     C                     LEAVE
     C                     ENDIF
      * SELECT ORDER
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     WRITEEDIWP621
      *
     C                     ENDDO
      *---------------------------------
     C                     CLOSEEDIWP62
      *
     C                     ENDSR
     C*===============================================================
     C* PRINT
     C*===============================================================
     C           #PRINT    BEGSR
      *
     C                     OPEN EDIWP62
     C                     MOVE 'Y'       FIRST
     C                     Z-ADD0         SVTOKU
      *
     C                     DO   *HIVAL
     C                     READ EDIWP62                  97
     C   97                LEAVE
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELBATOKU    SVTOKU
     C                     ENDIF
      * BREAK?
     C           BATOKU    IFNE SVTOKU
     C                     EXCPT#LINE
     C                     ADD  1         LIN#
     C                     MOVELBATOKU    SVTOKU
     C                     ENDIF
      *
     C                     EXSR #PRT1
     C                     ENDDO
      *---------------------------------
     C                     CLOSEEDIWP62
      *
     C                     EXCPT#FOOT
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRT1     BEGSR
      * ADJ
      * USER PART
     C           BAMHN2    IFEQ *BLANK
     C                     MOVE ' '       @MH1
     C                     ELSE
     C                     MOVE '-'       @MH1
     C                     ENDIF
     C           BAMHN3    IFEQ *BLANK
     C                     MOVE ' '       @MH2
     C                     ELSE
     C                     MOVE '-'       @MH2
     C                     ENDIF
      * IAF PART
     C           BASHN2    IFEQ *BLANK
     C                     MOVE ' '       @SH1
     C                     ELSE
     C                     MOVE '-'       @SH1
     C                     ENDIF
     C           BASHN3    IFEQ *BLANK
     C                     MOVE ' '       @SH2
     C                     ELSE
     C                     MOVE '-'       @SH2
     C                     ENDIF
      * CUST NAME
     C           BATOKU    CHAINFGBPL01              99
     C           *IN99     IFEQ *OFF
     C                     MOVELB2SMEI    @TOKUN
     C                     ELSE
     C                     MOVE *BLANK    @TOKUN
     C                     ENDIF
      * DELIVERY NAME
     C           BANONY    CHAINFGBPL01              99
     C           *IN99     IFEQ *OFF
     C                     MOVELB2SMEI    @NONYN
     C                     ELSE
     C                     MOVE *BLANK    @NONYN
     C                     ENDIF
      * USER NAME
     C           BACRME    CHAINRGAPL11              99
     C           *IN99     IFEQ *OFF
     C                     MOVELJ8NAME    @USNM
     C                     ELSE
     C                     MOVE *BLANK    @USNM
     C                     ENDIF
      *
     C                     MOVELBACRME    @USR
     C                     MOVELBACRTM    @CRTM
      * PRINT HEADER
     C           LIN#      IFGE 72
     C                     EXCPT#HDR
     C                     Z-ADD5         LIN#
     C                     ENDIF
      * PRINT DETAIL
     C**                   ADD  1         SEQ#
     C                     EXCPT#DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
     C*===============================================================
     C* CSV DOWNLOAD
     C*===============================================================
     C           #CSV      BEGSR
      *
     C                     OPEN EDIWP62
     C                     MOVE 'Y'       FIRST
     C                     Z-ADD0         SVTOKU
      *
     C                     DO   *HIVAL
     C                     READ EDIWP62                  97
     C   97                LEAVE
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELBATOKU    SVTOKU
     C                     EXSR #CSV@H
     C                     ENDIF
      * BREAK?
     C           BATOKU    IFNE SVTOKU
     C**                   EXCPT#LINE
     C                     MOVELBATOKU    SVTOKU
     C                     ENDIF
      *
     C                     EXSR #CSV@D
     C                     ENDDO
      *---------------------------------
     C                     CLOSEEDIWP62
      *
     C                     EXSR #CSV@F
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  CSV HEADER                                        *
      *----------------------------------------------------*
     C           #CSV@H    BEGSR
     C                     CLEAREDIWP631
      * HEADER
     C                     MOVEL'CUSTOMER'WKTOKU
     C                     MOVEL'NAME    'WKTONM
     C                     MOVEL'DELIVERY'WKNONY
     C                     MOVEL'NAME    'WKNONM
     C                     MOVEL'FACTORY 'WKNKOJ
     C                     MOVEL'DOCK    'WKNUKE
     C                     MOVEL'USR_PART'WKMHIN
     C                     MOVEL'IAF_PART'WKSHIN
     C                     MOVEL'SHP_DATE'WKNOHZ
     C                     MOVEL'BIN#    'WKNOBN
     C                     MOVEL'ORD_QTY 'WKSRYO
     C                     MOVEL'CRT_DATE'WKCRHZ
     C                     MOVEL'TIME    'WKCRTM
     C                     MOVEL'USER_ID 'WKUSR
     C                     MOVEL'NAME    'WKUSRN
      *
     C                     WRITEEDIWP631
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  CSV HEADER                                        *
      *----------------------------------------------------*
     C           #CSV@D    BEGSR
     C                     CLEAREDIWP631
      * ADJ
     C                     MOVELBANKOJ    WKNKOJ
     C                     MOVELBANUKE    WKNUKE
      * USER PART
     C           BAMHN2    IFEQ *BLANK
     C                     MOVE ' '       @MH1
     C                     ELSE
     C                     MOVE '-'       @MH1
     C                     ENDIF
     C           BAMHN3    IFEQ *BLANK
     C                     MOVE ' '       @MH2
     C                     ELSE
     C                     MOVE '-'       @MH2
     C                     ENDIF
     C                     MOVEL@MHIN     WKMHIN
      * IAF PART
     C           BASHN2    IFEQ *BLANK
     C                     MOVE ' '       @SH1
     C                     ELSE
     C                     MOVE '-'       @SH1
     C                     ENDIF
     C           BASHN3    IFEQ *BLANK
     C                     MOVE ' '       @SH2
     C                     ELSE
     C                     MOVE '-'       @SH2
     C                     ENDIF
     C                     MOVEL@SHIN     WKSHIN
      * CUST NAME
     C                     MOVELBATOKU    WKTOKU
     C           BATOKU    CHAINFGBPL01              99
     C           *IN99     IFEQ *OFF
     C                     MOVELB2SMEI    WKTONM
     C                     ENDIF
      * DELIVERY NAME
     C                     MOVELBANONY    WKNONY
     C           BANONY    CHAINFGBPL01              99
     C           *IN99     IFEQ *OFF
     C                     MOVELB2SMEI    WKNONM
     C                     ENDIF
      *
     C                     MOVELBANOHZ    WKNOHZ
     C                     MOVELBANOBN    WKNOBN
     C                     MOVELBASRYO    WKSRYO
     C                     MOVELBACRHZ    WKCRHZ
     C                     MOVELBACRTM    WKCRTM
      * USER NAME
     C                     MOVELBACRME    WKUSR
     C           BACRME    CHAINRGAPL11              99
     C           *IN99     IFEQ *OFF
     C                     MOVELJ8NAME    WKUSRN
     C                     ENDIF
      *
     C                     WRITEEDIWP631
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  CSV FOOT                                          *
      *----------------------------------------------------*
     C           #CSV@F    BEGSR
      *
     C                     CLEAREDIWP631
     C                     MOVEL'*TOTAL* 'WKTOKU
     C                     MOVELSEQ#      WKTONM
     C                     WRITEEDIWP631
      *
     C                     ENDSR
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C           K#PL06    KLIST
     C                     KFLD           KMHN1   5
     C                     KFLD           KMHN2   5
     C                     KFLD           KMHN3   5
     C                     KFLD           KMHN4   5
      *
     C                     MOVE *BLANK    $RTN
     C                     TIME           @SDATE
     C                     Z-ADD0         @FROM   80
     C                     Z-ADD0         @TO     80
     C                     Z-ADD88        LIN#    30
     C                     Z-ADD0         SEQ#    90
      *
     C                     MOVELTODAY     XFROM
     C                     MOVELTODAY     XTO
      *
     C                     MOVE *BLANK    @TOKUN 15
     C                     MOVE *BLANK    @NONYN 15
     C                     MOVE *BLANK    @USNM  15
     C                     MOVE *BLANK    @USR    6
     C                     MOVE *BLANK    @CRTM   40
     C                     Z-ADD0         SVTOKU  40
     C                     MOVE 'Y'       FIRST   1
      *
     C                     ENDSR
      *===============================================================
     OQPRINT  E   01           #HDR
     O                         #PGM      11
     O                         #USER     21
     O                                   50 '** SALES ORDER LIST '
     O                                   70 '(BIN# >= 9) **      '
     O                         TODAY    105 '    .  .  '
     O                         NOW      115 '  :  :  '
     O                         PAGE  Z  123
     O                                  119 'P.'
     O        E   03           #HDR
     O                                    6 'FROM:'
     O                         @FROM     17 '    /  /  '
     O                                   25 'TO:'
     O                         @TO       36 '    /  /  '
     O        E 1              #HDR
     O                                    9 'CUSTOMER'
     O                                   30 'DELIVERY'
     O                                   45 'FC'
     O                                   50 'DOCK'
     O                                   60 'USER_PART'
     O                                   77 'IAF_PART'
     O                                   92 'DUE_DATE'
     O                                   98 'BIN'
     O                                  111 'QTY'
     O                                  121 'CRT_DATE'
     O                                  127 'TIME'
     O                                  133 'USER'
     O                                  140 'NAME'
     O        E 1              #HDR
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O                                  120 '--------------------'
     O                                  140 '--------------------'
     O                                  160 '--------------------'
     O        E 1              #DTL
     O                         BATOKU  +001
     O                         @TOKUN  +001
     O                         BANONY  +001
     O                         @NONYN  +001
     O                         BANKOJ  +001
     O                         BANUKE  +002
     O                         @MHIN   +001
     O                         @SHIN   +001
     O                         BANOHZ  +001 '    /  /  '
     O                         BANOBN  +001
     O                         BASRYO1 +001
     O                         BACRHZ  +001 '    /  /  '
     O                         @CRTM   +001 '0 :  '
     O                         @USR    +001
     O                         @USNM   +001
     O        E 1              #LINE
     O                                    2 '**'
     O        E 1              #FOOT
     O                                   12 '** TOTAL **'
     O                         SEQ#  1   24
** MSG   +.........+.........+.........+.........+.........+
ENTER DATE "FROM" !                                          01
ENTER DATE "TO" !                                            02
DATE "FROM" IS NOT IN CALENDAR MASTER !                      03
DATE "TO" IS NOT IN CALENDAR MASTER !                        04
PRESS F7 TO PRINT...                                         05
THERE IS NO TARGET DATA !                                    06
* ERROR * IT WILL BE OVER 10 PAGES. PLEASE USE F9 !          07
DATE "FROM" IS GREATER THAN "TO" !                           08
