     H            Y.
     F**************************************************************************
     F*  PROGRAM    : DIE MASTER TRANSFER                                      *
     F*  WRITTEN    : 11/5/2015                                                *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F*  FUNCTION   : READ GCQPP11 AND OUTPUT GCQWP61                          *
     F**************************************************************************
     FGCQPW61 CF  E                    WORKSTN
     FGCQPL15 IF  E           K        DISK
     FGCQWP61 IF  E                    DISK                      A
      *------------------------------------------------------------
     E                    MSG     1   5 80
      *------------------------------------------------------------
     I            DS
     I                                        1   7 T6KAT
     I                                        1   2 T6KAT1
     I                                        3   6 T6KAT2
     I                                        7   7 T6KAT3
     I            DS
     I                                        1   7 SVKAT
     I                                        1   2 SVKAT1
     I                                        3   6 SVKAT2
     I                                        7   7 SVKAT3
     I            DS
     I                                        1   6 T6TKR
     I                                        1   1 T6TKR1
     I                                        2   3 T6TKR2
     I                                        4   5 T6TKR3
     I                                        6   6 T6TKR4
     I            DS
     I                                        1   6 SVTKR
     I                                        1   1 SVTKR1
     I                                        2   3 SVTKR2
     I                                        4   5 SVTKR3
     I                                        6   6 SVTKR4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *******************************************************
      *                    MAIN ROUTINE
      *******************************************************
     C           W@ID      DOWNE'99'
     C                     EXFMTGCQPW611
     C                     MOVE *OFF      *IN85
     C                     MOVE *OFF      *IN51
     C                     MOVE *OFF      *IN52
     C                     MOVE *OFF      ALLFLG  1
     C                     SELEC
      * CMD1:END
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C                     MOVEL'1'       @CMD1
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN85     IFEQ *OFF
     C                     EXSR #OUT
     C                     MOVEL'99'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      * CHECK DIE#
     C           @DIE1     IFEQ *BLANK
     C           @DIE2     ANDEQ*BLANK
     C           @DIE3     ANDEQ*BLANK
     C                     MOVE *ON       ALLFLG
     C                     GOTO ECHK1
     C                     ENDIF
      * DIE#
     C           K3@L15    CHAINGCQPL15              99
     C           *IN99     IFEQ *ON
     C                     SETON                     5185
     C                     MOVELMSG,2     @MSG
     C                     GOTO ECHK1
     C                     ENDIF
      *
     C           ECHK1     ENDSR
      *------------------------------------------------------
      *   WRITE
      *------------------------------------------------------
     C           #OUT      BEGSR
      *
     C                     MOVE *OFF      *IN80
     C           ALLFLG    IFEQ *ON
     C           *LOVAL    SETLLGCQPL15
     C                     ELSE
     C           K3@L15    SETLLGCQPL15
     C                     ENDIF
      *
     C           *IN80     DOUEQ*ON
     C                     SELEC
     C           ALLFLG    WHEQ *ON
     C                     READ GCQPL15                  80
     C           @DIE3     WHEQ *BLANK
     C           K2@L15    READEGCQPL15                  80
     C                     OTHER
     C           K3@L15    READEGCQPL15                  80
     C                     ENDSL
      *
     C           *IN80     IFEQ *OFF
     C           T6SKJY    ANDEQ*BLANK
      *FIRST?
     C           FIRST     IFEQ *ON
     C                     MOVE *OFF      FIRST
     C                     MOVELT6KAT     SVKAT
     C                     MOVELT6TKR     SVTKR
     C                     ENDIF
      *BREAK?
     C           T6KAT     IFNE SVKAT
     C           T6TKR     ORNE SVTKR
     C                     EXSR #BRK
     C                     ENDIF
      *DETAIL
     C                     EXSR #DTL
     C                     ENDIF
     C                     ENDDO
      *2ND BREAK
     C           FIRST     IFEQ *OFF
     C                     EXSR #BRK
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  BREAK
      *------------------------------------------------------
     C           #BRK      BEGSR
      *
     C                     WRITEGCQWP61R
     C                     ADD  1         CNT
      *
     C                     MOVELT6KAT     SVKAT
     C                     MOVELT6TKR     SVTKR
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SAVE
      *------------------------------------------------------
     C           #DTL      BEGSR
      *
     C                     MOVELT6KAT1    TWKAT1
     C                     MOVELT6KAT2    TWKAT2
     C                     MOVELT6KAT3    TWKAT3
     C                     MOVELT6TKR1    TWTKR1
     C                     MOVELT6TKR2    TWTKR2
     C                     MOVELT6TKR3    TWTKR3
     C                     MOVELT6TKR4    TWTKR4
     C                     MOVELT6TKR5    TWTKR5
     C                     MOVELT6KIHZ    TWKIHZ
     C                     MOVELT6KOCD    TWKOCD
     C                     MOVELT6SRYO    TWSRYO
     C                     MOVELT6KMAX    TWKMAX
      *
     C           T6SYOS    IFNE 0
     C           T6SRYO    DIV  T6SYOS    @ANS    90
     C           @ANS      MULT 4         TWKMAX
     C                     ENDIF
      *
     C                     MOVELT6SYOS    TWSYOS
      *
     C                     ENDSR
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           @CMD1   1
      *
     C           K2@L15    KLIST
     C                     KFLD           @DIE1
     C                     KFLD           @DIE2
      *
     C           K3@L15    KLIST
     C                     KFLD           @DIE1
     C                     KFLD           @DIE2
     C                     KFLD           @DIE3
      *
     C                     MOVE *BLANK    @CMD1
     C                     MOVE *ON       FIRST   1
     C                     MOVE *BLANK    W@ID    2
     C                     Z-ADD0         CNT     80
      * DUMMY READ
     C                     READ GCQWP61                  99
      *
     C                     ENDSR
** (MSG)
ENTER DIE NUMBER!
DIE NUMBER DOES NOT EXIST IN MASTER!



