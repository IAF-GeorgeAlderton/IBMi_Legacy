      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C                     EXSR #INIT
     C           *INKA     IFEQ *OFF
     C                     EXSR #MAIN
     C                     EXSR #DISP
     C                     END
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     TIME           W@TIME
     C*
     C                     Z-ADD*ZERO     WTQTY  110
     C                     Z-ADD*ZERO     WTCONT 110
      *
     C                     ENDSR
      *------------------------------------------------------
      *   GET TARGET DATE
      *------------------------------------------------------
     C           #INIT     BEGSR
     C*
     C                     DO   *HIVAL
     C*
     C                     MOVE CMD,1     D@CMD
     C                     EXFMTDSP01
     C   KA                LEAVE
     C*
     C           D@DATE    IFEQ *ZERO
     C                     ITER
     C                     ELSE
     C                     Z-ADDD@DATE    K@DATE
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
      *------------------------------------------------------
      *   MAIN
      *------------------------------------------------------
     C           #MAIN     BEGSR
     C*
     C           *LOVAL    SETLLAAMPL11
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AAMPL11                  98
     C   98                LEAVE
     C           CKSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C*
     C                     Z-ADD*ZERO     W@QTY   90
     C                     Z-ADD*ZERO     W@CONT  90
     C*
     C           K#P01     KLIST
     C                     KFLD           CKHIN1
     C                     KFLD           CKHIN2
     C                     KFLD           CKHIN3
     C                     KFLD           K@YYYY
     C                     KFLD           K@MMMM
     C           K#P01     SETLLAB#PL09
     C*
     C                     DO   *HIVAL
     C*
     C           K#P01     READEAB#PL09                  97
     C   97                LEAVE
     C           B1SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C*
     C           B1SYUY    IFEQ *ZERO
     C                     Z-ADDB1SRYO    B1SYUY
     C                     END
     C*
     C           B1SRYO    DIV  B1SYUY    W@CNT   90
     C                     ADD  W@CNT     W@CONT
     C*
     C                     ADD  B1SRYO    W@QTY
     C*
     C                     ENDDO
     C*
     C                     ADD  W@QTY     WTQTY
     C                     ADD  W@CONT    WTCONT
     C*
     C                     DO   15        X       20
     C*
     C           NPRC,X    IFEQ *BLANK
     C                     LEAVE
     C                     END
     C*
     C           NPRC,X    CHAINAB#WP9I              96
     C           *IN96     IFEQ *ON
     C                     CLEARAB#WP9IR
     C                     MOVELNPRC,X    W9PROC
     C                     END
     C*
     C                     ADD  W@QTY     W9QTY
     C                     ADD  W@CONT    W9CONT
     C*
     C  N96                UPDATAB#WP9IR
     C   96                WRITEAB#WP9IR
     C*
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C                     ENDSR
      *------------------------------------------------------
      *   DISP
      *------------------------------------------------------
     C           #DISP     BEGSR
     C*
     C                     EXSR #DSET1
     C                     EXSR #DSET2
     C*
     C                     DO   *HIVAL
     C*
     C                     MOVEL*ON       *IN51
     C                     MOVEL*OFF      *IN52
     C*
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTCTL01
     C   KA                LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDSR
      *------------------------------------------------------
      *   WORK DAYS
      *------------------------------------------------------
     C           #DSET1    BEGSR
      *
     C                     Z-ADD*ZERO     W@DAYS  31
      *
     C           K#AGD     KLIST
     C                     KFLD           K@YYYY
     C                     KFLD           K@MMMM
     C           K#AGD     SETLLAGDPL12
     C*
     C                     DO   *HIVAL
     C*
     C           K#AGD     READEAGDPL12                  89
     C   89                LEAVE
     C*
     C           F8HIRU    IFEQ *BLANK
     C                     ADD  0.5       W@DAYS
     C                     END
     C           F8YORU    IFEQ *BLANK
     C                     ADD  0.5       W@DAYS
     C                     END
     C*
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   DISP INT
      *------------------------------------------------------
     C           #DSET2    BEGSR
      *
     C                     MOVE *OFF      *IN51
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *ON       *IN51
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
      *
     C                     Z-ADDW@DAYS    D@DAYS
     C                     Z-ADDWTCONT    D@TCNT
     C           WTCONT    DIV  W@DAYS    D@DCNT    H
      *
     C           *LOVAL    SETLLAB#WP9I
      *
     C                     DO   *HIVAL
      *
     C                     READ AB#WP9I                  80
     C   80                LEAVE
      *
     C                     CLEARSFL01
     C                     MOVELW9PROC    S@PROC
     C                     Z-ADDW9CONT    S@CONT
     C                     MOVEL'('       S@KKK1
     C           W9CONT    DIV  W@DAYS    S@DCNT    H
     C                     MOVEL')'       S@KKK2
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
      *
     C                     ENDDO
      *
     C           RRN1      IFEQ *ZERO
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     MOVE MSG,1     D@MSG
     C                     ENDIF
      *
     C                     Z-ADD1         #RCNO
     C*
     C                     ENDSR
**  CMD
F1:END
F1:END      F12:GO BACK
**  MSG
  NO DATA
