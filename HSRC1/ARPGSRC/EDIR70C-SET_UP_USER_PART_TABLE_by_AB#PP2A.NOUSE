     H            Y/                                    1
     H** EDIR70 *******************************************************
     H*  SET UP USER PART TABLE                                       *
     H*  RUN IN FCKC00 (10:10AM BY JOBSCDE)                           *
     H*  JW  2019.09.25                                               *
     H*****************************************************************
     FEDIPL46 IF  E           K        DISK
     FAB#PL2ACIF  E           K        DISK
      *================================================================
     I            DS
     I                                        1  140@TIME
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                     *PROGRAM #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I                                      264 269 #JBNO
     C*===============================================================
     C*  MAIN PROGRAM
     C*===============================================================
     C                     EXSR #INIT
     C*
     C           *LOVAL    SETLLEDIPL46
     C                     DO   *HIVAL
     C                     READ EDIPL46                  90
     C   90                LEAVE
      *
     C           E5NONY    SETLLAB#PL2AC
     C                     DO   *HIVAL
     C           E5NONY    READEAB#PL2AC                 91
     C   91                LEAVE
      *
     C           E5MHN     IFEQ ACMHN
     C           E5UPRT    IFNE ACMHIN
     C                     EXSR #PRINT
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
      *
     C                     TIME           @TIME
      *
     C                     ENDSR
      *===============================================================
