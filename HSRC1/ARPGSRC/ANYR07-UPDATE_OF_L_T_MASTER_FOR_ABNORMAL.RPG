     H            Y.
     F** ANYR07 **************************************
     F* UPDATE OF L/T MASTER FOR ABNORMAL DETECTION  *
     F* T-SAKAKI           2018.08.10                *
     F************************************** ANYR07 **
     FANYPW07 CF  E                    WORKSTN
     FAAAPL01 IF  E           K        DISK
     FANYPP01 UF  E           K        DISK                      A
     E                    KOS     1   3  1   KON     6   ﾃcﾆ]hﾎﾞ]
     E                    ER      1  10 60
     I            DS
     I                                        1  140WSDT
     I                                        1   60WTIME
     I                                        7  140WDATE
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *
     C           KEY       KLIST
     C                     KFLD           WKANB
     C                     KFLD           A1JOK1
     C                     KFLD           A1JOK2
      *
     C           KEY2      KLIST
     C                     KFLD           WKJOK   2
     C                     KFLD           WKANB
      *
     C                     TIME           WSDT
     C                     Z-ADD0         A1SKHZ
     C                     MOVEL*BLANK    WKANB   1
     C                     MOVEL*BLANK    W1JON1
     C                     MOVEL*BLANK    W1JON2
      *
     C*------------------------------*
     C*     ...画面　－　１...     *
     C*------------------------------*
     C           STP1      TAG
     C                     EXFMTANYPW071
     C                     SETOF                     010203
     C                     SETOF                     99
      *
     C           *INKJ     IFEQ '1'
     C                     CALL 'ANYR05'
     C                     GOTO STP1
     C                     END
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C*----------------------------------------*
     C*     ...更新区分　の　チェック...     *
     C*----------------------------------------*
     C                     SETOF                     90
     C                     Z-ADD1         A       10
     C           KTYPE     LOKUPKOS,A                    90
     C           *IN90     IFEQ '0'
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
     C                     MOVE KON,A     WNAME
      *
     C*------------------------------------------*
     C*     ...条件コード　の　チェック...     *
     C*------------------------------------------*
     C                     MOVEL'E'       WKANB   1
     C                     MOVEL*BLANK    WKJOK
     C           A1JOK1    IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     ELSE
     C                     MOVELA1JOK1    WKJOK
     C           KEY2      CHAINAAAPL01              88
     C           A5SKJY    IFEQ 'D'
     C                     SETON                     88
     C                     ELSE
     C                     MOVELA5JOKM    W1JON1
     C                     ENDIF
     C*
     C           *IN88     IFEQ *ON
     C                     SETON                     0299
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     ENDIF
     C                     ENDIF
     C** JOK2
     C                     MOVEL*BLANK    WKJOK
     C           A1JOK2    IFEQ *BLANK
     C           A1JOK1    IFEQ 'SO'
     C                     SETON                     0399
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     ENDIF
     C                     ELSE
     C                     MOVELA1JOK2    WKJOK
     C           KEY2      CHAINAAAPL01              88
     C           A5SKJY    IFEQ 'D'
     C                     SETON                     88
     C                     ELSE
     C                     MOVELA5JOKM    W1JON2
     C                     ENDIF
     C           *IN88     IFEQ *ON
     C                     SETON                     0399
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     ENDIF
     C                     ENDIF
      *
     C*----------------------------------------*
     C*     ...マスター　の　チェック...     *
     C*----------------------------------------*
     C                     MOVEL*BLANK    WKANB   1
     C                     SETOF                     90
     C           KEY       CHAINANYPP011             90
     C           KTYPE     IFEQ '2'
     C           *IN90     IFEQ '0'
     C           A1SKJY    IFEQ 'D'
     C           A1SKHZ    ANDLEWDATE
     C                     GOTO STP2
     C                     END
      *
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C           KTYPE     IFEQ '1'
     C           *IN90     IFEQ '1'
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,5      MSG
     C                     GOTO STP1
     C                     END
      *
     C           A1SKJY    IFEQ 'D'
     C           A1SKHZ    ANDLEWDATE
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,6      MSG
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C           KTYPE     IFEQ '0'
     C           *IN90     IFEQ '1'
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,7      MSG
     C                     GOTO STP1
     C                     END
      *
     C           A1SKJY    IFEQ 'D'
     C           A1SKHZ    ANDLEWDATE
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,8      MSG
     C                     GOTO STP1
     C                     END
     C                     END
     C           STP2      TAG
      *
     C           KTYPE     IFEQ '2'
     C                     MOVE *BLANK    A1SKJY
     C                     Z-ADD0         A1SKHZ
     C                     Z-ADD0         A1LTIM
     C                     END
      *
     C*------------------------------*
     C*     ...画面　－　２...     *
     C*------------------------------*
     C           STP3      TAG
     C                     EXFMTANYPW072
     C                     SETOF                     99
      *
     C           *INKC     IFEQ '1'
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C                     END
      *
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP3
     C                     END
      *
     C           KTYPE     IFEQ '0'
     C                     MOVE 'D'       A1SKJY
     C                     Z-ADDWDATE     A1SKHZ
     C                     END
      *
     C                     Z-ADDWDATE     A1KOHZ
     C                     Z-ADDWTIME     A1TIME
     C                     MOVEL#WSID     A1KOME
     C                     MOVE KTYPE     MTYPE
     C                     MOVE WNAME     MNAME
     C                     MOVE A1JOK1    MGYO1
     C                     MOVE A1JOK2    MGYO2
      *
     C           *IN90     IFEQ '0'
     C                     UPDATANYPP011
     C                     ELSE
     C                     WRITEANYPP011
     C                     END
      *
     C                     EXSR SUBRTN
     C                     GOTO STP1
      *
      *
     C*----------------------------------------*
     C*         ...サブルーチン...           *
     C*     ...画面－１　の　クリアー...     *
     C*----------------------------------------*
     C           SUBRTN    BEGSR
     C                     MOVE *BLANK    KTYPE
     C                     MOVE *BLANK    WNAME
     C                     MOVE *BLANK    A1JOK1
     C                     MOVE *BLANK    A1JOK2
     C                     Z-ADD0         A1LTIM
     C                     ENDSR
      *
**  KOS.KON
0CANCEL
1CHANGE
2ADD
**  ERR
E-01 UPDATE INSTRUCTION IS <0 1 2>
E-02 INPUT CONDITION CODE
E-03 DOES NOT EXIST IN CONDTION MASTER
E-04 ADD WAS APPOINTED BUT M/F EXIST
E-05 CHANGE WAS APPOINTED BUT M/F DON'T EXIST
E-06 CHANGE WAS APPOINTED BUT M/F IS CANCELLED ALREADY
E-07 CANCEL WAS APPOINTED BUT M/F DON'T EXIST
E-08 CANCEL WAS APPOINTED BUT M/F IS CANCELLED ALREADY
E-09 INPUT KANJI(FULL NAME)
E-10 INPUT KANJI(PRINT KANBAN)
