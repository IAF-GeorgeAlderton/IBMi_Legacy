 DE2 C                     ENDDO
     C   KC                ITER
      *
     C                     ENDSL
     C*
     C*明細画面のセット
     C                     SELEC
     C           W1OPT     WHEQ '1'
     C                     EXSR #SET3A
     C           W1OPT     WHEQ '2'
     C                     EXSR #SET3B
     C           W1OPT     WHEQ '3'
     C                     EXSR #SET3C
     C           W1OPT     WHEQ '4'
     C                     EXSR #SET3D
      * MSK
     C           W1OPT     WHEQ '5'
     C                     EXSR #SET3E
      *
     C           W1OPT     WHEQ '6'
     C                     EXSR #SET3F
     C                     ENDSL
     C*
     C           RRN1      CABEQ0         @SCR2
     C*------------------------------*
     C*        画面－３            *
     C*------------------------------*
 DO2 C                     DO   *HIVAL
     C*  明細照会画面（見出し）
     C                     SELEC
     C           W1OPT     WHEQ '1'
     C                     WRITESCR3A
     C           W1OPT     WHEQ '2'
     C                     WRITESCR3B
     C           W1OPT     WHEQ '3'
     C                     WRITESCR3C
     C           W1OPT     WHEQ '4'
     C                     WRITESCR3D
     C           W1OPT     WHEQ '5'
     C                     WRITESCR3E
     C           W1OPT     WHEQ '6'
     C                     WRITESCR3F
     C                     ENDSL
     C*  明細照会画面（データ）
     C                     MOVEA'100'     *IN,93
     C           LAST      COMP 0                    94
     C                     EXFMTSFLCTL
     C                     SETOF                     94  99
     C                     SETOF                     41
     C                     MOVE *BLANK    MSG
     C                     Z-ADD$POS      NBR
      * CMD-1
     C   KA                EXSR #PGME
      * CMD-3
     C   KC                LEAVE
      * ROL-UP
     C   91                EXSR #ROLU
      * ROL-DWN
     C   92                SETON                         99
     C   92                MOVELERR,5     MSG
      * MSK 2002.03.22 *
     C                     Z-ADD0         X       60
     C                     EXSR $SB900
      *
 DE2 C                     ENDDO
     C                     GOTO @SCR2
     C*
DE1  C                     ENDDO
     C***********************************************
     C*    プログラム開始・初期処理               *
     C***********************************************
     C           #INIT     BEGSR
   C1C* * *                MOVE *BLANK    W2MHN5  5
   C1C* * *                MOVE *BLANK    W2MHN6  5
   C1C* * *                MOVE *BLANK    W2MHN7  5
     C                     Z-ADD*ZERO     W2NOH8
     C                     TIME           WTIME
     C                     Z-ADD*DATE     SYSH8
     C*
     C                     ENDSR
     C***********************************************
     C*    プログラム終了                         *
     C***********************************************
     C           #PGME     BEGSR
     C                     SETON                     LR
     C                     RETRN
     C*
     C                     ENDSR
     C***********************************************
     C*    画面２項目チェック(1)                  *
     C***********************************************
     C           #CHK2A    BEGSR
     C                     MOVE *BLANK    D3TONM
     C                     MOVE *BLANK    D3NONM
     C                     MOVE ' '       W#SW    1
      *
      *          D2NOYM    IFNE 0
      *                    MOVE '*'       W#SW
      *                    END
     C*
     C           D2NUKE    IFNE *BLANK
     C                     MOVE '*'       W#SW
     C                     ELSE
     C           W#SW      IFEQ '*'
     C                     SETON                     25  99
     C                     MOVELERR,2     MSG
     C                     END
     C                     END
     C*
     C           D2NKOJ    IFNE *BLANK
     C                     MOVE '*'       W#SW
     C                     ELSE
