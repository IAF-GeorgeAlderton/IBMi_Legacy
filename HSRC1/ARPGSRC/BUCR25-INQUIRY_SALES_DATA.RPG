     C                     MOVE '*'       W#SW
     C                     ELSE
     C           W#SW      IFEQ '*'
     C                     SETON                     22  99
     C                     MOVELERR,2     MSG
     C                     END
     C                     END
     C*
     C           D2SHN1    IFNE *BLANK
     C           D2SHN2    ORNE *BLANK
     C           D2SHN3    ORNE *BLANK
     C                     MOVE '*'       W#SW
     C                     ELSE
     C           W#SW      IFEQ '*'
     C                     SETON                     21  99
     C                     MOVELERR,2     MSG
     C                     ELSE
     C                     MOVEA'111111'  *IN,21
     C                     SETON                         99
     C                     MOVELERR,2     MSG
     C                     END
     C                     END
     C*
     C           MSG       CABNE*BLANK    @CH2AE
      *
      * CMD-5 (リスト作成）
     C           *INKE     IFEQ '1'
     C                     MOVE D2SHN1    P1HIN1  5
     C                     MOVE D2SHN2    P1HIN2  5
     C                     MOVE D2SHN3    P1HIN3  2
     C                     Z-ADDD2TOKU    P1TOKU  40
     C                     Z-ADDD2NONY    P1NONY  40
     C                     MOVE D2NKOJ    P1NKOJ  1
     C                     MOVE D2NUKE    P1NUKE  4
     C                     MOVE *BLANK    P1STS   1
     C                     CALL 'MBDC82'  MBDC82
     C           P1STS     IFEQ '9'
     C                     MOVELERR,65    MSG
     C                     SETON                     99
     C                     SETOF                     KE
     C                     END
     C                     GOTO @CH2AE
     C                     END
      *
     C*
 B1  C           D2TOKU    IFNE 0
     C           D2TOKU    CHAINFGBPL01              90
     C  N90      B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     90
     C                     END
  B2 C           *IN90     IFEQ *ON
     C                     SETON                     22  99
     C                     MOVELERR,3     MSG
  X2 C                     ELSE
     C                     MOVELB2KEMI    D3TONM
  E2 C                     END
 E1  C                     END
     C*
 B1  C           D2NONY    IFNE 0
     C           D2NONY    CHAINFGBPL01              90
     C  N90      B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE*DATE
