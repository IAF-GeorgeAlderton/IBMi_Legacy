  X2 C                     ELSE
     C                     MOVELB2KEMI    D3NONM
  E2 C                     END
 E1  C                     END
     C*
 B1  C           D2NOYM    IFNE *ZERO
  B2 C           D2NOM     IFLT 1
     C           D2NOM     ORGT 12
     C                     SETON                     26  99
     C                     MOVELERR,4     MSG
  X2 C                     ELSE
     C* * *                Z-ADD0         W2NOD
     C* * *                MOVELW2NOH6    PHIZ
     C* * *                MOVE *BLANK    PPHZ
     C* * *                CALL 'DATR00'
