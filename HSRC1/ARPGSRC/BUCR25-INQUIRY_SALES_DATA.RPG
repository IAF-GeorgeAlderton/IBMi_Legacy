     C* * *      D1OPT     ORGT '6'
     C           D1OPT     ORGT '3'
     C                     SETON                     11  99
     C                     MOVELERR,1     MSG
     C                     ITER
     C                     END
     C*
     C           D1OPT     IFEQ '3'
     C                     MOVE '6'       W1OPT   1
     C                     ELSE
     C                     MOVE D1OPT     W1OPT
     C                     END
     C*
     C                     SELEC
     C           W1OPT     WHEQ '1'
     C                     CLEARSCR2A
     C           W1OPT     WHEQ '2'
     C                     CLEARSCR2B
     C           W1OPT     WHEQ '3'
     C                     CLEARSCR2C
     C           W1OPT     WHEQ '4'
     C                     CLEARSCR2D
     C           W1OPT     WHEQ '5'
     C                     CLEARSCR2E
     C           W1OPT     WHEQ '6'
     C                     CLEARSCR2F
     C                     ENDSL
     C*------------------------------*
     C*        画面－２            *
     C*------------------------------*
     C           @SCR2     TAG
     C*キー項目入力画面
     C                     SELEC
<S1> C           W1OPT     WHEQ '1'
 DO2 C                     DO   *HIVAL
     C                     EXFMTSCR2A
     C                     MOVEA'000000'  *IN,21
     C                     SETOF                     99
     C                     MOVE *BLANK    MSG
     C   KA                EXSR #PGME
     C   KC                LEAVE
     C                     EXSR #CHK2A
     C   KE                GOTO @SCR2
     C  N99                LEAVE
 DE2 C                     ENDDO
     C   KC                ITER
     C*
<S2> C           W1OPT     WHEQ '2'
 DO2 C                     DO   *HIVAL
     C                     EXFMTSCR2B
     C                     MOVEA'000000'  *IN,21
     C                     SETOF                     99
     C                     MOVE *BLANK    MSG
     C   KA                EXSR #PGME
     C   KC                LEAVE
     C                     EXSR #CHK2B
     C   KE                GOTO @SCR2
     C  N99                LEAVE
 DE2 C                     ENDDO
     C   KC                ITER
     C*
<S3> C           W1OPT     WHEQ '3'
 DO2 C                     DO   *HIVAL
     C                     EXFMTSCR2C
     C                     MOVEA'000000'  *IN,21
     C                     SETOF                     99
     C                     MOVE *BLANK    MSG
     C   KA                EXSR #PGME
     C   KC                LEAVE
     C                     EXSR #CHK2C
     C  N99                LEAVE
 DE2 C                     ENDDO
     C   KC                ITER
     C*
<S4> C           W1OPT     WHEQ '4'
 DO2 C                     DO   *HIVAL
     C                     EXFMTSCR2D
     C                     MOVEA'000000'  *IN,21
     C                     SETOF                     99
     C                     MOVE *BLANK    MSG
     C   KA                EXSR #PGME
     C   KC                LEAVE
     C                     EXSR #CHK2D
     C  N99                LEAVE
 DE2 C                     ENDDO
     C   KC                ITER
     C* MSK
<S4> C           W1OPT     WHEQ '5'
 DO2 C                     DO   *HIVAL
     C                     EXFMTSCR2E
     C                     MOVEA'000000'  *IN,21
     C                     SETOF                     99
     C                     MOVE *BLANK    MSG
     C   KA                EXSR #PGME
     C   KC                LEAVE
     C                     EXSR #CHK2E
     C  N99                LEAVE
 DE2 C                     ENDDO
     C   KC                ITER
     C* MSK
<S4> C           W1OPT     WHEQ '6'
 DO2 C                     DO   *HIVAL
     C                     EXFMTSCR2F
     C                     MOVEA'000000'  *IN,21
     C                     SETOF                     99
