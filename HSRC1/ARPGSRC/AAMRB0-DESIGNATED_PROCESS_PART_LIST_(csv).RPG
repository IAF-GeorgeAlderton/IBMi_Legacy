     C           F3NONY    OREQ 0170
     C           F3NONY    OREQ 0755
     C                     ITER
     C                     END
      ***
     C                     ADD  F3TNSU    WKZSNA
     C                     ENDDO
      **
     C                     MULT AFSKSU    WKZSNA
      **
     C           $S911E    ENDSR
