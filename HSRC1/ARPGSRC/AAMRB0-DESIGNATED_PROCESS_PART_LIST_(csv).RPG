     C           HKT,A     OREQ PKT2                        工程２
     C           HKT,A     OREQ PKT3                        工程３
     C                     MOVEL'OK'      @OK     2
  E3 C                     ENDIF
 E2  C                     ENDIF
E1   C                     ENDIF
