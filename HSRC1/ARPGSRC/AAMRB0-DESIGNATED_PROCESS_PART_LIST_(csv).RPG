     C                     MOVELMEK1      W@MEK
     C                     Z-ADD1         @M      20
     C           W@MEK2    LOKUP@2,@M                    75
     C           *IN75     IFEQ '1'
     C                     MOVEL#2,@M     E@ME
     C                     END
     C           W@MEK2    IFEQ 'D'
     C           W@MEK4    ANDEQ'B'
     C                     MOVEL#TXT,1    E@ME
     C                     END
      **カラー
     C                     Z-ADD1         @M
     C           W@MEK4    LOKUP@4,@M                    75
     C           *IN75     IFEQ '1'
     C                     MOVE #4,@M     E@CL             カラー
     C                     END
      **脱水素
     C                     Z-ADD1         @M
     C           W@MEK3    LOKUP@3,@M                    75
     C           *IN75     IFEQ '1'
     C                     MOVE #3,@M     E@H              脱水素
     C                     END
     C                     ENDSR
      **************************
      **日当り箱数           *
      **************************
     C           ##HIAT    BEGSR
S1   C           SYSS      IFNE 0
     C           W@ZSNA    DIV  W@KDOA    W@DDHA
<28> C                     DIV  SYSS      W@DDHA           箱／日N-1
     C           W@SNNM    DIV  W@KDO0    W@DDH0
<29> C                     DIV  SYSS      W@DDH0           箱／日N
     C           W@S1NM    DIV  W@KDO1    W@DDH1
<30> C                     DIV  SYSS      W@DDH1           箱／日N+1
     C           W@S2NM    DIV  W@KDO2    W@DDH2
<31> C                     DIV  SYSS      W@DDH2           箱／日N+2
E1   C                     ENDIF
      **************************
      **日当りｋｇ           *
      **************************
      **完成重量が０の場合
     C           KASI      IFEQ 0
     C           SYSS      ANDNE0
     C           10000     DIV  SYSS      KASI      H
     C                     ENDIF
      ***完成重量　／　１０００
      ***完成重量が無い場合は１０とする
S1   C           KASI      IFEQ 0
     C                     Z-ADD10        W@KASI
X1   C                     ELSE
     C                     Z-ADDKASI      W@KASI
E1   C                     ENDIF
     C                     DIV  1000      W@KASI
      ***Ｘ　収容数
     C                     MULT SYSS      W@KASI
      *単重×実績／１０００／稼働日
     C           KASI      MULT W@ZSNA    WWDDKA 153
     C           WWDDKA    DIV  1000      WWDDKA 153
<32> C           WWDDKA    DIV  W@KDOA    W@DDKA 153       前月ｋｇ／日
      *
     C           KASI      MULT W@SNNM    WWDDK0 153
     C           WWDDK0    DIV  1000      WWDDK0 153
<33> C           WWDDK0    DIV  W@KDO0    W@DDK0 153       当月ｋｇ／日
      *
     C           KASI      MULT W@S1NM    WWDDK1 153
     C           WWDDK1    DIV  1000      WWDDK1 153
<34> C           WWDDK1    DIV  W@KDO1    W@DDK1 153       次月ｋｇ／日
      *
     C           KASI      MULT W@S2NM    WWDDK2 153
     C           WWDDK2    DIV  1000      WWDDK2 153
<35> C           WWDDK2    DIV  W@KDO2    W@DDK2 153       次次月ｋｇ／日
     C                     ENDSR
      *================================================================
      *  実績　　                                                   *
      *================================================================
     C           $SB910    BEGSR
      **
     C                     CALL 'MCER00'
     C                     PARM           P@T     6        N
     C                     PARM           P@A     6        N-1
     C                     PARM           P@B     6        N-2
     C                     PARM           P@C     6        N-3
     C                     PARM           P@D     6        N-4
     C                     PARM           P@E     6        N-5
     C*
     C                     MOVE P@T       Q@T     60
     C                     MOVE P@A       Q@A     60
     C                     MOVE P@B       Q@B     60
     C                     MOVE P@C       Q@C     60
     C                     MOVE P@D       Q@D     60
     C                     MOVE P@E       Q@E     60
      **
     C           HINKEY    SETLLMBDPL011
      *-------------------------
S1   C                     DO   *HIVAL
     C           HINKEY    READEMBDPL011                 21
     C         21          LEAVE
      ***海外は読み飛ばし
     C           F3NONY    IFEQ 0111
     C           F3NONY    OREQ 0094
     C           F3NONY    OREQ 0200
     C           F3NONY    OREQ 0170
     C           F3NONY    OREQ 0755
     C                     ITER
     C                     END
      ***       前月
     C           W@UYMA    IFEQ Q@T
     C                     ADD  F3TNSU    W@ZSNA           前月実績
     C                     END
     C           W@UYMA    IFEQ Q@A
     C                     ADD  F3ANSU    W@ZSNA
     C                     END
     C           W@UYMA    IFEQ Q@B
     C                     ADD  F3BNSU    W@ZSNA
     C                     END
     C           W@UYMA    IFEQ Q@C
     C                     ADD  F3CNSU    W@ZSNA
     C                     END
     C           W@UYMA    IFEQ Q@D
     C                     ADD  F3DNSU    W@ZSNA
     C                     END
     C           W@UYMA    IFEQ Q@E
     C                     ADD  F3ENSU    W@ZSNA
     C                     END
      *
     C                     ENDDO
      *-------------------------
     C           $S910E    ENDSR
     C*---------------------------------------------------------------*
     C*  実績（構成品）                                             *
     C*---------------------------------------------------------------*
     C           $SB911    BEGSR
     C                     Z-ADD*ZERO     WKZSNA 100
      **
