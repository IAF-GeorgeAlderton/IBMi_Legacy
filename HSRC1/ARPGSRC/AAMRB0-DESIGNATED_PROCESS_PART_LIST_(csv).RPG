      *****************************************************************
      *パラメータ
      *****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PYY     40       年
     C                     PARM           PMM     20       月
     C                     PARM           PKT     3        工程１
     C                     PARM           PKT2    3        工程２
     C                     PARM           PKT3    3        工程３
     C                     PARM           PBM     4        部門
      *****************************************************************
      *キーリスト
      *****************************************************************
     C           HINKEY    KLIST
     C                     KFLD           W@HIN1  5
     C                     KFLD           W@HIN2  5
     C                     KFLD           W@HIN3  2
     C           HN2KEY    KLIST
     C                     KFLD           W2HIN1  5
     C                     KFLD           W2HIN2  5
     C                     KFLD           W2HIN3  2
     C           KEYF81    KLIST
     C                     KFLD           #KYY    40
     C                     KFLD           #KMM    20
      *MSK 2008.11.13
     C           KEYMC1    KLIST
     C                     KFLD           W@HIN1
     C                     KFLD           W@HIN2
     C                     KFLD           W@HIN3
     C           KEYMC2    KLIST
     C                     KFLD           W2HIN1
     C                     KFLD           W2HIN2
     C                     KFLD           W2HIN3
      *****************************************************************
      *初期処理
      *****************************************************************
     C                     MOVE PBM       WBM     40       部門
     C                     MOVEL'1'       OPNCLS  1
      **現在の設定月
     C                     Z-ADD*ZERO     W@UYM
     C                     MOVELPYY       W@UYM            年
     C                     MOVE PMM       W@UYM            月
     C                     MOVE W@UYM     UYM     40       年月
      **１月前
S1   C           W@UMM     IFEQ 1
     C           W@UYY     SUB  1         W@UYYA
     C                     Z-ADD12        W@UMMA
X1   C                     ELSE
     C           W@UYM     SUB  1         W@UYMA
E1   C                     END
     C                     Z-ADDW@UYYA    #KYY
     C                     Z-ADDW@UMMA    #KMM
     C                     Z-ADD*ZERO     W@KDO   31
     C                     EXSR #KADO                      稼動日数
<36> C                     Z-ADDW@KDO     W@KDOA  31       前月稼動日数
      **当月
     C                     Z-ADDW@UYM     W@UYM0
     C                     Z-ADDW@UYY0    #KYY
     C                     Z-ADDW@UMM0    #KMM
     C                     Z-ADD*ZERO     W@KDO
     C                     EXSR #KADO
<37> C                     Z-ADDW@KDO     W@KDO0  31       当月稼動日数
      **１月後
     C           W@UMM0    IFEQ 12
     C           W@UYY0    ADD  1         W@UYY1
     C                     Z-ADD01        W@UMM1
     C                     ELSE
     C           W@UYM0    ADD  1         W@UYM1
     C                     END
     C                     Z-ADDW@UYY1    #KYY
     C                     Z-ADDW@UMM1    #KMM
     C                     Z-ADD*ZERO     W@KDO
     C                     EXSR #KADO
<38> C                     Z-ADDW@KDO     W@KDO1  31       次月稼働日数
      **２月後
     C           W@UMM1    IFEQ 12
     C           W@UYY1    ADD  1         W@UYY2
     C                     Z-ADD01        W@UMM2
     C                     ELSE
     C           W@UYM1    ADD  1         W@UYM2
     C                     END
     C                     Z-ADDW@UYY2    #KYY
     C                     Z-ADDW@UMM2    #KMM
     C                     Z-ADD*ZERO     W@KDO
     C                     EXSR #KADO
<39> C                     Z-ADDW@KDO     W@KDO2  31       次次月稼動日数
      **ヘッダー印刷
     C                     EXCPT$HED
      **
      *****************************************************************
      *メイン
      *****************************************************************
      *､､､､､､､､､､､､､､､､､､､､､､､､､
      *､､､､､､､､､､､､､､､､､､､､､､､､､
      *(AAMPP11)..社内かんばん切り替えマスター
      *､､､､､､､､､､､､､､､､､､､､､､､､､
      *､､､､､､､､､､､､､､､､､､､､､､､､､
S1   C                     DO   *HIVAL
     C                     READ AAMPP11                  91
     C         91          LEAVE
     C**削除
 S2  C           CKSKJY    IFEQ 'D'
     C           CKSKHZ    ANDLE*DATE
     C                     ITER
 E2  C                     ENDIF
     C**現在工程
     C                     MOVE *BLANK    HKT              工程
     C                     Z-ADD0         HBM              部門
     C                     MOVE *BLANK    HKB              機番
     C                     MOVE *BLANK    HKS              機種
     C                     MOVE *BLANK    HTKR             所番地
     C                     MOVE *BLANK    HKCD             かん種類
     C                     MOVE *BLANK    HHBN             工程内品番
     C                     Z-ADD0         HKHB             切替日・便
     C                     Z-ADD0         HLT              ロット
     C                     Z-ADD1         A       20
     C                     Z-ADD0         B       20
     C*--------------------
 S2  C           1         DO   15        A
  S3 C           NKT,A     IFNE *BLANK                     新工程
     C                     ADD  1         B
     C                     MOVE NKT,A     HKT,B            工程
     C                     Z-ADDNBM,A     HBM,B            部門
     C                     MOVE NKB,A     HKB,B            機番
     C*
12/18C           HBM,B     IFNE 0
  |  C                     CALL 'MZARSB'
  |  C                     PARM           HBM,B
  |  C                     PARM           HKT,B
  |  C                     PARM           HKB,B
  |  C                     PARM           HKS,B
12/18C                     END
     C*
     C                     MOVE NTKR,A    HTKR,B           所番地
     C                     MOVE NKCD,A    HKCD,B           かん種類
     C                     MOVE NHBN,A    HHBN,B           工程内品番
     C                     Z-ADDNKHB,A    HKHB,B           切替日・便
  E3 C                     ENDIF
 E2  C                     ENDDO
     C*--------------------
     C**対象工程
     C*--------------------
 S2  C           1         DO   15        A
  S3 C           HKT,A     IFEQ *BLANK                     工程
     C                     LEAVE
  E3 C                     ENDIF
     C                     EXSR $HANTE                     出力判定
  S3 C           @OK       IFEQ 'OK'
     C                     EXSR OUTPUT
  E3 C                     ENDIF
 S2  C                     ENDDO
     C*--------------------
     C**
E1   C                     ENDDO
      *､､､､､､､､､､､､､､､､､､､､､､､､､
