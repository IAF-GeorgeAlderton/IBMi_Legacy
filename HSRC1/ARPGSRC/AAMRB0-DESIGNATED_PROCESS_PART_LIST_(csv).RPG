     C           HKT,A     OREQ PKT3                       工程３
 S2  C           PBM       IFEQ *BLANK                     部門ALL
     C                     MOVEL'OK'      @OK     2
 X2  C                     ELSE
  S3 C           HBM,A     IFEQ WBM                         =部門EQ
     C                     MOVEL'OK'      @OK     2
  E3 C                     ENDIF
 E2  C                     ENDIF
E1   C                     ENDIF
      *
S1   C           HBM,A     IFEQ WBM                         =部門EQ
 S2  C           PKT       IFEQ *BLANK
     C           PKT2      ANDEQ*BLANK
     C           PKT3      ANDEQ*BLANK
     C                     MOVEL'OK'      @OK     2
 X2  C                     ELSE
