      *
     C           M6SKJY    IFEQ 'D'
     C                     GOTO @END
     C                     END
     C           M6BMON    IFEQ 0111
     C                     GOTO @END
     C                     END
      *
      *失効日の拡大
     C                     MOVE M6STDT    PRDAT
     C           M6STMM    IFNE 99
     C                     MOVE M6STDT    PDATE   8
     C                     MOVE '+'       PPORM   1        + OR -
     C                     MOVE '0005'    PDAYS   4
     C                     MOVE *BLANK    PRDAT   8
     C                     MOVE *BLANK    PRTN    1
     C                     CALL 'DATR1A'
     C                     PARM           PDATE   8
     C                     PARM           PPORM   1        + OR -
     C                     PARM           PDAYS   4
     C                     PARM           PRDAT   8
     C                     PARM           PRTN    1
     C                     END
     C                     MOVE PRDAT     W@STDT  80
      *有効日の拡大
     C                     MOVE M6UKDT    PDATE   8
     C                     MOVE '-'       PPORM   1        + OR -
     C                     MOVE '0005'    PDAYS   4
     C                     MOVE *BLANK    PRDAT   8
     C                     MOVE *BLANK    PRTN    1
     C                     CALL 'DATR1A'
     C                     PARM           PDATE   8
     C                     PARM           PPORM   1        + OR -
     C                     PARM           PDAYS   4
     C                     PARM           PRDAT   8
     C                     PARM           PRTN    1
     C                     MOVE PRDAT     W@UKDT  80
      *
     C                     TIME           WTIME
      *
     C           WTIHZ     IFGE W@UKDT
     C           WTIHZ     ANDLEW@STDT
     C                     ELSE
     C                     GOTO @END
     C                     END
      *
     C                     Z-ADDM6SYUY    M@SYUY  50
      *
     C                     Z-ADD0         J1TANJ  73
     C                     CALL 'AJUR19'
     C                     PARM           M6HIN1
     C                     PARM           M6HIN2
     C                     PARM           M6HIN3
     C                     PARM           J1TANJ
      *
     C                     EXCPTODAT
      *
     C           @END      TAG
