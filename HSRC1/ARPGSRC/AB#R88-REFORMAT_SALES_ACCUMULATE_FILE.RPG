     H            Y.
     F** AB#R26 ******************************
     F*   ..売上累積ファイル　　再編成..   *
     F*     I-HASADA            87.10.29     *
     F****************************** AB#R26 **
     FAB#PP01 IP  E                    DISK
     FAB#PLNO UF  E           K        DISK                      A    UC
     FAB#WP88 O   E                    DISK
     FAB#WPCP O   E                    DISK
     IAB#PP011
     I              B1NOBI                          INNOBI
     I              B1LOTO                          INLOTO
     I            DS
     I                                        1   80UHIZK
     I                                        1   40UYY
     I                                        5   60UMM
     I                                        7   80UDD
     I            DS
     I                                        1   80MHIZK
     I                                        1   60MHYM
     I                                        1   40MYY
     I                                        5   60MMM
     I                                        7   80MDD
     I            DS
     I                                        1   80B1SKHZ
     I                                        1   40B1SKYY
     I                                        5   60B1SKMM
     I                                        7   80B1SKDD
     I            DS
     I                                        1   80JHIZK
     I                                        1   60JHYM
     I                                        1   40B1JRYY
     I                                        5   60B1JRMM
     I                                        7   80B1JRDD
      *
     C           *ENTRY    PLIST
     C                     PARM           PHIZK   8
     C                     PARM           PRECD   7
     C                     PARM           PKENS   7
      *
     C*---------------------------*
     C*   ...1 ﾅbhﾓ ﾉv ﾉ ﾆﾑﾒ...   *
     C*---------------------------*
     C           *IN01     IFEQ '0'
     C                     SETON                     01
     C                     TIME           STIME   60
     C                     MOVE PHIZK     UHIZK
     C                     Z-ADDUHIZK     MHIZK
      *
     C           MMM       IFEQ 01
     C                     SUB  1         MYY
     C                     Z-ADD12        MMM
     C                     ELSE
     C                     SUB  1         MMM
     C                     END
     C                     END
      *
     C                     ADD  1         WRECD   70
     C                     Z-ADDINNOBI    B1NOBI
     C                     MOVE INLOTO    B1LOTO
      *
     C           B1SKJY    IFEQ 'D'
     C           B1SKHZ    IFLE UHIZK
     C                     WRITEAB#WP881
     C                     GOTO END
     C                     END
     C                     END
      *
     C*-------------------------------------*
     C*   ...qgjﾞﾆﾆmbﾍﾞ bﾃﾞ ﾉ mﾞ-j ﾆﾑﾒ...   *
     C*-------------------------------------*
     C           JHIZK     IFGT UHIZK
     C                     ADD  1         WKENS   70
     C                     WRITEAB#WPCP1
     C                     GOTO END
     C                     END
      *
     C*----------------------------------------*
     C*   ...ﾆmbﾍﾞﾑﾒ 4fiﾞlbﾈﾞ] ﾉ mﾞ-j ﾆﾑﾒ...   *
     C*----------------------------------------*
     C           JHYM      IFLT MHYM
     C                     WRITEAB#WP881
     C                     GOTO END
     C                     END
      *
     C*------------------------------*
     C*   ...hﾒﾃﾆﾇﾞv mﾞ-j ﾉ ﾆﾑﾒ...   *
     C*------------------------------*
     C           B1SKJY    IFNE 'D'
     C           B1SEMM    IFEQ 0
     C           B1KRKS    IFNE 0
     C                     ADD  1         WKENS
     C                     WRITEAB#WPCP1
     C                     GOTO END
     C                     END
     C                     END
      *
     C           B1SEMM    IFNE 0
     C           B1KRKS    IFNE 0
     C           JHYM      IFGE MHYM
     C                     WRITEAB#WPCP1
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C*--------------------------------------*
     C*   ...ﾆmblﾞg mbﾆﾞﾑcmﾞ-j ﾌﾞlhalﾎﾟ...   *
     C*--------------------------------------*
     C                     WRITEAB#WP881
      *
     C           END       TAG
      *
     C*---------------------------*
     C*   ...ﾅbs]ﾈb ﾆﾏcilﾆﾑﾒ...   *
     C*---------------------------*
     CLR                   TIME           ETIME   60
     CLR                   OPEN AB#PLNO
     CLR                   SETOF                     07
     CLR         UMM       CHAINAB#PLNO1             07
      *
     CLRN07                Z-ADDI5RENO    WRENO   70
     CLR 07                Z-ADD0         WRENO
     CLR                   Z-ADD1         I5RENO
     CLR 07                Z-ADDUMM       I5TUKI
     CLRN07                UPDATAB#PLNO1
     CLR 07                WRITEAB#PLNO1
     CLR                   CLOSEAB#PLNO
      *
     CLR                   MOVE WRECD     PRECD
     CLR                   MOVE WKENS     PKENS
