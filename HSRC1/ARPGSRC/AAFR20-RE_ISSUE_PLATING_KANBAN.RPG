     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,2     ERRMSG
     C                     GOTO STP01
     C                     END
     C*
     C*  fﾞx] (2) ﾉ ﾈｮn
     C*
     C                     MOVEA'00000'   *IN,31
     C                     MOVEA'00000'   *IN,36
