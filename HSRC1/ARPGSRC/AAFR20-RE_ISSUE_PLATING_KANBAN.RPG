     C           I         ADD  30        J
     C                     MOVEA'1'       *IN,J
     C                     MOVE I         NO,I
     C                     MOVE *BLANK    DSHIN
     C                     MOVELA31HB5    DSHIN1
     C                     MOVEL'-'       DSHIN2
     C                     MOVELA32HB5    DSHIN3
     C                     MOVEL'-'       DSHIN4
     C                     MOVELA33HB2    DSHIN5
