     C*  EXFMT  fﾞx] (1)                                             *
     C****************************************************************
     C           STP01     TAG
     C                     EXFMTAAFPW201
     C           *INKA     IFEQ '1'
     C                     MOVEL'1'       *INLR
     C                     RETRN
     C                     END
     C*
     C                     MOVEA'00000'   *IN,01
     C                     MOVEA'00000'   *IN,06
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    ERRMSG
     C*
     C*  fﾞx] (1) ﾉ kｩｮh
     C*
     C           XXBAN1    IFEQ *BLANK
     C           XXBAN2    ANDEQ*BLANK
     C           XXBAN3    ANDEQ*BLANK
     C           XXBAN4    ANDEQ*BLANK
     C                     MOVEA'1111'    *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,1     ERRMSG
     C                     GOTO STP01
     C                     END
     C*
     C           KEY1      KLIST
     C                     KFLD           XXBAN1
     C                     KFLD           XXBAN2
     C                     KFLD           XXBAN3
     C                     KFLD           XXBAN4
     C           KEY1      SETLLAAFPL031                 40
     C           *IN,40    IFEQ '0'
