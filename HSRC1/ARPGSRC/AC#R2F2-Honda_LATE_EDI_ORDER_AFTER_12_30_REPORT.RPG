     H            Y.
     F** AC#R2F2 ********************************************
     F*  HONDA LATE EDI ORDER AFTER 12:30 REPORT (V.2)      *
     F*  (RUN IN VJBC74 15:45)                              *
     F*  WRITTEN: JW (SRA) 2022.01.03                       *
     F*  -------------------------------------              *
     F*  JW       2025.01.28 REMOVE EP90S                   *
     F*******************************************************
     FAB#EL92TIF  E           K        DISK
     FAB#EL91SIF  E           K        DISK
     FAB#PL1L IF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
      *===================================================
      * SYSTEM DATE
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I            DS
     I                                        1   80A9PLSH
     I                                        1   40X9NOYY
     I                                        5   60X9NOMM
     I                                        7   80X9NODD
     I            DS
     I                                        1   80AEPLSH
     I                                        1   40XENOYY
     I                                        5   60XENOMM
     I                                        7   80XENODD
      *
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      *
     C                     EXSR #862
      *
     C                     EXSR #850
      *
      *
     C           SEQ#      IFEQ 0
     C                     MOVE *ON       *IN85
     C                     ELSE
     C                     MOVE '*'       $RTN
     C                     ENDIF
      * PRINT FOOT
     C                     EXCPT@FOT1
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * CHECK EDI862 BY EP92
      *======================================================
     C           #862      BEGSR
      *
     C           K#90S     SETLLAB#EL92T
     C                     DO   *HIVAL
     C                     READ AB#EL92T                 88
     C   88                LEAVE
      * CHECK QTY=0
     C           A9QNTY    IFEQ 0
     C                     ITER
     C                     ENDIF
      * CHECK CREATE DATE
     C           E9CRDT    IFNE KECRDT
     C                     ITER
     C                     ENDIF
      * CHECK TIME
     C           E9CRTM    IFLT KECRTM
     C                     ITER
     C                     ENDIF
      * CHECK SHIP DATE
     C                     EXSR #GETNX
     C           A9PLSH    IFLE TODAY
     C           A9PLSH    ORGT NEXTD
     C                     ITER
     C                     ENDIF
      * CHECK IF EXIST IN PP10
     C                     EXSR #PP10A
      *
     C                     EXSR #PRT1
      *
     C                     ENDDO
      *
     C                     ENDSR
      *======================================================
      * CHECK EDI850 BY EP90
      *======================================================
     C           #850      BEGSR
      *
     C           K#90S     SETLLAB#EL91S
     C                     DO   *HIVAL
     C                     READ AB#EL91S                 88
     C   88                LEAVE
      * CHECK 850, QTY=0
     C           AEQNTY    IFEQ 0
     C           AEEDID    ORNE '850'
     C                     ITER
     C                     ENDIF
      * CHECK CREATE DATE
     C           AECRDT    IFNE KECRDT
     C                     ITER
     C                     ENDIF
      * CHECK TIME
     C           AECRTM    IFLT KECRTM
     C                     ITER
     C                     ENDIF
      * CHECK SHIP DATE
     C                     EXSR #GETNX
     C           AEPLSH    IFLE TODAY
     C           AEPLSH    ORGT NEXTD
     C                     ITER
     C                     ENDIF
      * CHECK IF EXIST IN PP10
     C                     EXSR #PP10B
      *
     C                     EXSR #PRT2
      *
     C                     ENDDO
      *
     C                     ENDSR
      *======================================================
      * GET NEXT SHIP DATE
      *======================================================
     C           #GETNX    BEGSR
      *
     C                     MOVELTODAY     $DT8
     C                     MOVE '+'       $SIGN
     C                     MOVEL'0001'    $DAYS
     C                     MOVE 'Y'       $IAF
     C                     CALL 'UTLR10'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN3   1
      *
     C                     MOVEL$TGT8     NEXTD   80
      *
     C                     ENDSR
      *======================================================
      * DETECT IF ORDER IS IN AB#PP10
      *======================================================
     C           #PP10A    BEGSR
      * GET USER PART
     C                     MOVELA9MHIN    @@MHIN 15
     C                     MOVELA9MHIN    $IN
     C                     CALL 'UTLR73'
     C                     PARM           $IN    30
     C                     PARM           $MHIN  20
     C                     PARM           $MHN1   5
     C                     PARM           $MHN2   5
     C                     PARM           $MHN3   5
     C                     PARM           $MHN4   5
     C                     PARM           $RTN1   1
      * GET NONY
     C                     MOVELA9PLNT    $$PLNT
     C                     MOVELA9SHCD    $$SHCD
     C                     CALL 'UTLR74'
     C                     PARM           $$PLNT  3
     C                     PARM           $$SHCD 10
     C                     PARM           $TOKU   4
     C                     PARM           $NONY   4
     C                     PARM           $RTN2   1
      * SET KEY
     C                     MOVEL$NONY     KANONY
     C                     Z-ADDX9NOYY    KANOYY
     C                     Z-ADDX9NOMM    KANOMM
     C                     Z-ADDX9NODD    KANODD
     C                     MOVEL'00  '    KANUKE
      *
     C                     MOVELA9ODRN    KAODRN
      *
     C                     MOVEL$MHN1     KAMHN1
     C                     MOVEL$MHN2     KAMHN2
     C                     MOVEL$MHN3     KAMHN3
     C                     MOVEL$MHN4     KAMHN4
      *
     C                     Z-ADD0         WQTY    70
     C                     Z-ADD0         WSYOS   60
      *
     C           K#PL1L    SETLLAB#PL1L
     C                     DO   *HIVAL
     C           K#PL1L    READEAB#PL1L                  98
     C   98                LEAVE
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  BASRYO    WQTY
     C                     Z-ADDBASYOS    WSYOS
      *
     C                     ENDDO
      * CHECK FULL QTY?
     C           WSYOS     IFNE 0
     C           A9QNTY    DIV  WSYOS     SHO     70
     C                     MVR            REM     70
     C           REM       IFNE 0
     C                     ADD  1         SHO
     C           SHO       MULT WSYOS     A9QNTY
     C                     ENDIF
     C                     ENDIF
      *
     C           WQTY      IFEQ A9QNTY
J    C                     MOVE 'NO '     WFLG    3
     C                     MOVE '   '     WARW    3
     C                     ELSE
     C                     MOVE '***'     WFLG
     C                     MOVE '-->'     WARW
     C                     ADD  1         CHG#
     C                     ENDIF
      *
     C                     ENDSR
      *======================================================
      * DETECT IF ORDER IS IN AB#PP10
      *======================================================
     C           #PP10B    BEGSR
      * GET USER PART
     C                     MOVELAEMHIN    @@MHIN 15
     C                     MOVELAEMHIN    $IN
     C                     CALL 'UTLR73'
     C                     PARM           $IN    30
     C                     PARM           $MHIN  20
     C                     PARM           $MHN1   5
     C                     PARM           $MHN2   5
     C                     PARM           $MHN3   5
     C                     PARM           $MHN4   5
     C                     PARM           $RTN1   1
      * GET NONY
     C                     MOVELAEPLNT    $$PLNT
     C                     MOVELAESHCD    $$SHCD
     C                     CALL 'UTLR74'
     C                     PARM           $$PLNT  3
     C                     PARM           $$SHCD 10
     C                     PARM           $TOKU   4
     C                     PARM           $NONY   4
     C                     PARM           $RTN2   1
      * SET KEY
     C                     MOVEL$NONY     KANONY
     C                     Z-ADDXENOYY    KANOYY
     C                     Z-ADDXENOMM    KANOMM
     C                     Z-ADDXENODD    KANODD
     C                     MOVEL'00  '    KANUKE
      *
     C                     MOVELAEODRN    KAODRN
      *
     C                     MOVEL$MHN1     KAMHN1
     C                     MOVEL$MHN2     KAMHN2
     C                     MOVEL$MHN3     KAMHN3
     C                     MOVEL$MHN4     KAMHN4
      *
     C                     Z-ADD0         WQTY    70
     C                     Z-ADD0         WSYOS   60
      *
     C           K#PL1L    SETLLAB#PL1L
     C                     DO   *HIVAL
     C           K#PL1L    READEAB#PL1L                  98
     C   98                LEAVE
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  BASRYO    WQTY
     C                     Z-ADDBASYOS    WSYOS
      *
     C                     ENDDO
      * CHECK FULL QTY?
     C           WSYOS     IFNE 0
     C           AEQNTY    DIV  WSYOS     SHO     70
     C                     MVR            REM     70
     C           REM       IFNE 0
     C                     ADD  1         SHO
     C           SHO       MULT WSYOS     AEQNTY
     C                     ENDIF
     C                     ENDIF
      *
     C           WQTY      IFEQ AEQNTY
J    C                     MOVE 'NO '     WFLG    3
     C                     MOVE '   '     WARW    3
     C                     ELSE
     C                     MOVE '***'     WFLG
     C                     MOVE '-->'     WARW
     C                     ADD  1         CHG#
     C                     ENDIF
      *
     C                     ENDSR
      *======================================================
      * PRINT
      *======================================================
     C           #PRT1     BEGSR
      * HEADER
     C           LIN#      IFGE 66
     C                     EXCPT@HDR1
     C                     Z-ADD4         LIN#
     C                     ENDIF
      * BREAK ?
     C           SVCRTM    IFEQ 0
     C                     Z-ADDE9CRTM    SVCRTM
     C                     ENDIF
     C           SVCRTM    IFNE E9CRTM
     C                     EXCPT@BRK1
     C                     ADD  1         LIN#
     C                     Z-ADDE9CRTM    SVCRTM
     C                     ENDIF
      * ADJUST
     C                     MOVELKAODRN    XXODRN 11
JW2  C           A9QNTY    SUB  WQTY      WDIS    70
      * DETAIL
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL1
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *======================================================
      * PRINT
      *======================================================
     C           #PRT2     BEGSR
      * HEADER
     C           LIN#      IFGE 66
     C                     EXCPT@HDR1
     C                     Z-ADD4         LIN#
     C                     ENDIF
      * BREAK ?
     C           SVCRTM    IFEQ 0
     C                     Z-ADDAECRTM    SVCRTM
     C                     ENDIF
     C           SVCRTM    IFNE AECRTM
     C                     EXCPT@BRK1
     C                     ADD  1         LIN#
     C                     Z-ADDAECRTM    SVCRTM
     C                     ENDIF
      * ADJUST
     C                     MOVELKAODRN    XXODRN 11
JW2  C           AEQNTY    SUB  WQTY      WDIS    70
      * DETAIL
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL2
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C           K#90S     KLIST
     C                     KFLD           KECRDT  80
     C                     KFLD           KECRTM  60
      *
     C           K#92S     KLIST
     C                     KFLD           K#ODRN 20
     C                     KFLD           K#CRDT  80
     C                     KFLD           K#CRTM  60
     C                     KFLD           K#EDID  3
     C                     KFLD           K#PLNT  3
     C                     KFLD           K#SHCD 10
     C                     KFLD           K#MHIN 30
      *
     C           K#PL1L    KLIST
     C                     KFLD           KANONY  40
     C                     KFLD           KANOYY  40
     C                     KFLD           KANOMM  20
     C                     KFLD           KANODD  20
     C                     KFLD           KANUKE  4
     C                     KFLD           KAODRN 10
     C                     KFLD           KAMHN1  5
     C                     KFLD           KAMHN2  5
     C                     KFLD           KAMHN3  5
     C                     KFLD           KAMHN4  5
      *
     C                     MOVE *BLANK    $RTN
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD0         CHG#    40
     C                     Z-ADD0         SVCRTM  60
     C                     TIME           SDATE
      *
     C                     Z-ADDTODAY     KECRDT
J    C                     Z-ADD123000    KECRTM
      * PRINT HEADER
     C                     EXCPT@HDR1
     C                     MOVE *OFF      *IN85
     C                     Z-ADD4         LIN#    30
      *
     C                     ENDSR
      *====================================================
     OQPRINT  E   01           @HDR1
     O                                    1 '.'
     O        E   02           @HDR1
     O                         #PGM      10
     O                                   40 '<< HONDA LATE EDI OR'
J    O                                   60 'DER AFTER 12:30 REPO'
     O                                   67 'RT >>  '
     O                                  109 'DATE'
     O                         TODAY    112 '    /  /  '
     O                         NOW      122 '  :  :  '
     O                                  126 'P.'
     O                         PAGE  Z  130
     O        E   03           @HDR1
     O                                    5 'SEQ#'
     O                                   15 'RCV DATE'
     O                                   23 'TIME'
     O                                   33 'DELV#'
     O                                   43 'SHIP DATE'
     O                                   52 'ORDER#'
     O                                   67 'USER PART'
     O                                   79 'PLANT'
     O                                   88 'SHIP TO'
     O                                  100 'CURR QTY'
J    O                                  116 'REQUEST'
     O                                  121 'CHG'
JW2  O                                  131 'DISCRE.'
     O        E   04           @HDR1
     O                                    5 '----'
     O                                   15 '--------'
     O                                   23 '----'
     O                                   33 '-----'
     O                                   43 '---------'
     O                                   52 '------'
     O                                   72 '--------------'
     O                                   79 '-----'
     O                                   88 '-------'
     O                                  100 '--------'
     O                                  116 '-------'
     O                                  121 '---'
JW2  O                                  131 '-------'
      *
     O        E 1              @DTL1
     O                         SEQ#  Z +001
     O                         E9CRDT  +002 '    /  /  '
     O                         E9CRTM  +001 '0 :  :  '
     O                         $NONY   +002
     O                         A9PLSH  +002 '    /  /  '
     O                         XXODRN  +002
     O                         @@MHIN  +001
     O                         A9PLNT  +002
     O                         A9SHCD  +003
     O                         WQTY  1 +000
     O                         WARW    +002
     O                         A9QNTY1 +000
     O                         WFLG    +002
JW2  O                         WDIS  O +000
      *
     O        E 1              @DTL2
     O                         SEQ#  Z +001
     O                         AECRDT  +002 '    /  /  '
     O                         AECRTM  +001 '0 :  :  '
     O                         $NONY   +002
     O                         AEPLSH  +002 '    /  /  '
     O                         XXODRN  +002
     O                         @@MHIN  +001
     O                         AEPLNT  +002
     O                         AESHCD  +003
     O                         WQTY  1 +000
     O                         WARW    +002
     O                         AEQNTY1 +000
     O                         WFLG    +002
JW2  O                         WDIS  O +000
      *
      *
     O        E 1              @FOT1
     O                                    1 '.'
     O        E 1      85      @FOT1
     O                                 +001 '** THERE IS NO ORDE'
     O                                 +000 'R TO REPORT...     '
     O        E 1              @FOT1
     O                                 +001 '** END OF REPORT **'
     O                                 +005 '(CHANGED ORDER:'
     O                         CHG#  1 +001
     O                                 +001 ')'
      *
     O        E 1              @BRK1
     O                                    1 '.'
