     C                     ENDSR
      *******************************************************
      *  RETRIEVAL KANBAN QTY                               *
      *******************************************************
     C           #RQTY     BEGSR
      *
JW3   * RETRIEVAL KANBAN BY MACHINE
     C                     Z-ADD0         RQT
     C           1         DO   7         IX      20
     C           MQT,IX    IFEQ 0
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADD0         RQTY    30
      * DAILY SET
     C           HST,IX    DIV  20        DSETW   80
     C                     MVR            REM     30
     C           REM       IFGT 0
     C                     ADD  1         DSETW
     C                     ENDIF
      * / UW --> DUW
     C           S2COIL    IFEQ 0
     C                     Z-ADDDSETW     DUW     80
     C                     ELSE
     C           DSETW     DIV  S2COIL    DUW
     C                     MVR            REM
     C           REM       IFGT 0
     C                     ADD  1         DUW
     C                     ENDIF
     C                     ENDIF
      * IF RQTY <= 3 AND S2MAX >= 3 --> RQTY=3
     C           DUW       IFLT 2
     C                     Z-ADD3         RQTY
     C                     ELSE
     C                     Z-ADDDUW       RQTY
     C                     ENDIF
      * MAX 12
     C           RQTY      IFGT 12
     C                     Z-ADD12        RQTY
     C                     ENDIF
      * MINIMUM 1
     C           RQTY      IFLT 1
     C                     Z-ADD1         RQTY
     C                     ENDIF
      *
     C                     Z-ADDRQTY      RQT,IX
     C                     ENDDO
      *
      **IF DUW <  MCN# --> RQTY=MCN#
      **IF DUW >= MCN# --> RQTY=DUW
     C**         DUW       IFLT MQT,IX
     C**                   Z-ADDMQT,IX    RQT,IX
     C**                   ELSE
     C**                   Z-ADDDUW       RQT,IX
     C**                   ENDIF
      **
     C**                   ENDDO
      * AREA
     C                     EXSR #AREA
      *
     C                     ENDSR
      *------------------------------------------------------
      *  ADJUST AREA QTY
      *------------------------------------------------------
     C           #AREA     BEGSR
      *
     C                     XFOOTRQT       RQTTL   30
      *
     C           RQTTL     SUB  S2MAX     DIFF    30
      *
     C           DIFF      IFEQ 0
     C                     GOTO XAREA
     C                     ENDIF
      *
      * IF RQTTL > S2MAX  --> ADJ (-)
     C           DIFF      IFGE 1
     C                     EXSR #SETJ
      *
     C                     Z-ADD0         IA      30
     C                     Z-ADD0         IB      30
     C                     Z-ADD0         IC      30
     C                     DO   *HIVAL
     C                     ADD  1         IA
     C           IA        IFGE 8
     C                     Z-ADD1         IA
     C                     ENDIF
      *
     C                     Z-ADD1         IB
     C           IA        LOKUPJQT,IB                   94
     C           *IN94     IFEQ *ON
     C                     SUB  1         RQT,IB
     C                     ADD  1         IC
     C                     ENDIF
      *
     C           IC        IFGE DIFF
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C           XAREA     ENDSR
      *------------------------------------------------------
      *  SET SEQUENCE#
      *------------------------------------------------------
     C           #SETJ     BEGSR
      *
     C                     Z-ADD0         JQT
     C                     Z-ADDMQT       WQT
     C                     Z-ADD0         IY      30
     C           1         DO   7         IX
     C                     EXSR #GETS
     C           IY        IFEQ 0
     C                     LEAVE
     C                     ELSE
     C                     Z-ADDIX        JQT,IY
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      * GET SMALLEST MACHIN#
      *------------------------------------------------------
     C           #GETS     BEGSR
     C                     Z-ADD0         IY
      * MQT,7
     C           WQT,7     IFGE 1
      *
     C           WQT,1     IFNE 0
     C           WQT,7     ANDLEWQT,1
      *
     C           WQT,2     IFNE 0
     C           WQT,7     ANDLEWQT,2
      *
     C           WQT,3     IFNE 0
     C           WQT,7     ANDLEWQT,3
      *
     C           WQT,4     IFNE 0
     C           WQT,7     ANDLEWQT,4
      *
     C           WQT,5     IFNE 0
     C           WQT,7     ANDLEWQT,5
      *
     C           WQT,6     IFNE 0
     C           WQT,7     ANDLEWQT,6
     C           WQT,1     OREQ 0
     C           WQT,2     ANDEQ0
     C           WQT,3     ANDEQ0
     C           WQT,4     ANDEQ0
     C           WQT,5     ANDEQ0
     C           WQT,6     ANDEQ0
     C                     Z-ADD7         IY
     C                     GOTO XGETS
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      * MQT,6
     C           WQT,6     IFGE 1
      *
     C           WQT,1     IFNE 0
     C           WQT,6     ANDLEWQT,1
      *
     C           WQT,2     IFNE 0
     C           WQT,6     ANDLEWQT,2
      *
     C           WQT,3     IFNE 0
     C           WQT,6     ANDLEWQT,3
      *
     C           WQT,4     IFNE 0
     C           WQT,6     ANDLEWQT,4
      *
     C           WQT,5     IFNE 0
     C           WQT,6     ANDLEWQT,5
     C           WQT,1     OREQ 0
     C           WQT,2     ANDEQ0
     C           WQT,3     ANDEQ0
     C           WQT,4     ANDEQ0
     C           WQT,5     ANDEQ0
     C                     Z-ADD6         IY
