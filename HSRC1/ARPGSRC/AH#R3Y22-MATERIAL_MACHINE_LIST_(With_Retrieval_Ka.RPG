      * SET ERROR MSG WHEN RRN2=0
     C           RRN2      IFEQ 0
     C                     Z-ADD1         RRN2
     C                     MOVELERR,3     S@ZAIS
     C                     WRITESFL02
     C                     ENDIF
      *
