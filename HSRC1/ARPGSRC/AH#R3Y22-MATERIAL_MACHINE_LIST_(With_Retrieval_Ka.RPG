     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      * MQT,5
     C           WQT,5     IFGE 1
      *
     C           WQT,1     IFNE 0
     C           WQT,5     ANDLEWQT,1
      *
     C           WQT,2     IFNE 0
     C           WQT,5     ANDLEWQT,2
      *
     C           WQT,3     IFNE 0
     C           WQT,5     ANDLEWQT,3
      *
     C           WQT,4     IFNE 0
     C           WQT,5     ANDLEWQT,4
     C           WQT,1     OREQ 0
     C           WQT,2     ANDEQ0
     C           WQT,3     ANDEQ0
     C           WQT,4     ANDEQ0
     C                     Z-ADD5         IY
     C                     GOTO XGETS
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      * MQT,4
     C           WQT,4     IFGE 1
      *
     C           WQT,1     IFNE 0
     C           WQT,4     ANDLEWQT,1
      *
     C           WQT,2     IFNE 0
     C           WQT,4     ANDLEWQT,2
      *
     C           WQT,3     IFNE 0
     C           WQT,4     ANDLEWQT,3
     C           WQT,1     OREQ 0
     C           WQT,2     ANDEQ0
     C           WQT,3     ANDEQ0
     C                     Z-ADD4         IY
     C                     GOTO XGETS
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      * MQT,3
     C           WQT,3     IFGE 1
      *
     C           WQT,1     IFNE 0
     C           WQT,3     ANDLEWQT,1
      *
     C           WQT,2     IFNE 0
     C           WQT,3     ANDLEWQT,2
     C           WQT,1     OREQ 0
     C           WQT,2     ANDEQ0
     C                     Z-ADD3         IY
     C                     GOTO XGETS
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      * MQT,2
     C           WQT,2     IFGE 1
      *
     C           WQT,1     IFNE 0
     C           WQT,2     ANDLEWQT,1
     C           WQT,1     OREQ 0
     C                     Z-ADD2         IY
     C                     GOTO XGETS
     C                     ENDIF
     C                     ENDIF
      * MQT,7
     C           WQT,7     IFGE 1
     C           WQT,1     ANDEQ0
     C           WQT,2     ANDEQ0
     C           WQT,3     ANDEQ0
     C           WQT,4     ANDEQ0
     C           WQT,5     ANDEQ0
     C           WQT,6     ANDEQ0
     C                     Z-ADD7         IY
     C                     GOTO XGETS
     C                     ENDIF
      * MQT,6
     C           WQT,6     IFGE 1
     C           WQT,1     ANDEQ0
     C           WQT,2     ANDEQ0
     C           WQT,3     ANDEQ0
     C           WQT,4     ANDEQ0
     C           WQT,5     ANDEQ0
     C                     Z-ADD6         IY
     C                     GOTO XGETS
     C                     ENDIF
      * MQT,5
     C           WQT,5     IFGE 1
     C           WQT,1     ANDEQ0
     C           WQT,2     ANDEQ0
     C           WQT,3     ANDEQ0
     C           WQT,4     ANDEQ0
     C                     Z-ADD5         IY
     C                     GOTO XGETS
     C                     ENDIF
      * MQT,4
     C           WQT,4     IFGE 1
     C           WQT,1     ANDEQ0
     C           WQT,2     ANDEQ0
     C           WQT,3     ANDEQ0
     C                     Z-ADD4         IY
     C                     GOTO XGETS
     C                     ENDIF
      * MQT,3
     C           WQT,3     IFGE 1
     C           WQT,1     ANDEQ0
     C           WQT,2     ANDEQ0
     C                     Z-ADD3         IY
     C                     GOTO XGETS
     C                     ENDIF
      * MQT,2
     C           WQT,2     IFGE 1
     C           WQT,1     ANDEQ0
     C                     Z-ADD2         IY
     C                     GOTO XGETS
     C                     ENDIF
      * MQT,1
     C           WQT,1     IFGE 1
     C                     Z-ADD1         IY
     C                     GOTO XGETS
     C                     ENDIF
      *
     C           XGETS     TAG
     C           IY        IFNE 0
     C                     Z-ADD0         WQT,IY
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  MACHINE USAGE
      *------------------------------------------------------
     C           #MCN      BEGSR
      * RESET PARAMETER
     C                     Z-ADD0         MQT
     C                     Z-ADD0         HST
     C                     Z-ADD0         IY      30
     C                     MOVEA*BLANK    MCN
      *
      * READ ZAPL10 (WIRE/PART MASTER)
     C           K#IZ10    SETLLIZAPL10
     C                     DO   *HIVAL
     C           K#IZ10    READEIZAPL10                  91
     C   91                LEAVE
      *
     C           ZBSKJY    IFEQ 'D'
     C           ZBSKHZ    ANDLED@DATE
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELZBSHN1    K#SHN1
     C                     MOVELZBSHN2    K#SHN2
     C                     MOVELZBSHN3    K#SHN3
     C           K#11      SETLLAAMPL11
     C                     DO   *HIVAL
     C           K#11      READEAAMPL11                  98
     C   98                LEAVE
      * GET HD/BM/NF
     C           CKKO01    IFEQ 'HD '
     C           CKKO01    OREQ 'BM '
     C           CKKO01    OREQ 'NF '
      * GET SIZE
     C                     MOVELCKKB01    K#MANO
     C                     MOVE *BLANK    K#LOCT
     C           K#7G      CHAINABBPP7G              96
     C   96                MOVE *BLANK    K#MANO
     C   96                MOVELCKNB01    K#LOCT
     C   96      K#7G      CHAINABBPP7G              97
     C           *IN96     IFEQ *OFF
     C           *IN97     OREQ *OFF
      * MONTHLY SET
     C                     SELEC
     C           A#SIZE    WHEQ 'M6 '
     C*                    ADD  1         MQT,1
     C                     ADD  ZBMSJR    HST,1
     C           A#SIZE    WHEQ 'M8 '
     C                     ADD  ZBMSJR    HST,2
     C           A#SIZE    WHEQ 'M10'
     C                     ADD  ZBMSJR    HST,3
     C           A#SIZE    WHEQ 'TS '
     C                     ADD  ZBMSJR    HST,4
     C           A#SIZE    WHEQ 'E/G'
     C                     ADD  ZBMSJR    HST,5
     C           A#SIZE    WHEQ 'H/V'
     C                     ADD  ZBMSJR    HST,6
     C           A#SIZE    WHEQ 'NUT'
     C                     ADD  ZBMSJR    HST,7
     C                     ENDSL
      * CHECK MACHINE#
     C                     Z-ADD1         XX      30
     C           CKKB01    LOKUPMCN,XX                   95
     C           *IN95     IFEQ *OFF
     C                     ADD  1         IY
     C                     MOVELCKKB01    MCN,IY
     C                     SELEC
     C           A#SIZE    WHEQ 'M6 '
     C                     ADD  1         MQT,1
     C           A#SIZE    WHEQ 'M8 '
     C                     ADD  1         MQT,2
     C           A#SIZE    WHEQ 'M10'
     C                     ADD  1         MQT,3
     C           A#SIZE    WHEQ 'TS '
     C                     ADD  1         MQT,4
     C           A#SIZE    WHEQ 'E/G'
     C                     ADD  1         MQT,5
     C           A#SIZE    WHEQ 'H/V'
     C                     ADD  1         MQT,6
     C           A#SIZE    WHEQ 'NUT'
     C                     ADD  1         MQT,7
     C                     ENDSL
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
     C                     ENDDO
      *
     C                     ENDSR
