     H            Y.
     F** ABMR51 *********************************************
     F* NO SHIPMENT M/F LITS
     F*    HOTTA.               2018.08.07                  *
     F*******************************************************
     FABBPL06 IF  E           K        DISK
     FGADPL11 IF  E           K        DISK
     FABMWP51 O   E                    DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
      *
     I            DS
     I                                        1   80W@DATE
     I                                        1   60W@DTYM
     I                                        1   40W@DTYY
     I                                        5   60W@DTMM
     I                                        7   80W@DTDD
      *
     I            DS
     I                                        1   8 CTIHZ
     I                                        1   2 CTIMM
     I                                        3   4 CTIDD
     I                                        5   8 CTIYY
      *
     I              'NO SHIPMENT ERROR'   C         FNAM1
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P@DTYM  60
     C                     PARM           P@FNAM 30
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
     C                     TIME           WTIME
     C                     MOVE WTIMM     CTIMM
     C                     MOVE WTIDD     CTIDD
     C                     MOVE WTIYY     CTIYY
     C                     MOVEL*BLANK    P@FNAM
     C                     MOVELFNAM1     P@FNAM
     C*****      FNAM1     CAT  CTIHZ:1   P@FNAM
      *
     C           KEYQ5     KLIST
     C                     KFLD           K@DTYM  60
     C                     Z-ADDP@DTYM    K@DTYM
     C           KEYQ5     SETLLABBPL061
     C           KEYQ5     READEABBPL061                 80
     C           *IN80     DOWEQ'0'
     C                     EXSR #SB400
     C           KEYQ5     READEABBPL061                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------------------------*
      * FORECAST                                    *
      *---------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C           KEYS2     KLIST
     C                     KFLD           Q5TOKU
     C                     KFLD           Q5NONY
     C                     KFLD           Q5NKOJ
     C                     KFLD           Q5NUKE
      *
     C           KEYS3     KLIST
     C                     KFLD           Q5TOKU
     C                     KFLD           Q5NONY
     C                     KFLD           Q5NKOJ
      *
     C           KEYS4     KLIST
     C                     KFLD           Q5TOKU
     C                     KFLD           Q5NONY
      *
     C                     MOVEL'0'       GET     1
     C           KEYS4     SETLLGADPL111
     C           KEYS4     READEGADPL111                 21
     C           *IN21     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           B5SKJY    IFEQ 'D'
     C           B5SKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR $SB222
     C                     ENDIF
     C           KEYS4     READEGADPL111                 21
     C                     ENDDO
      *
     C           GET       IFEQ '0'
     C                     CLEARABMWP511
     C                     Z-ADDQ5TOKU    W1TOKU
     C                     Z-ADDQ5NONY    W1NONY
     C                     MOVELQ5NKOJ    W1NKOJ
     C                     MOVELQ5NUKE    W1NUKE
     C                     MOVELQ5MHN1    W1MHN1
     C                     MOVELQ5MHN2    W1MHN2
     C                     MOVELQ5MHN3    W1MHN3
     C                     MOVELQ5MHN4    W1MHN4
     C                     MOVELQ5SHN1    W1SHN1
     C                     MOVELQ5SHN2    W1SHN2
     C                     MOVELQ5SHN3    W1SHN3
     C                     WRITEABMWP511
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      * CHK                                                *
      *----------------------------------------------------*
     CSR         $SB222    BEGSR
      *
     C                     MOVEL'0'       GETK    1
     C           Q5NKOJ    IFEQ *BLANK
     C                     MOVEL'1'       GETK
     C                     ELSE
     C           B5NKOJ    IFEQ Q5NKOJ
     C                     MOVEL'1'       GETK
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVEL'0'       GETU    1
     C           Q5NUKE    IFEQ *BLANK
     C                     MOVEL'1'       GETU
     C                     ELSE
     C           B5NUKE    IFEQ Q5NUKE
     C                     MOVEL'1'       GETU
     C                     ENDIF
     C                     ENDIF
      *
     C           GETK      IFEQ '1'
     C           GETU      ANDEQ'1'
     C                     MOVEL'1'       GET
     C                     ENDIF
      *
     CSR         $S222E    ENDSR
