     H            Y.                                                      EER050
     F** GBFR32 ********************************************
     F* ESTIMATE PART NAME M/F ACCOUNT BOOK < SALES UNIT PRICE ESTIMATE> *
     F*            M-OKUDA          1985.11.18             *
     F******************************************************
     FGBFPL31 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FGBFPR32 O   E                    PRINTER
     E                    MD      1   1 18               vjﾞﾆ
     E                    MS      1   2 10               xbﾆﾑc
     I            DS
     I                                        1   80UHIZK
     I                                        1   40UYY
     I                                        5   80UMD
     I            DS
     I                                        1   80MDYY
     I                                        1   40AMD
     I                                        5   80AYY
     C******************************************************
     C* M-NO               ﾌﾟ[x-j- ﾉ cinﾒ                  *
     C******************************************************
     C           *ENTRY    PLIST
     C                     PARM           USER   10
     C                     PARM           PTOKU   4
     C                     PARM           PTKOJ   1
     C                     MOVE PTOKU     UTOKU   40
     C                     MOVE *BLANK    TMEIG  16
     C                     Z-ADD*DATE     UHIZK
     C                     Z-ADDUYY       AYY
     C                     Z-ADDUMD       AMD
     C                     Z-ADD0         BTOKU   40
     C                     MOVE *BLANK    BTKOJ   1
     C                     MOVE MD,1      HD     18
     C                     SETOF                     04
     C           UTOKU     CHAINFGBPL011             04
     C           *IN04     IFEQ '0'
     C           B2SKJY    IFNE 'D'
     C                     MOVELB2SMEI    TMEIG
     C                     END
     C                     END
     C******************************************************
     C* M-NO               mﾞ-jﾈln & ﾑvﾃv                  *
     C******************************************************
     C                     SETOF                     05
     C           MKEY      KLIST
     C                     KFLD           BTOKU
     C                     KFLD           BTKOJ
     C                     KFLD           HKBN
     C                     KFLD           MCOD
     C                     MOVE *BLANK    HKBN    1
     C                     MOVE *BLANK    MCOD    2
     C           MKEY      SETLLGBFPL311
     C           STEP01    TAG
     C                     READ GBFPL31                  05
     C           *IN05     CABEQ'1'       END
     C           G8SKJY    CABEQ'D'       STEP01
     C*          G8TOKU    CABNEUTOKU     END
     C*          G8TKOJ    CABNEPTKOJ     END
     C           KBUHN     IFNE G8BUHN
     C                     SETON                     01
     C                     MOVE G8BUHN    KBUHN   1
     C                     EXSR MSYO
     C                     WRITEGBFPR321
     C                     Z-ADD0         P
     C                     END
     C           P         IFGT 50
     C                     WRITEGBFPR321
     C                     Z-ADD0         P       20
     C                     END
     C                     WRITEGBFPR322
     C           P         ADD  1         P
     C                     GOTO STEP01
     C           END       TAG
     C                     SETON                     LR
     C******************************************************
     C* M-NO               xbﾆﾑchﾎﾞ] ﾉ pﾏcﾒﾑh ﾅﾎﾞﾓ-k]      *
     C******************************************************
     C           MSYO      BEGSR
     C                     MOVE *BLANK    TYPE   10
     C           G8BUHN    IFEQ 'B'
     C                     MOVE MS,1      TYPE
     C                     GOTO STEPS1
     C                     ELSE
     C           G8BUHN    IFEQ 'K'
     C                     MOVE MS,2      TYPE
     C                     END
     C                     END
     C           STEPS1    TAG
     C                     ENDSR
**            TITLE
ESTIMATE PART NAME
**            TITLE
CPLT PART
COMPT
