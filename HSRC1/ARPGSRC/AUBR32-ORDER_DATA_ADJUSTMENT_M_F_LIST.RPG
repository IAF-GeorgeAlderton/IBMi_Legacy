     H            Y.
      ***************************************************************
      *  PROGRAM NAME.  : ORDERING DATA ADJUSTMENT M/F LIST         *
      *  PROGRAM ID.    : AUBR32.      <RPG>                        *
      *  CREATE DATE.   : MAR.13'86.                                *
      *  AUTHOR.        : E.KAWASHIMA                               *
      ***************************************************************
     FAUBPL31 IP  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FGADPL11 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     I            DS
     I                                        1  14 HINBAN
     I                                        1   5 CEHIN1
     I                                        6   6 HINA
     I                                        7  11 CEHIN2
     I                                       12  12 HINB
     I                                       13  14 CEHIN3
     I*
     I            DS
     I                                        3  10 YYYYYY
     I                                        1   40CESTYY
     I                                        5   5 Y1
     I                                        6   70CESTMM
     I                                        8   8 Y2
     I                                        9  100CESTDD
     I*
     I            DS
     I                                        3  10 ZZZZZZ
     I                                        1   40CEENYY
     I                                        5   5 Z1
     I                                        6   70CEENMM
     I                                        8   8 Z2
     I                                        9  100CEENDD
     I*
     I            DS
     I                                        1   80CESKHZ
     I                                        1   40CESKYY
     I                                        5   60CESKMM
     I                                        7   80CESKDD
     I*
     C                     SETOF                     0102
     C  N03                TIME           WTIME   60
     C  N03                SETON                     0203
     C           CESKJY    IFEQ 'D'
     C           CESKHZ    IFLE *DATE
     C                     GOTO STEP99
     C                     END
     C                     END
     C*
     C                     MOVEL'-'       HINA
     C                     MOVEL'-'       HINB
     C                     MOVEL'.'       Y1
     C                     MOVEL'.'       Y2
     C                     MOVEL'.'       Z1
     C                     MOVEL'.'       Z2
     C                     TIME           WTIME
     C*
     C           CETOKU    CHAINFGBPL011             10
     C           *IN,10    IFEQ '0'
     C                     MOVELB2SMEI    AAAAAA 16
     C                     ELSE
     C                     MOVEL*BLANK    AAAAAA
     C                     END
     C*
     C           CENONY    CHAINFGBPL011             11
     C           *IN,11    IFEQ '0'
     C                     MOVELB2SMEI    BBBBBB 16
     C                     ELSE
     C                     MOVEL*BLANK    BBBBBB
     C                     END
     C*
     C           KEY1      KLIST
     C                     KFLD           CETOKU
     C                     KFLD           CENONY
     C                     KFLD           CENKOJ
     C                     KFLD           CENUKE
     C           KEY1      CHAINGADPL111             12
     C           *IN,12    IFEQ '0'
     C                     MOVELB5KMEI    CCCCCC 24
     C                     ELSE
     C                     MOVEL*BLANK    CCCCCC
     C                     END
     C*
     C                     SETON                     01
     C           STEP99    TAG
     OQPRINT  H  102   1P
     O       OR        OF
     O                                  131 '+-------------------+'
     O        H  1     1P
     O       OR        OF
     O                                  131 '|         |         |'
     O        H  1     1P
     O       OR        OF
     O                                   89 'TIME'
     O                         WTIME     98 '  :  :  '
     O                                  131 '|         |         |'
     O        H  2     1P
     O       OR        OF
     O                                   12 'AUBR32-1 '
     O                                   28 '      '
     O                                   35 'A-PICS'
     O                                   49 'ORDERING DATA'
     O                                   72 'ADJUSTMENT M/F ACCOUNT'
     O                                   77 'BOOK'
     O                                   89 'DATE'
     O                         UDATE Y   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O                                  131 '+-------------------+'
 2   O        H  2     02
     O       OR        OF
     O                                   18 'INT CO. PART NO'
     O                                   28 'CUSTOMER'
     O                                   50 'F   RCV'
     O                                   67 'RECEIVING CO.'
     O                                   85 'FACTORY'
     O                                  111 'RECEIVING'
     O                                  132 'START DATE EXIT DATE'
     O        D  1     01
     O                         HINBAN    17
     O                         CETOKU    24
     O                         AAAAAA    42
     O                         CETKOJ    44
     O                         CETUKE    51
     O                         CENONY    58
     O                         BBBBBB    77
     O                         CENKOJ    79
     O                         CCCCCC   105
     O                         CENUKE   110
     O                         YYYYYY   121
     O                         ZZZZZZ   131
