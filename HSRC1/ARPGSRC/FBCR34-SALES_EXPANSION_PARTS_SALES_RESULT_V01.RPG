     H            Y.
     F** FBCR34 ************************************
     A*   SALES EXPANSION PARTS SALES RESULT       *
     F*   T.SAKAKI                2016.07.20       *
     F************************************ FBCR34 **
     FFBCPW31 CF  E                    WORKSTN
     FFBCPL20 IF  E           K        DISK
     F            FBCPP201                          KRENAMEFBC22R
     FFBCPP25 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FAB#PL0T IF  E           K        DISK
     F** CSV DATA
     FFBCWP31 O   F     210            DISK
      *---------------------------------------------------------------
     E                    MSG     1   3 78
      *---------------------------------------------------------------
     I            DS
     I                                        1   80W@YMD
     I                                        1   40W@YY
     I                                        5   60W@MM
     I                                        7   80W@DD
     I                                        1   60W@YM
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *----------------------------------------------------*
      *   ENTRY     L  I  S  T                             *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           PDEST  50
      *----------------------------------------------------*
      *   MAIN                                             *
      *----------------------------------------------------*
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVELD@DEST    PDEST
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------------*
      * INITIALIZE                                         *
      *----------------------------------------------------*
     C           *INZSR    BEGSR
      *
     C           K#AGD     KLIST
     C                     KFLD           W@YY
     C                     KFLD           W@MM
     C           K#GAD     KLIST
     C                     KFLD           K@TOKU  40
     C                     KFLD           K@NONY  40
     C           K#GAD1    KLIST
     C                     KFLD           K@TOKU  40
     C                     KFLD           K@NONY  40
     C                     KFLD           K@NKOJ  1
     C           K#GAD2    KLIST
     C                     KFLD           K@TOKU  40
     C                     KFLD           K@NONY  40
     C                     KFLD           K@NKOJ  1
     C                     KFLD           K@NUKE  4
     C           K#FBC2    KLIST
     C                     KFLD           F2MHN1
     C                     KFLD           F2MHN2
     C                     KFLD           F2MHN3
     C                     KFLD           F2MHN4
     C                     KFLD           F2TOKU
      *
     C           K#AB      KLIST
     C                     KFLD           F2TOKU
     C                     KFLD           F2MHN1
     C                     KFLD           F2MHN2
     C                     KFLD           F2MHN3
     C                     KFLD           F2MHN4
     C                     KFLD           W@YY
     C                     KFLD           W@MM
      *
     C                     MOVE '01'      @@ID    2
     C                     MOVE *ALL'-'   @@LIN 132
      *
     C                     MOVELPDEST     D@DEST
      *
     C                     ENDSR
      *----------------------------------------------------*
      *   1ST SCREEN                                       *
      *----------------------------------------------------*
     C           #SCRN1    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #PRT
     C                     MOVE '99'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  CHECK
      *----------------------------------------------------*
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
      * USER ID
     C           D@SLPS    IFNE *BLANK
     C           D@SLPS    CHAINFBCPL20              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     MOVE MSG,2     D@MSG
     C                     ENDIF
     C                     ENDIF
     C           D@YYMM    IFEQ *ZERO
     C  N99                MOVE MSG,1     D@MSG
     C                     SETON                     6299
     C                     ENDIF
      *
     C                     Z-ADDD@YYMM    W@YM
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C  N99                MOVE MSG,1     D@MSG
     C                     SETON                     6299
     C                     ENDIF
      *
     C           D@DEST    IFEQ *BLANK
     C  N99                MOVE MSG,3     D@MSG
     C                     SETON                     6399
     C                     ENDIF
      *
     C                     ENDSR
      *---------------------------------------------------
      *  OUTPUT
      *---------------------------------------------------
     C           #PRT      BEGSR
      *
     C                     EXCPT@@HED
      *
     C                     TIME           @@TIME  60
     C                     Z-ADD1         W@DD
     C                     Z-ADDW@YMD     W@STRT  80
     C                     Z-ADD31        W@DD
     C                     Z-ADDW@YMD     W@END   80
      *
     C                     MOVE *BLANK    @@SLPS 10
     C                     Z-ADD*ZERO     @@TOKU  40
     C                     Z-ADD*ZERO     @@GTOT 110
     C                     Z-ADD*ZERO     @@GAMT 132
     C                     Z-ADD*ZERO     @@CNT   50
     C                     Z-ADD*ZERO     @@CAMT 112
     C                     Z-ADD*ZERO     @@CTOT  90
     C                     Z-ADD*ZERO     @@SAMT 112
     C                     Z-ADD*ZERO     @@STOT  90
     C           D@SLPS    SETLLFBCPL20
     C           *IN80     DOUEQ*ON
     C           D@SLPS    IFNE *BLANK
     C           D@SLPS    READEFBCPL20                  80
     C                     ELSE
     C                     READ FBCPL20                  80
     C                     ENDIF
      *
1    C           *IN80     IFEQ *OFF
|     *
|2   C           F2SKJY    IFEQ 'D'
||   C           F2SYMD    ANDLE*DATE
||   C                     ITER
|2   C                     ENDIF
|     *
|2   C           F2STYM    IFLE D@YYMM
||   C           F2ENYM    ANDGED@YYMM
||    *
||3  C           F2SLSP    IFNE @@SLPS
|||4 C           @@SLPS    IFNE *BLANK
|||| C                     Z-ADD*ZERO     @@CAMT 112
|||| C                     Z-ADD*ZERO     @@CTOT  90
|||| C                     Z-ADD*ZERO     @@SAMT 112
|||| C                     Z-ADD*ZERO     @@STOT  90
|||4 C                     ENDIF
|||   *
|||  C                     MOVE F2SLSP    @@SLPS
||3  C                     ELSE
|||4 C           @@TOKU    IFNE *ZERO
|||| C           @@TOKU    ANDNEF2TOKU
|||| C                     Z-ADD*ZERO     @@CAMT 112
|||| C                     Z-ADD*ZERO     @@CTOT  90
|||4 C                     ENDIF
||3  C                     ENDIF
||    *
||   C                     Z-ADDF2TOKU    @@TOKU
||    *
||   C                     MOVE *BLANK    @@DSC  15
||   C           F2CLAS    CHAINFBCPP25              95
||3  C           *IN95     IFEQ *OFF
|||  C                     MOVELF5DESC    @@DSC
||3  C                     ENDIF
||    *
||   C                     EXSR #ACT
||   C                     EXCPT@@DTL
||   C                     ADD  1         @@CNT
||   C                     ADD  @@ACT     @@GTOT
||   C                     ADD  @@AMT     @@GAMT 132
||   C                     ADD  @@AMT     @@CAMT 112
||   C                     ADD  @@ACT     @@CTOT  90
||   C                     ADD  @@AMT     @@SAMT 112
||   C                     ADD  @@ACT     @@STOT  90
||    *
|2   C                     ENDIF
1    C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------
      * RESULT
      *------------------------------------------------
     C           #ACT      BEGSR
      *
     C                     Z-ADD*ZERO     @@ACT   90
     C           K#AB      SETLLAB#PL0T
     C           *IN90     DOUEQ*ON
     C           K#AB      READEAB#PL0T                  90
     C           *IN90     IFEQ *OFF
     C           B1SKJY    ANDEQ*BLANK
%0001C           F2NONY    IFNE *ZERO
     C           F2NONY    ANDNEB1NONY
     C                     ITER
     C                     ENDIF
     C           F2NKOJ    IFNE *BLANK
     C           F2NKOJ    ANDNEB1NKOJ
     C                     ITER
     C                     ENDIF
     C           F2NUKE    IFNE *BLANK
     C           F2NUKE    ANDNEB1NUKE
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  B1SRYO    @@ACT
     C                     ENDIF
     C                     ENDDO
      *
     C           @@ACT     MULT F2UPRC    @@AMT  152
      *
     C                     ENDSR
      *----------------------------------------------------*
      * CLEAR
      *----------------------------------------------------*
     C           #CLR      BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *OFF      *IN99
      *
     C                     ENDSR
      *===============================================================
     OFBCWP31 E                @@HED
    1O                                      'CUSTOMER",'
    2O                                      'DELIVERY,'
    3O                                      'FACTORY,'
    4O                                      'DOCK,'
    5O                                      'USER PART#1,'
    5O                                      '#2,'
    5O                                      '#3,'
    5O                                      '#4,'
    6O                                      'CLASS,'
    7O                                      'START,'
    8O                                      'END,'
    9O                                      'PRICE,'
   10O                                      'RESULT,'
   11O                                      'AMOUNT,'
   12O                                      'REMARKS 1,'
   13O                                      'REMARKS 2,"'
      **
     O        E                @@DTL
     O                         F2TOKU
     O                                      '","'
     O                         F2NONY
     O                                      '",="'
     O                         F2NKOJ
     O                                      '",="'
     O                         F2NUKE
     O                                      '",="'
     O                         F2MHN1
     O                                      '",="'
     O                         F2MHN2
     O                                      '",="'
     O                         F2MHN3
     O                                      '",="'
     O                         F2MHN4
     O                                      '","'
     O                         @@DSC
     O                                      '",'
     O                         F2STYM       '    /  '
     O                                      ','
     O                         F2ENYM       '    /  '
     O                                      ',"'
     O                         F2UPRC4
     O                                      '","'
     O                         @@ACT 1
     O                                      '","'
     O                         @@AMT 1
     O                                      '",'
     O                         F2RMK1
     O                                      ','
     O                         F2RMK2
     O                                      ',"'
