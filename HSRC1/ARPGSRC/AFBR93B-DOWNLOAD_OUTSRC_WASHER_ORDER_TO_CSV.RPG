     H            Y.                                    1
     H* AFBR93B *******************************************************
     H* DOWNLOAD OUTSRC WASHER ORDER TO CSV                           *
     H* JW     2024.06.18                                             *
     H*********************AFBPL96*************************************
     FAFBPL92 IF  E           K        DISK
     FAFBPL90AIF  E           K        DISK
     FAFBPL90BIF  E           K        DISK
     FAFBWP93 O   E                    DISK
      *--------------------------------------------------------------
     I            DS
     I                                        1  12 B9PART
     I                                        1   5 B9PAR1
     I                                        6  10 B9PAR2
     I                                       11  12 B9PAR3
     I            DS
     I                                        1   80B9NYHZ
     I                                        1   40B9NYYY
     I                                        5   60B9NYMM
     I                                        7   80B9NYDD
     I            DS
     I                                        1   80B9NOHZ
     I                                        1   40B9NOYY
     I                                        5   60B9NOMM
     I                                        7   80B9NODD
     I            DS
     I                                        1   80B9ODHZ
     I                                        1   40B9ODYY
     I                                        5   60B9ODMM
     I                                        7   80B9ODDD
     I            DS
     I                                        1   80K1ODHZ
     I                                        1   40K1ODYY
     I                                        5   60K1ODMM
     I                                        7   80K1ODDD
     I            DS
     I                                        1  12 K1PART
     I                                        1   5 K1PAR1
     I                                        6  10 K1PAR2
     I                                       11  12 K1PAR3
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------
     C                     EXSR #INIT
      *
     C                     SELEC
      * BY SUPP
     C           XSUPP     WHNE *BLANK
     C           $PART     ANDEQ*BLANK
     C                     EXSR #SUPP
      * BY PART
     C           XSUPP     WHEQ *BLANK
     C           $PART     ANDNE*BLANK
     C                     EXSR #PART
      * BY ORDER DATE
     C                     OTHER
     C                     EXSR #ODAT
     C                     ENDSL
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
      * GET BY SUPP
      *-----------------------------------------------
     C           #SUPP     BEGSR
      *
     C           K#92A     SETLLAFBPL92
     C                     DO   *HIVAL
     C                     READ AFBPL92                  98
     C   98                LEAVE
      * END
     C           XSUPP     IFNE *BLANK
     C           K1SUPP    ANDNEXSUPP
     C                     LEAVE
     C                     ENDIF
      * END
     C           B9ODHZ    IFGT @TO
     C                     LEAVE
     C                     ENDIF
      * DELETED
     C           B9SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * IGNORE
     C           $PART     IFNE *BLANK
     C           B9PART    ANDNE$PART
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #SET
     C                     WRITEAFBPW931
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------
      * GET BY PART
      *-----------------------------------------------
     C           #PART     BEGSR
      *
     C           K#9AA     SETLLAFBPL90A
     C                     DO   *HIVAL
     C           K#9AB     READEAFBPL90A                 98
     C   98                LEAVE
      * END
     C           B9ODHZ    IFGT @TO
     C                     LEAVE
     C                     ENDIF
      * DELETED
     C           B9SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * IGNORE
     C           XSUPP     IFNE *BLANK
     C           B9SUPP    ANDNEXSUPP
     C                     ITER
     C                     ENDIF
      * IGNORE
     C           $PART     IFNE *BLANK
     C           B9PART    ANDNE$PART
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #SET
     C                     WRITEAFBPW931
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------
      * GET BY ORDER DATE
      *-----------------------------------------------
     C           #ODAT     BEGSR
      *
     C           K#90B     SETLLAFBPL90B
     C                     DO   *HIVAL
     C                     READ AFBPL90B                 98
     C   98                LEAVE
      * END
     C           B9ODHZ    IFGT @TO
     C                     LEAVE
     C                     ENDIF
      * DELETED
     C           B9SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * IGNORE
     C           XSUPP     IFNE *BLANK
     C           B9SUPP    ANDNEXSUPP
     C                     ITER
     C                     ENDIF
      * IGNORE
     C           $PART     IFNE *BLANK
     C           B9PART    ANDNE$PART
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #SET
     C                     WRITEAFBPW931
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------
      * SET WORK DATA
      *-----------------------------------------------
     C           #SET      BEGSR
      *
     C                     CLEARAFBPW931
     C                     MOVELB9SUPP    A5SUPP
      * GET SUPP NAME
     C                     MOVELB9SUPP    $DLV
     C                     CALL 'UTLR62'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTN    1
     C                     MOVEL$NAME1    A5SUPN
      * EDIT DATE
     C                     MOVELB9ODHZ    $SRC      P
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C                     MOVEL$TRUE2    A5ODAT
      * EDIT BIN
     C                     MOVELB9ODBB    $IN10     P
     C                     MOVEL'03'      $LONG
     C                     CALL 'EDTR04A'
     C                     PARM           $IN10  10
     C                     PARM           $LONG   2
     C                     PARM           $OUT11 11
     C                     MOVEL$OUT11    A5BIN
      * EDIT PART
     C                     MOVELB9PART    $SHIN
     C                     CALL 'EDTR02'
     C                     PARM           $SHIN  12
     C                     PARM           $SHIN2 14
     C                     MOVEL$SHIN2    A5PART
      *
     C                     MOVELB9HAKO    A5BOX
     C                     MOVELB9ODNO    A5ODNO
     C                     MOVELB9NYHZ    A5RDAT
      * EDIT DATE
     C                     MOVELB9NYHZ    $SRC      P
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C                     MOVEL$TRUE2    A5RDAT
      * EDIT BIN
     C                     MOVELB9ODBB    LTR3    3
     C                     MOVELLTR3      $IN10     P
     C                     MOVEL'03'      $LONG
     C                     CALL 'EDTR04A'
     C                     PARM           $IN10  10
     C                     PARM           $LONG   2
     C                     PARM           $OUT11 11
     C                     MOVEL$OUT11    A5RBIN
      *
     C           B9HAKO    MULT B9SYOS    NUM8    80
     C                     MOVELNUM8      A5QTY
     C                     MOVELB9SYOS    A5QPC
      * EDIT WEIGHT KG
     C**                   MOVELB9WGT1    NUM72   72
     C**                   Z-ADDNUM72     $IN
     C**                   CALL 'EDTR05B'
     C**                   PARM           $IN    156
     C**                   PARM           $TRUE3 17
     C**                   MOVEL$TRUE3    A5WGT1
      * EDIT WEIGHT LB
     C**         B9WGT1    MULT 2.20462   NUM72
     C**                   Z-ADDNUM72     $IN
     C**                   CALL 'EDTR05B'
     C**                   PARM           $IN    156
     C**                   PARM           $TRUE3 17
     C**                   MOVEL$TRUE3    A5WGT2
      * GET LOCATION
     C                     MOVELB9PART    P@SHN
     C                     MOVELB9SUPP    P@DPT
     C                     MOVELB9ODHZ    P@DAT
     C                     CALL 'UEXR05E'
     C                     PARM           P@SHN  12
     C                     PARM           P@DPT   4
     C                     PARM           P@DAT   8
     C                     PARM           O@LOC   6
     C                     PARM           O@SET   5
     C                     PARM           O@LT    3
     C                     MOVELO@LOC     A5LOC
     C                     MOVELO@SET     A5SET
      * EDIT LOCATION
     C                     MOVELO@LOC     LTR1    1
     C           LTR1      IFNE '-'
     C                     MOVELO@LOC     $LOC6
     C                     CALL 'EDTR06B'
     C                     PARM           $LOC6   6
     C                     PARM           $LOC9   9
     C                     MOVEL$LOC9     A5LOC
     C                     ENDIF
      * EDIT LAED TIME
     C                     MOVELO@LT      NUM31   31
     C                     Z-ADDNUM31     $IN
     C                     CALL 'EDTR05B'
     C                     PARM           $IN    156
     C                     PARM           $TRUE  17
     C                     MOVEL$TRUE     A5LT
      * PARAMETER
     C                     MOVEL@FROM     A5FRDT
     C                     MOVEL@TO       A5TODT
     C                     MOVEL$SUPP     A5SUP1
     C                     MOVEL$PART     A5SHIN
      *
     C                     MOVELTODAY     $DATE1
     C                     MOVELNOW       $TIME1
     C                     MOVEL'YMD'     $YMD
     C                     CALL 'EDTR01 '
     C                     PARM           $DATE1  8
     C                     PARM           $TIME1  6
     C                     PARM           $YMD    3
     C                     PARM           $DATE2 10
     C                     PARM           $TIME2  8
     C                     MOVEL$DATE2    A5CRHZ
     C                     MOVEL$TIME2    A5CRTM
      *
     C                     MOVEL#USER     A5CRUS
     C                     MOVEL#PGM      A5CRPG
      *
     C                     ENDSR
      *-----------------------------------------------
      * SET HEADE
      *-----------------------------------------------
     C           #HEAD     BEGSR
      *
     C                     CLEARAFBPW931
     C                     MOVEL'SUPPLIER'A5SUPP
     C                     MOVEL'SUP_NAME'A5SUPN
     C                     MOVEL'ORD_DATE'A5ODAT
     C                     MOVEL'ORD_BIN 'A5BIN
     C                     MOVEL'IAF_PART'A5PART
     C                     MOVEL'BOX     'A5BOX
     C                     MOVEL'ORDER#  'A5ODNO
     C                     MOVEL'ETA_DATE'A5RDAT
     C                     MOVEL'RCV_BIN#'A5RBIN
     C                     MOVEL'LEAD_TIM'A5LT
     C                     MOVEL'QTY     'A5QTY
     C                     MOVEL'QPC     'A5QPC
     C**                   MOVEL'WGT_(KG)'A5WGT1
     C**                   MOVEL'WGT_(LB)'A5WGT2
     C                     MOVEL'LOCATION'A5LOC
     C                     MOVEL'SET#    'A5SET
      * PARAMETER
     C                     MOVEL'INP*FROM'A5FRDT
     C                     MOVEL'INP*TO  'A5TODT
     C                     MOVEL'INP*SUPP'A5SUP1
     C                     MOVEL'INP*PART'A5SHIN
     C                     MOVEL'OUT_DATE'A5CRHZ
     C                     MOVEL'OUT_TIME'A5CRTM
     C                     MOVEL'OUT_USER'A5CRUS
     C                     MOVEL'OUT_PGM 'A5CRPG
      *
     C                     WRITEAFBPW931
      *
     C                     ENDSR
      *-----------------------------------------------
      * INITIAL SETTING
      *-----------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SUPP   4
     C                     PARM           $FROM   8
     C                     PARM           $TO     8
     C                     PARM           $PART  12
      *
     C                     TIME           SDATE
      *
     C           K#92A     KLIST
     C                     KFLD           K1SUPP  4
     C                     KFLD           K1ODYY
     C                     KFLD           K1ODMM
     C                     KFLD           K1ODDD
      *
     C           K#92B     KLIST
     C                     KFLD           K1SUPP
      *
     C           K#9AA     KLIST
     C                     KFLD           K1PAR1  5
     C                     KFLD           K1PAR2  5
     C                     KFLD           K1PAR3  2
     C                     KFLD           K1ODYY  40
     C                     KFLD           K1ODMM  20
     C                     KFLD           K1ODDD  20
      *
     C           K#9AB     KLIST
     C                     KFLD           K1PAR1
     C                     KFLD           K1PAR2
     C                     KFLD           K1PAR3
      *
     C           K#90B     KLIST
     C                     KFLD           K1ODYY
     C                     KFLD           K1ODMM
     C                     KFLD           K1ODDD
      *
     C           $FROM     IFEQ *BLANK
     C           $FROM     OREQ *ZERO
     C                     MOVELTODAY     @FROM   80
     C                     ELSE
     C                     MOVEL$FROM     @FROM
     C                     ENDIF
      *
     C           $TO       IFEQ *BLANK
     C           $TO       OREQ *ZERO
     C                     MOVEL@FROM     @TO     80
     C                     ELSE
     C                     MOVEL$TO       @TO
     C                     ENDIF
      *
     C                     MOVEL$PART     K1PART
     C                     MOVEL@FROM     K1ODHZ
      *
     C           $SUPP     IFEQ '    '
     C           $SUPP     OREQ '*ALL'
     C           $SUPP     OREQ '0000'
     C           $SUPP     OREQ '9999'
     C                     MOVE *BLANK    XSUPP   4
     C                     ELSE
     C                     MOVEL$SUPP     XSUPP
     C                     ENDIF
      *
     C                     MOVEL$SUPP     K1SUPP
      * SET HEADER
     C                     EXSR #HEAD
      *
     C                     ENDSR
