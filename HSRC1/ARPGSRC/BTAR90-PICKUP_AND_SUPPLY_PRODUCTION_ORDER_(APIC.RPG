     C           KEY1      KLIST
     C                     KFLD           @HIN1
     C                     KFLD           @HIN2
     C                     KFLD           @HIN3
      *
     C           KEY2      KLIST
     C                     KFLD           @HIN1
     C                     KFLD           @HIN2
     C                     KFLD           @HIN3
     C                     KFLD           WKYM
      *
     C           KEY3      KLIST
     C                     KFLD           @KYY
     C                     KFLD           @KMM
      *
     C*----------------------------------------------------*
     C*                   １画面                         *
     C*----------------------------------------------------*
      *
     C           STP1      TAG
     C                     MOVE *BLANK    @KOKU
     C                     MOVE *BLANK    @KYY
     C                     MOVE *BLANK    @KMM
     C                     MOVE *BLANK    @HIN
      *
     C           STP2      TAG
     C                     Z-ADD0         #PH
     C                     Z-ADD0         #MH
     C                     MOVE *BLANK    #ZM
     C                     MOVE *BLANK    @HOL
     C                     EXFMTBTAPW901
     C                     SETOF                     010203
     C                     SETOF                     04
     C                     SETOF                     99
      *-------*
      * CMD-1 *
      *-------*
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *------*
      *更新*
      *------*
     C           @KOKU     IFNE '0'
     C           @KOKU     ANDNE'1'
     C           @KOKU     ANDNE'2'
     C                     SETON                     0199
     C                     MOVELER,1      MSG
     C                     GOTO STP2
     C                     END
      *
     C                     SETOF                     01
     C                     Z-ADD1         A       20
     C           @KOKU     LOKUPWKJ1,A                   01
     C           *IN01     IFEQ '1'
     C                     MOVE WKJ2,A    WKSNM
     C                     SETOF                     01
     C                     END
      *------------*
      *計画予定日*
      *------------*
     C           @KYY      IFLT 1994
     C           @KMM      ORLT 1
     C           @KMM      ORGT 12
     C                     SETON                     0299
     C                     MOVELER,2      MSG
     C                     GOTO STP2
     C                     END
      *
     C                     MOVEL@KYY      WKYM    60
     C                     MOVE @KMM      WKYM
     C                     MOVEL*YEAR     WUKYM   60
     C                     MOVE UMONTH    WUKYM
      *
     C           WKYM      IFLT WUKYM
     C                     SETON                     0299
     C                     MOVELER,3      MSG
     C                     GOTO STP2
     C                     END
      *------*
      *品番*
      *------*
     C           @HIN1     IFEQ *BLANK
     C           @HIN2     ANDEQ*BLANK
     C           @HIN3     ANDEQ*BLANK
     C                     SETON                     0399
     C                     MOVELER,4      MSG
     C                     GOTO STP2
     C                     END
      *--------------------------------------*
      *平準化確定発注ファイル／品番チェック*
      *--------------------------------------*
     C                     SETOF                     03
     C           KEY1      CHAINAGAPL411             03
     C           *IN03     IFEQ '0'
     C           CBSKJY    ANDEQ'D'
     C           CBSKHZ    ANDLE*DATE
     C                     SETON                     03
     C                     END
     C           *IN03     IFEQ '1'
     C                     SETON                     99
     C                     MOVELER,5      MSG
     C                     GOTO STP2
     C                     END
      *----------------------------------*
      *Ａ－ＰＩＣＳ計画発行受注ファイル*
      *----------------------------------*
     C                     SETOF                     98
     C           KEY2      CHAINBTAPL901             98
      *
     C*取消OR変更
     C           @KOKU     IFEQ '0'
     C           @KOKU     OREQ '1'
     C           *IN98     IFEQ '1'
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVELER,6      MSG
     C                     GOTO STP2
     C                     END
      *
     C           BTSKJY    IFEQ 'D'
     C           BTSKHZ    ANDLE*DATE
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVELER,7      MSG
     C                     GOTO STP2
     C                     END
     C                     END
      *
     C*追加
     C           @KOKU     IFEQ '2'
     C           *IN98     IFEQ '0'
     C           BTSKJY    IFEQ 'D'
     C           BTSKHZ    ANDLE*DATE
     C                     ELSE
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVELER,8      MSG
     C                     GOTO STP2
     C                     END
     C                     END
     C                     END
      *計画予定日
     C                     MOVE '  .  '   @KYM
     C                     MOVEL@KYYX     @KYM
     C                     MOVE @KMM      @KYM
      *品番
     C                     MOVE '-'       WH1
     C                     MOVE '-'       WH2
     C           @HIN3     IFEQ *BLANK
     C                     MOVE *BLANK    WH2
     C                     END
      *収容数
     C                     Z-ADDCBSYUY    @SYUSU
      *前工程
     C                     MOVE *BLANK    @MAENM
     C                     SETOF                     32
     C           CBMBMN    CHAINFGBPL011             32
     C           *IN32     IFEQ '0'
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELB2SMEI    @MAENM
     C                     END
     C                     END
      *フィールドクリア
     C           @KOKU     IFEQ '2'
     C                     Z-ADD0         #PH
     C                     Z-ADD0         #MH
     C                     MOVE *BLANK    #ZM
     C                     END
      *
     C*青山カレンダーチェック
     C                     EXSR $HOLI
      *
     C*----------------------------------------------------*
     C*                   ２画面                         *
     C*----------------------------------------------------*
     C*画面罫線
     C                     BITOF'01234567'X00     1
     C                     MOVE X00       X2F     1
     C                     BITON'24567'   X2F
     C                     MOVE 'F'       KBFR
      *
     C                     WRITEBTAPW904
     C                     WRITEBTAPW903
      *
     C           STP4      TAG
     C                     EXFMTBTAPW902
     C                     SETOF                     010203
     C                     SETOF                     040506
     C                     SETOF                     070809
     C                     SETOF                     101112
     C                     SETOF                     131415
     C                     SETOF                     161718
     C                     SETOF                     192021
     C                     SETOF                     222324
     C                     SETOF                     252627
     C                     SETOF                     282930
     C                     SETOF                     3199
      *
     C           *INKC     IFEQ '1'
     C                     GOTO STP1
     C                     END
      *
     C  NKE                GOTO STP4
      *
     C*----------------------------------------------------*
     C*                   データ更新                     *
     C*----------------------------------------------------*
     C                     TIME           WTIME
     C                     Z-ADD*DATE     BTKOHZ
     C                     Z-ADDJI        BTKOHH
     C                     Z-ADDFU        BTKOSS
     C                     MOVE @@USER    BTKOME
      *
     C           @KOKU     IFEQ '0'
     C                     MOVE 'D'       BTSKJY
     C                     Z-ADD*DATE     BTSKHZ
     C                     ELSE
     C                     MOVE *BLANK    BTSKJY
     C                     Z-ADD0         BTSKHZ
     C                     END
      *
     C                     MOVE @HIN1     BTSHN1
     C                     MOVE @HIN2     BTSHN2
     C                     MOVE @HIN3     BTSHN3
     C                     MOVE WKYM      BTKEYM
      *
     C           *IN98     IFEQ '0'
     C                     UPDATBTAPL901
     C                     ELSE
     C                     WRITEBTAPL901
     C                     END
      *
     C*****************************************************************
     C*         青山カレンダーチェック
     C*****************************************************************
     C           $HOLI     BEGSR                                      $
      *
     C*休日'*XX*'
     C                     MOVEA'00000000'*IN,41
     C                     MOVEA'00000000'*IN,49
     C                     MOVEA'00000000'*IN,57
     C                     MOVEA'0000000' *IN,65
     C                     MOVE *BLANK    @HOL
      *
     C                     Z-ADD0         N       20
     C                     Z-ADD1         A
     C           KEY3      SETLLAGDPL121
     C           1         DO   31        A
     C                     SETOF                     80
     C           KEY3      READEAGDPL121                 80
     C           *IN80     IFEQ '0'
     C                     MOVE *BLANK    WHOL
     C                     MOVELA         WHH23
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     MOVE '*'       WHH1
     C                     MOVE '*'       WHH4
     C                     END
     C           WHH2      IFEQ '0'
     C                     MOVE *BLANK    WHH2
     C                     END
     C                     MOVE WHOL      @HOL,A
     C                     END
     C                     END
      *
     C* 今日以前は入力禁止
     C                     Z-ADD1         A
     C                     Z-ADD0         N
     C           1         DO   31        A
     C           A         ADD  40        N
      *
     C           WKYM      IFEQ WUKYM
     C           A         IFLE UDAY
     C                     MOVE '1'       *IN,N
     C                     END
     C                     END
      *
     C                     MOVE @HOL,A    WHOL
     C           WHH1      IFEQ '*'
     C                     MOVE '1'       *IN,N
     C                     END
     C           WHH23     IFEQ *BLANK
     C                     MOVE '1'       *IN,N
     C                     END
     C                     END
      *
     C           WKYM      IFLT WUKYM
     C                     Z-ADD1         A
     C                     Z-ADD0         N
     C           1         DO   31        A
     C           A         ADD  40        N
     C                     MOVE '1'       *IN,N
     C                     END
     C                     END
      *
     C                     ENDSR
      *
      *
**  ERR-MSG
E-01 UPDATE INSTRUCTION IS WRONG
E-02 PLAN PUBLICATION DATE IS LOGICAL ERROR
E-03 PLAN PUBLICATION DATE IS SMALLER THAN TODAY
E-04 INPUT PART NO
E-05 THERE IS NOT PART NO INPUT INTO IN FIXED ORDERING FILE
E-06 THERE ISN'T IT IN A-PICS PLAN PUBLIC MANAGEMENT M/F
E-07 IT IS CANCELLED ALREADY
E-08 THERE IS DATA
E-09 NUMBER OF BOXES CAN'T INPUT BOTH
**  WKJ1/WKJ2(FACTORY)
00-CANCEL
11-CHANGE
22-ADD
