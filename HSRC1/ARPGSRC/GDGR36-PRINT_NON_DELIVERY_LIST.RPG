      *  K.KASHIWAGI 2001.03.15   *
      *  CHANGE %001 N.HAYAKAWA  2004.01.15
      ******************* GDGR36 **
     FGDGWP36 IP  F     128            DISK
     FGDGPL25 IF  E           K        DISK
     FQPRINT  O   F     158     OF     PRINTER
      *
     IGDGWP36 AA  01
     I                                        1   5 IHIN1 L2
     I                                        6  10 IHIN2 L2
     I                                       11  12 IHIN3 L2
     I                                       13  180IODER L1
     I                                       13  14 IODR1
     I                                       15  16 IODR2
     I                                       17  18 IODR3
     I                                       19  230IITEM L1
     I                                       24  310IODHZ
     I                                       32  380ISYOS
     I                                       39  430IMAIS
     I                                       44  500ISURY
      *
     I                                       51  51 IHANY
     I                                       52  590IDLHZ
      *
      *
     I            DS
     I                                        1   80IESKHZ
     I                                        1   40IESKYY
     I                                        5   60IESKMM
     I                                        7   80IESKDD
     I            DS
     I                                        1   80IESOHZ
     I                                        1   40IESKOY
     I                                        5   60IESKOM
     I                                        7   80IESKOD
     I            DS
     I                                        1   80IENYHZ
     I                                        1   40IENYUY
     I                                        5   60IENYUM
     I                                        7   80IENYUD
     I            DS
     I                                        1   6 IINVO
     I                                        1   2 IIVO1
     I                                        3   6 IIVO2
     I           SDS
     I                                        1   8 @PGMID
      *------*
      * PARM *
      *------*
     C           *ENTRY    PLIST
     C                     PARM           US     10
      *
     C                     MOVE *BLANK    WUSER   9
     C                     MOVE *BLANK    WUSME  15
     C                     CALL 'APLR00'
     C                     PARM           US
     C                     PARM           WUSME
     C                     MOVELWUSME     WUSER
      *-----*
      * KEY *
      *-----*
     C           KEY       KLIST
     C                     KFLD           IODER
     C                     KFLD           IITEM
      *-----*
      * INZ *
      *-----*
     C           *IN05     IFEQ '0'
     C                     SETON                     05
     C                     Z-ADD0         GSKSU   70
     C                     Z-ADD0         GSKHK   30
     C                     Z-ADD0         GRESU   70
     C                     Z-ADD0         GREHK   30
     C                     Z-ADD0         GMISU   70
     C                     Z-ADD0         GMIHK   30
     C                     MOVE *BLANK    IINVO   6
     C                     Z-ADD0         ISYSU   70
     C                     Z-ADD0         ISKHK   50
     C                     Z-ADD0         ISOHZ   80
     C                     Z-ADD0         INYHZ   80
 %001C                     MOVE *BLANK    IPALE   4
     C                     TIME           WTIME   60
     C                     MOVE *BLANK    $$HANY  1        CARRY CODE
     C                     EXCPTHD
     C                     END
      *
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     END
      *
     C           *INL2     IFEQ '1'
     C           *IN50     ANDEQ'1'
     C                     EXCPTDT1
     C                     END
     C                     SETON                     50
      *----------------------*
      * SHIPPING INFORMATION *
      *----------------------*
     C                     SETOF                     20
     C           KEY       SETLLGDGPL25
     C                     DO   *HIVAL
     C                     SETOF                     1077
     C           KEY       READEGDGPL251                 10
     C           *IN20     IFEQ '0'
     C           *IN10     IFEQ '1'
     C                     SETON                     2077
     C                     EXCPTDT2
     C                     END
     C                     END
     C           *IN10     IFEQ '0'
     C           IESKJY    IFEQ 'D'
     C           IESKHZ    ANDLE*DATE
     C                     ELSE
     C           *IN20     IFEQ '0'
     C                     SETON                     2077
     C                     END
      *
     C                     MOVELIEINVO    IINVO
     C                     Z-ADDIESURY    ISYSU
     C           ISYSU     DIV  ISYOS     ISKHK
     C*                    Z-ADDIESBOX    ISKHK
     C                     Z-ADDIESOHZ    ISOHZ
     C                     Z-ADDIENYHZ    INYHZ
 %001C                     MOVE IEPARE    IPALE
     C*
     C                     MOVE IEHANY    $$HANY           CARRY CODE
     C*
     C           IENYUK    IFEQ *BLANK
     C                     ADD  IESURY    GSKSU
     C                     ELSE
     C                     ADD  IESURY    GSKSU
     C                     ADD  IESURY    GRESU
     C                     END
     C                     EXCPTDT2
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     END
     C                     END
     C                     END
     C  N10                ENDDO
      *
     CL1         ISURY     SUB  GSKSU     GMISU
     CL1         GMISU     DIV  ISYOS     GMIHK
     CL1         GSKSU     DIV  ISYOS     GSKHK
     CL1         GRESU     DIV  ISYOS     GREHK
     CL1                   EXCPTDT3
     CL1                   MOVE *BLANK    IINVO
     CL1                   Z-ADD0         ISYSU
     CL1                   Z-ADD0         ISKHK
     CL1                   Z-ADD0         ISOHZ
     CL1                   Z-ADD0         INYHZ
 %001CL1                   MOVE *BLANK    IPALE
     CL1                   Z-ADD0         GSKSU
     CL1                   Z-ADD0         GSKHK
     CL1                   Z-ADD0         GRESU
     CL1                   Z-ADD0         GREHK
     CL1                   Z-ADD0         GMISU
     CL1                   Z-ADD0         GMIHK
