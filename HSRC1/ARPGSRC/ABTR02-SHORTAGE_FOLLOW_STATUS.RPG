     H            Y.
     F** ABTR02 *********************************************
     F* SHORTAGE FOLLOW STATUS
     F*   SAKAKI.         2019.10.29                        *
     F*******************************************************
     FABTWP01 IF  E           K        DISK
     FAB#PPM1 IF  E           K        DISK
     FABTWP02 O   E                    DISK                      A
     E                    OKB        15  3               機番
     E                    OKO        15  3               工程
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  140SDATE
     I                                        1   60STIME
      *
     I            DS
     I                                        1  12 W1SHIN
     I                                        1   5 W1LPR1
     I                                        6  10 W1LPR2
     I                                       11  12 W1LPR3
      *
     I            DS
     I                                        1  20 X1SRT#
     I                                        4   4 X1SRT4
     I                                        4   5 X1SRT5
      *
     I            DS
     I                                        1   3 W1SRTN
     I                                        1   1 W1SRT#
     I                                        2   3 W1SRT0
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *----------------------------------------------------*
      * ENTRY                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1KBN   1
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     TIME           WTIME
      *
     C                     MOVEL'1'       OPNCLS
     C                     READ ABTWP01                  20
     C           *IN20     DOWEQ'0'
     C                     EXSR #SB500
     C                     READ ABTWP01                  20
     C                     ENDDO
      *
     C           OPNCLS    IFEQ '0'
     C                     MOVE '9'       OPNCLS
     C                     CALL 'AAMRSB'
      *入力パラメータ
     C                     PARM           A2BHB1  5
     C                     PARM           A2BHB2  5
     C                     PARM           A2BHB3  2
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARABTWP021
     C                     Z-ADDW1TOKU    W2TOKU
     C                     Z-ADDW1NONY    W2NONY
     C                     MOVELW1NKOJ    W2NKOJ
     C                     MOVELW1NUKE    W2NUKE
     C                     Z-ADDW1NODT    W2NODT
     C                     MOVELW1NOBN    W2NOBN
     C           KEYM1     KLIST
     C                     KFLD           K@NONY  4
     C                     KFLD           K@BIN   2
     C                     MOVELW1NONY    K@NONY
     C                     MOVE W1NOBN    K@BIN
     C           KEYM1     CHAINAB#PPM1              47
     C           *IN47     IFEQ '0'
     C           M@SKJY    IFEQ 'D'
     C           M@SKDT    ANDLESDATE
     C                     ELSE
     C                     MOVELM@NTIM    W2NOTM
     C           M@CHGD    IFGT SDATE
     C                     MOVELM@OTIM    W2NOTM
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     MOVELW1ODRN    W2ODRN
     C                     MOVELW1MHN1    W2MHN1
     C                     MOVELW1MHN2    W2MHN2
     C                     MOVELW1MHN3    W2MHN3
     C                     MOVELW1MHN4    W2MHN4
     C                     MOVELW1UKAN    W2UKAN
     C                     MOVELW1LOC     W2LOC
     C                     MOVELW1LZET    W2LZET
     C                     MOVELW1LOC1    W2LOC1
     C                     MOVELW1LOC2    W2LOC2
     C                     MOVELW1LOC3    W2LOC3
     C                     MOVELW1LOC4    W2LOC4
     C                     MOVELW1LPR1    W2LPR1
     C                     MOVELW1LPR2    W2LPR2
     C                     MOVELW1LPR3    W2LPR3
     C                     Z-ADDW1ODAT    W2ODAT
     C                     Z-ADDW1OTIM    W2OTIM
     C                     MOVELW1OTMC    W2OTMC
     C                     Z-ADDW1CNT     W2CNT
     C                     MOVELW1AKAN    W2AKAN
     C                     MOVELW1AZET    W2AZET
     C                     MOVELW1ALOT    W2ALOT
     C                     MOVELW1APAG    W2APAG
     C                     Z-ADDW1ALD3    W2ALD3
     C                     Z-ADDW1ADA1    W2ADA1
     C                     Z-ADDW1NYKO    W2NYKO
     C                     Z-ADDW1SRT     W2SRT
     C                     Z-ADDW1OUK     W2OUK
     C                     Z-ADDW1BZK     W2BZK
     C                     Z-ADDW1DSK     W2DSK
     C                     Z-ADDW1JCK     W2JCK
     C                     Z-ADDW1SBK     W2SBK
     C                     Z-ADDW1LOQK    W2LOQK
     C                     Z-ADDW1OUI     W2OUI
     C                     Z-ADDW1BZI     W2BZI
     C                     Z-ADDW1DSI     W2DSI
     C                     Z-ADDW1JCI     W2JCI
     C                     Z-ADDW1SBI     W2SBI
     C                     Z-ADDW1LOQI    W2LOQI
     C                     Z-ADDW1PLOU    W2PLOU
     C                     Z-ADDW1PLBZ    W2PLBZ
     C                     Z-ADDW1PLDS    W2PLDS
     C                     Z-ADDW1PLJC    W2PLJC
     C                     Z-ADDW1PLSB    W2PLSB
     C                     Z-ADDW1PLLO    W2PLLO
     C                     Z-ADDW1PRE     W2PRE
     C                     Z-ADDW1CVS     W2CVS
     C                     Z-ADDW1ALL     W2ALL
      * SRT
     C                     Z-ADDW1SRT     W2SRTD
      * S.T.済
      * S.T.中
      * S.T.前
     C                     SELEC
     C           P1KBN     WHEQ '2'
     C                     Z-ADDW1BZK     W2STKD
     C                     Z-ADDW1BZI     W2STID
     C                     Z-ADDW1PLBZ    W2STPD
     C           P1KBN     WHEQ '5'
     C                     Z-ADDW1DSK     W2STKD
     C                     Z-ADDW1DSI     W2STID
     C                     Z-ADDW1PLDS    W2STPD
     C           P1KBN     WHEQ '6'
     C                     Z-ADDW1JCK     W2STKD
     C                     Z-ADDW1JCI     W2STID
     C                     Z-ADDW1PLJC    W2STPD
     C                     ENDSL
      * SB済
     C                     Z-ADDW1SBK     W2SBKD
      * H.T.済
     C                     Z-ADDW1LOQK    W2HTKD
      * SB中
     C                     Z-ADDW1SBI     W2SBID
      * H.T.中
     C                     Z-ADDW1LOQI    W2HTID
      * SB前
     C                     Z-ADDW1PLSB    W2SBPD
      * H.T.前
     C                     Z-ADDW1PLLO    W2HTPD
      * CV集荷後
     C                     Z-ADDW1PRE     W2PRED
      *
     C                     MOVEL'0'       W@F     1
     C                     SELEC
      * INSPECTION
     C           P1KBN     WHEQ '1'
     C           W2SRTD    IFGT 0
     C                     MOVEL'1'       W@F
     C                     ENDIF
      * S.T.
     C           P1KBN     WHEQ '2'
     C           P1KBN     OREQ '5'
     C           P1KBN     OREQ '6'
     C           W2SRTD    IFLT W2CNT
     C           W2STKD    IFGT 0
     C           W2STID    ORGT 0
     C           W2STPD    ORGT 0
     C                     MOVEL'1'       W@F
     C                     ENDIF
     C                     ENDIF
      * SB
     C           P1KBN     WHEQ '3'
     C           W2SRTD    IFLT W2CNT
     C           W2SBKD    IFGT 0
     C           W2SBID    ORGT 0
     C           W2SBPD    ORGT 0
     C                     MOVEL'1'       W@F
     C                     ENDIF
     C                     ENDIF
      * H.T.
     C           P1KBN     WHEQ '4'
     C           W2SRTD    IFLT W2CNT
     C           W2HTKD    IFGT 0
     C           W2HTID    ORGT 0
     C           W2HTPD    ORGT 0
     C                     MOVEL'1'       W@F
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSL
      *
     C           W@F       IFEQ '1'
     C                     EXSR #SB510
     C                     WRITEABTWP021
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB510    BEGSR
      *
     C                     MOVEA*BLANK    OKB
     C                     MOVEA*BLANK    OKO
     C                     CALL 'AAMRSB'
      *入力パラメータ
     C                     PARM           W1LPR1
     C                     PARM           W1LPR2
     C                     PARM           W1LPR3
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     MOVEL'0'       OPNCLS
     C                     MOVEAPKBN      OKB
     C                     MOVEAPKOT      OKO
      *
     C           P1KBN     IFEQ '1'
     C                     CALL 'UTLR57'
     C                     PARM           W1SHIN
     C                     PARM           X1SRTN 20
     C                     PARM           X1SRT# 20
     C                     PARM           X1RTN   1
     C                     MOVELX1SRTN    W2PROC
     C                     MOVELX1SRT#    W2MSN#
     C*
     C           X1SRT4    IFGE '0'
     C           X1SRT4    ANDLE'9'
     C                     MOVEL*BLANK    W2MSN#
     C                     MOVEL'#'       W1SRT#
     C                     MOVELX1SRT5    W1SRT0
     C                     MOVELW1SRTN    W2MSN#
     C                     ENDIF
     C*
     C                     ENDIF
     C                     MOVEL*BLANK    WKOT1   3
     C                     MOVEL*BLANK    WKOT2   3
     C                     MOVEL*BLANK    WKOT3   3
     C                     SELEC
     C           P1KBN     WHEQ '1'
     C           P1KBN     WHEQ '2'
     C                     MOVEL'BZ '     WKOT1   3
     C****                 MOVEL'DS '     WKOT2   3
     C****                 MOVEL'JC '     WKOT3   3
     C                     EXSR #SB511
     C           P1KBN     WHEQ '3'
     C                     MOVEL'SB '     WKOT1   3
     C                     EXSR #SB511
     C           P1KBN     WHEQ '4'
     C                     MOVEL'LOQ'     WKOT1   3
     C                     EXSR #SB511
     C           P1KBN     WHEQ '5'
     C                     MOVEL'DS '     WKOT1   3
     C                     EXSR #SB511
     C           P1KBN     WHEQ '6'
     C                     MOVEL'JC '     WKOT1   3
     C                     EXSR #SB511
     C                     ENDSL
      *
     CSR         ESB510    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB511    BEGSR
      *
     C                     Z-ADD1         X       30
     C           X         DOWLE15
     C           OKO,X     IFEQ WKOT1
     C**         OKO,X     OREQ WKOT2
     C**         OKO,X     OREQ WKOT3
     C                     MOVELOKO,X     W2PROC
     C                     MOVELOKB,X     W2MSN#
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      * KRO(JC)
     C           P1KBN     IFEQ '6'
     C           W2PROC    IFEQ *BLANK
     C                     Z-ADD1         X       30
     C           X         DOWLE15
     C           OKO,X     IFEQ 'KRO'
     C           OKB,X     ANDEQ'JC4'
     C                     MOVELOKO,X     W2PROC
     C                     MOVELOKB,X     W2MSN#
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB511    ENDSR
