     H            Y.
     F** A#R0681O1 *****************************************
     F*  PMO ORDER PROCESSING                              *
     F*  CPOIED FROMA#R0681O (2023.04.18) BY JW            *
     F*---------------------------------------------       *
JW1  F*    JW  09/16/19 CHG FORMAT (3 TO 5 DAYS)           *
JW2  F*    JW  12/10/19 ADD TENNESSEE (0682)               *
JW3  F*    JW  07/29/20 CHG FORMAT (5 TO 3 DAYS)           *
JW4  F*    JW  04/18/23 CHG BIN#                           *
     F******************************************************
     FPMO     IF  F     800            DISK                           UC
     FAB#WPMO O   E                    DISK
      *--------------------------------------------------------
     E                    AY        800  1
     E                    DAT        10  8 0
     E                    A2          2  1
     E                    A9          9  1
     E                    A9X         9  1
     E                    A20        20  1
      *--------------------------------------------------------
     IPMO     AA  01
     I                                        1  12 SEQ
     I                                       13  60 DAT0
     I                                       13 268 DAT1
     I                                      269 524 DAT2
     I                                      525 780 DAT3
     I            DS
     I                                        1   80YMD
     I                                        1   2 CNTRY
     I                                        3   4 YEAR
     I                                        5   6 MONTH
     I                                        7   8 DAY
     I            DS
     I                                        1   8 ORDR
     I                                        1   2 MM
     I                                        3   4 DD
     I                                        5   8 YY
     I            DS
     I                                        1  20 AWMHIN
     I                                        1   5 AWMHN1
     I                                        6  10 AWMHN2
     I                                       11  15 AWMHN3
     I                                       16  20 AWMHN4
      ********************************************************
      * MAIN ROUTINE
      ********************************************************
     C                     EXSR #INIT
      * CHECK BUILDING
     C                     OPEN PMO
     C                     EXSR #BLD
     C                     CLOSEPMO
      * BUILDING  ERROR
JX1  C           @BLD      IFEQ *BLANK
 .   C                     MOVE '2'       PID
 .   C                     GOTO ERR1
 .   C                     ELSE
 .   C           @BLD      IFEQ 'MIX '
 .   C                     MOVE '3'       PID
 .   C                     GOTO ERR1
 .   C                     ENDIF
JX1  C                     ENDIF
      * PROCESS
     C                     OPEN PMO
     C                     EXSR #PROC
     C                     CLOSEPMO
      *
JX1  C           ERR1      TAG
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================
      * PROCESS
      *======================================
     C           #PROC     BEGSR
      *
     C                     DO   *HIVAL
     C                     READ PMO                      97
     C   97                LEAVE
      *
     C                     MOVEADAT1      AY,1
     C                     MOVEADAT2      AY,257
     C                     MOVEADAT3      AY,513
      *
     C           *IN70     IFEQ *OFF
JW2   *===============
 |    * SET SHIPTO FLAG (SFLAG=O: PMO, T: PMT)
 |    *===============
 |   C                     Z-ADD1         IX      30
 |   C           'OHIO'    SCAN DAT1      IX             10
 |   C   10                MOVE 'O'       SFLAG   1
 |   C                     Z-ADD1         IX
 |   C           'TENNE'   SCAN DAT1      IX             10
JW2  C   10                MOVE 'T'       SFLAG
      *===============
      * GET SHIP DATE
      *===============
     C           'DUE DAT' SCAN DAT1      IX             10
     C**N10                GOTO @END
JX1  C  N10                ITER
      *================
      * HEADER PROCESS
      *================
     C                     EXSR #HDR
     C  N70                MOVE *ON       *IN70
JX1  C                     ITER
     C                     ENDIF
      *================
      * DETAIL PROCESS
      *================
     C                     Z-ADD*ZERO     IW      30
     C           *IN70     IFEQ *ON
     C                     EXSR #DTL
     C                     ENDIF
      *
     C                     ENDDO
      *
JX1  C                     ENDSR
      ********************************************************
      * CHECK BIULDING 1 OR 2
      ********************************************************
     C           #BLD      BEGSR
      *
     C                     MOVE *BLANK    @BLD1   4
     C                     MOVE *BLANK    @BLD2   4
      *
     C                     DO   *HIVAL
     C                     READ PMO                      98
     C   98                LEAVE
      * CHECK PMO1
     C           @BLD1     IFEQ *BLANK
     C                     Z-ADD1         IX      30
     C           'PMO1'    SCAN DAT0      IX             10
     C           *IN10     IFEQ *ON
     C                     MOVEL'BLD1'    @BLD1
     C                     ENDIF
     C                     ENDIF
      * CHECK PMO2
     C           @BLD2     IFEQ *BLANK
     C                     Z-ADD1         IX      30
     C           'PMO2'    SCAN DAT0      IX             10
     C           *IN10     IFEQ *ON
     C                     MOVEL'BLD2'    @BLD2
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      * CHECK DOCK
     C                     MOVE *BLANK    @BLD    4
     C                     SELEC
     C           @BLD1     WHNE *BLANK
     C           @BLD2     ANDEQ*BLANK
     C                     MOVEL@BLD1     @BLD
     C           @BLD1     WHEQ *BLANK
     C           @BLD2     ANDNE*BLANK
     C                     MOVEL@BLD2     @BLD
     C           @BLD1     WHEQ *BLANK
     C           @BLD2     ANDEQ*BLANK
     C                     MOVEL'    '    @BLD
     C                     OTHER
     C                     MOVE 'MIX '    @BLD
     C                     ENDSL
      *
     C                     ENDSR
     C***************************************************
     C* HEADER PROCESS
     C***************************************************
     C           #HDR      BEGSR
      *
     C                     Z-ADD*ZERO     DAT
     C                     Z-ADD*ZERO     IY      30
     C                     Z-ADD*ZERO     II      30
     C                     Z-ADD1         IX
     C           ','       LOKUPAY,IX                    10
     C  N10                GOTO XHDR
     C                     ADD  1         IX
     C           ','       LOKUPAY,IX                    10   11
     C  N10                GOTO XHDR
     C                     ADD  1         IX
     C           ','       LOKUPAY,IX                    10
     C  N10                GOTO XHDR
     C                     ADD  1         IX
     C           ','       LOKUPAY,IX                    10
     C  N10                GOTO XHDR
     C                     ADD  1         IX
     C           ','       LOKUPAY,IX                    10
     C  N10                GOTO XHDR
      *
JW3  C                     DO   3
      *
     C                     ADD  1         IX
     C           ','       LOKUPAY,IX                    10
     C  N10                LEAVE
      *
     C                     MOVEL*ZERO     YMD
     C                     Z-ADDIX        IZ      30
     C* MM
     C                     ADD  1         IZ
     C           '/'       LOKUPAY,IZ                    10
     C  N10                LEAVE
     C           IZ        SUB  2         IY
     C                     MOVEAAY,IY     A2
     C           A2,2      IFGE '0'
     C           A2,2      ANDLE'9'
     C                     MOVE A2,2      MONTH
     C           A2,1      IFGE '0'
     C           A2,1      ANDLE'9'
     C                     MOVELA2,1      MONTH
     C                     END
     C                     ELSE
     C           A2,1      IFGE '0'
     C           A2,1      ANDLE'9'
     C                     MOVE A2,1      MONTH
     C                     END
     C                     END
     C* DD
     C                     ADD  1         IZ
     C           '/'       LOKUPAY,IZ                    10
     C  N10                LEAVE
     C           IZ        SUB  2         IY
     C                     MOVEAAY,IY     A2
     C           A2,2      IFGE '0'
     C           A2,2      ANDLE'9'
     C                     MOVE A2,2      DAY
     C           A2,1      IFGE '0'
     C           A2,1      ANDLE'9'
     C                     MOVELA2,1      DAY
     C                     END
     C                     ELSE
     C           A2,1      IFGE '0'
     C           A2,1      ANDLE'9'
     C                     MOVE A2,1      DAY
     C                     END
     C                     END
     C* YY
     C           IZ        ADD  1         IY
     C                     MOVEAAY,IY     A2
     C           A2,2      IFGE '0'
     C           A2,2      ANDLE'9'
     C                     MOVE A2,2      YEAR
     C           A2,1      IFGE '0'
     C           A2,1      ANDLE'9'
     C                     MOVELA2,1      YEAR
     C                     END
     C                     ELSE
     C           A2,1      IFGE '0'
     C           A2,1      ANDLE'9'
     C                     MOVE A2,1      YEAR
     C                     END
     C                     END
     C*
     C                     MOVEL'20'      CNTRY
      *
     C                     ADD  1         II
     C                     Z-ADDYMD       DAT,II
      *
     C                     ENDDO
      *
     C           XHDR      ENDSR
     C***************************************************
     C* DETAIL PROCESS
     C***************************************************
     C           #DTL      BEGSR
      *
     C                     Z-ADD1         IX
     C           '-'       LOKUPAY,IX                    10
      * PART#
     C           *IN10     CABEQ*OFF      XDTL
      *
     C                     Z-ADD*ZERO     IX
     C                     Z-ADD*ZERO     IZ
     C                     MOVEL*BLANK    A20
     C                     DO   *HIVAL
     C                     ADD  1         IX
     C           AY,IX     IFEQ ','
     C           AY,IX     OREQ *BLANK
     C                     LEAVE
     C                     END
     C           AY,IX     IFEQ '-'
     C                     ITER
     C                     END
     C                     ADD  1         IZ
     C                     MOVELAY,IX     A20,IZ
     C                     ENDDO
     C                     MOVEAA20       AWMHIN
     C           AWMHIN    IFEQ *BLANK
     C                     GOTO XDTL
     C                     END
      * KANBAN NUMBER
     C                     ADD  1         IX
     C           '-'       LOKUPAY,IX                    10
     C           *IN10     CABEQ*OFF      XDTL
      *
     C           IX        SUB  3         IZ
     C           6         SUBSTDAT1:IZ   AWSBAN
      * QTY/BOX
     C                     ADD  1         IX
     C           ','       LOKUPAY,IX                    10
     C  N10                GOTO XDTL
     C                     Z-ADDIX        IZ
     C                     Z-ADD*ZERO     IW
     C                     MOVEL*BLANK    A9
     C                     DO   *HIVAL
     C                     ADD  1         IZ
     C           AY,IZ     IFEQ ','
     C                     LEAVE
     C                     END
     C                     ADD  1         IW
     C                     MOVELAY,IZ     A9,IW
     C                     ENDDO
      *
     C                     MOVE '0'       A9X
     C                     Z-ADD9         IW
     C                     Z-ADD9         IV      30
     C                     DO   9
     C           A9,IW     IFNE *BLANK
     C                     MOVE A9,IW     A9X,IV
     C                     SUB  1         IV
     C                     END
     C                     SUB  1         IW
     C           IW        IFEQ *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVE @9C       @9      90
     C                     Z-ADD@9        AWSYOS
      * QTY
     C                     Z-ADD*ZERO     IY
     C                     Z-ADD*ZERO     II
     C                     Z-ADD*ZERO     IW
     C                     MOVE *BLANK    A9
     C*
     C                     ADD  1         IX
     C           ','       LOKUPAY,IX                    10
     C  N10                GOTO XDTL
     C                     ADD  1         IX
     C           ','       LOKUPAY,IX                    10
     C  N10                GOTO XDTL
      *
JW3  C                     DO   3
     C*
     C                     ADD  1         IX
     C           ','       LOKUPAY,IX                    10
     C  N10                LEAVE
     C*
     C                     Z-ADDIX        IZ
     C                     Z-ADD*ZERO     IW
     C                     MOVEL*BLANK    A9
      *
     C                     DO   *HIVAL
     C                     ADD  1         IZ
     C           AY,IZ     IFEQ ','
     C           AY,IZ     OREQ ' '
     C                     LEAVE
     C                     END
     C                     ADD  1         IW
     C                     MOVELAY,IZ     A9,IW
     C                     ENDDO
      *
     C                     MOVE '0'       A9X
     C                     Z-ADD9         IW
     C                     Z-ADD9         IV      30
     C                     DO   9
     C           A9,IW     IFNE *BLANK
     C                     MOVE A9,IW     A9X,IV
     C                     SUB  1         IV
     C                     END
     C                     SUB  1         IW
     C           IW        IFEQ *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVE @9C       @9      90
     C                     Z-ADD@9        AWSRYO
     C*
     C                     ADD  1         II
     C*
     C           AWSRYO    IFEQ *ZERO
     C                     ITER
     C                     END
     C*
     C                     Z-ADD0681      AWTOKU
     C                     Z-ADD0681      AWNONY
JW2   * FOR PMT
 |   C           SFLAG     IFEQ 'T'
 |   C                     Z-ADD0682      AWNONY
JW2  C                     ENDIF
      *
     C                     MOVE '0'       AWNKOJ
     C                     MOVE '00  '    AWNUKE
     C           AWSBAN    IFEQ *BLANK
     C                     MOVEL'0000'    AWSBAN
     C                     END
      *
     C           DAT,II    IFGE *DATE
     C                     Z-ADDDAT,II    AWSHDT
     C                     Z-ADDDAT,II    YMD
     C                     MOVELYEAR      YY
     C                     MOVELMONTH     MM
     C                     MOVELDAY       DD
     C                     MOVELORDR      AWORDN
     C                     MOVEL@BLD      AWBLD
     C                     WRITEAB#WPMO1
     C                     MOVE '1'       PID
     C                     END
     C*
     C                     ENDDO
      *
     C           XDTL      ENDSR
     C***************************************************
     C* INITIAL SETTING
     C***************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           PID     1
     C                     MOVE ' '       PID
      *
     C                     ENDSR
