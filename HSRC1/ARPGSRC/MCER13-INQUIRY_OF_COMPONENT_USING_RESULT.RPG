     H            Y.
     F** MCER13 **********************************
     F* ...INQUIRY OF  COMPONENT USING RESULT... *
     F* PROGRAM ID.   : MCER13. <RPG>            *
     F* CREATE DATE.  : MAY.24,'89.              *
     F* AUTHOR.       : E.KAWASHIMA <G.B.C>      *
     F* CHANGE PERSON : S.YAMAGAMI               *
     F*
     F* ADD LOCATION SELECTION
     F*      TCH 03/25/2004
     F* TCHK1 09/06/06 CHG MONTHLY SETTING VOLUME
     F********************************** MCER13 **
     FMCEPW13 CF  E                    WORKSTN
     F                                        RRN   KSFILE DSP2R
     FMCENP13 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
TCHK1FFCEPL11 IF  E           K        DISK
     FAKBPL01 IF  E           K        DISK
     E                    MSG     1   3 60               d[ｰxｮﾈｰﾆﾞ
     I            DS
     I                                        1  14 @HIN
     I                                        1   5 @HIN1
     I                                        6   6 @HINA
     I                                        7  11 @HIN2
     I                                       12  12 @HINB
     I                                       13  14 @HIN3
     C* KEY *
     C           KEY       KLIST
     C                     KFLD           MCSHN1
     C                     KFLD           MCSHN2
     C                     KFLD           MCSHN3
     C           K#AKB     KLIST
     C                     KFLD           D@LOC1
     C                     KFLD           D@LOC2
     C                     KFLD           D@LOC3
     C                     KFLD           D@LOC4
     C******************************************************
     C*  START  PROGRAM <GCER13>                           *
     C******************************************************
     C           *ENTRY    PLIST
     C                     PARM           @YYMM   6
     C                     MOVEL@YYMM     YYMM    60
     C*
     C           STP0      TAG
     C                     MOVE *BLANK    HIN1
     C                     MOVE *BLANK    HIN2
     C                     MOVE *BLANK    HIN3
     C                     MOVE *BLANK    D@LOC1
     C                     MOVE *BLANK    D@LOC2
     C                     MOVE *BLANK    D@LOC3
     C                     MOVE *BLANK    D@LOC4
     C                     Z-ADD0         TOT1
     C                     Z-ADD0         TOT2
     C                     Z-ADD0         TOT3
     C******************************************************
     C*  EXFMT  <fﾞx] 1>                                   *
     C******************************************************
     C           STP1      TAG
     C                     EXFMTMCEPW131
     C                     MOVEA'00'      *IN,01
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    ERR
     C*
     C           *INKA     IFEQ '1'
     C                     MOVEL'1'       *INLR
     C                     RETRN
     C                     END
     C*
     C******************************************************
     C*  <fﾞx] 1 ﾉ kｩｮh>                                   *
     C******************************************************
     C*
     C*  ﾍ]ﾌﾞ] kｩｮh
     C*
     C           HIN1      IFEQ *BLANK
     C           HIN2      ANDEQ*BLANK
     C           HIN3      ANDEQ*BLANK
     C           D@LOC1    ANDEQ*BLANK
     C           D@LOC2    ANDEQ*BLANK
     C           D@LOC3    ANDEQ*BLANK
     C                     MOVEA'1'       *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,1     ERR
     C                     GOTO STP1
     C                     END
      *
     C           HIN1      IFEQ *BLANK
     C           D@LOC1    ANDNE*BLANK
     C           K#AKB     SETLLAKBPL01
     C           *IN90     DOUEQ*ON
     C           K#AKB     READEAKBPL01                  90
     C           *IN90     IFEQ *OFF
     C           L1SKJY    ANDEQ*BLANK
     C           L1STHZ    ANDEQ99999999
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     MOVE *ON       *IN02
     C                     MOVE *ON       *IN88
     C                     MOVELMSG,2     ERR
     C                     GOTO STP1
     C                     ELSE
     C                     MOVE L1SHN1    HIN1
     C                     MOVE L1SHN2    HIN2
     C                     MOVE L1SHN3    HIN3
     C                     ENDIF
      *
     C                     ENDIF
     C*
     C           KEY1      KLIST
     C                     KFLD           HIN1
     C                     KFLD           HIN2
     C                     KFLD           HIN3
     C                     EXSR #SET
     C*
     C           ERR       IFNE *BLANK
     C                     MOVEA'1'       *IN,99
     C           D@LOC1    IFNE *BLANK
     C                     MOVE *BLANK    HIN1
     C                     MOVE *BLANK    HIN2
     C                     MOVE *BLANK    HIN3
     C                     ENDIF
     C                     GOTO STP1
     C                     END
     C*
     C******************************************************
     C*  EXFMT  (fﾞx] 2)                                   *
     C******************************************************
     C           STP2      TAG
     C                     WRITEDSP2X
     C                     MOVEA'1'       *IN,91
     C                     EXFMTDSP2C
     C                     MOVEA'0'       *IN,91
     C*
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    ERR
     C*
     C           *INKC     IFEQ '1'
     C                     GOTO STP0
     C                     END
     C*
     C                     GOTO STP2
     C*
     C******************************************************
     C           #SET      BEGSR                           *
     C******************************************************
     C*
     C                     Z-ADD0         RRN
     C                     MOVEA'1'       *IN,92
     C                     WRITEDSP2C
     C                     MOVEA'0'       *IN,92
     C*
     C           KEY1      SETLLMCENP131
     C                     MOVE *BLANK    @HIN
     C                     Z-ADD0         @IAFY
     C                     Z-ADD0         @IAFN
     C                     Z-ADD0         TOT1
     C                     Z-ADD0         TOT2
     C                     Z-ADD0         TOT3
     C                     DO   *HIVAL
     C           KEY1      READEMCENP131                 50
     C           *IN,50    IFEQ '0'
     C                     MOVE *BLANK    @HIN
     C                     MOVELMCSHN1    @HIN1
     C                     MOVELMCSHN2    @HIN2
     C                     MOVELMCSHN3    @HIN3
     C           @HIN2     IFNE *BLANK
     C                     MOVEL'-'       @HINA
     C                     END
     C*
     C           @HIN3     IFNE *BLANK
     C                     MOVEL'-'       @HINB
     C                     END
     C*
     C                     Z-ADD0         @IAFY
     C                     Z-ADD0         @IAFN
     C*
     C           MCTHCD    IFEQ 0111
     C                     Z-ADDMCSRYO    @IAFY
     C                     ADD  @IAFY     TOT1
     C                     ELSE
     C                     Z-ADDMCSRYO    @IAFN
     C                     ADD  @IAFN     TOT2
     C                     END
     C*号口以外の処理*
     C                     Z-ADD0         @SETI
     C                     SETOF                     3031
     C           KEY       CHAINFCEPL011             31
     C           *IN31     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C                     SETON                     31
     C                     END
     C           *IN31     IFEQ '0'
     C                     Z-ADDA2GEKN    @SETI
TCHK1C           KEY       CHAINFCEPL11              94
TCHK1C           *IN94     IFEQ *OFF
TCHK1C           FCCD01    ANDNE*ZERO
TCHK1C           FCGK01    DIV  FCCD01    @@QTY   90
TCHK1C           @@QTY     MULT 20        @SETI
TCHK1C                     END
     C                     ADD  @SETI     TOT3
     C           A2TEHI    IFNE 'G'
     C                     SETON                     30
     C                     END
     C                     END
     C*
     C                     ADD  1         RRN
     C                     WRITEDSP2R
     C                     END
     C  N50                END
     C*
     C           RRN       IFEQ 0
     C                     MOVEA'1111'    *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,2     ERR
     C                     END
     C*
     C                     ENDSR
     C*
     C*
     C*
**  MSG (ERROR MESSAGE )
E-01 INPUT COMPONENTS NO OR LOCATION
E-02 THERE ISN'T APPLICABLE DATA
E-03 LOCATION CODE ERROR.
