     H            Y.
     F** GCQR88 *******************************************************
     F*  DIE SETTING# INQUIRY ( CALCULATE THE NUMBER OF SHEETS )      *
     F*----------+-----+---------+------------------------------------*
     F*2022.05.13|TEC. |T.MITSUI | 22047  INITIAL VERSION.            *
     F******************************************************* GCQR88 **
     F*          FILE DEFINE                              *
     F*****************************************************
     F*==< DIE INFORMATION DATA (2) >==*
     FGCQWP87 IF  E           K        DISK
     F*
     F*
     F*==< DIE INFORMATION DATA (3) >==*
     FGCQWP88 O   E                    DISK
     F*
     E*****************************************************
     E*          ARRAY DEFINE                             *
     E*****************************************************
     E                    @KOS        6  5 0
     E                    @SRO        6 11 0
     E*
     I*****************************************************
     I*          DATA STRACTURE DEFINE                    *
     I*****************************************************
     I*==< SYSTEM INF. >==*
     I           SDS
     I                                     *PROGRAM @@PGM
     I                                      244 253 @@WSID
     I                                      254 263 @@USER
     I                                      264 269 @@JBNO
     I*==< GCQWP87 >==*
     I            DS
     I                                        1   6 W2KEY@
     I                                        1   2 W2KAT1
     I                                        3   6 W2KAT2
     I*==< GCQWP88 >==*
     I            DS
     I                                    P   1  180@KOS
     I                                    P   1   30W3KOS5
     I                                    P   4   60W3KOS4
     I                                    P   7   90W3KOS3
     I                                    P  10  120W3KOS2
     I                                    P  13  150W3KOS1
     I                                    P  16  180W3KOS0
     I            DS
     I                                    P   1  360@SRO
     I                                    P   1   60W3SRO5
     I                                    P   7  120W3SRO4
     I                                    P  13  180W3SRO3
     I                                    P  19  240W3SRO2
     I                                    P  25  300W3SRO1
     I                                    P  31  360W3SRO0
     I*==< WORK >==*
     I            DS
     I                                        1  140S@TIME
     I                                        1   60S@HMS
     I                                        7  140S@YMD
     I            DS
     I                                        1   6 W@KEY@
     I                                        1   2 W@KAT1
     I                                        3   6 W@KAT2
     I*
     C*****************************************************
     C*          PARM LIST                                *
     C*****************************************************
     C           *ENTRY    PLIST
     C                     PARM           P@BASE  60
     C                     PARM           P@EXTR  1
     C                     PARM           P@DISP  1
     C*
     C*****************************************************
     C*          MAIN ROUTINE                             *
     C*****************************************************
     C                     TIME           S@TIME
     C*                    ____________
     C           *LOVAL    SETLLGCQWP87
     C                     READ GCQWP87                  91
     C*                    ~~~~~~~~~~~~
D----C           *IN91     DOWEQ'0'
|    C                     EXSR #IZ88
|    C                     MOVELW2KEY@    W@KEY@
|    C*
|D---C           *IN91     DOWEQ'0'
||   C           W2KEY@    ANDEQW@KEY@
||   C                     ADD  W2SRO5    W3SRO5
||   C                     ADD  W2SRO4    W3SRO4
||   C                     ADD  W2SRO3    W3SRO3
||   C                     ADD  W2SRO2    W3SRO2
||   C                     ADD  W2SRO1    W3SRO1
||   C                     ADD  W2SRO0    W3SRO0
||   C                     ADD  W2FSM0    W3FSM0
||   C                     ADD  W2FSM1    W3FSM1
||   C                     ADD  W2FSM2    W3FSM2
||   C*                    ____________
||   C                     READ GCQWP87                  91
||   C*                    ~~~~~~~~~~~~
|E---C                     ENDDO
|    C*
|    C                     EXSR #WT88
E----C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C*****************************************************
     C*  #IZ88   GCQWP88 INITIALIZE                       *
     C*****************************************************
     C           #IZ88     BEGSR
     C*
     C                     CLEARGCQWP881
     C                     MOVELW2KAT1    W3KAT1
     C                     MOVELW2KAT2    W3KAT2
     C                     Z-ADDW2LTIM    W3LTIM
     C                     Z-ADDW2SYOS    W3SYOS
     C                     Z-ADDW2SRYO    W3SRYO
     C                     Z-ADDW2MAIS    W3MAIS
     C                     Z-ADDW2SQTY    W3SQTY
     C                     Z-ADDW2YYM5    W3YYM5
     C                     Z-ADDW2YYM4    W3YYM4
     C                     Z-ADDW2YYM3    W3YYM3
     C                     Z-ADDW2YYM2    W3YYM2
     C                     Z-ADDW2YYM1    W3YYM1
     C                     Z-ADDW2YYM0    W3YYM0
     C                     Z-ADDW2KOS5    W3KOS5
     C                     Z-ADDW2KOS4    W3KOS4
     C                     Z-ADDW2KOS3    W3KOS3
     C                     Z-ADDW2KOS2    W3KOS2
     C                     Z-ADDW2KOS1    W3KOS1
     C                     Z-ADDW2KOS0    W3KOS0
     C*
     C           #IZ88E    ENDSR
     C*****************************************************
     C*  #WT88   GCQWP88 CALCUTATE & WRITE                *
     C*****************************************************
     C           #WT88     BEGSR
     C*
     C*==< CALCULATION OF SPAN OF LIFE >==*
     C                     XFOOT@KOS      W@KOS@  50
     C                     XFOOT@SRO      W@SRO@ 110
I----C           W@KOS@    IFNE *ZERO
|    C           W@SRO@    DIV  W@KOS@    W3AVSL
+----C                     ELSE
|    C                     Z-ADD*ZERO     W3AVSL
E----C                     ENDIF
     C*
     C*==< SET THE VALUE >==*
     C                     Z-ADD1.25      W3APSF
     C                     Z-ADD20.0      W3AVOD
     C                     Z-ADD34.0      W3APLT
     C                     Z-ADD1.1       W3APCF
     C                     Z-ADD0.5       W3APIF
     C*
     C*==< N >==*
     C*        ( CALCULATE THE NUMBER NEEDED PER MONTH )
I----C           W3AVSL    IFNE *ZERO
|    C           W3FSM0    DIV  W3AVSL    W3RQM0
+----C                     ELSE
|    C                     Z-ADD*ZERO     W3RQM0
E----C                     ENDIF
     C*
     C*        ( CALCULATE THE NUMBER OF SHEETS )
     C           W3RQM0    MULT W3APSF    W@NUM1 114
     C           W3SYOS    MULT W3AVOD    W@NUM2 114
     C           W@NUM1    DIV  W@NUM2    W@NUM3 114
     C           W3APLT    MULT W3APCF    W@NUM4 114
     C           W@NUM3    MULT W@NUM4    W@NUM5 114
     C           W3RQM0    DIV  W3SYOS    W@NUM6 114
     C           W@NUM6    MULT W3APIF    W@NUM7 114
     C           W@NUM5    ADD  W@NUM7    W@NUM8 114
     C           W@NUM8    ADD  0.9999    W3CLN0
     C                     MOVEL*BLANK    W3CLF0
I----C           W3CLN0    IFEQ *ZERO
|    C                     Z-ADD1         W3CLN0
|    C                     MOVEL'*'       W3CLF0
E----C                     ENDIF
     C           W3CLN0    SUB  W3MAIS    W3CLD0
     C*
     C*==< N+1 >==*
     C*        ( CALCULATE THE NUMBER NEEDED PER MONTH )
I----C           W3AVSL    IFNE *ZERO
|    C           W3FSM1    DIV  W3AVSL    W3RQM1
+----C                     ELSE
|    C                     Z-ADD*ZERO     W3RQM1
E----C                     ENDIF
     C*
     C*        ( CALCULATE THE NUMBER OF SHEETS )
     C           W3RQM1    MULT W3APSF    W@NUM1 114
     C           W3SYOS    MULT W3AVOD    W@NUM2 114
     C           W@NUM1    DIV  W@NUM2    W@NUM3 114
     C           W3APLT    MULT W3APCF    W@NUM4 114
     C           W@NUM3    MULT W@NUM4    W@NUM5 114
     C           W3RQM1    DIV  W3SYOS    W@NUM6 114
     C           W@NUM6    MULT W3APIF    W@NUM7 114
     C           W@NUM5    ADD  W@NUM7    W@NUM8 114
     C           W@NUM8    ADD  0.9999    W3CLN1
     C                     MOVEL*BLANK    W3CLF1
I----C           W3CLN1    IFEQ *ZERO
|    C                     Z-ADD1         W3CLN1
|    C                     MOVEL'*'       W3CLF1
E----C                     ENDIF
     C           W3CLN1    SUB  W3MAIS    W3CLD1
     C*
     C*==< SORT ITEM >==*
S----C                     SELEC
+----C           P@DISP    WHEQ '1'
|    C                     Z-ADD*ZERO     W3SRTA
|    C                     Z-ADD*ZERO     W3SRTB
|    C*
+----C           P@DISP    WHEQ '2'
|I---C           W3CLD0    IFGE *ZERO
||   C                     Z-ADDW3CLD0    W3SRTA
|+---C                     ELSE
||   C                     Z-SUBW3CLD0    W3SRTA
|E---C                     ENDIF
|    C                     Z-ADD*ZERO     W3SRTB
|    C*
+----C           P@DISP    WHEQ '3'
|I---C           W3CLD1    IFGE *ZERO
||   C                     Z-ADDW3CLD1    W3SRTA
|+---C                     ELSE
||   C                     Z-SUBW3CLD1    W3SRTA
|E---C                     ENDIF
|    C                     Z-ADD*ZERO     W3SRTB
E----C                     ENDSL
     C*                    _____________
     C                     WRITEGCQWP881
     C*                    ~~~~~~~~~~~~~
     C           #WT88E    ENDSR
     C*
