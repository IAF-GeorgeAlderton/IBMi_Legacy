     C                     MOVE *BLANK    H2
     C                     Z-ADD*ZERO     Y       20
     C           1         DO   20        X       20
     C           H1,X      IFNE *BLANK
     C           H1,X      ANDNE'-'
     C           H1,X      ANDNE','
     C           H1,X      ANDNE'.'
     C                     ADD  1         Y
     C                     MOVE H1,X      H2,Y
     C                     ENDIF
     C                     ENDDO
     C                     MOVEAH2        WMHIN
