     F*************************** FBCR06 **
     FFBCPW06 CF  E                    WORKSTN
     FFBCPL02 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FFBCWP06 O   F     100            DISK
JW1  E                    ER      1   5 60
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
JW1   * PARAMETER
"    C           *ENTRY    PLIST
"    C                     PARM           $PTR    1
      *
     C           STP1      TAG
     C                     EXFMTFBCPW061
     C                     SETOF                     3199
JW1  C                     SETOF                     32
"    C                     MOVE *BLANK    @ERR
      *
     C           *IN01     IFEQ '1'
     C                     GOTO LAST
     C                     END
      * CHECK DELIVERY
     C           @NONY     IFEQ 0
     C                     SETON                     3199
     C                     MOVE ER,1      @ERR
     C                     GOTO STP1
     C                     END
     C                     MOVE @NONY     WNONY   40
      *
     C                     SETOF                     11
     C           WNONY     CHAINFGBPL011             11
     C           *IN11     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C**JW1      B2SKHZ    ANDLE*DATE
     C                     SETON                     11
     C                     END
     C           *IN11     IFEQ '1'
     C                     SETON                     0199
     C                     MOVE ER,2      @ERR
     C                     GOTO STP1
     C                     END
JW1   * CHECK PRINTER
 |   C           @PTR      IFEQ 0
 |   C                     SETON                     3299
 |   C                     MOVE ER,3      @ERR
 |   C                     GOTO STP1
 |   C                     ENDIF
 |    *
 |   C           @PTR      IFNE 1
 |   C           @PTR      ANDNE2
 |   C           @PTR      ANDNE9
 |   C                     SETON                     3299
 |   C                     MOVE ER,4      @ERR
 |   C                     GOTO STP1
 |   C                     ENDIF
JW1  C                     MOVE @PTR      $PTR
      *
     C           *IN05     IFEQ '0'
 |   C                     MOVE ER,5      @ERR
     C                     GOTO STP1
     C                     END
      *
     C           @NONY     SETLLFBCPL021
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           WNONY     READEFBCPL021                 10
     C           *IN10     IFEQ '0'
     C           FBSKJY    IFEQ 'D'
     C**JW1      FBSKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     SETON                     U1
     C                     EXCPTDT
      *
     C                     END
     C                     END
     C  N10                END
      *
     C           LAST      TAG
     C                     SETON                     LR
     C                     RETRN
      *
     OFBCWP06 E                DT
     O                         FBTOKU     4
     O                         FBNONY     8
     O                         FBNKOJ     9
     O                         FBNUKE    13
     O                         FBMHIN    33
     O                         FBOTAN    43
     O                         FBNTAN    53
     O                         FBTKHZ    61
     O                         FBTSHZ    69
      *
** ER
