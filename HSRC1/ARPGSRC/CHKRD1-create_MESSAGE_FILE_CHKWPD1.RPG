     H            Y.
      ** CHKRD1 *******************************************************
      * ..メッセージファイル作成..
      *  KIRI 2016.12.02
      *****************************************************************
     FCHKWPD0 IP  F     256            DISK
     FCHKWPD1 O   E                    DISK
      *================================================================
     ICHKWPD0 AA
     I                                        1   6 I$HED
      *                                                    １行目
     I                                        2   8 I$MSGI
     I                                       11  12 I$SEV
     I                                       15  26 I$MSGT
     I                                       28 159 I$MSG
      *                                                    ２行目
     I                                       24  33 I$JOB
     I                                       35  44 I$USER
     I                                       46  51 I$JOBN
     I                                       71  78 I$DATE
     I                                       80  94 I$TIME
      *
     I              '  5770'              C         $5570
     I              ' MSGID'              C         $MSGID
      *================================================================
     C           I$HED     IFEQ $5570
     C                     SETON                     11
     C                     SETOF                     12
     C                     GOTO @END
     C                     ENDIF
     C*
     C           I$HED     IFEQ $MSGID
     C   11                SETON                     12
     C                     GOTO @END
     C                     ENDIF
      ***********
     C                     SETOF                     11
     C           *IN12     IFEQ *ON
     C           *IN13     IFEQ *OFF
     C                     CLEARCHKWPD11
     C                     MOVELI$MSGI    W@MSGI
     C                     MOVELI$SEV     W@SEV
     C                     MOVELI$MSGT    W@MSGT
     C                     MOVELI$MSG     W@MSG
     C                     SETON                     13
     C                     ELSE
     C                     MOVELI$JOB     W@JOB
     C                     MOVELI$USER    W@USER
     C                     MOVELI$JOBN    W@JOBN
     C                     MOVELI$DATE    W@DATE
     C                     MOVELI$TIME    W@TIME
     C                     WRITECHKWPD11
     C                     SETOF                     13
     C                     ENDIF
     C                     ENDIF
      *
      *
     C           @END      TAG
