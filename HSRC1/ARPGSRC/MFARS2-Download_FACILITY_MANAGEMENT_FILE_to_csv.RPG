     H            Y.
     H* MFARS2 *************************************************
     H* DOWNLOAD FACILITY MANAGEMENT FILE TO CSV SV            *
     H* JW       2025.12.02                                    *
     H**********************************************************
     FMFAPL25 IF  E           K        DISK
     FMFAWP21 O   E                    DISK
      **********************************************************
     E                    TXT     1   8 11
      * EDIT COST
     I            DS
     I                                        1   9 W@COST
     I                                        1   1 M@W1
     I                                        2   3 M@COS1
     I                                        4   4 M@H1
     I                                        5   6 M@COS2
     I                                        7   7 M@H2
     I                                        8   9 M@COS3
      * EDIT ASSET
     I            DS
     I                                        1   9 W@ASET
     I                                        1   4 M@SYS1
     I                                        5   5 M@H3
     I                                        6   9 M@SYS2
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     C**********************************************************
     C* MAIN
     C**********************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ MFAPL25                  98
     C   98                LEAVE
      *
     C           M@SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           P@KBN1    IFNE *BLANK
     C           P@KBN1    ANDNEM@KBN1
     C                     ITER
     C                     ENDIF
      *
     C           P@KGUN    IFNE *BLANK
     C           P@KGUN    ANDNEM@KGUN
     C                     ITER
     C                     ENDIF
      *
     C           P@COS1    IFNE *BLANK
     C           P@COS1    ANDNEM@COS1
     C                     ITER
     C                     ENDIF
      *
     C           P@COS2    IFNE *BLANK
     C           P@COS2    ANDNEM@COS2
     C                     ITER
     C                     ENDIF
      *
     C           P@COS3    IFNE *BLANK
     C           P@COS3    ANDNEM@COS3
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #SET
      *
     C                     WRITEMFAWP211
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C**********************************************************
     C* SET DATA
     C**********************************************************
     C           #SET      BEGSR
      *
     C                     CLEARMFAWP211
      * SET HEADER
     C                     MOVELM@KOJY    M2KOJY
     C                     MOVELM@KOTE    M2KOTE
     C                     MOVELM@KBN1    M2KBN1
     C                     MOVELM@KGUN    M2KGUN
     C                     MOVELW@COST    M2COST
     C                     MOVELW@ASET    M2ASET
     C                     MOVELM@RPMH    M2RPMH
      *
     C                     ENDSR
     C**********************************************************
     C* INITIAL SETTING
     C**********************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@KBN1  3
     C                     PARM           P@KGUN  3
     C                     PARM           P@COS1  2
     C                     PARM           P@COS2  2
     C                     PARM           P@COS3  2
     C                     PARM           P@SYS1  4
     C                     PARM           P@SYS2  4
      *
     C                     TIME           SDATE
     C                     MOVELTXT,8     M@W1
     C                     MOVE '-'       M@H1
     C                     MOVE '-'       M@H2
     C                     MOVE '-'       M@H3
      * SET HEADER
     C                     MOVELTXT,01    M2KOJY
     C                     MOVELTXT,02    M2KOTE
     C                     MOVELTXT,03    M2KBN1
     C                     MOVELTXT,04    M2KGUN
     C                     MOVELTXT,05    M2COST
     C                     MOVELTXT,06    M2ASET
     C                     MOVELTXT,07    M2RPMH
     C                     MOVEL#PGM      M2FIL1
     C                     MOVE TODAY     M2FIL1
      *
     C                     WRITEMFAWP211
      *
     C                     ENDSR
** TXT 11A
DEPT         1
PROCESS      2
MACHINE      3
GROUP        4
COST CENTER  5
ASSET        6
TURN/H       7
'            8
