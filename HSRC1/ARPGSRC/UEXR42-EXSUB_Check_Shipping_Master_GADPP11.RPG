     H            Y.
      ** UEXR42 ****************************************************
      *  CHECK SHIPPING MASTER                                     *
      *  JW     2021.05.24                                         *
      **************************************************************
      *  CALLING SEQ.                                              *
     C*                    CALL 'UEXR42 '
     C*                    PARM           $TOKU   4
     C*                    PARM           $NONY   4
     C*                    PARM           $NKOJ   1
     C*                    PARM           $NUKE   4
     C*                    PARM           $RTN    1
     F*   IN  $TOKU   4A  CUSTOMER#                                *
     F*       $NONY   4A  DELIV#                                   *
     F*       $NKOJ   1A  FACTORY                                  *
     F*       $NUKE   4A  DOCK                                     *
     F*   OUT $RTN    1A  RETURN FLAG (BLANK=OK,                   *
     F*                   Y = OK                                   *
     F*                   N =SHIPPING INF NOT FOUND                *
      **************************************************************
     FGADPL11 IF  E           K        DISK
      ***********************************************************
     E                    IN         20  1
     E                    OT         20  1
     I            DS
     I                                        1  140WSDT
     I                                        1   60NOW
     I                                        7  140TODAY
      ****************************************************
      * MAIN ROUTINE
      ****************************************************
     C                     EXSR #INIT
      *
     C                     MOVEL$TOKU     @TOKU   40
     C                     MOVEL$NONY     @NONY   40
     C           @TOKU     SETLLGADPL11
     C                     DO   *HIVAL
     C           @TOKU     READEGADPL11                  98
     C   98                LEAVE
      *
     C           B5SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * CHECK NONY
     C           $NONY     IFNE *BLANK
     C           @NONY     ANDNEB5NONY
     C                     ITER
     C                     ENDIF
      * CHECK NKOJ
     C           $NKOJ     IFNE *BLANK
     C           B5NKOJ    ANDNE*BLANK
     C           B5NKOJ    ANDNE'0'
     C           $NKOJ     ANDNEB5NKOJ
     C                     ITER
     C                     ENDIF
      * CHECK NKUKE
     C           $NUKE     IFNE *BLANK
     C           B5NUKE    ANDNE*BLANK
     C           B5NUKE    ANDNE'0'
     C           B5NUKE    ANDNE'00'
     C           $NUKE     ANDNEB5NUKE
     C                     ITER
     C                     ENDIF
      *
     C                     MOVEL'Y'       OKFLG
     C                     LEAVE
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ****************************************************
      * INITIALIZE
      ****************************************************
     C           #INIT     BEGSR
     C*
     C           *ENTRY    PLIST
     C                     PARM           $TOKU   4        IN
     C                     PARM           $NONY   4        "
     C                     PARM           $NKOJ   1        "
     C                     PARM           $NUKE   4        "
     C                     PARM           $RTN    1        OUT
      *
     C                     MOVE 'N'       OKFLG   1
      *
     C                     ENDSR
