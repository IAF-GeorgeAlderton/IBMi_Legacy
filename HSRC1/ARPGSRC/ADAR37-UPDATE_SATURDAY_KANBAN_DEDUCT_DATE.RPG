     H            Y/
     F***************************************************
     F*   UPDATE SATURDAY KANBAN DEDUCT DATE            *
     F*              NOV/13/01                          *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FADAPW37 CF  E                    WORKSTN
     F                                              KINFDS @INFDS
     FAD#PL12 UF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
      *------------------------------------------------------------
     E                    CMD     1   2 78
     E                    ERR     1   2 78
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80W@YMD
     I                                        1   40CATEYY
     I                                        5   60CATEMM
     I                                        7   80CATEDD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C           W@ID      CASEQ'02'      #DSP02
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#AD      KLIST
     C                     KFLD           D@DELV
     C********             KFLD           K@FACT  1
     C                     KFLD           D@DOCK
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C                     KFLD           K@GYM   2
      *
     C           K#AG      KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
      *
     C                     MOVEL'01'      W@ID    2
     C                     MOVEL'16'      K@GYM
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     MOVEL'02'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C                     Z-ADDD@DAT1    K@YMD
     C           K#AD      CHAINAD#PL12             N90
     C           *IN90     IFEQ *ON
     C                     MOVEA'1111'    *IN,61
     C                     MOVE *ON       *IN99
     C                     MOVE ERR,1     D@MSG
     C                     ELSE
     C                     Z-ADDW@YMD     D@DAT3
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #DSP02    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP02
      *
     C                     SELEC
      * F1
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * F12
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
      * F5
     C                     OTHER
     C                     EXSR #CHK2
     C           *INKE     IFEQ *ON
     C           *IN99     ANDEQ*OFF
     C                     EXSR #UPD
     C                     MOVEL'01'      W@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     EXSR #CLR
     C           D@DAT3    IFEQ *ZERO
     C           D@DAT3    ORLT *DATE
     C                     SETON                     6599
     C                     MOVE ERR,2     D@MSG
     C                     ELSE
     C                     Z-ADDD@DAT3    K@YMD
     C           K#AG      CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6599
     C                     MOVE ERR,2     D@MSG
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   UPDATE
      *------------------------------------------------------
     C           #UPD      BEGSR
      *
     C                     Z-ADDD@DAT1    K@YMD
     C           K#AD      SETLLAD#PL12
     C           *IN90     DOUEQ*ON
     C           K#AD      READEAD#PL12                  90
     C           *IN90     IFEQ *OFF
     C           CASKJY    ANDEQ*BLANK
     C           CANSRY    ANDLT*ZERO
     C                     Z-ADDD@DAT3    W@YMD
     C                     UPDATAD#PP111
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD*ZERO     D@DAT1
     C                     Z-ADD*ZERO     D@DELV
     C                     MOVE *BLANK    D@FACT
     C                     MOVE *BLANK    D@DOCK
      *
     C                     ENDSR
      *------------------------------------------------------
**  CMD
F1: END
