     H            Y.                                    1
     H***ALGR20*****************************************************************
     H*  HEAT TREAT PRE-LOAD SIGN PRINT                                        *
     H*
     H* LEC   02/25/20 CREATE
     H**************************************************************************
     FALGPW20 CF  E                    WORKSTN
     FMFAPL34 IF  E           K        DISK
      *
     FALGPR20 O   E                    PRINTER                        UC
      **************************************************************************
     E                    ERR     1   5 60
      **************************************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I            DS
     I                                        1  16 QRBC
     I                                        1  15 HTBCIN
     I I            'L01'                     1   3 HTQRID
     I                                        4   6 HTMCH#
     I                                        4   5 SATSUN
     I                                        7   90HTTIME
     I                                       10  120HTTEMP
     I                                       13  152HTCO2
     I                                       16  16 HTCHDG
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'10'      #FMT10
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      **************************************************************************
      *         INITIALIZE
      **************************************************************************
     C           *INZSR    BEGSR
      *
      * FOR QR CHECK DIGIT
     C           P#BRC     PLIST
     C                     PARM           PMAREA100
     C                     PARM           PMBYTE  3
     C                     PARM           PMCHK   1
     C                     PARM           PMRTCD  1
      *
     C                     CLEARFMT100
      *
     C                     MOVEL'10'      @@ID    2
     C                     SETOF                     313233
     C                     SETOF                     3499
     C                     MOVEL*BLANK    MSG
      *
     C                     ENDSR
      *************************************************************************
      *     1ST SCREEN
      **************************************************************************
     C           #FMT10    BEGSR
      *
     C                     EXFMTFMT100
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN99
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK10
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #PRINT
     C                     RESETQRBC
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************************
      *     1ST SCREEN CHECK
      **************************************************************************
     C           #CHK10    BEGSR
      *
     C                     SETOF                     313233
     C                     SETOF                     3499
     C                     MOVE 'N'       TMPLOC  1
      *
     C                     DO
      *
     C           SATSUN    IFEQ 'SS'
     C                     MOVE 'Y'       TMPLOC           TEMP LOCATION
     C                     ENDIF
      *
      * machine # check...
     C           HTMCH#    CHAINMFAPL34              51
     C           *IN51     IFEQ *OFF
     C           M@SKJY    ANDEQ*BLANK
     C           TMPLOC    OREQ 'Y'
      *               do nothing
     C                     ELSE
     C                     SETON                     3199
     C                     MOVELERR,1     MSG
     C                     LEAVE
     C                     ENDIF
      *
      * time check...
     C           HTTIME    IFEQ *ZERO
     C           TMPLOC    ANDEQ'N'
     C                     SETON                     3299
     C                     MOVELERR,2     MSG
     C                     LEAVE
     C                     ENDIF
      *
      * temperature check...
     C           HTTEMP    IFEQ *ZERO
     C           TMPLOC    ANDEQ'N'
     C                     SETON                     3399
     C                     MOVELERR,3     MSG
     C                     LEAVE
     C                     ENDIF
      *
      * CO2 % check...
     C           HTCO2     IFEQ *ZERO
     C           TMPLOC    ANDEQ'N'
     C                     SETON                     3499
     C                     MOVELERR,4     MSG
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************************
      *       PRINT DETAIL
      **************************************************************************
     C           #PRINT    BEGSR
      *
     C                     OPEN ALGPR20
      *
     C           TMPLOC    IFEQ 'Y'
     C                     Z-ADD*ZERO     HTTIME
     C                     Z-ADD*ZERO     HTTEMP
     C                     Z-ADD*ZERO     HTCO2
     C                     ENDIF
      *
     C                     MOVELHTBCIN    PMAREA    P
     C                     MOVE '015'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
      * get check digit...
     C                     CALL 'ALBRCC'  P#BRC
      *
     C                     MOVELPMCHK     HTCHDG
      *
     C                     MOVELQRBC      P@QRBC
     C                     MOVELHTMCH#    P@MACH
     C                     MOVELHTTIME    P@TIME
     C                     MOVELHTTEMP    P@TEMP
     C                     MOVELHTCO2     P@CO2
      *
     C                     WRITEP@SIGN
      *
     C                     CLOSEALGPR20
      *
     C                     MOVELERR,5     MSG
     C                     MOVE *ON       *IN99
      *
     C                     ENDSR
      **************************************************************************
** ERR
MACHINE# NOT FOUND
TIME CANNOT BE ZERO
TEMPERATURE CANNOT BE ZERO
CO2 % CANNOT BE ZERO
  SIGN HAS BEEN CREATED
