     FAFFWP19 IF  E           K        DISK
     FAL#PP21 IF  E           K        DISK
     FAL#PPG1 O   E           K        DISK
      *
     E                    RTE        30 10
      *-----------------------------------------------------------------
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   80AFSHDT
     I                                        1   40WNOYY
     I                                        5   60WNOMM
     I                                        7   80WNODD
     I            DS
     I                                        1   80YYMMDD
     I                                        1   4 YY
     I                                        5   6 MM
     I                                        7   8 DD
      *
     I            DS
     I                                        1   40HHMM
     I                                        1   2 HH
     I                                        3   4 MN
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *
     C           *ENTRY    PLIST
     C                     PARM           EFFDAT  80
      *
      *----------------------------------------------------*
      * MAIN ROUTINE
      *----------------------------------------------------*
      *
     C                     TIME           WSDT
      *
      *
     C           *IN50     DOWEQ*OFF
     C                     READ AFFWP19                  50
     C   50                LEAVE
      *
     C           A9NAMC    IFEQ '50SER'
     C                     ITER
     C                     ENDIF
      *
     C                     CLEARAL#PPG11
      *
     C           A9NAMC    CHAINAL#PP21              51
     C           *IN51     IFEQ *OFF
     C                     Z-ADDC2TOKU    CGTOKU
     C                     Z-ADDC2NONY    CGNONY
     C                     ENDIF
      *
     C                     Z-ADDTODAY     CGKOHZ
     C                     Z-ADDNOW       CGKOTI
     C                     MOVEL#USER     CGKOME
     C                     MOVELA9NUKE    CGNUKE
     C                     MOVELA9SURT    CGSURT
     C                     Z-ADDEFFDAT    CGKIHZ
     C                     WRITEAL#PPG11
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
