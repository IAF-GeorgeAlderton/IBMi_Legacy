     H            Y.
      ** MYAR12 ********************************
      * PLURA PLANES TURN RATIO MASTER INQUIRY *
      *複数機番比率マスター照会              *
      *負荷グラフデータ                      *
      *   I-HASADA                2013/03/11   *
      ******************************** MYAR12 **
     FMYAPW12 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL
     FMYAPL11 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FFCETL03 IF  E           K        DISK
      *
     E                    HSJ         4  1               数字検索
     E                    TSU    10  10  1               数字0-9
     E                    ER      1   7 70               d[ｰxｮﾈｰﾆﾞ
      *
     I            DS
     I                                        1   80W1SKHZ
     I                                        1   40W1SKYY
     I                                        5   60W1SKMM
     I                                        7   80W1SKDD
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
     I            DS
     I                                        1   80A6GSHZ
     I                                        1   40A6GSYY
     I                                        5   60A6GSMM
     I                                        7   80A6GSDD
     I            DS
     I                                        1  12 IDHNB
     I                                        1   5 IDHN1
     I                                        6  10 IDHN2
     I                                       11  12 IDHN3
     I            DS
     I                                        1  14 ODHNB
     I                                        1   5 ODHN1
     I                                        6   6 ODH1
     I                                        7  11 ODHN2
     I                                       12  12 ODH2
     I                                       13  14 ODHN3
     I            DS
     I                                        1  14 WDHNB
     I                                        1   5 WDHN1
     I                                        6   6 WDH1
     I                                        7  11 WDHN2
     I                                       12  12 WDH2
     I                                       13  14 WDHN3
     I            DS
     I                                        1   5 OKIBN
     I                                        1   3 OKIB1
     I                                        4   4 OKI1
     I                                        5   5 OKIB2
      *
     C           KEY1      KLIST
     C                     KFLD           WKOJO
     C                     KFLD           IKOTI
     C                     KFLD           IDHN1
     C                     KFLD           IDHN2
     C                     KFLD           IDHN3
      *
     C           KEY2      KLIST
     C                     KFLD           WKOJO
     C                     KFLD           IKOTI
      *
     C           KEY3      KLIST
     C                     KFLD           IDHN1
     C                     KFLD           IDHN2
     C                     KFLD           IDHN3
      *
      *------------*
      * 画面－１ *
      *------------*
     C           STP1      TAG
     C                     EXFMTMYAPW121
     C                     SETOF                     515253
     C                     SETOF                     99
      *
      *======
      *  F1
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
      *--------*
      * 工場 *
      *--------*
     C           IKOJO     IFEQ *BLANK
     C                     SETON                     5199
     C                     MOVELER,1      MSG
     C                     GOTO STP1
     C                     END
      *
      *============
      * 数字検索
     C                     MOVEAIKOJO     HSJ
      *
     C                     Z-ADD1         A       20
     C           1         DO   4         A
     C                     SETOF                     01
     C           HSJ,A     LOKUPTSU                      01
     C           *IN01     IFEQ '0'
     C                     SETON                     5199
     C                     MOVELER,2      MSG
     C                     GOTO STP1
     C                     END
     C                     END
      *
      *====================
      * 細目マスター検索
     C                     MOVELIKOJO     WKOJO   40
      *
     C                     SETOF                     01
     C                     MOVE *BLANK    WKJNM
     C           WKOJO     CHAINFGBPL011             01
     C           *IN01     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     01
     C                     END
     C           *IN01     IFEQ '0'
     C                     MOVELB2SMEI    WKJNM
     C                     ELSE
     C                     SETON                     5199
     C                     MOVELER,3      MSG
     C                     GOTO STP1
     C                     END
      *
      *--------*
      * 工程 *
      *--------*
     C           IKOTI     IFEQ *BLANK
     C                     SETON                     5299
     C                     MOVELER,4      MSG
     C                     GOTO STP1
     C                     END
      *
      *========================
      * 工程名称マスター検索
     C                     SETOF                     01
     C           IKOTI     CHAINFCETL031             01
     C           *IN01     IFEQ '0'
     C           A6GSKD    ANDEQ'D'
     C           A6GSHZ    ANDLE*DATE
     C                     SETON                     01
     C                     END
     C           *IN01     IFEQ '1'
     C                     SETON                     5299
     C                     MOVELER,5      MSG
     C                     GOTO STP1
     C                     END
      *
      *------------------------*
      * 代表品番             *
      * 部品情報マスター検索 *
      *------------------------*
     C                     MOVE *BLANK    WDHNB
      *
     C           IDHNB     IFNE *BLANK
      *
     C                     SETOF                     01
     C           KEY3      CHAINFCEPL011             01
     C           *IN01     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     01
     C                     END
     C           *IN01     IFEQ '1'
     C                     SETON                     5399
     C                     MOVELER,6      MSG
     C                     GOTO STP1
     C                     END
      *
     C                     MOVELIDHN1     WDHN1
     C                     MOVELIDHN2     WDHN2
     C                     MOVELIDHN3     WDHN3
     C                     MOVEL'-'       WDH1
     C                     MOVEL'-'       WDH2
     C                     END
      *
      *------------------------*
      * サブファイルセット   *
      * 複数機番比率マスター *
      * 画面－２             *
      *------------------------*
     C                     SETOF                     1112
     C                     Z-ADD0         RRN     40
     C                     Z-ADD0         @RRN
     C                     Z-ADD1         @SFLRN
      *
     C           IDHNB     IFNE *BLANK
     C           KEY1      SETLLMYAPL111
     C                     ELSE
     C           KEY2      SETLLMYAPL111
     C                     END
      *
     C                     DO   *HIVAL
     C                     SETOF                     10
      *
     C           IDHNB     IFNE *BLANK
     C           KEY1      READEMYAPL111                 10
     C                     ELSE
     C           KEY2      READEMYAPL111                 10
     C                     END
     C           *IN10     IFEQ '0'
      *
     C           W1SKJY    IFEQ 'D'
     C           W1SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELW1DHN1    $DHN1   5
     C                     MOVELW1DHN2    $DHN2   5
     C                     MOVELW1DHN3    $DHN3   2
     C                     MOVELW1KIBN    $KIBN   3
     C                     MOVELW1KIBH    $KIBH   1
     C                     Z-ADDW1PAST    $PAST   30
     C                     EXSR SUBMS
     C                     END
      *
     C                     ELSE
     C                     SETON                     12
     C                     END
     C  N12                END
      *
      *--------------------*
      * データが０件処理 *
      *--------------------*
     C           RRN       IFEQ 0
     C                     MOVE *BLANK    $DHN1
     C                     MOVE *BLANK    $DHN2
     C                     MOVE *BLANK    $DHN3
     C                     MOVE *BLANK    $KIBN
     C                     MOVE *BLANK    $KIBH
     C                     Z-ADD0         $PAST
     C                     EXSR SUBMS
      *
     C                     SETON                     99
     C                     MOVELER,7      MSG
     C                     END
      *
      *----------------------------*
      * コマンド表示パネル       *
      * サブファイル制御レコード *
      * 画面－２                 *
      *----------------------------*
     C           STP2      TAG
     C                     WRITEMYAPW122
      *
      *====================
      *  SFLDSP,SFLDSPCTL
     C                     SETON                     93
     C                     EXFMTSFLCTL
     C                     SETOF                     93
      *
      *======
      *  F3
     C           *INKC     IFEQ '1'
     C                     SETOF                     99
     C                     EXSR SUBR
     C                     GOTO STP1
     C                     END
      *
      *====================
      *  @CRRCD:SFLCSRRRN
      *  @SFLRN:SFLRCDNBR
     C           @CRRCD    IFEQ 0
     C                     Z-ADD1         @CRRCD
     C                     END
     C                     Z-ADD@CRRCD    @SFLRN
     C                     GOTO STP2
      *
      *
      *@@@@@@@@@@@@@@@@@@@@*
      * サブルーチン     *
      * 画面－１クリアー *
      *@@@@@@@@@@@@@@@@@@@@*
     C           SUBR      BEGSR
      *
     C                     MOVE *BLANK    IKOJO
     C                     MOVE *BLANK    IKOTI
     C                     MOVE *BLANK    IDHNB
      *
     C                     ENDSR
      *
      *
      *@@@@@@@@@@@@@@@@@@@@@@@@*
      * サブルーチン         *
      * サブファイルセット   *
      * 複数機番比率マスター *
      *@@@@@@@@@@@@@@@@@@@@@@@@*
     C           SUBMS     BEGSR
      *
     C           *IN11     IFEQ '0'
     C                     SETON                     11
      *
      *============================
      * サブファイル制御レコード
      *  SFLCLR
     C                     SETON                     94
     C                     WRITESFLCTL
     C                     SETOF                     94
     C                     END
      *
     C                     CLEARSFL
      *
     C                     MOVE $DHN1     ODHN1
     C                     MOVE $DHN2     ODHN2
     C                     MOVE $DHN3     ODHN3
     C                     MOVEL'-'       ODH1
     C                     MOVEL'-'       ODH2
      *
     C                     MOVEL$KIBN     OKIB1
     C                     MOVEL$KIBH     OKIB2
     C           $KIBH     IFNE *BLANK
     C                     MOVEL'-'       OKI1
     C                     END
      *
     C                     Z-ADD$PAST     OPAST
      *
     C                     ADD  1         RRN
     C                     Z-ADDRRN       @RRN
     C                     WRITESFL                      12
      *
     C                     ENDSR
      *
** TSU
0123456789
** ER
E-01 A FACTORY CORD IS NOT INPUT
E-02 PLEASE INPUT THE FACTORY CORD WITH A NUMBER
E-03 A RATHER THIN MASTER DOES NOT HAVE A FACTORY CORD
E-04 A PROCESS CORD IS NOT INPUT
E-05 A PROCESS NAME MASTER DOES NOT HAVE A PROCESS CORD
E-06 A PART MASTER DOES NOT HAVE A REPRESENTATIVE ARTICLE NUMBER
E-07 THERE ARE NOT DATA TO INQUIRE ABOUT
