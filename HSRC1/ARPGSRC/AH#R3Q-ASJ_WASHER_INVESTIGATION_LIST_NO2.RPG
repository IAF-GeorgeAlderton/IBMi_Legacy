     C           *IN94     IFEQ *OFF
     C           IESKJY    ANDEQ' '
     C           IENYUK    ANDNE*BLANK
     C           IEHANY    ANDEQ'S'
     C                     ADD  IESBOX    W@RCVQ
     C                     ENDIF
     C                     ENDDO
      * SPECIAL ORDER(AIR, ETC.)
     C           KEY2X     SETLLGDGPL41
     C           *IN94     DOUEQ*ON
     C           KEY2      READEGDGPL41                  94
     C           *IN94     IFEQ *OFF
     C                     ADD  G4NOHK    W@RCVQ
     C                     ENDIF
     C                     ENDDO
      *
      * INVENTORY AS OF 1ST OF THE MONTH
     C           K#AZA     CHAINAZAPL51              94
     C           *IN94     IFEQ *OFF
     C                     Z-ADDZ5BOXQ    W@INVQ  72
     C                     ELSE
     C                     Z-ADD*ZERO     W@INVQ
     C                     ENDIF
      * SHIPPED
     C                     Z-ADD*ZERO     @@QTY  112
     C           KEY2      SETLLMCENP131
     C           *IN94     DOUEQ*ON
     C           KEY2      READEMCENP131                 94
     C           *IN94     IFEQ *OFF
     C                     EXSR #BOX1
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           W@QTBX    IFNE *ZERO
     C           @@QTY     DIV  W@QTBX    W@ABQY  72H
     C                     ENDIF
      *
     C           W@INVQ    ADD  W@RCVQ    W@BAL   62
     C                     SUB  W@ABQY    W@BAL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SHIPPED BOXES
      *------------------------------------------------------
     C           #BOX1     BEGSR
      *
     C                     Z-ADD*ZERO     WKNEC   10
     C           K#MCN     SETLLFCEPL01
     C           *IN95     DOUEQ*ON
     C           K#MCN     READEFCEPL01                  95
     C           *IN95     IFEQ *OFF
     C           A2GSKD    ANDEQ*BLANK
     C                     Z-ADD1         B       10
     C           DSPNO     LOKUPCOM,B                    79
     C           *IN79     IFEQ '1'
     C                     Z-ADDNEC,B     WKNEC
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C* ACTUAL
     C           K#APP     SETLLAB#PL18
     C           *IN95     DOUEQ*ON
     C           K#APP     READEAB#PL18                  95
     C           *IN95     IFEQ *OFF
     C           BASKJY    ANDEQ' '
     C           BANODD    IFGT *DAY
     C                     LEAVE
     C                     ENDIF
      *
     C           BASRYO    MULT WKNEC     WKSAIZ  92
     C                     ADD  WKSAIZ    @@QTY
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------*
     C           #HEDA     BEGSR
      *
     C                     MOVEA*BLANK    HN
     C                     MOVE *BLANK    LL
     C                     Z-ADD0         @Z      30
     C           KEY2      SETLLMCENP13
     C                     DO   *HIVAL
     C           KEY2      READEMCENP13                  90
     C           *IN90     IFEQ *OFF
     C                     MOVE *BLANK    WSHIN
     C                     MOVELMCSHN1    WSHN1
     C                     MOVELMCSHN2    WSHN2
     C                     MOVELMCSHN3    WSHN3
     C                     MOVE '-'       WBAR1
     C                     MOVE '-'       WBAR2
     C           WSHN3     IFEQ *BLANK
     C                     MOVE *BLANK    WBAR2
     C                     END
     C                     ADD  1         @Z
     C                     MOVE WSHIN     HN,@Z
      *
     C           K#MCN     CHAINAAMPL11              10
     C           *IN10     IFEQ *OFF
     C                     Z-ADD1         Z
     C           'RL '     LOKUPKO,Z                     10
     C           *IN10     IFEQ *ON
     C                     Z-ADD*ZERO     C       20
     C                     MOVE *BLANK    CC
     C           Z         DO   15        L       20
     C           LC,L      IFNE '------'
     C           LC,L      ANDNE*BLANK
     C                     MOVE LC,L      WLOC
     C                     MOVE WLOC2     WL2
     C                     MOVE WLOC3     WL3
     C                     ADD  1         C
     C           C         IFEQ 6
     C                     MOVE '*'       CC,5
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVELWLL       CC,C
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEACC        LL,@Z
     C                     ENDIF
     C                     ENDIF
      *
     C           @Z        IFGE 5
     C                     WRITEHEDA
     C                     Z-ADD0         @Z
     C                     MOVEA*BLANK    HN
     C                     MOVEA*BLANK    LL
     C                     END
     C                     END
     C  N90                ENDDO
      *
     C           @Z        IFGE 1
     C           @Z        ANDLT5
     C                     WRITEHEDA
     C                     END
     C           EHEDA     ENDSR
      *-----------------------------------------------------*
