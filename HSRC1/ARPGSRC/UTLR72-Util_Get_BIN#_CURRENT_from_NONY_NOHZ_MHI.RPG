     H            Y.
     F** UTLR72 ****************************************************
     F*  UTILITY- GET BIN# "CURRENT" FROM NONY.SHPDATE.ODRN        *
     F*  WRITTEN: JW (SRA)                                         *
     F*           03/20/2019                                       *
     F*------------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR72'
     F*                    PARM           $NONY   4
     F*                    PARM           $NUKE   4
     F*                    PARM           $NOHZ   8
     F*                    PARM           $MHIN  20
     F*                    PARM           $ODRN  10
     F*                    PARM           $BIN    2
     F*                    PARM           $ASN   16
     F*                    PARM           $RTN    1
     F*   IN  $NONY   4   DELIVERY#
     F*       $NUKE   4   DOCK
     F*       $NOHZ   8   SHIP DATE
     F*       $MHIN  20   USER PART
     F*       $ODRN  10   ORDER#
     F*   OUT $BIN    2   BIN#
     F*       $ASN   16   ASN#
     F*       $RTN    1   RETURN
     F******************************************************
     FAB#PL1L IF  E           K        DISK
      *--------------------------------------------------------
     E                    DAT        10  1
      *--------------------------------------------------------
     I            DS
     I                                        1   80KANOHZ
     I                                        1   40KANOYY
     I                                        5   60KANOMM
     I                                        7   80KANODD
     I            DS
     I                                        1  20 KAMHIN
     I                                        1   5 KAMHN1
     I                                        6  10 KAMHN2
     I                                       11  15 KAMHN3
     I                                       16  20 KAMHN4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
     C                     EXSR #INZ
      *
     C           K#PP10    SETLLAB#PL1L
     C                     DO   *HIVAL
     C           K#PP10    READEAB#PL1L                  98
     C   98                LEAVE
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELBANOBN    $BIN
     C                     MOVELBAINVN    $ASN
     C                     LEAVE
      *
     C                     ENDDO
      *
     C           $BIN      IFEQ '00'
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
     C           #INZ      BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4
     C                     PARM           $NUKE   4
     C                     PARM           $NOHZ   8
     C                     PARM           $MHIN  20
     C                     PARM           $ODRN  10
     C                     PARM           $BIN    2
     C                     PARM           $ASN   16
     C                     PARM           $RTN    1
      *
     C           K#PP10    KLIST
     C                     KFLD           KANONY  40
     C                     KFLD           KANOYY
     C                     KFLD           KANOMM
     C                     KFLD           KANODD
     C                     KFLD           KANUKE  4
     C                     KFLD           KAODRN 10
     C                     KFLD           KAMHN1
     C                     KFLD           KAMHN2
     C                     KFLD           KAMHN3
     C                     KFLD           KAMHN4
      *
     C                     MOVEL$NONY     KANONY
     C                     MOVEL$NOHZ     KANOHZ
     C                     MOVEL$NUKE     KANUKE
     C                     MOVEL$ODRN     KAODRN
     C                     MOVEL$MHIN     KAMHIN
      *
     C                     MOVEL'00'      $BIN
     C                     MOVE *BLANK    $ASN
     C                     MOVE *BLANK    $RTN
      *
     C                     ENDSR
