      *** GDGR04 *****************************************************
      *    ASJ PARTS ORDER SUMMARIZATION件数確認
      * KIRI  14/11/26
      ****************************************************************
     H            Y/                                    1
     FGDGPL06 IF  E           K        DISK
      *-----------------------------------------------------------
      *-----------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     C****************************************************************
     C*       MAIN ROUTINE
     C****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           P@FACT  3        工場
     C                     PARM           P@KENS  50       データ件数
      *
     C                     Z-ADD*ZERO     @@8     80
     C                     Z-ADD0         P@KENS
     C           @@8       SETLLGDGPL06
      *-------------------------
     C                     DO   *HIVAL
     C           @@8       READEGDGPL06                  90
     C   90                LEAVE
     C***
     C***                        GET DEPARTMENT CODE ( PART NO )
     C                     CALL 'GDGR1Y'
     C                     PARM IAHIN1    P$HIN1  5        PART NO1
     C                     PARM IAHIN2    P$HIN2  5        PART NO2
     C                     PARM IAHIN3    P$HIN3  2        PART NO3
     C                     PARM           P$BMON  4
     C                     MOVE '  '      @@FACT  2        工場CHECK
     C** = ATC
 S2  C           P@FACT    IFEQ 'ATC'                      工場
  S3 C           P$BMON    IFEQ '0002'                     部門
   3 C           P$BMON    OREQ '0094'                     部門
     C                     MOVE 'OK'      @@FACT           工場CHECK
  E3 C                     ENDIF
 E2  C                     ENDIF
     C** = ASJ
 S2  C           P@FACT    IFEQ 'ASJ'                      工場
  S3 C           P$BMON    IFEQ '8990'                     部門
     C                     MOVE 'OK'      @@FACT           工場CHECK
  E3 C                     ENDIF
 E2  C                     ENDIF
     C**
     C           @@FACT    IFEQ 'OK'                       工場CHECK
     C                     ADD  1         P@KENS
     C                     ENDIF
     C***
     C                     ENDDO
      *-------------------------
      *
     C                     SETON                     LR
     C                     RETRN
      *-------------------------------------------------------
