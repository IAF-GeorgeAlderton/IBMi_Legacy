     F* TCHK1 03/03/09 RE-MAKE
     F* TCHK2 02/11/13 ADD AEP
     F* TCHK3 09/10/14 HONDA RE-MAKE
     F********************************** AB#R6B **
     FAB#PL6A IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      **********************************************************
     I            DS
     I                                        1  120#TIME
     I                                        1   60WTIME
     I            DS
     I                                        1   60K@YYMM
     I                                        1   40K@YY
     I                                        5   60K@MM
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     C****************************************************
      *
     C           P@CUST    IFNE 'HAM  '
     C                     MOVELP@CUST    K@CUST
     C                     EXSR #OUT
     C                     ELSE
     C                     MOVEL'200  '   K@CUST
     C                     EXSR #OUT
     C                     MOVEL'MAP  '   K@CUST
     C                     EXSR #OUT
     C                     MOVEL'210  '   K@CUST
     C                     EXSR #OUT
     C                     MOVEL'ELP  '   K@CUST
     C                     EXSR #OUT
     C                     MOVEL'260  '   K@CUST
     C                     EXSR #OUT
     C                     MOVEL'IPS  '   K@CUST
     C                     EXSR #OUT
     C                     MOVEL'HAM  '   K@CUST
     C                     EXSR #OUT
TCHK2C                     MOVEL'AEP  '   K@CUST
TCHK2C                     EXSR #OUT
TCHK3C                     MOVEL'HTM  '   K@CUST
TCHK3C                     EXSR #OUT
TCHK3C                     MOVEL'HMA  '   K@CUST
TCHK3C                     EXSR #OUT
TCHK3C                     MOVEL'HCM  '   K@CUST
TCHK3C                     EXSR #OUT
TCHK3C                     MOVEL'HMI  '   K@CUST
TCHK3C                     EXSR #OUT
TCHK3C                     MOVEL'HSP  '   K@CUST
TCHK3C                     EXSR #OUT
TCHK3C                     MOVEL'AHM  '   K@CUST
TCHK3C                     EXSR #OUT
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *--------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@CUST  5
     C                     PARM           P@YMD   80
TCHK3C                     PARM           P@TIME  60
      *
     C           K#KEY     KLIST
     C                     KFLD           K@CUST  5
     C                     KFLD           K@DATE  80
     C*                    KFLD           K@YY    40
     C*                    KFLD           K@MM    20
      *
     C****                 Z-ADDP@YYMM    K@YYMM
     C                     Z-ADDP@YMD     K@DATE
     C*******    K@DATE    ADD  99        W@END   80
      *
     C                     TIME           #TIME
      *
     C                     ENDSR
      *--------------------------------------------------
     C           #OUT      BEGSR
      *--------------------------------------------------
     C                     MOVEA'00'      *IN,97
     C                     MOVE *BLANK    @@MANI 16
     C                     Z-ADD*ZERO     TSAMT  122
     C                     Z-ADD*ZERO     TMAMT  122
     C                     Z-ADD*ZERO     WCNT    60
     C           K#KEY     SETLLAB#PL6A
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAB#PL6A                  90
     C           *IN90     IFEQ *OFF
     C*          APPRDT    IFGT W@END
     C*                    LEAVE
     C*                    ENDIF
TCHK3C*
TCHK3C           APPRTM    IFNE P@TIME
TCHK3C                     ITER
TCHK3C                     END
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
      *
     C           APMANI    IFNE @@MANI
     C           *IN97     ANDEQ*ON
     C                     EXCPT@STOT
     C                     ENDIF
     C  N97                MOVE *ON       *IN97
     C           APUNIT    IFNE *ZERO
     C           APIQTY    MULT APUNIT    @@AMNT 122
     C                     ELSE
     C                     Z-ADDAPTAMT    @@AMNT
     C                     ENDIF
     C                     EXCPT@DTL
      *
     C                     ADD  @@AMNT    TSAMT  122
     C                     ADD  @@AMNT    TMAMT  122
     C                     ADD  1         WCNT    60
     C                     MOVE APMANI    @@MANI
     C                     ENDIF
     C                     ENDDO
      *
     C   97                EXCPT@STOT
     C   97                EXCPT@GTOT
      *
     C                     ENDSR
     C**************************************************************************
     OQPRINT  E  102           @HED
     O                                  131 '.....................'
     O*
     O        E  1             @HED
     O                                  131 '.         .         .'
     O*
     O        E  1             @HED
     O                                   89 'TIME'
     O                         WTIME     98 '  :  :  '
     O                                  131 '.         .         .'
     O*
     O        E  1             @HED
     O                         #PGM      12
JW   O                         #USER     22
     O                         APCNAM    30
     O                                   55 'ACCOUNT PAYABLE'
     O                                   67 'DETAIL LIST'
     O                                   89 'DATE'
     O                         UDATE Y   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O                                  131 '.....................'
