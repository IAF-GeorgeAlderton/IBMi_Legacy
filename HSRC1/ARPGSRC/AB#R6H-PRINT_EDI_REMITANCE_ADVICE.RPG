     O                                  119 'DOCK'
     O*
     O        E                @HED
     O                                    9 'NO.'
     O                                   31 'CODE'
     O                                   40 'NUMBER'
     O                                  106 'DATE'
     O                                  119 'CODE'
     O*
     O        E 11             @STOT
     O                                   47 '***'
     O                                   60 'TOTAL AMOUNT'
     O                                   71 'MANIFEST'
     O                         TMAMT JB  94
     O                                  121 'SUB('
     O                         WCNT  JB 128
     O                                  129 ')'
     O*
     O        E 1              @GTOT
     O                                   47 '***'
     O                                   60 'TOTAL AMOUNT'
     O                                   71 'DELIVERY'
     O                         TSAMT JB  94
     O                                  111 '('
     O                         APMAMTJB 128
     O                                  129 ')'
     O*
     O        E 1              @DTL
     O                         APCARD     9
     O                         APPAR1    19
     O                                   20 '-'
     O                         APPAR2    25
     O                         APCLRC    30
     O                         APMANI    50
     O                         APIQTY1   63
     O                         APUNIT1   75
