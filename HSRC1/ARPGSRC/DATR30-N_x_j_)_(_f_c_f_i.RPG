     H            Y.
     F** DATR30 ********************************************
     F*    パラメータの日付が稼働日かどうか判断          *
     F*      Y.MAEDA                       2009.07.29      *
     F******************************************** DATR20 **
     FAGDPL12 IF  E           K        DISK
     I            DS
     I                                        1  140WTIME
     I                                        1   80WDATE
     I                                        7  100WYY
     I                                       11  120WMM
     I                                       13  140WDD
     C           KEY1      KLIST
     C                     KFLD           KYY     40
     C                     KFLD           KMM     20
     C                     KFLD           KDD     20
      *PSTS = 0  稼働日
      *PSTS = 1  非稼働日
     C           *ENTRY    PLIST
     C                     PARM           PSTS    1
     C                     TIME           WTIME
     C                     Z-ADDWYY       KYY
     C                     Z-ADDWMM       KMM
     C                     Z-ADDWDD       KDD
     C                     MOVEL'0'       PSTS
     C                     SETOF                     77
     C           KEY1      CHAINAGDPL121             77
     C           *IN77     IFEQ '1'
     C                     MOVEL'1'       PSTS
     C                     END
     C           *IN77     IFEQ '0'
     C           F8HIRU    IFEQ '*'
     C           F8YORU    OREQ '*'
     C                     MOVEL'1'       PSTS
     C                     END
     C                     END
     C                     SETON                     LR
     C                     RETRN
