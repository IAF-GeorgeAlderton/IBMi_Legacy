     H            Y.
     F** ASKR99 **************************************
     F* 10/18臨時
     F*       SAKAKI.       2019.10.18               *
     F************************************************
     FFCEPL01 IF  E           K        DISK
     FAAHPL03 IF  E           K        DISK
     FAAFPL03 IF  E           K        DISK
     FASKWP99 O   E                    DISK                      A
     E                    OBM        15  4               部門
     E                    OKB        15  3               機番
     E                    OTK        15  6               所番地
     E                    OKO        15  3               工程
     E                    SHR        15  1               種類
      *
     I            DS
     I                                        1  12 A2BHB
     I                                        1   5 A2BHB1
     I                                        6  10 A2BHB2
     I                                       11  12 A2BHB3
      *
     I            DS
     I                                        1   6 WTKR
     I                                        1   1 WTKR1
     I                                        2   3 WTKR2
     I                                        4   5 WTKR3
     I                                        6   6 WTKR4
      *
     I            DS
     I                                        1  20 $SRTN
     I                                        1   4 WXX4
     I                                        4   4 WX44
      *
     I            DS
     I                                        1  20 $SRT#
     I                                        2   3 WXX2
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
      *
     C                     MOVEL'1'       OPNCLS
      *
     C                     READ FCEPL011                 80
     C           *IN80     DOWEQ'0'
     C           A2GSKD    IFEQ ' '
     C                     EXSR #SB400
     C                     ENDIF
     C                     READ FCEPL011                 80
     C                     ENDDO
      *
     C           OPNCLS    IFEQ '0'
     C                     MOVE '9'       OPNCLS
     C                     CALL 'AAMRSB'
      *入力パラメータ
     C                     PARM           A2BHB1  5
     C                     PARM           A2BHB2  5
     C                     PARM           A2BHB3  2
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * DATA                                               *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     CALL 'UTLR14A'
     C                     PARM           A2BHB1  5
     C                     PARM           A2BHB2  5
     C                     PARM           A2BHB3  2
     C                     PARM           PMLOCA  6
     C                     PARM           PMKIND  1
     C                     PARM           PMPRCN  3
     C                     PARM           PMPRCR  3
     C                     PARM           PMMCNN  3
     C                     PARM           PMMCNR  3
     C                     PARM           PMDPTN  40
     C                     PARM           PMDPTR  40
     C                     PARM           PMRTN   1
      *
      *
     C                     MOVEA*BLANK    OBM
     C                     MOVEA*BLANK    OKB
     C                     MOVEA*BLANK    OTK
     C                     MOVEA*BLANK    OKO
     C                     MOVEA*BLANK    SHR
     C                     CALL 'AAMRSB'
      *入力パラメータ
     C                     PARM           A2BHB1  5
     C                     PARM           A2BHB2  5
     C                     PARM           A2BHB3  2
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     MOVEL'0'       OPNCLS
     C                     MOVEAPBMN      OBM
     C                     MOVEAPKBN      OKB
     C                     MOVEAPTKR      OTK
     C                     MOVEAPKOT      OKO
     C                     MOVEAPKOT      SHR
      *
      *
      *
     C                     Z-ADD1         X       20
     C           'TSL'     LOKUPOKO,X                    29
      *
     C                     CALL 'UTLR57'
     C                     PARM           A2BHB  12
     C                     PARM           $SRTN  20
     C                     PARM           $SRT#  20
     C                     PARM           $RTN    1
      * (1)
     C           *IN29     IFEQ '1'
     C           $RTN      IFEQ '*'
     C                     CLEARASKWP991
     C                     MOVEL'1'       WKBN
     C                     MOVELA2BHB     WSHN
     C                     MOVELOTK,X     WTKR
     C                     MOVELOKB,X     WMSN
     C                     MOVELSHR,X     WKIND
     C                     MOVEL$SRTN     WSRTN
     C                     MOVEL$SRT#     WSRT#
     C                     WRITEASKWP991
     C                     ENDIF
     C                     ENDIF
      * (2)
     C           *IN29     IFEQ '0'
     C           $RTN      IFEQ ' '
     C                     CLEARASKWP991
     C                     MOVEL'2'       WKBN
     C                     MOVELSHR,X     WKIND
     C                     MOVELA2BHB     WSHN
     C                     MOVELPMLOCA    WTKR
     C                     MOVELPMMCNN    WMSN
     C                     MOVELPMKIND    WKIND
     C                     MOVEL$SRTN     WSRTN
     C                     MOVEL$SRT#     WSRT#
     C                     WRITEASKWP991
     C                     ENDIF
     C                     ENDIF
      * (3)
     C                     MOVEL'NG'      WOKNG   2
1    C           *IN29     IFEQ '1'
     C                     MOVELOKB,X     MSNO    3
 2   C           $RTN      IFEQ ' '
     C                     CLEARASKWP991
     C                     MOVEL'3'       WKBN
     C                     MOVELA2BHB     WSHN
     C                     MOVELOTK,X     WTKR
     C                     MOVELOKB,X     WMSN
     C                     MOVEL$SRTN     WSRTN
     C                     MOVEL$SRT#     WSRT#
     C*
     C                     MOVE WMSN      WXX1    2
     C                     MOVE WMSN      WX33    1
     C           WXX4      IFEQ 'SRT '
     C           WXX1      IFEQ WXX2
     C                     MOVEL'OK'      WOKNG
     C                     ENDIF
     C                     ELSE
     C           WX33      IFEQ WX44
     C                     MOVEL'OK'      WOKNG
     C                     ENDIF
     C                     ENDIF
     C           WMSN      IFEQ 'S00'
     C           WXX4      ANDEQ'SORT'
     C                     MOVEL'OK'      WOKNG
     C                     ENDIF
     C*
     C           WOKNG     IFEQ 'NG'
     C                     WRITEASKWP991
     C                     ENDIF
     C*
     C                     ENDIF
     C                     ENDIF
      * (4) (5)
     C**
     C                     MOVELPMLOCA    WTKR
     C           KEYAAH    KLIST
     C                     KFLD           WTKR1
     C                     KFLD           WTKR2
     C                     KFLD           WTKR3
     C                     KFLD           WTKR4
     C                     MOVEL'0'       VNL     1
     C**
     C           KEYAAH    SETLLAAHPL03
     C           KEYAAH    READEAAHPL03                  84
     C           *IN84     DOWEQ'0'
     C           L6SKJY    IFEQ ' '
     C           L6UKHZ    ANDLE*DATE
     C           L6STHZ    ANDGT*DATE
     C           L6JOK1    IFEQ 'VN'
     C           L6JOK2    OREQ 'VN'
     C           L6JOK3    OREQ 'VN'
     C           L6JOK4    OREQ 'VN'
     C           L6JOK5    OREQ 'VN'
     C           L6JOK6    OREQ 'VN'
     C           L6JOK7    OREQ 'VN'
     C           L6JOK1    OREQ 'V1'
     C           L6JOK2    OREQ 'V1'
     C           L6JOK3    OREQ 'V1'
     C           L6JOK4    OREQ 'V1'
     C           L6JOK5    OREQ 'V1'
     C           L6JOK6    OREQ 'V1'
     C           L6JOK7    OREQ 'V1'
     C                     MOVEL'1'       VNL
     C                     ENDIF
     C                     ENDIF
     C           KEYAAH    READEAAHPL03                  84
     C                     ENDDO
     C**
     C           VNL       IFNE '1'
     C           KEYAAH    SETLLAAFPL03
     C           KEYAAH    READEAAFPL03                  84
     C           *IN84     DOWEQ'0'
     C           A3SKJY    IFEQ ' '
     C           A3UKHZ    ANDLE*DATE
     C           A3STHZ    ANDGT*DATE
     C           A3JOK1    IFEQ 'VN'
     C           A3JOK2    OREQ 'VN'
     C           A3JOK3    OREQ 'VN'
     C           A3JOK4    OREQ 'VN'
     C           A3JOK5    OREQ 'VN'
     C           A3JOK6    OREQ 'VN'
     C           A3JOK1    OREQ 'V1'
     C           A3JOK2    OREQ 'V1'
     C           A3JOK3    OREQ 'V1'
     C           A3JOK4    OREQ 'V1'
     C           A3JOK5    OREQ 'V1'
     C           A3JOK6    OREQ 'V1'
     C                     MOVEL'1'       VNL
     C                     ENDIF
     C                     ENDIF
     C           KEYAAH    READEAAFPL03                  84
     C                     ENDDO
     C                     ENDIF
     C*
     C                     Z-ADD1         X       20
     C           'VNL'     LOKUPOKO,X                    29
     C*
     C           *IN29     IFEQ '0'
     C           VNL       ANDEQ'1'
     C                     CLEARASKWP991
     C                     MOVEL'4'       WKBN
     C                     MOVELA2BHB     WSHN
     C                     MOVELPMLOCA    WTKR
     C                     MOVELPMMCNN    WMSN
     C                     MOVEL*BLANK    WSRTN
     C                     MOVEL*BLANK    WSRT#
     C                     MOVELPMKIND    WKIND
     C                     WRITEASKWP991
     C                     ENDIF
     C           *IN29     IFEQ '1'
     C           VNL       ANDEQ'0'
     C                     CLEARASKWP991
     C                     MOVEL'5'       WKBN
     C                     MOVELA2BHB     WSHN
     C                     MOVELOTK,X     WTKR
     C                     MOVELOKB,X     WMSN
     C                     MOVEL*BLANK    WSRTN
     C                     MOVEL*BLANK    WSRT#
     C                     MOVELPMKIND    WKIND
     C                     WRITEASKWP991
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
