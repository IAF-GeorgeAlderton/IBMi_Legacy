     C*================================================================
     C* DISPLAY 2 SET
     C*================================================================
     C           #SET2     BEGSR
     C*
     C                     MOVEA'000'     *IN,01
     C                     MOVEA'000000'  *IN,11
     C                     MOVEA'000000'  *IN,21
     C                     MOVEA'0'       *IN,99
