     C                     CALL 'CNVR10'
     C                     PARM           P@INDT  8
     C                     PARM           P@OTDT 11
     C                     MOVE P@OTDT    WXNDAT
     C*
     C*
     C*
     C                     MOVE *BLANK    HN               USR PARTSNO
     C                     Z-ADD0         SU               ORDER QTY
     C                     MOVE *BLANK    NS               ORDER TYPE
     C                     Z-ADD0         SB               SUB CODE
     C                     MOVE *BLANK    MO               MEMO
     C                     MOVE *BLANK    SH               PARTS NO
     C                     Z-ADD0         TN               TANKA
     C                     Z-ADD0         J       10
     C*
     C                     ENDSR
     C*================================================================
     C*
     C*================================================================
     C           #UP       BEGSR
     C*
     C           J         IFLT 6
     C                     ADD  1         J
     C                     MOVE *BLANK    HN,J             USR PARTSNO
     C                     Z-ADD0         SU,J             ORDER QTY
     C                     MOVE 'C1'      NS,J             SHIP TYPE
     C                     Z-ADD0         SB,J             SUB CODE
     C                     MOVE *BLANK    MO,J             MEMO
     C                     MOVE *BLANK    SH,J             PARTS NO
     C                     Z-ADD0         TN,J             TANKA
     C                     ADD  1         WKODED
     C                     Z-ADDWKODED    SB,J             SUB CODE
     C           J         ADD  10        J1      20
     C           J         ADD  20        J2      20
     C                     MOVEA'000000'  *IN,11           INPUT OFF
     C                     MOVE '1'       *IN,J1           INPUT
     C                     MOVE '1'       *IN,J2           DSP
     C                     ENDIF
     C*
     C                     ENDSR
     C*================================================================
     C* CMD-7 REMOVE
     C*================================================================
     C           #DOWN     BEGSR
     C*
     C                     MOVE *BLANK    HN,J             USR PARTSNO
     C                     Z-ADD0         SU,J             ORDER QTY
     C                     MOVE *BLANK    NS,J             ORDER TYPE
     C                     Z-ADD0         SB,J             SUB CODE
     C                     MOVE *BLANK    MO,J             MEMO
     C                     MOVE *BLANK    SH,J             PARTS NO
     C                     Z-ADD0         TN,J             TANKA
     C           J         IFGT 1
     C                     MOVE '0'       *IN,J2           DSP
     C                     SUB  1         J
     C                     SUB  1         WKODED
     C                     ENDIF
     C                     Z-ADDWKODED    SB,J             SUB CODE
     C           J         ADD  10        J1      20
     C           J         ADD  20        J2      20
     C                     MOVEA'000'     *IN,01           ERROR
     C                     MOVEA'0'       *IN,99           ERROR
     C                     MOVEA'000000'  *IN,11           INPUT OFF
     C                     MOVE '1'       *IN,J1           INPUT
     C                     MOVE '1'       *IN,J2           DSP
     C*
     C                     ENDSR
     C*================================================================
     C* fﾞx] 1 CHECK
     C*================================================================
     C           #CHKW1    BEGSR
     C                     MOVEA'00000000'*IN,01
     C                     MOVEA'0'       *IN,09
     C                     MOVEA'0'       *IN,99
     C                     MOVEL*BLANK    MSG
     C* CUSTOMER
     C           W1TOKU    IFEQ 0
