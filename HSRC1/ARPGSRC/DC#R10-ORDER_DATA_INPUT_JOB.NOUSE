     C* ORDER NO
B1   C           W1ODNO    IFEQ *BLANK
     C  N99                MOVELEMSG,7    MSG
     C                     SETON                     0799
     C                     GOTO @CHK1
X1   C                     ELSE
     C           W1ODNO    CHAINDO#PPNO1             90
 B2  C           *IN90     IFEQ *OFF
