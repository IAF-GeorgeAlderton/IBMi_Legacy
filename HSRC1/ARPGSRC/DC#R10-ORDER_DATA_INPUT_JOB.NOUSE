     C                     Z-ADDW1NDAT    F8KYMD
     C* AGDPL12
     C           KEYF8     CHAINAGDPL121             90
B1   C           *IN90     IFEQ *ON
     C                     SETON                     0199
X1   C                     ELSE
 B2  C           XX        DOUEQ0
     C                     READPAGDPL121                 90
  B3 C           *IN90     IFEQ *ON
     C                     SETON                     0199
  X3 C                     ELSE
  B4 C           F8HIRU    IFNE '*'
     C                     SUB  1         XX
  E4 C                     ENDIF
  E3 C                     ENDIF
 E2  C                     ENDDO
E1   C                     ENDIF
     C*
     C           *IN01     IFEQ *OFF
     C                     Z-ADDF8KYMD    W2TDAT
     C                     ELSE
     C                     Z-ADD0         W2TDAT
     C                     ENDIF
     C*
     C           W1HIKI    IFEQ 'A'
