     C                     EXSR #UP
     C                     GOTO @S20
     C                     ENDIF
     C*
     C                     Z-ADDWKODED    S5ODED
     C                     UPDATDO#PPNO1
     C                     GOTO @S01
     C*================================================================
     C* DISPLAY 1 SET
     C*================================================================
     C           #SET1     BEGSR
     C                     Z-ADD0         W1TOKU
