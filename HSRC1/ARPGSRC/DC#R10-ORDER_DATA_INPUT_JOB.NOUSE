     C                     Z-ADDSU,J1     B8SRYO           DELIVERY QTY
     C                     MOVE 'C'       B8TANI                    UNITS
     C                     MOVE '2'       B8NSYO           DELIVERY SECTION
     C                     Z-ADD0         B8NOYY           DELIVERY DATE YY
     C                     Z-ADD0         B8NOMM                         MM
     C                     Z-ADD0         B8NODD                         DD
     C*
     C                     Z-ADDW2TDAT    WKYMD
     C                     Z-ADDWKYY      B8TEYY           SHIP ORDER DATE YY
     C                     Z-ADDWKMM      B8TEMM                           MM
     C                     Z-ADDWKDD      B8TEDD                           DD
     C                     Z-ADDW1NDAT    WKYMD
