     C*
     C                     READ DC#WP101                 90 DUMMY-READ
     C*
     C           @S01      TAG
     C                     EXSR #SET1
     C*--------------------
     C           @S10      TAG
     C                     EXFMTDC#PW101
     C   KA                SETON                     LR
     C   KA                RETRN
     C* CHECK
     C                     EXSR #CHKW1
     C   99                GOTO @S10
     C                     EXSR #SET2
     C                     EXSR #UP
     C*--------------------
     C           @S20      TAG
     C                     EXFMTDC#PW102
     C                     MOVEA'00000000'*IN,01
     C                     MOVEA'0'       *IN,09
     C                     MOVEA'0'       *IN,99
     C   KA                SETON                     LR
     C   KA                RETRN
     C*
     C   KC                UPDATDO#PPNO1
     C   KC                GOTO @S01
     C* REMOVE
     C   KG                EXSR #DOWN
     C   KG                GOTO @S20
     C* CHECK
     C                     EXSR #CHKW2
     C   99                GOTO @S20
     C* NEXT
     C  NKE                EXSR #UP
     C  NKE                GOTO @S20
     C* INPUT OK (KE)
     C                     EXSR #UPDAT
     C*
     C           J         IFEQ 6
     C                     MOVE *BLANK    HN               USR PARTSNO
     C                     Z-ADD0         SU               ORDER QTY
     C                     MOVE *BLANK    NS               ORDER TYPE
     C                     Z-ADD0         SB               SUB CODE
     C                     MOVE *BLANK    MO               MEMO
     C                     MOVE *BLANK    SH               PARTS NO
     C                     Z-ADD0         TN               TANKA
