 X2  C                     ELSE
     C                     MOVE W1ODNO    S5ODNO
     C                     Z-ADD0         S5ODED
     C                     Z-ADDS5ODED    WKODED
     C                     WRITEDO#PPNO1
     C           W1ODNO    CHAINDO#PPNO1             90
 E2  C                     ENDIF
E1   C                     ENDIF
     C* DELIVERY DATE
B1   C           W1NDAT    IFEQ 0
     C  N99                MOVELEMSG,8    MSG
     C                     SETON                     0899
     C                     GOTO @CHK1
X1   C                     ELSE
     C*
     C                     Z-ADDW1NDAT    F8KYMD
     C           KEYF8     CHAINAGDPL121             90    CALENDAR
 B2  C           *IN90     IFEQ *ON
     C  N99                MOVELEMSG,9    MSG
     C                     SETON                     0899
     C                     GOTO @CHK1
 X2  C                     ELSE
  B3 C           W1NDAT    IFLT ODRDAT
     C  N99                MOVELEMSG,18   MSG
     C                     SETON                     0899
     C                     GOTO @CHK1
  E3 C                     ENDIF
 E2  C                     ENDIF
E1   C                     ENDIF
     C* DELIVERY METHOD
     C           W1HIKI    IFEQ *BLANK
     C  N99                MOVELEMSG,10   MSG
     C                     SETON                     0999
