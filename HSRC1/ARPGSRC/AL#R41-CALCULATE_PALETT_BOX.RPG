     H            Y.
     F** AL#R41 **************************************
     F*パレットの空箱計算                          *
     F*        ITS.         2015.06.22               *
     F************************************************
     FAL#WP71 IF  E           K        DISK
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1IAFB  3
     C                     PARM           P1IAFP  3
     C                     PARM           P9EMPT  30
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
     C                     Z-ADD0         P9EMPT
     C                     EXSR #SB400
     C                     EXSR #SB410
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *箱数カウント　Ｄ箱は２箱としてカウント
      *-----------------------------------------------------
     CSR         #SB400    BEGSR
      *
     C                     Z-ADD0         WKCNTC  40
     C                     Z-ADD0         WKCNTD  40
     C           *LOVAL    SETLLAL#WP711
     C                     READ AL#WP711                 90
     C           *IN90     DOWEQ'0'
     C           W1IAFB    IFEQ P1IAFB
     C           W1IAFP    ANDEQP1IAFP
     C           W1SYOT    IFEQ 'D'
     C                     ADD  2         WKCNTD
     C                     ELSE
     C                     ADD  1         WKCNTC
     C                     ENDIF
     C                     ENDIF
     C                     READ AL#WP711                 90
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *-----------------------------------------------------
      *
      *-----------------------------------------------------
     CSR         #SB410    BEGSR
      *
     C                     Z-ADD0         WKCNT   40
     C           WKCNTC    ADD  WKCNTD    WKCNT
     C           WKCNTD    IFEQ 0
     C                     EXSR #SB411
     C                     ELSE
     C                     EXSR #SB412
     C                     ENDIF
      *
     CSR         ESB410    ENDSR
      *-----------------------------------------------------
      *Ｄ箱がない場合
      *-----------------------------------------------------
     CSR         #SB411    BEGSR
      *
     C                     Z-ADD0         P9EMPT
     C                     Z-ADD0         SYO     30
     C                     Z-ADD0         AMR     30
     C           WKCNT     DIV  12        SYO
     C                     MVR            AMR
     C           AMR       IFNE 0
     C           12        SUB  AMR       P9EMPT
     C                     ENDIF
      *
     CSR         ESB411    ENDSR
      *-----------------------------------------------------
      *Ｄ箱がある場合
      *-----------------------------------------------------
     CSR         #SB412    BEGSR
      *
     C                     Z-ADD0         P9EMPT
     C                     Z-ADD0         SYO     30
     C                     Z-ADD0         AMR     30
     C           WKCNT     DIV  12        SYO
     C                     MVR            AMR
     C           AMR       IFNE 0
     C           12        SUB  AMR       P9EMPT
     C                     ENDIF
      *
     C                     Z-ADD0         TOTAL   40
     C           P9EMPT    ADD  WKCNT     TOTAL
     C           TOTAL     IFLT 24
     C                     ADD  12        P9EMPT
     C                     ENDIF
      *
     CSR         ESB412    ENDSR
