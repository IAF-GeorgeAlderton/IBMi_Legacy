     H            Y.
     F** UEXR21B*********************************************
     F*  PROGRAM: EXSUB - GET UNSCAN QTY                    *
     F*  WRITTEN: JW (SRA) 2020.08.25                       *
JW1  F*  JW                2021.04.29 CHECK @SCAN=0         *
     F*-----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UEXR21B'
     F*                    PARM           $NONY   4
     F*                    PARM           $NKOJ   1
     F*                    PARM           $NUKE   4
     F*                    PARM           $NOHZ   8
     F*                    PARM           $NOBN   2
     F*                    PARM           $SHIN  12
     F*                    PARM           $ODRN  10
     F*                    PARM           $UNS    5
     F*                    PARM           $RTN    1
     F*  IN  $NONY   4A  DELIV#
     F*      $NKOJ   1A  FACTORY
     F*      $NUKE   4A  DOCK
     F*      $NOHZ   8A  SHIP DATE
     F*      $NOBN   2A  BIN#
     F*      $SHIN  12A  IAF PART#
     F*      $ODRN  10A  ORDER#
     F*  OUT $UNS    5A  UNSCAN LABEL
     F*      $RTN    1A  RETURN CODE (OK:BLANK, *:ERROR)
     F******************************************************
     FAB#PL1R IF  E           K        DISK
     FAB#PL70 IF  E           K        DISK
      *===================================================
      * SYSTEM DATE
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      * KEY FIELDS
     I            DS
     I                                        1   80K#NOHZ
     I                                        1   40K#NOYY
     I                                        5   60K#NOMM
     I                                        7   80K#NODD
     I            DS
     I                                        1   80BANOHZ
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I            DS
     I                                        1  12 BASHIN
     I                                        1   5 BASHN1
     I                                        6  10 BASHN2
     I                                       11  12 BASHN3
     I            DS
     I                                        1  12 K#SHIN
     I                                        1   5 K#SHN1
     I                                        6  10 K#SHN2
     I                                       11  12 K#SHN3
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      * GET ORDER BOX
     C           K#PL1R    SETLLAB#PL1R
     C                     DO   *HIVAL
     C           K#PL1R    READEAB#PL1R                  98
     C   98                LEAVE
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * GET SYOS
     C                     EXSR #GETBX
     C           @SYOS     IFEQ 0
     C                     LEAVE
     C                     ENDIF
      * GET SCAN QTY
     C                     EXSR #GETSC
      *
     C           @BOX      SUB  @SCAN     @NUM    50
     C           @NUM      IFGT 0
     C                     Z-ADD@NUM      @UNS    50
     C                     ENDIF
     C                     LEAVE
      *
     C                     ENDDO
      *
     C                     MOVEL@UNS      $UNS
     C           @UNS      IFEQ 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * GET # OF BOX
      *======================================================
     C           #GETBX    BEGSR
     C                     Z-ADD0         @BOX    50
      * GET SYOS
     C                     Z-ADD0         @SYOS   50
     C           BASYOS    IFNE 0
     C                     Z-ADDBASYOS    @SYOS
     C                     ELSE
     C           BAUSYS    IFNE 0
     C                     Z-ADDBAUSYS    @SYOS
     C                     ELSE
     C                     Z-ADDBASRYO    @SYOS
     C                     ENDIF
     C                     ENDIF
      *
     C           @SYOS     IFNE 0
     C           BASRYO    DIV  @SYOS     @BOX
     C                     MVR            REV     63
     C           REV       IFNE 0
     C                     ADD  1         @BOX
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *======================================================
      * GET SCAN QTY
      *======================================================
     C           #GETSC    BEGSR
      *
     C                     Z-ADD0         @SCAN   50
     C                     MOVELBANONY    K@NONY
     C                     MOVELBAODRN    K@ODRN
     C                     MOVELBANOBN    K@NOBN
      *
     C           K#PL70    SETLLAB#PL70
      * SEARCH BY ORDER#
     C                     DO   *HIVAL
     C           K#PL70    READEAB#PL70                  97
     C   97                LEAVE
     C           EKSKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
     C           EKSRYO    IFNE 0
     C                     ADD  1         @SCAN
     C                     END
     C                     ENDDO
      * SEARCH BY INVOICE#
     C**JW1                MOVELBAINVN    LTR10  10
     C**         LTR10     IFNE K@ODRN
      *
JW1  C           @SCAN     IFEQ 0
      *
     C                     MOVELBAINVN    K@ODRN
     C           K#PL70    SETLLAB#PL70
     C*
     C                     DO   *HIVAL
     C           K#PL70    READEAB#PL70                  96
     C   96                LEAVE
     C           EKSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           EKSRYO    IFNE 0
     C                     ADD  1         @SCAN
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDSR
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $NOHZ   8
     C                     PARM           $NOBN   2
     C                     PARM           $SHIN  12
     C                     PARM           $ODRN  10
     C                     PARM           $UNS    5
     C                     PARM           $RTN    1
      *
     C           K#PL1R    KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#NKOJ  1
     C                     KFLD           K#NUKE  4
     C                     KFLD           K#NOHZ  80
     C                     KFLD           K#NOBN  20
     C                     KFLD           K#SHIN 12
     C                     KFLD           K#ODRN 10
     C*
     C           K#PL70    KLIST
     C                     KFLD           BATOKU
     C                     KFLD           K@NONY  4
     C                     KFLD           BANKOJ
     C                     KFLD           BANUKE
     C                     KFLD           BAMHN1
     C                     KFLD           BAMHN2
     C                     KFLD           BAMHN3
     C                     KFLD           BAMHN4
     C                     KFLD           K@ODRN 10
     C                     KFLD           BANOYY
     C                     KFLD           BANOMM
     C                     KFLD           BANODD
     C                     KFLD           K@NOBN  2
     C                     KFLD           BADEYY
     C                     KFLD           BADEMM
     C                     KFLD           BADEDD
      *
     C                     MOVEL$NONY     K#NONY
     C                     MOVEL$NKOJ     K#NKOJ
     C                     MOVEL$NUKE     K#NUKE
     C                     MOVEL$NOHZ     K#NOHZ
     C                     MOVEL$NOBN     K#NOBN
     C                     MOVEL$SHIN     K#SHIN
     C                     MOVEL$ODRN     K#ODRN
     C                     MOVEL'00000'   $UNS
     C                     Z-ADD0         @UNS    50
     C                     MOVE *BLANK    $RTN
      *
     C                     ENDSR
