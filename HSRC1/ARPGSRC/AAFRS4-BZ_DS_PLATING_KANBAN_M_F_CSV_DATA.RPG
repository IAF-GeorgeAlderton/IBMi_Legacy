     FAAFPL03 IP  E                    DISK
     FFCEPL01 IF  E           K        DISK
     FMFAPL25 IF  E           K        DISK
     FFCGPP31 IF  E           K        DISK
     FFCGPP41 IF  E           K        DISK
     FFCGPP05 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FAAFWPS4 O   F    2048            DISK
JW1  I            DS
"    I                                        1  140SDATE
"    I                                        1   60NOW
"    I                                        7  140TODAY
      *================================================================
      *  START  PROGRAM
      *===============================================================
     C           A3SKJY    IFEQ 'D'
     C                     GOTO @END
     C                     END
      *
     C           A3SBIN    IFNE 99
     C                     GOTO @END
     C                     END
      *
     C           A3SSYS    IFEQ 0
     C                     GOTO @END
     C                     END
      *
     C           A3KCD1    IFNE 'C'
     C           A3KCD2    ORNE 'A'
     C                     GOTO @END
     C                     END
      *
     C           A3KTSU    DIV  20        W@KTSU  90
     C           A3KTSU    DIV  A3SSYS    O@BXPD  51
      *
     C                     MOVE A31HB5    P@HIN1  5
     C                     MOVE A32HB5    P@HIN2  5
     C                     MOVE A33HB2    P@HIN3  2
     C                     MOVE A3ATK1    P@BAN1  1
     C                     MOVE A3ATK2    P@BAN2  2
     C                     MOVE A3ATK3    P@BAN3  2
     C                     MOVE A3ATK4    P@BAN4  1
     C                     MOVE *BLANK    P@BMON  4
     C                     MOVE 'BZ '     P@KOTE  3
     C                     MOVE *BLANK    P@KIBN  3
     C                     MOVE *BLANK    P@KHIN 12
     C                     MOVE *BLANK    P@FLG   1
      *
     C                     CALL 'AAMRS8'  AAMRS8
      *
     C           AAMRS8    PLIST
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
     C                     PARM           P@BAN1  1
     C                     PARM           P@BAN2  2
     C                     PARM           P@BAN3  2
     C                     PARM           P@BAN4  1
     C                     PARM           P@BMON  4
     C                     PARM           P@KOTE  3
     C                     PARM           P@KIBN  3
     C                     PARM           P@KHIN 12
     C                     PARM           P@FLG   1
      *
     C           P@FLG     IFEQ *BLANK
     C           P@BMON    ANDNE'0111'
     C                     MOVE A3ATK1    P@BAN1  1
     C                     MOVE A3ATK2    P@BAN2  2
     C                     MOVE A3ATK3    P@BAN3  2
     C                     MOVE A3ATK4    P@BAN4  1
     C                     MOVE *BLANK    P@BMON  4
     C                     MOVE 'DS '     P@KOTE  3
     C                     MOVE *BLANK    P@KIBN  3
     C                     MOVE *BLANK    P@KHIN 12
     C                     MOVE *BLANK    P@FLG   1
      *
     C                     CALL 'AAMRS8'  AAMRS8
     C                     END
      * DSM
     C           P@FLG     IFEQ *BLANK
     C           P@BMON    ANDNE'0111'
     C                     MOVE A3ATK1    P@BAN1  1
     C                     MOVE A3ATK2    P@BAN2  2
     C                     MOVE A3ATK3    P@BAN3  2
     C                     MOVE A3ATK4    P@BAN4  1
     C                     MOVE *BLANK    P@BMON  4
     C                     MOVE 'DSM'     P@KOTE  3
     C                     MOVE *BLANK    P@KIBN  3
     C                     MOVE *BLANK    P@KHIN 12
     C                     MOVE *BLANK    P@FLG   1
      *
     C                     CALL 'AAMRS8'  AAMRS8
     C                     END
      *
     C           P@BMON    IFEQ *BLANK
     C                     MOVE *BLANK    P@BMON  4
     C                     MOVE *BLANK    P@KOTE  3
     C                     MOVE *BLANK    P@KIBN  3
     C                     GOTO @END
     C                     END
      *
      *****
     C                     MOVE P@BMON    W@BMON  40
     C                     MOVE P@KOTE    W@AKT   3
