     C*                    MAIN ROUTINE
     C**************************************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     EXFMTDSP01
      *
     C                     SELEC
      * F3 END
     C           *INKC     WHEQ *ON
     C                     LEAVE
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN85     IFEQ *ON
     C                     ITER
     C                     ENDIF
      * F5/F6 CREATE WF
     C           *INKE     IFEQ *ON
     C           *INKF     OREQ *ON
     C                     EXSR #OUT
     C                     ELSE
     C                     MOVELERR,6     XMSG
     C                     ITER
     C                     ENDIF
      * F5 CREATE DATA FOR PC
     C           *INKE     IFEQ *ON
     C                     EXSR #F5
     C                     LEAVE
     C                     ENDIF
      * F6 PRINT
     C           *INKF     IFEQ *ON
     C                     EXSR #F6
     C                     LEAVE
     C                     ENDIF
     C                     ENDSL
     C*
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------
     C           #CHK1     BEGSR
      *----------------------------------------------
     C                     SETOF                     616263
     C                     SETOF                     85
     C                     MOVE *BLANK    XMSG
      * CHECK DATE 1
     C           XDATE     IFEQ *ZERO
     C                     SETON                     6185
     C                     MOVELERR,1     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      * CHECK DATE 2
     C                     MOVELXDATE     $SRC
     C                     CALL 'UTLR01'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE   8
     C                     PARM           $RTN    1
     C           $RTN      IFNE *BLANK
     C                     SETON                     6185
     C                     MOVELERR,5     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
     C                     MOVEL$TRUE     XDATE
      * CHECK DATA
     C           K#OL01    KLIST
     C                     KFLD           XDATE
     C           K#OL01    SETLLALDPL67
     C                     DO   *HIVAL
     C                     READ ALDPL67                  91
     C   91                LEAVE
     C*
     C           AFRDAT    IFEQ 0
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C*
     C           *IN91     IFEQ *ON
     C                     SETON                     616285
     C                     MOVELERR,3     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      * CHECK SHIFT
     C           XSHFT     IFNE '1'
     C           XSHFT     ANDNE'2'
     C           XSHFT     ANDNE'3'
     C                     SETON                     6285
     C                     MOVELERR,2     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      * CHECK PRINTER
     C           XPRTR     IFNE '1'
     C           XPRTR     ANDNE'2'
     C           XPRTR     ANDNE'3'
     C           XPRTR     ANDNE'4'
     C           XPRTR     ANDNE'5'
JW1  C           XPRTR     ANDNE'6'
     C           XPRTR     ANDNE'9'
     C                     SETON                     6385
     C                     MOVELERR,4     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           XCHK1     ENDSR
      *----------------------------------------------
      * F5: DOWNLOAD
      *----------------------------------------------
     C           #F5       BEGSR
      *
     C                     ENDSR
      *----------------------------------------------
      * F6: PRINT
      *----------------------------------------------
     C           #F6       BEGSR
      *
     C                     MOVELXDATE     $DATE   8
     C                     MOVELXSHFT     $SFT    1
     C                     MOVELXPRTR     $PTYP   1
      *
     C                     SELEC
     C           P$TYP     WHEQ '1'                        PRINT BY LOCATION
     C                     CALL 'ALDC6F1'
     C                     PARM           $DATE
     C                     PARM           $SFT
     C                     PARM           $PTYP
      *
     C           P$TYP     WHEQ '2'                        PRINT BY SRT
     C                     CALL 'ALDC6G1'
     C                     PARM           $DATE
     C                     PARM           $SFT
     C                     PARM           $PTYP
     C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
     C*                    #OUTPUT
     C**************************************************************************
     C           #OUT      BEGSR
      *
     C           K#OL01    SETLLALDPL67
      *
     C                     DO   *HIVAL
      *
     C                     READ ALDPL67                  91
     C   91                LEAVE
      *
     C           AFRDAT    IFNE 0
     C                     ITER
     C                     ENDIF
      *
     C                     CLEARALDWP6E1
     C*
     C                     Z-ADDAFODAT    AWDDAT
     C                     MOVELAFOTMC    AWUSRC
     C                     MOVELAFOTMC    W@USRC  60
     C           W@USRC    CHAINALBPL30              92
     C           *IN92     IFEQ *OFF
     C                     MOVELALWKNM    AWUSRN
     C                     END
      *
     C* CHECK FINAL LOCATION BY PART INF MASTER
     C           HKEY      KLIST
     C                     KFLD           ASHN1   5
     C                     KFLD           ASHN2   5
     C                     KFLD           ASHN3   2
      *
     C                     MOVELAFLPR1    ASHN1
     C                     MOVELAFLPR2    ASHN2
     C                     MOVELAFLPR3    ASHN3
      *
     C           HKEY      CHAINFCEPL011             99
     C           *IN99     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLETODAY
     C                     SETON                     99
     C                     END
      *
     C           *IN99     IFEQ *OFF
     C           A2TRHZ    IFGT TODAY
     C                     MOVELA2KTRT    AW@TRT
     C                     MOVEL'-'       WH1
     C                     MOVELA2KTRR    AW@TRR
     C                     ELSE
     C                     MOVELA2STRT    AW@TRT
     C                     MOVEL'-'       WH1
     C                     MOVELA2STRR    AW@TRR
     C                     END
     C                     END
     C                     MOVEL*BLANK    W@SHIN
     C                     MOVELAFLPR1    W@SHN1
     C                     MOVELAFLPR2    W@SHN2
     C                     MOVELAFLPR3    W@SHN3
     C           W@SHN2    IFNE *BLANK
     C                     MOVEL'-'       W@SHNA
     C                     END
     C           W@SHN3    IFNE *BLANK
     C                     MOVEL'-'       W@SHNB
     C                     END
     C                     MOVELW@SHIN    AWSHIN
     C                     EXSR #PROC
     C                     Z-ADD1         AWNBRS
     C*
     C                     Z-ADD*ZERO     X       20
     C           K#AAM     KLIST
     C                     KFLD           AFLPR1
     C                     KFLD           AFLPR2
     C                     KFLD           AFLPR3
     C           K#AAM     CHAINAAMPL11              92
     C           *IN92     IFEQ *OFF
     C                     Z-ADD1         X       20
     C           0000      LOKUPDEP,X                    93
     C                     SUB  1         X
     C           DEP,X     IFEQ 0111
     C           DEP,X     OREQ 8990
     C           AWPROC    IFEQ 'JC '
     C           DEP,X     IFEQ 0111
     C                     EXSR #SUB1
     C                     END
     C                     END
     C                     ELSE
     C           DEP,X     CHAINFGBPL01              94
     C           *IN94     IFEQ *OFF
     C                     MOVELB2SMEI    AWSMEI
     C                     END
     C                     END
     C                     END
     C*
     C                     Z-ADDAFNONY    AWNONY
     C           K#GAD     KLIST
     C                     KFLD           AFTOKU
     C                     KFLD           AFNONY
     C           K#GAD     CHAINGADPL11              92
     C           *IN92     IFEQ *OFF
     C                     MOVELB5KMEI    AWNONM
     C                     END
     C                     MOVELAFNUKE    AWNUKE
     C*
     C                     MOVELAFNOYY    W@NOYY
     C                     MOVELAFNOMM    W@NOMM
     C                     MOVELAFNODD    W@NODD
     C                     MOVEL'/'       W@NOAA
     C                     MOVEL'/'       W@NOAB
     C                     MOVELW@NODT    AWNODT
     C                     MOVELAFNOBN    AWNOBN
     C*
     C                     MOVELAFUKAN    W@KNBN
     C                     MOVEL*BLANK    W@TM1
     C                     MOVELSHTM      W@TM1
     C                     MOVELW@TM11    W@DET1
     C                     MOVEL':'       W@DETA
     C                     MOVELW@TM12    W@DET2
     C                     MOVELW@DETM    AWDETM
     C                     MOVELW@PALT    AWPALT
      * PREVIOUS LOCATION ---
     C                     MOVELAW@TRT    $LOC
     C                     MOVE AW@TRR    $LOC
     C                     MOVELAFLPR1    $SHN1
     C                     MOVELAFLPR2    $SHN2
     C                     MOVELAFLPR3    $SHN3
     C                     CALL 'UTLC05'
     C                     PARM           $LOC    4
     C                     PARM           $SHN1   5
     C                     PARM           $SHN2   5
     C                     PARM           $SHN3   2
     C                     PARM           $PLOC   4
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$PLOC     P@LOC2
     C                     MOVE '-'       P@LOCH
     C                     MOVE $PLOC     P@LOC3
     C                     ELSE
     C                     MOVE *BLANK    P@LOC2
     C                     MOVE *BLANK    P@LOCH
     C                     MOVE *BLANK    P@LOC3
     C                     ENDIF
     C                     MOVELP@LOCX    AWLOCX
      *
     C* SORT CODE ---
     C                     MOVELAFLPR1    P@SHN1
     C                     MOVELAFLPR2    P@SHN2
     C                     MOVELAFLPR3    P@SHN3
     C                     MOVELP@SHN     $SHIN
     C                     CALL 'UTLR57'
     C                     PARM           $SHIN  12
     C                     PARM           $SRTN  20
     C                     PARM           $SRT#  20
     C                     PARM           $RTN    1
JW1   * MERGE FLD1 & FLD2
 |   C                     MOVEL$SRTN     $FLD1     P
 |   C                     MOVEL$SRT#     $FLD2     P
 |   C                     CALL 'UTLC11'
 |   C                     PARM           $FLD1 128
 |   C                     PARM           $FLD2 128
 |   C                     PARM           $FLD3 128
 |   C                     MOVEL$FLD3     P@SRT   7
 |    *
 |   C**                   MOVEL$SRTN     P@SRT   7
 |   C**                   MOVEL$SRT#     LTR3    3
JW1  C**                   MOVE LTR3      P@SRT
      *
     C                     MOVELP@SRT     AWSRT
      *
     C                     MOVEAPRC       AWP
     C                     MOVEAMCN       AWM
      *
     C                     WRITEALDWP6E1
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*-----------------------------------------------------           *********
     C           #PROC     BEGSR
      *
     C                     DO
      *
     C           K#AAM     CHAINAAMPL11              91
     C   91                LEAVE
     C*
     C                     Z-ADD1         X
     C           '   '     LOKUPPRC,X                    92
     C                     SUB  1         X
     C           X         IFLE *ZERO
     C                     Z-ADD1         X
     C                     END
     C                     MOVELPRC,X     AWPROC
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*-----------------------------------------------------
     C           #SUB1     BEGSR
     C*
     C                     DO
     C*
     C           K#AAM     SETGTAAHTL06
     C                     DO   *HIVAL
     C           K#AAM     REDPEAAHTL06                  97
     C   97                LEAVE
     C           L6SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           L6UKHZ    IFGT TODAY
     C                     ITER
     C                     END
     C           L6STHZ    IFLE TODAY
     C                     ITER
     C                     END
     C                     LEAVE
     C                     ENDDO
     C*
     C           *IN97     IFEQ *OFF
     C           JOK,1     IFNE *BLANK
     C           JOK,1     CHAINAAAPL01              96
     C           *IN96     IFEQ *OFF
     C                     MOVELA5JOKM    AWSMEI
     C                     END
     C                     END
     C           JOK,2     IFNE *BLANK
     C           JOK,2     CHAINAAAPL01              96
     C           *IN96     IFEQ *OFF
     C           AWSMEI    CAT  ':':0     AWSMEI
     C           AWSMEI    CAT  A5JOKM:0  AWSMEI
     C                     END
     C                     END
     C           JOK,3     IFNE *BLANK
     C           JOK,3     CHAINAAAPL01              96
     C           *IN96     IFEQ *OFF
     C           AWSMEI    CAT  ':':0     AWSMEI
     C           AWSMEI    CAT  A5JOKM:0  AWSMEI
     C                     END
     C                     END
     C                     LEAVE
     C                     END
     C* PLATING
     C           K#AAM     SETGTAAFTL06
     C*
     C                     DO   *HIVAL
     C*
     C           K#AAM     REDPEAAFTL06                  97
     C   97                LEAVE
     C           A3SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           A3UKHZ    IFGT TODAY
     C                     ITER
     C                     END
     C           A3STHZ    IFLE TODAY
     C                     ITER
     C                     END
     C           A3ATOB    IFEQ 0111
     C                     ELSE
     C                     ITER
     C                     END
     C*
     C                     LEAVE
     C*
     C                     ENDDO
     C*
     C   97                LEAVE
     C*
     C           JOA,1     IFNE *BLANK
     C           JOA,1     CHAINAAAPL01              96
     C           *IN96     IFEQ *OFF
     C                     MOVELA5JOKM    AWSMEI
     C                     END
     C                     END
     C           JOA,2     IFNE *BLANK
     C           JOA,2     CHAINAAAPL01              96
     C           *IN96     IFEQ *OFF
     C           AWSMEI    CAT  ':':0     AWSMEI
     C           AWSMEI    CAT  A5JOKM:0  AWSMEI
     C                     END
     C                     END
     C           JOA,3     IFNE *BLANK
     C           JOA,3     CHAINAAAPL01              96
     C           *IN96     IFEQ *OFF
     C           AWSMEI    CAT  ':':0     AWSMEI
     C           AWSMEI    CAT  A5JOKM:0  AWSMEI
     C                     END
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
