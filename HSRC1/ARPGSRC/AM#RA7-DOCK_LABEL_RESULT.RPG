     H            Y.
     F** AM#RA7 *********************************************
     F* DOCK LABEL RESULT                                   *
     F*    ITS.             2015.06.22                      *
     F*******************************************************
     FAM#PL11 IF  E           K        DISK
     FAM#WPA7 O   E                    DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  140SDATE
     I                                        1   60STIME
      *
     I            DS
     I                                        1  140R0DE
     I                                        1   80R0SSHZ
     I                                        9  140R0SSTI
      *
     I            DS
     I                                        1  140WKDE
     I                                        1   80WKDED
     I                                        9  140WKDET
      *
     I            DS
     I                                        1  140WKDE1
     I                                        1   80WKDED1
     I                                        9  140WKDET1
      *
     I            DS
     I                                        1  140WKDE2
     I                                        1   80WKDED2
     I                                        9  140WKDET2
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1SHID  8
     C                     PARM           P1DED1  80
     C                     PARM           P1DET1  40
     C                     PARM           P1DED2  80
     C                     PARM           P1DET2  40
     C                     PARM           P1SURT  9
     C                     PARM           P1IAFB  3
     C                     PARM           P1IAFP  3
     C                     PARM           P1NONY  40
     C                     PARM           P1NUKE  4
     C                     PARM           P1ORD# 12
     C                     PARM           P1PALT  2
     C                     PARM           P1KNB#  4
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1HNTE  1
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     TIME           WTIME
     C                     Z-ADD0         WKDE1
     C                     Z-ADD0         WKDE2
     C                     Z-ADDP1DED1    WKDED1
     C                     MOVELP1DET1    WKDET1
     C                     MOVE '00'      WKDET1
     C                     Z-ADDP1DED2    WKDED2
     C                     MOVELP1DET2    WKDET2
     C           WKDED2    IFEQ 0
     C                     Z-ADD*HIVAL    WKDED2
     C                     ENDIF
     C           WKDET2    IFEQ 0
     C                     Z-ADD*HIVAL    WKDET2
     C                     ELSE
     C                     MOVE '59'      WKDET2
     C                     ENDIF
      *
     C                     MOVEL*BLANK    WKHNTE  2
     C                     SELEC
     C           P1HNTE    WHEQ '2'
     C                     MOVEL'NG'      WKHNTE  2
     C           P1HNTE    WHEQ '3'
     C                     MOVEL'OK'      WKHNTE  2
     C                     ENDSL
      *
     C                     EXSR #SB390
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB390    BEGSR
      *
     C           KEY65A    KLIST
     C                     KFLD           P1DED1
      *
     C                     MOVEL'0'       GET65   1
     C                     TIME           WTIME
     C           KEY65A    SETLLAM#PL111
     C                     READ AM#PL111                 80
     C           *IN80     DOWEQ'0'
     C           R0DE      ANDLEWKDE2
     C           R0SKJY    IFEQ 'D'
     C           R0SKHZ    ANDLESDATE
     C                     ELSE
     C                     EXSR #SB391
     C                     ENDIF
     C                     READ AM#PL111                 80
     C                     ENDDO
      *
     CSR         ESB390    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB391    BEGSR
      *
     C           WKHNTE    IFEQ *BLANK
     C                     MOVEL'0'       GETDTA  1
     C                     EXSR #SB711
     C           GETDTA    IFEQ '1'
     C                     Z-ADDR0SSHZ    WKDED
     C                     Z-ADDR0SSTI    WKDET
     C                     EXSR #SB500
     C                     ENDIF
     C                     ELSE
     C           R0HNTE    IFEQ WKHNTE
     C                     MOVEL'0'       GETDTA  1
     C                     EXSR #SB711
     C           GETDTA    IFEQ '1'
     C                     Z-ADDR0SSHZ    WKDED
     C                     Z-ADDR0SSTI    WKDET
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB391    ENDSR
      *----------------------------------------------------*
      * AM#WPA7                                            *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAM#WPA71
     C                     Z-ADDR0SSHZ    W1SSHZ
     C                     Z-ADDR0SSTI    W1SSTI
     C                     MOVELR0USCD    W1USCD
     C                     MOVELR0USNM    W1USNM
     C                     MOVELR0HNTE    W1HNTE
     C                     MOVELR0TICK    W1TICK
     C                     MOVELR0SURT    W1SURT
     C                     MOVELR0SHID    W1SHID
     C                     MOVELR0SHIT    W1SHIT
     C                     MOVELR0SMEI    W1SMEI
     C                     MOVELR0DOCK    W1DOCK
     C                     MOVELR0ORD#    W1ORD#
     C                     MOVELR0PALT    W1PALT
     C                     Z-ADDR0NONY    W1NONY
     C                     MOVELR0NKOJ    W1NKOJ
     C                     MOVELR0NUKE    W1NUKE
     C                     MOVELR0IAFB    W1IAFB
     C                     MOVELR0IAFP    W1IAFP
     C                     MOVELR0PPUL    W1PPUL
     C                     MOVELR0EXT     W1EXT
     C                     MOVELR0SAT     W1SAT
     C                     MOVELR0DLBL    W1DLBL
     C                     MOVELR0NAMC    W1NAMC
     C                     MOVELR0SUPC    W1SUPC
     C                     MOVELR0DDCK    W1DDCK
     C                     MOVELR0DRD#    W1DRD#
     C                     MOVELR0MART    W1MART
     C                     MOVELR0DALT    W1DALT
     C                     MOVELR0MROS    W1MROS
     C                     WRITEAM#WPA71
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      *受注データ                                        *
      *----------------------------------------------------*
     CSR         #SB711    BEGSR
      *
     C           P1SHID    IFNE '00000000'
     C           R0SHID    IFNE P1SHID
     C                     GOTO ESB711
     C                     ENDIF
     C                     ENDIF
     C           P1SURT    IFNE *BLANK
     C           R0SURT    IFNE P1SURT
     C                     GOTO ESB711
     C                     ENDIF
     C                     ENDIF
     C           P1IAFB    IFNE *BLANK
     C           R0IAFB    IFNE P1IAFB
     C                     GOTO ESB711
     C                     ENDIF
     C                     ENDIF
     C           P1IAFP    IFNE *BLANK
     C           R0IAFP    IFNE P1IAFP
     C                     GOTO ESB711
     C                     ENDIF
     C                     ENDIF
     C           P1NONY    IFNE 0
     C           R0NONY    IFNE P1NONY
     C                     GOTO ESB711
     C                     ENDIF
     C                     ENDIF
     C           P1NUKE    IFNE *BLANK
     C           R0NUKE    IFNE P1NUKE
     C                     GOTO ESB711
     C                     ENDIF
     C                     ENDIF
     C           P1ORD#    IFNE *BLANK
     C           R0ORD#    IFNE P1ORD#
     C                     GOTO ESB711
     C                     ENDIF
     C                     ENDIF
     C           P1PALT    IFNE *BLANK
     C           R0PALT    IFNE P1PALT
     C                     GOTO ESB711
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVEL'1'       GETDTA  1
      *
     CSR         ESB711    ENDSR
