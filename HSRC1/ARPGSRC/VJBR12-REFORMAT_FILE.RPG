     C           FKEY1     KLIST
     C                     KFLD           PGM1
     C                     KFLD           KEY1
      *
     C           FKEY2     KLIST
     C                     KFLD           PGM2
     C                     KFLD           KEY2
      *
     C           ACALL     PLIST
     C                     PARM           AFILE            FILE
     C                     PARM           ALIBR            LIBRARY
     C                     PARM           ANUKI            DATE
     C                     PARM           ASKRE            NOT USE
     C                     PARM           ASKHI            NOT USE
      *=============================================================
      *
     C**JW1                MOVE *BLANK    KEY1    7
JW1  C                     MOVE *BLANK    KEY1    8
     C                     MOVE *BLANK    PGM1    6
      *
     C                     Z-ADD12        SFLSIZ  20
     C                     Z-ADD*DATE     YMD
     C                     Z-ADD0         RRN     40
     C                     Z-ADD0         HRRN
     C                     Z-ADD0         HSGY
     C                     MOVE *BLANK    HPGM
     C                     MOVE *BLANK    HFIL
     C                     Z-ADD0         HSKR
     C                     Z-ADD0         HSKH
     C                     Z-ADD0         HSTI
     C                     MOVE *BLANK    HKUB
     C                     MOVE *BLANK    HLIB
      *
     C           STP0      TAG
     C                     WRITEVJBPW123
     C                     EXFMTVJBPW121
     C                     Z-ADD0         A       20
     C                     Z-ADD0         WNO
     C           FKEY1     SETLLVJBPL121
     C                     EXSR SFLSET
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C                     WRITEVJBPW122
      *
     C                     DO   *HIVAL
      *
     C* DISPLAY SUB-FILE
     C           RRN       COMP 0                    20
     C                     SETON                     21
     C                     WRITEVJBPW123
     C                     EXFMTSFLCTL
     C                     SETOF                     102021
     C                     SETOF                     319899
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C* ROLL UP/DOWN
     C           *IN25     IFEQ '1'
     C           *IN26     OREQ '1'
     C                     EXSR ROLLUD
     C                     EXSR SFLSET
     C                     ELSE
      *
     C* INITIAL FILE POINTER SET
     C           *INKE     IFEQ '1'
     C           WNO       IFEQ 0
     C                     SETON                     1099
     C                     MOVE ER,3      MSG
     C                     ELSE
      *
     C                     Z-ADD1         B       20
     C           WNO       LOKUPHRRN,B                   31
     C           *IN31     IFEQ '0'
     C                     SETON                     1099
     C                     MOVE ER,1      MSG
     C                     ELSE
      *
     C           HSGY,B    IFNE 0
     C*                    SETON                     1099
     C*                    MOVE ER,2      MSG
     C                     ELSE
      *
     C                     Z-ADD0         WNO
     C                     MOVE *BLANK    CPGMR  10
     C                     MOVELHPGM,B    CPGMR
     C                     MOVE HFIL,B    AFILE
     C                     MOVE HLIB,B    ALIBR   8
     C                     MOVE HSKR,B    ASKRE   3
     C                     MOVE HSKH,B    ASKHI   3
      *
     C           HKUB,B    IFEQ 'S'
     C                     MOVE *DATE     ANUKI   8
     C                     ELSE
      *
     C                     SETOF                     31
     C                     Z-ADDYM        WYM
     C                     Z-ADD31        WDD
     C                     Z-ADDHSTI,B    W       20
      *
     C           1         DO   W
     C           WMM       IFEQ 01
     C                     SUB  1         WYY
     C                     Z-ADD12        WMM
     C                     ELSE
     C                     SUB  1         WMM
     C                     END
     C                     END
     C                     MOVE WYMD      ANUKI
     C                     END
      *
     C                     SETON                     98
     C                     CALL CPGMR     ACALL
      *
     C**JW1                MOVE HFIL,1    KEY2    7
JW1  C                     MOVE HFIL,1    KEY2    8
     C                     MOVE HPGM,1    PGM2    6
     C                     SUB  C         A
     C                     Z-ADD0         WNO
     C           FKEY2     SETLLVJBPL121
     C                     EXSR SFLSET
     C                     END
     C                     END
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C*****************************************************************
     C           ROLLUD    BEGSR
     C*****************************************************************
     C           *IN26     IFEQ '1'
     C           HFIL,12   IFEQ *BLANK
     C                     ADD  1         A
     C                     ADD  1         C
     C                     END
     C           SFLSIZ    ADD  C         ROLLL#  20
     C           1         DO   ROLLL#
     C           STP1      TAG
     C                     SETOF                     9097
     C                     READPVJBPL121                 90
     C           *IN90     IFEQ '1'
     C                     SUB  1         A
     C           *LOVAL    SETLLVJBPL121
     C                     GOTO STP3
     C                     END
      *
     C           FEFILE    IFLT KEY1
     C                     SETON                     90
     C                     SUB  1         A
     C                     GOTO STP3
     C                     END
     C           FESKJY    IFEQ 'D'
     C           FESKHZ    ANDLE*DATE
     C                     GOTO STP1
     C                     END
     C           KE,M      IFEQ 0
     C                     GOTO STP1
     C                     END
     C                     SUB  1         A
     C           STP3      TAG
     C  N90                END
     C                     END
     C                     ENDSR
      *
     C*****************************************************************
     C           SFLSET    BEGSR
     C*****************************************************************
     C                     SETOF                     8090
     C                     Z-ADD0         RRN
     C                     SETON                     22
     C                     WRITESFLCTL
     C                     SETOF                     22
      *
     C           *IN90     DOWEQ'0'
     C                     SETOF                     90
     C                     READ VJBPL121                 90
     C           *IN90     IFEQ '0'
     C           FESKJY    IFEQ 'D'
     C           FESKHZ    ANDLE*DATE
     C                     GOTO STP2
     C                     END
     C           KE,M      IFEQ 0
     C                     GOTO STP2
     C                     END
      *
     C           *IN80     IFEQ '0'
     C                     SETON                     80
     C                     Z-ADD0         C       20
     C                     Z-ADD0         HRRN
     C                     Z-ADD0         HSGY
     C                     MOVE *BLANK    HPGM
     C                     MOVE *BLANK    HFIL
     C                     Z-ADD0         HSKR
     C                     Z-ADD0         HSKH
     C                     Z-ADD0         HSTI
     C                     MOVE *BLANK    HKUB
     C                     MOVE *BLANK    HLIB
     C                     END
      *
     C                     ADD  1         RRN
     C                     ADD  1         A
     C                     ADD  1         C
     C                     Z-ADDA         HRRN,C
     C                     Z-ADDFESGYO    HSGY,C
     C                     MOVE FEJPGM    HPGM,C
     C                     MOVE FEFILE    HFIL,C
     C                     Z-ADDFESKRE    HSKR,C
     C                     Z-ADDFESKHI    HSKH,C
     C                     Z-ADDFESTEI    HSTI,C
     C                     MOVE FEKUBN    HKUB,C
     C                     MOVE FELIBL    HLIB,C
     C                     EXSR MOV001
     C                     WRITESFL                      90
     C                     ELSE
      *
     C           HFIL,12   IFEQ *BLANK
     C           *HIVAL    SETLLVJBPL121
     C                     ELSE
      *
     C           *HIVAL    SETGTVJBPL121
     C           *IN97     IFEQ '0'
     C                     SETON                     97
     C                     ADD  1         A
     C                     ADD  1         C
     C                     END
     C                     END
      *
     C                     END
     C           STP2      TAG
     C                     END
     C                     ENDSR
      *
