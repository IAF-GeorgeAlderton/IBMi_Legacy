     H            Y.
     F** AJNR01 **********************************
     F*納期遵守率の見える化                    *
     F* ON TIME DELIVERY RATE STAGNATION         *
     F*     SAKAKI.        2019.09.30            *
     F********************************************
     FAH#PL16 IF  E           K        DISK
     FALCPL06 IF  E           K        DISK
     FALRPL08 IF  E           K        DISK
     FAJNWP00 UF  E           K        DISK                      A
     FAJNWP01 O   E                    DISK                      A
     FAJNWP03 UF  E           K        DISK                      A
     FAAIPL11 IF  E           K        DISK
     E                    CDBI       24  2 0             ﾍﾞ] xb     (ncﾆﾞl)
     E                    OBM        15  4               部門
     E                    OKB        15  3               機番
     E                    OTK        15  6               所番地
     E                    OKO        15  3               工程
      *
     I            DS
     I                                        1  48 CDBI
     I                                        1   20CDBI01
     I                                        3   40CDBI02
     I                                        5   60CDBI03
     I                                        7   80CDBI04
     I                                        9  100CDBI05
     I                                       11  120CDBI06
     I                                       13  140CDBI07
     I                                       15  160CDBI08
     I                                       17  180CDBI09
     I                                       19  200CDBI10
     I                                       21  220CDBI11
     I                                       23  240CDBI12
     I                                       25  260CDBI13
     I                                       27  280CDBI14
     I                                       29  300CDBI15
     I                                       31  320CDBI16
     I                                       33  340CDBI17
     I                                       35  360CDBI18
     I                                       37  380CDBI19
     I                                       39  400CDBI20
     I                                       41  420CDBI21
     I                                       43  440CDBI22
     I                                       45  460CDBI23
     I                                       47  480CDBI24
      *
     I            DS
     I                                        1   80W1CR1
     I                                        1   40W1HTYY
     I                                        5   60W1HTMM
     I                                        7   80W1HTDD
      *
     I            DS
     I                                        1  12 CFHINA
     I                                        1   5 CFHIN1
     I                                        6  10 CFHIN2
     I                                       11  12 CFHIN3
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
      *
     C           *ENTRY    PLIST
     C                     PARM           P1CR1   8
     C                     PARM           P1CR2   8
     C                     PARM           P1DATA  1
     C                     PARM           P1FILT  1
     C                     PARM           P1HH01  40
     C                     PARM           P1HH02  40
     C                     PARM           P1HH03  40
     C                     PARM           P1HH04  40
     C                     PARM           P1HH05  40
     C                     PARM           P1HH06  40
     C                     PARM           PCMD    2
      *
     C                     TIME           SDATE
     C                     MOVEL'1'       OPNCLS
     C           P1HH01    IFNE 0
     C                     CLEARAJNWP001
     C                     Z-ADDP1HH01    W0HH
     C                     WRITEAJNWP001
     C                     ENDIF
     C           P1HH02    IFNE 0
     C                     CLEARAJNWP001
     C                     Z-ADDP1HH02    W0HH
     C                     WRITEAJNWP001
     C                     ENDIF
     C           P1HH03    IFNE 0
     C                     CLEARAJNWP001
     C                     Z-ADDP1HH03    W0HH
     C                     WRITEAJNWP001
     C                     ENDIF
     C           P1HH04    IFNE 0
     C                     CLEARAJNWP001
     C                     Z-ADDP1HH04    W0HH
     C                     WRITEAJNWP001
     C                     ENDIF
     C           P1HH05    IFNE 0
     C                     CLEARAJNWP001
     C                     Z-ADDP1HH05    W0HH
     C                     WRITEAJNWP001
     C                     ENDIF
     C           P1HH06    IFNE 0
     C                     CLEARAJNWP001
     C                     Z-ADDP1HH06    W0HH
     C                     WRITEAJNWP001
     C                     ENDIF
      * OTHERS
     C                     CLEARAJNWP001
     C                     Z-ADD9999      W0HH
     C                     WRITEAJNWP001
      *
     C                     MOVE P1CR1     W1CR1   80
     C                     MOVE P1CR2     W1CR2   80
      *
     C           KEYCF1    KLIST
     C                     KFLD           W1HTYY  40
     C                     KFLD           W1HTMM  20
     C                     KFLD           W1HTDD  20
      *
     C           KEYCF1    SETLLAH#PL151
     C                     READ AH#PL151                 80
     C           *IN80     DOWEQ'0'
     C           CFHTHZ    ANDLEW1CR2
     C           CFSKJY    IFEQ 'D'
     C           CFSKHZ    ANDLEWDATE
     C                     ELSE
     C                     EXSR #SB400
     C                     ENDIF
     C                     READ AH#PL151                 80
     C                     ENDDO
      *
     C                     EXSR #CLOSE
     C           OPNCLS    IFEQ '0'
     C                     MOVE '9'       OPNCLS
     C                     CALL 'AAMRSB'
      *入力パラメータ
     C                     PARM           CFHIN1  5
     C                     PARM           CFHIN2  5
     C                     PARM           CFHIN3  2
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     ENDIF
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * DATA                                               *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEA*BLANK    OBM
     C                     MOVEA*BLANK    OKB
     C                     MOVEA*BLANK    OTK
     C                     MOVEA*BLANK    OKO
     C                     CALL 'AAMRSB'
      *入力パラメータ
     C                     PARM           CFHIN1  5
     C                     PARM           CFHIN2  5
     C                     PARM           CFHIN3  2
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     MOVEL'0'       OPNCLS
     C                     MOVEAPBMN      OBM
     C                     MOVEAPKBN      OKB
     C                     MOVEAPTKR      OTK
     C                     MOVEAPKOT      OKO
     C** TS-LINE OR NOT
     C           P1FILT    IFEQ '1'                        TS-LINE ONLY
     C                     Z-ADD1         A       20
     C           'OQ1'     LOKUPOKB,A                    29
     C           *IN29     IFEQ '0'
     C                     GOTO ESB400
     C                     ENDIF
     C                     ENDIF
     C***
     C** BZ/DS
     C                     MOVEL'0'       PHBFLG  1
     C                     MOVEL*BLANK    KB1     1
     C**  CHECK DS PROCESS
     C                     Z-ADD1         A       20
     C           'DS '     LOKUPOKO,A                    29
     C           *IN29     IFEQ '1'
     C                     MOVELOKB,A     KB1
     C           KB1       IFEQ 'G'                        DS1
     C           KB1       OREQ 'H'                        DS2
     C           KB1       OREQ 'J'                        DS3
     C           KB1       OREQ 'K'                        DS4
     C                     MOVEL'1'       PHBFLG  1
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADD1         LL      40
     C           LL        DOWLECFMAIS
     C                     MOVE LL        P@PAGE  2
     C                     Z-ADD0         P@BOX   40
      *
     C                     SELEC
      *---------------------------------------
      * A-PICS
      *---------------------------------------
     C           P1DATA    WHEQ '7'
      * ISSUE
     C                     Z-ADDCFHTHZ    P@DAT1  80
     C                     Z-ADD0         P@TIM1  60
     C                     Z-ADD1         A       20
     C           0111      CHAINAAIPL111             49
     C           *IN49     IFEQ '0'
     C           CFHTBB    LOKUPCDBI,A                   69
     C           *IN69     IFEQ '1'
     C           A         IFEQ 24
     C                     ELSE
     C                     MOVELA         P@TIM1  60
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C*
     C                     EXSR #SB410                     CV SCAN
     C                     Z-ADDW@BOX     P@BOX
     C                     Z-ADDP@DATE    P@DAT2  80
     C                     Z-ADDP@TIME    P@TIM2  60
      *---------------------------------------
      * CV
      *---------------------------------------
     C           P1DATA    WHEQ '1'
     C                     EXSR #SB410                     CV SCAN
     C                     Z-ADDP@DATE    P@DAT1  80
     C                     Z-ADDP@TIME    P@TIM1  60
     C                     Z-ADDW@BOX     P@BOX
     C           P@DAT1    IFNE 0
     C                     EXSR #SB411                     PRELOAD
     C                     Z-ADDP@DATE    P@DAT2  80
     C                     Z-ADDP@TIME    P@TIM2  60
     C                     ENDIF
      *---------------------------------------
      * BZ,DS,JC
      *---------------------------------------
     C           P1DATA    WHEQ '2'
     C           P1DATA    OREQ '3'
     C           P1DATA    OREQ '4'
     C                     EXSR #SB411                     PRELOAD
     C                     Z-ADDP@DATE    P@DAT1  80
     C                     Z-ADDP@TIME    P@TIM1  60
     C***                  Z-ADDW@BOX     P@BOX
     C                     Z-ADD4         P@BOX
     C           P@DAT1    IFNE 0
     C                     EXSR #SB421                     LOADING
     C                     Z-ADDP@DATE    P@DAT2  80
     C                     Z-ADDP@TIME    P@TIM2  60
     C                     ENDIF
      *---------------------------------------
      * INSPECTION
      *---------------------------------------
     C           P1DATA    WHEQ '5'
     C                     EXSR #SB411                     PRELOAD(SRT)
     C           W1RTN     IFEQ *BLANK
     C                     Z-ADDP@DATE    P@DAT1  80
     C                     Z-ADDP@TIME    P@TIM1  60
     C***                  Z-ADDW@BOX     P@BOX
     C                     Z-ADD1         P@BOX
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
     C           P@DAT1    IFNE 0
     C                     EXSR #SB431                     STORE IN
     C                     Z-ADDP@DATE    P@DAT2  80
     C                     Z-ADDP@TIME    P@TIM2  60
     C                     ENDIF
      *---------------------------------------
      * BZ/DS/JC
      *---------------------------------------
     C           P1DATA    WHEQ '6'
     C                     EXSR #SB441                     UNLOAD
     C                     Z-ADDP@DATE    P@DAT1  80
     C                     Z-ADDP@TIME    P@TIM1  60
     C***                  Z-ADDW@BOX     P@BOX
     C                     Z-ADD4         P@BOX
     C           PHBFLG    IFEQ '1'
     C                     Z-ADD2         P@BOX
     C                     ENDIF
     C*
     C           P@DAT1    IFNE 0
     C                     EXSR #SB411                     PRELOAD(SRT)
     C           W1RTN     IFEQ *BLANK
     C                     Z-ADDP@DATE    P@DAT2  80
     C                     Z-ADDP@TIME    P@TIM2  60
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSL
      *---------------------------------------
      * WRITE RESULT
      *---------------------------------------
     C                     EXSR #SB500
      *
     C                     ADD  1         LL
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      * 1. CV(LOCATION)                                    *
      *----------------------------------------------------*
     CSR         #SB410    BEGSR
      *
     C                     Z-ADD4         W@BOX
      * PT KANBAN
     C           OKO,1     IFEQ 'KN'
     C           OKO,2     ANDEQ'HT'
     C                     Z-ADD1         W@BOX
     C                     ENDIF
      *
     C                     Z-ADD0         P@DATE  80
     C                     Z-ADD0         P@TIME  60
     C***                  Z-ADD0         W@BOX   30
     C           ALCKEY    KLIST
     C                     KFLD           CFCHYU
     C                     KFLD           CFZENO
     C                     KFLD           CFTHNO
     C           ALCKEY    SETLLALCPL06
     C           ALCKEY    READEALCPL06                  88
     C           *IN88     DOWEQ'0'
     C           P@DATE    ANDEQ0
     C           A8ERR     IFEQ *BLANK
     C           A8BRC3    ANDNE*BLANK
     C           A8DATE    ANDGECFHTHZ
     C           A8BRCD    ANDEQP@PAGE
     C                     Z-ADDA8DATE    P@DATE
     C                     Z-ADDA8TIME    P@TIME
     C***                  Z-ADD4         W@BOX
     C                     ENDIF
     C           ALCKEY    READEALCPL06                  88
     C                     ENDDO
      *
      * CHECK PT SCAN RESULT
     C           P@DATE    IFEQ 0
      *
     C           ALRKEY    KLIST
     C                     KFLD           CFZENO
     C                     KFLD           CFTHNO
      *
     C           ALRKEY    SETGTALRPL08
     C           ALRKEY    REDPEALRPL08                  88
     C           *IN88     DOWEQ'0'
     C           P@DATE    ANDEQ0
     C           PTOKNG    IFEQ 'OK'
     C           PTCODT    ANDGECFHTHZ
     C           PTPAGE    ANDEQP@PAGE
     C                     Z-ADDPTCODT    P@DATE
     C                     Z-ADDPTCOTM    P@TIME
     C***                  Z-ADD1         W@BOX   30
     C                     ENDIF
     C           ALRKEY    REDPEALRPL08                  88
     C                     ENDDO
      *
     C                     ENDIF
      *
     CSR         ESB410    ENDSR
      *----------------------------------------------------*
      * 1. CV(PRELOAD) 2. BZ(PRELOAD) 3. DS(PRELOAD) 4. JC(PRELOAD)
      * 5. SRT(PRELOAD)
      *----------------------------------------------------*
     CSR         #SB411    BEGSR
      *
     C                     Z-ADD0         P@DATE  80
     C                     Z-ADD0         P@TIME  60
     C***                  Z-ADD0         W@BOX   30
     C           ALCKEY    SETLLALCPL06
     C           ALCKEY    READEALCPL06                  88
     C           *IN88     DOWEQ'0'
     C           P@DATE    ANDEQ0
     C           A8ERR     IFEQ *BLANK
     C           A8BRC3    ANDEQ*BLANK
     C           A8DATE    ANDGECFHTHZ
     C           A8BRCD    ANDEQP@PAGE
      *
     C                     MOVELA8BRC2    LTR3    3
     C                     MOVELA8BRC2    LTR8    8
      * PRELOAD (SRT)
     C           P1DATA    IFEQ '5'
     C           P1DATA    OREQ '6'
     C           LTR3      IFEQ 'SRT'
     C                     CALL 'UTLR57'
     C                     PARM           CFHINA
     C                     PARM           W1SRTN 20
     C                     PARM           W1SRT# 20
     C                     PARM           W1RTN   1
     C           W1RTN     IFEQ ' '
     C                     Z-ADDA8DATE    P@DATE
     C                     Z-ADDA8TIME    P@TIME
     C                     Z-ADD1         W@BOX   30
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      * PRELOAD (MACHINE)
     C                     ELSE
     C           LTR3      IFNE 'SRT'
     C           LTR8      ANDNE'SHIPPING'
     C                     Z-ADDA8DATE    P@DATE
     C                     Z-ADDA8TIME    P@TIME
     C                     Z-ADD4         W@BOX   30
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
      *
     C           ALCKEY    READEALCPL06                  88
     C                     ENDDO
      *
     CSR         ESB411    ENDSR
      *----------------------------------------------------*
      * 2. BZ(LOADING) 3. DS(LOADING) 4. JC(LOADING)
      *----------------------------------------------------*
     CSR         #SB421    BEGSR
      *
     C                     Z-ADD0         P@DATE  80
     C                     Z-ADD0         P@TIME  60
     C***                  Z-ADD0         W@BOX   30
      * BZ
     C                     SELEC
     C           P1DATA    WHEQ '2'
     C                     Z-ADD0         P@WIHZ
     C                     Z-ADD0         P@WITM
     C                     CALL 'ALDRT5'
     C                     PARM           CFHIN1  5        PART NUMBER 1
     C                     PARM           CFHIN2  5        PART NUMBER 2
     C                     PARM           CFHIN3  2        PART NUMBER 3
     C                     PARM           CFTHNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           CFHTHZ  80       KANBAN PUBLICATION
      *                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
     C                     Z-ADDP@WIHZ    P@DATE
     C                     Z-ADDP@WITM    P@TIME
     C           P@DATE    IFNE 0
     C                     Z-ADD1         W@BOX   30
     C                     ENDIF
      * DS
     C           P1DATA    WHEQ '3'
     C                     Z-ADD0         P@WIHZ
     C                     Z-ADD0         P@WITM
     C                     CALL 'ALDRT6'
     C                     PARM           CFHIN1  5        PART NUMBER 1
     C                     PARM           CFHIN2  5        PART NUMBER 2
     C                     PARM           CFHIN3  2        PART NUMBER 3
     C                     PARM           CFTHNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           CFHTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
     C                     Z-ADDP@WIHZ    P@DATE
     C                     Z-ADDP@WITM    P@TIME
     C           P@DATE    IFNE 0
     C                     Z-ADD1         W@BOX   30
     C                     ENDIF
      * JC
     C           P1DATA    WHEQ '4'
     C                     Z-ADD0         P@WIHZ
     C                     Z-ADD0         P@WITM
     C                     CALL 'ALDRT3'
     C                     PARM           CFHIN1  5        PART NUMBER 1
     C                     PARM           CFHIN2  5        PART NUMBER 2
     C                     PARM           CFHIN3  2        PART NUMBER 3
     C                     PARM           CFTHNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PRODUCTION ORDER
     C                     PARM           CFHTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@WIHZ  80       WEIGHING DATE
     C                     PARM           P@WITM  60       WEIGHING TIME
     C                     PARM           P#OPN   1
     C                     Z-ADDP@WIHZ    P@DATE
     C                     Z-ADDP@WITM    P@TIME
     C           P@DATE    IFNE 0
     C                     Z-ADD1         W@BOX   30
     C                     ENDIF
      *
     C                     ENDSL
      *
     CSR         ESB421    ENDSR
      *----------------------------------------------------*
      * 5. INSPECTION (LOCATION)                           *
      *----------------------------------------------------*
     CSR         #SB431    BEGSR
      *
     C                     Z-ADD0         P@DATE  80
     C                     Z-ADD0         P@TIME  60
     C***                  Z-ADD0         W@BOX   30
      *  STORE IN
     C                     Z-ADD0         P@WIHZ
     C                     Z-ADD0         P@WITM
     C                     CALL 'ALDRTA'
     C                     PARM           CFZENO  4
     C                     PARM           CFTHNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PRODUCTION ORDER
     C                     PARM           CFHTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@CODT  80
     C                     PARM           P@COTM  60
     C                     PARM           P#OPN   1
     C*
     C                     Z-ADDP@CODT    P@DATE
     C                     Z-ADDP@COTM    P@TIME
     C           P@DATE    IFNE 0
     C                     Z-ADD1         W@BOX   30
     C                     ENDIF
     C*
     CSR         ESB431    ENDSR
      *----------------------------------------------------*
      * 6. BZ(UNLOADING)/DS(UNLOADING)/JC(UNLOADING)
      *----------------------------------------------------*
     CSR         #SB441    BEGSR
      *
     C                     Z-ADD0         P@DATE  80
     C                     Z-ADD0         P@TIME  60
     C***                  Z-ADD0         W@BOX   30
      * BZ
     C                     Z-ADD0         P@CODT
     C                     Z-ADD0         P@COTM
     C                     CALL 'ALDRT8'
     C                     PARM           CFHIN1  5        PART NUMBER 1
     C                     PARM           CFHIN2  5        PART NUMBER 2
     C                     PARM           CFHIN3  2        PART NUMBER 3
     C                     PARM           CFTHNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           CFHTHZ  80       KANBAN PUBLICATION
     C*                               OUT ------
     C                     PARM           P@KEHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@KETM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
     C           P@KEHZ    IFNE 0
     C                     Z-ADD4         W@BOX   30
     C                     Z-ADDP@KEHZ    P@CODT
     C                     Z-ADDP@KETM    P@COTM
     C                     ENDIF
      * DS
     C           P@KEHZ    IFEQ 0
     C                     CALL 'ALDRT4'
     C                     PARM           CFHIN1  5        PART NUMBER 1
     C                     PARM           CFHIN2  5        PART NUMBER 2
     C                     PARM           CFHIN3  2        PART NUMBER 3
     C                     PARM           CFTHNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           CFHTHZ  80       KANBAN PUBLICATION
     C*                               OUT ------
     C                     PARM           P@KEHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@KETM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
     C           P@KEHZ    IFNE 0
     C                     Z-ADDP@KEHZ    P@CODT
     C                     Z-ADDP@KETM    P@COTM
     C           PHBFLG    IFEQ '1'
     C                     Z-ADD2         W@BOX   30
     C                     ELSE
     C                     Z-ADD4         W@BOX   30
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      * JC
     C           P@KEHZ    IFEQ 0
     C                     CALL 'ALDRT2'
     C                     PARM           CFHIN1  5        PART NUMBER 1
     C                     PARM           CFHIN2  5        PART NUMBER 2
     C                     PARM           CFHIN3  2        PART NUMBER 3
     C                     PARM           CFTHNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           CFHTHZ  80       KANBAN PUBLICATION
     C*                               OUT ------
     C                     PARM           P@KEHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@KETM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
     C           P@KEHZ    IFNE 0
     C                     Z-ADDP@KEHZ    P@CODT
     C                     Z-ADDP@KETM    P@COTM
     C                     Z-ADD4         W@BOX   30
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADDP@CODT    P@DATE
     C                     Z-ADDP@COTM    P@TIME
     C*
     CSR         ESB441    ENDSR
      *----------------------------------------------------*
      * WORK                                               *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     Z-ADDP@DAT1    P1DAT1
     C                     Z-ADDP@TIM1    P1TIM1
      *
     C           P1DATA    IFEQ '2'
     C           P1DATA    OREQ '3'
     C           P1DATA    OREQ '4'
     C           P1DATA    OREQ '5'
     C           P1DATA    OREQ '6'
      *
     C           P@DAT2    IFEQ 0
     C                     Z-ADDWDATE     P@DAT2
     C                     Z-ADDWTIME     P@TIM2
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     Z-ADDP@DAT2    P1DAT2
     C                     Z-ADDP@TIM2    P1TIM2
      *
     C                     Z-ADD0         P9DAY
     C                     Z-ADD0         P9THH
     C                     Z-ADD0         P9TMM
     C                     Z-ADD0         P9TSS
      *
     C                     Z-ADD0         @RGE    40
     C*
     C** EITHER IS 0, IT IS NOT WRITTEN
     C           P@DAT1    IFEQ 0
     C           P@DAT2    OREQ 0
     C                     ELSE
     C                     MOVEL*BLANK    P9OMIT
     C                     CALL 'AJNR99'
     C                     PARM           P1DAT1  80
     C                     PARM           P1TIM1  60
     C                     PARM           P1DAT2  80
     C                     PARM           P1TIM2  60
     C                     PARM           P9DAY   50
     C                     PARM           P9THH   20
     C                     PARM           P9TMM   20
     C                     PARM           P9TSS   20
     C                     PARM           P9OMIT  1
     C           P9OMIT    IFEQ '1'
     C                     GOTO ESB500
     C                     ENDIF
      *
     C           P9DAY     MULT 24        W@DDHH  40
     C           W@DDHH    MULT 60        W@DDM1  50
