     H            Y.
     F** ABFR07A *******************************************
     F*  FORD ROUTE MASTER INQ BY PLANT                  *
     F*  T.SAKAKI                           2016.10.19     *
     F* ------------------------------                     *
JW1  F*  JW         2023.04.14 ADD PLANT POSITION          *
JW2  F*  JW         2025.01.02 ADD BIN#                    *
     F******************************************************
     FABFPW07ACF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN   KSFILE SFL01
     FABFDL02 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
      *
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
     I            DS
     I                                        1   80QASKHZ
     I                                        1   40QASKYY
     I                                        5   60QASKMM
     I                                        7   80QASKDD
     I            DS
     I                                        1  10 QAEFHZ
     I                                        1   40QAEFYY
     I                                        5   5 WKDT
     I                                        6   70QAEFMM
     I                                        8   8 WKDT2
     I                                        9  100QAEFDD
     I            DS
     I                                        1  10 QAKOHZ
     I                                        1   40QAKOYY
     I                                        5   5 WKDT3
     I                                        6   70QAKOMM
     I                                        8   8 WKDT4
     I                                        9  100QAKODD
     C***************************************************************
     C* MAIN ROUTINE
     C***************************************************************
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C* INITIAL SETTINGS
     C*===============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $PLNT   5
     C* SET DATA
JW1  C                     MOVEL$PLNT     XPLANT
 "   C                     EXSR #SET1
      *
     C                     ENDSR
     C*===============================================================
JW1   * SET SUBFILE DATA
     C*===============================================================
     C           #SET1     BEGSR
      *
     C                     MOVEA*ALL'0'   *IN
     C*  SFLCLR
     C                     SETON                     72
     C                     WRITECTL01
     C                     SETOF                     72
     C                     Z-ADD0         RRN     40
     C                     Z-ADD0         ENDRRN  40
     C                     MOVE *BLANK    @@UMU   1        データ有無
      *
     C                     MOVE *BLANK    SVPLAN  5
      *
     C           XPLANT    SETLLABFDL02
S1   C                     DO   *HIVAL
     C                     READ ABFDL02                  90
     C   90                LEAVE
 S2  C           QASKJY    IFEQ 'D'
     C           QASKHZ    ANDLE*DATE
     C                     ITER
 E2  C                     ENDIF
     C* BRAEK ?
     C           QAPLAN    IFNE SVPLAN
     C           SVPLAN    ANDNE*BLANK
     C                     CLEARSFL01
     C                     ADD  1         RRN
     C                     WRITESFL01
     C                     ENDIF
     C*
     C                     MOVELQAPLAN    SBPLAN
     C                     MOVELQADOCK    SBDOCK
     C                     MOVELQAICCD    SBICCD
     C                     MOVELQAROUT    SBROUT
     C                     MOVELQAMODE    SBMODE
     C                     MOVELQANONY    SBNONY
      *
     C           QANONY    CHAINFGBPL01              55
     C  N55                MOVELB2SMEI    SBSMEI
      *
      *
     C                     MOVEL'/'       WKDT
     C                     MOVEL'/'       WKDT2
     C                     MOVELQAEFHZ    SBEFHZ
      *
     C                     MOVEL'/'       WKDT3
     C                     MOVEL'/'       WKDT4
     C**JW2                MOVELQAKOHZ    SBKOHZ
      * GET BIN#
JW2  C                     MOVELSBNONY    $NONY   4
     C                     MOVELSBDOCK    $DOCK   4
     C                     CALL 'UTLR34G'
     C                     PARM           $NONY   4
     C                     PARM           $DOCK   4
     C                     PARM           $BIN#   2
     C                     PARM           $ROUT   4
     C                     MOVEL$BIN#     SBBIN
      *
     C                     MOVELQAKOME    SBKOUS
      *
     C                     ADD  1         RRN
     C                     WRITESFL01
     C                     MOVELQAPLAN    SVPLAN
      *
E1   C                     ENDDO
     C*-------------------------
     C           RRN       IFEQ 0
     C                     CLEARSFL01
     C                     MOVEL'NO DATA 'SBSMEI
     C                     ADD  1         RRN
     C                     WRITESFL01
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
      *
     C                     MOVE '#DSP1   '@STEP
     C                     Z-ADD1         DSPRRN
      *
JW1  C                     ENDSR
     C*===============================================================
      * DISPLAY 1ST SCREEN
     C*===============================================================
     C           #DSP1     BEGSR
     C                     SETON                     71
     C                     WRITEDSP01
     C                     EXFMTCTL01
     C                     SETOF                     71
     C                     MOVEA'0'       *IN,99
     C                     Z-ADD$$RRN     DSPRRN
      *
     C                     SELEC
      * F1 *
     C           *INKA     WHEQ *ON
     C                     MOVE '#END    '@STEP
      * F3 *
     C           *INKC     WHEQ *ON
     C                     MOVE '#END    '@STEP
      * F12*
     C           *INKL     WHEQ *ON
     C                     MOVE '#END    '@STEP
      * ENTR
     C                     OTHER
     C           *IN73     IFEQ *OFF
JW1  C                     EXSR #SET1
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
