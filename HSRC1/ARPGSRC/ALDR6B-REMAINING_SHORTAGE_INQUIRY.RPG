     C           $CHK22    TAG
     C                     ENDSR
      *===============================================================
      *г‚µгѓ–гѓ•г‚Ўг‚¤гѓ«дЅњж€ђ(DAY)
      *===============================================================
     C           #SFST1    BEGSR
     C*
     C                     SETON                     73    SFLCLR
     C                     WRITESFCTL1
     C                     SETOF                     73
     C*
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         ENDRRN  40
     C                     Z-ADD0         M$ODAT  80
     C                     Z-ADD0         M$BOXS  60
     C                     Z-ADD0         M$BOX1  60       :TOYOTA
     C                     Z-ADD0         M$BOX2  60       :HONDA
     C                     Z-ADD0         M$BOX3  60       :FORD
     C                     Z-ADD0         M$BOX4  60       :TIER1
     C*
     C* .. SHIPPING SHORTAGE FILE                         *
      **----------------------------------
     C                     DO   *HIVAL
     C                     READ ALDPL66                  90
     C  N90      AFODAT    IFGT D2YMD2                     SHRTG DATE
     C                     SETON                     90
     C                     ENDIF
     C   90                LEAVE
     C           AFSKJC    IFEQ 'D'
     C           AFDATE    ANDLE@SYSHZ
     C                     ITER
     C                     ENDIF
     C**
     C           AFODAT    IFNE M$ODAT
     C           M$BOXS    IFNE 0
     C                     EXSR #SFWR1
     C                     ENDIF
     C                     Z-ADDAFODAT    M$ODAT  80
     C                     Z-ADD0         M$BOXS  60
     C                     Z-ADD0         M$BOX1  60       :TOYOTA
     C                     Z-ADD0         M$BOX2  60       :HONDA
     C                     Z-ADD0         M$BOX3  60       :FORD
     C                     Z-ADD0         M$BOX4  60       :TIER1
     C                     ENDIF
     C**
     C                     ADD  1         M$BOXS
     C**                   ---- TOYOTA.FORD,HONDA,TIER1 ----
     C                     EXSR ##NONY
     C                     ENDDO
      **--------------------------------
     C           M$BOXS    IFNE 0
     C                     EXSR #SFWR1
     C                     ENDIF
     C*
     C                     Z-ADDRRN1      ENDRRN
     C                     ENDSR
      **----------------------------------------------------
      **----------------------------------------------------
     C           #SFWR1    BEGSR
     C                     MOVE *BLANK    S1SEL             SEL
     C                     Z-ADDM$ODAT    S1DATE            DATE
     C                     Z-ADDM$BOXS    S1BOXS            BOXES
     C                     Z-ADDM$BOX1    S1BOX1           :TOYOTA
     C                     Z-ADDM$BOX2    S1BOX2           :HONDA
     C                     Z-ADDM$BOX3    S1BOX3           :FORD
     C                     Z-ADDM$BOX4    S1BOX4           :TIER1
     C                     ADD  1         RRN1
     C                     WRITESFREC1
     C                     ENDSR
      **----------------------------------------------------
      ** ---- TOYOTA.FORD,HONDA,TIER1 ----
      **----------------------------------------------------
     C           ##NONY    BEGSR
      *
     C                     MOVE AFNONY    $DLV
      *
     C                     CALL 'UTLR62B'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTN    1
      *
     C                     SELEC
     C           $GRP      WHEQ 'TYT'
     C                     ADD  1         M$BOX1           :TOYOTA
     C           $GRP      WHEQ 'HND'
     C                     ADD  1         M$BOX2           :HONDA
     C           $GRP      WHEQ 'FRD'
     C                     ADD  1         M$BOX3           :FORD
     C                     OTHER
     C                     ADD  1         M$BOX4           :TIER1
     C                     ENDSL
      *
     C           @SKIP     ENDSR
      *===============================================================
      *г‚µгѓ–гѓ•г‚Ўг‚¤гѓ«дЅњж€ђ(MONTH)
      *===============================================================
     C           #SFST2    BEGSR
     C*
     C                     SETON                     73    SFLCLR
     C                     WRITESFCTL2
     C                     SETOF                     73
     C*                                   D2YMD2 =<YYYYMM31>
     C                     Z-ADD31        D2DD2
     C*
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         ENDRRN  40
     C                     Z-ADD0         M$ODYM  60
     C                     Z-ADD0         M$BOXS  60
     C*
     C* .. SHIPPING SHORTAGE FILE                         *
      **----------------------------------
     C                     DO   *HIVAL
     C                     READ ALDPL66                  90
     C  N90      AFODAT    IFGT D2YMD2                     SHRTG DATE
     C                     SETON                     90
     C                     ENDIF
     C   90                LEAVE
     C           AFSKJC    IFEQ 'D'
     C           AFDATE    ANDLE@SYSHZ
     C                     ITER
     C                     ENDIF
     C**
     C           AFODYM    IFNE M$ODYM
     C           M$BOXS    IFNE 0
     C                     EXSR #SFWR2
     C                     ENDIF
     C                     Z-ADDAFODYM    M$ODYM  60
     C                     Z-ADD0         M$BOXS  60
     C                     ENDIF
     C**
     C                     ADD  1         M$BOXS
     C                     ENDDO
      **--------------------------------
     C           M$BOXS    IFNE 0
     C                     EXSR #SFWR2
     C                     ENDIF
     C*
     C                     Z-ADDRRN1      ENDRRN
     C                     ENDSR
      **----------------------------------------------------
      **----------------------------------------------------
     C           #SFWR2    BEGSR
      **
     C           KEYF8     KLIST
     C                     KFLD           M$ODYY
     C                     KFLD           M$ODMM
     C           KEYF8     SETLLAGDPL12
     C                     Z-ADD0         $$DAYS  31
      **--------------------------------
     C                     DO   *HIVAL
     C           KEYF8     READEAGDPL12                  95
     C   95                LEAVE
     C           F8HIRU    IFNE '*'
     C                     ADD  0.5       $$DAYS
     C                     ENDIF
     C           F8YORU    IFNE '*'
     C                     ADD  0.5       $$DAYS
     C                     ENDIF
     C                     ENDDO
      **--------------------------------
      **
     C                     Z-ADDM$ODYM    S2MONT            MONTH
     C                     Z-ADDM$BOXS    S2BOXS            BOXES
     C                     Z-ADD$$DAYS    S2DAYS
     C                     Z-ADD0         S2PERD           BOXES/DAYS
     C           S2DAYS    IFNE 0
     C           S2BOXS    DIV  S2DAYS    S2PERD    H      BOXES/DAYS
     C                     ENDIF
     C                     ADD  1         RRN1
     C                     WRITESFREC2
      **
     C                     ENDSR
