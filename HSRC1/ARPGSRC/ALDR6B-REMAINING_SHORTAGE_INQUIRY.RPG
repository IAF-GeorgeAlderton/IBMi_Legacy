     C           #DSP2     BEGSR
     C*
     C                     EXFMTDSP02
     C*
     C                     SETOF                     212299
     C                     MOVE *BLANK    D2ERR
     C*
      *
S1   C                     SELEC
     C*
     C*  < F3 > BACK
     C           *INKC     WHEQ *ON
     C                     MOVE '#DSP1   '@STEP
     C*  <           >
-1   C                     OTHER
     C                     MOVE '#CHK2   '@STEP
E1   C                     ENDSL
      *
     C                     ENDSR
      *===============================================================
      *  з”»йќўпј’гЂЂгѓЃг‚§гѓѓг‚Ї
      *===============================================================
     C           #CHK2     BEGSR
      *
     C                     SELEC
     C           D1SEL     WHEQ '1'
