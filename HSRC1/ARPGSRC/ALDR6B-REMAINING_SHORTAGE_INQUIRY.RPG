     I              '1: EACH DAY         'C         $SEL1
     I              '2: EACH MONTH       'C         $SEL2
     C*===============================================================
     C*
      *===============================================================
      *  START  PROGRAM
      *===============================================================
     C                     MOVE '#INIT   '@STEP   8
      *
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            е€ќжњџе‡¦зђ†
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C           @STEP     CASEQ'#DSP3   '#DSP3
     C                     ENDCS
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      * е€ќжњџпѕ€пЅ®mb
      *===============================================================
     C           #INIT     BEGSR
      *
     C                     MOVEA*ALL'0'   *IN
     C                     TIME           @TIME
     C                     MOVE *BLANK    D1SEL
     C                     MOVE '#DSP1   '@STEP
      *
     C                     ENDSR
      *===============================================================
      *  з”»йќўпј‘гЂЂиЎЁз¤є
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     EXFMTDSP01
     C*
     C                     SETOF                     11  99
     C                     MOVE *BLANK    D1ERR
     C*
      *
S1   C                     SELEC
     C*
     C*  < F1 > END
     C           *INKA     WHEQ *ON
     C                     MOVE '#END    '@STEP
     C*  <           >
-1   C                     OTHER
     C                     MOVE '#CHK1   '@STEP
E1   C                     ENDSL
      *
     C                     ENDSR
      *===============================================================
      *  з”»йќўпј‘гЂЂгѓЃг‚§гѓѓг‚Ї
      *===============================================================
     C           #CHK1     BEGSR
      *
     C                     SELEC
     C           D1SEL     WHEQ '1'
     C                     MOVEL$SEL1     D2SEL
     C                     MOVEA'000'     *IN,20
     C           D1SEL     WHEQ '2'
     C                     MOVEL$SEL2     D2SEL
     C                     MOVEA'100'     *IN,20
     C                     OTHER
     C                     MOVELER,1      D1ERR
     C                     SETON                     1199
     C                     ENDSL
      *
     C           *IN99     IFEQ *ON
     C                     MOVE '#DSP1   '@STEP
     C                     ELSE
     C                     MOVE '#DSP2   '@STEP
     C**                   Z-ADD0         D2YMD1
     C**                   Z-ADD0         D2YMD2
     C**                   Z-ADD0         D2YM1
     C**                   Z-ADD0         D2YM2
JW1  C                     Z-ADD@SYSHZ    D2YMD1
 .   C                     Z-ADD@SYSHZ    D2YMD2
 .   C                     Z-ADD@SYSYM    D2YM1
JW1  C                     Z-ADD@SYSYM    D2YM2
     C                     ENDIF
     C                     ENDSR
      *===============================================================
      *  з”»йќўпј’гЂЂиЎЁз¤є
