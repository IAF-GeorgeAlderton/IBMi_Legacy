      *
     C           *IN99     IFEQ *ON
     C                     MOVE '#DSP2   '@STEP
     C                     ELSE
     C                     Z-ADD1         RRN1
     C                     MOVE '#DSP3   '@STEP
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------
     C           #CHK21    BEGSR
      *YYYYMMDD
     C           D2YMD1    IFEQ 0
     C                     MOVELER,2      D2ERR
     C                     SETON                     2199
     C                     GOTO $CHK21
     C                     ENDIF
      *
     C                     MOVELD2YMD1    P$DATE
     C                     CALL 'DATR10'
     C                     PARM           P$DATE  8
     C                     PARM           P$RTN   1
      *
     C           P$RTN     IFEQ '1'
     C                     MOVELER,3      D2ERR
     C                     SETON                     2199
     C                     GOTO $CHK21
     C                     ENDIF
      *
      *
     C           D2YMD2    IFEQ 0
     C                     MOVELER,2      D2ERR
     C                     SETON                     2299
     C                     GOTO $CHK21
     C                     ENDIF
      *
     C                     MOVELD2YMD2    P$DATE
     C                     CALL 'DATR10'
     C                     PARM           P$DATE  8
     C                     PARM           P$RTN   1
      *
     C           P$RTN     IFEQ '1'
     C                     MOVELER,3      D2ERR
     C                     SETON                     2299
     C                     GOTO $CHK21
     C                     ENDIF
      *
     C           D2YMD1    IFGT D2YMD2
     C                     MOVELER,4      D2ERR
     C                     SETON                     212299
     C                     GOTO $CHK21
     C                     ENDIF
     C*
     C* .. SHIPPING SHORTAGE FILE                         *
     C*
     C           D2YMD1    SETLLALDPL66
     C*
     C                     EXSR #SFST1
      *
     C           ENDRRN    IFEQ 0
     C                     MOVELER,5      D2ERR
     C                     SETON                     212299
     C                     GOTO $CHK21
     C                     ENDIF
      *
     C           $CHK21    TAG
     C                     ENDSR
      *----------------------------------------------------
     C           #CHK22    BEGSR
      *YYYYMM
     C           D2YM1     IFEQ 0
     C                     MOVELER,2      D2ERR
     C                     SETON                     2199
     C                     GOTO $CHK22
     C                     ENDIF
      *
     C           D2YM1     MULT 100       D2YMD1
     C                     ADD  1         D2YMD1
     C                     MOVELD2YMD1    P$DATE
     C                     CALL 'DATR10'
     C                     PARM           P$DATE  8
     C                     PARM           P$RTN   1
      *
     C           P$RTN     IFEQ '1'
     C                     MOVELER,3      D2ERR
     C                     SETON                     2199
     C                     GOTO $CHK22
     C                     ENDIF
      *
      *
     C           D2YM1     IFEQ 0
     C                     MOVELER,2      D2ERR
     C                     SETON                     2299
     C                     GOTO $CHK22
     C                     ENDIF
      *
     C           D2YM2     MULT 100       D2YMD2
     C                     ADD  1         D2YMD2
     C                     MOVELD2YMD2    P$DATE
     C                     CALL 'DATR10'
     C                     PARM           P$DATE  8
     C                     PARM           P$RTN   1
      *
     C           P$RTN     IFEQ '1'
     C                     MOVELER,3      D2ERR
     C                     SETON                     2299
     C                     GOTO $CHK22
     C                     ENDIF
      *
     C           D2YM1     IFGT D2YM2
     C                     MOVELER,4      D2ERR
     C                     SETON                     212299
     C                     GOTO $CHK22
     C                     ENDIF
     C*
     C* .. SHIPPING SHORTAGE FILE                         *
     C*
     C           D2YMD1    SETLLALDPL66
     C*
     C                     EXSR #SFST2
      *
     C           ENDRRN    IFEQ 0
     C                     MOVELER,5      D2ERR
     C                     SETON                     212299
