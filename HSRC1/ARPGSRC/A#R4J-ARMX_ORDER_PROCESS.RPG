     H            Y.
     F** AB#R4J ********************************************
     F*  ARMX ORDER PROCESSING                             *
     F*                                                    *
     F* TCHK1  02/07/06 CREATE                             *
     F******************************************************
     FARMX    IP  F     600            DISK
     FAB#WARM O   E                    DISK
      *--------------------------------------------------------
     E                    MN1    12  12  3
     E                    MN2    12  12  3
      *
     E                    AY        600  1
     E                    DTS        14  8 0
     E                    MMS        14  2 0
     E                    DDS        14  2 0
     E                    QTY        14  9 0
      *
     E                    AO#        10  1
     E                    A21         2  1
     E                    APT        15  1
     E                    AQT         9  1
     E                    SQT         9  1
      *--------------------------------------------------------
     IARMX    AA  01
     I                                        1  12 DAT1
     I                                       13 600 DAT2
      *
     I            DS
     I                                        1  15 #PART
     I                                        1   5 AWMHN1
     I                                        6  10 AWMHN2
     I                                       11  15 AWMHN3
      *
     I            DS
     I                                        1   6 W#MNDD
     I                                        1   3 W#MN
     I                                        4   4 W#DASH
     I                                        5   6 W#DD
     I            DS
     I                                        1   80YMD
     I                                        1   40YEAR
     I                                        5   60MONTH
     I                                        7   80DAY
     I            DS
     I                                        1  140W@TIME
     I                                        1   20W@TH
     I                                        3   40W@TM
     I                                        5   60W@TS
     I                                        7  100W@DY
     I                                       11  120W@DM
     I                                       13  140W@DD
      *
      *
      * CONSTANT
     C                     CLEARAB#WARM1
     C                     Z-ADD3316      AWTOKU
     C                     Z-ADD3316      AWNONY
     C                     MOVE '0'       AWNKOJ
     C                     MOVE '00  '    AWNUKE
     C                     MOVE '000000'  AWSBAN
     C                     MOVE '1'       AWBIN#
      *
     C                     CLEARAY
     C                     MOVEADAT2      AY,1
     C* =================
     C* HEADER #1(ORDER#)
     C* =================
     C           *IN99     IFEQ *OFF
     C                     Z-ADD1         X       30
     C           'RELEASE 'SCAN DAT2      X              10
     C  N10                Z-ADD1         X
     C  N10      'Release 'SCAN DAT2      X              10
     C  N10                Z-ADD1         X
     C  N10      'release 'SCAN DAT2      X              10
     C  N10                GOTO @@END
     C*
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @@END
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @@END
     C*
     C                     MOVEL*BLANK    AO#
     C                     MOVEL*BLANK    W@ORD# 10
     C                     Z-ADDX         Y       30
     C                     Z-ADD*ZERO     Z       30
     C*
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C           AY,Y      IFEQ ','
     C                     LEAVE
     C                     END
     C                     ADD  1         Z
     C                     MOVELAY,Y      AO#,Z
     C                     ENDDO
     C                     MOVEAAO#       W@ORD#
     C*
     C                     MOVEL*ON       *IN99
     C                     GOTO @@END
     C                     END
     C* =========
     C* HEADER #2(DATE.YY)
     C* =========
     C           *IN98     IFEQ *OFF
     C                     Z-ADD1         X       30
     C           'LAST CUM'SCAN DAT2      X              10
     C  N10                Z-ADD1         X
     C  N10      'last cum'SCAN DAT2      X              10
     C  N10                Z-ADD1         X
     C  N10      'Last Cum'SCAN DAT2      X              10
     C  N10                Z-ADD1         X
     C  N10      'Last cum'SCAN DAT2      X              10
     C  N10                Z-ADD1         X
     C  N10      'last Cum'SCAN DAT2      X              10
     C  N10                GOTO @@END
     C*
     C                     MOVEL*OFF      W@ERR   1
     C                     EXSR @DATE1
     C           W@ERR     IFEQ *OFF
     C                     MOVE *ON       *IN98
     C                     END
     C                     GOTO @@END
     C                     END
     C*
     C*=======
     C* DETAIL
     C*=======
     C                     Z-ADD1         X
     C           '-'       SCAN DAT2      X              10
     C  N10                GOTO @@END
     C*
     C                     Z-ADD1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @@END
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @@END
     C* -------------
     C*   PART NUMBER
     C* -------------
     C                     MOVEL*BLANK    APT
     C                     Z-ADDX         Y       30
     C                     Z-ADD*ZERO     Z       30
     C*
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C           AY,Y      IFEQ ','
     C                     LEAVE
     C                     END
     C           AY,Y      IFEQ '-'
     C           AY,Y      OREQ ' '
     C                     ITER
     C                     END
     C                     ADD  1         Z
     C                     MOVELAY,Y      APT,Z
     C                     ENDDO
     C                     MOVEAAPT       #PART
     C* -------
     C* QTY/BOX
     C* -------
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @@END
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @@END
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @@END
     C*
     C                     MOVE *BLANKS   AQT
     C                     Z-ADDX         Y
     C                     Z-ADD*ZERO     Z
     C*
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C           AY,Y      IFEQ ','
     C                     LEAVE
     C                     END
     C           AY,Y      IFLT '0'
     C           AY,Y      ORGT '9'
     C                     ITER
     C                     END
     C                     ADD  1         Z
     C                     MOVELAY,Y      AQT,Z
     C                     ENDDO
     C*
     C                     MOVEL*ALL'0'   SQT
     C                     EXSR #QTY
     C                     MOVEASQT       AWXXXX
     C                     MOVE AWXXXX    AW5555  5
     C                     MOVELAW5555    AWSYOS
      * ---
      * QTY
      * ---
     C                     Z-ADD*ZERO     Z
     C                     CLEARQTY
     C*
     C                     DO   *HIVAL
     C*
     C                     ADD  1         Z
     C           Z         IFGT 14
     C                     LEAVE
     C                     END
     C*
     C                     MOVE *BLANKS   AQT
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                LEAVE
     C                     Z-ADDX         Y
     C                     Z-ADD*ZERO     J       20
     C*
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C           AY,Y      IFEQ ','
     C           AY,Y      OREQ ' '
     C                     LEAVE
     C                     END
     C           AY,Y      IFLT '0'
     C           AY,Y      ORGT '9'
     C                     ITER
     C                     END
     C                     ADD  1         J
     C                     MOVELAY,Y      AQT,J
     C                     ENDDO
     C*
     C                     MOVEL*ALL'0'   SQT
     C                     EXSR #QTY
     C                     MOVEASQT       AWXXXX  9
     C                     MOVELAWXXXX    QTY,Z
     C*
     C                     ENDDO
     C*
     C                     Z-ADD*ZERO     Z
     C*
     C                     DO   *HIVAL
     C*
     C                     ADD  1         Z
     C           Z         IFGT 14
     C                     LEAVE
     C                     END
     C*
     C           DTS,Z     IFNE *ZERO
     C           QTY,Z     ANDNE*ZERO
     C                     MOVELQTY,Z     AWSRYO
     C                     Z-ADDDTS,Z     AWSHDT
     C                     MOVELW@ORD#    AWORDN
     C* WRITE
     C                     WRITEAB#WARM1
     C                     MOVE '1'       PID
     C                     END
     C*
     C                     ENDDO
     C*-------------------------------------------------
     C*
     C*
     C           @@END     TAG
     C******************************************************
     C           @DATE1    BEGSR
     C******************************************************
     C                     CLEARDTS
     C                     CLEARMMS
     C                     CLEARDDS
     C*
     C                     DO
     C*
     C           ','       LOKUPAY,X                     10
     C           *IN10     IFEQ *OFF
     C                     MOVEL*ON       W@ERR
     C                     LEAVE
     C                     END
     C*
     C                     Z-ADD*ZERO     Z
     C*
     C                     DO   *HIVAL
     C*
     C                     ADD  1         Z
     C           Z         IFGT 14
     C                     LEAVE
     C                     END
     C* MMDD
     C           X         ADD  1         Y
     C                     MOVEAAY,Y      W#MNDD
     C           W#MNDD    IFEQ *BLANK
     C                     MOVEL*ON       W@ERR
     C                     LEAVE
     C                     END
     C*
     C                     Z-ADD1         I       20
     C           W#MN      LOKUPMN1,I                    11
     C           *IN11     IFEQ *OFF
     C                     Z-ADD1         I
     C           W#MN      LOKUPMN2,I                    11
     C           *IN11     IFEQ *OFF
     C                     MOVEL*ON       W@ERR
     C                     LEAVE
     C                     END
     C                     END
     C*
     C                     MOVEAW#DD      A21
     C           A21,1     IFLT '0'
     C           A21,1     ORGT '3'
     C                     MOVEL*ON       W@ERR
     C                     LEAVE
     C                     END
     C           A21,2     IFLT '0'
     C           A21,2     ORGT '9'
     C                     MOVEL*ON       W@ERR
     C                     LEAVE
     C                     END
     C*
     C                     Z-ADDI         MMS,Z
     C                     MOVELW#DD      DDS,Z
     C*
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                LEAVE
     C*
     C                     ENDDO
     C*
     C           W@ERR     IFEQ *ON
     C                     LEAVE
     C                     END
     C*
     C                     Z-ADD*ZERO     Z
     C                     Z-ADD*ZERO     Y
     C*
     C                     DO   *HIVAL
     C*
     C                     ADD  1         Z
     C           Z         IFGT 14
     C                     LEAVE
     C                     END
     C*
     C           MMS,Z     IFLT W@DM
     C           W@DY      ADD  1         W@YYYY  40
     C                     ELSE
     C                     Z-ADDW@DY      W@YYYY
     C                     END
     C                     Z-ADDW@YYYY    YEAR
     C                     Z-ADDMMS,Z     MONTH
     C                     Z-ADDDDS,Z     DAY
     C                     Z-ADDYMD       DTS,Z
     C*
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C           #QTY      BEGSR
     C******************************************************
     C                     Z-ADD9         S       20
     C                     Z-ADD9         F       20
     C                     DO   9
     C           AQT,S     IFGE '0'
     C           AQT,S     ANDLE'9'
     C                     MOVE AQT,S     SQT,F
     C           F         SUB  1         F
     C                     END
     C           S         SUB  1         S
     C                     ENDDO
      *
     C                     ENDSR
      ******************************************************
     C           *INZSR    BEGSR
      ******************************************************
      *
     C                     TIME           W@TIME
      *
     C           *ENTRY    PLIST
     C                     PARM           PID     1
      *
     C                     ENDSR
