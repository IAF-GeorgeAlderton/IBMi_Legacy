     H            Y.
     F** CHKR57D ***************************************************************
     F*  PROGRAM    : CHECK HONDA PLANT VS SHIP MASTER ERROR                   *
     F*  WRITTEN    : 2022.12.19                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#PLHN2IF  E           K        DISK
     FGADPL11DIF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     E                    MSG     1   2 35
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        7  100@YEAR
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C                     EXSR #PROC1
      *
     C                     EXSR #PROC2
      * TOTAL
     C           SEQ#      IFEQ 0
     C                     EXCPT@HDR
     C                     EXCPT@TTL1
     C                     ELSE
     C                     MOVE '*'       $RTN
     C                     EXCPT@TTL2
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  CHECK SHIPPING MASTER                             *
      *----------------------------------------------------*
     C           #PROC1    BEGSR
      *
     C           *LOVAL    SETLLAB#PLHN2
      *
     C                     DO   *HIVAL
     C                     READ AB#PLHN2                 98
     C   98                LEAVE
      * IGNORE
     C           AHSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * CHECK
     C                     MOVE *OFF      *IN97
     C           AHNONY    SETLLGADPL11D
     C                     DO   *HIVAL
     C           AHNONY    READEGADPL11D                 97
     C   97                LEAVE
      *
     C           B5SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           AHTOKU    IFEQ B5TOKU
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           *IN97     IFEQ *ON
     C                     MOVELMSG,1     XMSG
     C                     EXSR #PRNT1
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  CHECK PLANT MASTER                                *
      *----------------------------------------------------*
     C           #PROC2    BEGSR
      *
     C           *LOVAL    SETLLGADPL11D
      *
     C                     DO   *HIVAL
     C                     READ GADPL11D                 98
     C   98                LEAVE
      * IGNORE
     C           B5SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * SELECT HONDA
     C           B5TOKU    IFNE 0294
     C           B5TOKU    ANDNE0295
     C           B5TOKU    ANDNE0296
     C           B5TOKU    ANDNE0390
     C           B5TOKU    ANDNE0391
     C           B5TOKU    ANDNE0400
     C           B5TOKU    ANDNE1602
     C           B5TOKU    ANDNE3135
     C                     ITER
     C                     ENDIF
      * CHECK
     C                     MOVE *OFF      *IN96
     C           B5NONY    SETLLAB#PLHN2
     C                     DO   *HIVAL
     C           B5NONY    READEAB#PLHN2                 96
     C   96                LEAVE
      *
     C           AHSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           B5TOKU    IFEQ AHTOKU
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           *IN96     IFEQ *ON
     C                     MOVELMSG,2     XMSG
     C                     EXSR #PRNT2
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRNT1    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL1
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRNT2    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL2
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     MOVE ' '       $RTN
     C                     MOVE *BLANK    XMSG   35
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** SHIPPING VS PLANT'
     O                                   60 ' MASTER CHECK LIST *'
     O                                   80 '* (GADPP11/AB#PPHN) '
     O                                   90 'DATE'
     O                         TODAY    101 '    .  .  '
     O                         NOW      111 '  :  :  '
     O                                  115 'P.'
     O                         PAGE  Z  119
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   10 'NONY'
     O                                   16 'DOCK'
     O                                   31 'ERROR MESSAGE'
     O        E 1              @DTL1
     O                         SEQ#  1 +000
     O                         AHNONY  +001
     O                         AHTOKU  +002
     O                         XMSG    +002
      *
     O        E 1              @DTL2
     O                         SEQ#  1 +000
     O                         B5NONY  +001
     O                         B5NUKE  +002
     O                         XMSG    +002
      *
     O        E 1              @TTL1
     O                                 +000 ' ** THERE IS NO ERRO'
     O                                 +000 'R FOR THIS REPORT **'
      *
     O        E 1              @TTL2
     O                                 +000 ' ** TOTAL ERROR'
     O                         SEQ#  1 +001
     O                                 +001 '**'
** MSG(35A) .......2.........3....>
SHIP MASTER NOT FOTD ! (GADPP11)      01
PLANT MASTER NOT FOUND ! (AB#PPHN)    02
