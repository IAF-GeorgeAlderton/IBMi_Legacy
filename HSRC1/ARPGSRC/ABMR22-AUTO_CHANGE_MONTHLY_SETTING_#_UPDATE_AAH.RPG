     C           KEYB5     KLIST
     C                     KFLD           L6KCD1
     C                     KFLD           L6KCD2
     C                     MOVEL'0'       GET     1
     C           KEYB5     SETLLABMPPB51
     C           KEYB5     READEABMPPB51                 94
     C           *IN94     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           AHSKJY    IFEQ 'D'
     C           AHSKHZ    ANDLE*DATE
     C                     ELSE
     C                     SELEC
     C           AHFUGO    WHEQ '1'
     C           W@HAKD    IFLT AHHTSU
     C                     Z-ADDAHADJU    WKADJU
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           AHFUGO    WHEQ '2'
     C           W@HAKD    IFGT AHHTSU
     C                     Z-ADDAHADJU    WKADJU
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           AHFUGO    WHEQ '3'
     C           W@HAKD    IFEQ AHHTSU
     C                     Z-ADDAHADJU    WKADJU
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           AHFUGO    WHEQ '4'
     C           W@HAKD    IFLE AHHTSU
     C                     Z-ADDAHADJU    WKADJU
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           AHFUGO    WHEQ '5'
     C           W@HAKD    IFGE AHHTSU
     C                     Z-ADDAHADJU    WKADJU
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           AHFUGO    WHEQ '6'
     C           W@HAKD    IFNE AHHTSU
     C                     Z-ADDAHADJU    WKADJU
     C                     MOVEL'1'       GET
     C                     ENDIF
     C                     ENDSL
     C                     ENDIF
     C           KEYB5     READEABMPPB51                 94
     C                     ENDDO
      *
     CSR         ESB711    ENDSR
      *---------------------------*
      * A-PICS 以外　調整枚数
      *---------------------------*
     CSR         #SB720    BEGSR
      *
     C                     Z-ADD0         SA@     30
      *今回ー前回　枚数
     C           WMAIS     SUB  SVKMAX    SA      50
     C                     Z-ADDSA        SA@
     C                     MULT -1        SA@
      *今回/前回
     C                     Z-ADD0         RITU    72
     C           SVKMAX    IFNE 0
     C           WMAIS     DIV  SVKMAX    RITU
     C                     ENDIF
      *
     C                     MULT 100       RITU
     C           RITU      IFGE 100
     C                     SUB  100       RITU
     C                     ELSE
     C           100       SUB  RITU      RITU
     C                     ENDIF
      *
     C           RITU      IFLT WKADJU
     C           WMAIS     ORLE 12
     C                     Z-ADDSA@       L6AUAJ
     C                     ADD  L6AUAJ    L6AMXH
     C                     ADD  L6AUAJ    L6MAXH
     C                     Z-ADD0         WMAIS
     C                     CALL 'ABCR07'  ACALL
     C                     ENDIF
      *
     CSR         ESB720    ENDSR
      *---------------------------*
      *エラーファイル           *
      *---------------------------*
     CSR         #SB800    BEGSR
      *
     C                     MOVELL6SHN1    ABJHN1
     C                     MOVELL6SHN2    ABJHN2
     C                     MOVELL6SHN3    ABJHN3
     C                     MOVELL6ATK1    ABATK1
     C                     MOVELL6ATK2    ABATK2
     C                     MOVELL6ATK3    ABATK3
     C                     MOVELL6ATK4    ABATK4
     C                     MOVELL6KCD1    ABKCD1
     C                     MOVELL6KCD2    ABKCD2
     C                     WRITEABMWP301
      *
     CSR         ESB800    ENDSR
      *---------------------------*
      *結果                     *
      *---------------------------*
     CSR         #SB810    BEGSR
      *
     C                     MOVELL6KCD1    @BKCD1
     C                     MOVELL6KCD2    @BKCD2
     C                     MOVELL6SHN1    @BJHN1
     C                     MOVELL6SHN2    @BJHN2
     C                     MOVELL6SHN3    @BJHN3
     C                     MOVELL6ATOB    @BATOB
     C                     MOVELL6ATOK    @BATOK
     C                     MOVELL6ATK1    @BATK1
     C                     MOVELL6ATK2    @BATK2
     C                     MOVELL6ATK3    @BATK3
     C                     MOVELL6ATK4    @BATK4
     C                     Z-ADDL6KTSU    @AKTSU
     C                     Z-ADDL6KMAX    @AKMAX
     C                     Z-ADDL6MAXH    @AMAXH
     C                     Z-ADDL6LOTO    @AKLOT
     C                     Z-ADDL6PADJ    @APADJ
     C                     Z-ADDL6AUAJ    @AAUAJ
     C                     Z-ADDL6DUPH    @ADUPH
     C                     Z-ADDL6OTHH    @AOTHH
     C                     Z-ADDWKSRYO    @ANSRY
      *
     C                     Z-ADD0         @UMAXD
     C                     Z-ADD0         @UMAX
     C           APICS     IFEQ '1'
     C                     Z-ADDP9NOHZ    @UMAXD
     C                     Z-ADDP9HAKO    @UMAX
     C                     ENDIF
     C                     Z-ADDW@HAKD    @NBOXD
     C                     MOVELAPICS     @APICS
     C           @AKMAX    SUB  @BKMAX    @SA
     C                     Z-ADD0         @SA2
     C           @AKMAX    SUB  @AAUAJ    R123    30
     C           @BKMAX    IFNE 0
     C           R123      DIV  @BKMAX    @SA2
     C                     ENDIF
     C                     MOVEL' '       @AKERR
     C           *IN99     IFEQ '1'
     C                     MOVEL'*'       @AKERR
     C                     ENDIF
      *
     C                     WRITEABMWP311
      *
     CSR         ESB810    ENDSR
