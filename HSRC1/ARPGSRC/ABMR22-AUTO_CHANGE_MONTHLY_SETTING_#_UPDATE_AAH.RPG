     C           WKSRYO    DIV  20        @3KTSU  90
     C           W2OMIT    IFEQ '0'
     C                     SELEC
     C           @3KTSU    WHLT L6KTSU
     C                     MOVEL'51'      L6STI1
     C           @3KTSU    WHGT L6KTSU
     C                     MOVEL'52'      L6STI1
