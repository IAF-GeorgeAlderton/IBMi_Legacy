     H            Y.
     F** EDIR81 ********************************************
     F*  PROGRAM: SET DELIVERY CODE IN EALFL(4A)           *
     F*  WRITTEN: JW (SRA) 2024.02.22                      *
     F*----------------------------------------------------*
     FAB#EL40SUF  E           K        DISK
      *--------------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           $DATE   8
      * GET YESTERDAY
     C                     MOVEL$DATE     $DT8
     C                     MOVE '-'       $SIGN
     C                     MOVE '0001'    $DAYS
     C                     MOVE 'N'       $IAF
     C                     CALL 'UTLR10'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN    1
     C                     MOVEL$TGT8     @YESTD  80
      *
     C           @YESTD    SETLLAB#EL40S
     C                     DO   *HIVAL
     C                     READ AB#EL40S                 99
     C   99                LEAVE
      *
     C                     MOVELENONY     EALFL
     C                     EXSR #ADJ
      *
     C                     UPDATAB#E40S1
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      ******************************
      * SET ACTUAL DELIVERY CODE
      ******************************
     C           #ADJ      BEGSR
      *
     C                     MOVELEPRTNR    LTR6    6
     C                     SELEC
     C           LTR6      WHEQ 'ASI   '                   ARVIN SANGO
     C                     EXSR #ASI
     C           LTR6      WHEQ 'SUBARU'                   SAI
     C                     EXSR #SAI
     C           LTR6      WHEQ 'SRG GL'                   SRG
     C                     EXSR #SRG
     C           LTR6      WHEQ 'VASCOR'                   VASCOR
     C                     EXSR #VAS
     C           LTR6      WHEQ 'AISIN-'                   AISIN
     C                     EXSR #AIS
     C           LTR6      WHEQ 'FUTABA'                   FUTABA
     C                     EXSR #FUT
     C           LTR6      WHEQ 'TMMNA '                   TMMNA
     C                     MOVEL'3411'    EALFL
     C                     OTHER
     C                     ENDSL
      *
     C                     ENDSR
      *=============================
      * #ASI
      *=============================
     C           #ASI      BEGSR
      *
     C                     SELEC
     C           ENUKE     WHEQ 'N1  '
     C                     MOVEL'0878'    EALFL
     C           ENUKE     WHEQ 'N2  '
     C                     MOVEL'0873'    EALFL
     C           ENUKE     WHEQ 'W1  '
     C                     MOVEL'0878'    EALFL
     C           ENUKE     WHEQ 'M1  '
     C                     MOVEL'0881'    EALFL
     C           ENUKE     WHEQ 'SP1 '
     C                     MOVEL'0876'    EALFL
     C           ENUKE     WHEQ 'TX  '
     C                     MOVEL'0879'    EALFL
     C           ENUKE     WHEQ '1   '
     C                     MOVEL'0880'    EALFL
     C                     ENDSL
      *
     C                     ENDSR
      *=============================
      * #SAI
      *=============================
     C           #SAI      BEGSR
      *
     C                     SELEC
     C           ECUNM     WHEQ '    '
     C                     MOVEL'3611'    EALFL
     C           ESTAD     WHEQ 'SAP '
     C           ESUB#     ANDEQ'D73901'
     C                     MOVEL'3618'    EALFL
     C                     OTHER
     C                     MOVEL'3617'    EALFL
     C                     ENDSL
      *
     C                     ENDSR
      *=============================
      * #SRG
      *=============================
     C           #SRG      BEGSR
      *
     C                     SELEC
     C           EN1ST     WHEQ 'SRG611'
     C                     MOVEL'0560'    EALFL
     C           EN1ST     WHEQ 'SRG110'
     C                     MOVEL'2727'    EALFL
     C           EN1ST     WHEQ 'SRG607'
     C                     MOVEL'2757'    EALFL
     C           EN1ST     WHEQ 'SRG617'
     C                     MOVEL'2737'    EALFL
     C           EN1ST     WHEQ 'SRG107'
     C                     MOVEL'3222'    EALFL
     C           EN1ST     WHEQ 'SRG605'
     C                     MOVEL'0543'    EALFL
     C           EN1ST     WHEQ 'SRG162'
     C                     MOVEL'????'    EALFL
     C           EN1ST     WHEQ 'SRG604'
     C                     MOVEL'????'    EALFL
     C                     ENDSL
      *
     C                     ENDSR
      *=============================
      * #VAS
      *=============================
     C           #VAS      BEGSR
      *
     C                     SELEC
     C           ENUKE     WHEQ 'H3  '
     C                     MOVEL'3953'    EALFL
     C                     ENDSL
      *
     C                     ENDSR
      *=============================
      * #AIS   AISIN
      *=============================
     C           #AIS      BEGSR
      *
     C                     MOVELEPRTNR    LTR8    8
     C                     SELEC
     C           LTR8      WHEQ 'AISIN-UP'
     C                     MOVEL'0966'    EALFL
     C           LTR8      WHEQ 'AISIN-DP'
     C                     MOVEL'0777'    EALFL
     C           LTR8      WHEQ 'AISIN-TP'
     C                     MOVEL'0479'    EALFL
     C           LTR8      WHEQ 'AISIN-MP'
     C                     MOVEL'0987'    EALFL
     C                     ENDSL
      *
     C                     ENDSR
      *=============================
      * #FUT
      *=============================
     C           #FUT      BEGSR
      *
     C                     SELEC
     C           EN1ST     WHEQ 'FIT'
     C                     MOVEL'0578'    EALFL
     C                     ENDSL
      *
     C                     ENDSR
