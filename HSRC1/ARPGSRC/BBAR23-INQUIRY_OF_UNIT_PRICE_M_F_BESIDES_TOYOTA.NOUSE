     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,1     ERR
     C                     GOTO STP1
     C                     END
      *
     C                     MOVE *BLANK    SHIN
     C                     MOVELHIN1      SHIN1
     C                     MOVELHIN2      SHIN2
     C                     MOVELHIN3      SHIN3
