     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,6     ERR
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C                     MOVEA'0000'    *IN,20
     C           TKCD      IFNE 0
     C                     MOVEA'1000'    *IN,20
     C                     ELSE
     C           HIN1      IFNE *BLANK
     C           HIN2      IFEQ *BLANK
     C           HIN3      ANDEQ*BLANK
     C                     MOVEA'0100'    *IN,20
     C                     END
     C                     END
      *
     C           HIN1      IFNE *BLANK
     C           HIN2      ANDNE*BLANK
     C           HIN3      IFEQ *BLANK
     C                     MOVEA'0010'    *IN,20
     C                     END
     C                     END
      *
