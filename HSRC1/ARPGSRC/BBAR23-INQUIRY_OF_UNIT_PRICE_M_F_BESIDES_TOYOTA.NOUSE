     C                     DO   *HIVAL
     C           KEY6      READEBBCPL021                 40
     C   40                GOTO STP3
      *
     C           *IN,40    IFEQ '0'
     C           BCSKJY    IFEQ 'D'
     C           BCSKHZ    ANDLE*DATE
     C                     GOTO @END3
     C                     END
      *
     C*          *IN20     IFEQ '1'
     C*          *IN23     OREQ '1'
     C*          BCSH12    IFNE HIN12
     C*                    GOTO @END3
     C*                    END
     C*                    END
      *
     C*          *IN22     IFEQ '1'
     C*          BCSH10    IFNE HIN10
     C*                    GOTO @END3
     C*                    END
     C*                    END
      *
     C                     ADD  1         NO
     C                     Z-ADDBCKTNK    XTANK
     C                     Z-ADDBCKSHZ    XKSHZ
     C                     Z-ADDBCKEHZ    XKEHZ
      *
     C*  ﾍﾍｭcﾆﾞ
     C                     Z-ADDBCKTNK    @KTNK
     C                     Z-ADDBCKSHZ    @KSHZ
     C                     Z-ADDBCKEHZ    @KEHZ
     C                     Z-ADDBCZTNK    @ZTNK
     C                     Z-ADDBCZSHZ    @ZSHZ
     C                     Z-ADDBCZEHZ    @ZEHZ
     C                     ADD  1         RRN3
     C                     ADD  1         CNTR3
     C                     MOVEL'*'       ZSW3
     C                     WRITEDSP3R
      *
     C* MAX mﾞｰj <11>
     C           CNTR3     CABEQ11        STP3
     C                     END
     C           @END3     TAG
     C  N40                END
      *
     C           STP3      TAG
     C                     Z-ADD0         XNO
     C           STP3X     TAG
      *
     C*  ﾅﾎﾞﾎｦbﾓ ﾛﾃｰnﾞ NO ﾈｮn
     C                     Z-ADD1         RCDNBX
     C                     MOVEA'1'       *IN,91
     C                     WRITEDSP3C
     C                     MOVEA'0'       *IN,91
     C                     EXFMTDSP3X
      *
     C                     MOVEA'0'       *IN,01
     C                     MOVEA'0'       *IN,44
     C                     MOVEA'0'       *IN,88
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    ERR
      *
     C           *INKA     IFEQ '1'
     C                     MOVEL'1'       *INLR
     C                     RETRN
     C                     END
      *
     C           *INKC     IFEQ '1'
     C                     MOVEL'*'       WWKBN
     C                     GOTO @OWARI
     C                     END
      *
     C*  ﾜｰﾓ aｮﾎﾟ
     C           *IN,77    IFEQ '1'
     C                     Z-ADD0         CNTR3
     C                     EXSR ROLUP3
     C                     Z-ADDRRN3      RCDNBX
      *
     C           *IN,44    IFEQ '1'
     C                     MOVEA'1'       *IN,99
     C                     END
     C                     GOTO STP3
     C                     END
      *
     C           XNO       IFEQ 0
     C                     MOVEL'*'       WWKBN
     C                     GOTO @OWARI
     C                     END
      *
     C*  ﾅﾎﾞﾎｦbﾓ ﾛﾃｰnﾞ NO ﾈｮn
     C                     Z-ADD1         RCDNBX
      *
     C           XNO       IFNE 0
     C                     MOVE *BLANK    FLG     1
     C                     Z-ADDRRN3      XXRRN3  50
      *
     C                     DO   *HIVAL    RRN@@3  50
     C           RRN@@3    CHAINDSP3R                42
     C           *IN,42    IFEQ '0'
     C           XNO       IFEQ RRN@@3
      *
     C                     Z-ADD@KTNK     KTNK
     C                     Z-ADD@KSHZ     KSHZ
     C                     Z-ADD@KEHZ     KEHZ
     C                     Z-ADD@ZTNK     ZTNK
     C                     Z-ADD@ZSHZ     ZSHZ
     C                     Z-ADD@ZEHZ     ZEHZ
      *
     C                     EXSR #SET4
     C                     UPDATDSP3R
     C                     MOVEL'*'       FLG
      *
     C                     END
     C                     END
     C  N42                END
      *
     C           FLG       IFEQ *BLANK
     C                     MOVEA'1'       *IN,01
     C                     MOVEA'1'       *IN,88
     C                     MOVELMSG,5     ERR
     C                     GOTO STP3X
     C                     END
     C                     END
      *
     C                     Z-ADDXXRRN3    RRN3
     C                     MOVEA'1'       *IN,44
     C                     GOTO STP3
      *
     C           @OWARI    ENDSR
      *
     C******************************************************
     C           ROLUP3    BEGSR                           *
     C******************************************************
     C                     MOVE *BLANK    ZSW3
     C                     Z-ADD0         XTANK
     C                     Z-ADD0         XKSHZ
     C                     Z-ADD0         XKEHZ
      *
     C                     DO   *HIVAL
     C           KEY6      READEBBCPL021                 40
     C   40                GOTO @ROLE3
      *
     C           *IN,40    IFEQ '0'
     C           BCSKJY    IFEQ 'D'
     C           BCSKHZ    ANDLE*DATE
     C                     GOTO @EXIT3
     C                     END
      *
     C*          *IN20     IFEQ '1'
     C*          *IN23     OREQ '1'
     C*          BCSH12    IFNE HIN12
     C*                    GOTO @EXIT3
     C*                    END
     C*                    END
      *
     C*          *IN22     IFEQ '1'
     C*          BCSH10    IFNE HIN10
     C*                    GOTO @EXIT3
     C*                    END
     C*                    END
      *
     C                     ADD  1         NO
     C                     Z-ADDBCKTNK    XTANK
     C                     Z-ADDBCKSHZ    XKSHZ
     C                     Z-ADDBCKEHZ    XKEHZ
      *
     C*  ﾍﾍｭcﾆﾞ
     C                     Z-ADDBCKTNK    @KTNK
     C                     Z-ADDBCKSHZ    @KSHZ
     C                     Z-ADDBCKEHZ    @KEHZ
     C                     Z-ADDBCZTNK    @ZTNK
     C                     Z-ADDBCZSHZ    @ZSHZ
     C                     Z-ADDBCZEHZ    @ZEHZ
     C                     ADD  1         RRN3
     C                     ADD  1         CNTR3
     C                     MOVEL'*'       ZSW3
     C                     WRITEDSP3R
      *
     C           CNTR3     CABEQ11        @ROLE3
     C                     END
     C           @EXIT3    TAG
     C  N40                END
      *
     C           @ROLE3    TAG
      *
     C*  ﾃﾛbﾆﾞｭc mﾞｰj oﾆ
     C           ZSW3      IFEQ *BLANK
     C                     MOVEA'1'       *IN,44
     C                     END
      *
     C                     ENDSR
      *
     C******************************************************
     C           #SET4     BEGSR                           *
     C******************************************************
     C           STP4      TAG
     C                     EXFMTBBAPW232
      *
     C           *INKC     IFEQ '1'
     C                     MOVEA'1'       *IN,42
     C                     Z-ADD0         XNO
     C                     GOTO #SET4E
     C                     END
      *
     C           #SET4E    ENDSR
      *
**  MSG (ERROR MESSAGE )
E-01 INPUT INTRAL COMPANY PART NO.
E-02 EXIST DATA IN TOYOTA SYS VOL PROD UNIT PRC JDG USER M/F
E-03 THERE ISN'T APPLICABLE DATA
E-04 INPUT NO.
E-05 NO. ISN'T RIGHT
E-06 EXIST DATA IN TOYOTA SYSTEM SUPPLY PART UNIT PRICE M/F
