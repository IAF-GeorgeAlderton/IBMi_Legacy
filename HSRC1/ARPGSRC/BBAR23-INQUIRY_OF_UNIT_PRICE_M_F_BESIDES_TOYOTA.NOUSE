     C                     END
      *
     C           SHIN3     IFNE *BLANK
     C                     MOVEL'-'       SHINB
     C                     END
      *
     C           TKCD      IFNE 0
     C           TKCD      CHAINBBEPL011             10
     C           *IN,10    IFEQ '0'
