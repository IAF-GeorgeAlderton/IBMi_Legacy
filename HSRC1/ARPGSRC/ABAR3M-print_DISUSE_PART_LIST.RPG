     H            Y.
     F** ABAR3M *********************************************
     F*  PRINT DISUSE PART LIST                             *
     F*  J.WATANABE  1/13/2017                              *
     F*                                                     *
     F*******************************************************
     FABAPW3M CF  E                    WORKSTN
     FFCEPL01 IF  E           K        DISK
     FQPRINT  O   F     132     OA     PRINTER
     ********************************************************
     I* SYSTEM DATE
     I            DS
     I                                        1  120WTIME
     I                                        1   60SYTM1
     I                                        7  120SYDT1
     I* PART NUMBER OF ABFPP10
     I            DS
     I                                        1  12 FBIPAR
     I                                        1   5 #PAR1
     I                                        6  10 #PAR2
     I                                       11  12 #PAR3
     I* CHANGE DATE OF PART MASTER
     I            DS
     I                                        1   80CDATE
     I                                        1   40CDAT1
     I                                        5   60CDAT2
     I                                        7   80CDAT3
     I                                        3   80CDAT
     I            DS
     I                                        1   80WYMD
     I                                        3   80WYMD6
     I                                        1   40WYY
     I                                        5   60WMM
     I                                        7   80WDD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ***********************************************************
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C                     MOVE '1'       P@END
      *
     C           *INKE     WHEQ *ON
     C                     MOVE *ON       *IN10
     C                     WRITEDSP01
     C                     EXSR #PROC
     C                     MOVEL'99'      W@ID
      *
     C                     ENDSL
      *
     C                     ENDSR
      *-------------------------------------------------------
     C           #PROC     BEGSR
      *
     C           *IN80     DOWEQ*OFF
     C                     READ FCEPL01                  80
     C           *IN80     IFEQ *OFF
      * SELECT DISUSE PART
     C           A2GSKD    IFEQ 'D'
     C                     EXSR #OUT
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-------------------------------------------------------
     C           #OUT      BEGSR
     C*
     C                     Z-ADDFBQTY2    NET,I
     C                     MOVEAFBQTCD    CD,I
     C                     Z-ADDFBCSDT    DAS,I
     C                     Z-ADDFBCEDT    DAE,I
      *
     C                     ENDSR
     C*****************************************************************
     C*  PRINT
     C*********************************************************
     C           #PRINT    BEGSR
     C*
     C           *IN98     IFEQ *OFF
     C           *INOA     OREQ *ON
     C                     EXCPT@HED1
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
     C           *IN97     IFEQ *OFF
     C   OA                EXCPT@HED1
     C           I         SUB  1         Z       20
     C   OA                EXCPT@HED1
     C                     EXCPT@DTL1
     C                     MOVE *ON       *IN97
     C                     ENDIF
     C                     Z-ADDI         Z
     C   OA                EXCPT@HED1
     C                     EXCPT@DTL1
      *
     C                     ENDSR
     C********************************************************
     OQPRINT  E    2           @HED1
     O                                   50 '** DISUSE PART LIST **  '
     O                                   89 'DATE'
     O                         SYDT1 Y   98
     O                                  104 'PAGE'
     O                         PAGE1 Z  108
     O        E    3           @HED1
     O                                   89 'TIME'
     O                         SYTM1     98 '  :  :  '
     O        E    4           @HED1
     O                                   16 'SCHEDULE ISSUE'
     O                                   34 'PART NUMBER'
     O                                   55 'DELIVERY CODE'
     O                                   62 'CODE'
     O                                   75 'START DATE'
     O                                   87 'END DATE'
     O                                  104 'CUM QUANTITY'
     O                                  121 'QUANTITY'
     O                                  130 'BOXES'
     O        E 1              @DTL1
     O                                   14 '0 '
