     C                     SETOF                     20
     C           KEY2      READEAEBPL111                 20
     C           *IN20     IFEQ '0'
     C           AGNGEK    IFNE 0
      *
     C                     Z-ADD0         $KBMN   40
     C                     MOVE *BLANK    $UKER   4
     C                     Z-ADDAGKBMN    @KBMN
     C                     MOVE AGUKER    @UKER
      *
     C           PKBMK     IFEQ 'P'
     C                     Z-ADD@KBMN     $KBMN
     C                     MOVE @UKER     $UKER
     C                     Z-ADD0111      @KBMN
     C                     MOVE '01  '    @UKER
     C                     ELSE
      *
     C                     SETOF                     21
     C           AGKBMN    LOKUPTB1                      21
     C           *IN21     IFEQ '0'
     C                     Z-ADD@KBMN     $KBMN
     C                     MOVE @UKER     $UKER
     C                     Z-ADD0111      @KBMN
     C                     MOVE '01  '    @UKER
     C                     END
     C                     END
      *
