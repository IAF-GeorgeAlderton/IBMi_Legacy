     H            Y.
     F** EDSR21 ********************************************
     F*  PROGRAM: UTILITY -  SAVE ABAEP10/11               *
     F*  WRITTEN: JW (SRA)                                 *
     F*           03/25/2016                               *
     F*----------------------------------------------------*
     FABAEP10 IF  E                    DISK
     FABAEP11 IF  E                    DISK
     FABAEP10SO   E                    DISK
     FABAEP11SO   E                    DISK
      *--------------------------------------------------------
     I            DS
     I                                        1  140D#TIME
     I                                        1   60NOW
     I                                        7  140TODAY
      *--------------------------------------------------------
      * INITIAL SETTING
     C                     TIME           D#TIME
      * SAVE ABAEP10 --------------------------------------
     C                     MOVE *OFF      *IN99
     C           *IN99     DOWEQ*OFF
     C                     READ ABAEP10                  99
     C           *IN99     IFEQ *OFF
     C                     Z-ADDTODAY     ABCRDT
     C                     Z-ADDNOW       ABCRTM
     C                     WRITEABAE10S1
     C                     ENDIF
     C                     ENDDO
      *
      * SAVE ABAEP11 --------------------------------------
     C                     MOVE *OFF      *IN99
     C           *IN99     DOWEQ*OFF
     C                     READ ABAEP11                  99
     C           *IN99     IFEQ *OFF
     C                     Z-ADDTODAY     AECRDT
     C                     Z-ADDNOW       AECRTM
     C                     WRITEAEAE11S1
     C                     ENDIF
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
