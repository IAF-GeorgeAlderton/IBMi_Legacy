     H            Y.
     FABWP455LUF  E           K        DISK
     F****************************************************
     C                     MOVEL*BLANK    WWTOKU  4
     C                     MOVEL*BLANK    WWNONY  4
     C                     MOVEL*BLANK    WWMHIN 20
     C                     MOVEL*BLANK    W@SHIN 12
     C                     MOVEL*BLANK    WWNUKE  4
     C*
     C           *LOVAL    SETLLABWP455R
     C*
     C                     DO   *HIVAL
     C                     READ ABWP455R                 99
     C   99                LEAVE
     C*
     C           WWTOKU    IFEQ *BLANK
     C           WWNONY    ANDEQ*BLANK
     C           WWMHIN    ANDEQ*BLANK
     C           W@SHIN    ANDEQ*BLANK
     C                     MOVELWTOKU     WWTOKU  4
     C                     MOVELWNONY     WWNONY  4
     C                     MOVELWMHIN     WWMHIN 20
     C                     MOVEL@SHIN     W@SHIN 12
     C                     MOVELWNUKE     WWNUKE  4
     C                     ITER
     C                     END
     C*
     C           WWTOKU    IFEQ WTOKU
     C           WWNONY    ANDEQWNONY
     C           WWMHIN    ANDEQWMHIN
     C           W@SHIN    ANDEQ@SHIN
     C           WNUKE     IFNE WWNUKE
     C                     MOVEL'D'       WSDLF
     C                     UPDATABWP455R
     C                     END
     C                     ELSE
     C                     MOVELWTOKU     WWTOKU
     C                     MOVELWNONY     WWNONY
     C                     MOVELWMHIN     WWMHIN
     C                     MOVEL@SHIN     W@SHIN
     C                     MOVELWNUKE     WWNUKE
     C                     END
     C*
     C                     ENDDO
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
