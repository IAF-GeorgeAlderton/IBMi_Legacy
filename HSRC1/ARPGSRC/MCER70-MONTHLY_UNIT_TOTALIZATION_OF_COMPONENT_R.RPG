      *
     C*----------------------------------*
     C*  ..社内かんばん切替マスター..  *
     C*----------------------------------*
     C                     SETOF                     10
     C                     Z-ADD0         HBM
     C                     MOVE *BLANK    HKB
     C           KEY1      CHAINAAMPL111             10
     C           *IN10     IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
      *
     C           *IN10     IFEQ '0'
     C                     Z-ADD1         A       20
     C                     Z-ADD0         B       20
     C           1         DO   15        A
     C                     MOVELNUKH,A    WUKH    80
     C           WUKH      IFGT *DATE
     C           OKBM,A    IFNE 0
     C                     ADD  1         B
     C                     Z-ADDOKBM,A    HBM,B
     C                     MOVELOKBN,A    HKB,B
     C                     END
     C                     ELSE
      *
     C           NKBM,A    IFNE 0
     C                     ADD  1         B
     C                     Z-ADDNKBM,A    HBM,B
     C                     MOVELNKBN,A    HKB,B
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C                     SETOF                     35
     C           KBN       LOKUPHKB                      35
     C           *IN35     IFEQ '0'
     C                     GOTO END
     C                     END
      *
     C                     SETOF                     10
     C                     Z-ADD1         A
     C           HBM,1     LOKUPTB1,A                    10
     C           *IN10     IFEQ '1'
     C                     MOVE TB2,A     WTEKB   1
     C                     ELSE
     C                     MOVE '9'       WTEKB
     C                     END
