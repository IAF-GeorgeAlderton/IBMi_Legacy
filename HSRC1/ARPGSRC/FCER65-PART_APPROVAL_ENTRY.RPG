     FFCEPW65 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FFCEPL60 UF  E           K        DISK                      A
     FGADPL11 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FFAAPL05 IF  E           K        DISK
     FFAAPL04 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
      *------------------------------------------------------------
     E                    CMD     1   3 78
     E                    MSG     1   4 78
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C           W@ID      CASEQ'03'      #SCRN3
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#FCE     KLIST
     C                     KFLD           D@SHN1
     C                     KFLD           D@SHN2
     C                     KFLD           D@SHN3
     C           K#FC6     KLIST
     C                     KFLD           D@SHN1
     C                     KFLD           D@SHN2
     C                     KFLD           D@SHN3
     C                     KFLD           K@CUST  40
     C           K#FA1     KLIST
     C                     KFLD           D@MHN1
     C                     KFLD           D@MHN2
     C                     KFLD           D@MHN3
     C           K#FA2     KLIST
     C                     KFLD           B7SHN1
     C                     KFLD           B7SHN2
     C                     KFLD           B7SHN3
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#FC61    KLIST
     C                     KFLD           T@SHN1
     C                     KFLD           T@SHN2
     C                     KFLD           T@SHN3
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @@RRN   40
     C                     MOVEL'01'      W@ID    2
     C                     MOVE '3411'    D@CUST
      *
     C                     ENDSR
      *------------------------------------------------------
      *  1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
      * END
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
      * INQUIRY
     C           *INKI     WHEQ *ON
     C                     MOVE D@SHN1    T@SHN1
     C                     MOVE D@SHN2    T@SHN2
     C                     MOVE D@SHN3    T@SHN3
     C                     EXSR #SET3
     C                     MOVE '03'      W@ID
     C                     OTHER
      * CHECK & NEXT
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET2
     C                     MOVE '02'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
      *
     C           D@CUST    IFEQ *BLANK
     C                     SETON                     6199
     C                     MOVE MSG,1     D@MSG
     C                     ELSE
     C                     MOVE D@CUST    K@CUST
     C           K@CUST    CHAINGADPL11              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     MOVE MSG,1     D@MSG
     C                     ENDIF
     C                     ENDIF
      *
     C           D@MHN1    IFEQ *BLANK
     C           D@SHN1    ANDEQ*BLANK
     C  N99                MOVE MSG,2     D@MSG
     C                     SETON                     626399
     C                     ENDIF
      * IAF PART
     C           D@SHN1    IFNE *BLANK
     C           K#FCE     CHAINFCEPL01              90
     C           *IN90     IFEQ *ON
     C  N99                MOVE MSG,2     D@MSG
     C                     SETON                     6299
     C                     ELSE
     C           A2GSKD    IFNE *BLANK
     C  N99                MOVE MSG,3     D@MSG
     C                     SETON                     6299
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      * CUSTOMER PART
     C           D@MHN1    IFNE *BLANK
     C                     MOVE *OFF      *IN91
     C           K#FA1     SETLLFAAPL05
     C           *IN90     DOUEQ*ON
     C           K#FA1     READEFAAPL05                  90
     C           *IN90     IFEQ *OFF
     C           B7SKBN    IFEQ *BLANK
     C                     MOVE *OFF      *IN91
     C                     LEAVE
     C                     ELSE
     C                     MOVE *ON       *IN91
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C           *IN91     IFEQ *OFF
     C  N99                MOVE MSG,2     D@MSG
     C                     SETON                     6399
     C                     ELSE
     C  N99                MOVE MSG,3     D@MSG
     C                     SETON                     6399
     C                     ENDIF
     C                     ELSE
      *
     C           K#FA2     CHAINFCEPL01              90
     C           *IN90     IFEQ *ON
     C  N99                MOVE MSG,2     D@MSG
     C                     SETON                     6399
     C                     ELSE
     C           A2GSKD    IFNE *BLANK
     C  N99                MOVE MSG,3     D@MSG
     C                     SETON                     6399
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SET DATA FOR 2ND SCREEN
      *------------------------------------------------------
     C           #SET2     BEGSR
      *
     C                     MOVE A2BHB1    D@SHN1
     C                     MOVE A2BHB2    D@SHN2
     C                     MOVE A2BHB3    D@SHN3
     C           D@MHN1    IFEQ *BLANK
     C           K#FCE     CHAINFAAPL04              90
     C           *IN90     IFEQ *OFF
     C                     MOVE B7MHN1    D@MHN1
     C                     MOVE B7MHN2    D@MHN2
     C                     MOVE B7MHN3    D@MHN3
     C                     MOVE B7MHN4    D@MHN4
     C                     ENDIF
     C                     ENDIF
      *
     C           K#FC6     CHAINFCEPL60             N90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDF6SBDT    D@SBDT
     C                     Z-ADDF6APDT    D@APDT
     C                     ELSE
     C                     Z-ADD*ZERO     D@SBDT
     C                     Z-ADD*ZERO     D@APDT
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP02
      *
     C                     SELEC
      * END
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
      * GO BACK
     C           *INKL     WHEQ *ON
     C                     EXSR #CLR
     C                     EXSR #CLR2
     C                     MOVE '01'      W@ID
     C                     OTHER
      * CHECK & NEXT
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
     C                     EXSR #CLR2
     C                     MOVE '01'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CLEAR 1ST SCREEN
      *------------------------------------------------------
     C           #CLR2     BEGSR
      *
     C*******              MOVE *BLANK    D@CUST
     C                     MOVE *BLANK    D@SHN1
     C                     MOVE *BLANK    D@SHN2
     C                     MOVE *BLANK    D@SHN3
     C                     MOVE *BLANK    D@MHN1
     C                     MOVE *BLANK    D@MHN2
     C                     MOVE *BLANK    D@MHN3
     C                     MOVE *BLANK    D@MHN4
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     EXSR #CLR
      *
     C           D@SBDT    IFNE *ZERO
     C                     Z-ADDD@SBDT    K@YMD
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C  N99                MOVE MSG,4     D@MSG
     C                     SETON                     6499
     C                     ENDIF
     C                     ENDIF
      *
     C           D@APDT    IFNE *ZERO
     C                     Z-ADDD@APDT    K@YMD
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C  N99                MOVE MSG,4     D@MSG
     C                     SETON                     6599
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  UPDATE
      *------------------------------------------------------
     C           #UPD      BEGSR
      *
     C           K#FC6     CHAINFCEPL60              90
     C                     Z-ADD*DATE     F6KODT
     C                     TIME           F6KOTM
     C                     MOVEL#USER     F6KOME
     C                     Z-ADDD@SBDT    F6SBDT
     C                     Z-ADDD@APDT    F6APDT
     C                     MOVELD@SHN1    F6PRT1
     C                     MOVELD@SHN2    F6PRT2
     C                     MOVELD@SHN3    F6PRT3
     C                     MOVE D@CUST    F6CUST
     C                     MOVE D@MHN1    F6MHN1
     C                     MOVE D@MHN2    F6MHN2
     C                     MOVE D@MHN3    F6MHN3
     C                     MOVE D@MHN4    F6MHN4
     C  N90                UPDATFCEPP601
     C   90                WRITEFCEPP601
      *
     C                     ENDSR
      *------------------------------------------------------
      *  RESET SUBFILE DATA
      *------------------------------------------------------
     C           #SET3     BEGSR
      *
     C                     Z-ADD*ZERO     RRN1
     C                     Z-ADD*ZERO     @@RRN
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
      *
     C                     MOVE *OFF      *IN80
     C                     MOVE T@SHN1    W@SHN1  5
     C                     MOVE T@SHN2    W@SHN2  5
     C                     MOVE T@SHN3    W@SHN3  2
     C           K#FC61    SETLLFCEPL60
     C                     EXSR #SET33
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SET DATA FOR SUBFILE
      *------------------------------------------------------
     C           #SET33    BEGSR
      *
     C                     Z-ADD*ZERO     @@CNT   30
     C           *IN80     DOWEQ*OFF
     C                     READ FCEPL60             N    80
     C           *IN80     IFEQ *OFF
     C                     ADD  1         RRN1
     C                     MOVE F6CUST    S@CUST
     C                     MOVE F6PRT1    S@SHN1
     C                     MOVE F6PRT2    S@SHN2
     C                     MOVE F6PRT3    S@SHN3
     C                     Z-ADDF6SBDT    S@SBDT
     C                     Z-ADDF6APDT    S@APDT
     C                     WRITESFL01
     C                     ADD  1         @@CNT
     C           @@CNT     IFEQ 17
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           RRN1      IFEQ *ZERO
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  3RD SCREEN
      *------------------------------------------------------
     C           #SCRN3    BEGSR
      *
     C                     MOVE CMD,3     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      W@ID
     C                     EXSR #CLR2
     C                     EXSR #CLR
      * ROLL UP
     C           *IN38     WHEQ *ON
     C           *IN80     ANDEQ*OFF
     C                     EXSR #SET33
      *
     C           T@SHN1    WHNE W@SHN1
     C           T@SHN2    ORNE W@SHN2
     C           T@SHN3    ORNE W@SHN3
     C                     EXSR #SET3
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
**  CMD
F1:END      F9:INQUIRY
F1:END      F5:UPDATE      F12:GO BACK
F1:END      F12:GO BACK
