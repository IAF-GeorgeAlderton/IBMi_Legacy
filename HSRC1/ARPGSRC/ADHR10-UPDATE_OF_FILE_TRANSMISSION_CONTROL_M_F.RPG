JW1   *   JW     2022.05.18 ADD AAIPP22               *
      *************************************** ADHR10 **
     FAAIPP21 UF  E           K        DISK
JW1  FAAIPP22 O   E           K        DISK
      *
JW1  I            DS
 .   I                                        1  140SDATE
 .   I                                        1   60NOW
 .   I                                        7  140TODAY
 .    *
 .   I           SDS
 .   I                                        1   8 #PGM
 .   I                                      244 253 #WSID
 .   I                                      254 263 #USER
JW1  I                                      264 269 #JOB
      *************************************************
     C           *ENTRY    PLIST
     C                     PARM           PFILE   8
     C                     PARM           PCHK    1
      *
JW1  C                     TIME           SDATE
      *************************************************
     C           PFILE     CHAINAAIPP211             01
     C           *IN01     IFEQ '0'
      *
     C           PCHK      IFEQ 'C'
     C           AIJUNB    IFEQ '*'
     C           AIKANR    ANDEQ*BLANK
     C                     SETON                     U8
     C                     END
     C                     ELSE
      *
     C                     MOVE *BLANK    AIKANR
      *
     C           PCHK      IFEQ 'H'
     C                     MOVE 'H'       AIJUNB
     C                     ELSE
      *
     C           PCHK      IFEQ 'D'
     C                     MOVE 'D'       AIJUNB
     C                     ELSE
      *
     C           PCHK      IFEQ 'E'
     C                     MOVE '*'       AIKANR
     C                     END
      *
     C                     MOVE '*'       AIJUNB
     C                     END
     C                     END
     C                     END
      *
     C                     UPDATAAIPP211
      *
JW1  C                     EXSR #LOG
      *
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *************************
JW1   * OUTPUT LOG RECORD
 .    *************************
 .   C           #LOG      BEGSR
 .    *
     C                     Z-ADDTODAY     AILGDT
     C                     Z-ADDNOW       AILGTM
     C                     MOVEL#USER     AILGUS
     C                     MOVEL#PGM      AILGPG
     C                     MOVEL#WSID     AILGWS
     C                     MOVEL#JOB      AILGJB
     C                     MOVEL'UPD'     AILGFC    P
 .    *
 .   C                     WRITEAAIPP221
 .    *
JW1  C                     ENDSR
