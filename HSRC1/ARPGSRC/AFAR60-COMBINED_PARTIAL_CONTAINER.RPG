     H**************************************************************************
     H*
     H* *INKC = 1(CF03)
     H* *INKE = 1(CF05)
     H* *IN29 = 1(BZ KANBAN) 0(A-PICS KANBAN)
     H* *IN30 = ERROR
     H* *IN31 = 1(KANBAN1)
     H* *IN32 = 1(LOT1)
     H* *IN33 = 1(KANBAN2)
     H* *IN34 = 1(LOT2)
