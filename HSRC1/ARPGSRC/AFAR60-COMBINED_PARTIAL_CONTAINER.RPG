     H* *IN38 = 1(LOT4)
     H* *IN39 = 1(KANBAN5)
     H* *IN40 = 1(LOT5)
     H* *IN41 = 1(KANBAN6)
     H* *IN42 = 1(LOT6)
     H* *IN90 = 1(NOT READ AFAPP60)
     H* *IN91 = 1(FOUND ALP:NEW LOT NUMBER
     H* *IN92 = 1(NOT READ FCETL11)
     H* *IN93 = 1(NOT READ AGAPL31)
     H* *IN94 = 1(NOT READ AFANP65)
     H* *IN95 = 1(NOT READ AAFTL01)
     H**************************************************************************
     FAFAPW60 CF  E                    WORKSTN
     FFCETL11 IF  E           K        DISK
     FAFAPP60 IF  E           K        DISK                      A
     FAGAPL31 IF  E           K        DISK
     FAFANP65 UF  E           K        DISK                      A
     FAAFTL01 IF  E           K        DISK
     FAAMPL11 IF  E           K        DISK
     FAH#PL11 UF  E           K        DISK
     F**************************************************************************
     E                    KAN         6 15               APICS/BZ KANBAN
     E                    LOT         6  8               LOT ID TAG
     E                    ZET         6  4               ZETI
     E                    TEH         6  3               TEHAI
     E                    ALP    26  26  1               ALPHABET
     E                    ER      1   5 15
     E                    PRC        15  3               PROCESS
     E                    LOC        15  6               LOCATION
     E                    KK         15  1               KANBAN
     I**************************************************************************
