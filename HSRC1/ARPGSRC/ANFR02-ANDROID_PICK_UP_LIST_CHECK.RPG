     H            Y/
     F******************************************************
     F*  ANDROID PICK UP LIST CHECK                        *
     F*                                                    *
     F* TCHK1 07/14/06 CREATE(COPY FROM ABFR02)            *
     F******************************************************
     FABR6L02 IF  E           K        DISK
     FAB#PL90 IF  E           K        DISK
      *------------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C                     MOVE *BLANK    P@FLG
     C                     Z-ADDP@RLDT    K@YMD
     C           P@NONY    IFNE *BLANK
     C                     MOVE P@NONY    K@NONY
     C                     MOVE P@DOCK    K@DOCK
     C                     EXSR #CHK1
     C           P@NONY    CHAINAB#PL90              90
     C           *IN90     IFEQ *ON
     C           *IN90     OREQ *OFF
     C           YASKJY    ANDNE*BLANK
     C                     MOVE '2'       P@FLG
     C                     ENDIF
      *
     C                     ELSE
     C                     EXSR #CHK2
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@NONY  4
     C                     PARM           P@DOCK  4
     C                     PARM           P@SHDT  80
     C                     PARM           P@BIN   20
     C                     PARM           P@RLDT  80
     C                     PARM           P@FLG   1
     C           K#KEY     KLIST
     C                     KFLD           P@SHDT
     C                     KFLD           P@BIN
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C                     KFLD           K@DD    20
     C                     KFLD           K@NONY  40
     C                     KFLD           K@DOCK  4
      *
     C           KEY1      KLIST
     C                     KFLD           KDELY   40
     C                     KFLD           KDOCK   4
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C           K#KEY     SETLLABR6L02
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEABR6L02                  90
     C           *IN90     IFEQ *OFF
     C           FCSKJY    ANDEQ*BLANK
     C           FCSEQ#    ANDNE*ZERO
TTTT C*                    MOVE '1'       P@FLG
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     DO
      *
     C                     Z-ADD2855      K@NONY
     C                     MOVE '00  '    K@DOCK
     C                     EXSR #CHK1
     C           P@FLG     IFNE *BLANK
     C                     MOVE '2855'    P@NONY
     C                     LEAVE
     C                     END
      *
     C                     Z-ADD2856      K@NONY
     C                     MOVE '00  '    K@DOCK
     C                     EXSR #CHK1
     C           P@FLG     IFNE *BLANK
     C                     MOVE '2856'    P@NONY
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
