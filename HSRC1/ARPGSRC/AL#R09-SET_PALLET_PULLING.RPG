     H            Y.
     F** AL#R09  *******************************************
     F*便でパレットが１種類をパレットＰＵＬＬＩＮＧに    *
     F*      ITS.        2015.06.03                        *
     F******************************************************
     FAL#PP11 UF  E           K        DISK
     FAL#PL03 IF  E           K        DISK
     E                    PL        999  2
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      *
     C                     READ AL#PP111                 81
     C           *IN81     DOWEQ'0'
     C                     EXSR #SB400
     C                     READ AL#PP111                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *-----------------------------------------------------
      * AL#PP01
      *-----------------------------------------------------
     CSR         #SB400    BEGSR
      *
     C           KEYCA     KLIST
     C                     KFLD           C1SHID
     C                     KFLD           C1SHIT
     C                     KFLD           C1SURT
     C                     KFLD           C1NONY
     C                     KFLD           C1NKOJ
     C                     KFLD           C1NUKE
     C                     CLEARPL
     C                     Z-ADD0         X       40
     C           KEYCA     SETLLAL#PL031
     C           KEYCA     READEAL#PL031                 90
     C           *IN90     DOWEQ'0'
     C           CASKJY    IFEQ 'D'
     C           CASKHZ    ANDLESDATE
     C                     ELSE
     C           CAFIXD    IFEQ 0
     C                     EXSR #SB410
     C                     ENDIF
     C                     ENDIF
     C           KEYCA     READEAL#PL031                 90
     C                     ENDDO
      *
     C           X         IFEQ 1
     C                     MOVEL'1'       C1PPUL
     C                     UPDATAL#PP111
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *-----------------------------------------------------
      * AL#PP11
      *-----------------------------------------------------
     CSR         #SB410    BEGSR
      *パレット種類
     C                     MOVEL*BLANK    WKPALT  2
     C           CAPALT    IFEQ *BLANK
     C                     MOVEL'**'      WKPALT
     C                     ELSE
     C                     MOVELCAPALT    WKPALT
     C                     ENDIF
     C           WKPALT    LOKUPPL                       29
     C           *IN29     IFEQ '0'
     C                     ADD  1         X
     C                     MOVELWKPALT    PL,X
     C                     ENDIF
      *
     CSR         ESB410    ENDSR
