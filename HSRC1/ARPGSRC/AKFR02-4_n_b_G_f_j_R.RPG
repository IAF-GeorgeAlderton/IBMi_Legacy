     C           KEY1      KLIST
     C                     KFLD           @SHN1
     C                     KFLD           @SHN2
     C                     KFLD           @SHN3
      *
     C           *ENTRY    PLIST
     C                     PARM           PUSR   10
     C                     PARM           PSHN   12
     C                     MOVE PSHN      @SHN
      *
     C*------------------------------------*
     C*  ..構成品番計画通知書マスター..  *
     C*------------------------------------*
     C                     SETOF                     01
     C           KEY1      CHAINAKFPL011             01
     C           *IN01     IFEQ '0'
     C           M4SKJY    ANDEQ'D'
     C           M4SKHZ    ANDLE*DATE
     C                     SETON                     01
     C                     END
     C           *IN01     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C*------------------------------------*
     C*  ..構成品かんばん切替マスター..  *
     C*------------------------------------*
     C                     SETOF                     01
     C           KEY1      CHAINAKEPL011             01
     C           *IN01     IFEQ '0'
     C           M3SKJY    ANDEQ'D'
     C           M3SKHZ    ANDLE*DATE
     C                     SETON                     01
     C                     END
     C           *IN01     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C*----------------------*
     C*  ..工程チェック..  *
     C*----------------------*
     C                     SETOF                     01
     C                     Z-ADD1         A       20
     C           1         DO   15        A
     C           NKMN,A    IFGE M4KOHZ
     C           OKOT,A    IFEQ NKOT,A
     C           OKBM,A    ANDEQNKBM,A
     C                     ELSE
     C                     SETON                     01
     C                     END
     C                     END
     C  N01                END
     C           *IN01     IFEQ '0'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           M4IKOU    IFEQ '#'
     C                     MOVE *BLANK    M4TAHH
     C                     MOVE *BLANK    M4KATH
     C                     MOVE *BLANK    M4SYSH
     C                     MOVE *BLANK    M4SYHH
     C                     MOVE *BLANK    M4GEKH
     C                     MOVE *BLANK    M4KOTH
     C                     MOVE *BLANK    M4IKOU
     C                     Z-ADD1         M4KOSN
     C                     END
      *
     C           M4KOSN    IFNE 2
     C                     MOVE '*'       M4KOTH
     C                     MOVE *BLANK    M4LIST
     C                     END
      *
     C                     Z-ADD*DATE     M4KOHZ
     C                     TIME           M4TIME
     C                     MOVELPUSR      M4KOME
     C                     UPDATAKFPL011
      *
     C                     SETON                     LR
     C                     RETRN
