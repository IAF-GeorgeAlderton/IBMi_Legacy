     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C           W@ID      CASEQ'02'      #DSP02
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      *
     C           K#FCE     KLIST
     C                     KFLD           IEHIN1
     C                     KFLD           IEHIN2
     C                     KFLD           IEHIN3
     C           K#78X     KLIST
     C                     KFLD           IEHIN1
     C                     KFLD           IEHIN2
     C                     KFLD           IEHIN3
     C                     KFLD           IEINVO
     C                     KFLD           IEPARE
     C           K#78      KLIST
     C                     KFLD           IEHIN1
     C                     KFLD           IEHIN2
     C                     KFLD           IEHIN3
     C                     KFLD           IEINVO
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @@RRN   40
     C                     MOVEL'01'      W@ID    2
     C                     Z-ADD*ZERO     DAT
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     MOVEL'02'      W@ID
     C                     EXSR #WRT
     C                     EXSR #SET
TCH04C           *INKJ     IFEQ *ON
     C                     MOVEL'99'      W@ID
TCH04C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C           D@OPTN    IFNE '1'
     C           D@OPTN    ANDNE'2'
     C                     SETON                     6199
     C                     ENDIF
      *
     C           D@INVO    IFEQ *BLANK
     C                     SETON                     6299
     C                     ELSE
     C           D@INVO    CHAINGDGPL26              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6299
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SET DATE AND INVOICE#
      *------------------------------------------------------
     C           #WRT      BEGSR
      *
     C                     CLOSEGDGWP77                99
     C                     CLOSEGDGWL77                99
     C                     CLOSEGDGWL78                99
     C                     MOVEAKWD,1     P@CMD
     C                     Z-ADD75        P@LEN
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN GDGWP77
     C                     OPEN GDGWL77
     C                     OPEN GDGWL78
      *
     C                     MOVE *ALL'9'   IVO
     C                     MOVE *ALL'9'   DTE
     C                     Z-ADD*ZERO     X       30
     C           D@INVO    SETLLGDGPL26
     C           *IN90     DOUEQ*ON
     C                     READ GDGPL26                  90
     C           *IN90     IFEQ *OFF
     C           IESKJY    ANDEQ*BLANK
     C           IEHANY    ANDEQ'S'
     C           K#FCE     CHAINFCEPL01              91
     C           *IN91     IFEQ *ON
     C           A2GSKD    ORNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C           IEINVO    LOKUPIVO                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         X
     C           X         IFGT 5
     C                     LEAVE
     C                     ENDIF
     C                     MOVELIEINVO    IVO,X
     C                     Z-ADDIETYMD    DTE,X
     C                     ENDIF
      *
     C           K#78X     CHAINGDGWL78              92
     C           *IN92     IFEQ *OFF
     C                     ADD  IESBOX    SBOX
     C                     UPDATGDWR78
     C                     ELSE
      *
     C                     Z-ADD0         @@SEQN  20
     C           K#78      SETLLGDGWL78
     C           *IN92     DOUEQ*ON
     C           K#78      READEGDGWL78                  92
     C           *IN92     IFEQ *OFF
     C           SEQNO     IFGT @@SEQN
     C                     Z-ADDSEQNO     @@SEQN  20
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           @@SEQN    ADD  1         SEQNO
TCH38C           K#FCE     CHAINAAMPL111             67
   | C           *IN67     IFEQ '0'
     C           CKSKJY    ANDEQ' '
     C                     MOVELCKNB01    WKL3    3
     C                     MOVELWKL3      LOC1
     C                     MOVE WKL3      LOC2
     C                     MOVE CKNB01    WKR3    3
     C                     MOVELWKR3      LOC3
     C                     MOVE WKR3      LOC4
     C                     ENDIF
     C*                    MOVELA2STRK    LOC1
     C*                    MOVELA2STRT    LOC2
   | C*                    MOVELA2STRR    LOC3
TCH38C*                    MOVELA2STRD    LOC4
     C                     MOVE IEINVO    IVNO
     C                     MOVE IEHIN1    HIN1
     C                     MOVE IEHIN2    HIN2
     C                     MOVE IEHIN3    HIN3
 %001C                     MOVE IEPARE    PARE
     C                     Z-ADDIESBOX    SBOX
     C                     Z-ADDIETYMD    TYMD
     C                     WRITEGDGWP771
      *
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR 2ND SCREEN
      *------------------------------------------------------
     C           #SET      BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1
      *
     C                     SORTADTE
     C                     SORTAIVO
