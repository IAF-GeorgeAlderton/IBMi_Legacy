      *
     C           *IN80     IFEQ *OFF
      *
     C           @@HIN     IFNE *BLANK
     C           @@HIN     ANDNEIEHIN
     C           @@SQNO    ORNE *ZERO
     C           @@SQNO    ANDNESEQNO
     C                     ADD  1         RRN1
     C                     WRITESFL01
TCH04C           *INKJ     IFEQ *ON
TCH04C                     EXSR #WRTD2
TCH04C                     ENDIF
     C                     CLEARSFL01
     C                     ENDIF
      *
     C                     MOVE IEHIN     @@HIN
     C                     Z-ADDSEQNO     @@SQNO
     C                     MOVE HIN1      S@PRT1
     C                     MOVE HIN2      S@PRT2
     C                     MOVE HIN3      S@PRT3
     C                     MOVE LOC1      S@LOC1
     C                     MOVE LOC2      S@LOC2
     C                     MOVE LOC3      S@LOC3
     C                     MOVE LOC4      S@LOC4
     C                     Z-ADD1         X
     C           IVNO      LOKUPINV,X                    10
     C           *IN10     IFEQ *ON
     C                     Z-ADDSBOX      QTY,X
     C                     MOVE PARE      CAS,X
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           @@HIN     IFNE *BLANK
     C           RRN1      OREQ *ZERO
     C                     ADD  1         RRN1
