     FGDKPW11 CF  E                    WORKSTN
     FGDKPL08 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     E****************************************************************
     E                    MSG     1   1 59
     I****************************************************************
     I*
     I            DS
     I                                        1   60D1MMYY
     I                                        1   20D1MM
     I                                        3   60D1YY
     I*
     I            DS
     I                                        1   60W1YYMM
     I                                        1   40W1YY
     I                                        5   60W1MM
     I*
     I            DS
     I                                        1   80ITUKDT
     I                                        1   60ITUKYM
     I                                        1   40ITUKYY
     I                                        5   60ITUKMM
     I                                        7   80ITUKDD
     I*
     I            DS
     I                                        1   80OOUKDT
     I                                        5   80OOUKYY
     I                                        1   20OOUKMM
     I                                        3   40OOUKDD
     I*
     I            DS
     I                                        1   80OODATE
     I                                        5   80OODAYY
     I                                        1   20OODAMM
     I                                        3   40OODADD
     I*
     I            DS
     I                                        1   80WWDATE
     I                                        1   40WWDAYY
     I                                        5   60WWDAMM
     I                                        7   80WWDADD
     I*
     C****************************************************************
     C*           MAIN ROUTINE                                       *
     C****************************************************************
     C*
     C                     Z-ADD*DATE     WWDATE
     C                     Z-ADDWWDAYY    OODAYY
     C                     Z-ADDWWDAMM    OODAMM
     C                     Z-ADDWWDADD    OODADD
     C                     MOVEL*ALL'-'   LIN128128
     C                     Z-ADD0         D1MMYY
     C                     MOVE *OFF      *IN11
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    D#MSG
     C*
     C           @LOP      TAG
     C*
     C                     WRITEDSP02
     C                     EXFMTDSP01
     C                     MOVE *OFF      *IN11
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    D#MSG
     C*
     C   KA                GOTO @END
     C*
     C                     EXSR #CHK01
     C           *IN99     CABNE*OFF      @LOP
     C*
B01  C           *INKE     IFEQ *ON
     C*
     C                     MOVE *BLANK    WWVEND  4
     C                     MOVE *BLANK    WWINVO  6
     C                     Z-ADD0         WWUKDT  80
     C                     Z-ADD0         WWKIN1 110
     C                     Z-ADD0         WWKIN2 110
     C                     MOVE *OFF      *IN20
     C                     MOVE *OFF      *IN21
     C                     Z-ADDD1YY      W1YY
     C                     Z-ADDD1MM      W1MM
     C           *LOVAL    SETLLGDKPL081
     C*
B02  C                     DO   *HIVAL
     C                     READ GDKPL081                 30
     C   30                LEAVE
     C           ITUKYM    COMP W1YYMM               3131
     C   31                ITER
     C*
B03  C           ITVEND    IFNE WWVEND
     C   20                EXCPTTTL1
     C   20                ADD  WWKIN1    WWKIN2
     C   20                EXCPTTTL2
     C                     MOVELITVEND    WWVEND
     C                     MOVEL*BLANK    OOVNAM 20
     C                     MOVELWWVEND    B2CODE
     C           B2CODE    CHAINFGBPL011             31
     C  N31                MOVELB2SMEI    OOVNAM
     C                     EXCPTHED
     C                     MOVE *OFF      *INOF
     C                     MOVEL*BLANK    WWINVO
     C                     MOVEL*BLANK    WWUKDT
     C                     Z-ADD0         WWKIN1
     C                     Z-ADD0         WWKIN2
     C                     MOVE *OFF      *IN20
     C                     MOVE *OFF      *IN21
E03  C                     ENDIF
     C*
     C                     EXSR #CLR
     C*
B03  C           ITINVO    IFNE WWINVO
     C   21                EXCPTTTL1
     C                     ADD  WWKIN1    WWKIN2
     C                     Z-ADD0         WWKIN1
     C                     Z-ADD0         WWUKDT
     C                     MOVE ITINVO    OOINVO
     C                     MOVE *OFF      *IN21
     C                     MOVE *ON       *IN22
E03  C                     ENDIF
     C*
B03  C           ITUKDT    IFNE WWUKDT
     C                     Z-ADDITUKYY    OOUKYY
     C                     Z-ADDITUKMM    OOUKMM
     C                     Z-ADDITUKDD    OOUKDD
     C                     MOVE *ON       *IN23
E03  C                     ENDIF
     C*
     C                     Z-ADDITITEM    OOITEM
     C                     MOVELITTYPE    OOTYPE
     C                     MOVELITHIN     OOHIN
     C                     Z-ADDITSRY     OOSRY
     C                     Z-ADDITTAN     OOTAN
     C                     MOVELITTKBN    OOTKBN
     C                     Z-ADDITKIN     OOKIN
 SEL C                     SELEC
     C           ITYUSO    WHEQ 'S'
     C                     MOVEL'SEA'     OOYUSO
     C           ITYUSO    WHEQ 'A'
     C                     MOVEL'AIR'     OOYUSO
 ESELC                     ENDSL
     C                     MOVELITKAMO    OOKAMO
     C*
     C                     MOVEA'0'       *IN,50
     C           ITTKBN    IFEQ '8'
     C                     MOVEA'1'       *IN,50
     C                     END
     C*
B023 C           *INOF     IFEQ *ON
     C                     EXCPTHED
     C                     MOVEA'11'      *IN,22
     C                     MOVE ITINVO    OOINVO
     C                     Z-ADDITUKYY    OOUKYY
     C                     Z-ADDITUKMM    OOUKMM
     C                     Z-ADDITUKDD    OOUKDD
     C                     MOVE *OFF      *INOF
E03  C                     ENDIF
     C*
     C                     EXCPTDTL
     C                     MOVE *ON       *IN20
     C                     MOVE *ON       *IN21
     C*
     C                     ADD  OOKIN     WWKIN1
     C*
     C                     MOVELITVEND    WWVEND
     C                     MOVELITINVO    WWINVO
     C                     MOVELITUKDT    WWUKDT
     C*
E02  C                     ENDDO
     C*
B02  C           *IN20     IFEQ *ON
     C                     EXCPTTTL1
     C                     ADD  WWKIN1    WWKIN2
     C                     EXCPTTTL2
E02  C                     ENDIF
     C*
     C                     GOTO @END
     C*
E01  C                     ENDIF
     C*
     C                     GOTO @LOP
     C*
     C           @END      TAG
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
     C*
     C****************************************************************
     C*          #CHK01    INPUT-DATA CHECK
     C****************************************************************
     C           #CHK01    BEGSR
     C*
     C           D1YY      IFEQ 0
     C  N99                MOVELMSG,1     D#MSG
     C                     SETON                     9911
     C                     END
     C           D1MM      IFLT 1
     C           D1MM      ORGT 12
     C  N99                MOVELMSG,1     D#MSG
     C                     SETON                     9911
     C                     END
     C*
     C                     ENDSR
     C****************************************************************
     C*          #CLR      FIELD CLEAR
     C****************************************************************
     C           #CLR      BEGSR
     C*
     C                     MOVEA'00'      *IN,22
     C*
     C                     MOVE *BLANK    OOINVO  6
     C                     Z-ADD0         OOUKDT  80
     C                     MOVEL*BLANK    OOITEM  50
     C                     MOVEL*BLANK    OOTYPE  1
     C                     MOVEL*BLANK    OOHIN  20
     C                     Z-ADD0         OOSRY   70
     C                     Z-ADD0         OOTAN  145
     C                     MOVEL*BLANK    OOTKBN  1
     C                     Z-ADD0         OOKIN  110
     C                     MOVEL*BLANK    OOYUSO  3
     C                     MOVEL*BLANK    OOKAMO  4
     C*
     C                     ENDSR
     C****************************************************************
     O****************************************************************
     OQPRINT  E   01           HED
