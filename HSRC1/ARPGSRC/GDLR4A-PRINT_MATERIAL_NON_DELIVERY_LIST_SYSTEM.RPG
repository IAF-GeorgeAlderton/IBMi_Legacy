     C           *IN05     IFEQ '0'
     C                     SETON                     05
     C                     Z-ADD0         MAIS    30
     C                     END
      *
     C           KEY1      KLIST
     C                     KFLD           LEODR1
     C                     KFLD           LEODR2
     C                     KFLD           LEODR3
