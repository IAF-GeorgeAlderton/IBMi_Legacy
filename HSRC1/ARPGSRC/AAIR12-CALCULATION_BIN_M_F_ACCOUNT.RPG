     C*  START PROGRAM  <AAIR12>                                     *
     C****************************************************************
     C  N01                GOTO STP99
     C           *IN,90    IFEQ '0'
     C                     MOVE *BLANK    TYTLE
     C                     MOVELCOM,1     TYTLE
     C                     MOVE *BLANK    PSW     1
     C                     MOVEA'1'       *IN,90
     C                     END
     C*
     C           PSW       IFEQ *BLANK
     C                     OPEN AAIPR12
     C                     MOVEL'*'       PSW
     C                     END
     C*
     C           CDBMON    CHAINFGBPL011             10
     C   10                MOVE *BLANK    B2KEMI
     C*
     C                     MOVEA'00000'   *IN,11
     C                     MOVEA'00000'   *IN,16
     C                     MOVEA'00000'   *IN,21
     C                     MOVEA'00000'   *IN,26
     C                     MOVEA'00000'   *IN,31
     C                     MOVEA'00000'   *IN,36
     C                     MOVEA'00000'   *IN,41
     C                     MOVEA'00000'   *IN,46
     C                     MOVEA'00000'   *IN,51
     C                     MOVEA'00000'   *IN,56
     C                     MOVEA'00000'   *IN,61
     C                     MOVEA'00000'   *IN,66
     C                     MOVE *BLANK    DTNM
     C                     MOVE *BLANK    OKNM
     C                     MOVE *BLANK    DNNM
     C                     MOVE *BLANK    ONNM
     C*
     C                     DO   24        I       50
     C           CDBI,I    IFNE 0
     C           I         ADD  10        J       50
     C                     MOVEA'1'       *IN,J
     C           CDDT,I    LOKUPTAB1      TAB2           10
     C   10                MOVELTAB2      DTNM,I
     C           CDOK,I    LOKUPTAB3      TAB4           10
     C   10                MOVELTAB4      OKNM,I
     C                     END
     C           CDBN,I    IFNE 0
     C           I         ADD  40        J
     C                     MOVEA'1'       *IN,J
     C           CDDN,I    LOKUPTAB1      TAB2           10
     C   10                MOVELTAB2      DNNM,I
     C           CDON,I    LOKUPTAB3      TAB4           10
     C   10                MOVELTAB4      ONNM,I
     C                     END
     C                     END
     C                     WRITEHED
     C*
     C           STP99     TAG
