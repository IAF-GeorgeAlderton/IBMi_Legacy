     H            Y.
     F** UEXR20F ***************************************************
     F*  PROGRAM:  GET INVOICE# FROM ABAEP20S (AUTOKINITON)        *
     F*  WRITTEN: JW (SRA)  2024.04.03                             *
     F*  FOR AUTOKINITON                                           *
     F*------------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UEXR20F'
     F*                    PARM           $NONY   4
     F*                    PARM           $MHIN  20
     F*                    PARM           $NOHZ   8
     F*                    PARM           $ODRN  10
     F*                    PARM           $INVN  16
     F*                    PARM           $PRTR  10
     F*   IN  $NONY :  4A DELIVERY CODE
     F*   "   $MHIN : 20A USER PART#
     F*   "   $NOHZ :  8A SHIP DATE
     F*   OUT $ODRN : 10A ORDER#
     F*   "   $INVN : 16A INVOICE#
     F*   "   $PRTR : 10A PARTNER ID
     F******************************************************
     FABAEL20AIF  E           K        DISK
     F******************************************************
     I            DS
     I                                        1  10 AEPRTR
     I                                        1   8 PRTR8
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
     C                     EXSR #INIT
      *
     C           KEY1      SETLLABAEL20A
     C                     DO   *HIVAL
     C           KEY1      READEABAEL20A                 98
     C   98                LEAVE
      *
     C           PRTR8     IFEQ 'AUTOKINI'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELAEODRN    $ODRN
     C                     MOVELAESPID    $INVN
     C                     MOVELAEPRTR    $PRTR
     C                     LEAVE
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *=============================================================
      *                    INITIAL PROCESS
      *=============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4
     C                     PARM           $MHIN  20
     C                     PARM           $NOHZ   8
     C                     PARM           $ODRN  10
     C                     PARM           $INVN  16
     C                     PARM           $PRTR  10
      *
     C           KEY1      KLIST
     C                     KFLD           K#NONY  4
     C                     KFLD           K#MHIN 30
     C                     KFLD           K#DAT1  80
      *
     C                     MOVEL$NONY     K#NONY
     C                     MOVEL$MHIN     K#MHIN
     C                     MOVEL$NOHZ     K#DAT1
     C                     MOVE *BLANK    $ODRN
     C                     MOVE *BLANK    $INVN
     C                     MOVE *BLANK    $PRTR
      *
     C                     ENDSR
