     H            Y/                                    1
     FGDJPW10 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL01
     FGDJPP15 UF  E           K        DISK
     E                    MSG     1   5 50
     I****************************************************************
     I            DS
     I                                        1  17 IOBAR
     I                                        1   1 IOBAR1
     I                                        2   5 IOBAR2
     I                                        6  13 IOKATA
     I                                        9  11 IOKOTE
     I                                       12  12 IOBAR3
     I            DS
     I                                        1  17 S1BAR
     I                                        1   1 S1BAR1
     I                                        2   5 S1BAR2
     I                                        6  13 S1KATA
     I                                        9  11 S1KOTE
     I                                       12  12 S1BAR3
     I            DS
     I                                        1  12 WWHIN
     I                                        1   5 WWHIN1
     I                                        6  10 WWHIN2
     I                                       11  12 WWHIN3
     I                                        1   2 WWDIE1
     I                                        3   6 WWDIE2
     I                                        7   7 WWDIE3
     I                                        8   8 WWDIE4
     I            DS
     I                                        1  14 S1PART
     I                                        1   5 S1HIN1
     I                                        7  11 S1HIN2
     I                                       13  14 S1HIN3
     I                                        1   2 S1DIE1
     I                                        3   3 S1DW1
     I                                        4   7 S1DIE2
     I                                        8   8 S1DW2
     I                                        9   9 S1DIE3
     I                                       10  10 S1DW3
     I                                       11  11 S1DIE4
     I                                       12  14 S1DW4
     C****************************************************************
     C*           KLIST                            *
     C****************************************************************
     C*** joeﾜﾆ ﾓbﾈg ﾎｦbﾓ ***
     C           GDJKY1    KLIST
     C                     KFLD           D1KIKI
     C                     KFLD           D1SEQ1
     C           GDJKY2    KLIST
     C                     KFLD           D1KIKI
     C                     KFLD           S1SEQ
     C****************************************************************
     C*           MAIN ROUTINE                                       *
     C****************************************************************
     C           @DSP00    TAG
     C                     EXSR #INIT
     C*** DSP01 ***
     C           @DSP01    TAG
     C                     EXFMTDSP01
     C                     MOVEA'000'     *IN,11
     C                     MOVEL'0'       *IN99
     C                     MOVE *BLANK    D#MSG
     C*
     C           *INKA     CABEQ'1'       @END
     C*
     C                     EXSR #D1CHK
     C           *IN99     CABEQ'1'       @DSP01
     C*
     C                     EXSR #SFSET
     C*** SFL01 ***
     C           @SFL01    TAG
     C                     MOVEA'11'      *IN,81
     C                     WRITEDSP02
     C                     EXFMTCTL01
     C                     MOVEA'00'      *IN,81
     C                     MOVEA'000'     *IN,11
     C                     MOVEL'0'       *IN99
     C                     MOVE *BLANK    D#MSG
     C*
     C           *INKA     CABEQ'1'       @END
     C           *INKC     CABEQ'1'       @DSP01
     C*
     C*
     C                     EXSR #SFCHK
     C           *IN99     CABEQ'1'       @SFL01
     C*
     C           *INKE     CABEQ'0'       @SFL01
     C                     EXSR #UPDAT
     C*
     C                     GOTO @DSP00
     C**
     C           @END      TAG
     C                     SETON                     LR
     C                     RETRN
     C****************************************************************
     C*          #INIT                                               *
     C****************************************************************
     C           #INIT     BEGSR                                     *
     C                     MOVE '000'     *IN,11
     C                     MOVEL'0'       *IN99
     C                     MOVE *BLANK    D#MSG
     C                     MOVE *BLANK    D1KIKI
     C                     Z-ADD*ZERO     D1SEQ1
     C                     Z-ADD*ZERO     D1SEQ2
     C                     ENDSR
     C****************************************************************
     C*          #D1CHK    DSP1 CHECK                                 *
     C****************************************************************
     C           #D1CHK    BEGSR                                     *
     C           D1KIKI    IFEQ *BLANK
     C                     MOVE '1'       *IN11
     C  N99                MOVELMSG,5     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     END
     C*** INVENTORY DATA (BAR CODE)
     C           GDJKY1    SETLLGDJPP151             91
     C           *IN91     IFEQ *ON
     C                     MOVE '11'      *IN11
     C  N99                MOVELMSG,1     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     END
     C                     ENDSR
     C****************************************************************
     C*          #SFSET   SFL1 SET                                   *
     C****************************************************************
     C           #SFSET    BEGSR                                     *
     C                     MOVE *ON       *IN40
     C                     Z-ADD*ZERO     RRN     40
     C                     Z-ADD1         RECNO   40
     C                     MOVE *ON       *IN83
     C                     WRITECTL01                      (SFLCLR)
     C                     MOVE *OFF      *IN83
     C*
     C                     DO   *HIVAL
     C           D1KIKI    READEGDJPP151                 91
     C           *IN91     IFEQ *ON
     C                     LEAVE
     C                     END
     C           D1SEQ2    IFNE 0
     C           IOSEQ     IFGT D1SEQ2
     C                     LEAVE
     C                     END
     C                     END
     C*
     C*
     C                     Z-ADDIOSEQ     S1SEQ
     C                     MOVE IOKKBN    S1KKBN
     C                     MOVE IOBAR     S1BAR
     C                     MOVE *BLANK    S1PART
     C                     Z-ADD0         S1SYUY
     C                     Z-ADDIOMAIS    S1MAIS
     C                     MOVE *BLANK    @@HIN  12
     C                     Z-ADD0         @@SYUY           QUANTITY IN BOX
     C                     MOVE *BLANK    @@PART           PARTS NO.
     C                     Z-ADD0         @@DEP            DEPARTMENT
     C                     Z-ADD0         @@ERR            ERROR
      *** ADD 11/13 A.IDOTA ***
     C                     Z-ADD0         @@LOT            LOT
      *** ADD 11/13 A.IDOTA ***
     C                     CALL 'GDJR12'               20
     C                     PARM           IOKKBN           PROCESS CODE
     C                     PARM           IOBAR1           KANBAN KBN
     C                     PARM           IOBAR2           ID NUMBER
     C                     PARM           IOBAR3           SEIHIN KBN
     C                     PARM           IOKATA           KATA NO.
     C                     PARM           IOKOTE           KOTE NO.
     C                     PARM           @@HIN  12
     C                     PARM           @@SYUY  70       QUANTITY IN BOX
     C                     PARM           @@PART 12        PARTS NO.
     C                     PARM           @@DEP   40       DEPARTMENT
     C                     PARM           @@ERR   10       ERROR
      *** ADD 11/13 A.IDOTA ***
     C                     PARM           @@LOT   30       LOT
      *** ADD 11/13 A.IDOTA ***
     C                     FREE 'GDJR12'
     C   20                Z-ADD1         @@ERR
     C           @@ERR     IFEQ 0
     C                     MOVE @@PART    WWHIN
     C                     MOVE *ALL'-'   S1PART
     C           IOKKBN    IFNE '7'
     C                     MOVE WWHIN1    S1HIN1
     C                     MOVE WWHIN2    S1HIN2
     C                     MOVE WWHIN3    S1HIN3
     C           WWHIN3    IFEQ *BLANK
     C                     MOVE '   '     S1PART
     C                     END
     C                     ELSE
     C                     MOVE WWDIE1    S1DIE1
     C                     MOVE WWDIE2    S1DIE2
     C                     MOVE WWDIE3    S1DIE3
     C                     MOVE WWDIE4    S1DIE4
     C                     MOVE *BLANK    S1DW4
     C           WWDIE4    IFEQ *BLANK
     C                     MOVE *BLANK    S1DW3
     C                     END
     C           WWDIE3    IFEQ *BLANK
     C                     MOVE *BLANK    S1DW2
     C                     END
     C                     END
     C                     Z-ADD@@SYUY    S1SYUY
     C                     END
     C                     ADD  1         RRN
     C                     WRITESFL01
     C                     CLEARSFL01
     C                     ENDDO
     C**
     C**
     C                     Z-ADD1         RECNO
     C**
     C                     ENDSR
     C****************************************************************
     C*          #SFCHK   SFL1 CHECK                                 *
     C****************************************************************
     C           #SFCHK    BEGSR                                     *
     C*
     C                     Z-ADD1         RECNO
     C                     Z-ADD1         RRN
     C           1         DO   *HIVAL    RRN
     C           RRN       CHAINSFL01                91
     C           *IN91     IFEQ *ON
     C                     LEAVE
     C                     END
     C                     MOVEA'000'     *IN,11
     C*
     C*
     C           S1KKBN    IFEQ '1'
     C           S1KKBN    OREQ '2'
     C           S1KKBN    OREQ '3'
     C           S1KKBN    OREQ '4'
     C           S1KKBN    OREQ '5'
     C           S1KKBN    OREQ '6'
     C           S1KKBN    OREQ '7'
     C           S1KKBN    OREQ '8'
     C                     ELSE
     C                     MOVEA'1'       *IN,11
     C  N99                MOVELMSG,3     D#MSG
     C  N99                Z-ADDRRN       RECNO
     C  N99                MOVEA'1'       *IN,99
     C                     END
     C*
     C           S1MAIS    IFEQ 0
     C                     MOVEA'1'       *IN,12
     C  N99                MOVELMSG,2     D#MSG
     C  N99                Z-ADDRRN       RECNO
     C  N99                MOVEA'1'       *IN,99
     C                     END
     C                     MOVE *BLANK    S1PART
     C                     Z-ADD0         S1SYUY
     C                     MOVE *BLANK    @@HIN
     C                     Z-ADD0         @@SYUY           QUANTITY IN BOX
     C                     MOVE *BLANK    @@PART           PARTS NO.
     C                     Z-ADD0         @@DEP            DEPARTMENT
     C                     Z-ADD0         @@ERR            ERROR
      *** ADD 11/13 A.IDOTA ***
     C                     Z-ADD0         @@LOT            LOT
      *** ADD 11/13 A.IDOTA ***
     C                     CALL 'GDJR12'               20
     C                     PARM           S1KKBN           PROCESS CODE
     C                     PARM           S1BAR1           KANBAN KBN
     C                     PARM           S1BAR2           ID NUMBER
     C                     PARM           S1BAR3           SEIHIN KBN
     C                     PARM           S1KATA           KATA NO.
     C                     PARM           S1KOTE           KOTE NO.
     C                     PARM           @@HIN
     C                     PARM           @@SYUY  70       QUANTITY IN BOX
     C                     PARM           @@PART 12        PARTS NO.
     C                     PARM           @@DEP   40       DEPARTMENT
     C                     PARM           @@ERR   10       ERROR
      *** ADD 11/13 A.IDOTA ***
     C                     PARM           @@LOT   30       LOT
      *** ADD 11/13 A.IDOTA ***
     C                     FREE 'GDJR12'
     C   20                Z-ADD1         @@ERR
     C           @@ERR     IFEQ 0
     C                     MOVE @@PART    WWHIN
     C                     MOVE *ALL'-'   S1PART
     C           S1KKBN    IFNE '7'
     C                     MOVE WWHIN1    S1HIN1
     C                     MOVE WWHIN2    S1HIN2
     C                     MOVE WWHIN3    S1HIN3
     C           WWHIN3    IFEQ *BLANK
     C                     MOVE '   '     S1PART
     C                     END
     C                     ELSE
     C                     MOVE WWDIE1    S1DIE1
     C                     MOVE WWDIE2    S1DIE2
     C                     MOVE WWDIE3    S1DIE3
     C                     MOVE WWDIE4    S1DIE4
     C                     MOVE *BLANK    S1DW4
     C           WWDIE4    IFEQ *BLANK
     C                     MOVE *BLANK    S1DW3
     C                     END
     C           WWDIE3    IFEQ *BLANK
     C                     MOVE *BLANK    S1DW2
     C                     END
     C                     END
     C                     Z-ADD@@SYUY    S1SYUY
     C                     END
     C           @@ERR     IFEQ 1
     C                     MOVEA'1'       *IN,11
     C  N99                MOVELMSG,4     D#MSG
     C  N99                Z-ADDRRN       RECNO
     C  N99                MOVEA'1'       *IN,99
     C                     END
     C                     UPDATSFL01
     C                     ENDDO
     C**
     C                     ENDSR
     C****************************************************************
     C*          #UPDAT    FILE UPDATE                               *
     C****************************************************************
     C           #UPDAT    BEGSR                                     *
     C*
     C                     Z-ADD1         RRN
     C           1         DO   *HIVAL    RRN
     C           RRN       CHAINSFL01                91
     C           *IN91     IFEQ *ON
     C                     LEAVE
     C                     END
     C           GDJKY2    CHAINGDJPP151             92
     C           *IN92     IFEQ '0'
     C                     MOVE S1KKBN    IOKKBN           PROCESS CODE
     C                     Z-ADDS1MAIS    IOMAIS           BOXES
     C                     UPDATGDJPP151
     C                     END
     C                     ENDDO
     C**
     C**
     C**
     C                     ENDSR
**  MSG  **
INVENTORY DATA (BAR CODE) NOT FOUND.
INPUT THE BOXES.
INCORRECT PROCESS CLASS.
