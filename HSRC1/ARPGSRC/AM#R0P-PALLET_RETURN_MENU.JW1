     C                     ENDIF
     C                     ENDDO
      *
      *
     C                     SELEC
      * PALLET RETURN SCAN
     C           D1SEL     WHEQ 1
     C                     MOVEL'AM#C45N' WPGM
      *
     C                     OTHER
     C                     SETON                     3199
     C                     MOVELER,1      MSG
     C                     EXSR #SB999
     C                     GOTO ESB210
     C                     ENDSL
      *
      * CALL PROCESS
     C                     SELEC
