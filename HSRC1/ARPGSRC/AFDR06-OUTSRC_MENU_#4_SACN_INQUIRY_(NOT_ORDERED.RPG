     H            Y.                                    1
     H** AFDR06 *******************************************************
     H* OUT SOURCE INQUIRY(CURTIS)                                    *
     H*        NOT ORDERED YET                                        *
     H* TCH DEC/12/17
     H* TCHK1 12/10/08 ADD PTC(2424)
     H* TCHK2 02/26/09 ADD DEPOR(2929)
     H* TCHK3 03/11/10 ADD SWD(2828) TALMA(3333)
     H* TCHK4 05/13/10 ADD SEKIDO(3111),SRA(3222),VICO(3444)
     H* TCHK5 03/10/11 ADD FCO(2112)
     H* TCHK6 01/27/12 ADD ROCKFORD SECONDARIES(4444)
     H* TCHK7 09/20/12 ADD FAS(5555)
     H* TCHK8 10/22/13 BUG FIX
     H**************************************************************************
     FAFDPW06 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FAFDPL10 IF  E           K        DISK
     F            AFDPP101                          KRENAMEAFD10R
     F                                              KINFDS @INFDA
TCHK7FAFDPL13 IF  E           K        DISK
TCHK7F            AFDPP101                          KRENAMEAFD13R
TCHK8F                                              KINFDS @INFDB
     FAFDPP10 UF  E                    DISK
     FAFDPL15 UF  E           K        DISK
      *--------------------------------------------------------------
     E                    CMD     1   1 78
     E                    ERR     1   1 78
TCHK7E                    TAB1    1  21  5   TAB2   15
     I**************************************************************************
     I* BARCODE
     I*(KANRI CODE+ZETAI NO+TEHAI NO+PAGE NO+NIJI KAKO KUBUN+TAISYO KUBN+
     I**************************************************************************
     I@INFDS      DS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I@INFDA      DS
     I                                    B 397 4000@@RCD
TCHK8I@INFDB      DS
TCHK8I                                    B 397 4000@@R13
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------
     C*
     C           *ENTRY    PLIST
     C                     PARM           SUPLY   4
     C                     PARM           SUPX    1
      *
     C           K#AF10    KLIST
     C                     KFLD           SUPLY
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C                     KFLD           K@DD    20
     C           K#15      KLIST
     C                     KFLD           ADKANR
     C                     KFLD           ADZETI
     C                     KFLD           ADTEHI
     C                     KFLD           ADPAGE
     C                     KFLD           ADNIJI
     C                     KFLD           ADTAIS
     C                     KFLD           ADSYUK
     C                     KFLD           ADHKOS
     C                     KFLD           ADCHKD
     C                     KFLD           ADBINN
     C                     KFLD           ADODNO
     C                     KFLD           ADSUPP
      *
     C                     Z-ADD*ZERO     K@YY
     C                     Z-ADD*ZERO     K@MM
     C                     Z-ADD*ZERO     K@DD
     C           SUPLY     CAT  SUPX:0    SCODE   5 P
     C           SCODE     LOKUPTAB1      TAB2           90
     C           *IN90     IFEQ *ON
     C                     MOVELTAB2      D@SUPP
     C                     ENDIF
      *
     C                     MOVE SUPLY     @SUPP   40
     C                     MOVE '01'      @@ID    2
     C                     SETOF                     30
     C                     EXSR #SET
      *
     C                     ENDSR
     C**************************************************************************
     C*    1ST SCREEN
     C**************************************************************************
     C           #SCRN1    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
B02  C           *INKC     WHEQ '1'
     C                     MOVEL'99'      @@ID    2
     C*
     C                     OTHER
     C                     EXSR #CHK1
     C*
B04  C           *IN99     IFEQ *OFF
B04  C           *INKX     ANDEQ*ON
     C                     EXSR #DLT
     C                     MOVEL'99'      @@ID
     C                     ENDIF
     C                     ENDSL
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK1
     C**************************************************************************
     C           #CHK1     BEGSR
     C*
     C                     MOVE *ON       *IN99
     C                     Z-ADD*ZERO     WRRN    40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           S@SLCT    IFEQ 'D'
     C                     MOVE *OFF      *IN99
     C                     ENDIF
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C**************************************************************************
     C*            DELETE
     C**************************************************************************
     C           #DLT      BEGSR
     C*
     C                     MOVE *ON       *IN99
     C                     Z-ADD*ZERO     WRRN    40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           S@SLCT    ANDEQ'D'
     C           H@REC     CHAINAFDPP10              80
     C           *IN80     IFEQ *OFF
     C                     MOVE 'D'       ADSKJY
     C                     Z-ADD*DATE     ADSKDT
     C                     Z-ADD*DATE     ADKODT
     C                     TIME           ADKOTM
     C                     MOVEL#USER     ADKOME
     C                     MOVEL#PGM      ADKOPG
     C                     UPDATAFDPP101
      *
     C           K#15      SETLLAFDPL15
     C           *IN95     DOUEQ*ON
     C           K#15      READEAFDPL15                  95
     C           *IN95     IFEQ *OFF
     C           A5SKJY    ANDEQ*BLANK
     C                     MOVE 'D'       A5SKJY
     C                     Z-ADD*DATE     A5SKDT
     C                     Z-ADD*DATE     A5KODT
     C                     TIME           A5KOTM
     C                     MOVEL#USER     A5KOME
     C                     MOVEL#PGM      A5KOPG
     C                     UPDATAFDPP151
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C**************************************************************************
     C*    SET DATA FOR 1ST SCREEN
     C**************************************************************************
     C           #SET      BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
     C                     MOVE *BLANK    @@BIN   3
     C                     Z-ADD*ZERO     @@CNT   20
TCHK7C           SUPLY     IFEQ '5555'
TCHK7C           K#AF10    SETLLAFDPL13
TCHK7C                     ELSE
     C           K#AF10    SETLLAFDPL10
TCHK7C                     END
      *
     C           *IN80     DOUEQ*ON
TCHK7C           SUPLY     IFEQ '5555'
TCHK7C           K#AF10    READEAFDPL13                  80
TCHK7C                     ELSE
     C           K#AF10    READEAFDPL10                  80
TCHK7C                     END
      *
     C           *IN80     IFEQ *OFF
     C           ADSKJY    ANDEQ*BLANK
      *
     C           SUPX      IFNE *BLANK
     C           SUPX      ANDNEADFILR
     C                     ITER
     C                     ENDIF
      *
     C           @@BIN     IFNE ADBINN
     C                     Z-ADD*ZERO     @@CNT
     C                     ENDIF
      *
     C                     ADD  1         @@CNT
     C                     Z-ADD@@CNT     S@NMBR
     C                     MOVE ADBINN    S@BINN
     C                     MOVE ADBINN    @@BIN
     C                     MOVE ADPAR1    S@PAR1
     C                     MOVE ADPAR2    S@PAR2
     C                     MOVE ADPAR3    S@PAR3
     C                     MOVE ADTEHI    S@TEHI
     C                     MOVE ADPAGE    S@PAGE
     C                     MOVELADLTNO    S@LOTN
     C                     Z-ADDADSYOS    S@QTY
     C                     Z-ADDADKODT    S@DATE
     C                     Z-ADDADKOTM    S@TIME
      *
TCHK8C           SUPLY     IFEQ '5555'
TCHK8C                     Z-ADD@@R13     H@REC
TCHK8C                     ELSE
     C                     Z-ADD@@RCD     H@REC
TCHK8C                     END
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           RRN1      IFEQ *ZERO
     C                     ADD  1         RRN1
     C                     MOVE ERR,1     D@MSG
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     ENDSR
      *---------------------------------------------------------
** CMD
 'D' DELETE     F3:END     F23:DELETE
