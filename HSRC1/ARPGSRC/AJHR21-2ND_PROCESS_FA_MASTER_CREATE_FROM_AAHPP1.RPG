     C           *ENTRY    PLIST
     C                     PARM           TVMENT  1
     C                     PARM           P@MCD   1
     C***                  MOVE P@MCD     C@MCD   1
     C                     MOVE TVMENT    MENT    1
     C*
     C           *IN05     IFEQ '0'
     C                     SETON                     05
     C           MENT      IFEQ '2'
     C                     EXCPTCLR
     C                     END
     C                     END
     C*
     C           JHSKJY    IFEQ 'D'
     C                     GOTO END
     C                     END
     C****************************************
     C*ＦＡの品番がメッキに無い時ＦＡを削除*
     C****************************************
     C           KEY1      KLIST
     C                     KFLD           JHSHN1
     C                     KFLD           JHSHN2
     C                     KFLD           JHSHN3
     C**********************************************************
     C*引き取りかんばんからＦＡマスターの未使用品番をチェック*
     C**********************************************************
     C           KEY1      SETLLAAHTL061
     C                     SETOF                     10
     C           MELOOP    TAG
     C           KEY1      READEAAHTL061                 10
     C           *IN10     IFEQ '1'
     C                     MOVE 'D'       JHSKJY
     C                     Z-ADD*YEAR     JHSKYY
     C                     Z-ADDUMONTH    JHSKMM
     C                     Z-ADDUDAY      JHSKDD
     C                     MOVEL'AJHR15'  JHKOME
     C                     MOVE '0'       JHMENT
     C                     UPDATAJHPL011
     C                     GOTO END
     C                     ELSE
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    IFLE *DATE
     C                     GOTO MELOOP
     C                     END
     C                     END
     C                     END
     C*有効日・失効日のチェック*
JW2   * TEMP1 - IF JBD, THEN GOTO MELOOP
 |   C           L6JOK1    IFEQ 'JB'
 |   C           *DATE     ANDEQ20180618
 |   C                     GOTO MELOOP
JW2  C                     ENDIF
      *
JW2   * TEMP2 - IF PART=U1219-B4031, THEN GOTO MELOOP
 |   C           L6SHN1    IFEQ 'U1219'
 |   C           L6SHN2    ANDEQ'B4031'
 |   C           *DATE     ANDEQ20180618
 |   C                     GOTO MELOOP
JW2  C                     ENDIF
      *
     C           L6UKHZ    IFLE *DATE
     C           L6STHZ    ANDGT*DATE
     C                     ELSE
     C                     GOTO MELOOP
     C                     END
      *
     C*引き取りかんばんマスターに有りの時ＯＫ*
     C                     GOTO OK
