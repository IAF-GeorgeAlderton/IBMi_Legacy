     H            Y.
     F** AB#R0I3 ***************************************************************
     F*  PROGRAM    : CHECK & FIX HONDA DUPLICATE ORDER                        *
     F*  WRITTEN    : 2020.06.11                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#PL2P IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *---------------------------------------------------
     I            DS
     I                                        1  140@DATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ***********************************************************
     C                     EXSR #INIT
      *
     C           TODAY     SETLLAB#PL2P
     C                     DO   *HIVAL
     C                     READ AB#PL2P                  98
     C   98                LEAVE
      * SELECT
     C           ACUPID    IFNE ' '
     C                     ITER
     C                     ENDIF
     C           ACQNTY    IFEQ 0
     C                     ITER
     C                     ENDIF
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELACPLSH    SVPLSH
     C                     MOVELACNONY    SVNONY
     C                     MOVELACNKOJ    SVNKOJ
     C                     MOVELACNUKE    SVNUKE
     C                     MOVELACBIN     SVBIN
     C                     MOVELACODRN    SVODRN
     C                     MOVELACMHN1    SVMHN1
     C                     MOVELACMHN2    SVMHN2
     C                     MOVELACMHN3    SVMHN3
     C                     MOVELACMHN4    SVMHN4
     C                     MOVELACUPID    SVUPID
     C                     ENDIF
      * BREAK?
     C           ACPLSH    IFNE SVPLSH
     C           ACNONY    ORNE SVNONY
     C           ACNKOJ    ORNE SVNKOJ
     C           ACNUKE    ORNE SVNUKE
     C           ACBIN     ORNE SVBIN
     C           ACODRN    ORNE SVODRN
     C           ACMHN1    ORNE SVMHN1
     C           ACMHN2    ORNE SVMHN2
     C           ACMHN3    ORNE SVMHN3
     C           ACMHN4    ORNE SVMHN4
     C           ACUPID    ORNE SVUPID
     C                     EXSR #BRK1
     C                     ENDIF
      * DETAIL PROCESS
     C                     ADD  ACQNTY    @QNTY
     C                     ADD  1         @CNT
      *
     C                     ENDDO
      * LAST BREAK
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK1
     C                     ENDIF
      * SET RETURN CODE
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * BREAK                                              *
      *----------------------------------------------------*
     C           #BRK1     BEGSR
      *
     C           @CNT      IFGE 2
     C                     EXSR #PRINT
      * UPDATE
     C           $UPD      IFEQ 'Y'
     C                     EXSR #UPD
     C                     ENDIF
      *
     C                     ENDIF
      * RESET
     C                     MOVELACPLSH    SVPLSH
     C                     MOVELACNONY    SVNONY
     C                     MOVELACNKOJ    SVNKOJ
     C                     MOVELACNUKE    SVNUKE
     C                     MOVELACBIN     SVBIN
     C                     MOVELACODRN    SVODRN
     C                     MOVELACMHN1    SVMHN1
     C                     MOVELACMHN2    SVMHN2
     C                     MOVELACMHN3    SVMHN3
     C                     MOVELACMHN4    SVMHN4
     C                     MOVELACUPID    SVUPID
     C                     Z-ADD0         @QNTY
     C                     Z-ADD0         @CNT
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  UPDATE AB#PP2A                                    *
      *----------------------------------------------------*
     C           #UPD      BEGSR
      *
     C                     CALL 'AB#R0I4'
     C                     PARM           $UPD
     C                     PARM           SVPLSH
     C                     PARM           SVNONY
     C                     PARM           SVNKOJ
     C                     PARM           SVNUKE
     C                     PARM           SVBIN
     C                     PARM           SVODRN
     C                     PARM           SVMHN1
     C                     PARM           SVMHN2
     C                     PARM           SVMHN3
     C                     PARM           SVMHN4
     C                     PARM           @QNTY
     C                     PARM           @CNT
     C                     PARM           $RTN2   1
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $UPD    1
     C                     PARM           $RTN1   1
      *
     C                     MOVE *BLANK    $RTN1
     C                     MOVE *BLANK    $RTN2
     C                     TIME           @DATE
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         SEQ#    50
     C                     Z-ADD88        LIN#    30
     C                     Z-ADD0         @QNTY
     C                     Z-ADD0         @CNT    20
      *
     C           *LIKE     DEFN ACPLSH    SVPLSH
     C           *LIKE     DEFN ACNONY    SVNONY
     C           *LIKE     DEFN ACNKOJ    SVNKOJ
     C           *LIKE     DEFN ACNUKE    SVNUKE
     C           *LIKE     DEFN ACBIN     SVBIN
     C           *LIKE     DEFN ACODRN    SVODRN
     C           *LIKE     DEFN ACMHN1    SVMHN1
     C           *LIKE     DEFN ACMHN2    SVMHN2
     C           *LIKE     DEFN ACMHN3    SVMHN3
     C           *LIKE     DEFN ACMHN4    SVMHN4
     C           *LIKE     DEFN ACUPID    SVUPID
     C           *LIKE     DEFN ACQNTY    @QNTY
      *
     C                     ENDSR
      ************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                         $UPD      12
     O                                   40 '** HONDA DUPLICATE O'
     O                                   60 'RDER LIST (AB#PP2A) '
     O                                   80 '**                  '
     O                         TODAY     98 '    .  .  '
     O                         NOW      108 '0 :  :  '
     O                                  112 'P.'
     O                         PAGE  Z  116
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   15 'SHP_DATE'
     O                                   23 'DELV'
     O                                   26 'F'
     O                                   31 'DOCK'
     O                                   37 'BIN#'
     O                                   44 'ORDER#'
     O                                   65 'PART1'
     O                                   72 'PART2'
     O                                   79 'PART3'
     O                                   86 'PART4'
     O                                   93 'QTY'
     O                                   99 'COUNT'
     O        E 1              @DTL
     O                         SEQ#  Z +000
     O                         SVPLSH  +002 '    /  /  '
     O                         SVNONY  +002
     O                         SVNKOJ  +002
     O                         SVNUKE  +002
     O                         SVBIN   +002
     O                         SVODRN  +002
     O                         SVMHN1  +002
     O                         SVMHN2  +002
     O                         SVMHN3  +002
     O                         SVMHN4  +002
     O                         @QNTY Z +001
     O                         @CNT  Z +004
