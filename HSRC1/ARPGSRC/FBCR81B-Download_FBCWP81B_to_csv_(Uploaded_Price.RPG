     H            Y.
     F****************************************************************
     F*  PROGRAM    : FBCR81B                                        *
     F*  WRITTEN    : JW (SRA) 2025.03.10                            *
     F*  FUNCTION   : READ FBCWP81 AND UTPUT TO FBCWP81B (CSV)       *
     F****************************************************************
     FFBCWP81 IF  E           K        DISK
     FFBCWP81BO   E                    DISK
      *---------------------------------------------------------------
     E                    TBL     1  10 20
      *---------------------------------------------------------------
     I            DS
     I                                        1  20 F8MHIN
     I                                        1   5 F8MHN1
     I                                        6  10 F8MHN2
     I                                       11  15 F8MHN3
     I                                       16  20 F8MHN4
     I            DS
     I                                        1  12 F8SHIN
     I                                        1   5 F8SHN1
     I                                        6  10 F8SHN2
     I                                       11  12 F8SHN3
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ******************************************************
      *                    MAIN PROCESS
      ******************************************************
      * Initial Process
     C                     EXSR #INIT
      *
     C           *LOVAL    SETLLFBCWP81
     C                     DO   *HIVAL
     C                     READ FBCWP81                  98
     C   98                LEAVE
      *
     C                     EXSR #WRT1
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ******************************************************
      *  EDIT DATA
      ******************************************************
     C           #WRT1     BEGSR
      *
     C                     ADD  1         SEQ#
     C           SEQ#      IFEQ 1
     C                     EXSR #HDR1
     C                     ENDIF
      *
     C                     CLEARFBCW81B1
     C                     MOVELSEQ#      F1SEQ#
      *
     C                     MOVELF8MHIN    $MHIN
     C                     CALL 'EDTR02A'
     C                     PARM           $MHIN  20
     C                     PARM           $MHIN2 23
     C                     MOVEL$MHIN2    F1MHIN
      *
     C                     MOVELF8PLNT    F1PLNT
     C                     MOVELF8TOKU    F1TOKU
     C                     MOVELF8NONY    F1NONY
      *
     C                     Z-ADDF8UP      $IN
     C                     CALL 'EDTR05A'
     C                     PARM           $IN    156
     C                     PARM           $TRUE  17
     C                     PARM           $RTN    1
     C                     MOVEL$TRUE     F1UP
      *
     C                     MOVELF8EFDT    $DATE1
     C                     MOVE 'YMD'     $YMD
     C                     MOVE '/'       $SEP
     C                     CALL 'EDTR01A'
     C                     PARM           $DATE1  8
     C                     PARM           $YMD    3
     C                     PARM           $SEP    1
     C                     PARM           $DATE2 10
     C                     MOVEL$DATE2    F1EFDT
      *
     C                     MOVEL'9999/99/'F1EXDT
     C                     MOVE '99'      F1EXDT
      *
     C                     MOVELF8SHIN    $SHIN
     C                     CALL 'EDTR02'
     C                     PARM           $SHIN  12
     C                     PARM           $SHIN2 14
     C                     MOVEL$SHIN2    F1SHIN
      *
     C                     MOVELTODAY     $DATE1
     C                     MOVELNOW       $TIME1
     C                     MOVE 'YMD'     $YMD
     C                     CALL 'EDTR01 '
     C                     PARM           $DATE1  8
     C                     PARM           $TIME1  6
     C                     PARM           $YMD    3
     C                     PARM           $DATE2 10
     C                     PARM           $TIME2  8
     C                     MOVEL$DATE2    F1KOHZ
     C                     MOVEL$TIME2    F1KOTM
      *
     C                     MOVEL#USER     F1KOME
     C                     WRITEFBCW81B1
      *
     C                     ENDSR
      ******************************************************
      * CREATE HEADER
      ******************************************************
     C           #HDR1     BEGSR
      *
     C                     CLEARFBCW81B1
     C                     MOVEL'SEQ#    'F1SEQ#
     C                     MOVELTBL,1     F1MHIN
     C                     MOVEL'PLANT   'F1PLNT
     C                     MOVEL'CUST#   'F1TOKU
     C                     MOVEL'DELV#   'F1NONY
     C                     MOVEL'U/PRICE 'F1UP
     C                     MOVEL'EFT_DATE'F1EFDT
     C                     MOVEL'EXP_DATE'F1EXDT
     C                     MOVELTBL,2     F1SHIN
      *
     C                     MOVEL'UPD_DATE'F1KOHZ
     C                     MOVEL'UPD_TIME'F1KOTM
     C                     MOVEL'UPD_USER'F1KOME
     C                     WRITEFBCW81B1
      *
     C                     ENDSR
      *************************************
      * INITIAL ROUTINE
      *************************************
     C           #INIT     BEGSR
      *
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    50
      *
     C                     ENDSR
** TBL(20A)........2
CUST_PART#             1
IAF_PART#              2
                       3
                       4
                       5
                       6
                       7
                       8
                       9
                      10
