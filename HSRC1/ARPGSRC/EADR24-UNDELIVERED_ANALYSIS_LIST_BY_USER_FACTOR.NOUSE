     C                     RETRN
     C                     END
      *
     C           E4MIHZ    IFGT ENHZ
     C                     MOVEL'1'       *INLR
     C                     RETRN
     C                     END
      *
     C           E4SKJY    IFEQ 'D'
     C           E4SKHZ    ANDLE*DATE
     C                     GOTO @END
     C                     END
      *
     C           USR       IFNE 9999
     C           USR       CABNEE4NONY    @END
     C                     END
      *  ﾃcﾆﾞｭc xb
     C                     SETOF                     20
     C                     MOVE *BLANK    @KONM  15
     C           KEY2      CHAINGADPL131             20
     C           *IN20     IFEQ '0'
     C                     MOVELB5KMEI    @KONM
     C                     ELSE
     C                     MOVEL'UNKNWN'  @KONM
     C                     END
      *
     C                     SETOF                     15
     C                     MOVELE4NONY    @NONY   40       ﾉcpｬc
     C                     MOVE *BLANK    @NONM  16        ﾏｰﾅﾞｰNM
     C           @NONY     CHAINFGBPL011             15
     C           *IN,15    IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,15
     C                     END
      *
     C           *IN,15    IFEQ '0'
     C                     MOVELB2SMEI    @NONM
     C                     END
      *
     C                     MOVELE4NUKE    @NUKE   4        cibﾛ
     C                     MOVELE4SHN1    @HIN1   5        ﾍ]ﾌﾞ] 1
     C                     MOVELE4SHN2    @HIN2   5              2
     C                     MOVELE4SHN3    @HIN3   2              3
     C                     Z-ADDE4MIHZ    @MIHZ   80       vﾉc ﾍﾞ
     C                     Z-ADDE4MAIS    @MMIS   40       vﾉc ubﾇc
      *
     C                     SETOF                     50
     C                     Z-ADD0         WSYS    50
     C                     Z-ADD0         @STEI   30
     C                     MOVE *BLANK    BNCHI
     C           KEY4      CHAINFCEPL011             50
     C           *IN,50    IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,50
     C                     END
     C           *IN50     IFEQ '0'
      *
     C           A2SYHZ    IFGT *DATE
     C                     Z-ADDA2KSYS    WSYS
     C                     ELSE
     C                     Z-ADDA2SSYS    WSYS
     C                     END
      *
     C           A2TRHZ    IFGT *DATE
     C                     MOVE A2KTRK    BNT1
     C                     MOVE A2KTRT    BNT2
     C                     MOVE A2KTRR    BNT3
     C                     MOVE A2KTRD    BNT4
     C                     ELSE
     C                     MOVE A2STRK    BNT1
     C                     MOVE A2STRT    BNT2
     C                     MOVE A2STRR    BNT3
     C                     MOVE A2STRD    BNT4
     C                     END
      *
     C           BNT2      IFNE *BLANK
