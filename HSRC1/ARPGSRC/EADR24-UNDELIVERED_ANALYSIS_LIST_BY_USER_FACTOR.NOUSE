     C*  obﾆﾞ ﾇc
     C*
     C                     Z-ADDNYMD1     NYMD2
     C           NMM1      ADD  1         NMM2
     C           NMM2      IFEQ 13
     C                     Z-ADD01        NMM2
     C           NYY1      ADD  1         NYY2
     C                     END
      *
     C                     Z-ADDNYMD2     NYMD3
     C           NMM2      ADD  1         NMM3
     C           NMM3      IFEQ 13
     C                     Z-ADD01        NMM3
     C           NYY2      ADD  1         NYY3
     C                     END
      *
     C                     Z-ADD0         @CD1    31
     C                     Z-ADD0         @CD2    31
     C                     Z-ADD0         @CD3    31
      *
     C           KKEY1     SETLLAGDPL121
      *
     C                     DO   *HIVAL
     C                     SETOF                     09
     C           KKEY1     READEAGDPL121                 09
     C           *IN09     IFEQ '0'
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         @CD1
     C                     ELSE
      *
     C                     ADD  0.5       @CD1
     C                     END
      *
     C                     END
     C                     END
     C  N09                END
      *
     C           KKEY2     SETLLAGDPL121
      *
     C                     DO   *HIVAL
     C                     SETOF                     09
     C           KKEY2     READEAGDPL121                 09
     C           *IN09     IFEQ '0'
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
      *
     C           F8HIRU    IFEQ *BLANK
