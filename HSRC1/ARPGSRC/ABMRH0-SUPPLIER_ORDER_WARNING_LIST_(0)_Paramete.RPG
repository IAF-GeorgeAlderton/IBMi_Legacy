     H            Y.
     F** ABMRH0 **************************************
     F*仕入先　オーダー警告リスト
     F*     HOTTA.           2018.06.18              *
     F************************************************
     FABMPWH0 CF  E                    WORKSTN
     E                    ER      1  19 65
      *
     I            DS
     I                                        1   60W@NTYM
     I                                        1   40W@NTYY
     I                                        5   60W@NTMM
     I                                        7   80W@NTDD
      *
     I            DS
     I                                        1   80S@NTDT
     I                                        1   60S@NTYM
     I                                        1   40S@NTYY
     I                                        5   60S@NTMM
     I                                        7   80S@NTDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
     I              '0123456789'          C         WKCKSU
      *
     C           *ENTRY    PLIST
     C                     PARM           P@CMD   2
     C                     PARM           PRTG@  10
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      *  メインルーチン                                  *
      *----------------------------------------------------*
     C                     EXSR $SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR $SB200
     C                     ENDDO
     C                     EXSR $SB300
      *----------------------------------------------------*
      *   初期処理                                       *
      *----------------------------------------------------*
     CSR         $SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVE '01'      DSPSW   2
     C                     MOVE *BLANK    P@CMD   2
      *
     C                     MOVEL*BLANK    PRTG@
     C                     MOVEL*BLANK    D1OUTQ
      *
     CSR         $S100E    ENDSR
      *----------------------------------------------------*
      *   主処理                                         *
      *----------------------------------------------------*
     CSR         $SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR $SB210
     C                     ENDDO
      *
     CSR         $S200E    ENDSR
      *----------------------------------------------------*
      *   終了処理                                       *
      *----------------------------------------------------*
     CSR         $SB300    BEGSR
      *
     C                     SETON                     LR
     C                     RETRN
      *
     CSR         $S300E    ENDSR
      *----------------------------------------------------*
      *   第一画面表示                                   *
      *----------------------------------------------------*
     CSR         $SB210    BEGSR
      *
     C                     EXFMTABMPWH01
     C                     SETOF                     3099
     C                     MOVEL*BLANK    D1ERR
      * F1
     C           *IN01     IFEQ '1'
     C                     MOVE '01'      P@CMD   2
     C                     MOVE '99'      DSPSW
     C                     GOTO $S210E
     C                     ENDIF
     C           D1OUTQ    IFEQ '1'
     C           D1OUTQ    OREQ '2'
     C           D1OUTQ    OREQ '3'
     C           D1OUTQ    OREQ '4'
JW   C           D1OUTQ    OREQ '9'
     C                     ELSE
     C                     SETON                     3099
     C                     MOVELER,2      D1ERR
     C                     GOTO $S210E
     C                     ENDIF
      * F5
     C                     MOVEL*BLANK    PRTG@
      *
     C                     SELEC
     C           D1OUTQ    WHEQ '1'
     C                     MOVEL'QPRINT  'PRTG@
     C           D1OUTQ    WHEQ '2'
     C                     MOVEL'QPRINTC 'PRTG@
     C           D1OUTQ    WHEQ '3'
     C                     MOVEL'LANPRT03'PRTG@
     C           D1OUTQ    WHEQ '4'
     C                     MOVEL'QPRINTB 'PRTG@
JW   C           D1OUTQ    WHEQ '9'
     C                     MOVEL'EPRINT1 'PRTG@
     C                     ENDSL
      *
     C           *IN05     IFEQ '1'
     C           *IN99     IFEQ '0'
     C                     MOVE '05'      P@CMD   2
     C                     MOVE '99'      DSPSW
     C                     ENDIF
     C                     ENDIF
      *
     CSR         $S210E    ENDSR
