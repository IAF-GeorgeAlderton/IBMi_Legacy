      *
     C                     MOVELRN104     @@6     6
     C           @@6       LOKUPTAB1      TAB2           10
     C           *IN10     IFEQ *ON
     C                     MOVELTAB2      RATOKU
     C                     MOVE TAB2      RANONY
     C                     ENDIF
      *
     C                     ENDSR
