JW1   * SAVE AB#EP81 TO AB#EP81S
JW   C                     TIME           D#TIME
JW   C                     Z-ADDTODAY     RRCRDT
JW   C                     Z-ADDNOW       RRCRTM
JW1  C                     WRITEEB#E80S1
      *
     C           *INL1     IFEQ *ON
     C                     CLEARAB#EPRA1
      * CUSTOMER,SHIP TO
     C           RPRTNR    IFEQ 'FORD'
     C                     EXSR #FORD
     C                     ELSE
     C                     EXSR #SHTO
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     MOVELRREFE     RAREF#
     C                     MOVE RDATE     RADATE
     C                     MOVE RREPK     RARFQ1
     C                     MOVELRREF2     RARFN1
     C                     MOVELRRESI     RARFQ2
     C                     MOVELRREF3     RARFN2
     C                     MOVE RDTM1     RADTM1
     C                     MOVE RDTM2     RADAT2
     C                     Z-ADDRRQTY     RARQTY
     C                     Z-ADDRRTND     RARRQY
     C                     Z-ADDRQQTY     RAQQTY
     C                     MOVELRRCD8     RARCND
     C                     Z-ADDRRCD9     RASHQY
      * CUSTOMER PART#
     C                     MOVEARPART     MH1       P
     C                     MOVE *BLANK    MH2
     C                     Z-ADD*ZERO     Y       20
     C           1         DO   30        X       20
     C           MH1,X     IFNE '-'
     C           MH1,X     ANDNE'/'
     C           MH1,X     ANDNE'.'
     C           MH1,X     ANDNE*BLANK
     C                     ADD  1         Y
     C                     MOVE MH1,X     MH2,Y
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAMH2       WMHIN     P
      * IAF PART#
     C                     MOVELRATOKU    PTOKU   4
     C                     MOVEL*BLANK    PNKOJ   1
     C                     MOVEL*BLANK    PNUKE   4
     C                     MOVE RANONY    PNONY   4
     C                     MOVELWMHIN     @MHIN  20
     C                     MOVEL*BLANK    @SHIN  12
     C                     MOVEL*BLANK    @FLG    1
      *
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           @MHIN  20
     C                     PARM           @SHIN  12
     C                     PARM           @FLG    1
      *
     C                     MOVEL@SHIN     WSHIN
     C                     WRITEAB#EPRA1
      *-----------------------------------------------------------
      *  INITIALIZE
      *-----------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  SHIP TO
      *--------------------------------------------------------
     C           #FORD     BEGSR
      *
     C                     Z-ADD5149      RATOKU
     C                     MOVELRN104     @@5     5
     C           @@5       CHAINABF9P01              90
     C                     MOVELF9DELY    RANONY
      *
     C                     ENDSR
