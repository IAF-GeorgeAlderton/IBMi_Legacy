     C                     SELEC
     C           WWPROC    WHEQ 'LAN'
     C                     MOVE 'L'       W@KID
     C           WWPROC    WHEQ 'RL '
     C                     MOVE 'R'       W@KID
     C           WWPROC    WHEQ 'RT '
