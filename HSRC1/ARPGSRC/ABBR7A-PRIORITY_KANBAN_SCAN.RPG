     C*                    MAIN ROUTINE
     C**************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'00'      #SCRN0
     C           @@ID      CASEQ'01'      #SCRN1
     C           @@ID      CASEQ'02'      #SCRN2
     C           @@ID      CASEQ'03'      #SCRN3
     C           @@ID      CASEQ'04'      #SCRN4
     C           @@ID      CASEQ'11'      #SCR11
     C           @@ID      CASEQ'12'      #SCR12
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C**************************************************************************
     C*         INITIALIZE
     C**************************************************************************
     C           *INZSR    BEGSR
      *
     C           P#BRC     PLIST
     C                     PARM           PMAREA100
     C                     PARM           PMBYTE  3
     C                     PARM           PMCHK   1
     C                     PARM           PMRTCD  1
      *
     C           K#AP11    KLIST
     C                     KFLD           WWZETI
     C                     KFLD           WWORDR
      *
     C           K#KEY     KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
      *
     C           K#ABB     KLIST
     C                     KFLD           K@DATE  80
     C                     KFLD           D@SHFT
     C                     KFLD           WBAR
      *
     C           K#ABH     KLIST
     C                     KFLD           K@FCT   40
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
      *
     C           K#ABHX    KLIST
     C                     KFLD           K@FCT   40
     C                     KFLD           W@CPR1
     C                     KFLD           W@CPR2
     C                     KFLD           W@CPR3
      *
     C           K#AGD     KLIST
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C                     KFLD           K@DD    20
      *
TCHK4C                     TIME           WSDT
TCHK4C                     Z-ADDWSSYYY    K@YY
TCHK4C                     Z-ADDWSSMMM    K@MM
TCHK4C                     Z-ADDWSSDDD    K@DD
     C                     Z-ADD*ZERO     @@CNT   20
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C                     ADD  1         @@CNT
     C           @@CNT     IFEQ 7
     C                     Z-ADDF8YMD     @YMDB   80
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
TCHK4C                     Z-ADDWSSDAT    K@DATE
TCHK4C                     Z-ADDWSSDAT    W@DATE  80
TCHK4C*
     C                     Z-ADD0111      K@FCT
      *
     C                     MOVE '00'      @@ID    2
     C                     MOVE *BLANK    @@K     1
JW1  C                     MOVE *OFF      OWFLG   1        ONEWAY KANBAN
      *
TCHK4C                     Z-ADDWSSTM6    @@TIM   60
     C                     SELEC
     C           @@TIM     WHLE 120000
     C                     MOVE '3'       D@SHFT
     C           @@TIM     WHLE 170000
     C                     MOVE '1'       D@SHFT
     C           @@TIM     WHLE 240000
     C                     MOVE '2'       D@SHFT
     C                     ENDSL
     C*
     C                     ENDSR
     C*************************************************************************
     C*     SHIFT ENTRY
     C**************************************************************************
     C           #SCRN0    BEGSR
      *
     C                     EXFMTDSP00
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
      *
     C                     OTHER
     C                     EXSR #CHK0
     C           *IN99     IFEQ *OFF
     C                     MOVE '01'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
     C*************************************************************************
     C*     SHIFT ENTRY
     C**************************************************************************
     C           #CHK0     BEGSR
      *
     C                     SETOF                     6199
      *
     C           D@SHFT    IFLT '1'
     C           D@SHFT    ORGT '3'
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
     C*************************************************************************
     C*          IST SCREEN
     C**************************************************************************
     C           #SCRN1    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
      * F3: END
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
      * F7: CANCEL
     C           *INKG     WHEQ *ON
     C                     MOVE '03'      @@ID
      * F2: LOCATION ENTRY
     C           *INKB     WHEQ *ON
     C                     MOVE '11'      @@ID
      * F4: # OF PRV KANBAN
     C           *INKD     WHEQ *ON
     C           @@BRCD    IFEQ *BLANK
     C                     MOVE *ON       *IN99
     C                     MOVELERR,6     ERR1             "NO PREVIOUS "
     C                     MOVELERR,7     ERR2             "KANBAN      "
     C                     EXFMTERR01
     C                     ELSE
     C                     MOVE '02'      @@ID
     C                     MOVEL@@BRCD    D@KNBN
     C                     Z-ADD*ZERO     D@NBRS
     C                     Z-ADD@@LOT     D@LOT
     C           @@LOT     COMP *ZERO                1111
     C                     ENDIF
      * ENTR KEY
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #WRT
     C                     CLEARDSP01
     C                     ELSE
     C                     EXFMTERR01
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
     C*     CHECK
     C**************************************************************************
     C           #CHK1     BEGSR
     C*
     C                     MOVE *BLANK    ERR1                         F5
     C                     MOVE *BLANK    ERR2                         F5
     C                     SETOF                     996162
JW1  C                     MOVE *OFF      OWFLG
      *
     C           D@KNBN    IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     ERR1             "KANBAN ERROR"
JW   C                     MOVE '2'       ERR1             2
     C                     ELSE
      *
     C                     MOVE D@KNBN    WBAR
     C           WWZETI    CHAINFCETL11              90
B01  C           *IN90     IFEQ *ON
     C                     SETON                     9961
     C                     MOVELERR,1     ERR1             "KANBAN ERROR"
JW   C                     MOVE '3'       ERR1             3
     C                     ENDIF
      *
     C           K#ABB     CHAINABBPL72              90
     C           *IN90     IFEQ *OFF
     C                     SETON                     9961
     C                     MOVELERR,2     ERR1             "ALREADY"
     C                     MOVELERR,3     ERR2             "SCANNED"
JW   C                     MOVE '1'       ERR2             1
     C                     ENDIF
      * CHECK DIGIT
     C                     MOVELWBAR      PMAREA    P
     C                     MOVE '014'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     ERR1             "KANBAN ERROR"
JW   C                     MOVE '4'       ERR1             4
     C                     ELSE
     C           PMCHK     IFNE WWCHK
     C                     SETON                     9961
     C                     MOVELERR,1     ERR1             "KANBAN ERROR"
JW   C                     MOVE '5'       ERR1             5
     C                     ENDIF
     C                     ENDIF
      * IF NO ERROR .........
     C           *IN99     IFEQ *OFF
     C                     MOVE *BLANK    WWNXP   3
     C                     MOVE *BLANK    WWNCP   3
     C                     MOVE *BLANK    WWNLC   6
TCHK7C                     MOVEL*BLANK    W@LOCT
TCHK7C                     MOVEL*BLANK    W@MCHN
TCHK7C                     MOVEL*BLANK    W@CPRT
TCHK7C                     MOVEL*BLANK    W@CMNT
TCHK7C                     MOVEL*BLANK    W@RTN   1
      *
     C                     SELEC
      *------------------------------------------------
     C           WWKANS    WHGE '0'
     C           WWKANS    ANDLE'9'
      *
     C                     Z-ADD1         D@NBRS
     C                     Z-ADD*ZERO     W@ISDT  80
      * LOCATION
TCHK6C                     CLEAR@RC
TCHK6C                     CLEAR@OC
TCHK6C                     CLEAR@K
TCHK6C                     CLEAR@CN
TCHK6C                     CLEAR@RT
     C           K#KEY     CHAINAAMPL11              90
TCHK6C           *IN90     IFEQ *OFF
TCHK6C                     EXSR #SET1@
TCHK6C                     END
TCHK7C* SEARCH CURRENT
     C           WWPROC    IFEQ 'YSL'
     C                     MOVE 'SL '     WWPROC
     C                     ENDIF
      *
     C                     Z-ADD1         X       20
TCHK6C           WWPROC    LOKUP@RC,X                    10
      * IF PROCESS NOT FOUND, DEFAULT PROCESS = LATEST PROCESS
     C           *IN10     IFEQ *OFF
     C                     MOVE ' '       WWPROC
TCHK6C           WWPROC    LOKUP@RC,X                    10
     C                     ENDIF
      *
     C           *IN10     IFEQ *ON
     C           X         DO   15        XX      20
     C           @OC,XX    IFNE '------'
     C           @OC,XX    ANDNE'++++++'
     C           @OC,XX    ANDNE*BLANK
     C                     MOVE @RC,XX    WWNXP   3
     C                     MOVE @CN,XX    WWNCP   3
     C                     MOVE @OC,XX    WWNLC   6
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     DO   15
     C                     SUB  1         X
     C           X         IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
      *
TCHK5C           @OC,X     IFEQ '------'
TCHK5C           @OC,X     OREQ '++++++'
TCHK5C                     ITER
TCHK5C                     END
      *
TCHK7C                     MOVEL'1'       W@RTN   1
     C                     EXSR #CMT
      *
     C                     LEAVE
     C                     ENDDO
      *
     C                     ENDIF
TCHK7C* SEARCH NEW
TCHK7C           *IN10     IFEQ *OFF
TCHK7C           WWPROC    LOKUPPRC,X                    10
TCHK7C           *IN10     IFEQ *ON
TCHK7C           X         DO   15        XX      20
TCHK7C           LOC,XX    IFNE '------'
TCHK7C           LOC,XX    ANDNE'++++++'
TCHK7C           LOC,XX    ANDNE*BLANK
TCHK7C                     MOVE PRC,XX    WWNXP   3
TCHK7C                     MOVE MCN,XX    WWNCP   3
TCHKKC                     MOVE LOC,XX    WWNLC   6
TCHK7C                     LEAVE
TCHK7C                     ENDIF
TCHK7C                     ENDDO
TCHK7C                     DO   15
TCHK7C                     SUB  1         X
TCHK7C           X         IFEQ *ZERO
TCHK7C                     LEAVE
TCHK7C                     ENDIF
TCHK7C           LOC,X     IFEQ '------'
TCHK7C           LOC,X     OREQ '++++++'
TCHK7C                     ITER
TCHK7C                     END
TCHK7C                     MOVEL'2'       W@RTN   1
TCHK7C                     EXSR #CMT
TCHK7C                     LEAVE
TCHK7C                     ENDDO
TCHK7C                     END
TCHK7C                     END
TCHK7C* SEARCH OLD
TCHK7C           *IN10     IFEQ *OFF
TCHK7C           WWPROC    LOKUPPRO,X                    10
TCHK7C           *IN10     IFEQ *ON
TCHK7C           X         DO   15        XX      20
TCHK7C           LOX,XX    IFNE '------'
TCHK7C           LOX,XX    ANDNE'++++++'
TCHK7C           LOX,XX    ANDNE*BLANK
TCHK7C                     MOVE PRO,XX    WWNXP   3
TCHK7C                     MOVE MCX,XX    WWNCP   3
TCHKKC                     MOVE LOX,XX    WWNLC   6
TCHK7C                     LEAVE
TCHK7C                     ENDIF
TCHK7C                     ENDDO
TCHK7C                     DO   15
TCHK7C                     SUB  1         X
TCHK7C           X         IFEQ *ZERO
TCHK7C                     LEAVE
TCHK7C                     ENDIF
TCHK7C           LOX,X     IFEQ '------'
TCHK7C           LOX,X     OREQ '++++++'
TCHK7C                     ITER
TCHK7C                     END
TCHK7C                     MOVEL'3'       W@RTN   1
TCHK7C                     EXSR #CMT
TCHK7C                     LEAVE
TCHK7C                     ENDDO
TCHK7C                     END
TCHK7C                     END
