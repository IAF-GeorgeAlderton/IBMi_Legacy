     H            Y.
     F** T#TR71 *********************************************
     F*前後ロット違い
     F*       SAMEJIMA.            2015.10.16               *
     F*******************************************************
     FAAMPL11 IF  E           K        DISK
     FT#TWP71 O   E                    DISK                      A
     FABHPL03 IF  E           K        DISK
     FADHPL03 IF  E           K        DISK
     E                    OKT        15  3               工程
     E                    OTK        15  6               所番地
     E                    OSY        15  1               か種
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
      *
     I            DS
     I                                        1   80WKDATE
     I                                        1   40WKDAYY
     I                                        5   60WKDAMM
     I                                        7   80WKDADD
      *
     I            DS
     I                                        1   6 WKTKR
     I                                        1   1 WKTKR1
     I                                        2   3 WKTKR2
     I                                        4   5 WKTKR3
     I                                        6   6 WKTKR4
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     MOVEL'1'       OPNCLS
     C                     TIME           SDATE
      *
     C           *LOVAL    SETLLAAMPL111
     C                     READ AAMPL111                 80
     C           *IN80     DOWEQ'0'
     C           CKSKJY    IFEQ 'D'
     C           CKSKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #SB400
     C                     ENDIF
     C                     READ AAMPL111                 80
     C                     ENDDO
      *
     C           OPNCLS    IFEQ '0'
     C                     MOVE '9'       OPNCLS
     C                     CALL 'AAMRSB'
     C                     PARM           A2BHB1  5
     C                     PARM           A2BHB2  5
     C                     PARM           A2BHB3  2
     C                     PARM           OPNCLS  1
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEA*BLANK    OKT
     C                     MOVEA*BLANK    OTK
     C                     MOVEA*BLANK    OSY
     C                     CALL 'AAMRSB'
      *入力パラメータ
     C                     PARM           CKHIN1  5
     C                     PARM           CKHIN2  5
     C                     PARM           CKHIN3  2
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     MOVEL'0'       OPNCLS
     C                     MOVEAPKOT      OKT
     C                     MOVEAPTKR      OTK
     C                     MOVEAPSHR      OSY
      *
     C                     Z-ADD1         X       30
     C                     MOVEL'0'       GET     1
     C           X         DOWLE14
     C           OTK,X     IFNE '------'
     C                     EXSR #SB410
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     CSR         #SB410    BEGSR
      *
     C                     Z-ADD0         WKLOT1  30
     C                     Z-ADD0         WKLOT2  30
     C                     MOVEL*BLANK    WKKOT1  3
     C                     MOVEL*BLANK    WKKOT2  3
     C                     MOVELOKT,X     WKKOT1  3
     C                     MOVELOTK,X     WKTKR
     C                     MOVELOSY,X     WKSY    1
     C           KEYT      KLIST
     C                     KFLD           WKTKR1
     C                     KFLD           WKTKR2
     C                     KFLD           WKTKR3
     C                     KFLD           WKTKR4
      *自工程のロット                                    *
     C                     EXSR #SB490
     C                     Z-ADDWKLOT     WKLOT1  30
      *後工程のロット                                    *
     C           X         ADD  1         X2      30
     C                     MOVEL'0'       WKJI    1
     C           X2        DOWLE15
     C           WKJI      ANDEQ'0'
     C           OTK,X2    IFNE '------'
     C                     MOVEL'1'       WKJI    1
     C                     MOVELOKT,X2    WKKOT2  3
     C                     MOVELOTK,X2    WKTKR
     C                     MOVELOSY,X2    WKSY
     C                     EXSR #SB490
     C                     Z-ADDWKLOT     WKLOT2  30
     C                     ENDIF
     C                     ADD  1         X2
     C                     ENDDO
      *
     C           WKLOT1    IFNE 0
     C           WKLOT2    ANDNE0
     C           WKLOT1    ANDNEWKLOT2
     C                     EXSR #SB500
     C                     ENDIF
      *
     CSR         ESB410    ENDSR
      *----------------------------------------------------*
      *ロット                                            *
      *----------------------------------------------------*
     CSR         #SB490    BEGSR
      *
     C                     Z-ADD0         WKLOT   30
     C                     SELEC
     C           WKSY      WHEQ 'A'
     C           KEYT      SETGTABHPL031
     C           KEYT      REDPEABHPL031                 83
     C           *IN83     IFEQ '0'
     C                     Z-ADDM6LOTK    WKLOT
     C                     ENDIF
     C           WKSY      WHEQ 'B'
     C           KEYT      SETGTADHPL031
     C           KEYT      REDPEADHPL031                 83
     C           *IN83     IFEQ '0'
     C                     Z-ADDJ6LOTO    WKLOT
     C                     ENDIF
     C                     ENDSL
      *
     CSR         ESB490    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEART#TWP711
     C                     MOVELCKHIN1    W1HIN1
     C                     MOVELCKHIN2    W1HIN2
     C                     MOVELCKHIN3    W1HIN3
     C                     MOVELWKKOT1    W1KOT1
     C                     Z-ADDWKLOT1    W1LOT1
     C                     MOVELWKKOT2    W1KOT2
     C                     Z-ADDWKLOT2    W1LOT2
     C                     WRITET#TWP711
      *
     CSR         ESB500    ENDSR
