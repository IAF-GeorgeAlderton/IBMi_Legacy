     C           *ENTRY    PLIST
     C                     PARM           PHM     4
     C                     CALL 'ADKR90'
     C                     PARM           PHM     4
     C                     PARM           P1APHZ  80
     C                     PARM           P1APBN  20
      *便数
     C                     Z-ADD0         WKCIBI  20
     C           0111      CHAINAAIPL111             20
     C           *IN20     IFEQ '0'
     C                     Z-ADDCDCIBI    WKCIBI
     C                     ENDIF
      *
     C                     TIME           WDATE
     C                     READ ADKWP20                  80
     C           *IN80     DOWEQ'0'
     C           CASKJY    IFEQ 'D'
     C                     ELSE
     C                     EXSR #SB400
     C                     ENDIF
     C                     READ ADKWP20                  80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------*
      *                                      *
      *--------------------------------------*
     CSR         #SB400    BEGSR
      *
     C           KEYAGA    KLIST
     C                     KFLD           CASHN1
     C                     KFLD           CASHN2
     C                     KFLD           CASHN3
     C           KEYAGA    CHAINAGAPL411             22
     C           *IN22     IFEQ '0'
     C           CBSKJY    IFEQ 'D'
     C           CBSKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #SB500
      *バレル端数をゼロにする
     C                     Z-ADD0         CBHASU
     C                     UPDATAGAPL411
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *--------------------------------------*
      *                                      *
      *--------------------------------------*
     CSR         #SB500    BEGSR
      *指定便
     C                     Z-ADD0         SITEBN  20
     C                     Z-ADD1         X       30
     C           X         DOWLE24
     C           CBTR,X    IFNE 0
     C                     ADD  1         SITEBN
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     C                     CLEARADKWP211
     C                     MOVELCASKJY    W1SKJY
     C                     Z-ADDCATOKU    W1TOKU
     C                     MOVELCATKOJ    W1TKOJ
     C                     MOVELCATUKE    W1TUKE
     C                     Z-ADDCANONY    W1NONY
     C                     MOVELCANKOJ    W1NKOJ
     C                     MOVELCANUKE    W1NUKE
     C                     MOVELCAMHN1    W1MHN1
     C                     MOVELCAMHN2    W1MHN2
     C                     MOVELCAMHN3    W1MHN3
     C                     MOVELCASHN1    W1SHN1
     C                     MOVELCASHN2    W1SHN2
     C                     MOVELCASHN3    W1SHN3
     C                     Z-ADDCABMON    W1BMON
     C                     MOVELCAKJYN    W1KJYN
     C                     MOVELCAKOBI    W1KOBI
     C                     MOVELCASEBN    W1SEBN
     C                     MOVELCASKKB    W1SKKB
     C                     Z-ADDCAHAKO    W1HAKO
     C                     Z-ADDCBSYUY    W1SYUY
     C                     MOVELCATHAI    W1THAI
     C                     MOVELCAKBAN    W1KBAN
     C                     MOVELCANBAN    W1NBAN
     C                     Z-ADDCANSRY    W1NSRY
     C                     Z-ADDCAOSRY    W1OSRY
     C                     MOVELCABNKA    W1BNKA
     C                     Z-ADDCABNSI    W1BNSI
     C                     Z-ADDCABNBO    W1BNBO
     C                     Z-ADDCATEYY    W1TEYY
     C                     Z-ADDCATEMM    W1TEMM
     C                     Z-ADDCATEDD    W1TEDD
     C                     Z-ADDCATEHH    W1TEHH
     C                     Z-ADDCATEFN    W1TEFN
     C                     MOVELCABAN1    W1BAN1
     C                     MOVELCABAN2    W1BAN2
     C                     MOVELCABAN3    W1BAN3
     C                     MOVELCABAN4    W1BAN4
     C                     Z-ADDCASAI1    W1SAI1
     C                     Z-ADDCASAI2    W1SAI2
     C                     Z-ADDCASAI3    W1SAI3
     C                     Z-ADDCANOYY    W1NOYY
     C                     Z-ADDCANOMM    W1NOMM
     C                     Z-ADDCANODD    W1NODD
     C                     Z-ADDCANOBB    W1NOBB
     C                     MOVELCAGYOM    W1GYOM
     C                     MOVELCADTSY    W1DTSY
     C                     MOVELCADTSO    W1DTSO
     C                     Z-ADDCASAYY    W1SAYY
     C                     Z-ADDCASAMM    W1SAMM
     C                     Z-ADDCASADD    W1SADD
     C                     Z-ADDCASAJI    W1SAJI
     C                     Z-ADDCASAPN    W1SAPN
     C                     Z-ADDCAJTNO    W1JTNO
     C                     Z-ADDCBBARL    W1BARL
     C                     Z-ADDCBHASU    W1HASU
     C           CBSYUY    MULT CBBARL    W1BSRY
      *バレル端数を今回数量に加える
     C           CANSRY    ADD  CBHASU    W1SRYO
     C                     Z-ADDP1APHZ    W1APHZ
     C                     Z-ADDP1APBN    W1APBN
      *上限計算
     C                     Z-ADDW1APHZ    P1APHZ
     C                     Z-ADDW1APBN    P1APBN
     C                     MOVELW1SHN1    P1SHN1
     C                     MOVELW1SHN2    P1SHN2
     C                     MOVELW1SHN3    P1SHN3
     C                     Z-ADDWKCIBI    P1CIBI
     C                     Z-ADD0         P9ALL
     C                     Z-ADD0         P9HND
     C                     Z-ADD0         P9RNJ
     C                     Z-ADD0         P9SRYO
     C                     Z-ADD0         P9LIMD
     C                     Z-ADD0         P9LIMB
     C                     CALL 'ADKR9B'
     C                     PARM           P1APHZ  80
     C                     PARM           P1APBN  20
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1CIBI  20
     C                     PARM           P9ALL   50
     C                     PARM           P9HND   50
     C                     PARM           P9RNJ   50
     C                     PARM           P9SRYO 120
     C                     PARM           P9LIMD 120
     C                     PARM           P9LIMB 120
     C                     PARM           P9RTCD  1
     C                     Z-ADDP9ALL     W1ALL
     C                     Z-ADDP9HND     W1HND
     C                     Z-ADDP9RNJ     W1RNJ
     C                     Z-ADDP9LIMD    W1LIMD
     C                     Z-ADDP9LIMB    W1LIMB
     C                     Z-ADDP9SRYO    W1LIMT
     C                     MOVELP9RTCD    W1RTCD
      *連続上限カット回数
     C                     EXSR #SB590
     C                     Z-ADDWKTIMS    W1TIMS
     C           SITEBN    IFEQ 0
     C                     MOVEL'1'       W1TRBN
     C                     ELSE
     C                     MOVEL'0'       W1TRBN
     C                     ENDIF
      *工程情報
     C                     MOVELW1SHN1    P1SHN1
     C                     MOVELW1SHN2    P1SHN2
     C                     MOVELW1SHN3    P1SHN3
     C                     MOVELCBKDAI    P1KDAI  1
     C                     Z-ADDW1APHZ    P1APHZ
     C                     Z-ADDW1APBN    P1APBN
     C                     CALL 'ADKR44'
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1APHZ  80
     C                     PARM           P1APBN  20
     C                     PARM           P9DATA  1
     C                     PARM           P9CODE  1
     C                     PARM           P9GROP  2
     C                     PARM           P9PROC  3
     C                     PARM           P9KBN   3
     C                     MOVELP9DATA    W1DATA
     C                     MOVELP9CODE    W1CODE
     C                     MOVELP9GROP    W1GROP
     C                     MOVELP9PROC    W1PROC
     C                     MOVELP9KBN     W1KBN
      *
     C                     WRITEADKWP211
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      *連続上限カット回数                                *
      *----------------------------------------------------*
     CSR         #SB590    BEGSR
      *
     C                     Z-ADD0         WKTIMS  50
     C           KEY00     KLIST
     C                     KFLD           W1APHZ
     C                     KFLD           W1APBN
     C                     MOVEL'0'       ENDSW   1
      *生産指示実行履歴を最後から読む
     C           KEY00     SETGTADKPP051
     C                     READPADKPP051                 88
     C           *IN88     DOWEQ'0'
     C           ENDSW     ANDEQ'0'
     C           ZZSKJY    IFEQ 'D'
     C           ZZSKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #SB591
     C                     ENDIF
     C                     READPADKPP051                 88
     C                     ENDDO
      *
     CSR         ESB590    ENDSR
      *----------------------------------------------------*
      *連続上限カット回数                                *
      *----------------------------------------------------*
     CSR         #SB591    BEGSR
      *
     C           KEY26     KLIST
     C                     KFLD           W1SHN1
     C                     KFLD           W1SHN2
     C                     KFLD           W1SHN3
     C                     KFLD           ZZAPHZ
     C                     KFLD           ZZAPBN
      *該当の生産指示実行日便のデータがあり、上限カットあれば
      *回数をカウントアップ
     C                     MOVEL'0'       GET26   1
     C           KEY26     SETLLADKPL261
     C           KEY26     READEADKPL261                 82
     C           *IN82     DOWEQ'0'
     C           GET26     ANDEQ'0'
     C           D2SKJY    IFEQ 'D'
     C           D2SKHZ    ANDLE*DATE
     C                     ELSE
     C           D2CUT     IFGT 0
     C           D2CUT     ANDGED2BSRY
     C                     MOVEL'1'       GET26   1
     C                     ENDIF
     C                     ENDIF
     C           KEY26     READEADKPL261                 82
     C                     ENDDO
     C           GET26     IFEQ '0'
     C                     MOVEL'1'       ENDSW
     C                     ELSE
     C                     ADD  1         WKTIMS
     C                     ENDIF
      *
     CSR         ESB591    ENDSR
