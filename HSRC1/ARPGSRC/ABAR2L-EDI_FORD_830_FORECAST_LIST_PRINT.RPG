     H            Y.
     F** ABAR2L *********************************************
     F*  FORD EDI830 FORECAST LIST                          *
     F*  TCH 00.06.19                                       *
     F*                                                     *
     F*  *IN30=1 (FIRST ABFPP20 RECORD)                     *
     F*  *IN90=1 (NOT READ ABFPP20)                         *
     F*  *IN93=1 (NOT READ FCEPL01)                         *
     F*  *IN95=0 (FIRST RECORD)                             *
     F******************************************* ABAR2K ****
     FABFPL11 UP  E           K        DISK
     FABFPL20 UF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FQPRINT3 O   F     132     OF     PRINTER
     ********************************************************
     ********************************************************
     IABFPP101    01
     I                                              FBDOCK
     I                                              FBPART
     I                                              FBSIDT
     I* SYSTEM DATE
     I            DS
     I                                        1  120WTIME
     I                                        1   60SYTM1
     I                                        7  120SYDT1
     I* PART NUMBER OF ABFPP10
     I            DS
     I                                        1  12 FBIPAR
     I                                        1   5 #PAR1
     I                                        6  10 #PAR2
     I                                       11  12 #PAR3
     I* CHANGE DATE OF PART MASTER
     I            DS
     I                                        1   80CDATE
     I                                        1   40CDAT1
     I                                        5   60CDAT2
     I                                        7   80CDAT3
     I                                        3   80CDAT
      ***********************************************************
     C                     TIME           WTIME
     C*
     C* DEFINE PARM1 AND PARM2 AS PARAMETER FROM INPUT FILE
     C           *ENTRY    PLIST
     C                     PARM           PUSR   10
     C*
     C* DEFINE KEY1 (ABFPP20)
     C           KEY1      KLIST
     C                     KFLD           FBDOCK
     C                     KFLD           FBPART
     C                     KFLD           FBSIDT
     C*
     C           KEY2      KLIST
     C                     KFLD           #PAR1   5
     C                     KFLD           #PAR2   5
     C                     KFLD           #PAR3   2
     C*
     C                     MOVELPUSR      WUSR    7
     C*
     C*
     C           FBDOCK    IFEQ 'APNAA'
     C*GET SYOSU
     C           KEY2      CHAINFCEPL011             93
     C           *IN93     IFEQ '0'
     C                     MOVE A2SSYS    WSYSU   50
     C*
     C                     ELSE
     C                     Z-ADD*ZERO     WSYSU
     C                     END
     C*
     C                     MOVE '1'       FBPRNT
     C                     UPDATABFPP101
     C*
     C           *IN95     IFEQ '0'
     C                     EXCPT#HED1
     C                     SETON                     95
     C                     END
     C*
     C                     EXCPT#DTL1
     C                     EXSR @WRT2
     C*
     C                     END
     C*****************************************************************
     C*     @SYOS:CALCULATION WITH REMAINDER
     C*****************************************************************
     C           @WRT2     BEGSR
     C*
     C                     SETON                     30
     C*
     C           KEY1      SETLLABFPP201
     C           KEY1      READEABFPP201                 90
     C           *IN90     DOWEQ'0'
     C                     EXCPT#PP20
     C*
     C                     MOVE '1'       FDPRNT
     C                     UPDATABFPP201
     C                     SETOF                     30
     C           KEY1      READEABFPP201                 90
     C                     END
     C*
     C                     ENDSR
     C********************************************************
     OQPRINT3 E    2           #HED1
     O       OR        OF
     O                                  131 '.....................'
     O*
     O        E 1              #HED1
     O       OR        OF
     O                                  131 '.         .         .'
     O*
     O        E 1              #HED1
     O       OR        OF
     O                                   89 'TIME'
     O                         SYTM1     98 '  :  :  '
     O                                  112 '. '
     O                         WUSR     119
     O                                  131 '.         .'
     O*
     O        E 11             #HED1
     O       OR        OF
     O                                    8 'ABAR2L'
     O                                   50 'EDI FORD 830 FOR'
     O                                   60 'ECAST LIST'
     O                                   89 'DATE'
     O                         SYDT1 Y   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O                                  131 '.....................'
     O*
     O        E 1              #HED1
     O                                   22 'SCHEDULE'
     O                                   31 'START'
     O                                   40 'END'
     O                                   56 'QTY/'
     O                                   66 '<<<'
     O                                   84 'FABRICATION'
     O                                   94 '>>>'
     O                                  102 '<<<'
     O                                  112 'RAW'
     O                                  121 'MATERIAL'
     O                                  130 '>>>'
     O        E 1              #HED1
     O                                    5 'PART'
     O                                   22 'DATE'
     O                                   31 'DATE'
     O                                   40 'DATE'
     O                                   56 'CNT'
     O                                   71 'START'
     O                                   80 'END'
     O                                   94 'CUM QTY'
     O                                  107 'START'
     O                                  116 'END'
     O                                  130 'CUM QTY'
     O*
     O        E 1              #DTL1
     O                         FBIPAR    13
     O                         FBSIDT    22 '0 /  /  '
     O                         FBHSDT    31 '0 /  /  '
     O                         FBHEDT    40 '0 /  /  '
     O                         WSYSU     56 '  ,   '
     O*
     O                         FBFISD    71 '0 /  /  '
     O                         FBFIED    80 '0 /  /  '
     O                         FBFIQT    94 ' ,   ,   ,   '
     O*
     O                         FBMTSD   107 '0 /  /  '
     O                         FBMTED   116 '0 /  /  '
     O                         FBMTQT   130 ' ,   ,   ,   '
     O*
     O        E 1      30      #PP20
     O                 30                27 '<<< NOTE >>>'
     O*
     O        E 1              #PP20
     O                         FDNOTE   115
