     C           #KEY      KLIST
     C                     KFLD           #HIN1   5
     C                     KFLD           #HIN2   5
     C                     KFLD           #HIN3   2
      *
     C           *ENTRY    PLIST
     C                     PARM           PCMD3   1        * CMD-3
     C                     PARM           PARM1   1        * f]ﾌﾞ] ﾆｬﾓb
     C                     PARM           PARM2   1        * d[-ﾃ-nﾞ
     C                     PARM           PARM3   5        * ﾍ] 1
     C                     PARM           PARM4   5        * ﾍ] 2
     C                     PARM           PARM5   2        * ﾍ] 3
      *
     C                     MOVE *BLANK    SW1     1
     C                     MOVE PARM3     #HIN1   5
     C                     MOVE PARM4     #HIN2   5
     C                     MOVE PARM5     #HIN3   2
     C           #KEY      CHAINAAMPL111             31
TCHK1C           *IN31     IFEQ '0'
TCHK1C           CKSKJY    ANDEQ'D'
TCHK1C           CKSKHZ    ANDLE*DATE
TCHK1C                     SETON                     31
TCHK1C                     END
     C           *IN31     IFEQ '1'
     C                     MOVE 'E'       PARM2
     C                     GOTO LAST
     C                     ELSE
TCHK C*                    Z-ADD15        X       20
TCHK C                     Z-ADD1         X       20
     C                     DO   15
     C           PARM1     IFEQ 'X'
     C           AR2,X     IFNE *BLANK
     C                     GOTO SRATCH
     C                     END
     C                     ELSE
     C           AR2,X     IFEQ PARM1
     C                     GOTO SRATCH
     C                     END
     C                     END
     C                     GOTO LOOP
     C           SRATCH    TAG
      *
     C******************************************************
     C* CALL PROGRAM FOR KANBAN MASTER INQUIRY             *
     C******************************************************
     C                     MOVE *BLANK    PARM2
     C                     MOVE *BLANK    WCMD3   1
     C                     MOVE HR1,X     NENBIN
     C                     MOVE AR1,X     WKBAN
     C           AR2,X     LOKUPTABX1     TABY1          20
     C           *IN20     IFEQ '1'
      *
     C                     CALL TABY1
     C                     PARM           WCMD3
     C                     PARM           WBAN1
     C                     PARM           WBAN2
     C                     PARM           WBAN3
     C                     PARM           WBAN4
     C                     PARM           HYY
     C                     PARM           HMM
     C                     PARM           HDD
     C                     PARM           BIN
     C                     PARM           PARM2
      *
     C           WCMD3     IFEQ '1'
     C                     MOVE '1'       PCMD3
     C                     GOTO LAST
     C                     END
      *
     C           PARM2     IFEQ *BLANK
     C                     MOVE '*'       SW1     1
     C                     END
     C                     END
      *
     C           LOOP      TAG
TCHK C*                    SUB  1         X
TCHK C                     ADD  1         X
     C                     END
     C                     END
      *
     C           SW1       IFNE '*'
     C                     MOVE '9'       PARM2
     C                     ELSE
     C                     MOVE *BLANK    PARM2
     C                     END
      *
JW1  C                     EXSR #DUMMY
      *
     C*************************
     C* END OF PROGRAM        *
     C*************************
     C           LAST      TAG
     C                     SETON                       LR
     C                     RETRN
     C*************************
JW1  C* DUMMY SUBROUTINE      *
 .   C*************************
 .   C           #DUMMY    BEGSR
 V    *
     C                     GOTO XDUMMY
