      * OPTION D
     C                     CALL 'AKAR21'
      * OPTION E
     C                     CALL 'AKAR22'
 A    * OPTION F
 .   C                     CALL 'AKAR32'
 .    *
JW1  C           XDUMMY    ENDSR
