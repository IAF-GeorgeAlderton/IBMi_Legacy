     H            Y.
     F** T#TR10 *********************************************
     F* SETTING #(MACHINE GROUP)                            *
     F*             Y.SAMEJIMA     2015.06.18               *
     F*******************************************************
     FABHPP01 IF  E                    DISK
     FABBPP7G IF  E           K        DISK
     FT#TWP10 O   E                    DISK                      A
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C*
     C           1         SETLLABHPP011
     C                     DO   *HIVAL
     C                     READ ABHPP011                 99
     C   99                LEAVE
     C                     EXSR #SB100
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*****************************************************************
     C           #SB100    BEGSR
     C*
     C           M6SKJY    IFNE *BLANK
     C                     GOTO ESB100
     C                     ENDIF
     C*
     C           M6STYY    IFNE 9999
     C                     GOTO ESB100
     C                     ENDIF
     C*
     C                     MOVEL*BLANK    @FLG    1
     C                     MOVEL*BLANK    @KOTE   3
     C           M6AKT1    IFEQ 'HD '
     C           M6AKT1    OREQ 'BM '
     C                     MOVELM6AKT1    @KOTE
     C                     MOVEL'1'       @FLG
     C                     EXSR #SB110
     C                     ENDIF
     C           M6AKT2    IFEQ 'HD '
     C           M6AKT2    OREQ 'BM '
     C                     MOVELM6AKT2    @KOTE
     C                     MOVEL'2'       @FLG
     C                     EXSR #SB110
     C                     ENDIF
     C           M6AKT3    IFEQ 'HD '
     C           M6AKT3    OREQ 'BM '
     C                     MOVELM6AKT3    @KOTE
     C                     MOVEL'3'       @FLG
     C                     EXSR #SB110
     C                     ENDIF
     C           M6AKT4    IFEQ 'HD '
     C           M6AKT4    OREQ 'BM '
     C                     MOVELM6AKT4    @KOTE
     C                     MOVEL'4'       @FLG
     C                     EXSR #SB110
     C                     ENDIF
     C*
     C           ESB100    ENDSR
     C*****************************************************************
     C           #SB110    BEGSR
     C*
     C                     MOVEL*BLANK    @MCN    3
     C                     SELEC
     C           @FLG      WHEQ '1'
     C                     MOVELM6KBN1    @MCN
     C           @FLG      WHEQ '2'
     C                     MOVELM6KBN2    @MCN
     C           @FLG      WHEQ '3'
     C                     MOVELM6KBN3    @MCN
     C           @FLG      WHEQ '4'
     C                     MOVELM6KBN4    @MCN
     C                     ENDSL
     C*
     C                     CLEART#TWP101
     C*
     C                     SETOF                     98
     C           @MCN      CHAINABBPP7G              98
     C           *IN98     IFEQ '0'
     C                     MOVELA#SIZE    T#GROP
     C                     ELSE
     C                     MOVEL'999'     T#GROP
     C                     ENDIF
     C*
     C                     MOVELM6HIN1    T#HIN1
     C                     MOVELM6HIN2    T#HIN2
     C                     MOVELM6HIN3    T#HIN3
     C                     MOVELM6JBN1    T#JBN1
     C                     MOVELM6JBN2    T#JBN2
     C                     MOVELM6JBN3    T#JBN3
     C                     MOVELM6JBN4    T#JBN4
     C                     MOVEL@MCN      T#MCNE
     C                     MOVEL@KOTE     T#PROC
     C                     Z-ADDM6KTSU    T#KTSU
     C                     Z-ADDM6KSSU    T#KSSU
     C*
     C                     WRITET#TWP101
     C*
     C           ESB110    ENDSR
