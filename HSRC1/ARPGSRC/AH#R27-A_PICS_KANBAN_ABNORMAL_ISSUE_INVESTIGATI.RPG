     C*--------------*
     C* KEY1～KEY3 *
     C*--------------*
     C* 社内品番コード
     C           KEY1      KLIST
     C                     KFLD           CBSHN1
     C                     KFLD           CBSHN2
     C                     KFLD           CBSHN3
     C*----------*
     C*初期設定*
     C*----------*
     C           *ENTRY    PLIST
     C                     PARM           USER   10
     C           STP1      TAG
     C                     MOVE *BLANK    PUSNM  15
     C                     CALL 'APLR00'
     C                     PARM           USER
     C                     PARM           PUSNM
     C                     MOVELPUSNM     WUSNM   9
     C                     Z-ADD*DATE     WYMD    80
     C                     Z-ADD0         @IJYSU  70
     C                     TIME           WTIME   60
     C                     Z-ADD1.25      @KEISU
     C                     MOVE 'N'       @DOTI
     C                     SETOF                     55
     C                     SETON                     U1
     C*--------*
     C*画面１*
     C*--------*
     C           STP2      TAG
     C                     EXFMTAH#PW271
     C                     SETOF                     019902
     C                     SETOF                     0304
     C*-------*
     C* CMD-1 *
     C*-------*
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     SETOF                     U1
     C                     RETRN
     C                     END
     C*------------*
     C*データ確認*
     C*------------*
     C** 日当設定箱数区分確認
     C                     Z-ADD1         @I      10
     C           @TNSC     LOKUPTTB5,@I                  31
     C           *IN31     IFEQ '0'
     C                     SETON                     9902
     C                     MOVELERR,1     MSG
     C                     END
     C                     MOVEL*BLANK    @HACOS 16
     C                     MOVELTTB6,@I   @HACOS
     C*
     C** 係数ブランク確認
     C           @KEISU    IFEQ 0
     C                     SETON                     9903
     C                     MOVELERR,1     MSG
     C                     END
      *
     C** 印刷Ｙ，Ｎ確認
     C           @DOTI     IFNE 'Y'
     C           @DOTI     ANDNE'N'
     C                     SETON                     9904
     C                     MOVELERR,1     MSG
     C                     END
     C           @DOTI     IFEQ 'N'
     C                     SETOF                     U1
     C                     END
      *
     C** 部門コ－ドブランク確認
     C           BKOBF     IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVELERR,1     MSG
     C                     END
     C                     MOVELBKOBF     BKOBM   40
      *
     C**  部門全探索（仕入先除く）場合
     C           BKOBF     IFEQ '9999'
     C*
     C           *INKE     IFNE '1'
     C           *IN99     ORNE '0'
     C                     GOTO STP2
     C                     END
     C*
     C                     Z-ADD0         TTB2
     C                     Z-ADD0         @ZIJYS  80
     C*
     C           1         DO   1         J       20
     C                     Z-ADDTTB1,J    BKOBM
     C                     SETOF                     15
     C           BKOBM     CHAINFGBPL011             15
     C           B2SKJY    IFNE 'D'
     C           B2SKHZ    ORGT WYMD
     C           *IN15     IFNE '1'
     C                     EXSR STP3
     C                     ADD  @IJYSU    @ZIJYS
     C                     Z-ADD@IJYSU    TTB2,J
     C                     END
     C                     END
     C                     END
     C*
     C           *IN55     IFNE '1'
     C                     SETON                     0199
     C                     MOVELERR,4     MSG
     C                     GOTO STP2
     C                     END
     C*
     C                     EXCPTZKENSU
     C           1         DO   1         J       20
     C                     Z-ADDTTB1,J    BKOBM
     C                     SETOF                     15
     C           BKOBM     CHAINFGBPL011             15
     C           B2SKJY    IFNE 'D'
     C           B2SKHZ    ORGT WYMD
     C           *IN15     IFNE '1'
     C                     EXCPTZKENME
     C                     END
     C                     END
     C                     END
     C                     EXCPTZKENDU
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C** 部門コ－ドの確認
     C                     SETOF                     15
     C           BKOBM     CHAINFGBPL011             15
     C*
     C           *IN15     IFEQ '1'
     C                     SETON                     0199
     C                     MOVELERR,2     MSG
     C                     GOTO STP2
     C                     END
     C*
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLEWYMD
     C                     SETON                     0199
     C                     MOVELERR,3     MSG
     C                     GOTO STP2
     C                     END
     C*
     C           *IN99     IFEQ '1'
     C                     GOTO STP2
     C                     END
      *
     C           *INKE     IFEQ '1'
     C           *IN99     ANDEQ'0'
     C                     EXSR STP3
     C           *IN55     IFNE '1'
     C                     SETON                     0199
     C                     MOVELERR,4     MSG
     C                     GOTO STP2
     C                     END
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C*
     C                     GOTO STP2
     C*
     C*********************************************************
     C*  サブル－チンSTP3   *
     C*************************
     C*
     C*----------------------------------------*
     C* 入力部門コードから、異常品番抜き出し *
     C*----------------------------------------*
     C           STP3      BEGSR
     C           BKOBM     SETLLAGATL321             77
     C                     SETOF                     2566
     C                     SETON                     OF
     C                     Z-ADD0         @IJYSU
     C           STP4      TAG
     C           BKOBM     READEAGATL321                 25
      *------------------*
      *品番抜き出し終了*
      *------------------*
     C           *IN25     IFEQ '1'
     C           *IN66     IFNE '1'
     C                     SETON                     0199
     C                     MOVELERR,4     MSG
     C                     GOTO OWARI
     C                     END
     C   OF                EXCPTMIDASI
     C   OF                SETOF                     OF
     C                     EXCPTSIMESI
     C                     GOTO OWARI
     C                     END
      *--------------------*
      *部門・削除条件確認*
      *--------------------*
     C*          BKOBM     IFNE CBMBMN
     C*                    GOTO STP4
     C*                    END
     C           CBSKHZ    IFLE WYMD
     C           CBSKJY    ANDEQ'D'
     C                     GOTO STP4
     C                     END
     C*
     C                     SETOF                     35
     C           KEY1      CHAINFCEPL011             35
      *
      *-----------------------*
      * 抜出条件　右辺の項１*
      *-----------------------*
     C                     Z-ADD0         @STSU  101
     C                     Z-ADD0         NITESU  61
      *
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLEWYMD
     C                     SETON                     35
     C                     END
     C           *IN35     IFNE '1'
     C                     MOVE CBSHNZ    PSHIN  12
     C                     MOVE *ALL'0'   PGSRY   9
     C                     MOVE *ALL'0'   PHSRY   9
     C                     CALL 'AAVR02'
     C                     PARM           PSHIN
     C                     PARM           PGSRY
     C                     PARM           PHSRY
     C                     MOVE PHSRY     @TTSU   90
     C*
     C           A2SYHZ    IFLE WYMD
     C           A2SSYS    IFLE 0
     C                     Z-ADD0         @STSU
     C                     ELSE
     C           @TTSU     DIV  A2SSYS    @STSU
     C                     END
     C                     ELSE
     C           A2KSYS    IFLE 0
     C                     Z-ADD0         @STSU
     C                     ELSE
     C           @TTSU     DIV  A2KSYS    @STSU
     C                     END
     C                     END
     C*
     C                     Z-ADD@STSU     NITESU
     C           TTB3,@I   IFGT NITESU
     C           TTB4,@I   ORLE NITESU
     C                     GOTO STP4
     C                     END
     C           CBBARL    IFNE 0
     C           @STSU     DIV  CBBARL    @SSSU   90
     C           CBBARL    MULT @SSSU     @SSSS  101
     C           @STSU     SUB  @SSSS     @SSSS
     C           @SSSS     IFGT 0
     C                     ADD  1         @SSSU
     C           CBBARL    MULT @SSSU     @STSU
     C                     ELSE
     C           CBBARL    MULT @SSSU     @STSU
     C                     END
     C                     ELSE
     C                     Z-ADD0         @STSU
     C                     END
     C                     MULT @KEISU    @STSU
     C                     END
      *----------------------*
      *抜出条件　左辺の項  *
      *----------------------*
     C                     Z-ADD0         @STSS   50
     C                     ADD  CBHK01    @STSS
     C                     ADD  CBHK02    @STSS
     C                     ADD  CBHK03    @STSS
     C                     ADD  CBHK04    @STSS
     C                     ADD  CBHK05    @STSS
     C                     ADD  CBHK06    @STSS
     C                     ADD  CBHK07    @STSS
     C                     ADD  CBHK08    @STSS
     C                     ADD  CBHK09    @STSS
     C                     ADD  CBHK10    @STSS
     C                     ADD  CBHK11    @STSS
     C                     ADD  CBHK12    @STSS
     C                     ADD  CBHK13    @STSS
     C                     ADD  CBHK14    @STSS
     C                     ADD  CBHK15    @STSS
     C                     ADD  CBHK16    @STSS
     C                     ADD  CBHK17    @STSS
     C                     ADD  CBHK18    @STSS
     C                     ADD  CBHK19    @STSS
     C                     ADD  CBHK20    @STSS
     C                     ADD  CBHK21    @STSS
     C                     ADD  CBHK22    @STSS
     C                     ADD  CBHK23    @STSS
     C                     ADD  CBHK24    @STSS
     C*
      *----------------------*
      *抜粋条件にあえば出力*
      *----------------------*
     C           @STSU     IFLT @STSS
     C           CBBARL    ANDLT@STSS
     C                     MOVELUSER      AHKOME
     C                     MOVELCBSHN1    AHHIN1
     C                     MOVELCBSHN2    AHHIN2
     C                     MOVELCBSHN3    AHHIN3
     C                     Z-ADDWYMD      AHYMD
     C                     WRITEAH#WP301
     C                     SETON                     5566
     C           A2TRHZ    IFGT WYMD
     C                     MOVELA2KTRK    A2ZTRK  1
     C                     MOVELA2KTRT    A2ZTRT  2
     C                     MOVELA2KTRR    A2ZTRR  2
     C                     MOVELA2KTRD    A2ZTRD  1
     C                     ELSE
     C                     MOVELA2STRK    A2ZTRK
     C                     MOVELA2STRT    A2ZTRT
     C                     MOVELA2STRR    A2ZTRR
     C                     MOVELA2STRD    A2ZTRD
     C                     END
     C           1         DO   32        K       20
     C           TTB7,K    IFEQ 99
     C                     Z-ADD0         TTB7,K
     C                     END
     C                     END
     C   OF                EXCPTMIDASI
     C   OF                SETOF                     OF
     C                     ADD  1         @IJYSU
     C                     EXCPTMEISAI
     C                     END
     C                     GOTO STP4
     C           OWARI     ENDSR
