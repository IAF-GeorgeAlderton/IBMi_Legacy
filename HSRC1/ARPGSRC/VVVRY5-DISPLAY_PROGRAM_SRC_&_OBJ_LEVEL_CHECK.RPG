     H            Y.
     F** VVVRY5 ******************************************************
     F*  VVVRY5
     F*  2014.10.09 KIRI                                             *
     F*-----------------------------------
JW1  F*  JW   2018.04.20 CHG
     F****************************************************** VVVRY5 **
     FVVVPWY5 CF  E                    WORKSTN
     FVVVPPA0 IF  E           K        DISK
     FVVVWPY5 O   F    1024            DISK
      *================================================================
     E                    MSG     1  10 60
      *================================================================
     I            DS
     I                                        1   60W@TIME
      *
     I            DS
     I                                        1  13 W$DT
     I                                        2   7 W$DATE
     I                                        8  13 W$TIME
      *================================================================
      *           MAIN ROUTINE                                       *
      *================================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#CHK1 F5'#CHK1
     C           @STEP     CASEQ'#JIKKO  '#JIKKO
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*================================================================
     C*  INIT
     C*================================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     MOVE *BLANK    D1FILE
     C                     MOVE *BLANK    D1ERR
     C*
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
     C*================================================================
     C*  DSP1
     C*================================================================
     C           #DSP1     BEGSR
     C                     EXFMTDSP01
     C                     MOVE '#CHK1   '@STEP
     C* < F1=ON >
     C   KA                MOVE '#END    '@STEP
     C* < F5=ON >
     C   KE                MOVE '#CHK1 F5'@STEP
     C                     ENDSR
     C*================================================================
     C*  CHK1
     C*================================================================
     C           #CHK1     BEGSR
     C                     MOVEA'0000'    *IN,11           <11 - 14>
     C                     MOVEA'0'       *IN,99           <99>
     C                     MOVE *BLANK    D1ERR
      *
     C           D1FILE    IFEQ *BLANK
     C                     MOVELMSG,1     D1ERR
     C                     SETON                     9911
     C                     GOTO @CHK1Z
     C                     ENDIF
      * PROGRAM REFERENCE
     C           D1FILE    SETLLVVVPPA0                  50:EQ
     C*
     C           *IN50     IFEQ *OFF
     C                     MOVELMSG,2     D1ERR
     C                     SETON                     9911
     C                     GOTO @CHK1Z
     C                     ENDIF
     C*-------------------------*
     C           @CHK1Z    TAG
     C*-------------------------*
     C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK1 F5'
     C                     MOVE '#JIKKO  '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
      *================================================================
      *  JIKKO
      *================================================================
     C           #JIKKO    BEGSR
      *
      * PROGRAM REFERENCE
     C           D1FILE    SETLLVVVPPA0
     C                     MOVEL*BLANK    P@PGM            RPGPGM
      *-----------------------------------
S1   C                     DO   *HIVAL
     C           D1FILE    READEVVVPPA0                  90
     C   90                LEAVE
     C*
 S2  C           VVPNAM    IFEQ P@PGM                      RPGPGM
     C                     ITER
 E2  C                     ENDIF
     C                     MOVELVVPNAM    P@PGM            RPGPGM
     C                     CALL 'VVVCY6'
     C                     PARM           P@PGM  10        RPGPGM
     C                     PARM           P@OBJL 10        &OBJLIB
     C                     PARM           P@OBJA 10        &OBJATR
     C                     PARM           P@TEXT 50        &TEXT
     C                     PARM           P@OBJD 13        &OBJCRT
     C                     PARM           P@SRCM 10        &SRCMBR
     C                     PARM           P@SRCD 13        &SRCDATE
     C                     PARM           P@SRCF 10        &SRCF
     C                     PARM           P@SRCL 10        &SRCFLIB
     C                     PARM           P@SRCC 13        &SRCCHGD
     C                     PARM           P@SRTP 10        &SRCTYPE
     C                     PARM           P@USED  7        &USEDATE
     C                     PARM           P@USEC  50       &USECOUNT
     C*
     C*
      * CHECK SOURCE TYPE IS "NOT USED'
     C                     MOVELP@SRTP    P#SRTP 10
     C           P#SRTP    IFEQ 'RPG'
     C           P#SRTP    OREQ 'RPGLE'
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C*
     C                     MOVE '   '     P#SRCM  3        &SRCMBR
     C                     MOVE '   '     P#SRCC  3        &SRCCHGD
      * CHECK PROGRAM NAME VS MEMBER NAME
     C           P@PGM     IFNE P@SRCM                     &SRCMBR
     C                     MOVE 'XXX'     P#SRCM           &SRCMBR
     C                     ENDIF
      * CHECK PROGRAM SOUCE CREATE DATE/TIME VS CHANGE DATE/TIME
     C           P@SRCD    IFNE P@SRCC                     &SRCDATE
     C                     MOVE 'XXX'     P#SRCC           &SRCCHGD
     C                     ENDIF
      * OBJECT CREATE DATE/TIME
     C                     MOVELP@OBJD    W$DT
     C                     MOVELW$DATE    $$OBJD  60
     C                     MOVELW$TIME    $$OBJT  60
      * SOURCE CREATE DATE/TIME
     C                     MOVELP@SRCD    W$DT
     C                     MOVELW$DATE    $$SRCD  60
     C                     MOVELW$TIME    $$SRCT  60
      * SOURCE CHANGE DATE/TIME
     C                     MOVELP@SRCC    W$DT
     C                     MOVELW$DATE    $$CHGD  60
     C                     MOVELW$TIME    $$CHGT  60
      * LATEST USE DATE
     C                     MOVELP@USED    W$DT
     C                     MOVELW$DATE    $$USED  60
      *
     C  N10                EXCPT$HED
     C                     EXCPT$DATA
     C                     SETON                     10
E1   C                     ENDDO
      *-----------------------------------
     C*
     C                     MOVE '#END    '@STEP
     C*
     C                     ENDSR
      *================================================================
     OVVVWPY5 E                $HED
     O                                      'FILE NEME,'
     O                                      'PROGRAM,'
     O                                      'PGMLIB,'
     O                                      'PGM-TYPE,'
     O                                      'PGMTEXT,'
     O                                      'SRCMBR,MBRCHECK,'
     O                                      'SRCFILE,'
     O                                      'SRCLIB,'
     O                                      'OBJ-CRT-DATE,'
     O                                      'OBJ_CRT-TIME,'
     O                                      'OBJ-CRT-BY,'
     O                                      'OBJ-CRT-BY,'
     O                                      'SRC-CHG-DATE,'
     O                                      'SRC-CHG-TIME,'
     O                                      'SRC-TYPE,'
     O                                      'CHECK,'
     O                                      'OBJ-USE-DATE,'
     O                                      'USE-CNT,'
     O        E                $DATA
     O                                      '="'
     O                         D1FILE
     O                                      '",="'
     O                         P@PGM
     O                                      '",="'
     O                         P@OBJL
     O                                      '",'
  ATRO                         P@OBJA
     O                                      ',"'
     O                         P@TEXT
     O                                      '",="'
     O                         P@SRCM
     O                                      '",="'
     O                         P#SRCM
     O                                      '",="'
     O                         P@SRCF
     O                                      '",="'
     O                         P@SRCL
     O                                      '",="'
      * OBJ-CRT-DATE
     O                         $$OBJD       '0  /  /  '
     O                                      '",="'
     O                         $$OBJT       '  :  :  '
     O                                      '",="'
      * SRC-CRT-DATE
     O                         $$SRCD       '0  /  /  '
     O                                      '",="'
     O                         $$SRCT       '  :  :  '
     O                                      '",="'
      * SRC-CHG-DATE
     O                         $$CHGD       '0  /  /  '
     O                                      '",="'
     O                         $$CHGT       '  :  :  '
     O                                      '","'
      * CHECK SRC TYPE
     O                         P#SRTP
     O                                      '",="'
      * CHECK SRC DATE
     O                         P#SRCC
     O                                      '","'
      * USE-DATE
     O                         $$USED       '0  /  /  '
     O                                      '","'
      * USE-CNT
     O                         P@USEC3
     O                                      '","'
     O                         VVFUS@
     O                                      '"'
      *================================================================
**  MSG  **
