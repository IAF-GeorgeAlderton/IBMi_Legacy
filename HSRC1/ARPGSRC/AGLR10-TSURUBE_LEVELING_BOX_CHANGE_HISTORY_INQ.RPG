      *
     C                     EXFMTAGLPW101
     C                     SETOF                     313233
     C                     SETOF                     343536
     C                     SETOF                     99
     C                     MOVEL*BLANK    D1ERR
      * F1
     C           *IN01     IFEQ '1'
     C                     MOVEL'01'      PCMD
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     Z-ADDD1C1      A1C1
     C                     Z-ADDD1C2      A1C2
     C           D1CR2     IFEQ 0
     C                     Z-ADD99999999  A1CR2
     C                     ENDIF
     C           D1CB2     IFEQ 0
     C                     Z-ADD99        A1CB2
     C                     ENDIF
     C           A1C2      IFNE 0
     C           A1C1      IFGT A1C2
     C                     MOVELER,3      D1ERR
     C                     SETON                     313233
     C                     SETON                     3499
