     H**************************************************************************
     FAFDPW09 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FAFDPL10 IF  E           K        DISK
     F            AFDPP101                          KRENAMEAFD10R
     F                                              KINFDS @INFDA
     FAFDPP10 UF  E                    DISK
     FAFDPL15 UF  E           K        DISK
      *--------------------------------------------------------------
     E                    CMD     1   1 78
     E                    ERR     1   1 78
TCHK7 ********            TAB1    1  20  5   TAB2   15
     E                    TAB1    1  21  5   TAB2   15
     I**************************************************************************
     I**************************************************************************
     I@INFDS      DS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I@INFDA      DS
     I                                    B 397 4000@@RCD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------
     C*
     C           *ENTRY    PLIST
     C                     PARM           SUPLY   4
     C                     PARM           SUPX    1
      *
     C           K#AF10    KLIST
     C                     KFLD           SUPLY
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C                     KFLD           K@DD    20
     C           K#15      KLIST
     C                     KFLD           ADKANR
     C                     KFLD           ADZETI
     C                     KFLD           ADTEHI
     C                     KFLD           ADPAGE
     C                     KFLD           ADNIJI
     C                     KFLD           ADTAIS
     C                     KFLD           ADSYUK
     C                     KFLD           ADHKOS
     C                     KFLD           ADCHKD
     C                     KFLD           XXBINN  3
     C                     KFLD           ADODNO
     C                     KFLD           ADSUPP
      *
     C                     Z-ADD*ZERO     K@YY
     C                     Z-ADD*ZERO     K@MM
     C                     Z-ADD*ZERO     K@DD
     C           SUPLY     CAT  SUPX:0    SCODE   5 P
     C           SCODE     LOKUPTAB1      TAB2           90
     C           *IN90     IFEQ *ON
     C                     MOVELTAB2      D@SUPP
     C                     ENDIF
      *
     C                     MOVE SUPLY     @SUPP   40
     C                     MOVE '01'      @@ID    2
     C                     SETOF                     30
     C                     EXSR #SET
      *
     C                     ENDSR
     C**************************************************************************
     C*    1ST SCREEN
     C**************************************************************************
     C           #SCRN1    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCNO
     C                     SELEC
B02  C           *INKC     WHEQ '1'
     C                     MOVEL'99'      @@ID    2
     C*
     C                     OTHER
     C                     EXSR #CHK1
     C*
B04  C           *IN99     IFEQ *OFF
B04  C           *INKX     ANDEQ*ON
     C                     EXSR #UPD
     C                     MOVEL'99'      @@ID
     C                     ENDIF
     C                     ENDSL
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK1
     C**************************************************************************
     C           #CHK1     BEGSR
     C*
     C                     MOVE *OFF      *IN99
     C                     MOVE *OFF      *IN61
     C                     Z-ADD*ZERO     WRRN    40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C                     SETOF                     61
     C           S@BINN    IFEQ *BLANK
     C                     SETON                     9961
     C                     Z-ADDWRRN      #RCNO
     C                     ENDIF
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C**************************************************************************
     C*           UPDATE
     C**************************************************************************
     C           #UPD      BEGSR
     C*
     C                     MOVE *ON       *IN99
     C                     Z-ADD*ZERO     WRRN    40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           H@REC     CHAINAFDPP10              80
     C           *IN80     IFEQ *OFF
     C           S@BINN    ANDNEADBINN
     C                     MOVE ADBINN    XXBINN
     C                     MOVE S@BINN    ADBINN
     C                     TIME           ADKOTM
     C                     MOVEL#USER     ADKOME
     C                     MOVEL#PGM      ADKOPG
     C                     UPDATAFDPP101
      *
     C           K#15      SETLLAFDPL15
     C           *IN95     DOUEQ*ON
     C           K#15      READEAFDPL15                  95
     C           *IN95     IFEQ *OFF
     C           A5SKJY    ANDEQ*BLANK
     C                     MOVE S@BINN    A5BINN
     C                     MOVEL#USER     A5KOME
     C                     MOVEL#PGM      A5KOPG
     C                     UPDATAFDPP151
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C**************************************************************************
     C*    SET DATA FOR 1ST SCREEN
     C**************************************************************************
     C           #SET      BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
     C                     MOVE *BLANK    @@BIN   3
     C                     Z-ADD*ZERO     @@CNT   20
     C           K#AF10    SETLLAFDPL10
     C           *IN80     DOUEQ*ON
     C           K#AF10    READEAFDPL10                  80
     C           *IN80     IFEQ *OFF
     C           ADSKJY    ANDEQ*BLANK
      *
     C           SUPX      IFNE *BLANK
     C           SUPX      ANDNEADFILR
     C                     ITER
     C                     ENDIF
      *
     C           @@BIN     IFNE ADBINN
     C                     Z-ADD*ZERO     @@CNT
     C                     ENDIF
     C                     ADD  1         @@CNT
     C                     Z-ADD@@CNT     S@NMBR
     C                     MOVE ADBINN    S@BINN
     C                     MOVE ADBINN    @@BIN
     C                     MOVE ADPAR1    S@PAR1
     C                     MOVE ADPAR2    S@PAR2
     C                     MOVE ADPAR3    S@PAR3
     C                     MOVE ADTEHI    S@TEHI
     C                     MOVE ADPAGE    S@PAGE
     C                     MOVELADLTNO    S@LOTN
     C                     Z-ADDADSYOS    S@QTY
     C                     Z-ADD@@RCD     H@REC
     C                     ADD  1         RRN1
     C                     WRITESFL01
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           RRN1      IFEQ *ZERO
     C                     ADD  1         RRN1
     C                     MOVE ERR,1     D@MSG
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     Z-ADD1         #RCNO
      *
     C                     ENDSR
