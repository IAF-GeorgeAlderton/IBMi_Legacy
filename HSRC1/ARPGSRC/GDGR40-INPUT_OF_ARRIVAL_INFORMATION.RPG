     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C           *NAMVAR   DEFN           GDKD01  20
     C                     IN   *NAMVAR
     C                     Z-ADDGDKD01    COUNT   20
     C*
     C                     EXSR #INIT
     C                     MOVE *BLANK    D1INVO
      * DEFAULT VALUE
     C                     MOVEL'US0'     D1INVO
     C                     Z-ADD*DATE     D1DATE
     C*
     C           @DSP01    TAG
     C                     EXFMTDSP01
     C                     MOVEA'00'      *IN,11
     C                     MOVEL'0'       *IN99
     C                     MOVE *BLANK    D#MSG
     C* < F1=ON >
     C           *INKA     CABEQ'1'       @END
     C*
     C                     EXSR #CHK01
     C           *IN99     CABEQ'1'       @DSP01
     C* < F5=OFF >
     C           *INKE     CABEQ'0'       @DSP01
     C*
     C           *IN77     IFEQ *OFF
     C           D1INVO    SETLLGDGPL261
     C                     DO   *HIVAL
     C           D1INVO    READEGDGPL261                 10
     C   10                LEAVE
     C           IESKJY    IFEQ 'D'                        DELETE CODE
     C           IESKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C*<UPDATE>
     C                     Z-ADDIESKOY    @@YY    40
     C                     Z-ADDIESKOM    @@MM    20
     C                     EXSR #RAT01
     C                     EXSR #UPD01
     C                     ENDDO
     C                     ENDIF
      ** MATERIAL INFORMATION
     C           *IN78     IFEQ *OFF
     C                     Z-ADDLESKOY    @@YY    40
     C                     Z-ADDLESKOM    @@MM    20
     C                     EXSR #RAT01
     C                     EXSR #UPDM
     C                     ENDIF
      *
     C           *IN40     IFEQ '1'
     C                     EXCPT#TO
     C                     END
      *
     C                     MOVE *BLANK    D1INVO
     C********             GOTO @DSP01
      *
     C* <END>
     C           @END      TAG
     C                     SETON                     LR
     C                     RETRN
