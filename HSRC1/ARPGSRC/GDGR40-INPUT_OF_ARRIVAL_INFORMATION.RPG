     C                     ENDSR
     C****************************************************************
     C           #UPD01    BEGSR                                     *
     C****************************************************************
     C*<>
     C*
     C                     MOVEL*BLANK    #ER
     C                     TIME           @@TIME
     C                     Z-ADDD1YY      IENYUY
     C                     Z-ADDD1MM      IENYUM
     C                     Z-ADDD1DD      IENYUD
     C                     MOVEL'*'       IENYUK
     C                     EXSR #UPD02
     C                     Z-ADD*DATE     IEKOHZ
     C                     Z-ADD@TIME     IEKOTM
     C                     MOVELPPUSER    IEKOME
     C                     UPDATGDGPL261
     C                     EXSR #UPD03
     C*
     C                     ENDSR
     C****************************************************************
     C           #UPD02    BEGSR                                     *
     C****************************************************************
     C*<>
     C           KEY1      KLIST
     C                     KFLD           IEODER
     C                     KFLD           IEITEM
     C*
     C                     Z-ADD0         ICODRY
     C                     Z-ADD0         ICODRM
     C                     Z-ADD0         ICODRD
     C                     MOVE *BLANK    ICIFMK
     C                     MOVE *BLANK    ICSEIH
     C                     TIME           @@TIME
     C                     SETOF                     10
     C           KEY1      SETLLGDGPL161
     C                     DO   *HIVAL
     C           KEY1      READEGDGPL161                 10
     C   10                LEAVE
     C           ICSKJY    IFEQ 'D'                        DELETE CODE
     C           ICSKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C                     LEAVE
     C                     ENDDO
      *PART TYPE
     C                     MOVEL*BLANK    WTYPE   1
     C** 発注データなし
     C           *IN10     IFEQ '1'
     C                     EXSR #TYPE
     C                     MOVE '1'       #ER,1
     C                     END
     C**
     C           *IN10     IFEQ '0'
     C                     MOVELICSEIH    WTYPE   1
     C** すでに納入済み
     C           ICIFMK    IFEQ '*'
     C                     MOVE '2'       #ER,2
     C                     GOTO UPDEND
     C                     END
     C** キャンセル済み
     C           ICIFMK    IFEQ 'C'
     C                     MOVE '3'       #ER,3
     C                     GOTO UPDEND
     C                     END
     C                     ADD  IESURY    ICIFSU
     C           ICIFSU    IFGE ICSURY
     C                     MOVEL'*'       ICIFMK
     C                     Z-ADDW1YEAR    ICIFNY
     C                     Z-ADDW1MONT    ICIFNM
     C                     Z-ADDW1DAY     ICIFND
     C                     Z-ADDD1DATE    ICIFHZ
     C                     END
     C                     Z-ADD*DATE     ICKOHZ
     C                     Z-ADD@TIME     ICKOTM
     C                     MOVELPPUSER    ICKOME
     C                     UPDATGDGPL161
     C                     END
     C*
     C           UPDEND    ENDSR
     C*****************************************************************
     C           #UPD03    BEGSR                                     *
     C****************************************************************
     C*<>
     C           KEY2      KLIST
     C                     KFLD           WVEND
     C                     KFLD           WTYPE
     C                     KFLD           GDKKEY
     C*
     C                     MOVE '8990'    WVEND   4
     C                     MOVE *BLANK    GDKKEY 20
     C                     MOVELIEHINB    GDKKEY
     C           KEY2      SETLLGDKPL011                 10
     C                     MOVEA'0'       *IN,90
     C                     DO   *HIVAL
     C           ##4       TAG
     C           KEY2      READEGDKPL011                 10
     C           *IN10     IFEQ '0'
     C           ISSKJY    IFEQ 'D'
     C           ISSKHZ    IFLE *DATE
     C                     GOTO ##4
     C                     END
     C                     END
     C           ISSTHZ    IFGT IEJYHZ
     C                     GOTO ##4
     C                     END
     C           ISENHZ    IFLT IEJYHZ
     C                     GOTO ##4
     C                     END
     C                     MOVEA'1'       *IN,90
     C                     END
     C  N10                END
     C**単価マスターなし
     C                     Z-ADD0         WTANK   82
     C           *IN90     IFEQ '0'
     C                     Z-ADD0         WTKP   145
     C                     MOVE '4'       #ER,4
     C                     ELSE
     C*          IEHANY    IFEQ 'S'
     C                     Z-ADDISTKP1    WTKP
     C                     Z-ADDISTKP1    WTANK   82
     C*                    END
     C*          IEHANY    IFEQ 'A'
     C*                    Z-ADDISTKP2    WTKP
     C*                    END
     C**ＩＡＦ単価とＡＳＪ単価アンマッチ
     C           WTKP      IFNE IETANK
     C                     MOVE '5'       #ER,5
     C                     END
     C                     END
     C*品番ＴＹＰＥが不明な時は、購入実績に出力しない。
     C           WTYPE     IFEQ *BLANK
     C                     MOVE '6'       #ER,6
     C                     GOTO @JUMP
     C                     END
     C*
     C           FCEKEY    KLIST
     C                     KFLD           IEHIN1
     C                     KFLD           IEHIN2
     C                     KFLD           IEHIN3
      *
     C                     SETOF                     10
     C           FCEKEY    CHAINFCEPL011             10
     C   10                MOVE *BLANK    A2MMEI
     C*
     C                     MOVE *BLANK    ITSKJY
     C                     Z-ADD0         ITSKYY
     C                     Z-ADD0         ITSKMM
     C                     Z-ADD0         ITSKDD
     C                     Z-ADD*YEAR     ITKOYY
     C                     Z-ADDUMONTH    ITKOMM
     C                     Z-ADDUDAY      ITKODD
     C                     Z-ADD@TIMEH    ITKOHH
     C                     Z-ADD@TIMEM    ITKOSS
     C                     MOVE PPUSER    ITKOME
     C                     MOVE IEINVO    ITINVO
     C                     Z-ADDIEODER    ITODER
     C                     Z-ADDIEITEM    ITITEM
     C                     Z-ADDIEIKBN    ITIKBN
 %001C                     MOVE IEPARE    ITPARE
     C                     Z-ADD0         ITBXNO
     C                     MOVE WTYPE     ITTYPE
     C                     MOVELIEHINB    ITHIN
     C                     MOVELA2MMEI    ITNAME
     C                     MOVE WVEND     ITVEND
     C                     MOVE *BLANK    ITKAMO
     C                     Z-ADDIESBOX    ITHAKO
     C                     Z-ADDIESURY    ITSRY
     C                     Z-ADDWTKP      ITTAN
     C                     MOVE *BLANK    ITTKBN
     C           ITSRY     MULT ITTAN     ITKIN
     C                     Z-ADDRARATE    ITRATE
     C                     Z-ADD0         ITDOLL
     C           ITRATE    IFNE 0
     C           ITKIN     DIV  ITRATE    ITDOLL
     C                     END
     C                     Z-ADDICODRY    ITHTYY
     C                     Z-ADDICODRM    ITHTMM
     C                     Z-ADDICODRD    ITHTDD
     C                     Z-ADDD1YY      ITUKYY
     C                     Z-ADDD1MM      ITUKMM
     C                     Z-ADDD1DD      ITUKDD
     C                     Z-ADDIESKOY    ITSAYY
     C                     Z-ADDIESKOM    ITSAMM
     C                     Z-ADDIESKOD    ITSADD
     C                     Z-ADDIESKOY    ITSIYY
     C                     Z-ADDIESKOM    ITSIMM
     C                     Z-ADDIESKOD    ITSIDD
     C                     MOVELIEHANY    ITYUSO
      *
     C                     DO   COUNT
     C           ITSIMM    IFEQ 12
     C                     ADD  1         ITSIYY
     C                     Z-ADD1         ITSIMM
     C                     ELSE
     C                     ADD  1         ITSIMM
     C                     END
     C                     END
     C                     Z-ADDITSIMM    A       20
     C           A         IFEQ 2
     C           ITSIYY    DIV  4         WWW001  40
     C                     MVR            WWW002  40
     C           WWW002    IFEQ 0
     C                     Z-ADD13        A
     C                     END
     C                     END
     C                     Z-ADDMM,A      ITSIDD
     C*
     C                     Z-ADD0         ITMMYY
     C                     Z-ADD0         ITMMMM
     C                     Z-ADD0         ITMMDD
     C                     WRITEGDKPL051
     C           @JUMP     TAG
     C*
     C           WER       IFNE *BLANK
      *
     C           *IN40     IFEQ '0'
     C                     EXCPT#HED
     C                     SETON                     40
     C                     END
     C           *INOF     IFEQ '1'
     C                     EXCPT#TO
     C                     EXCPT#HED
     C                     MOVEL'0'       *INOF
     C                     END
      *
     C                     SETOF                     20
     C           IEHIN3    COMP *BLANK                   20
     C           IEHANY    IFEQ 'S'
