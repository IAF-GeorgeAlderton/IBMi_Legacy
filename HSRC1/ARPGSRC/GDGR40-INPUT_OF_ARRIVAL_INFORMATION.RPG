     C           #CHK01    BEGSR                                     *
     C****************************************************************
     C**第１画面チェック**
      *
     C           D1INVO    SETLLGDGPL261
     C                     DO   *HIVAL
     C           D1INVO    READEGDGPL261            N    77
     C   77                LEAVE
     C           IESKJY    IFEQ 'D'                        DELETE CODE
     C           IESKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C                     LEAVE
     C                     ENDDO
      *
     C                     MOVELD1INVO    K@INV1
     C                     MOVE D1INVO    K@INV2
     C           K#GL      SETLLGDLPL33
     C           *IN78     DOUEQ*ON
     C           K#GL      READEGDLPL33             N    78
     C           *IN78     IFEQ *OFF
     C           LESKJY    IFEQ 'D'                        DELETE CODE
     C           LESKHZ    ANDLE*DATE
     C                     ITER
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C**
     C           *IN77     IFEQ '1'
     C           *IN78     ANDEQ'1'
     C                     MOVEL'1'       *IN11
     C  N99                MOVELMSG,1     D#MSG
     C  N99                MOVEL'1'       *IN99
     C                     GOTO @CHK1E
     C                     END
     C           *IN77     IFEQ '0'
     C           IENYUK    IFNE *BLANK
     C                     MOVEL'1'       *IN11
     C  N99                MOVELMSG,3     D#MSG
     C  N99                MOVEL'1'       *IN99
     C                     GOTO @CHK1E
     C                     END
     C                     END
      *
     C           D1YY      IFEQ 0
     C           D1MM      ORLT 01
     C           D1MM      ORGT 12
     C           D1DD      ORLT 01
     C           D1DD      ORGT 31
     C                     MOVEL'1'       *IN12
     C  N99                MOVELMSG,2     D#MSG
     C  N99                MOVEL'1'       *IN99
     C                     GOTO @CHK1E
     C                     END
      *
     C           D1DATE    IFGT *DATE
     C                     MOVEL'1'       *IN12
     C  N99                MOVELMSG,2     D#MSG
     C  N99                MOVEL'1'       *IN99
     C                     GOTO @CHK1E
     C                     END
      *
     C           @CHK1E    ENDSR
