     C                     DO   *HIVAL
     C           ##3       TAG
     C           KEY3      READEAANPL061                 50
     C           *IN50     IFEQ '0'
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    IFLE *DATE
