     C*------------------*
     C* DISPLAY SCREEN #1
     C*------------------*
     C           STP1      TAG
     C   77                GOTO @JUMP
     C                     EXFMTAKAPW301
     C           @JUMP     TAG
     C                     SETOF                     0199
      * F1
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C*------------------*
     C* CHECK OPTION
     C*------------------*
     C           WKOUM     IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
      *
     C           WKOUM     IFNE '1'
     C           WKOUM     ANDNE'2'
     C           WKOUM     ANDNE'3'
     C           WKOUM     ANDNE'4'
     C                     SETON                     0199
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
     C*----------------*
     C* TITLE
     C*----------------*
     C                     SETOF                     30
     C                     Z-ADD1         I       10
     C           WKOUM     LOKUPCMT1,I                   30
     C   30                MOVE CMT2,I    WKONM
     C                     MOVE *BLANK    A2SHIN
      *
     C                     MOVE P@HIN1    A2BHB1
     C                     MOVE P@HIN2    A2BHB2
     C                     MOVE P@HIN3    A2BHB3
      *
     C*------------------*
     C* DIDPLAY SCREEN #2
     C*------------------*
     C           STP2      TAG
     C           *IN77     IFEQ '1'
