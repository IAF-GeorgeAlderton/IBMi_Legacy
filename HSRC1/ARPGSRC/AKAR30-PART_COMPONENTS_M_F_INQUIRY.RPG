     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
     C*
     C   77                GOTO @JUMP2
     C                     EXFMTAKAPW302
     C           @JUMP2    TAG
     C                     SETOF                     021099
      * F1
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      * F2
     C           *INKB     IFEQ '1'
