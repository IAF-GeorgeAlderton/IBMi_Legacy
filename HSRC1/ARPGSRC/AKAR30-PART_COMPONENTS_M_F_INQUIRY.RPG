      * GET ASJ HALF PRODUCT PART                           *
      *-----------------------------------------------------*
     C           #SB100    BEGSR
     C                     SETOF                     30
      *
     C           KEY1      SETLLFCEPL40
     C                     DO   *HIVAL
     C           KEY1      READEFCEPL40                  30
     C   30                LEAVE
     C           F4GSKD    IFEQ 'D'
     C           F4GSDT    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C                     LEAVE
     C                     ENDDO
      *
     C           *IN30     IFEQ '0'
     C                     MOVE TB1,1     HNAME
     C                     SETOF                     55
     C                     MOVE F4HPR1    HHIN1
     C                     MOVE F4HPR2    HHIN2
     C                     MOVE F4HPR3    HHIN3
     C                     ELSE
     C           KEY1      CHAINFCEPL41              30
     C           *IN30     IFEQ '0'
TCHK1C           F4GSKD    ANDEQ*BLANK
     C                     MOVE TB1,2     HNAME
     C                     SETOF                     55
     C                     MOVE F4PRT1    HHIN1
     C                     MOVE F4PRT2    HHIN2
     C                     MOVE F4PRT3    HHIN3
     C                     END
     C                     END
      *
     C           KEY1      CHAINFCEPL11              30
     C           *IN30     IFEQ *OFF
     C           FCCD01    ANDNE*ZERO
     C           FCGK01    DIV  FCCD01    @@QTY   90
     C           @@QTY     MULT 20        A2GEKN
     C                     ENDIF
