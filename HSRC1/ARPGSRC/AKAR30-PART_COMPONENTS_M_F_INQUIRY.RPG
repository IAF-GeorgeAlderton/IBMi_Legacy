     C*--------------------------*
     C*  ..設定月の稼動日数..  *
     C* GET WORK DAYS            *
     C*--------------------------*
     C                     Z-ADD0         $KCD
     C           KEY3      SETLLAGDPL121
      *
     C                     DO   *HIVAL
     C                     SETOF                     30
     C           KEY3      READEAGDPL121                 30
     C           *IN30     IFEQ '0'
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         $KCD
     C                     ELSE
      *
     C                     ADD  0.5       $KCD
     C                     END
      *
     C                     END
     C                     END
     C  N30                END
      *
     C                     MOVE P@MODE    WKOUM
     C           P@MODE    IFNE *BLANK
     C                     SETON                     77
     C                     END
