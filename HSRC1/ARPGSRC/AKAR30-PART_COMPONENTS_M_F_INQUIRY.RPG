     C*------------------*
     C* IAF PART#
     C*------------------*
     C           A2SHIN    IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVE ER,3      MSG
     C                     GOTO STP2
     C                     END
      *
     C*----------------------*
     C* PART# MASTER
     C*----------------------*
     C                     SETOF                     30
     C           KEY1      CHAINFCEPL011             30
     C           *IN30     IFEQ '1'
     C                     SETON                     0299
     C                     MOVE ER,4      MSG
     C                     GOTO STP2
     C                     ELSE
      *
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     0299
     C                     MOVE A2GSYY    WDLYY
     C                     MOVE A2GSMM    WDLMM
     C                     MOVE A2GSDD    WDLDD
     C           ER,5      CAT  WDLDT:1   MSG       P
     C                     GOTO STP2
     C                     END
     C                     END
