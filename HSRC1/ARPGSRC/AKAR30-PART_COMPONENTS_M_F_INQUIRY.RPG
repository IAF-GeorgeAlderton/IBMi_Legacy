     C*----------------------------*
     C* LOCATION FUNCTION
     C*----------------------------*
     C                     MOVE *BLANK    WHKOJ
     C                     MOVE *BLANK    WHTUR
     C                     MOVE *BLANK    WYOSI
     C                     Z-ADD0         WSHIY
     C                     SETOF                     30
     C           KEY2      CHAINAAQPL011             30
     C           *IN30     IFEQ '0'
     C           DBSKJY    ANDEQ'D'
     C           DBSKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
      *
     C           *IN30     IFEQ '0'
     C                     MOVE DBHKOJ    WHKOJ
     C                     MOVE DBHTUR    WHTUR
     C                     Z-ADDDBSHIY    WSHIY
     C                     MOVE DBYOSI    WYOSI
     C                     END
      *
     C           A2TEHI    IFEQ 'G'
