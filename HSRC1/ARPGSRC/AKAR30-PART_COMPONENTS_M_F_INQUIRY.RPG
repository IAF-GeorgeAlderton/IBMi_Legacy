     C                     SETOF                     81
     C           KEY1      READEAEBPL011                 81
     C           *IN81     IFEQ '0'
     C           AFSKJY    IFEQ 'D'
     C           AFSKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     SETON                     79
     C                     ADD  1         U
     C                     MOVE AFKHIN    @KH,U
     C                     Z-ADDAFSKSU    @KS,U
     C                     MOVE AFKOTI    @KT,U
     C                     MOVE AFKBMN    @KB,U
     C                     MOVE AFUKER    @UK,U
      *
     C                     END
     C                     END
