 .   C                     PARM           $PART  20
 .   C                     PARM           $NONY   4
 .   C                     PARM           $PTYP   1
 .   C                     PARM           $CO     3
JW1  C                     MOVEL$CO       WCO
     C*--------------------*
     C* ORDER#
     C*--------------------*
     C           A2TEHI    IFEQ 'G'
      *
     C*--------------------------------------*
     C* KANBAN EXCHANGE MASTER
     C*--------------------------------------*
     C                     SETOF                     30
     C                     MOVE *BLANK    KOT
     C                     Z-ADD0         KBM
     C                     MOVE *BLANK    KNM
     C           KEY1      CHAINAAMPL111             30
     C           *IN30     IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '0'
      *
     C                     Z-ADD1         A       20
     C                     Z-ADD0         B       20
     C           1         DO   15        A
     C                     MOVELKHZ,A     WHZ     80
     C           *DATE     IFLT WHZ
     C           QKO,A     IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE QKO,A     KOT,B
     C                     Z-ADDQBM,A     KBM,B
     C                     END
     C                     ELSE
      *
     C           NKO,A     IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE NKO,A     KOT,B
     C                     Z-ADDNBM,A     KBM,B
     C                     END
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C*--------------------*
     C* DEPARTMENT
     C*--------------------*
     C                     MOVE *BLANK    KNM
     C                     Z-ADD1         C       20
     C           1         DO   15        C
     C                     SETOF                     30
     C           KBM,C     CHAINFGBPL011             30
     C           *IN30     IFEQ '0'
     C                     MOVELB2SMEI    KNM,C
     C                     END
     C                     END
      *
     C*------------------------------*
     C* COMPONENT PART
     C*------------------------------*
