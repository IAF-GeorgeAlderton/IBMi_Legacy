     H            Y.
     F** FBCR3N  ***********************************
     A*   SALES EXPANSION PARTS SALES RESULT (V02) *
     A*   COPIED FROM FBCR34)                      *
     F*   J.WATA    2021.05.05 CHG CSV DATA        *
JW1  F*   J.WATA    2021.05.12 ADD CUSTOMER NAME   *
     F**********************************************
     FFBCPW3N CF  E                    WORKSTN
     FFBCPL20 IF  E           K        DISK
     F            FBCPP201                          KRENAMEFBC22R
     FFBCPP25 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FAB#PL0V IF  E           K        DISK
     FFBCWP3N O   F     250            DISK
      *---------------------------------------------------------------
     E**                  MSG     1   3 70
     E                    MSG     1   5 70
      *---------------------------------------------------------------
     I            DS
     I                                        1   80W@YMD
     I                                        1   40W@YY
     I                                        5   60W@MM
     I                                        7   80W@DD
     I                                        1   60W@YM
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        7  120@@YYMM
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *----------------------------------------------------*
      *   ENTRY     L  I  S  T                             *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           PDEST  50
      *----------------------------------------------------*
      *   MAIN                                             *
      *----------------------------------------------------*
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVELD@DEST    PDEST
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------------*
      * INITIALIZE                                         *
      *----------------------------------------------------*
     C           *INZSR    BEGSR
      *
     C           K#AGD     KLIST
     C                     KFLD           W@YY
     C                     KFLD           W@MM
      *
     C           K#GAD     KLIST
     C                     KFLD           K@TOKU  40
     C                     KFLD           K@NONY  40
      *
     C           K#GAD1    KLIST
     C                     KFLD           K@TOKU  40
     C                     KFLD           K@NONY  40
     C                     KFLD           K@NKOJ  1
      *
     C           K#GAD2    KLIST
     C                     KFLD           K@TOKU  40
     C                     KFLD           K@NONY  40
     C                     KFLD           K@NKOJ  1
     C                     KFLD           K@NUKE  4
      *
     C           K#FBC2    KLIST
     C                     KFLD           F2MHN1
     C                     KFLD           F2MHN2
     C                     KFLD           F2MHN3
     C                     KFLD           F2MHN4
     C                     KFLD           F2TOKU
      * USE PART(10A)
     C           K#AB10    KLIST
     C                     KFLD           F2TOKU
     C                     KFLD           W@YY
     C                     KFLD           W@MM
     C                     KFLD           F2MHN1
     C                     KFLD           F2MHN2
      * USE PART(20A)
     C           K#AB20    KLIST
     C                     KFLD           F2TOKU
     C                     KFLD           W@YY
     C                     KFLD           W@MM
     C                     KFLD           F2MHN1
     C                     KFLD           F2MHN2
     C                     KFLD           F2MHN3
     C                     KFLD           F2MHN4
      *
     C                     MOVE '01'      @@ID    2
     C                     MOVE *ALL'-'   @@LIN 132
      *
     C                     TIME           @SDATE
     C                     MOVEL#USER     D@SLPS
     C                     Z-ADD@@YYMM    D@YYMM
     C                     MOVELPDEST     D@DEST
      *
     C                     ENDSR
      *----------------------------------------------------*
      *   1ST SCREEN                                       *
      *----------------------------------------------------*
     C           #SCRN1    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #PRT
     C                     MOVE '99'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  CHECK
      *----------------------------------------------------*
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
      * USER ID
     C           D@SLPS    IFNE *BLANK
     C           D@SLPS    CHAINFBCPL20              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     MOVE MSG,2     D@MSG
     C                     ENDIF
     C                     ENDIF
      * SALES DATE
     C           D@YYMM    IFEQ *ZERO
     C  N99                MOVE MSG,1     D@MSG
     C                     SETON                     6299
     C                     ENDIF
      *
     C                     Z-ADDD@YYMM    W@YM
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C  N99                MOVE MSG,4     D@MSG
     C                     SETON                     6299
     C                     ENDIF
      * DESTINATION
     C           D@DEST    IFEQ *BLANK
     C  N99                MOVE MSG,3     D@MSG
     C                     SETON                     6399
     C                     ENDIF
      *
     C                     ENDSR
      *---------------------------------------------------
      *  OUTPUT
      *---------------------------------------------------
     C           #PRT      BEGSR
      *
     C                     EXCPT@@HED
      *
     C                     TIME           @@TIME  60
     C                     Z-ADD1         W@DD
     C                     Z-ADDW@YMD     W@STRT  80
     C                     Z-ADD31        W@DD
     C                     Z-ADDW@YMD     W@END   80
      *
     C                     MOVE *BLANK    @@SLPS 10
     C                     Z-ADD*ZERO     @@TOKU  40
     C                     Z-ADD*ZERO     @@GTOT 110
     C                     Z-ADD*ZERO     @@GAMT 132
     C                     Z-ADD*ZERO     @@CNT   50
     C                     Z-ADD*ZERO     @@CAMT 112
     C                     Z-ADD*ZERO     @@CTOT  90
     C                     Z-ADD*ZERO     @@SAMT 112
     C                     Z-ADD*ZERO     @@STOT  90
     C           D@SLPS    SETLLFBCPL20
     C           *IN80     DOUEQ*ON
     C           D@SLPS    IFNE *BLANK
     C           D@SLPS    READEFBCPL20                  80
     C                     ELSE
     C                     READ FBCPL20                  80
     C                     ENDIF
      *
1    C           *IN80     IFEQ *OFF
|     *
|2   C           F2SKJY    IFEQ 'D'
||   C           F2SYMD    ANDLE*DATE
||   C                     ITER
|2   C                     ENDIF
|     *
|2   C           F2STYM    IFLE D@YYMM
||   C           F2ENYM    ANDGED@YYMM
||    *
||3  C           F2SLSP    IFNE @@SLPS
|||4 C           @@SLPS    IFNE *BLANK
|||| C                     Z-ADD*ZERO     @@CAMT 112
|||| C                     Z-ADD*ZERO     @@CTOT  90
|||| C                     Z-ADD*ZERO     @@SAMT 112
|||| C                     Z-ADD*ZERO     @@STOT  90
|||4 C                     ENDIF
|||   *
|||  C                     MOVE F2SLSP    @@SLPS
||3  C                     ELSE
|||4 C           @@TOKU    IFNE *ZERO
|||| C           @@TOKU    ANDNEF2TOKU
|||| C                     Z-ADD*ZERO     @@CAMT 112
|||| C                     Z-ADD*ZERO     @@CTOT  90
|||4 C                     ENDIF
||3  C                     ENDIF
||    *
||   C                     Z-ADDF2TOKU    @@TOKU
||    *
||   C                     MOVE *BLANK    @@DSC  15
||   C           F2CLAS    CHAINFBCPP25              95
||3  C           *IN95     IFEQ *OFF
|||  C                     MOVELF5DESC    @@DSC
||3  C                     ENDIF
      * COMPARE WITH 20A
JW   C                     EXSR #ACT20
 .    * COMPARE WITH 10A
 .   C                     EXSR #ACT10
      * GET CUSTOMER NAME
     C           F2NONY    IFEQ 0
     C                     MOVELF2TOKU    $DLV
     C                     ELSE
     C                     MOVE F2NONY    $DLV
     C                     ENDIF
     C                     MOVE *BLANK    XXNAME 30
     C                     CALL 'UTLR62'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTN    1
     C                     MOVEL$NAME2    XXNAME
      *
||   C                     EXCPT@@DTL
||   C                     ADD  1         @@CNT
||   C                     ADD  @@ACT     @@GTOT
||   C                     ADD  @@AMT     @@GAMT 132
||   C                     ADD  @@AMT     @@CAMT 112
||   C                     ADD  @@ACT     @@CTOT  90
||   C                     ADD  @@AMT     @@SAMT 112
||   C                     ADD  @@ACT     @@STOT  90
||    *
|2   C                     ENDIF
1    C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------
      * COMPARE WITH 20A
      *------------------------------------------------
     C           #ACT20    BEGSR
      *
     C                     Z-ADD0         @@ACT   90
     C           K#AB20    SETLLAB#PL0V
     C           *IN90     DOUEQ*ON
     C           K#AB20    READEAB#PL0V                  90
     C           *IN90     IFEQ *OFF
     C           B1SKJY    ANDEQ*BLANK
      *
%0001C           F2NONY    IFNE *ZERO
     C           F2NONY    ANDNEB1NONY
     C                     ITER
     C                     ENDIF
      *
     C           F2NKOJ    IFNE *BLANK
     C           F2NKOJ    ANDNEB1NKOJ
     C                     ITER
     C                     ENDIF
      *
     C           F2NUKE    IFNE *BLANK
     C           F2NUKE    ANDNEB1NUKE
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  B1SRYO    @@ACT
     C                     ENDIF
     C                     ENDDO
      *
     C           @@ACT     MULT F2UPRC    @@AMT  152
      *
     C                     ENDSR
      *------------------------------------------------
      * COMPARE WITH 10A
      *------------------------------------------------
     C           #ACT10    BEGSR
      *
     C**                   Z-ADD0         @@ACT   90
     C           K#AB10    SETLLAB#PL0V
     C           *IN90     DOUEQ*ON
     C           K#AB10    READEAB#PL0V                  90
     C           *IN90     IFEQ *OFF
     C           B1SKJY    ANDEQ*BLANK
      *
JW   C           F2MHN3    IFEQ B1MHN3
     C           F2MHN4    ANDEQB1MHN4
     C                     ITER
     C                     ENDIF
      *
JW   C           B1MHN3    IFNE '  '
     C           B1MHN3    ANDNE'00'
     C           B1MHN3    ANDNE'01'
     C                     ITER
     C                     ENDIF
      *
%0001C           F2NONY    IFNE *ZERO
     C           F2NONY    ANDNEB1NONY
     C                     ITER
     C                     ENDIF
      *
     C           F2NKOJ    IFNE *BLANK
     C           F2NKOJ    ANDNEB1NKOJ
     C                     ITER
     C                     ENDIF
      *
     C           F2NUKE    IFNE *BLANK
     C           F2NUKE    ANDNEB1NUKE
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  B1SRYO    @@ACT
     C                     ENDIF
     C                     ENDDO
      *
     C           @@ACT     MULT F2UPRC    @@AMT  152
      *
     C                     ENDSR
      *----------------------------------------------------*
      * CLEAR
      *----------------------------------------------------*
     C           #CLR      BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *OFF      *IN99
      *
     C                     ENDSR
