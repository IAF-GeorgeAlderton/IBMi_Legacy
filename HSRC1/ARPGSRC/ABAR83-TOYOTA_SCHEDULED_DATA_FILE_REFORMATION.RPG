     C                     PARM           PKENS   7
     C                     MOVELPYM       WYM     60
      *
     C*-------------------*
     C*   ...ABAWP18...   *
     C*-------------------*
     C                     DO   *HIVAL
     C                     SETOF                     01
     C                     READ ABAWP181                 01
      *
     C           *IN01     IFEQ '1'
     C                     MOVE WRECD     PRECD
     C                     MOVE WKENS     PKENS
     C                     ELSE
      *
     C                     ADD  1         WRECD   70
      *
     C           ABDATE    IFLE WYM
     C                     DELETABAWP181
     C                     ELSE
     C                     ADD  1         WKENS   70
     C                     END
      *
     C                     END
     C  N01                END
