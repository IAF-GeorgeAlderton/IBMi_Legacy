     C****************************************************************
     C*  START PROGRAM  <AAJR13>                                     *
     C****************************************************************
     C                     MOVE *BLANK    TYTLE
     C                     MOVE *BLANK    MIDASI
     C                     MOVELCOM,1     TYTLE
     C                     MOVELTYT,1     MIDASI
     C                     MOVEA'0'       *IN,01
     C                     MOVEA'0'       *IN,99
     C*
     C*
     C           STP1      TAG
     C                     EXFMTAAJPW121
     C   KA                SETON                     LR
     C   KA                RETRN
     C*
     C                     MOVEA'00000'   *IN,01
     C                     MOVEA'0'       *IN,99
     C*
     C           CODE      IFEQ 0
     C                     MOVELMSG,1     ERRMSG
     C                     MOVEA'1'       *IN,01
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP1
     C                     END
     C*
     C*
     C           CODE      IFNE 0111
     C                     MOVELMSG,2     ERRMSG
     C                     MOVEA'1'       *IN,01
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP1
     C                     END
     C*
     C           TO        IFEQ *BLANK
     C                     MOVE *HIVAL    TO
     C                     END
     C           FROM      IFGT TO
     C                     MOVELMSG,3     ERRMSG
     C                     MOVEA'11'      *IN,02
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP1
     C                     END
     C*
     C           KEYA      KLIST
     C                     KFLD           FROM1
     C                     KFLD           FROM2
     C                     KFLD           FROM3
     C                     KFLD           FROM4
     C           KEYA      SETLLAAJPL111             10
     C           *IN,10    IFEQ '1'
     C                     MOVELMSG,6     ERRMSG
     C                     MOVEA'1'       *IN,02
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP1
     C                     END
     C*
     C*
     C           TYPE      IFEQ *BLANK
     C                     MOVELMSG,4     ERRMSG
     C                     MOVEA'1'       *IN,04
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP1
     C                     END
     C*
     C*
     C           TYPE      IFNE 'A'
     C           TYPE      IFNE 'B'
     C                     MOVELMSG,5     ERRMSG
     C                     MOVEA'1'       *IN,04
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP1
     C                     END
     C                     END
     C*
     C           TYPE2     IFNE 'A'
     C           TYPE2     IFNE 'B'
     C           TYPE2     IFNE 'C'
     C                     MOVELMSG,8     ERRMSG
     C                     MOVEA'1'       *IN,05
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP1
     C                     END
     C                     END
     C                     END
     C*
     C*  LET'S PRINT OUT
     C*
     C                     MOVEA'11'      *IN,21
     C                     MOVEA'0'       *IN,80
     C                     MOVEA'00'      *IN,50
     C                     Z-ADD0         XXBMON  40
     C                     Z-ADD0         TOTAL
     C                     MOVE *BLANK    SW      1
     C                     MOVE *BLANK    RSW     1
     C                     MOVE *BLANK    OBANC   6
     C*
     C           KEYB      KLIST
     C                     KFLD           CODE
     C                     KFLD           FROM1
     C                     KFLD           FROM2
     C                     KFLD           FROM3
     C                     KFLD           FROM4
     C*
     C*   FILE SET
     C*
     C           TYPE2     IFEQ 'A'
     C           CODE      IFEQ 9999
     C                     MOVE '1'       RSW
     C           KEYA      SETLLAAJPL111
     C                     ELSE
     C                     MOVE '2'       RSW
     C           KEYB      SETLLAAJTL121
     C                     END
     C                     END
     C*
     C           TYPE2     IFEQ 'B'
     C           CODE      IFEQ 9999
     C                     MOVE '3'       RSW
     C           KEYA      SETLLAAJTL161
     C                     ELSE
     C                     MOVE '4'       RSW
     C           KEYB      SETLLAAJTL151
     C                     END
     C                     END
     C*
     C           TYPE2     IFEQ 'C'
     C                     MOVE '5'       RSW
     C           KEYA      SETLLAAJPL111
     C                     END
     C*
     C                     DO   *HIVAL
     C*
     C*   FILE READ
     C*
     C           RSW       IFEQ '1'
     C                     READ AAJPL111                 90
     C                     ELSE
     C           RSW       IFEQ '2'
     C           CODE      READEAAJTL121                 90
     C                     ELSE
     C           RSW       IFEQ '3'
     C                     READ AAJTL161                 90
     C                     ELSE
     C           RSW       IFEQ '4'
     C           CODE      READEAAJTL151                 90
     C                     ELSE
     C           RSW       IFEQ '5'
     C                     READ AAJPL111                 90
     C                     END
     C                     END
     C                     END
     C                     END
     C                     END
     C*
     C           *IN,90    IFEQ '0'
     C           CJBAN     IFLE TO
     C*
     C*   ﾆﾞｭci] CHEK
     C*
     C           *DATE     IFLE CHHZK
     C                     MOVEA'1'       *IN,50
     C                     END
     C           CJBANC    IFNE OBANC
     C                     MOVEA'1'       *IN,51
     C                     MOVE CJBANC    OBANC
     C                     END
     C           RSW       IFEQ '1'
     C           RSW       OREQ '2'
     C           RSW       OREQ '3'
     C           RSW       OREQ '4'
     C           *IN,50    IFEQ '0'
     C           *IN,51    OREQ '0'
     C                     GOTO STP20
     C                     END
     C                     END
     C           RSW       IFEQ '1'
     C           RSW       OREQ '2'
     C           RSW       OREQ '3'
     C           RSW       OREQ '4'
     C           *IN,50    IFEQ '1'
     C           *IN,51    ANDEQ'1'
     C                     MOVEA'00'      *IN,50
     C                     END
     C                     END
     C*
     C*   nﾌﾞﾆ & END
     C*
     C           CODE      IFNE 9999
     C           RSW       IFEQ '2'
     C           RSW       OREQ '4'
     C           CODE      IFNE CJBMON
     C                     MOVEA'1'       *IN,90
     C                     GOTO STP20
     C                     END
     C                     ELSE
     C           CODE      CABNECJBMON    STP20
     C                     END
     C                     END
     C*
     C           *IN,80    IFEQ '0'
     C                     MOVEL'*'       SW
     C                     Z-ADDCJBMON    XXBMON
     C                     MOVEA'1'       *IN,80
     C                     END
     C*
     C*   jﾞbkｭc jbﾎﾟ = 'A'
     C*
     C           TYPE      IFEQ 'A'
     C           *IN,23    IFEQ '0'
     C                     SETON                     23
     C                     OPEN AAJPR12
     C                     END
     C           CJBMON    IFNE XXBMON
     C           *IN,21    IFEQ '1'
     C           XXBMON    CHAINFGBPL011             10
     C   10                MOVEL*BLANK    B2SMEI
     C                     WRITEHED1
     C                     MOVEA'0'       *IN,21
     C                     END
     C                     WRITETOT1
     C                     Z-ADD0         TOTAL
     C                     MOVEA'1'       *IN,21
     C                     Z-ADDCJBMON    XXBMON
     C                     END
     C*
     C           *IN,21    IFEQ '1'
     C           CJBMON    CHAINFGBPL011             10
     C   10                MOVEL*BLANK    B2SMEI
     C                     WRITEHED1
     C                     MOVEA'0'       *IN,21
     C                     END
     C                     MOVE *BLANK    SYUNAM
     C           CJSDYO    LOKUPTAB1      TAB2           10
     C   10                MOVELTAB2      SYUNAM
     C                     MOVE *BLANK    IRONM
     C           CJCOCR    LOKUPTAB3      TAB4           10
     C   10                MOVELTAB4      IRONM
     C                     Z-ADD1         M       20
     C           CJKDAI    LOKUPCD,M                     11
     C           *IN11     IFEQ '1'
     C                     MOVE ME,M      T3NAMK 20
     C                     ELSE
     C                     MOVE *BLANK    T3NAMK
     C                     END
     C                     WRITEDET1
     C                     ADD  1         TOTAL
     C                     END
     C*
     C*   jﾞbkｭc jbﾎﾟ = 'B'
     C*
     C           TYPE      IFEQ 'B'
     C           *IN,23    IFEQ '0'
     C                     SETON                     23
     C                     OPEN AAJPR13
     C                     END
     C           CJBMON    IFNE XXBMON
     C                     MOVEA'1'       *IN,22
     C                     Z-ADDCJBMON    XXBMON
     C                     END
     C           *IN,22    IFEQ '1'
     C           CJBMON    CHAINFGBPL011             10
     C   10                MOVEL*BLANK    B2SMEI
     C                     WRITEHED
     C                     MOVEA'0'       *IN,22
     C                     END
     C                     Z-ADD1         M       20
     C           CJKDAI    LOKUPCD,M                     11
     C           *IN11     IFEQ '1'
     C                     MOVE ME,M      T3NAMK 20
     C                     ELSE
     C                     MOVE *BLANK    T3NAMK
     C                     END
     C                     WRITEDET
     C                     END
     C*
     C                     ELSE
     C                     MOVEA'1'       *IN,90
     C                     END
     C                     END
     C*
     C           STP20     TAG
     C  N90                END
     C*
     C           SW        IFEQ *BLANK
     C                     MOVELMSG,6     ERRMSG
     C                     MOVEA'111'     *IN,01
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP1
     C                     END
     C*
     C*
     C           TYPE      IFEQ 'A'
     C           *IN,21    IFEQ '1'
     C           XXBMON    CHAINFGBPL011             10
     C   10                MOVEL*BLANK    B2SMEI
     C                     WRITEHED1
     C                     MOVEA'0'       *IN,21
     C                     END
     C                     WRITETOT1
     C                     Z-ADD0         TOTAL
     C                     MOVEA'1'       *IN,21
     C                     Z-ADDCJBMON    XXBMON
     C                     CLOSEAAJPR12
     C                     ELSE
     C                     CLOSEAAJPR13
     C                     END
     C*
     C                     MOVEL'1'       *INLR
     C                     RETRN
**       KANBAN NAME
