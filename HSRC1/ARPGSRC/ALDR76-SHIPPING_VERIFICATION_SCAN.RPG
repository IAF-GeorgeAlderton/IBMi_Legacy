     C           K#761C    SETLLALDPL761
     C*
     C                     DO   *HIVAL
     C           K#761C    READEALDPL761                 91
     C   91                LEAVE
     C           A7STS     IFEQ *BLANK
     C                     MOVEL*ON       *IN99
     C                     LEAVE
     C                     END
     C                     ENDDO
     C*
     C           *IN99     IFEQ *ON
     C           W@TCN1    ORNE W@TCN2
     C                     MOVELSTS,3     EMSG1
     C                     MOVEL*BLANK    EMSG2
     C                     EXFMTFMT990
     C           *INKB     IFEQ *ON
     C                     MOVEL*ON       *IN98
     C                     MOVEL*OFF      *IN99
     C                     END
     C                     ELSE
     C                     EXFMTFMT999
     C                     END
     C*
     C           K#761A    CHAINALDPL761             91
     C           *IN91     IFEQ *ON
     C                     CLEARALDPP761
     C                     END
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    A7KODT
     C                     Z-ADDWSSTM6    A7KOTM
     C                     MOVEL#USER     A7USER
     C                     MOVEL#WSID     A7WSID
     C                     MOVEL#PGM      A7PGID
     C                     MOVELD@TMCD    A7TMCD
     C                     MOVELBRCD20    A7PKL#
     C                     Z-ADDW@SEQ#    A7SEQ#
     C           *IN99     IFEQ *ON
     C                     MOVEL'NG'      A7STS
     C                     MOVELSTS,3     A7MSG3
     C                     ELSE
     C           *IN98     IFEQ *ON
     C           W@TCN1    ORNE W@TCN2
     C                     MOVEL'IM'      A7STS
     C                     MOVELSTS,3     A7MSG3
     C                     ELSE
     C                     MOVEL'OK'      A7STS
     C                     MOVELSTS,4     A7MSG3
     C                     END
     C                     END
     C   91                WRITEALDPP761
     C  N91                UPDATALDPP761
     C*
     C                     ENDSR
