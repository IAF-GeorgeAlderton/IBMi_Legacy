     C           F1ILOT    WHEQ *BLANK
     C           F1ALOT    ANDEQ*BLANK
     C           K#L92B    READEGDMPL92                  97
     C           F1ILOT    WHNE *BLANK
     C           K#L93B    READEGDMPL93                  97
     C           F1ALOT    WHNE *BLANK
     C           K#L94B    READEGDMPL94                  97
