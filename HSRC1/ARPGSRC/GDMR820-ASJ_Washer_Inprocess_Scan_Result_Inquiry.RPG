     C                     MOVEL'-'       W@PRTA
     C                     END
     C                     MOVELM9CPT2    W@PRT2
     C           M9CPT3    IFNE *BLANK
     C                     MOVEL'-'       W@PRTB
     C                     END
     C                     MOVELM9CPT3    W@PRT3
