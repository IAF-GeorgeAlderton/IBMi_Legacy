     C*                    MAIN ROUTINE
     C**************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'10'      #FMT10
     C           @@ID      CASEQ'20'      #FMT20
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C**************************************************************************
     C*         INITIALIZE
     C**************************************************************************
     C           *INZSR    BEGSR
      *
     C                     TIME           WSDT
     C*
     C                     Z-ADD*ZERO     F1SCFY
     C                     Z-ADD*ZERO     F1SCFM
     C                     Z-ADD*ZERO     F1SCFD
     C                     Z-ADD*ZERO     F1SCTY
     C                     Z-ADD*ZERO     F1SCTM
     C                     Z-ADD*ZERO     F1SCTD
     C                     MOVEL*BLANK    MSG
     C*
     C                     MOVEL'10'      @@ID    2
     C                     MOVEL*OFF      *IN89
     C*
     C                     ENDSR
     C*************************************************************************
     C*     1ST SCREEN(SCAN DATE)
     C**************************************************************************
     C           #FMT10    BEGSR
      *
     C                     SETOF                     8788
     C                     WRITEFMT099
     C                     EXFMTFMT010
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN89
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK10
     C           *IN89     IFEQ *OFF
     C                     EXSR #SET20
     C                     END
     C           *IN89     IFEQ *ON
     C                     MOVEL'10'      @@ID
     C                     ELSE
     C                     MOVEL'20'      @@ID
     C                     END
     C                     ENDSL
      *
     C                     ENDSR
     C*************************************************************************
     C*     1ST SCREEN CHECK
     C**************************************************************************
     C           #CHK10    BEGSR
     C*
     C                     SETOF                     313233
     C                     SETOF                     343589
     C                     TIME           WSDT
     C*
     C           F1SCFH    IFEQ *ZERO
     C                     SETON                     3189
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,1     MSG
     C                     END
     C                     END
     C*
     C           F1SCFH    IFGT WSSDAT
     C                     SETON                     3189
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,2     MSG
     C                     END
     C                     END
     C                     Z-ADDF1SCFH    W1SCFH
     C*
     C           F1SCTH    IFEQ *ZERO
     C                     Z-ADDW1SCFH    W1SCTH
     C                     ELSE
     C                     Z-ADDF1SCTH    W1SCTH
     C                     END
     C*
     C           W1SCFD    IFEQ *ZERO
     C                     Z-ADD01        W1SCFD
     C                     END
     C           W1SCTD    IFEQ *ZERO
     C           K#AGDA    KLIST
     C                     KFLD           W1SCTY
     C                     KFLD           W1SCTM
     C           K#AGDA    SETGTAGDPL12
     C           K#AGDA    REDPEAGDPL12                  98
     C           *IN98     IFEQ *OFF
     C                     Z-ADDF8KADD    W1SCTD
     C                     ELSE
     C                     Z-ADD31        W1SCTD
     C                     END
     C                     END
     C*
     C           W1SCFH    IFGT W1SCTH
     C                     SETON                     313289
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,3     MSG
     C                     END
     C                     END
     C*
     C           F1ILOT    IFNE *BLANK
     C           F1ALOT    ANDNE*BLANK
     C                     SETON                     343589
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,6     MSG
     C                     END
     C                     END
     C*
     C           F1ILOT    IFNE *BLANK
     C           F1ALOT    ORNE *BLANK
     C           F1SHIN    IFEQ *BLANK
     C                     SETON                     3389
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,7     MSG
     C                     END
     C                     END
     C                     END
     C*
     C                     ENDSR
     C*************************************************************************
     C*     2ND SCREEN SET
     C**************************************************************************
