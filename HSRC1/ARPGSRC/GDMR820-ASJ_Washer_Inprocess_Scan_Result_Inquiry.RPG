     C                     END
     C           M9SCND    IFGT W1SCTH
     C                     LEAVE
     C                     END
     C*
     C                     CLEARSFL020
     C*
     C                     Z-ADDM9SCND    S2DATE
     C                     MOVELM9TIHH    W9TIHH
     C                     MOVEL':'       W9@DY1
     C                     MOVELM9TIMM    W9TIMM
     C                     MOVELW9TIME    S2TIME
     C                     MOVELM9SCNR    S2OKNG
     C*
     C           M9SCNR    IFEQ 'NG'
