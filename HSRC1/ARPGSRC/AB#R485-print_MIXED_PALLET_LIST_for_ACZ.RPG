     C                     KFLD           IMHN4
      *
     C                     Z-ADD*ZERO     WW#BOX  90
     C                     Z-ADD*ZERO     W@L     10
     C                     Z-ADD*ZERO     W@M     50
     C                     Z-ADD*ZERO     W@S     20
     C           *LOVAL    SETLLABWPP31
     C                     DO   *HIVAL
     C                     READ ABWPP31                  99
     C           *IN99     IFEQ *ON
     C                     LEAVE
     C                     END
     C                     Z-ADD*ZERO     W@L
     C                     ADD  1         W@M
     C                     Z-ADD1         W@S
     C                     DO   FC#BOX
     C                     ADD  1         W@L
     C           W@L       IFGT 5
     C                     Z-ADD1         W@L
     C                     ADD  1         W@S
     C           W@S       IFGT 72
     C                     Z-ADD1         W@S
     C                     ADD  1         W@M
     C                     END
     C                     END
     C                     Z-ADDW@L       W#L
     C                     Z-ADDW@M       W#M
     C                     Z-ADDW@S       W#S
     C                     Z-ADD1         I#BOX
     C                     WRITEABWPP381
     C                     ENDDO
     C                     ENDDO
     C*
     C           *LIKE     DEFN ISBAN     W@SBAN
     C           *LIKE     DEFN IMHN      W@MHN
     C                     MOVEL*BLANK    W@SBAN
     C                     MOVEL*BLANK    W@MHN
     C                     MOVEL*BLANK    W@LOC1  1
     C                     MOVEL*BLANK    W@LOC2  2
     C                     MOVEL*BLANK    W@LOC3  2
     C                     MOVEL*BLANK    W@LOC4  1
     C                     Z-ADD*ZERO     WHAKO
     C                     Z-ADD*ZERO     WD#BOX  50
     C                     MOVEL*OFF      W@1ST   1
     C                     Z-ADD*ZERO     W@@L    10
     C           *LOVAL    SETLLABWPP38
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ABWPP38                  99
     C           *IN99     IFEQ *ON
     C                     EXSR SUBR
     C                     EXSR DOCR
     C                     LEAVE
     C                     END
     C*
     C           W@SBAN    IFEQ *BLANK
     C                     MOVELISBAN     W@SBAN
     C                     END
     C           W@MHN     IFEQ *BLANK
     C                     MOVELIMHN      W@MHN
     C                     END
     C           W@@L      IFEQ *ZERO
     C                     Z-ADDW#L       W@@L
     C                     END
     C           W@1ST     IFEQ *OFF
     C                     MOVELFCLOC1    W@LOC1
     C                     MOVELFCLOC2    W@LOC2
     C                     MOVELFCLOC3    W@LOC3
     C                     MOVELFCLOC4    W@LOC4
     C                     MOVEL*ON       W@1ST
     C                     END
     C*
     C           ISBAN     IFNE W@SBAN
     C           IMHN      ORNE W@MHN
     C           W#L       ORNE W@@L
     C                     EXSR SUBR
     C                     MOVELISBAN     W@SBAN
     C                     MOVELIMHN      W@MHN
     C                     Z-ADDW#L       W@@L
     C                     MOVELFCLOC1    W@LOC1
     C                     MOVELFCLOC2    W@LOC2
     C                     MOVELFCLOC3    W@LOC3
     C                     MOVELFCLOC4    W@LOC4
     C                     END
     C*
