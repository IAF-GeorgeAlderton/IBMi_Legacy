     C                     ELSE
     C                     MOVEL@KY2,5    #KEY2
     C                     MOVEL#KEY2     HKEY2
     C                     END
     C                     Z-ADD0         A
     C           KEY1      KLIST
     C                     KFLD           @YY
     C                     KFLD           @MM
     C                     KFLD           KUKER
     C                     KFLD           KSIRE
     C                     KFLD           KAKI1
     C                     KFLD           KZINM
     C                     KFLD           KZIKI
     C           KEY5      KLIST
     C                     KFLD           @YY
     C                     KFLD           @MM
     C                     KFLD           HUKER
     C                     KFLD           HSIRE
     C                     KFLD           HZINM
     C                     KFLD           HZIKI
     C           @JKBN     IFEQ 'A'
     C           KEY1      SETGTGK#PL141
     C                     ELSE
     C           KEY5      SETGTGK#PL211
     C                     END
     C                     DO   *HIVAL
     C           @JKBN     IFEQ 'A'
     C           KEY       READEGK#PL141                 99
     C   99                GOTO $RLUP
     C           X4SKJY    IFEQ 'D'
     C           X4SKHZ    CABLE*DATE     @001
     C                     END
     C           X4KOJ     CABNE@KOJ      @001
     C                     ELSE
     C           KEY       READEGK#PL211                 99
     C   99                GOTO $RLUP
     C           X6SKJY    IFEQ 'D'
     C           X6SKHZ    CABLE*DATE     @001
     C                     END
     C                     END
     C                     ADD  1         A
     C           A         IFEQ 1
     C                     EXSR #CLR2
     C                     END
     C           XXNO      ADD  A         @NO,A
     C                     EXSR #SET1
     C           A         CABGE5         $RLUP
     C           @001      TAG
     C                     END
     C           $RLUP     ENDSR
     C/SPACE 1
     C*****************************************************
     C* MO-NO12  SUBRUTN   ROLL-DOWN
     C*****************************************************
     C           #RLDN     BEGSR
     C                     MOVEA'00000'   *IN,41
     C                     MOVEA'00000'   *IN,46
     C           @JKBN     IFEQ 'A'
     C           @KY1,1    CABEQ*BLANK    $RLDN          99
     C                     ELSE
     C           @KY2,1    CABEQ*BLANK    $RLDN          99
     C                     END
     C                     Z-ADD6         A
     C                     Z-ADD@NO,1     XXNO
     C           @JKBN     IFEQ 'A'
     C                     MOVE @KY1,1    #KEY1
     C                     MOVE #KEY1     KKEY1
     C                     ELSE
     C                     MOVE @KY2,1    #KEY2
     C                     MOVE #KEY2     HKEY2
     C                     END
     C           @JKBN     IFEQ 'A'
     C           KEY1      SETLLGK#PL141
     C                     ELSE
     C           KEY5      SETLLGK#PL211
     C                     END
     C                     DO   *HIVAL
     C           @JKBN     IFEQ 'A'
     C                     READPGK#PL141                 99
     C   99                GOTO $RLDN
     C           X4SKJY    IFEQ 'D'
     C           X4SKHZ    CABLE*DATE     @002
     C                     END
     C           X4UKER    COMP @UKER                9999
     C   99                GOTO $RLDN
     C           X4SIRE    COMP @SIRE                9999
     C   99                GOTO $RLDN
     C           X4KOJ     COMP @KOJ                 9999
     C   99                GOTO $RLDN
     C                     ELSE
     C                     READPGK#PL211                 99
     C   99                GOTO $RLDN
     C           X6SKJY    IFEQ 'D'
     C           X6SKHZ    CABLE*DATE     @002
     C                     END
     C           X6UKER    COMP @UKER                9999
     C   99                GOTO $RLDN
     C           X6SIRE    COMP @SIRE                9999
     C   99                GOTO $RLDN
     C                     END
     C                     SUB  1         A
     C           A         IFEQ 5
     C                     EXSR #CLR2
     C                     END
     C           XXNO      SUB  1         @NO,A
     C                     Z-ADD@NO,A     XXNO
     C                     EXSR #SET1
     C           A         CABLE1         $RLDN
     C           @002      TAG
     C                     END
     C           $RLDN     ENDSR
     C/SPACE 1
     C*****************************************************
     C* MO-NO13  SUBRUTN   CHAIN & UPDAT
     C*****************************************************
     C           #UPDAT    BEGSR
     C           @JKBN     IFEQ 'A'
     C           KEY2      KLIST
     C                     KFLD           @YY
     C                     KFLD           @MM
     C                     KFLD           @UKER
     C                     KFLD           @SIRE
     C                     KFLD           WAKI1
     C                     KFLD           WZIN
     C                     KFLD           WZIK
     C                     SETOF                     30
     C           KEY2      CHAINGK#PL141             30
     C           *IN30     IFEQ '1'
     C                     MOVE '1'       *IN,Y
     C                     MOVE '1'       *IN,Z
     C                     MOVE '1'       *IN99
     C                     MOVELER,16     MSG
     C                     GOTO @SCR3
     C                     END
     C           X4SKJY    IFEQ 'D'
     C           X4SKHZ    ANDLE*DATE
     C                     MOVE '1'       *IN,Y
     C                     MOVE '1'       *IN,Z
     C                     MOVE '1'       *IN99
     C                     MOVELER,16     MSG
     C                     GOTO @SCR3
     C                     END
     C                     ADD  1         CNT
     C                     ADD  WJRY      X4JRYO
     C           WCOI      IFNE 0
     C                     ADD  WCOI      X4COIL
     C                     END
     C                     EXSR #SET3
     C                     UPDATGK#PL141
     C                     MOVE '1'       *IN,M
     C                     MOVE '1'       *IN,N
     C*
     C                     ELSE
     C*
     C           KEY4      KLIST
     C                     KFLD           @YY
     C                     KFLD           @MM
     C                     KFLD           @UKER
     C                     KFLD           @SIRE
     C                     KFLD           WZIN
     C                     KFLD           WZIK
     C                     SETOF                     30
     C           KEY4      CHAINGK#PL211             30
     C           *IN30     IFEQ '1'
     C                     MOVE '1'       *IN,Y
     C                     MOVE '1'       *IN,Z
     C                     MOVE '1'       *IN99
     C                     MOVELER,16     MSG
     C                     GOTO @SCR3
     C                     END
     C           X6SKJY    IFEQ 'D'
     C           X6SKHZ    ANDLE*DATE
     C                     MOVE '1'       *IN,Y
     C                     MOVE '1'       *IN,Z
     C                     MOVE '1'       *IN99
     C                     MOVELER,16     MSG
     C                     GOTO @SCR3
     C                     END
     C                     ADD  1         CNT
     C                     ADD  WJRY      X6JRYO
     C           WCOI      IFNE 0
     C                     ADD  WCOI      X6COIL
     C                     END
     C                     EXSR #SET3
     C                     UPDATGK#PL211
     C                     MOVE '1'       *IN,M
     C                     MOVE '1'       *IN,N
     C                     END
     C                     ENDSR
