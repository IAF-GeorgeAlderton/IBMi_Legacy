     H            Y.
      ** ALFR73 *********************************************
      * STORE WIRE INTO VIRTUAL LOCATION (WIRE)
      *   LEC .................     2025.06.23              *
      *******************************************************
     FALFPW73 CF  E                    WORKSTN
     FIZAWP01 IF  E                    DISK
      *
     E                    WK1        20  1
     E                    WK2        20  1
     E                    ER      1  10 60
      *
      *  wire kanban barcode
     I            DS
     I                                        1  20 WKKANB
     I                                        1   1 TYPE
     I                                        2   5 ABSID
     I                                        6  12 M#
     I                                       13  15 C#
     I                                       16  16 SPC
     I                                       17  17 CHDG1
      *
      *  ASJ wire kanban barcode
     I            DS
     I                                        1  16 WKASJ
     I                                        1   6 ORDT
     I                                        7  11 SEQ
     I                                       12  12 ATYPE
     I                                       13  16 AABSID
      *
      *  location QR ds
     I            DS
     I                                        1  10 D1QR
     I                                        1   6 LCLOCN
     I                                        7  10 LCFILL
      *
      *  location from izawp01
     I            DS
     I                                        1   6 SVLOCN
     I                                        1   1 SVLOC1
     I                                        2   3 SVLOC2
     I                                        4   5 SVLOC3
     I                                        6   6 SVLOC4
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60HHMMSS
     I                                        7  140WDATE
     I                                        7  100WYY
     I                                       11  120WMM
     I                                       13  140WDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           POPR    6
     C                     PARM           PWKNM  20
      *
     **==============================================================**
     **  KEY
     **==============================================================**
     C           K#KEY1    KLIST
     C                     KFLD           WIREBC 20
      *----------------------------------------------------*
      * MAINLINE                                           *
      *----------------------------------------------------*
     C                     MOVEL'01'      DSPSW   2
      *
     C           DSPSW     DOUEQ'99'
      *
     C                     SELEC
     C           DSPSW     WHEQ '01'
     C                     EXSR #SB100
     C           DSPSW     WHEQ '02'
     C                     EXSR #SB200
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *
      *------------------------------------------------------------*
      * SCREEN ONE - Display Screen for Location Tag
      *------------------------------------------------------------*
     C           #SB100    BEGSR
      *
     C                     EXFMTALFPW771
     C                     SETOF                     9931
      *
     C           *IN01     IFEQ *ON
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB100
     C                     ENDIF
      *
      * if Location code is Blank, display error
     C           D1QR      IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     EXSR #SB290
     C                     GOTO ESB100
     C                     ENDIF
      *
      * if Location QR code is Blank, display error
     C           D1QR      IFNE 'WIRE'
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     EXSR #SB290
     C                     GOTO ESB100
     C                     ENDIF
      *
     C                     MOVEL'02'      DSPSW
      *
     C           ESB100    ENDSR
      *
      *---------------------------------------------------------------
      * SECOND SCREEN - Display Screen for Wire Kanban
      *------------------------------------------------------------*
     C           #SB200    BEGSR
      *
     C                     EXFMTALFPW772
     C                     SETOF                     9931
     C                     TIME           WTIME
      *
     C           *IN01     IFEQ *ON
     C                     MOVEL'01'      DSPSW
     C                     MOVE *BLANKS   D2QR
     C                     MOVE *BLANKS   D1QR
     C                     GOTO ESB200
     C                     ENDIF
      *
      * remove '-' from bar code, unless it's check digit
     C                     MOVEAD2QR      WK1       P
     C                     MOVE *BLANK    WK2
     C                     Z-ADD*ZERO     X       20
     C                     Z-ADD*ZERO     Y       20
      *
     C           1         DO   20        X
     C           WK1,X     IFNE '-'
     C           WK1,X     ANDNE*BLANK
     C           X         ORGT 15
     C                     ADD  1         Y
     C                     MOVE WK1,X     WK2,Y
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAWK2       D2QR      P
      *
      * get absolute part id from wire kanban barcode just scanned
     C                     MOVELD2QR      WKKANB
      *
     C           D2QR      IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,2      D9ERR
     C                     EXSR #SB290
     C                     GOTO ESB200
     C                     ENDIF
      *
     C                     EXSR #SB150
      *
     C           *IN21     IFEQ *OFF
     C                     MOVELER,3      D9ERR
     C                     SETON                     99
     C                     EXSR #SB290
     C                     GOTO ESB200
     C                     ENDIF
      *
      * call update program for wire inventory...
     C                     EXSR #SB550
      *
      * display ok screen...
     C                     EXFMTALFPW095
      *
     C                     MOVEL*BLANK    D2QR
      *
     C           ESB200    ENDSR
      *------------------------------------------------------------*
      * GET WIRE INFO - Get material name, wire diameter, supplier *
      *------------------------------------------------------------*
     C           #SB150    BEGSR
      *
     C                     MOVE *OFF      *IN21
      *
     C           1         SETLLIZAWP01
     C                     DO   *HIVAL
      *
     C                     READ IZAWP01                  50
     C           *IN50     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C           ZCKNO3    IFEQ ABSID
     C                     MOVELZCADR1    SVLOC1
     C                     MOVELZCADR2    SVLOC2
     C                     MOVELZCADR3    SVLOC3
     C                     MOVELZCADR4    SVLOC4
     C                     MOVE *ON       *IN21            FOUND IT
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------------*
      * ERROR SCREEN - Display Error on Screen
      *------------------------------------------------------------*
     C           #SB290    BEGSR
      *
     C                     WRITEALFPW098
     C                     EXFMTALFPW099
      *
     C                     ENDSR
      *------------------------------------------------------------*
      * Call Program to Update Wire Inventory file
      *------------------------------------------------------------*
     C           #SB550    BEGSR
      *
     C                     MOVELW#PGM     ##PGM  10
     C                     CALL 'IZAR70U'
     C                     PARM           D2QR
     C                     PARM           LCLOCN
     C                     PARM           POPR
     C                     PARM           ##PGM
     C                     PARM           ##LOTN  8
     C                     PARM           ##CHRG  7
     C                     PARM           ##WEIG  51
     C                     PARM 'N'       CHGQ    1
     C                     PARM           NEWQ    21
     C                     PARM           RTNCD   1
      *
     C                     ENDSR
      *
      *----------------------------------------------------*
** ER(60A).........2.........3.........4.........5.........6
LOCATION TAG INVALID                                           01
SCAN WIRE KANBAN                                               02
ABSOLUTE ID NOT FOUND                                          03
                                                               04
                                                               05
                                                               06
                                                               07
                                                               08
                                                               09
                                                               10
