     H            Y.                                    1
     H** ABBR9A ****************************************************************
     H*  FLAG INVENTORY ENTRY                                                  *
     H*
     H* TCHK1 11/06/09 CREATE
     H* TCHK2 11/12/09 ADD ERROR LOG FILE
     H**************************************************************************
     FABBPW9A CF  E                    WORKSTN
     FAAJPL11 IF  E           K        DISK
     FFCEPL07 IF  E           K        DISK
TCHK2FGHCPL21 IF  E           K        DISK
     FABBPP9A UF  E           K        DISK                      A
     FABBPP9C O   E                    DISK
      **************************************************************************
     E                    ERR     1   5 15
      **************************************************************************
     I* BARCODE/LOCATION
     I            DS
     I                                        1  10 D@LOC
     I                                        1   4 LOCID
     I                                        5  10 D@LOC1
     I                                        5   5 LOC1
     I                                        6   7 LOC2
     I                                        8   9 LOC3
     I                                       10  10 LOC4
     I            DS
     I                                        1  20 D@P#LC
     I                                        1   4 PLOCID
     I                                        5  10 D@P#L1
     I                                        5   5 PLOC1
     I                                        6   7 PLOC2
     I                                        8   9 PLOC3
     I                                       10  10 PLOC4
TCHK2I            DS
TCHK2I                                        1  12 W@PART
TCHK2I                                        1   5 W@PRT1
TCHK2I                                        6  10 W@PRT2
TCHK2I                                       11  12 W@PRT3
     I* SYSTEM DATE & TIME
     I            DS
     I                                        1  140@TIME
     I                                        1   60ALTIME
     I                                        7  140ALDATE
     I            DS
     I                                        1  140@@DTTM
     I                                        1   60@@TIME
     I                                        7  140@@DATE
     I*
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     C**************************************************************************
     C*                    MAIN ROUTINE
     C**************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1           LOCATION
     C           @@ID      CASEQ'02'      #SCRN2           # OF KAN
     C                     ENDCS
     C                     ENDDO
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
     C**************************************************************************
     C           *INZSR    BEGSR
     C**************************************************************************
     C                     TIME           @TIME
     C                     TIME           @@DTTM
     C                     Z-ADD@@DATE    K@DATE
     C*
     C                     MOVEL'01'      @@ID    2
     C                     MOVEL*BLANK    D@LOC
     C                     MOVEL*BLANK    D@ERR
     C                     MOVEL*BLANK    W@LOC  10
     C*
     C                     ENDSR
     C**************************************************************************
     C           #SCRN1    BEGSR
     C**************************************************************************
     C*
     C                     EXFMTFMT010
     C                     MOVEL*BLANK    D@ERR
     C*
     C                     SELEC
     C*
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C*
     C           *INKB     WHEQ *ON
     C                     MOVELW@LOC     K@PREV
     C           K#P9A1    KLIST
     C                     KFLD           K@DATE  80
     C                     KFLD           K@PREV 10
     C           K#P9A1    CHAINABBPP9A              96
     C           *IN96     IFEQ '0'
     C                     MOVELA9BARC    D@P#LC
     C                     Z-ADDA9KANS    D@KANV
     C                     DO   *HIVAL
     C                     EXFMTFMT030
     C           *INKC     IFEQ *ON
     C                     LEAVE
     C                     END
     C           *INKD     IFEQ *ON
     C                     DELETABBPP9A
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     END
     C                     MOVEL'01'      @@ID
     C                     MOVEL*BLANK    D@LOC
     C                     MOVEL*BLANK    D@ERR
     C*
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     MOVE '02'      @@ID
     C                     END
     C*
     C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
     C*     CHECK LOC#
     C           #CHK1     BEGSR
     C**************************************************************************
     C                     MOVEL*OFF      *IN99                        F5
     C                     MOVEL*OFF      *IN61                        F5
     C                     MOVEL*BLANK    D@ERR                        F5
TCHK2C                     MOVEL*BLANK    W@ERFG  1
     C*
     C                     DO
     C*
     C           D@LOC     IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     D@ERR
     C                     LEAVE
     C                     END
     C*
     C           K#P9A2    KLIST
     C                     KFLD           K@DATE  80
     C                     KFLD           D@LOC
     C           K#P9A2    CHAINABBPP9A             N97
     C           *IN97     IFEQ *OFF
     C                     SETON                     9961
     C           D@ERR     IFEQ *BLANK
     C                     MOVELERR,2     D@ERR
TCHK2C                     MOVEL'2'       W@ERFG
TCHK2C                     EXSR #ERR
     C                     END
     C                     LEAVE
     C                     END
     C*
     C           K#AAJ1    KLIST
     C                     KFLD           LOC1
     C                     KFLD           LOC2
     C                     KFLD           LOC3
     C                     KFLD           LOC4
     C                     KFLD           K#YYYY  40
     C                     Z-ADD9999      K#YYYY
     C           K#AAJ1    CHAINAAJPL11              98
     C           *IN98     IFEQ *ON
     C                     SETON                     9961
     C           D@ERR     IFEQ *BLANK
     C                     MOVELERR,3     D@ERR
TCHK2C                     MOVEL'3'       W@ERFG
TCHK2C                     EXSR #ERR
     C                     END
     C                     LEAVE
     C                     END
     C*
     C           LOCID     CHAINFCEPL07              95
     C           *IN95     IFEQ *ON
     C           A2GSKD    ORNE *BLANK
     C                     SETON                     9961
     C           D@ERR     IFEQ *BLANK
     C                     MOVELERR,4     D@ERR
TCHK2C                     MOVEL'4'       W@ERFG
TCHK2C                     EXSR #ERR
     C                     END
     C                     LEAVE
     C                     END
     C*
     C           A2BHB1    IFNE CJHIN1
     C           A2BHB2    ORNE CJHIN2
     C           A2BHB3    ORNE CJHIN3
TCHK2C           K#L21A    KLIST
TCHK2C                     KFLD           A2BHB1
TCHK2C                     KFLD           A2BHB2
TCHK2C                     KFLD           A2BHB3
TCHK2C           K#L21A    SETLLGHCPL21
TCHK2C                     DO   *HIVAL
TCHK2C           K#L21A    READEGHCPL21                  94
TCHK2C   94                LEAVE
TCHK2C           M7MBN1    IFEQ LOC1
TCHK2C           M7MBN2    ANDEQLOC2
TCHK2C           M7MBN3    ANDEQLOC3
TCHK2C           M7MBN4    ANDEQLOC4
TCHK2C                     LEAVE
TCHK2C                     END
TCHK2C                     ENDDO
TCHK2C           *IN94     IFEQ *ON
     C                     SETON                     9961
     C           D@ERR     IFEQ *BLANK
     C                     MOVELERR,5     D@ERR
TCHK2C                     MOVEL'5'       W@ERFG
TCHK2C                     EXSR #ERR
     C                     END
     C                     LEAVE
TCHK2C                     END
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C**************************************************************************
     C* INPUT # OF CONT
     C           #SCRN2    BEGSR
     C**************************************************************************
     C                     EXFMTFMT020
     C                     MOVEL*BLANK    D@ERR
     C*
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '01'      @@ID
     C                     MOVEL*BLANK    D@LOC
     C                     Z-ADD*ZERO     D@KANS
     C                     OTHER
     C                     EXSR #CHK3
     C           *IN99     IFEQ *OFF
     C                     EXSR #WRT1
     C                     MOVEL'01'      @@ID
     C                     MOVELD@LOC     W@LOC  10
     C                     MOVEL*BLANK    D@LOC
     C                     Z-ADD*ZERO     D@KANS
     C                     END
     C                     ENDSL
     C*
     C                     ENDSR
     C**************************************************************************
     C           #CHK3     BEGSR
     C**************************************************************************
     C                     MOVE *OFF      *IN99                        F5
     C                     MOVE *BLANK    D@ERR                        F5
     C*
     C                     ENDSR
     C**************************************************************************
     C*     WRITE
     C           #WRT1     BEGSR
     C**************************************************************************
     C                     CLEARABBPP9AR
     C*
     C                     TIME           @@DTTM
     C                     Z-ADD@@DATE    A9KODT
     C                     Z-ADD@@TIME    A9KOTM
     C                     MOVEL#USER     A9USER
     C*
     C                     Z-ADDK@DATE    A9KDAT
     C                     MOVELD@LOC     A9BARC
     C                     Z-ADDD@KANS    A9KANS
     C*
     C                     MOVELLOCID     A9ZETI
     C                     MOVELLOC1      A9LOC1
     C                     MOVELLOC2      A9LOC2
     C                     MOVELLOC3      A9LOC3
     C                     MOVELLOC4      A9LOC4
     C*
     C                     MOVELCJHIN1    A9SHN1
     C                     MOVELCJHIN2    A9SHN2
     C                     MOVELCJHIN3    A9SHN3
     C*
     C                     WRITEABBPP9AR
     C*
     C                     ENDSR
TCHK2C**************************************************************************
TCHK2C*     ERROR LOG
TCHK2C           #ERR      BEGSR
TCHK2C**************************************************************************
TCHK2C                     CLEARABBPP9CR
TCHK2C*
TCHK2C                     TIME           @@DTTM
TCHK2C                     Z-ADD@@DATE    ACKODT
TCHK2C                     Z-ADD@@TIME    ACKOTM
TCHK2C                     MOVEL#USER     ACUSER
TCHK2C*
TCHK2C                     Z-ADDK@DATE    ACKDAT
TCHK2C                     MOVELD@LOC     ACBARC
TCHK2C*
TCHK2C                     MOVELLOCID     ACZETI
TCHK2C                     MOVELLOC1      ACLOC1
TCHK2C                     MOVELLOC2      ACLOC2
TCHK2C                     MOVELLOC3      ACLOC3
TCHK2C                     MOVELLOC4      ACLOC4
TCHK2C*
TCHK2C                     MOVELD@ERR     ACERRM
TCHK2C*
TCHK2C           W@ERFG    IFEQ '5'
TCHK2C                     MOVELA2BHB1    W@PRT1
TCHK2C                     MOVELA2BHB2    W@PRT2
TCHK2C                     MOVELA2BHB3    W@PRT3
TCHK2C                     MOVELW@PART    ACPAR1
TCHK2C                     MOVELCJHIN1    W@PRT1
TCHK2C                     MOVELCJHIN2    W@PRT2
TCHK2C                     MOVELCJHIN3    W@PRT3
TCHK2C                     MOVELW@PART    ACPAR2
TCHK2C                     END
TCHK2C*
TCHK2C                     WRITEABBPP9CR
TCHK2C*
TCHK2C                     ENDSR
** ERR
LOCATION BLANK
ALREADY SCANNED
LOCATION L ERR
LOCATION P ERR
LOCATION ERROR
