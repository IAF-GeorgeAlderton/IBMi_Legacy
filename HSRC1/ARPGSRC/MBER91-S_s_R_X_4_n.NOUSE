      *
     C           *INL1     IFEQ '1'
     C                     EXSR #SB100
     C                     END
      *
     C           *INOF     IFEQ '1'
     C                     EXCPTHED
     C                     SETOF                     OF
     C                     END
     C                     ADD  ITNSU     WTNSU
      *
     CL1                   EXCPTDET
