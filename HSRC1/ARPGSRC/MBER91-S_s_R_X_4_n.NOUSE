     C           #SB100    BEGSR
     C                     MOVE *BLANK    KOT
     C                     MOVE *BLANK    KBM
     C                     MOVE *BLANK    TKR
     C                     MOVE *BLANK    KBN
     C                     MOVE *BLANK    LSM
     C                     MOVE *BLANK    XTKR
     C                     MOVE *BLANK    WTKR
      *
     C                     SETOF                     10
     C           KEY1      CHAINAAMPL111             10
     C           *IN10     IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
      *
     C           *IN10     IFEQ '0'
     C                     Z-ADD1         A       20
     C                     Z-ADD0         B       20
     C           1         DO   13        A
     C                     MOVELCKHZ,A    WUKH    80
     C           *DATE     IFLT WUKH
     C           CKQK,A    IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE CKQK,A    KOT,B
     C                     Z-ADDCKQB,A    KBM,B
     C                     MOVE CKQT,A    XTKR
     C                     MOVE XTKR1     WATK1
     C                     MOVE '-'       WBTK1
     C                     MOVE XTKR2     WATK2
     C                     MOVE '-'       WBTK2
     C                     MOVE XTKR3     WATK3
     C                     MOVE '-'       WBTK3
     C                     MOVE XTKR4     WATK4
     C                     MOVE WTKR      TKR,B
     C                     MOVE CKQS,A    KBN,B
     C                     END
     C                     ELSE
     C           CKKO,A    IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE CKKO,A    KOT,B
     C                     Z-ADDCKBM,A    KBM,B
     C                     MOVE CKNB,A    XTKR
     C                     MOVE XTKR1     WATK1
     C                     MOVE '-'       WBTK1
     C                     MOVE XTKR2     WATK2
     C                     MOVE '-'       WBTK2
     C                     MOVE XTKR3     WATK3
     C                     MOVE '-'       WBTK3
     C                     MOVE XTKR4     WATK4
     C                     MOVE WTKR      TKR,B
     C                     MOVE CKTY,A    KBN,B
     C                     END
     C                     END
     C                     ENDDO
      *
     C                     ELSE
     C                     SETOF                     16
     C           KEY1      CHAINFCEPL011             16
     C           *IN16     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     16
     C                     END
     C           *IN16     IFEQ '0'
     C                     Z-ADD1         A
     C                     Z-ADD0         B
     C           1         DO   13        A
     C           @KOT,A    IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE @KOT,A    KOT,B
     C                     Z-ADD@KBM,A    KBM,B
     C                     END
     C                     ENDDO
     C                     END
      *
     C                     END
      *
     C                     MOVE *BLANK    LSM
     C                     Z-ADD1         B
     C           1         DO   13        B
     C                     SETOF                     15
     C           KBM,B     CHAINFGBPL011             15
     C           *IN15     IFEQ '0'
     C                     MOVELB2KEMI    LSM,B
     C                     END
     C                     ENDDO
     C*
     C                     MOVEA'00000000'*IN,31
     C                     MOVEA'00000'   *IN,38
     C                     Z-ADD1         A
     C           1         DO   13        A
     C           A         ADD  30        K       20
     C           KOT,A     IFEQ *BLANK
     C                     MOVE '1'       *IN,K
     C                     END
     C                     ENDDO
      *
     C                     ADD  1         FKEN    30
      *
     C           ESB100    ENDSR
