     H            Y.
     F** UTLR21A *******************************************
     F*  PROGRAM: UTILITY- GET LAST LOCATION BY IAF PART#  *
     F*  WRITTEN: JW (SRA)  2018.02.19                     *
     F*  -----------------------------                     *
     F*  JW    2019.01.04 ADD $MQTY
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR21A'
     F*                    PARM           $SHIN  12
     F*                    PARM           $LLOC   6
     F*                    PARM           $LQC    50
     F*                    PARM           $LPRC   3
     F*                    PARM           $LDPT   40
     F*                    PARM           $ZETI   4
ADD  F*                    PARM           $MQTY   90
     F*                    PARM           $RTN    1
     F*  IN  $SHIN : 12A  IAF PART
     F*  OUT $LLOC :  6A  CURRENT LAST LOCATION
     F*      $LQC  :  5,0 CURRENT QPC
     F*      $LPRC :  3A  LAST/FINAL PROCESS
     F*      $LDPT :  4,0 LAST/FINAL DEPARTMENT
     F*      $ZETI :  4A  ID#
ADD  F*      $MQTY :  9,0 MONTHLY SETTING QTY
     F*      $RTN  :  1A  RETURN CODE (BLANK/*)
     F******************************************************
     FFCEPL01 IF  E           K        DISK
     F******************************************************
      * PROCESS TABLE
      * NEW LOCATION
     I            DS
     I                                        1   6 NEWL
     I                                        1   1 A2STRK
     I                                        2   3 A2STRT
     I                                        4   5 A2STRR
     I                                        6   6 A2STRD
      * OLD LOCATION
     I            DS
     I                                        1   6 OLDL
     I                                        1   1 A2KTRK
     I                                        2   3 A2KTRT
     I                                        4   5 A2KTRR
     I                                        6   6 A2KTRD
      * LOCATION CHG DATE
     I            DS
     I                                        1   80A2TRHZ
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
      * Q/C CHG DATE
     I            DS
     I                                        1   80A2SYHZ
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
     I            DS
     I                                        1  12 @WSHN
     I                                        1   5 @WSHN1
     I                                        6  10 @WSHN2
     I                                       11  12 @WSHN3
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        1   20WSHH
     I                                        3   40WSMN
     I                                        5   60WSSS
     I                                        7  100WSYY
     I                                       11  120WSMM
     I                                       13  140WSDD
     I                                        1   40WSTM4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
      *
     C                     EXSR @INIT
      *
     C           KEY1      CHAINFCEPL01              99
     C           *IN99     IFEQ *OFF
      *
     C           A2TRHZ    IFGT TODAY
     C                     MOVELOLDL      $LLOC
     C                     ELSE
     C                     MOVELNEWL      $LLOC
     C                     ENDIF
      *
     C           A2SYHZ    IFGT TODAY
     C                     Z-ADDA2KSYS    $LQC
     C                     ELSE
     C                     Z-ADDA2SSYS    $LQC
     C                     ENDIF
      * LAST PROCESS/DEPT
     C                     MOVEL*BLANK    $LPRC
     C                     Z-ADD0         $LDPT
      * ZETI
     C                     MOVELA2ZETI    $ZETI
      * MONTHLY SETTING QTY
ADD  C                     Z-ADDA2GEKN    $MQTY
      *
     C                     ENDIF
      *
     C           *IN99     IFEQ *ON
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *=============================================================
      *                    INITIAL PROCESS
      *=============================================================
     C           @INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SHIN  12
     C                     PARM           $LLOC   6
     C                     PARM           $LQC    50
     C                     PARM           $LPRC   3
     C                     PARM           $LDPT   40
     C                     PARM           $ZETI   4
ADD  C                     PARM           $MQTY   90
     C                     PARM           $RTN    1
      *
     C           KEY1      KLIST
     C                     KFLD           @WSHN1
     C                     KFLD           @WSHN2
     C                     KFLD           @WSHN3
      * RETRIEVE SYSTEM TIME
     C                     TIME           WSDT
      *
     C                     CLEAR$LLOC
     C                     CLEAR$LQC
     C                     CLEAR$LPRC
     C                     CLEAR$LDPT
     C                     CLEAR$ZETI
     C                     CLEAR$MQTY
     C                     CLEAR$RTN
      *
     C                     MOVEL$SHIN     @WSHN
      *
     C                     ENDSR
