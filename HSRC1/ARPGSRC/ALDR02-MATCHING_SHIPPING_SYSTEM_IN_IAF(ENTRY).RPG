     C** QTY CHECK START ****************************************
     C*
     C*  TRANSFER FROM HEX TO CHAR NUMERIC
     C*                    Z-ADD*ZERO     WQTY2
     C*                    Z-ADD*ZERO     WQTY3
     C*                    Z-ADD1         WSISU
     C*                    Z-ADD4         L
     C*                    MOVEABQTY      QTY
     C*
     C*                    DO   4
     C*                    Z-ADD1         X
     C*          QTY,L     LOKUPHEX,X                    42
     C*
     C*          *IN42     IFNE '0'
     C*          WSISU     MULT NUM,X     WQTY2
     C*                    ADD  WQTY2     WQTY3
     C*                    END
     C*          16        MULT WSISU     WSISU
     C*                    SUB  1         L
     C*
     C*                    END
     C*
     C*  DEPENDS ON SYSTEM DATE, USE OLD/NEW QTY
     C*          WSDATE    IFGE WQDATE
     C*          WQTY3     IFEQ A2SSYS
     C*                    ELSE
     C*                    SETON                     3033
     C*          MSG       IFEQ *BLANK
     C*                    MOVE ERR,3     MSG
     C*                    END
     C*                    END
     C*
     C*                    ELSE
     C*          WQTY3     IFEQ A2KSYS
     C*                    ELSE
     C*                    SETON                     3033
     C*          MSG       IFEQ *BLANK
     C*                    MOVE ERR,3     MSG
     C*                    END
     C*                    END
     C*                    END
     C* NOT FILE READ
     C*                    ELSE
     C*                    SETON                     3033
     C*          MSG       IFEQ *BLANK
     C*                    MOVE ERR,3     MSG
     C*                    END
     C*                    END
