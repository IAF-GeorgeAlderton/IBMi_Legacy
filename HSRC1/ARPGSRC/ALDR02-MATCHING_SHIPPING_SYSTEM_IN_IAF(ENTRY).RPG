     C           @CHK3     BEGSR
      *
     C                     SETOF                     303929
     C                     MOVE *BLANK    MSG
      *
      * make sure barcode scanned has numeric absolute (part) id, if not then
      * display screen again.  because kanbans get folded and sometimes
      * faded and worn, so they don't scan correctly. not team members fault.
     C                     TESTN          IDNO7      55
     C           *IN55     IFEQ *OFF
     C                     ADD  1         BADSCN  50
     C                     MOVEL*ON       W@ERCK
     C           BADSCN    IFGE 3
     C                     MOVELERR,13    MSG
     C                     MOVEL*OFF      W@ERCK
     C                     ENDIF
     C                     SETON                     3039
     C                     MOVE *BLANKS   BARKAX
     C                     GOTO #ECHK3
     C                     ENDIF
      *
     C* KANBAN KUBUN OK?
     C*          POS       IFNE 'POS'
     C*          BARKBN    IFEQ 'A'
     C*          BARKBN    OREQ 'R'
     C*          BARKBN    OREQ 'T'
     C* ERROR
     C*                    ELSE
     C*                    SETON                     3039
     C*          MSG       IFEQ *BLANK
     C*                    MOVE ERR,1     MSG
     **                    MOVE '01'      A5ERID
      *
   E2C*                    END
   E1C*                    END
     C*                    ENDIF
     C* ZETAI NO CHECK
   B1C           *IN30     IFEQ '0'
   B2C           A2ZETI    IFEQ IDNO7
     C*
     C                     ELSE
     C                     SETON                     3039
   B3C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
     C                     MOVE '01'      A5ERID
   E3C                     END
   E2C                     END
   E1C                     END
