     FUAAPW02 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        SFLRRNKSFILE SFLREC
     FFAAPL04 IF  E           K        DISK
     E                    ERR     1   3 78
     IINFDS       DS
     I                                      273 282 WSNAME
     I* SUBFILE START LINE DATA BASEKEY SAVE
     I            DS
     I                                        10025 SKEYDS
     I* SUBFILE LAST LINE DATA BASEKEY SAVE
     I            DS
     I                                        10025 EKEYDS
     I* SEARCH LOVAL KEY
     I            DS
     I                                     00010005 LVKY01
     I                                     00060010 LVKY02
     I                                     00110012 LVKY03
     I                                     00130016 LVKY04
     I                                     00170020 LVKY05
     I                                     00210021 LVKY06
     I                                     00220025 LVKY07
     I                                        10025 LVKYDS
     I* SEARCH HIVAL KEY
     I            DS
     I                                     00010005 HVKY01
     I                                     00060010 HVKY02
     I                                     00110012 HVKY03
     I                                     00130016 HVKY04
     I                                     00170020 HVKY05
     I                                     00210021 HVKY06
     I                                     00220025 HVKY07
     I                                        10025 HVKYDS
     I* DATA BASE KEY WORK FIELD
     I            DS
     I                                     00010005 FLKY01
     I                                     00060010 FLKY02
     I                                     00110012 FLKY03
     I                                     001300160FLKY04
     I                                     001700200FLKY05
     I                                     00210021 FLKY06
     I                                     00220025 FLKY07
     I                                        10025 FKEYDS
     I* DATA BASE FULL KEY
     I            DS
     I                                     00010005 B7SHN1
     I                                     00060010 B7SHN2
     I                                     00110012 B7SHN3
     I                                     001300160B7TOKU
     I                                     001700200B7NONY
     I                                     00210021 B7NKJO
     I                                     00220025 B7NUKE
     I                                        10025 DBKEY
     C* DB FULL KEY
     C           FULKEY    KLIST
     C                     KFLD           FLKY01
     C                     KFLD           FLKY02
     C                     KFLD           FLKY03
     C                     KFLD           FLKY04
     C                     KFLD           FLKY05
     C                     KFLD           FLKY06
     C                     KFLD           FLKY07
     C* LINES SET-UP
     C                     Z-ADD19        LINES   30
     C/SPACE 2
     C***********************************************
     C* MAIN ROUTINE                                *
     C***********************************************
     C           PUT01     TAG
     C                     EXFMTSCR1
     C* COMMAND KEY CHECK
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C* INPUT FIELD CHECK
     C           WSKY01    IFEQ *BLANK
     C                     MOVE ERR,1     ERRMSG 78
     C                     GOTO ERR01
     C                     END
     C*       *****************************************             *USER*
     C*      *        INSERT OTHER CHECK ROUTINE       *            *USER*
     C*     *       * SAMPLE *                          *           *USER*
     C*     *              MOVE ERR,X     ERRMSG        *           *USER*
     C*      *             GOTO ERR01                  *            *USER*
     C*       *****************************************             *USER*
     C* HIVAL/LOVAL/FULLKEY  INITIALIZE
     C                     MOVE *HIVAL    HVKYDS
     C                     MOVE *LOVAL    LVKYDS
     C                     MOVE *BLANK    FLKY01
     C                     MOVE *BLANK    FLKY02
     C                     MOVE *BLANK    FLKY03
     C                     MOVE *ZERO     FLKY04
     C                     MOVE *ZERO     FLKY05
     C                     MOVE *BLANK    FLKY06
     C                     MOVE *BLANK    FLKY07
     C* HIVAL/LOVAL/FULLKEYY SET
     C                     MOVE WSKY01    HVKY01
     C                     MOVE WSKY01    LVKY01
     C                     MOVE WSKY01    FLKY01
     C           WSKY02    IFNE *BLANK
     C                     MOVE WSKY02    HVKY02
     C                     MOVE WSKY02    LVKY02
     C                     MOVE WSKY02    FLKY02
     C                     END
     C           WSKY03    IFNE *BLANK
     C                     MOVE WSKY03    HVKY03
     C                     MOVE WSKY03    LVKY03
     C                     MOVE WSKY03    FLKY03
     C                     END
     C           WSKY04    IFNE *ZERO
     C                     MOVE WSKY04    HVKY04
     C                     MOVE WSKY04    LVKY04
     C                     MOVE WSKY04    FLKY04
     C                     END
     C           WSKY05    IFNE *ZERO
     C                     MOVE WSKY05    HVKY05
     C                     MOVE WSKY05    LVKY05
     C                     MOVE WSKY05    FLKY05
     C                     END
     C           WSKY06    IFNE *BLANK
     C                     MOVE WSKY06    HVKY06
     C                     MOVE WSKY06    LVKY06
     C                     MOVE WSKY06    FLKY06
     C                     END
     C           WSKY07    IFNE *BLANK
     C                     MOVE WSKY07    HVKY07
     C                     MOVE WSKY07    LVKY07
     C                     MOVE WSKY07    FLKY07
     C                     END
     C* DB-READ SUBROUTINE
     C                     SETON                     9091
     C                     EXSR SFLSTR
     C                     SETOF                     9091
     C   99                GOTO PUT01
     C                     GOTO PUT02
     C/SPACE 1
     C           ERR01     TAG
     C                     SETON                     99
     C                     GOTO PUT01
     C/SPACE 2
     C* SECOND SCREEN
     C           PUT02     TAG
     C                     WRITESCR2
     C                     DO   *HIVAL
     C   99                SETON                     98
     C  N99                SETON                     9798
     C                     EXFMTSFLCTL
     C                     SETOF                     9798
     C* COMMAND KEY CHECK
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C  N91N92             GOTO PUT01
     C* CALL DB-READ SUBROUTINE
     C                     EXSR SFLSTR
     C                     END
     C/EJECT
     C***********************************************
     C* DB-READ & STORE SUBROUTINE                  *
     C***********************************************
     C           SFLSTR    BEGSR
     C                     Z-ADD*ZERO     LINECT
     C/SPACE 2
     C* ROLL-UP(DB-POINTER SET)
     C           *IN91     IFEQ '1'
     C                     Z-ADD1         SFLRRN  40
     C* FIRST CALL ?
     C           *IN90     IFEQ '1'
     C           FULKEY    SETLLFAAPL04
     C* NORMAL ROLL-UP
     C                     ELSE
     C           LAST      IFEQ '*'
     C                     MOVE ERR,2     ERRMSG
     C                     GOTO ERRSTR
     C                     END
     C* PREVIOUS END KEY SET
     C                     MOVE EKEYDS    FKEYDS
     C           FULKEY    SETGTFAAPL04
     C                     END
     C/SPACE 2
     C* ROLL-DOWN(DB-POINTER SET)
     C                     ELSE
     C           PAGCNT    SUB  1         PAGWRK  30
     C           PAGWRK    IFLE *ZERO
     C                     MOVE ERR,2     ERRMSG
     C                     GOTO ERRSTR
     C                     END
     C* PREVIOUS START KEY SET
     C                     MOVE SKEYDS    FKEYDS
     C           FULKEY    SETLLFAAPL04
     C                     Z-ADDLINES     SFLRRN
     C                     END
     C/SPACE 2
     C* FIRST CYCLE FIELD INITIALIZE
     C           *IN90     IFEQ '1'
     C                     Z-ADD*ZERO     PAGCNT
     C                     END
     C* SFLCLR
     C                     SETON                     96
     C                     WRITESFLCTL
     C                     SETOF                     96
     C/SPACE 2
     C* DB-READ LOOP
     C                     DO   *HIVAL
     C           *IN91     IFEQ '1'
     C           STEP01    TAG
     C                     READ FAAPL04                  20
     C  N20      B7SKBN    CABEQ'D'       STEP01
     C   20                SETON                     94
     C                     ELSE
     C           STEP02    TAG
     C                     READPFAAPL04                  20
     C  N20      B7SKBN    CABEQ'D'       STEP02
     C                     END
     C* END OF FILE GROUP
     C           *IN20     CABEQ'1'       LPOUT
     C* RANGE CHECK
     C           DBKEY     CABLTLVKYDS    LPOUT
     C           DBKEY     IFGT HVKYDS
     C                     SETON                     94
     C                     GOTO LPOUT
     C                     END
     C* DB-FIELD TO WORK-STATION FIELD
     C*       *****************************************             *USER*
     C*      *     INSERT ADDTIONAL STATEMENT          *            *USER*
     C*      *       FOR USER DEFINED FIELDS           *            *USER*
     C*       *****************************************             *USER*
     C                     ADD  1         LINECT  30
     C                     WRITESFLREC
     C* START LINE KEY SAVE
     C           SFLRRN    IFEQ 1
     C                     MOVE DBKEY     SKEYDS
     C           *IN91     CABEQ'0'       LPOUT
     C                     END
     C* LAST LINE KEY SAVE
     C           SFLRRN    IFEQ LINES
     C                     MOVE DBKEY     EKEYDS
     C           *IN91     CABEQ'1'       LPOUT
     C                     END
     C           *IN91     IFEQ '1'
     C                     ADD  1         SFLRRN
     C                     ELSE
     C                     SUB  1         SFLRRN
     C                     END
     C                     END
     C*
     C/SPACE 2
     C           LPOUT     TAG
     C           LINECT    IFEQ *ZEROS
     C                     MOVE ERR,3     ERRMSG
     C                     GOTO ERRSTR
     C                     END
     C* PAGE  CONTROL
     C           *IN91     IFEQ '1'
     C                     ADD  1         PAGCNT  30
     C           LINECT    IFLT LINES
     C                     MOVE '*'       LAST    1
     C                     ELSE
     C                     MOVE *BLANK    LAST
     C                     END
     C                     ELSE
     C                     MOVE *BLANK    LAST
     C                     SUB  1         PAGCNT
     C                     END
     C*
     C                     GOTO ENDSTR
     C           ERRSTR    TAG
     C                     SETON                     99
     C           ENDSTR    ENDSR
