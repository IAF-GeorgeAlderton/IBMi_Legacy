     H            Y.
     H** AAWR11 ***********************************
     H* UPDATE OF K LOCATION M/F   RPG   *.
     H* C:K.HIROTA                      86.11.25  *
     H*********************************************
     FAAWPW11 CF  E                    WORKSTN
     FAAWPL11 UF  E           K        DISK                      A
     E                    ERR     1  18 60
     E                    DAY    13  13  2 0
     I            DS
     I                                        1  100STYMD
     I                                        1   40STYY
     I                                        5   60STMM
     I                                        7   80STDD
     I                                        9  100STBB
     I            DS
     I                                        1  100ENYMD
     I                                        1   40ENYY
     I                                        5   60ENMM
     I                                        7   80ENDD
     I                                        9  100ENBB
     I            DS
     I                                        1   60KOTIME
     I                                        1   20KOHH
     I                                        3   40KOSS
     I            DS
     I                                        1   80SYSDAT
     I                                        1   40SYSYY
     I                                        5   60SYSMM
     I                                        7   80SYSDD
     I            DS
     I                                        1   80WKDATE
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
     C           *ENTRY    PLIST
     C                     PARM           PUSR   10
     C                     MOVE *BLANK    KOUKUB
     C                     MOVE *BLANK    BABAN1
     C                     MOVE *BLANK    BABAN2
     C                     MOVE *BLANK    BABAN3
     C                     MOVE *BLANK    BABAN4
     C******************
     C* 画面１の処理 *
     C******************
     C           STEP1     TAG
     C                     EXFMTAAWPW111
     C                     SETOF                     99
     C                     SETOF                     0102
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C*
     C           KOUKUB    IFEQ '0'
     C                     MOVE 'CANCEL'  KMEI
     C                     ELSE
     C           KOUKUB    IFEQ '1'
     C                     MOVE 'CHANGE'  KMEI
     C                     ELSE
     C           KOUKUB    IFEQ '2'
     C                     MOVE 'ADD   '  KMEI
     C                     ELSE
     C                     SETON                     9901
     C                     MOVELERR,1     ERRMSG
     C                     GOTO STEP1
     C                     END
     C                     END
     C                     END
     C*
     C*
     C           STEP2     TAG
     C*
     C           BABAN1    IFEQ *BLANK
     C           BABAN2    ANDEQ*BLANK
     C           BABAN3    ANDEQ*BLANK
     C           BABAN4    ANDEQ*BLANK
     C                     SETON                     9902
     C                     MOVELERR,2     ERRMSG
     C                     GOTO STEP1
     C                     END
     C*
     C*
     C           KEY       KLIST
     C                     KFLD           BABAN1
     C                     KFLD           BABAN2
     C                     KFLD           BABAN3
     C                     KFLD           BABAN4
     C*
     C           KEY       CHAINAAWPL111             40
     C*
     C           *IN40     IFEQ '1'
     C           KOUKUB    IFEQ '0'
     C                     SETON                     9901
     C                     MOVELERR,3     ERRMSG
     C                     GOTO STEP1
     C                     END
     C           KOUKUB    IFEQ '1'
     C                     SETON                     9901
     C                     MOVELERR,4     ERRMSG
     C                     GOTO STEP1
     C                     END
     C                     END
     C*
     C           *IN40     IFEQ '0'
     C           BASKJY    IFEQ 'D'
     C           KOUKUB    IFEQ '0'
     C                     SETON                     9901
     C                     MOVELERR,5     ERRMSG
     C                     GOTO STEP1
     C                     END
     C           KOUKUB    IFEQ '1'
     C                     SETON                     9901
     C                     MOVELERR,6     ERRMSG
     C                     GOTO STEP1
     C                     END
     C                     END
     C                     END
     C*
     C           *IN40     IFEQ '0'
     C           BASKJY    IFNE 'D'
     C           KOUKUB    IFEQ '2'
     C                     SETON                     9901
     C                     MOVELERR,7     ERRMSG
     C                     GOTO STEP1
     C                     END
     C                     END
     C                     END
     C*
     C           KOUKUB    IFEQ '2'
     C           *IN40     ANDEQ'1'
     C                     MOVE *BLANK    BAHIN1
     C                     MOVE *BLANK    BAHIN2
     C                     MOVE *BLANK    BAHIN3
     C                     Z-ADD0         START
     C                     Z-ADD0         FINAL
     C                     ELSE
     C                     Z-ADDBASTYY    STYY
     C                     Z-ADDBASTMM    STMM
     C                     Z-ADDBASTDD    STDD
     C                     Z-ADDBASTBB    STBB
     C                     Z-ADDBAENYY    ENYY
     C                     Z-ADDBAENMM    ENMM
     C                     Z-ADDBAENDD    ENDD
     C                     Z-ADDBAENBB    ENBB
     C                     Z-ADDSTYMD     START
     C                     Z-ADDENYMD     FINAL
     C                     END
     C*
     C*******************
     C*  画面２の処理 *
     C*******************
     C           STEP3     TAG
     C                     EXFMTAAWPW112
     C                     SETOF                     99
     C                     SETOF                     0304
     C*
     C*********************
     C* RETURN OF GAMEN 1 *
     C*********************
     C           *INKC     IFEQ '1'
     C                     MOVE *BLANK    KOUKUB
     C                     MOVE *BLANK    BABAN1
     C                     MOVE *BLANK    BABAN2
     C                     MOVE *BLANK    BABAN3
     C                     MOVE *BLANK    BABAN4
     C                     GOTO STEP1
     C                     END
     C*******************
     C* HINBAN CHECK    *
     C*******************
     C*
     C           BAHIN1    IFEQ *BLANK
     C           BAHIN2    ANDEQ*BLANK
     C           BAHIN3    ANDEQ*BLANK
     C           START     ANDEQ9999999999
     C           FINAL     ANDEQ9999999999
     C                     Z-ADD9999      BASTYY
     C                     Z-ADD99        BASTMM
     C                     Z-ADD99        BASTDD
     C                     Z-ADD99        BASTBB
     C                     Z-ADD9999      BAENYY
     C                     Z-ADD99        BAENMM
     C                     Z-ADD99        BAENDD
     C                     Z-ADD99        BAENBB
     C                     GOTO STEP4
     C                     END
     C*
     C*******  HINBAN  =  BLANK  ********
     C*
     C           BAHIN1    IFEQ *BLANK
     C           BAHIN2    ANDEQ*BLANK
     C           BAHIN3    ANDEQ*BLANK
     C                     Z-ADD9999999999START
     C                     Z-ADD9999999999FINAL
     C                     GOTO STEP3
     C                     END
     C*
     C*******************
     C* HIZUKE CHECK    *
     C*******************
     C**** START  DATE ****
     C*
     C                     Z-ADDSTART     STYMD
     C                     Z-ADDFINAL     ENYMD
     C*
     C           STYMD     IFEQ 0
     C                     SETON                     9903
     C                     MOVELERR,17    ERRMSG
     C                     GOTO STEP3
     C                     END
     C*
     C           STYY      IFLT 1
     C                     SETON                     9903
     C                     MOVELERR,8     ERRMSG
     C                     GOTO STEP3
     C                     END
     C*
     C           STMM      IFLT 1
     C           STMM      ORGT 12
     C                     SETON                     9903
     C                     MOVELERR,9     ERRMSG
     C                     GOTO STEP3
     C                     END
     C*
     C           STMM      IFEQ 2
     C           STYY      DIV  4         WKDIV   20
     C                     MVR            WKMVR   10
     C           WKMVR     IFEQ 0
     C                     Z-ADD13        MM      20
     C                     ELSE
     C                     Z-ADDSTMM      MM
     C                     END
     C                     ELSE
     C                     Z-ADDSTMM      MM
     C                     END
     C*
     C           STDD      IFLT 1
     C           STDD      ORGT DAY,MM
     C                     SETON                     9903
     C                     MOVELERR,10    ERRMSG
     C                     GOTO STEP3
     C                     END
     C*
     C                     Z-ADDSTYY      WKYY
     C                     Z-ADDSTMM      WKMM
     C                     Z-ADDSTDD      WKDD
     C           WKDATE    IFLT *DATE
     C                     SETON                     9903
     C                     MOVELERR,18    ERRMSG
     C                     GOTO STEP3
     C                     END
     C*
     C           STBB      IFLT 1
     C           STBB      ORGT 16
     C                     SETON                     9903
     C                     MOVELERR,15    ERRMSG
     C                     GOTO STEP3
     C                     END
     C***** END DATE *****
     C*
     C           ENYMD     IFEQ 0
     C                     SETON                     9904
     C                     MOVELERR,17    ERRMSG
     C                     GOTO STEP3
     C                     END
     C           ENYY      IFLT 1
     C                     SETON                     9904
     C                     MOVELERR,11    ERRMSG
     C                     GOTO STEP3
     C                     END
     C*
     C           ENMM      IFLT 1
     C           ENMM      ORGT 12
     C                     SETON                     9904
     C                     MOVELERR,12    ERRMSG
     C                     GOTO STEP3
     C                     END
     C*
     C           ENMM      IFEQ 2
     C           ENYY      DIV  4         WKDIV
     C                     MVR            WKMVR
     C           WKMVR     IFEQ 0
     C                     Z-ADD13        MM
     C                     ELSE
     C                     Z-ADDENMM      MM
     C                     END
     C                     ELSE
     C                     Z-ADDENMM      MM
     C                     END
     C*
     C           ENDD      IFLT 1
     C           ENDD      ORGT DAY,MM
     C                     SETON                     9904
     C                     MOVELERR,13    ERRMSG
     C                     GOTO STEP3
     C                     END
     C*
     C           ENBB      IFLT 1
     C           ENBB      ORGT 16
     C                     SETON                     9904
     C                     MOVELERR,16    ERRMSG
     C                     GOTO STEP3
     C                     END
     C*
     C****************************
     C*  START DATE  :  ENDDATE  *
     C****************************
     C*
     C*
     C           STYMD     IFGT ENYMD
     C                     MOVEA'11'      *IN,03
     C                     SETON                     99
     C                     MOVELERR,14    ERRMSG
     C                     GOTO STEP3
     C                     END
     C*
     C*********************
     C* CMD5 ON/OFF CHECK *
     C*********************
     C*
     C                     Z-ADDSTYY      BASTYY
     C                     Z-ADDSTMM      BASTMM
     C                     Z-ADDSTDD      BASTDD
     C                     Z-ADDSTBB      BASTBB
     C                     Z-ADDENYY      BAENYY
     C                     Z-ADDENMM      BAENMM
     C                     Z-ADDENDD      BAENDD
     C                     Z-ADDENBB      BAENBB
     C*
     C           STEP4     TAG
     C           *INKE     CABEQ'0'       STEP3
     C********************************
     C* SAKUJYO CODE INPUT OR DELETE *
     C********************************
     C*
     C                     TIME           KOTIME
     C                     Z-ADDKOHH      BAKOHH
     C                     Z-ADDKOSS      BAKOSS
     C                     Z-ADD*DATE     SYSDAT
     C                     Z-ADDSYSYY     BASKYY
     C                     Z-ADDSYSYY     BAKOYY
     C                     Z-ADDSYSMM     BASKMM
     C                     Z-ADDSYSMM     BAKOMM
     C                     Z-ADDSYSDD     BASKDD
     C                     Z-ADDSYSDD     BAKODD
     C                     MOVE PUSR      BAKOME
     C*
     C           KOUKUB    IFEQ '0'
     C                     MOVE 'D'       BASKJY
     C                     ELSE
     C                     MOVE *BLANK    BASKJY
     C                     END
     C******************
     C* OUTPUT OF FILE *
     C******************
     C           *IN40     IFEQ '1'
     C                     WRITEAAWPL111
     C                     ELSE
     C                     UPDATAAWPL111
     C                     END
     C************************
     C* RETUAN TO GAMEN NO.1 *
     C************************
     C                     MOVE *BLANK    KOUKUB
     C                     MOVE *BLANK    BABAN1
     C                     MOVE *BLANK    BABAN2
     C                     MOVE *BLANK    BABAN3
     C                     MOVE *BLANK    BABAN4
     C                     GOTO STEP1
     C*
     C*
**  DAY
E-01 UPDATE INSTRUCTION RANGE IS  OUTSIDE. SELECT <0 1 2>.
E-02 K LOCATION IS NOT INPUT
E-03 EXECUTED CANCEL IN THE DATA WHICH DIDN'T EXIST IN
E-04 EXECUTED CHANGE IN THE DATA WHICH DIDN'T EXIST IN
E-05 THE DATA WHICH DELETE IS DELETED ALREADY.
E-06 THE DATA WHICH CHANGE IT IS DELETED ALREADY.
E-07 THE DATA WHICH IS ADDED TO THAT EXIST ALREADY.
E-08 START DATE(YEAR) ISN'T RIGHT.
E-09 START DATE (MONTH) ISN'T RIGHT.
E-10 START DATE (DAY)  ISN'T RIGHT.
E-11 EXIT DATE (YEAR)  ISN'T RIGHT.
E-12 EXIT DATE (MONTH) ISN'T RIGHT.
E-13 EXIT DATE (DAY)  ISN'T RIGHT.
E-14 RANGE OF START DATE AND EXIT DATE ISN'T RIGHT.
E-15 START DATE(BIN) ISN'T RIGHT.
E-16 EXIT DATE (BIN)  ISN'T RIGHT.
E-17 INPUT DATE
E-08 START DATE ISN'T RIGHT INPUT A DATE AFTER TODAY.
**  DAY
31283130313031313031303129
