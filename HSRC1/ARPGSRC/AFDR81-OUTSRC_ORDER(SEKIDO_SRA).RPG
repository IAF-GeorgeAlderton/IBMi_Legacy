     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #DSP01
     C           @@ID      CASEQ'02'      #DSP02
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------
     C*
     C           *ENTRY    PLIST
     C                     PARM           PUSR   10
     C                     PARM           PWKCD   6
     C                     PARM           SUPLY   4
     C                     PARM           PID     1
     C*
     C           KEY1      KLIST
     C                     KFLD           A2BHB1           INTERNAL PART
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C*
     C           KEY4      KLIST
     C                     KFLD           BCOCD            CONTROL CD
     C                     KFLD           BZETI            ABSOLUTE #
     C                     KFLD           WTEHI            TEHAI
     C                     KFLD           BPAGE            PAGE
     C                     KFLD           BNIJI            2ND.TREATEMENT
     C                     KFLD           BTICD            TARGET TYPE
     C                     KFLD           BYUKO            SHIP EFFECTIVE
     C                     KFLD           BHASY            CONTAINER TYPE
     C                     KFLD           BCKDT            CHECK DIGIT
      *
     C           K#AFD     KLIST
     C                     KFLD           SUPLY
     C                     KFLD           K@ORYY  40
     C                     KFLD           K@ORMM  20
     C                     KFLD           K@ORDD  20
     C                     KFLD           K@BIN   3
      *
     C                     Z-ADD*ZERO     K@ORYY
     C                     Z-ADD*ZERO     K@ORMM
     C                     Z-ADD*ZERO     K@ORDD
      *
     C                     MOVE SUPLY     @SUPP   40
     C           SUPLY     CAT  PID:0     SCODE   5 P
     C           SCODE     LOKUPTAB1      TAB2           10
     C                     MOVELTAB2      TITL
     C                     MOVE KBN,1     KANBN
      *
     C                     MOVE '01'      @@ID    2
     C                     MOVE *BLANK    MSG
     C                     SETOF                     30
     C*
     C                     TIME           WSDT
     C*
     C                     ENDSR
     C**************************************************************************
     C*    1ST SCREEN (SCAN INTRA KANBAN)
     C**************************************************************************
     C           #DSP01    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C*
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      @@ID
     C*
     C                     OTHER
     C                     EXSR @CHK1
     C           *IN30     IFEQ *OFF
     C                     MOVEL'02'      @@ID
     C                     ELSE
     C                     EXFMTERR99
     C                     SETOF                     30
     C                     MOVE *BLANK    MSG
     C                     END
     C*
     C                     ENDSL
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK1
     C**************************************************************************
     C           @CHK1     BEGSR
     C*
     C                     MOVE *OFF      *IN30
     C                     MOVE *BLANK    MSG
     C*
     C* ABSOLUTE NUMBER CHECK
     C           BZETI     SETLLFCETL11
     C           #ZETI     TAG
     C           BZETI     READEFCETL11                  90
     C           *IN90     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C                     SETON                     30
     C                     MOVE ER,3      MSG
     C                     GOTO #ECHK1
     C                     END
     C                     ELSE
     C                     SETON                     30
     C                     MOVE ER,3      MSG
     C                     GOTO #ECHK1
     C                     END
     C*
     C* WEIGHT CHECK
     C           A2KASI    IFEQ *ZERO
     C                     SETON                     30
     C                     MOVE ER,7      MSG
     C                     GOTO #ECHK1
     C                     END
     C*
     C* ORDER DETAIL FILE
     C           KEY4      SETGTAFDPL11
     C           KEY4      REDPEAFDPL11                  93
     C           *IN93     IFEQ '0'
     C           ADODYY    IFEQ *ZERO
     C           ADSKJY    ANDEQ*BLANK
     C           ADSUPP    ANDEQSUPLY
     C                     SETON                     30
     C                     MOVE ER,4      MSG
     C                     GOTO #ECHK1
     C                     END
     C                     END
      *
      * DIVISION CHECK
     C                     MOVE *BLANK    @KK
     C           KEY1      CHAINAAMPL11              91
     C           1         DO   15        X       30
     C                     MOVELCHG,X     @CHG
     C           @CHGDT    IFGT *DATE
     C                     MOVELKX,X      @K#,X            KANBAN
     C                     Z-ADDDEX,X     @DEP,X           DEPARTMENT
     C                     ELSE
     C                     MOVELKK,X      @K#,X            KANBAN
     C                     Z-ADDDP,X      @DEP,X           DEPARTMENT
     C                     END
     C                     ENDDO
     C           1         DO   15        X       30
     C           @DEP,X    IFEQ @SUPP
     C           @K#,X     ANDNE*BLANK
     C                     MOVE @K#,X     @KK     1
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C           @KK       IFEQ *BLANK
     C           1         DO   15        X       30
     C           DP,X      IFEQ @SUPP
     C           KK,X      ANDNE*BLANK
     C                     MOVE KK,X      @KK     1
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C           @KK       IFEQ *BLANK
     C                     SETON                     30
     C                     MOVE ER,10     MSG
     C                     GOTO #ECHK1
     C                     ENDIF
      *
     C           KEY1      SETLLABHTL02
     C                     DO   *HIVAL
     C           KEY1      READEABHTL02                  91
     C   91                LEAVE
     C           M6SKJY    IFEQ 'D'
     C           M6SKHZ    ANDLEWSSDAT
     C                     ITER
     C                     END
TCHK3C*          WSSDAT    IFGE M6UKHZ
TCHK3C*          WSSDAT    ANDLEM6STHZ
TCHK3C           M6STYY    IFEQ 9999
     C           M6BMON    ANDEQ@SUPP
     C                     ELSE
     C                     ITER
     C                     END
     C                     Z-ADDM6SYUY    @@QTY
JW2  C                     MOVEL'M6SYUY  'ADFIL2
     C                     LEAVE
     C                     ENDDO
     C           *IN91     IFEQ *ON
     C                     SETON                     30
     C                     MOVE ER,10     MSG
     C                     GOTO #ECHK1
     C                     END
      *
     C           @@QTY     IFEQ *ZERO
     C                     Z-ADDA2SSYS    @@QTY   50       QTY/CONT.
JW2  C                     MOVEL'A2SSYS 1'ADFIL2
     C                     END
     C*
     C           #ECHK1    TAG
      *
     C                     ENDSR
     C**************************************************************************
     C*   2ND SCREEN
     C**************************************************************************
     C           #DSP02    BEGSR
     C*
     C                     EXFMTDSP02
     C*
     C                     SELEC
     C*
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      @@ID
     C*
     C                     OTHER
     C                     EXSR @CHK2
     C           *IN30     IFEQ '0'
     C                     EXSR @WRT
     C                     EXFMTDSPOK
     C                     MOVEL*BLANK    BARC1
     C                     MOVE *BLANKS   BARC2
     C                     MOVE '01'      @@ID
     C                     ELSE
     C                     EXFMTERR99
     C                     SETOF                     30
     C                     MOVE *BLANK    MSG
     C                     END
     C*
     C                     ENDSL
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK2
     C**************************************************************************
     C           @CHK2     BEGSR
     C*
     C                     MOVE *OFF      *IN30
     C                     MOVE *BLANK    MSG
     C*
     C           BARC2     IFEQ *ZERO
     C                     MOVE *ON       *IN30
     C                     MOVE ER,6      MSG
     C                     ELSE
     C                     MOVE BARC2     K@BIN
     C           K#AFD     CHAINAFDPL10              90
     C           *IN90     IFEQ *OFF
     C           ADSKJY    ANDEQ*BLANK
     C                     MOVE *ON       *IN30
     C                     MOVE ER,11     MSG
     C                     END
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @WRT
     C**************************************************************************
     C           @WRT      BEGSR
     C*
     C                     CLEARAFDPP101
     C                     CLEARAFDPP301
      *
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    ADKODT
     C                     Z-ADDWSSTM6    ADKOTM
     C                     MOVE PUSR      ADKOME                  USER
     C                     MOVEL#PGM      ADKOPG                  PGM-ID
     C                     MOVE PWKCD     ADWORK                  WORKER CD
     C                     MOVE BCOCD     ADKANR           CONTROL CODE
     C                     MOVE BZETI     ADZETI           ABSOLUTE
     C                     MOVE WTEHI     ADTEHI           TEHAI #
     C                     MOVE BPAGE     ADPAGE           PAGE #
     C                     MOVE BNIJI     ADNIJI           2ND TREATMENT
     C                     MOVE BTICD     ADTAIS           TARGET TYPE
     C                     MOVE BYUKO     ADSYUK           SHIP EFECTIVE
     C                     MOVE BHASY     ADHKOS           CONTAINER TYPE
     C                     MOVE BCKDT     ADCHKD           CHECK DIGIT
     C                     MOVE A2BHB1    ADPAR1           INTERNAL PART
     C                     MOVE A2BHB2    ADPAR2
     C                     MOVE A2BHB3    ADPAR3
     C                     Z-ADD@@QTY     ADSYOS           QTY/CONT.
     C                     MOVE SUPLY     ADSUPP
     C                     MOVELBARC2     ADBINN
     C                     Z-ADDA2KASI    ADWGHT
      *
     C                     MOVELPID       ADFILR
      *
     C                     WRITEAFDPP101
     C                     WRITEAFDPP301
JW1   * CREATE AFDPP12
 |   C                     TIME           SDATE
 |   C                     Z-ADDTODAY     ADCRDT
 |   C                     Z-ADDNOW       ADCRTM
 |   C                     MOVEL#USER     ADCRME
 |   C                     MOVEL#WSID     ADCRWS
 |   C                     MOVEL#PGM      ADCRPG
 |   C                     MOVELBARC1     ADBAR
JW1  C                     WRITEAFDPP121
     C*
      * call pgm to update/remove from outsource bin file.
     C                     MOVEL#PGM      P#PGM  10 P
     C                     MOVELBARC1     PBARCD 20 P
      *
     C                     CALL 'AFDR9U'
     C                     PARM           PWKCD
     C                     PARM           P#PGM
     C                     PARM           PBARCD
      *
     C                     ENDSR
     C*
** ERROR MESSAGE
BARCODE BLANK                   01
CONTROL CODE                    02
ABSOLUTE NO.                    03
ALREADY SCANNED                 04
LOT NUMBER                      05
BIN# ERROR                      06
COMPLET. WEIGHT                 07
PARTS ERROR                     08
DUPLICATE ERROR                 09
NOT THIS SUPPLY                 10
ALREADY@SCANNED                 11
NOT IAF PRODUCT                 12
CONTACT T/L                     13
** TAB1 / TAB2
3111 ** TO SEKIDO **
3222 **  TO  SRA  **
4456 * TO MITSUCHI *
** KBN
INTRA KANBAN:
