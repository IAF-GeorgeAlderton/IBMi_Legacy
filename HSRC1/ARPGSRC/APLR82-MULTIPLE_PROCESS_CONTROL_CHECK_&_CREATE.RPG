     H            Y.
     F** APLR82 **************************************
     F* MULTIPLE PROCESS CONTROL  CHECK & CREATE     *
     F*       T.SAKAKI      2016.10.13               *
     F************************************************
     FAPLPP80 UF  E           K        DISK                      A
     FRGAPL11 IF  E           K        DISK
      *
     I            DS
     I                                        1   80A1SKHZ
     I                                        1   40A1SKYY
     I                                        5   60A1SKMM
     I                                        7   80A1SKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 @@USER
     I                                      264 269 W#JBNO
      *----------------------------------------------------*
      * PARAMETER                                        *
      *   IN                                               *
      *      PIPGMN : PROGRAM NAME                         *
      *      PIITM1 : SAVED ITEM 1                         *
      *   OUT                                              *
      *      POUSID : USER ID                              *
      *      POKONA : USER NAME                            *
      *      POSTTS : '1' OK                               *
      *               '2' NG = PROCESSING BY OTHER USER    *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           PIPGMN 10
     C                     PARM           PIITM1 10
     C                     PARM           POWSID 10
     C                     PARM           POUSID 10
     C                     PARM           POKONA 15
     C                     PARM           POSTTS  1
      *
     C                     TIME           WTIME
      *
     C                     MOVEL*BLANK    POWSID
     C                     MOVEL*BLANK    POUSID
     C                     MOVEL*BLANK    POKONA
     C                     MOVEL*BLANK    POSTTS
     C           PIPGMN    CHAINAPLPP801             21
     C           *IN21     IFEQ '0'
     C           A1SKJY    ANDEQ'D'
     C           A1SKHZ    ANDLEWTIHZ
     C                     SETON                     21
     C                     ENDIF
      *
     C           *IN21     IFEQ '0'
     C                     MOVELA1WSID    POWSID
     C                     MOVELA1USID    POUSID
     C                     MOVELA1KONA    POKONA
     C                     MOVEL'2'       POSTTS            NG
     C                     ELSE
     C                     MOVEL'1'       POSTTS            OK
     C                     EXSR #WRT
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *----------------------------------------------------*
      * CREATE RECORD                                      *
      *----------------------------------------------------*
     CSR         #WRT      BEGSR
      *
     C           PIPGMN    CHAINAPLPP801             21
     C                     CLEARAPLPP801
      *
     C                     MOVEL*BLANK    A1SKJY
     C                     Z-ADD0         A1SKYY
     C                     Z-ADD0         A1SKMM
     C                     Z-ADD0         A1SKDD
     C                     Z-ADDWTIYY     A1KOYY
     C                     Z-ADDWTIMM     A1KOMM
     C                     Z-ADDWTIDD     A1KODD
     C                     Z-ADDTIMHH     A1KOTH
     C                     Z-ADDTIMMM     A1KOTM
     C                     Z-ADDTIMSS     A1KOTS
      *
     C                     MOVELW#WSID    A1WSID
     C                     MOVEL@@USER    A1USID
     C           @@USER    CHAINRGAPL111             22
     C           *IN22     IFEQ '0'
     C                     MOVELJ8NAME    A1KONA
     C                     ENDIF
      *
     C                     MOVELPIPGMN    A1PGMN
      *
     C           PIITM1    IFNE *BLANK
     C                     MOVELPIITM1    A1USID
     C                     ENDIF
     C*
     C                     Z-ADDWTIYY     A1STYY
     C                     Z-ADDWTIMM     A1STMM
     C                     Z-ADDWTIDD     A1STDD
     C                     Z-ADDTIMHH     A1STTH
     C                     Z-ADDTIMMM     A1STTM
     C                     Z-ADDTIMSS     A1STTS
      *
     C           *IN21     IFEQ '0'
     C                     UPDATAPLPP801
     C                     ELSE
     C                     WRITEAPLPP801
     C                     ENDIF
      *
     CSR         EWRT      ENDSR
      *
