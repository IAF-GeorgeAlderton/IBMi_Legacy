     H            Y.                                    1
     H***ALDR90*****************************************************************
     H* 2 PONT SCAN                                                            *
     H*        07/30/01(TCH)
     H*
     H* TCH    9/26/01 ADD 'T' AS APICS KANBAN ID                              *
     H* TCH   11/13/01 ADD E-KANBAN                                            *
     H**************************************************************************
     H*
     H* *IN05 = 1(ALDPW011 CF05)
     H*
     H* *IN11 = 1(ALDPW012 CF02)
     H* *IN12 = 1(ALDPW012 CF05)
     H* *IN13 = 1(ALDPW012 CF07)
     H*
     H* *IN14 = 1(ALDPW013 CF02)
     H* *IN15 = 1(ALDPW013 CF05)
     H* *IN16 = 1(ALDPW013 CF07)
     H*
     H* *IN17 = 1(ALDPW014 CF02)
     H* *IN18 = 1(ALDPW014 CF05)
     H*
     H*
     H* *IN21 = 1(ALDPW016 CF03) SHIPPING MENU
     H* *IN22 = 1(ALDPW016 CF05) RETURN
     H* *IN23 = 1(ALDPW016 CF07) SWITCH ASJ
     H*
     H* *IN21 = 1(ALDPW020 CF03) SHIPPING MENU
     H* *IN22 = 1(ALDPW020 CF05) RETURN
     H* *IN24 = 1(ALDPW020 CF07) SWITCH APICS
     H*
     H* *IN25 = 1(ALDPW021 CF05) RETURN
     H* *IN26 = 1(CHK8 OK,TO THE NEXT)
     H*
     H* *IN30 = ERROR
     H* *IN31 = SHIPPING DATE ERROR
     H* *IN32 = BIN ERROR
     H* *IN33 = BACK KANBAN BARCODE (TOYOTA 1)ERROR
     H* *IN34 = BACK KANBAN BARCODE (TOYOTA CUSTOMER)ERROR
     H* *IN37 = BACK KANBAN BARCODE (OTHERS) ERROR
     H* *IN39 = IAF,KOTEI,APICS KANBAN BARCODE ERROR
     H*
     H* *IN40 = 0 DISPLAY BACK KANBAN TOYOTA
     H*         1                     OTHERS
     H* *IN41 = 1 DISPLAY TOTAL
     H* *IN42 = 1 LOKUP
     H* *IN43 = 1 LOKUP (KBN)
     H* *IN44 = 1 LOKUP (BARCODE DATA)
     H*
     H* *IN89 = 1 NOT READ PART MASTER
     H* *IN90 = 1 NOT READ PART MASTER
     H* *IN91 = 1 NOT READ TOPICS CUSTOMER MASTER
     H* *IN93 = 1 NOT READ FCEPL01(PART MASTER)
     H* *IN92 = 1 NOT READ GADPL15(OUTGOING MASTER)
     H*
     H**************************************************************************
     FALDPW90 CF  E                    WORKSTN
     FALAPL02 IF  E           K        DISK
     FFCETL11 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FGADPL15 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FALDWP90 O   E           K        DISK                      A
     FAB#PL71 IF  E           K        DISK
     F**************************************************************************
     E                    BCD         4  7               TOYOTA BCD DATA
     E                    KBN         4  1               TOYOTA BCD KBN
     E                    ERR     1   6 15
     E                    WUSR        4  7               BACK KANBAN W/F
     E                    QTY         4  1               QTY
     E                    HEX    16  16  1               HEX CODE
     E                    NUM    16  16  2 0             CHAR NUMERIC
     E                    HON        20  1               HONDA BARCODE
     E                    HNO        20  1               HONDA PART
     I**************************************************************************
     I* TOYOTA (BACK KANBAN 1,BLOCK NUMBER=0)
     I            DS
     I                                        1   7 BARCD1
     I                                        1   6 BARCC1
     I                                        1   1 BLKNO1
     I                                        2   6 CUST3
     I                                        2   2 CUST21
     I                                        3   3 CUST22
     I                                        4   4 CUST23
     I                                        5   5 CUST24
     I                                        7   7 CHKD1
     I* TOYOTA (BACK KANBAN 2,BLOCK NUMBER=1)
     I            DS
     I                                        1   7 BARCD2
     I                                        1   6 BARCC2
     I                                        1   1 BLKNO2
     I                                        2   2 CUST1
     I                                        7   7 CHKD2
     I* TOYOTA (BACK KANBAN 3 ,BLOCK NUMBER=3)
     I            DS
     I                                        1   7 BARCD3
     I                                        1   6 BARCC3
     I                                        1   1 BLKNO3
     I                                        2   5 BQTY
     I                                        7   7 CHKD3
     I* TOYOTA (BACK KANBAN 4 ,BLOCK NUMBER=+)
     I            DS
     I                                        1   7 BARCD4
     I                                        1   6 BARCC4
     I                                        1   1 BLKNO4
     I                                        2   5 IDPNO
     I                                        7   7 CHKD4
     I* BACK KANBAN(OTHERS)
     I            DS
     I                                        1  19 BAROTH
     I                                        1  18 BARCC5
     I                                        1   4 DELIVL
     I                                        1   40WELIVL
     I                                        5   5 FACTRY
     I                                        6   9 DOCK
     I                                       10  13 IDCD
     I                                       14  180HQTY
     I                                       19  19 CHKD5
     I* A-PICS,KOUTEI,IAF
     I            DS
   T3I                                        1  17 BARKAX
     I                                        1  15 BARKAN
     I                                        1  15 IIAF
     I                                        1  14 IAPICS
     I                                        1   1 BARKBN
     I                                        2   5 IDNO7
     I                                        6   8 LOT
     I                                        9  10 PAG
     I                                       15  15 CHKD8
     I                                       17  17 CHKD7
     I                                       16  17 NODGT
     I* SYSTEM DATE(8 DIGITS) FOR FIRST SCREEN
     I            DS
     I                                        1   80WSDATE
     I                                        1   4 WSYYYY
     I                                        5   6 WSMM
     I                                        7   8 WSDD
     I                                        1   8 WSDAT
     I* SHIPPING DATE(8 DIGITS)
     I            DS
     I                                        1   80W@YMD8
     I                                        1   40SYY
     I                                        5   60SMM
     I                                        7   80SDD
     I* ACCOMMODATED QTY. CHANGE DATE(8 DIGITS)
     I            DS
     I                                        1   80WQDATE
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
     I* LOCATION CHANGE DATE(8 DIGITS)
     I            DS
     I                                        1   80WLDATE
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
     I* SYSTEM TIME
     I            DS
     I                                        1  120WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        7   80WSSYYY
     I                                        9  100WSSMMM
     I                                       11  120WSSDDD
     I                                        1   4 WSTIME
     I* KANBAN TYPE,ABSOLUTE#,ORDER#,SEHIN KUBUN,LOT#
     I            DS
     I                                        1  15 WIAF
     I                                        1   1 A9KANS
     I                                        2   5 A9ZETI
     I                                        6  11 A9ORDR
     I                                       12  12 A9SEHI
     I***                                    13  16 A9LOTN
     I* OUT-GOING TRACK DATA FILE(A-PICS) ALDPP30
     I* ALDWP10
     I            DS
     I                                        1 100 DATA
     I                                        1  17 A0BAR1
     I                                       18  45 A0BAR2
     I                                       46  53 A0SDAT
     I                                       54  57 A0PTIM
     I                                       58  63 A0UID
     I* ALAPP01 (KEY)
     I            DS
     I                                        1   6 KEY3
     I                                        1   5 KEY31
     I                                        6   6 KEY32
     I* FCEPL01 (KEY)
     I            DS
     I                                        1  12 WKPNO
     I                                        1   5 K11
     I                                        6  10 K12
     I                                       11  12 K13
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     C**************************************************************************
     C*                    MAIN ROUTINE
     C**************************************************************************
     C                     EXSR @INT
     C                     EXSR @MAIN
     C                     EXSR @END
     C**************************************************************************
     C*                    @INT
     C**************************************************************************
     C           @INT      BEGSR
     C*
     C           *ENTRY    PLIST
     C                     PARM           WORKER  6
     C                     PARM           WUSRID 10
     C*
     C* BBHR50
     C           P1        PLIST
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           PMHIN  20
     C                     PARM           PSHIN  12
     C                     PARM           PFLG    1
     C** KLIST
     C* AGDPL12(CALENDER MASTER)
     C           K#AGD     KLIST
     C                     KFLD           #KYY    40
     C                     KFLD           #KMM    20
     C                     KFLD           #KDD    20
     C           KEY1      KLIST
     C                     KFLD           K11
     C                     KFLD           K12
     C                     KFLD           K13
     C*  WORK FIELD
     C                     MOVEL*ALL'0'   WCLR   10        WORK FLG CLR
     C                     MOVEL*ALL'0'   WBBK2  12        WORK FLG CLR
     C                     MOVEAWCLR      *IN,30
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*BLANK    WUSR
     C                     Z-ADD*ZERO     I       20       KBN INDEX
     C                     Z-ADD*ZERO     M       20       CUL
     C                     Z-ADD*ZERO     L       20       TBL INDEX
     C                     Z-ADD*ZERO     X       20       TBL INDEX
     C                     Z-ADD*ZERO     WQTY2   40       FPR HEX CAL WORK
     C                     Z-ADD*ZERO     WQTY3   40       FPR HEX CAL WORK
     C                     Z-ADD*ZERO     WSISU   40       SISUU
     C*
     C                     Z-ADD*DATE     WSDATE
     C                     Z-ADD*DATE     D@YMD
     C                     MOVE 'E'       @@E
     C*
     C                     ENDSR
     C*************************************************************************
     C*                    @MAIN
     C**************************************************************************
     C           @MAIN     BEGSR
      *
     C           *IN99     DOUEQ*ON
     C                     EXSR #FRST
     C  N12                EXSR @CTL
     C                     SETOF                     12
      *
     C                     ENDDO
      *
     C                     ENDSR
     C**************************************************************************
     C*    1ST SCREEN
     C**************************************************************************
     C           #FRST     BEGSR
     C*
B001 C           *IN12     DOWEQ'0'                        STILL PRESS F5
      *
   TTC                     EXFMTALDPW010
     C*
     C   12                SETON                     99
     C                     EXSR #CHK0
     C           *IN90     CABEQ*OFF      @FRST
      *
     C                     ENDDO
     C*
     C           @FRST     ENDSR
     C**************************************************************************
     C*    CHECK FOR 1ST SCREEN
     C**************************************************************************
     C           #CHK0     BEGSR
      *
     C                     Z-ADDD@YMD     W@YMD8
     C                     ADD  2000      SYY
     C                     Z-ADDSYY       #KYY
     C                     Z-ADDSMM       #KMM
     C                     Z-ADDSDD       #KDD
      *
     C           K#AGD     CHAINAGDPL121             90
      *
     C                     ENDSR
     C**************************************************************************
     C*                    @CTL
     C**************************************************************************
     C           @CTL      BEGSR
     C*
     C                     MOVEAWBBK2     *IN,11
     C                     SETON                     40
     C*
B001 C           *IN12     DOWEQ'0'                        STILL PRESS F5
     C           *IN15     ANDEQ'0'
     C           *IN18     ANDEQ'0'
   TTC           MSG       IFNE *BLANK
   TTC                     EXFMTALDPW998
   TTC                     ENDIF
     C*
     C           @@E       IFEQ 'E'
     C                     EXSR #EKAN
     C  N99                ITER
     C   99                GOTO #SKP
     C                     ENDIF
     C*
     C           *IN40     IFEQ '0'
     C           *IN41     ANDEQ'0'
     C           #DSP1     TAG
     C                     EXFMTALDPW012                   TOYOTA
      * EKANBAN
     C           *INKF     IFEQ *ON
     C                     EXSR #EKAN
     C  N99                ITER
     C   99                GOTO #SKP
     C                     ENDIF
     C* IF BAR-CODE IS DUPLICATED,OMIT THE BAR-CODE
     C*
     C           *IN11     IFEQ '1'
     C           *IN12     OREQ '1'
     C           *IN13     OREQ '1'
     C                     GOTO #DSP9
     C                     END
     C*
     C           BARCD1    IFEQ BARCD2
     C           BARCD1    OREQ BARCD3
     C           BARCD1    OREQ BARCD4
     C                     GOTO #DSP1
     C                     END
     C*
     C           #DSP2     TAG
     C                     WRITEALDPW999
     C                     WRITEALDPW012
     C                     EXFMTALDPW017                   TOYOTA
      * EKANBAN
     C           *INKF     IFEQ *ON
     C                     EXSR #EKAN
     C  N99                ITER
     C   99                GOTO #SKP
     C                     ENDIF
      *
     C           BARCD2    IFEQ BARCD1
     C           BARCD2    OREQ BARCD3
     C           BARCD2    OREQ BARCD4
     C                     GOTO #DSP2
     C                     END
     C*
     C           #DSP3     TAG
     C                     WRITEALDPW999
     C                     WRITEALDPW012
     C                     WRITEALDPW017
     C                     EXFMTALDPW018                   TOYOTA
     C           BARCD3    IFEQ BARCD1
     C           BARCD3    OREQ BARCD2
     C           BARCD3    OREQ BARCD4
     C                     GOTO #DSP3
     C                     END
     C*
     C           #DSP4     TAG
     C                     WRITEALDPW999
     C                     WRITEALDPW012
     C                     WRITEALDPW017
     C                     EXFMTALDPW019                   TOYOTA
     C           BARCD4    IFEQ BARCD1
     C           BARCD4    OREQ BARCD2
     C           BARCD4    OREQ BARCD3
     C                     GOTO #DSP4
     C                     END
     C                     END
     C*
     C           #DSP9     TAG
     C*
     C   40N41             EXFMTALDPW013                   OTHERS
     C   41                EXFMTALDPW014                   TOTAL
      * EKANBAN
     C           *INKF     IFEQ *ON
     C                     EXSR #EKAN
     C  N99                ITER
     C   99                GOTO #SKP
     C                     ENDIF
      *
     C                     CLEARMSG
     C                     SETOF                     30
     C                     MOVEA'0000'    *IN,33
     C*
B003 C           *IN12     IFEQ '1'                        F5
     C           *IN15     OREQ '1'
     C           *IN18     OREQ '1'
     C*
     C                     SETOF                     4041
     C                     CLEARALDPW011
     C                     CLEARALDPW012                   TOYOTA 1
     C                     CLEARALDPW013                   OTHERS
     C                     CLEARALDPW014                   TOTAL
     C                     CLEARALDPW016                   APICS
     C                     CLEARALDPW017                   TOYOTA 2
     C                     CLEARALDPW018                   TOYOTA 3
     C                     CLEARALDPW019                   TOYOTA 4
     C                     CLEARALDPW020                   ASJ
     C*
     C                     ELSE
     C*
B003 C           *IN11     IFEQ '1'                        DSP2 CF01
     C                     SETOF                     11
     C                     SETON                     41
     C                     EXSR @CTL4
     C*
     C                     ELSE
B004 C           *IN13     IFEQ '1'                        DSP2 CF07
     C                     SETOF                     13
     C                     SETON                     40
     C                     CLEARBARCD1
     C                     CLEARBARCD2
     C                     CLEARBARCD3
     C                     CLEARBARCD4
     C*
     C                     ELSE
B005 C           *IN14     IFEQ '1'                        DSP3 CF01
     C                     SETOF                     14
     C                     SETON                     41
     C                     EXSR @CTL4
     C*
     C                     ELSE
B006 C           *IN16     IFEQ '1'                        DSP3 CF07
     C                     SETOF                     1640
     C                     CLEARBAROTH
     C*
     C                     ELSE
B007 C           *IN17     IFEQ '1'
     C                     SETOF                     1741  DSP4 CF01
     C*
     C                     ELSE
     C*
     C  N40N41             EXSR @CHK2
     C   40N41             EXSR @CHK3
      *
     C           *IN30     IFEQ *ON
 TT  C                     EXFMTALDPW998
     C                     GOTO #DSP9
     C                     ELSE
     C           @@E       IFEQ 'E'
     C                     ITER
     C                     ENDIF
      *
 TTE1C                     ENDIF
     C*
     C           *IN22     DOUEQ'1'
     C           *IN21     OREQ '1'
  T3 C           @IAF      IFEQ 'Y'
  T3 C                     EXSR @CTL7
  T3 C                     ELSE
     C                     EXSR @CTL6
  T3 C                     ENDIF
     C*
     C                     END
     C                     SETOF                     2122
E007 C                     END
E006 C                     END
     C*
E005 C                     END
     C*
E004 C                     END
     C*
E003 C                     END
E002 C                     END
     C*
E001 C                     END
     C*
     C           #SKP      ENDSR
     C**************************************************************************
     C*        E-KANBAN
     C**************************************************************************
     C           #EKAN     BEGSR
      *
     C                     MOVE 'E'       @@E     1
     C                     MOVE *OFF      *IN99
     C           @@E       DOWEQ'E'
     C                     EXFMTALDPW011
     C*
     C                     SELEC
      * MAIN MENU
     C           *INKE     WHEQ *ON
     C                     MOVE *ON       *IN99
     C                     MOVE *BLANK    @@E     1
     C                     LEAVE
      * TMMK
     C           *INKF     WHEQ *ON
     C                     MOVEA'00'      *IN,40
     C                     LEAVE
      * OTHERS
     C           *INKG     WHEQ *ON
     C                     MOVEA'10'      *IN,40
     C                     MOVE *BLANK    @@E     1
     C                     LEAVE
     C                     OTHER
     C                     EXSR @CHK9
     C           *IN30     IFEQ *ON
     C                     EXFMTALDPW998
     C                     ELSE
     C                     EXSR @CTL6
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------
     C           @CHK9     BEGSR
      *----------------------------------------------
     C                     SETOF                     3033
     C                     SETOF                     2122
     C                     MOVE *BLANK    MSG
      *
     C           BARCD0    IFEQ *BLANK
     C                     SETON                     3033
     C                     MOVE ERR,6     MSG
     C                     ELSE
     C           BARCD0    CHAINAB#PL71              90
      *
     C           *IN90     IFEQ *ON
     C                     MOVE ERR,6     MSG
     C                     SETON                     3033
     C           @@E       IFEQ 'E'
     C                     MOVELBARCD0    BAROTH
     C                     MOVE *BLANK    MSG
     C                     SETOF                     30
     C                     EXSR @CHK3
     C           *IN30     IFEQ *ON
     C                     MOVE ERR,6     MSG
     C                     SETON                     3033
     C                     ELSE
     C                     MOVE *BLANK    @@E
     C                     MOVEA'10'      *IN,40
     C                     ENDIF
     C                     ENDIF
     C                     ELSE
     C                     MOVE EKSYOS    HQTY
     C                     MOVELEKODRN    @@ORDN 10
     C           EKZETI    CHAINFCETL11              90
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*                    @CTL6(KANBAN)  APICS
     C**************************************************************************
     C           @CTL6     BEGSR
     C*
 T3  C                     MOVE '0'       *IN23
 T3  C                     MOVE '0'       *IN24
   B0C           *IN21     DOWEQ'0'
     C           *IN22     ANDEQ'0'
 T3  C           *IN23     ANDEQ'0'
     C*
 TTB1C           MSG       IFNE *BLANK
 TT  C                     EXFMTALDPW998
 TTE1C                     ENDIF
     C*
     C                     SETOF                     3039
     C                     CLEARMSG
     C                     EXFMTALDPW016
     C*
   B1C           *IN22     IFEQ '1'                        DSP6 CF05
     C                     ELSE
     C* MAIN MENU
   B2C           *IN21     IFEQ '1'                        DSP6 CF03
     C                     SETON                     20
     C                     SETON                     99
     C                     SETON                     121518
     C                     CLEARALDPW011
     C                     CLEARALDPW012
     C                     CLEARALDPW013
     C                     CLEARALDPW014
     C                     CLEARALDPW016
     C                     CLEARALDPW017
     C                     CLEARALDPW018
     C                     CLEARALDPW019
     C*
     C                     ELSE
 T3B3C           *IN23     IFEQ '1'
 T3  C                     MOVE 'Y'       @IAF    1
 T3  C                     MOVE '0'       *IN24
 T3  C                     EXSR @CTL7
 T3  C                     ELSE
     C                     EXSR @CHK6
     C  N30                EXSR @CHK8
   B4C           *IN30     IFEQ '0'
     C           *IN26     ANDEQ'1'
     C                     EXSR @WRT1                      TOYOTA BACK
     C                     EXSR @WRT
     C                     SETON                     2022
   E4C                     END
     C*
 T3E3C                     END
   E2C                     END
   E1C                     END
   E0C                     END
     C*
     C                     ENDSR
 T3  C**************************************************************************
  |  C*                    @CTL7(KANBAN - IAF)
     C**************************************************************************
     C           @CTL7     BEGSR
     C*
   B0C           *IN21     DOWEQ'0'
     C           *IN22     ANDEQ'0'
     C           *IN24     ANDEQ'0'
     C*
   B1C           MSG       IFNE *BLANK
     C                     EXFMTALDPW998
   E1C                     ENDIF
     C*
     C                     SETOF                     3039
     C                     CLEARMSG
     C                     EXFMTALDPW020
     C*
   B1C           *IN22     IFEQ '1'                        DSP6 CF05
     C                     ELSE
     C*
   B2C           *IN21     IFEQ '1'                        DSP6 CF03
     C                     SETON                     2099
     C                     SETON                     121518
     C                     CLEARALDPW011
     C                     CLEARALDPW012
     C                     CLEARALDPW013
     C                     CLEARALDPW014
     C                     CLEARALDPW020
     C                     CLEARALDPW017
     C                     CLEARALDPW018
     C                     CLEARALDPW019
     C*
     C                     ELSE
   B3C           *IN24     IFEQ '1'
     C                     MOVE ' '       @IAF
     C                     MOVE '0'       *IN23
     C                     ELSE
     C                     EXSR @CHK7
     C  N30                EXSR @CHK8
   B4C           *IN30     IFEQ '0'
     C           *IN26     ANDEQ'1'
     C                     EXSR @WRT2                      TOYOTA BACK
     C                     EXSR @WRT
     C                     SETON                     2022
   E4C                     END
     C*
   E3C                     END
   E2C                     END
   E1C                     END
   E0C                     END
 |   C*
 T3  C                     ENDSR
     C**************************************************************************
     C*                    @CTL4(INQUIRY TOTAL)
     C**************************************************************************
     C           @CTL4     BEGSR
     C*
     C           120       SUB  TOTAL     EMPTY
     C                     Z-ADD120       GTOTL
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK2(ONE-WAY KANBAN TOYOTA)
     C**************************************************************************
     C           @CHK2     BEGSR
     C* FULL ENTRY?(TOYOTA)
     C                     MOVE BLKNO1    KBN,1
     C                     MOVE BLKNO2    KBN,2
     C                     MOVE BLKNO3    KBN,3
     C                     MOVE BLKNO4    KBN,4
     C*
     C                     MOVE BARCD1    BCD,1
     C                     MOVE BARCD2    BCD,2
     C                     MOVE BARCD3    BCD,3
     C                     MOVE BARCD4    BCD,4
     C*
     C                     CLEARWUSR
     C                     Z-ADD1         I
     C           '0'       LOKUPKBN,I                    43
     C           *IN43     IFEQ '1'
     C                     MOVE BCD,I     WUSR,1
     C                     ELSE
     C                     SETON                     3033
     C                     END
     C*
     C                     Z-ADD1         I
     C           '1'       LOKUPKBN,I                    43
     C           *IN43     IFEQ '1'
     C                     MOVE BCD,I     WUSR,2
     C                     ELSE
     C                     SETON                     3033
     C                     END
     C*
     C                     Z-ADD1         I
     C           '2'       LOKUPKBN,I                    43
     C           *IN43     IFEQ '1'
     C                     MOVE BCD,I     WUSR,3
     C                     ELSE
     C                     SETON                     3033
     C                     END
     C*
     C                     Z-ADD1         I
     C           '+'       LOKUPKBN,I                    43
     C           *IN43     IFEQ '1'
     C                     MOVE BCD,I     WUSR,4
     C*
     C                     ELSE
     C                     SETON                     3033
     C                     END
     C*
     C           *IN30     IFEQ '0'
     C                     MOVEAWUSR,1    BARCD1
     C                     MOVEAWUSR,2    BARCD2
     C                     MOVEAWUSR,3    BARCD3
     C                     MOVEAWUSR,4    BARCD4
     C*
     C                     ELSE
     C                     SETON                     30
     C                     MOVEA'1111'    *IN,33
     C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
     C                     END
     C                     END
     C*
     C                     MOVELCUST3     KEY31
     C                     MOVE CUST1     KEY32
     C           KEY3      CHAINALAPL02              91
     C           *IN91     IFEQ '1'
     C                     SETON                     3033
     C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
     C                     END
     C                     GOTO #CHK2
     C*
     C                     ELSE
     C                     END
     C* PART MASTER
     C           IDPNO     CHAINFCETL11              90
     C           *IN90     IFEQ '0'
     C** QTY CHECK START ****************************************
     C*
     C*  TRANSFER FROM HEX TO CHAR NUMERIC
     C                     Z-ADD*ZERO     WQTY2
     C                     Z-ADD*ZERO     WQTY3
     C                     Z-ADD1         WSISU
     C                     Z-ADD4         L
     C                     MOVEABQTY      QTY
     C*
     C                     DO   4
     C                     Z-ADD1         X
     C           QTY,L     LOKUPHEX,X                    42
     C*
     C           *IN42     IFNE '0'
     C           WSISU     MULT NUM,X     WQTY2
     C                     ADD  WQTY2     WQTY3
     C                     END
     C           16        MULT WSISU     WSISU
     C                     SUB  1         L
     C*
     C                     END
     C*
     C*  DEPENDS ON SYSTEM DATE, USE OLD/NEW QTY
     C           WSDATE    IFGE WQDATE
     C           WQTY3     IFEQ A2SSYS
     C                     ELSE
     C                     SETON                     3033
     C           MSG       IFEQ *BLANK
     C                     MOVE ERR,3     MSG
     C                     END
     C                     END
     C*
     C                     ELSE
     C           WQTY3     IFEQ A2KSYS
     C                     ELSE
     C                     SETON                     3033
     C           MSG       IFEQ *BLANK
     C                     MOVE ERR,3     MSG
     C                     END
     C                     END
     C                     END
     C* NOT FILE READ
     C                     ELSE
     C                     SETON                     3033
     C           MSG       IFEQ *BLANK
     C                     MOVE ERR,3     MSG
     C                     END
     C                     END
     C*
     C           #CHK2     TAG
     C           *IN30     IFEQ '1'
     C                     MOVE *BLANK    BARCD1
     C                     MOVE *BLANK    BARCD2
     C                     MOVE *BLANK    BARCD3
     C                     MOVE *BLANK    BARCD4
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK3(ONE-WAY KANBAN OTHERS)
     C**************************************************************************
     C           @CHK3     BEGSR
     C*
     C                     SETOF                     2122
     C* PART MASTER
     C           IDCD      CHAINFCETL11              90
B01  C           *IN90     IFEQ '0'
     C** QTY CHECK
     C*  DEPENDS ON SYSTEM DATE, USE OLD/NEW QTY
B02  C           WSDATE    IFGE WQDATE
B03  C           HQTY      IFEQ A2SSYS
     C                     ELSE
     C                     SETON                     3037
B04  C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
E04  C                     END
E03  C                     END
     C*
     C                     ELSE
B03  C           HQTY      IFEQ A2KSYS
     C                     ELSE
     C                     SETON                     3037
B04  C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
E04  C                     END
E03  C                     END
E02  C                     END
     C*
     C                     ELSE
     C* NOT FILE READ
     C                     SETON                     3037
B02  C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
E02  C                     END
     C*****                END
     C*****                ELSE
     C* ERROR
     C                     SETON                     3037
B02  C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
E02  C                     END
     C                     END
     C*
     C           *IN30     IFEQ '0'
     C                     MOVE *BLANK    WUSR
     C                     MOVEABAROTH    WUSR
     C                     ELSE
     C           @@E       IFEQ ' '
     C                     MOVELBAROTH    BARCD0
     C                     EXSR @CHK9
     C           *IN30     IFEQ *OFF
     C                     MOVE 'E'       @@E
     C                     EXSR @CTL6
     C                     ENDIF
     C                     ENDIF
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK7(ASJ KANBAN)
     C**************************************************************************
     C           @CHK7     BEGSR
     C*
     C* APICS,KOTEI KANBAN(15 DIGITS) ERROR
     C           NODGT     IFEQ *BLANK                     APICS,KOTEI
     C                     SETON                     3039
     C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
     C                     END
     C                     END
     C* KANBAN KUBUN OK?
   B1C           *IN30     IFEQ '0'
   B2C           BARKBN    IFEQ 'I'
     C* ERROR
     C                     ELSE
     C                     SETON                     3039
   B3C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
   E3C                     END
   E2C                     END
   E1C                     END
     C* ZETAI NO CHECK
   B1C           *IN30     IFEQ '0'
   B2C           A2ZETI    IFEQ IDNO7
     C*
     C                     ELSE
     C                     SETON                     3039
   B3C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
   E3C                     END
   E2C                     END
   E1C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK6(APICS KANBAN)
     C**************************************************************************
     C           @CHK6     BEGSR
     C* KANBAN KUBUN OK?
     C           BARKBN    IFEQ 'A'
     C           BARKBN    OREQ 'R'
     C           BARKBN    OREQ 'T'
     C* ERROR
     C                     ELSE
     C                     SETON                     3039
     C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
   E2C                     END
   E1C                     END
     C* ZETAI NO CHECK
   B1C           *IN30     IFEQ '0'
   B2C           A2ZETI    IFEQ IDNO7
     C*
     C                     ELSE
     C                     SETON                     3039
   B3C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
   E3C                     END
   E2C                     END
   E1C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @WRT
     C**************************************************************************
     C           @WRT      BEGSR
     C*
     C*
     C                     ADD  1         TOTAL
     C*
     C                     CLEARALDPW011
     C                     CLEARALDPW012
     C                     CLEARALDPW017
     C                     CLEARALDPW018
     C                     CLEARALDPW019
     C                     CLEARALDPW013
     C                     CLEARALDPW016
     C                     CLEARALDPW020
     C                     CLEARALDPW021
     C*
     C                     EXFMTALDPW997
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @WRT
     C**************************************************************************
     C           @WRT2     BEGSR
     C*
     C                     CLEARALDPP901
     C                     TIME           A9UPTM
     C                     Z-ADD*DATE     A9UPDT
     C                     MOVEL#USER     A9USER
     C                     MOVEL#WSID     A9WSID
     C                     MOVE A2BHB1    A9SHN1           INTERNAL PART
     C                     MOVE A2BHB2    A9SHN2           INTERNAL PART
     C                     MOVE A2BHB3    A9SHN3           INTERNAL PART
     C                     ADD  SYY       A9INYY
     C                     Z-ADDSMM       A9INMM
     C                     Z-ADDSDD       A9INDD
     C                     MOVE IIAF      WIAF             IAF KANBAN
     C*
     C                     MOVE WORKER    A9OPER           WORKER
     C                     MOVE *BLANK    A9MHN1           USER PART
     C                     MOVE *BLANK    A9MHN2
     C                     MOVE *BLANK    A9MHN3
     C                     MOVE *BLANK    A9MHN4
     C                     Z-ADDHQTY      A9SSYS           UNIT QTY
     C                     Z-ADDHQTY      A9USYS           USER UNIT QTY
     C                     MOVE DELIVL    A9NONY           DELIVERY POINY
     C                     MOVE FACTRY    A9NKOJ                    FACTORY
     C                     MOVE DOCK      A9NUKE                    RECV
     C                     MOVE *BLANK    A9TOPX           TOPIX CODE
     C                     MOVE *BLANK    A9SALE           EFU/KANBAN
     C                     MOVE *BLANK    A9UPAG           BOTTOM KANBAN ISSU#
     C                     WRITEALDPP901
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @WRT
     C**************************************************************************
     C           @WRT1     BEGSR
     C*
     C                     CLEARALDPP901
     C                     TIME           A9UPTM
     C                     Z-ADD*DATE     A9UPDT
     C                     MOVEL#USER     A9USER
     C                     MOVEL#WSID     A9WSID
     C                     MOVE A2BHB1    A9SHN1           INTERNAL PART
     C                     MOVE A2BHB2    A9SHN2           INTERNAL PART
     C                     MOVE A2BHB3    A9SHN3           INTERNAL PART
     C                     ADD  SYY       A9INYY
     C                     Z-ADDSMM       A9INMM
     C                     Z-ADDSDD       A9INDD
     C****                 MOVE IIAF      WIAF             IAF KANBAN
     C*
     C                     MOVELBARKBN    A9KANS
     C                     MOVE WORKER    A9OPER           WORKER
     C                     MOVE *BLANK    A9MHN1           USER PART
     C                     MOVE *BLANK    A9MHN2
     C                     MOVE *BLANK    A9MHN3
     C                     MOVE *BLANK    A9MHN4
     C                     Z-ADDHQTY      A9SSYS           UNIT QTY
     C                     Z-ADDHQTY      A9USYS           USER UNIT QTY
     C                     MOVE DELIVL    A9NONY           DELIVERY POINY
     C                     MOVE FACTRY    A9NKOJ                    FACTORY
     C                     MOVE DOCK      A9NUKE                    RECV
     C                     MOVE *BLANK    A9TOPX           TOPIX CODE
     C                     MOVE *BLANK    A9SALE           EFU/KANBAN
     C                     MOVE PAG       A9PAG            BOTTOM KANBAN ISSU#
     C                     MOVE LOT       A9LOT            BOTTOM KANBAN ISSU#
     C                     MOVE IDNO7     A9ZETI
     C                     MOVEL@@ORDN    A9ORDR
     C                     WRITEALDPP901
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK8(HONDA)
     C**************************************************************************
     C           @CHK8     BEGSR
     C* HCM,ELP,MAP,HDM,SHOWA CANADA
     C           DELIVL    IFNE '0295'
     C           DELIVL    ANDNE'0296'
     C           DELIVL    ANDNE'3128'
     C           DELIVL    ANDNE'4126'
     C           DELIVL    ANDNE'0402'
     C           DELIVL    ANDNE'2020'
     C                     SETON                     26
     C                     GOTO #CHK8
     C                     END
     C*
     C                     SETOF                     26
     C*
B01  C           *IN25     DOWEQ'0'
     C           *IN26     ANDEQ'0'
     C   30                EXFMTALDPW998
     C                     SETOF                     30
     C                     MOVE *BLANK    MSG
     C  N30                EXFMTALDPW021
     C*
B02  C           *IN25     IFEQ '0'
     C*
     C* EDIT PART NUMBER
     C                     Z-ADD2         K       20
     C                     Z-ADD0         L       20
     C                     MOVEABARHON    HON
     C                     MOVEA*BLANK    HNO
B03  C           2         DO   19        K
B04  C           HON,K     IFNE ' '
     C           HON,K     ANDNE'-'
     C                     ADD  1         L
     C                     MOVE HON,K     HNO,L
E04  C                     END
E03  C                     END
     C*
     C* GET CUTOMER CODE FROM DELIVERY CODE
     C*
     C                     MOVE *BLANK    PTOKU
     C                     MOVE *BLANK    PNONY
     C                     MOVE *BLANK    PNKOJ
     C                     MOVE *BLANK    PMHIN
     C                     MOVE *BLANK    PSHIN
     C                     MOVE *BLANK    PFLG
     C*
     C           WELIVL    SETLLGADPP111
     C           #READ1    TAG
     C           WELIVL    READEGADPP111                 92
B03  C           *IN92     IFEQ '0'
B04  C           B5SKJY    IFEQ 'D'
     C                     GOTO #READ1
E04  C                     END
     C*
     C                     MOVE B5TOKU    PTOKU
     C                     MOVE B5NONY    PNONY
     C                     MOVE B5NKOJ    PNKOJ
     C                     MOVE DOCK      PNUKE
     C                     MOVEAHNO       PMHIN
E03  C                     END
     C*
     C* EXCHANGE USER PART # TO IAF PART
     C                     CALL 'BBHR50'  P1
     C                     MOVE PSHIN     WKPNO
     C*
     C* GET ABSOLUTE NUMBER
     C                     SETOF                     89
     C           KEY1      SETLLFCEPL011
     C           #READ2    TAG
     C           KEY1      READEFCEPL011                 93
B03  C           *IN93     IFEQ '0'
B04  C           A2GSKD    IFNE 'D'
     C*
     C* CHECK ABSOLUTE #(HONDA LABEL & AIAG)
     C                     SETON                     89
B05  C           A2ZETI    IFEQ IDCD
     C                     SETON                     26
     C*
     C                     ELSE
     C                     SETON                     30
B06  C           MSG       IFEQ *BLANK
     C                     MOVE ERR,4     MSG
     C                     END
     C                     END
     C*
     C                     ELSE
     C                     GOTO #READ2
     C                     END
E03  C                     END
     C*
     C           *IN89     IFEQ '0'
     C                     SETON                     30
     C           MSG       IFEQ *BLANK
     C                     MOVE ERR,4     MSG
     C                     END
     C                     END
     C*
     C                     END
     C                     END
     C*
     C           #CHK8     ENDSR
     C**************************************************************************
     C*                    @END
