     H            Y.
     F*** FCER60 *****************************
     F* SERVICE PARTS M/F MAINTENANCE      *
     F*                                      *
     F***************************** FCER60 ***
     FFCEPP30 UP  E                    DISK
     FFCEPL01 IF  E           K        DISK
     I            DS
     I                                        1   80A2SYMD
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
     I            DS
     I                                        1   80A2TYMD
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *****************************************************
      *  MAIN ROUTINE
      *****************************************************
     C           K#KEY     KLIST
     C                     KFLD           F3BHB1
     C                     KFLD           F3BHB2
     C                     KFLD           F3BHB3
      *
     C***        F3PTRT    IFEQ *BLANK
     C           K#KEY     CHAINFCEPL01              90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDA2TYMD    F3TYMD
     C                     Z-ADDA2KASI    F3KASI
     C                     MOVELA2DMEI    F3DMEI
     C                     MOVELA2SMEI    F3SMEI
     C                     MOVELA2ZETI    F3ZETI
     C                     Z-ADDA2SSYS    F3SSYS
     C                     MOVELA2STRK    F3PTRK
     C                     MOVELA2STRT    F3PTRT
     C                     MOVELA2STRR    F3PTRR
     C                     MOVELA2STRD    F3PTRD
     C                     Z-ADDA2SYMD    F3SYMD
      *
     C                     UPDATFCEPP301
     C                     ENDIF
     C***                  ENDIF
