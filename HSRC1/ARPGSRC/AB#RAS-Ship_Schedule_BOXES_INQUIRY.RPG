     C                     Z-ADD@DT,Z     W#DATE
     C                     MOVELW@SIZE    W#SIZE
 A   C                     Z-ADDW@QTY     W#QTY
 |   C                     Z-ADDW@BOX     W#BOX
 |   C                     WRITEAB#WPAQ1
JW4  C                     ENDIF
      * AB#WPAO
     C                     Z-ADD@DT,Z     W@DT
     C           KEYW#3    CHAINAB#WPAO1             94
     C           *IN94     IFEQ '0'
     C                     ADD  W@QTY     W#QTY
     C                     ADD  W@BOX     W#BOX
