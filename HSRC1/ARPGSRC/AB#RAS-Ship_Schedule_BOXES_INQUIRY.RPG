     C           M6AKT1    OREQ 'PRS'
     C                     MOVELM6AKT1    $PRC
     C                     LEAVE
     C                     ENDIF
      *
     C           M6AKT2    IFEQ 'INJ'
     C           M6AKT2    OREQ 'AK '
     C           M6AKT2    OREQ 'PRS'
     C                     MOVELM6AKT2    $PRC
     C                     LEAVE
     C                     ENDIF
      *
     C           M6AKT3    IFEQ 'INJ'
     C           M6AKT3    OREQ 'AK '
     C           M6AKT3    OREQ 'PRS'
     C                     MOVELM6AKT3    $PRC
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
