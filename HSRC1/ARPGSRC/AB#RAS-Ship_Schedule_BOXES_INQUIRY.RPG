TCHK1C                     ADD  W@QTY     @CQ,Z
TCHK1C                     ADD  W@BOX     @CB,Z
     C                     MOVE 'IAF'     W@OTYP
TCHK1C                     Z-ADD@CB,Z     X@BOX   81
     C                     EXSR #WPAS
JW3  C                     EXSR #WPAP
JW1  C**TEMP               EXSR #SB800
TCHK1C                     END
TCHK1C*
TCHK1C                     ENDDO
TCHK1C*
TCHK1C                     ENDSR
TCHK1 *-----------------------------------------------------
TCHK1C           #DSP03    BEGSR
TCHK1 *-----------------------------------------------------
TCHK1C                     MOVE CMD,4     D@CMD
TCHK1 *
TCHK1C                     MOVE *ON       *IN56
TCHK1C                     WRITEDSP99
TCHK1C                     EXFMTCTL02
TCHK1C                     MOVE *OFF      *IN56                       C
TCHK1 *
TCHK1C           @@REC     IFNE *ZERO
TCHK1C                     Z-ADD@@REC     #RCNO2
TCHK1C                     END
      *
TCHK1C                     SELEC
      * F3: END
TCHK1C           *INKA     WHEQ *ON
TCHK1C                     MOVE '99'      @@ID
      * F12: GO BACK
TCHK1C           *INKL     WHEQ *ON
TCHK1C                     MOVE '01'      @@ID
      * F5: HD DETAIL
TCHK1C           *INKE     WHEQ *ON
JW1  C                     MOVE '5'       @PF     1
     C**                   CALL 'AB#RAT'
JW4  C                     CALL 'AB#CBT'
     C                     PARM           @PF
     C                     MOVE *BLANK    D@MSG
JW5   * F6: RL DETAIL
 .   C           *INKF     WHEQ *ON
JW5  C                     MOVE MSG,6     D@MSG
JW1   * F7: HT DETAIL
 |   C           *INKG     WHEQ *ON
 |   C                     MOVE MSG,6     D@MSG
 |   C**                   MOVE '6'       @PF     1
 |   C**                   CALL 'AB#RAT'
 |   C**                   PARM           @PF
 |    * F8: ST DETAIL
 |   C           *INKH     WHEQ *ON
 |   C                     MOVE MSG,6     D@MSG
 |   C**                   MOVE '7'       @PF     1
 |   C**                   CALL 'AB#RAT'
 |   C**                   PARM           @PF
 |    * F9: JC DETAIL
 |   C           *INKI     WHEQ *ON
 |   C                     MOVE MSG,6     D@MSG
 |   C**                   MOVE '8'       @PF     1
 |   C**                   CALL 'AB#RAT'
JW1  C**                   PARM           @PF
TCHK1C                     ENDSL
TCHK1 *
TCHK1C                     ENDSR
      *-----------------------------------------------------
      * AB#WPAS DELETE
      *-----------------------------------------------------
     C           #WPCLR    BEGSR
JW1   * CLEAR AB#WPAR
 |   C           #WSID     SETLLAB#WPAR1
 |   C           #WSID     READEAB#WPAR1                 94
 |   C           *IN94     DOWEQ'0'
 |   C                     DELETAB#WPAR1
 |   C           #WSID     READEAB#WPAR1                 94
JW1  C                     ENDDO
      * CLEAR AB#WPAS
     C           #WSID     SETLLAB#WPAS1
     C           #WSID     READEAB#WPAS1                 94
     C           *IN94     DOWEQ'0'
     C                     DELETAB#WPAS1
     C           #WSID     READEAB#WPAS1                 94
     C                     ENDDO
 JW4  * CLEAR AB#WPAQ
  .  C           *LOVAL    SETLLAB#WPAQ1
  .  C                     READ AB#WPAQ1                 94
  .  C           *IN94     DOWEQ'0'
  .  C                     DELETAB#WPAQ1
  .  C                     READ AB#WPAQ1                 94
 JW4 C                     ENDDO
      * CLEAR AB#WPAT
     C           #WSID     SETLLAB#WPAT1
     C           #WSID     READEAB#WPAT1                 94
     C           *IN94     DOWEQ'0'
     C                     DELETAB#WPAT1
     C           #WSID     READEAB#WPAT1                 94
     C                     ENDDO
JW2   * CLEAR AB#WPAO
 .   C           #WSID     SETLLAB#WPAO1
 .   C           #WSID     READEAB#WPAO1                 94
 .   C           *IN94     DOWEQ'0'
 .   C                     DELETAB#WPAO1
 .   C           #WSID     READEAB#WPAO1                 94
JW2  C                     ENDDO
JW3   * CLEAR AB#WPAP
 .   C           *LOVAL    SETLLAB#WPAP1
 .   C                     READ AB#WPAP1                 94
 .   C           *IN94     DOWEQ'0'
 .   C                     DELETAB#WPAP1
 .   C                     READ AB#WPAP1                 94
 .   C                     ENDDO
 .    *
JW3  C                     ENDSR
      *-----------------------------------------------------
      * CREATE AB#WPAS 2
      *-----------------------------------------------------
     C           #WPAO     BEGSR
      * SET AB#WPAS
     C                     Z-ADD@DT,Z     W@DT
     C           *LOVAL    SETLLABBPP7G
     C                     READ ABBPP7G                  94
     C           *IN94     DOWEQ'0'
     C           A#SKJY    IFEQ *BLANK
JW3  C           A#MANO    ANDNE*BLANK
     C                     MOVELA#SIZE    W@SIZE
     C           KEYW#     CHAINAB#WPAS1             96
     C           *IN96     IFEQ '1'
     C                     CLEARAB#WPAS1
     C                     MOVEL#WSID     W#WSID
     C                     Z-ADD@DT,Z     W#DATE
     C                     MOVELW@SIZE    W#SIZE
     C                     Z-ADD0         W#QTY
     C                     Z-ADD0         W#BOX
     C                     WRITEAB#WPAS1
     C                     WRITEAB#WPAQ1
     C                     ENDIF
     C                     ENDIF
     C                     READ ABBPP7G                  94
     C                     ENDDO
      * OTHER
     C                     CLEARAB#WPAS1
     C                     MOVEL#WSID     W#WSID
     C                     Z-ADD@DT,Z     W#DATE
     C                     MOVELX'FFFFFF' W#SIZE
     C                     Z-ADD0         W#QTY
     C                     Z-ADD0         W#BOX
     C                     WRITEAB#WPAS1
      * ADD WPAQ
     C                     MOVELX'FFFFFF' W#SIZE
     C                     WRITEAB#WPAQ1
JW4   * ADD INJ
 .   C                     MOVEL'INJ'     W#SIZE
 .   C                     WRITEAB#WPAQ1
 .    * ADD AK
 .   C                     MOVEL'AK '     W#SIZE
 .   C                     WRITEAB#WPAQ1
 .    * ADD PRS
 .   C                     MOVEL'PRS'     W#SIZE
JW4  C                     WRITEAB#WPAQ1
JW1   * SET AB#WPAO
 .   C                     Z-ADD@DT,Z     W@DT
 .   C           *LOVAL    SETLLABBPP7G
 .   C                     READ ABBPP7G                  94
 .   C           *IN94     DOWEQ'0'
     C           A#SKJY    IFEQ *BLANK
JW3  C           A#MANO    ANDNE*BLANK
     C                     MOVELA#SIZE    W@SIZE
     C                     MOVELA#MANO    W@MCN
     C           KEYW#3    CHAINAB#WPAO1             96
     C           *IN96     IFEQ *ON
     C                     CLEARAB#WPAO1
     C                     MOVEL#WSID     W#WSID
     C                     Z-ADD@DT,Z     W#DATE
     C                     MOVELW@SIZE    W#SIZE
     C                     EXSR #SEQ
     C                     Z-ADD@SEQ      W#SEQ
     C                     MOVELW@MCN     W#MCN
     C                     Z-ADD0         W#QTY
     C                     Z-ADD0         W#BOX
     C                     WRITEAB#WPAO1
 .   C                     ENDIF
 .   C                     ENDIF
 .   C                     READ ABBPP7G                  94
JW1  C                     ENDDO
JW1   * OTHER
 .   C                     CLEARAB#WPAO1
 .   C                     MOVEL#WSID     W#WSID
 .   C                     Z-ADD@DT,Z     W#DATE
 .   C                     MOVELX'FFFFFF' W#SIZE
 .   C                     MOVE *BLANK    W#MCN
 .   C                     Z-ADD0         W#QTY
 .   C                     Z-ADD0         W#BOX
JW1  C                     WRITEAB#WPAO1
      * SHIP DATE
     C                     CLEARAB#WPAT1
     C                     MOVEL#WSID     W#WSID
     C                     Z-ADD@DT,Z     W#DATE
     C                     WRITEAB#WPAT1
