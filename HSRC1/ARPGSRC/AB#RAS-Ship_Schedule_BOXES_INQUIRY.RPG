      * GET SEQ#
      *-----------------------------------------------------
     C           #SEQ      BEGSR
      *
     C                     Z-ADD0         @SEQ    20
     C                     SELEC
     C           W#SIZE    WHEQ 'NUT'
     C                     Z-ADD01        @SEQ
     C           W#SIZE    WHEQ 'M8 '
     C                     Z-ADD02        @SEQ
     C           W#SIZE    WHEQ 'H/V'
     C                     Z-ADD05        @SEQ
     C           W#SIZE    WHEQ 'M6 '
     C                     Z-ADD04        @SEQ
     C           W#SIZE    WHEQ 'M10'
     C                     Z-ADD03        @SEQ
     C           W#SIZE    WHEQ 'TS '
     C                     Z-ADD06        @SEQ
     C           W#SIZE    WHEQ 'E/G'
     C                     Z-ADD07        @SEQ
     C           W#SIZE    WHEQ 'INJ'
     C                     Z-ADD08        @SEQ
     C           W#SIZE    WHEQ 'PRS'
     C                     Z-ADD09        @SEQ
     C           W#SIZE    WHEQ 'AK '
     C                     Z-ADD010       @SEQ
     C                     OTHER
     C                     Z-ADD99        @SEQ
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------
      * CREATE AB#WPAS
      *-----------------------------------------------------
     C           #WPAS     BEGSR
      *
     C                     MOVEL*BLANK    W@KB    3
     C           K#FCEA    CHAINAAMPL11              94
     C           *IN94     IFEQ '0'
     C           CKKO01    IFEQ 'HD '
     C           CKKO01    OREQ 'BM '
     C           CKKO01    OREQ 'NF '
     C                     MOVELCKKB01    W@KB
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVELX'FFFFFF' W@SIZE  3
JW3  C           W@KB      IFNE *BLANK
     C           W@KB      CHAINABBPP7G              94
     C           *IN94     IFEQ '0'
     C           A#SKJY    IFEQ *BLANK
     C                     MOVELA#SIZE    W@SIZE
JW2  C                     MOVELA#MANO    W@MCN
     C                     ENDIF
     C                     ENDIF
JW3  C                     ENDIF
      * AB#WPAS
     C           KEYW#     KLIST
     C                     KFLD           #WSID
     C                     KFLD           W@DT    80
     C                     KFLD           W@SIZE
     C                     Z-ADD@DT,Z     W@DT
     C           KEYW#     CHAINAB#WPAS1             94
     C           *IN94     IFEQ '0'
     C                     ADD  W@QTY     W#QTY
     C                     ADD  W@BOX     W#BOX
     C                     UPDATAB#WPAS1
     C                     ELSE
     C                     CLEARAB#WPAS1
     C                     MOVEL#WSID     W#WSID
     C                     Z-ADD@DT,Z     W#DATE
     C                     MOVELW@SIZE    W#SIZE
     C                     Z-ADDW@QTY     W#QTY
     C                     Z-ADDW@BOX     W#BOX
     C                     WRITEAB#WPAS1
     C                     ENDIF
      * AB#WPAQ
JW4   * ADJUST SIZE
     C                     MOVELW@SIZE    S@SIZE  3
 |   C           W@SIZE    IFEQ 'NUT'
 V   C                     EXSR #ADJ
     C           $PRC      IFNE *BLANK
     C                     MOVEL$PRC      W@SIZE
     C                     ENDIF
     C                     ENDIF
      *
     C           KEYQ#     KLIST
     C                     KFLD           W@DT    80
     C                     KFLD           W@SIZE
     C                     Z-ADD@DT,Z     W@DT
     C           KEYQ#     CHAINAB#WPAQ1             94
     C           *IN94     IFEQ '0'
     C                     ADD  W@QTY     W#QTY
     C                     ADD  W@BOX     W#BOX
     C                     UPDATAB#WPAQ1
     C                     ELSE
