      * AB#WPAR CREATE
      *-----------------------------------------------------
     C           #SB890    BEGSR
      * TEMP
     C                     GOTO XSB890
      *
     C                     Z-ADD@DT,Z     W@DT
     C           *LOVAL    SETLLABBPP7G
     C                     READ ABBPP7G                  94
     C           *IN94     DOWEQ'0'
     C           A#SKJY    IFEQ *BLANK
JW3  C           A#MANO    ANDNE*BLANK
     C                     MOVELA#SIZE    W@SIZE
     C                     MOVELA#MANO    W@MCN
