JW1   * AB#WPAR CREATE
 |    *-----------------------------------------------------
 |   C           #SB800    BEGSR
 V    * TEMP
 .   C                     GOTO XSB800
 .    *
 .   C                     MOVEL*BLANK    W@KB    3
 .   C           K#FCEA    CHAINAAMPL11              94
     C           *IN94     IFEQ '0'
     C           CKKO01    IFEQ 'HD '
     C           CKKO01    OREQ 'BM '
     C           CKKO01    OREQ 'NF '
     C                     MOVELCKKB01    W@KB
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVELX'FFFFFF' W@SIZE  3
     C           W@KB      CHAINABBPP7G              94
     C           *IN94     IFEQ '0'
     C           A#SKJY    IFEQ *BLANK
JW3  C           A#MANO    ANDNE*BLANK
     C                     MOVELA#SIZE    W@SIZE
     C                     ENDIF
     C                     ENDIF
      *
     C           KEYW#2    KLIST
     C                     KFLD           #WSID
     C                     KFLD           W@DT    80
     C                     KFLD           W@SIZE
     C                     KFLD           W@MCN   3
      *
     C           KEYW#3    KLIST
     C                     KFLD           #WSID
     C                     KFLD           W@DT    80
     C                     KFLD           W@SEQ   20
     C                     KFLD           W@SIZE
     C                     KFLD           W@MCN   3
      *
     C                     Z-ADD@DT,Z     W@DT
     C**TEMP               MOVELX         W@MCN
     C           KEYW#2    CHAINAB#WPAR1             94
     C           *IN94     IFEQ '0'
     C                     ADD  W@QTY     W#QTY
     C                     ADD  W@BOX     W#BOX
     C                     UPDATAB#WPAR1
     C                     ELSE
     C                     CLEARAB#WPAR1
     C                     MOVEL#WSID     W#WSID
     C                     Z-ADD@DT,Z     W#DATE
 .   C                     MOVELW@SIZE    W#SIZE
 .   C                     MOVELW@KB      W#PRC1
 .   C                     MOVELW@KB      W#PRCT
 .   C                     MOVELW@MCN     W#MCNT
 .   C                     Z-ADDW@QTY     W#QTY
 |   C                     Z-ADDW@BOX     W#BOX
 |   C                     WRITEAB#WPAR1
 V   C                     ENDIF
 .    *
JW1  C           XSB800    ENDSR
