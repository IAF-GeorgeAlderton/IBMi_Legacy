 .    *
 .   C                     CLEARAB#WPAP1
 .   C**                   MOVELW#WSID    WPWSID
 .   C                     MOVELW#SEQ     WPSEQ
 .   C                     MOVELW#SIZE    WPSIZE
 .   C                     MOVELW#MCN     WPMCN
 .   C                     MOVELW#DATE    WPDATE
 .   C                     Z-ADDW@QTY     WPQTY
 .   C                     Z-ADDW@BOX     WPBOX
 .   C                     MOVELW@SHIN    WPSHIN
 .   C                     MOVELCKKO01    WPFPRC
 .   C                     MOVELS@SIZE    WPOSIZ
 .   C                     MOVEL'AB#PP10' WPSRCF
 .   C                     MOVELW@OTYP    WPOTYP
      * GET PART INFORMATION
     C                     MOVELW@SHIN    PSHIN
     C                     CALL 'UTLR78E'
     C                     PARM           PSHIN  12
     C                     PARM           PZETI   4
     C                     PARM           PFPRC   3
     C                     PARM           PFDPT   40
     C                     PARM           PFMCN   3
