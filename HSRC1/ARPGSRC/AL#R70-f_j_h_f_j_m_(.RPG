     C                     ELSE
     C                     MOVE '1'       BAEXT
     C                     ENDIF
     C                     MOVE WKEXTR    BAPP
     C                     MOVEL*BLANK    WKCD
     C                     MOVELWKCONT    PMAREA
     C                     MOVEL'016'     PMBYTE
     C                     MOVEL*BLANK    PMCHK
     C                     MOVEL*BLANK    PMRTCD
     C                     CALL 'ALBRCC'
     C                     PARM           PMAREA100        *フィールド
     C                     PARM           PMBYTE  3        *有効桁数
     C                     PARM           PMCHK   1        * kｩｮhmﾞﾆﾞｮn
     C                     PARM           PMRTCD  1        * ﾒjｰ]ﾃｰnﾞ
     C                     MOVELPMCHK     WKCD
      *
     CSR         ESB100    ENDSR
