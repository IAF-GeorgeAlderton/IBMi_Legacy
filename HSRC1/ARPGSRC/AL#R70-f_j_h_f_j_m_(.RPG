     C                     TIME           WTIME
     C                     MOVEL*BLANK    WKIAFB  3
     C                     MOVEL*BLANK    WKEXT   1
     C                     Z-ADD0         WKEXTR  20
     C                     Z-ADD0         WKPAG#  30
     C                     Z-ADD0         WKPAGT  30
     C                     Z-ADD0         WKFIXD  80
     C                     Z-ADD0         WKTIMS  30
     C                     MOVEL*BLANK    SVIAFP  3
     C                     READ AL#WP711                 22
     C           *IN22     DOWEQ'0'
     C           W1PPUL    IFEQ '1'
     C           W1#K01    ANDEQ'1'
      *
     C           W1IAFP    IFNE SVIAFP
     C                     EXSR #SB100
     C                     EXCPTSIK
     C                     MOVELW1IAFP    SVIAFP  3
     C                     ENDIF
     C                     EXCPTDT
     C                     MOVEL'1'       W1FLG
     C                     UPDATAL#WP711
      *
     C                     ENDIF
     C                     READ AL#WP711                 22
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *仕切りデータ
      *-----------------------------------------------------
     CSR         #SB100    BEGSR
      *
     C                     MOVELW1IAFB    WKIAFB
     C                     MOVELW1EXT     WKEXT
     C                     Z-ADDW1EXTR    WKEXTR
     C                     Z-ADDW1FIXD    WKFIXD
     C                     Z-ADDW1TIMS    WKTIMS
      *
     C                     MOVELW1PPUL    WKPPUL  1
     C                     MOVE WKFIXD    BAFIXD
     C                     MOVE WKTIMS    BATIMS
     C                     MOVE WKIAFB    BAIAFB
     C           WKEXTR    IFEQ 0
