     FADAWP53 IP  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FADAPR53 O   E             50     PRINTER
     E                    TBL     1   4 10
     IADAWP531    01
     I                                              DATBMNL2
     I                                              DAHIN1L1
     I                                              DAHIN2L1
     I                                              DAHIN3L1
     I            DS
     I                                        1   80DAHDT
     I                                        1   40DAHTYY
     I                                        5   60DAHTMM
     I                                        7   80DAHTDD
     I            DS
     I                                        1  14 @HIN
     I                                        1   5 DAHIN1
     I                                        6   6 H1
     I                                        7  11 DAHIN2
     I                                       12  12 H2
     I                                       13  14 DAHIN3
     I            DS
     I                                        1   9 @KTKR
     I                                        1   1 @KTKR1
     I                                        2   2 @K1
     I                                        3   4 @KTKR2
     I                                        5   5 @K2
     I                                        6   7 @KTKR3
     I                                        8   8 @K3
     I                                        9   9 @KTKR4
     I            DS
     I                                        1   9 @TTKR
     I                                        1   1 @TTKR1
     I                                        2   2 @T1
     I                                        3   4 @TTKR2
     I                                        5   5 @T2
     I                                        6   7 @TTKR3
     I                                        8   8 @T3
     I                                        9   9 @TTKR4
     I            DS
     I                                        1   8 W@DATE
     I                                        1   4 W@YY
     I                                        5   6 W@MM
     I                                        7   8 W@DD
     I            DS
     I                                        1   6 WTKRO
     I                                        1   1 WTKR1
     I                                        2   3 WTKR2
     I                                        4   5 WTKR3
     I                                        6   6 WTKR4
     C           *IN02     IFEQ '0'
     C                     SETON                     02
     C/SPACE 1
     C           *ENTRY    PLIST
     C                     PARM           PARM1   1
     C                     PARM           PARM2   8
     C                     MOVE PARM2     @MID2
      *
     C/SPACE 1
     C           PARM1     IFEQ 'R'
     C                     MOVELTBL,1     @MID1
     C                     MOVELTBL,3     @MID3
     C                     END
     C/SPACE 1
     C           PARM1     IFEQ 'M'
     C                     MOVELTBL,2     @MID1
     C                     MOVELTBL,4     @MID3
     C                     END
     C                     END
     C/SPACE 1
     C           *INL2     IFEQ '1'
     C                     SETOF                     0350
     C                     Z-ADD0         @GMAS
     C                     MOVE *BLANK    @NAME
     C           DATBMN    CHAINFGBPL011             03
     C           *IN03     IFEQ '0'
     C                     MOVELB2SMEI    @NAME
     C                     END
     C                     WRITEADAPR531
     C                     END
     C/SPACE 1
     C                     ADD  DAMAIS    @MAIS
     C                     ADD  DAMAIS    @GMAS
      *
     C           @DAT1     IFEQ *ZERO
     C                     Z-ADDDAHDT     @DAT1
     C                     Z-ADDDAHDT     @DAT2
     C                     ELSE
     C           DAHDT     COMP @DAT1                  11
     C   11                Z-ADDDAHDT     @DAT1
     C           DAHDT     COMP @DAT2                12
     C   12                Z-ADDDAHDT     @DAT2
     C                     ENDIF
      *
     C/SPACE 1
     CL1                   EXSR SUBRTN
     C/SPACE 1
     CL2                   WRITEADAPR533
     C/SPACE 1
     C           SUBRTN    BEGSR
     C                     MOVE *BLANK    H1
     C                     MOVE *BLANK    H2
     C           DAHIN2    IFNE *BLANK
     C                     MOVE '-'       H1
     C                     END
     C           DAHIN3    IFNE *BLANK
     C                     MOVE '-'       H2
     C                     END
     C/SPACE 1
     C                     MOVE DABAN2    WTKRO
     C                     MOVE *BLANK    @KTKR
     C                     MOVE WTKR1     @KTKR1
     C                     MOVE WTKR2     @KTKR2
     C                     MOVE WTKR3     @KTKR3
     C                     MOVE WTKR4     @KTKR4
     C/SPACE 1
     C*                    MOVEL@KTKR2    WTKR    1
     C*          WTKR      IFEQ '0'
     C*                    MOVEL' '       @KTKR2
     C*                    END
     C*                    MOVEL@KTKR3    WTKR
     C*          WTKR      IFEQ '0'
     C*                    MOVEL' '       @KTKR3
     C*                    END
     C*          @KTKR4    IFEQ '0'
     C*                    MOVE '-'       @K3
     C*                    MOVE *BLANK    @KTKR4
     C*                    END
     C/SPACE 1
     C           @KTKR2    IFNE *BLANK
     C                     MOVE '-'       @K1
     C                     END
     C           @KTKR3    IFNE *BLANK
     C                     MOVE '-'       @K2
     C                     END
     C           @KTKR4    IFNE *BLANK
     C                     MOVE '-'       @K3
     C                     END
     C/SPACE 1
     C           DABAN1    IFNE *BLANK
     C                     MOVE DABAN1    WTKRO
     C                     ELSE
     C                     MOVE DABAN3    WTKRO
     C                     END
     C/SPACE 1
     C                     MOVE *BLANK    @TTKR
     C                     MOVE WTKR1     @TTKR1
     C                     MOVE WTKR2     @TTKR2
     C                     MOVE WTKR3     @TTKR3
     C                     MOVE WTKR4     @TTKR4
     C/SPACE 1
     C*                    MOVEL@TTKR2    WTKR    1
     C*          WTKR      IFEQ '0'
     C*                    MOVEL' '       @TTKR2
     C*                    END
     C*                    MOVEL@TTKR3    WTKR
     C*          WTKR      IFEQ '0'
     C*                    MOVEL' '       @TTKR3
     C*                    END
     C*          @TTKR4    IFEQ '0'
     C*                    MOVE '-'       @T3
     C*                    MOVE *BLANK    @TTKR4
     C*                    END
     C/SPACE 1
     C           @TTKR2    IFNE *BLANK
     C                     MOVE '-'       @T1
     C                     END
     C           @TTKR3    IFNE *BLANK
     C                     MOVE '-'       @T2
     C                     END
     C           @TTKR4    IFNE *BLANK
     C                     MOVE '-'       @T3
     C                     END
     C/SPACE 1
     C           *IN50     IFEQ '1'
     C                     WRITEADAPR531
     C                     SETOF                     50
     C                     END
     C/SPACE 1
      *
     C           @DAT1     IFEQ @DAT2
     C                     MOVE @DAT1     W@DATE
     C           W@MM      CAT  '/':0     @ISDT     P
     C           @ISDT     CAT  W@DD:0    @ISDT     P
     C                     ELSE
     C                     MOVE @DAT1     W@DATE
     C           W@MM      CAT  '/':0     @ISDT     P
     C           @ISDT     CAT  W@DD:0    @ISDT     P
     C           @ISDT     CAT  '->':1    @ISDT     P
     C                     MOVE @DAT2     W@DATE
     C           @ISDT     CAT  W@MM:1    @ISDT     P
     C           @ISDT     CAT  '/':0     @ISDT     P
     C           @ISDT     CAT  W@DD:0    @ISDT     P
     C                     ENDIF
      *
     C                     WRITEADAPR532
     C/SPACE 1
     C                     Z-ADD0         @MAIS
     C                     MOVE *BLANK    @ISDT
     C                     Z-ADD*ZERO     @DAT1   80
     C                     Z-ADD*ZERO     @DAT2   80
     C                     ENDSR
**  TBL
