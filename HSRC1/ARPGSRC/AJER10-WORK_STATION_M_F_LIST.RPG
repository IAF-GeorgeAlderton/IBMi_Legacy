     F************************************** AJER10 **
     FAJETL05 IP  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     IAJETL051
     I                                              H4KINOL2
     I                                              H4BSYOL1
     C                     SETOF                     01
     C                     TIME           WTIME   60
     C/SPACE 1
     C           *INL2     IFEQ '1'
     C           H4KINO    IFEQ '1'
     C                     MOVE '1 MACHIN'WKINO   8
     C                     ELSE
     C                     MOVE '2 MACHIN'WKINO
     C                     END
     C                     END
     C/SPACE 1
     C           H4SKJY    IFEQ 'D'
     C           H4SKHZ    ANDLE*DATE
     C                     ELSE
     C                     SETON                     01
     C                     END
     C/SPACE 1
     C           H4WSTY    IFEQ 'K'
     C                     MOVE ' KANA '  MOTY    6
     C                     ELSE
     C                     MOVE ' KANJI'  MOTY    6
     C                     END
      *
     C   L1                EXCPTDT
     OQPRINT  H  102   L2
     O       OR        OFNL2
