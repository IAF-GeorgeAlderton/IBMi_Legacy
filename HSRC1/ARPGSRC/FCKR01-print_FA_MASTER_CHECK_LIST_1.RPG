     H            Y.
     F** FCKR01 ****************************************************************
     F*  PROGRAM    : PRINT FA MASTER CHECK LIST 1                             *
     F*  WRITTEN    : 5/03/2017                                                *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAJSPP01 IF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
     I            DS
     I                                        1   80UPD@DT
     I                                        1   40J1KOYY
     I                                        5   60J1KOMM
     I                                        7   80J1KODD
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR @INIT
      *
     C           *IN98     DOWEQ*OFF
     C                     READ AJSPP01                  98
      * END?
     C           *IN98     IFEQ *OFF
     C           J1MKRI    ANDEQ0
     C           J1MKJI    ANDEQ0
     C           J1SKJY    ANDEQ*BLANK
     C           J121CD    ANDEQ0111
     C           J1MEK1    IFNE '.GM.'
     C           J1MEK1    ANDNE'.MA.'
     C                     EXSR @PRINT
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      * SET FLAG
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           @PRINT    BEGSR
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           @INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C                     Z-ADD*DATE     @DATE   80
     C                     TIME           @TIME   60
     C                     Z-ADD0         SEQ#    40
      *
     C                     EXCPT@HDR
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** FA MASTER CHECK L'
     O                                   60 'IST (1) ** (J1MEK1 I'
     O                                   80 'S NOT .GM. NOR .MA.)'
     O                         @DATE    102 '    .  .  '
     O                         @TIME    112 '  :  :  '
     O                                  115 'P.'
     O                         PAGE  Z  119
     O        E   03           @HDR
     O                                    7 '    '
     O                                   15 'DLT   '
     O                                   23 'PART1 '
     O                                   31 'PART2 '
     O                                   39 'PART3 '
     O                                   47 'PLC TH'
     O                                   55 'PLC PR'
     O                                   63 'PROC1 '
     O                                   71 'HDL CD'
     O                                   80 'UPD_DATE'
     O                                   89 'UPD_PGM'
     O                                  100 'U/WGT'
     O        E   04           @HDR
     O                                    7 'SEQ#'
     O                                   15 'J1SKJY'
     O                                   23 'J1SHN1'
     O                                   31 'J1SHN2'
     O                                   39 'J1SHN3'
     O                                   47 'J1MKRI'
     O                                   55 'J1MKJI'
     O                                   63 'J121CD'
     O                                   71 'J1MEK1'
     O                                   80 '        '
     O                                   88 'J1KOME'
     O                                  100 'J1TANJ'
     O        E 1              @DTL
     O                         SEQ#  Z +003
     O                         J1SKJY  +006
     O                         J1SHN1  +003
     O                         J1SHN2  +003
     O                         J1SHN3  +003
     O                         J1MKRI  +006
     O                         J1MKJI  +005
     O                         J121CD  +005
     O                         J1MEK1  +004
     O                         UPD@DT  +003
     O                         J1KOME  +002
     O                         J1TANJ3 +000
