     C*     4TH SCREEN CHECK
     C**************************************************************************
     C           #CHK40    BEGSR
     C*
     C                     MOVEL*BLANK    W4SHIN
     C                     MOVELF4LOC     W4LOC
     C                     SETOF                     9961
     C*
     C                     DO
     C*
     C           F4LOC     IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,2     F4ERR
     C                     MOVELERR,2     F99ER1
     C                     MOVELERR,3     F99ER2
     C                     LEAVE
     C                     END
     C*
     C                     MOVEL*OFF      W4@ERR  1
     C                     SELEC
     C           EKZETI    WHEQ '3622'                     M6-25
     C           W4ZETI    IFEQ '3611'                     U0609B3008
     C                     ELSE
     C                     MOVEL*ON       W4@ERR
