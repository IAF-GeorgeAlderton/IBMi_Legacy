     C                     END
     C*
     C           W2USER    CHAINAB#PL71              90
     C           *IN90     IFEQ *ON
     C                     SETON                     9961
     C           F2ERR     IFEQ *BLANK
     C                     MOVELERR,1     F2ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,4     F99ER2
     C                     END
     C                     LEAVE
     C                     END
     C*
     C           EKSRYO    IFNE *ZERO
     C                     SETON                     9961
     C           F2ERR     IFEQ *BLANK
     C                     MOVELERR,1     F2ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,5     F99ER2
     C                     END
     C                     LEAVE
     C                     END
     C*
     C           EKZETI    IFEQ '3622'                     M6-25
