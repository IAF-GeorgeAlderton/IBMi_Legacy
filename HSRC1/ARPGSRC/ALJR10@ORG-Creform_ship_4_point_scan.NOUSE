      *
     C                     ENDSR
     C**************************************************************************
     C*     2ND SCREEN CHECK
     C**************************************************************************
     C           #CHK20    BEGSR
     C*
     C                     MOVEL*BLANK    W2SHIN
     C                     MOVELF2USER    W2USER
     C                     SETOF                     9961
     C*
     C                     DO
     C*
     C           F2USER    IFEQ *BLANK
     C                     SETON                     9961
