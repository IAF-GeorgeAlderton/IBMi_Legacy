     C           EKZETI    WHEQ '3624'                     M6-25B
     C           W4ZETI    IFEQ '3611'                     U0609B3008
     C           W4ZETI    OREQ '3518'                     U0633B3007
     C                     ELSE
     C                     MOVEL*ON       W4@ERR
     C                     END
     C                     ENDSL
     C           W4@ERR    IFEQ *ON
     C                     SETON                     9961
     C                     MOVELERR,2     F4ERR
     C                     MOVELERR,2     F99ER1
     C                     MOVELERR,10    F99ER2
     C                     LEAVE
     C                     END
     C*
     C           W4ZETI    CHAINFCETL11              90
     C           *IN90     IFEQ *ON
     C           A2GSKD    ORNE *BLANK
