     H            Y.
     F** AA#R14 **************************************
     F* SHORTAGE FOLLOW STATUS (OQ)
     F*      OSHIMA.         2021.04.15              *
     F************************************************
     FAA#PW14 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL
     F                                              KNUM        1
     F                                              KINFDS INFDS
     FAA#WP14 IF  E           K        DISK
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTITM
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I            DS
     I                                        1   60W3TIME
     I                                        1   2 W3NTIH
     I                                        3   4 W3NTIM
      *
     I            DS
     I                                        1   5 S1TIME
     I                                        1   2 S1NTIH
     I                                        3   3 S1NTTT
     I                                        4   5 S1NTIM
      *
     I            DS
     I                                        1  10 S1COND
     I                                        1   2 S1HOJI
     I                                        3   3 S1CF1
     I                                        4   6 S1ONDO
     I                                        7   7 S1CF2
     I                                        8   8 S1CO21
     I                                        9   9 S1CO22
     I                                       10  10 S1CO23
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     IINFDS       DS
     I                                    B 370 3710#CUR
     I                                    B 378 3790#POS
     I                                      401 402 MJCODE
     I                                      401 404 MJCOD4
     I                                     *STATUS  @STTS
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1PG    50
     C                     PARM           P1DATE  8
     C                     PARM           P1TIME  6
     C                     PARM           P1REC  100
     C                     PARM           P1CMD   2
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * CONTROL                                            *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INIT                                               *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     C                     MOVE P1DATE    C1DATE
     C                     MOVE P1TIME    C1TIME
      *
     C                     MOVEL*BLANK    P1CMD
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * READ                                               *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
     C                     Z-ADD0         WKPAG@  30
     C           P1REC     DIV  10        SS      30
     C                     MVR            RR      30
     C           RR        IFNE 0
     C                     ADD  1         SS
     C                     ENDIF
     C           P1PG      IFGT SS
     C                     Z-ADD1         P1PG
     C                     ENDIF
      *
     C                     SETOF                     8166
     C           *LOVAL    SETLLAA#WP141
     C                     READ AA#WP141                 81
      *
     C           WKPAG@    DOWLTP1PG
     C                     EXSR #CLR
      *
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ AA#WP141                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     ADD  1         WKPAG@
     C                     ADD  1         WKPAGE
     C                     ENDDO
      *
     C                     Z-ADDP1PG      WKPAGE  30
     C                     MOVE '02'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * 1ST.                                               *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C           CTRX      IFEQ 0
     C                     SETON                     72
     C                     SETON                     99
     C                     ELSE
     C                     SETON                     7273
     C                     ENDIF
      *
     C*******              EXFMTSFLCTL
     C           CTRX      IFEQ 0
     C                     WRITEAA#PW149               92
     C                     ELSE
     C                     WRITESFLCTL                 92
     C                     ENDIF
     C                     READ AA#PW14                9898
      *
     C                     SETOF                     7273
     C                     SETOF                     3199
     C           *IN,98    IFEQ '1'
     C           @STTS     ANDEQ1331
     C           *IN81     IFEQ '1'
     C                     Z-ADD1         P1PG
     C                     ELSE
     C                     ADD  1         P1PG
     C                     ENDIF
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      * F1
     C           *IN01     IFEQ '1'
     C                     MOVEL'01'      P1CMD
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      * F5
     C           *IN05     IFEQ '1'
     C                     MOVEL'05'      P1CMD
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      * F7
     C****       *IN07     IFEQ '1'
     C****                 MOVEL'07'      P1CMD
     C****                 MOVE '99'      DSPSW
     C****                 GOTO ESB220
     C****                 ENDIF
      *
     C           CTRX      IFEQ 0
     C                     GOTO ESB220
     C                     ENDIF
      *
      *-----------------*
      * ROLLDOWN/PAGEUP *
      *-----------------*
     C           *IN52     IFEQ '1'
     C*                    ADD  1         CTRX
      * 1ST. PAGE
     C           WKPAGE    IFEQ 1
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
     C           *IN81     IFEQ '1'
     C                     SETOF                     81
     C           *HIVAL    SETGTAA#WP141
     C                     READPAA#WP141                 81
     C                     SUB  1         CTRX
     C                     ENDIF
      *
     C                     ADD  10        CTRX
      *                         L--表示行数
     C                     SETOF                     6627
      *
     C           *IN81     DOWEQ'0'
     C           *IN27     ANDEQ'0'
     C                     EXSR #READP
     C                     READPAA#WP141                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXTP
     C                     ENDDO
      *
     C                     Z-ADD0         CTRX    40
      *
     C           *IN81     IFEQ '1'
     C           *LOVAL    SETLLAA#WP141
     C                     READ AA#WP141                 81
     C                     ENDIF
      *
     C                     EXSR #CLR
     C                     SETOF                     8166
      *
     C                     SUB  1         WKPAGE
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ AA#WP141                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     GOTO ESB220
     C                     ENDIF
      *--------------------*
      * ROLL-UP            *
      *--------------------*
     C           *IN51     IFEQ '1'
     C           *IN81     ANDEQ'0'
      *
     C                     EXSR #CLR
      *
     C                     ADD  1         WKPAGE
     C                     SETOF                     6681
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ AA#WP141                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     GOTO ESB220
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * READ                                               *
      *----------------------------------------------------*
     CSR         #READ     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREAD
     C                     ENDIF
      *
     C                     ADD  1         RRN
     C                     ADD  1         @RRN
     C                     ADD  1         CTRX
     C                     EXSR #EDIT
     C                     WRITESFL
      *
     C           CTRX      IFEQ 10
     C                     SETON                       66
     C                     ENDIF
      *
     CSR         EREAD     ENDSR
      *----------------------------------------------------*
      * READP                                              *
      *----------------------------------------------------*
     CSR         #READP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREADP
     C                     ENDIF
      *
     C                     SUB  1         CTRX           27
      *
     CSR         EREADP    ENDSR
      *----------------------------------------------------*
      * SELECT DATA                                        *
      *----------------------------------------------------*
     CSR         #SELEC    BEGSR
      *
     C                     MOVEL'1'       WKGET
      *
     CSR         ESELEC    ENDSR
      *----------------------------------------------------*
      * CLEAR ITEM                                         *
      *----------------------------------------------------*
     CSR         #CLR      BEGSR
      *
     C                     SETON                     71
     C                     WRITESFLCTL
     C                     SETOF                     7166
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN    40
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         @SFRC1
      *
     CSR         ECLR      ENDSR
      *----------------------------------------------------*
      * EDIT ITEM                                          *
      *----------------------------------------------------*
     CSR         #EDIT     BEGSR
      *
     C                     Z-ADD0         #1NO   110
     C           WKPAGE    MULT 10        #1NO
     C                     SUB  10        #1NO
     C                     ADD  CTRX      #1NO
     C                     Z-ADD#1NO      S1NO
     C                     SETOF                     3839
     C                     SETON                     38
      *
     C                     MOVEL*BLANK    S1LOCA
     C           W3TKR1    CAT  '-':0     S1LOCA
     C           S1LOCA    CAT  W3TKR2:0  S1LOCA
     C           S1LOCA    CAT  '-':0     S1LOCA
     C           S1LOCA    CAT  W3TKR3:0  S1LOCA
     C           S1LOCA    CAT  '-':0     S1LOCA
     C           S1LOCA    CAT  W3TKR4:0  S1LOCA
     C                     MOVEL*BLANK    S1LOC
     C           5         SUBSTS1LOCA:3  S1LOC
      *
     C                     MOVEL*BLANK    S1SHN
     C                     MOVELW3SHN1    S1SHN
     C           W3SHN2    IFNE *BLANK
     C           S1SHN     CAT  '-':0     S1SHN
     C           S1SHN     CAT  W3SHN2:0  S1SHN
     C                     ENDIF
     C           W3SHN3    IFNE *BLANK
     C           S1SHN     CAT  '-':0     S1SHN
     C           S1SHN     CAT  W3SHN3:0  S1SHN
     C                     ENDIF
      *
     C                     MOVEL*BLANK    S1OQHN
     C                     MOVELW3OQH1    S1OQHN
     C           W3OQH2    IFNE *BLANK
     C           S1OQHN    CAT  '-':0     S1OQHN
     C           S1OQHN    CAT  W3OQH2:0  S1OQHN
     C                     ENDIF
     C           W3OQH3    IFNE *BLANK
     C           S1OQHN    CAT  '-':0     S1OQHN
     C           S1OQHN    CAT  W3OQH3:0  S1OQHN
     C                     ENDIF
      *
     C                     Z-ADDW3DATE    S1DATE
     C                     MOVEL*BLANK    S1TIME
     C                     MOVELW3NTIH    S1NTIH
     C                     MOVEL':'       S1NTTT
     C                     MOVELW3NTIM    S1NTIM
     C                     Z-ADDW3KQTY    S1KQTY
     C                     Z-ADDW3UNS     S1UNS
     C           W3PRE     MULT W3LOTO    S1PRE
     C                     Z-ADDW3QTY     S1INV
     C                     Z-ADDW3TDYS    S1DAYS
     C                     MOVELW3RONO    S1MSN#
      *
     C                     MOVE W3CO2P    WKCO2P  3
     C                     MOVEL*BLANK    S1COND
     C                     MOVE W3HOJI    S1HOJI
     C                     MOVEL'-'       S1CF1
     C                     MOVELW3ONDO    S1ONDO
     C                     MOVEL'-'       S1CF2
     C           1         SUBSTWKCO2P:1  S1CO21
     C                     MOVEL'.'       S1CO22
     C           1         SUBSTWKCO2P:2  S1CO23
      *
     C                     Z-ADDW3HOJI    H1HOJI
     C                     Z-ADDW3ONDO    H1ONDO
     C                     Z-ADDW3CO2P    H1CO2P
     C*
     C                     MOVEL*ALL'-'   S1FFFF
     C                     SETOF                     49
     C           S1DAYS    IFLT 1.0
     C                     SETON                     49
     C                     ENDIF
      *
     C                     SETOF                     48
     C           S1PRE     IFGT 0
     C                     SETON                     48
     C                     ENDIF
      *
     CSR         EEDIT     ENDSR
      *----------------------------------------------------*
      * NEXT DATA                                          *
      *----------------------------------------------------*
     CSR         #NEXT     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXT
     C                     ENDIF
      *
     C                     READ AA#WP141                 81
      *
     CSR         ENEXT     ENDSR
      *----------------------------------------------------*
      * PRV DATA                                           *
      *----------------------------------------------------*
     CSR         #NEXTP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXTP
     C                     ENDIF
      *
     C                     READPAA#WP141                 81
      *
     CSR         ENEXTP    ENDSR
