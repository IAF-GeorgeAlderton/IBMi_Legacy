     H            Y.
     F** AN#RF7 ********************************************
     F*  ANDROID CALCULATE ORDER QUANTITY                  *
     F*                                                    *
     F*  *IN89=1 NOT WORKING DAY                           *
     F*  *IN91=1 NOT EXIST ABRAP01(EDI KEY DATA)           *
     F*  *IN92=1 NOT EXIST ABR2L02(ANDROID DATA)           *
     F*  *IN94=1 NOT EXIST FCEPL01(PART MASTER)            *
     F*  *IN95=1 NOT EXIST ABFEP01(JULIAN CALENDER MASTER) *
     F*  *IN96=1 NOT EXIST AB#PL15(ORDER DATA)             *
     F*  *IN97=1 NOT EXIST AGDPL11(CALENDER FILE)          *
     F*                                                    *
     F* TCHK1 07/12/06 CREATE(COPY FROM AB#RF7F1)          *
     F******************************************************
     FABRAP01 IF  E           K        DISK
     FABR2L02 IF  E           K        DISK
     FABFEP01 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FAB#PL15 IF  E           K        DISK
     FAGDPL11 IF  E           K        DISK
     FGADPL11 IF  E           K        DISK
     FABWP455 O   E                    DISK
     FQPRINT  O   F     132     OF     PRINTER
     E****************************************************
     I* RELEASED DATE(PARAMETER)
     I            DS
     I                                        1   8 WRDATE
     I                                        1   80WRDAT
     I                                        1   40WRYYYY
     I                                        5   60WRMMMM
     I                                        7   80WRDDDD
     I* SHIPPING DATE(PARAMETER)
     I            DS
     I                                        1   8 WSDATE
     I                                        1   80WSDAT
     I                                        1   40WSYYYY
     I                                        5   60WSMMMM
     I                                        7   80WSDDDD
     I* TIME
     I            DS
     I                                        1  120WTMDT
     I                                        1   60WTIME
     I                                        7  120WDATE
      * DELETE DATE(YYYYMMDD) PART MASTER
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      * DELIVERY DATE(YYYYMMDD) AB#PP10
     I            DS
     I                                        1   80BANDAT
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
      * LAST SHIPPED DATE(YYMMDD) ABR2L02
     I            DS
     I                                        1   60AFLSDT
     I                                        1   20WFLSDT
     I                                        3   40K64
     I                                        5   60K65
     I* CHANGE DATE(PART MASTER)
     I            DS
     I                                        1   80A2SSHZ
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
     I* PART NUMBER(INTERNAL PART=NO BLANKS)
     I            DS
     I                                        1  12 @SHIN
     I                                        1   5 WHIN1
     I                                        6  10 WHIN2
     I                                       11  12 WHIN3
     I* PART NUMBER(USER)
     I            DS
     I                                        1  20 WMHIN
     I                                        1   5 WMHN1
     I                                        6  10 WMHN2
     I                                       11  15 WMHN3
     I                                       16  20 WMHN4
     I* INVOICE NUMBER(OUT FILE)
     I            DS
     I                                        1   6 WINV#
     I                                        1   3 WINV1
     I                                        4   60WINV2
     I* 2WEEKS AGO(CALENDER FILE)
     I            DS
     I                                        1   80F8DATE
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@Y
     I                                        5   60K@M
     I                                        7   80K@D
     I            DS
     I                                        1   80W@DAT1
     I                                        1   20W@DAT2
     I                                        3   80W@DAT3
     C***********************************************************
     C           *ENTRY    PLIST
     C                     PARM           PRYYYY  40
     C                     PARM           PRMMMM  20
     C                     PARM           PRDDDD  20
     C                     PARM           PSYYYY  40
     C                     PARM           PSMMMM  20
     C                     PARM           PSDDDD  20
     C                     PARM           PSIRE   4
     C* ABR2L02
     C           KEY2      KLIST
     C                     KFLD           K#PLAN  5        A + PLANT
     C                     KFLD           K#DOCK  4        DOCK
     C                     KFLD           K21              INTERNAL PART
     C                     KFLD           CFSIDT           SCHEDULE ISSUE DATE
     C                     KFLD           CFPOR#           ORDER #
     C                     KFLD           CFREF#           REFERENCE #
     C                     KFLD           K22              SHIP DATE
     C           KEY21     KLIST
     C                     KFLD           K#PLAN           A + PLANT
     C                     KFLD           K#DOCK           DOCK
     C                     KFLD           K21              INTERNAL PART
     C                     KFLD           CFSIDT           SCHEDULE ISSUE DATE
     C                     KFLD           CFPOR#           ORDER #
     C                     KFLD           CFREF#           REFERENCE #
     C* ABFEP01
     C           KEY3      KLIST
     C                     KFLD           WSYYYY           SHIP YYYY
     C                     KFLD           WSMMMM                MMMM
     C* FCEPL01
     C           KEY4      KLIST
     C                     KFLD           WHIN1            INTERNAL PART
     C                     KFLD           WHIN2
     C                     KFLD           WHIN3
     C* AB#PL15
     C           KEY7      KLIST
     C                     KFLD           K61              BATOKU
     C                     KFLD           K#NONY             NONY
     C                     KFLD           WNKOJ              NKOJ
     C                     KFLD           @NUKE   4        BANUKE
     C                     KFLD           WMHN1              MHN1
     C                     KFLD           WMHN2              MHN2
     C                     KFLD           WMHN3            BAMHN3
     C                     KFLD           WMHN4              MHN4
     C                     KFLD           WODRN              ODRN
     C* AB#PL15
     C           KEY6      KLIST
     C                     KFLD           K61              BATOKU
     C                     KFLD           K#NONY             NONY
     C                     KFLD           WNKOJ              NKOJ
     C                     KFLD           @NUKE            BANUKE
     C                     KFLD           WMHN1              MHN1
     C                     KFLD           WMHN2              MHN2
     C                     KFLD           WMHN3            BAMHN3
     C                     KFLD           WMHN4              MHN4
     C                     KFLD           WODRN              ODRN
     C                     KFLD           K63     40       BANOYY
     C                     KFLD           K64                NOMM
     C                     KFLD           K65                NODD
     C                     KFLD           K62              BANOBN
     C* AGDPL11
     C           KEY8      KLIST
     C                     KFLD           WRYYYY           SHIP YYYY
     C                     KFLD           WRMMMM                MMMM
     C                     KFLD           WRDDDD                DDDD
     C           K#AGD     KLIST
     C                     KFLD           K@Y              SHIP YYYY
     C                     KFLD           K@M                   MMMM
     C                     KFLD           K@D                   DDDD
      *
     C           K#GAD     KLIST
     C                     KFLD           @TOKU
     C                     KFLD           K#NONY  40
     C                     KFLD           WNKOJ
      *
     C           PSIRE     IFNE *BLANK
     C                     MOVE PSIRE     @@NONY  40
     C                     ELSE
     C                     Z-ADD*ZERO     @@NONY
     C                     ENDIF
     C***********************************************************
     C*
     C                     EXSR @INZ
     C                     EXSR @MAIN
     C                     EXSR @END
     C***********************************************************
     C* INITIALIZE WORK AREA
     C***********************************************************
     C           @INZ      BEGSR
     C*
     C                     TIME           WTMDT
     C*
     C                     Z-ADD*ZERO     WQTY2  100
     C                     Z-ADD*ZERO     WQTY3  100
     C                     Z-ADD*ZERO     WSUMQ  100
     C                     Z-ADD*ZERO     WODRQ  100
     C                     SETON                     OF
     C*
     C                     Z-ADDPRYYYY    WRYYYY
     C                     Z-ADDPRMMMM    WRMMMM
     C                     Z-ADDPRDDDD    WRDDDD
     C                     Z-ADDPSYYYY    WSYYYY
     C                     Z-ADDPSMMMM    WSMMMM
     C                     Z-ADDPSDDDD    WSDDDD
     C*
     C* NOT WORKING DAY?
     C           WRDATE    IFNE WSDATE
     C                     SETON                     89
     C                     END
     C*
     C* GET THE DATE OF 2WEEKS AGO
     C                     Z-ADD*ZERO     @CNT    20
     C                     Z-ADD*DATE     K@YMD
     C           K#AGD     SETLLAGDPL11
     C           *IN97     DOUEQ*ON
     C                     READPAGDPL11                  97
     C           *IN97     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     ADD  1         @CNT
     C           @CNT      IFEQ 7
     C                     Z-ADDF8DATE    @@STDT  80
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           KEY8      SETLLAGDPL111
     C                     DO   14
     C                     READPAGDPL111                 97
     C                     END
     C*
     C                     ENDSR
     C***********************************************************
     C* MAIN
     C***********************************************************
     C           @MAIN     BEGSR
     C*
     C* READ EDI KEY FILE
     C           *LOVAL    SETLLABRAP01R
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ABRAP01R                 91
     C   91                LEAVE
     C           CFDLCD    IFNE *BLANK
     C                     ITER
     C                     END
     C           CFSIDT    IFLT @@STDT
     C                     ITER
     C                     END
     C* READ EDI FILE
     C                     MOVELCFPART    K21    20
     C                     Z-ADDWRDAT     K22     80
     C                     MOVEL'A'       K#PLAN
     C                     MOVE CFDOCK    K#PLAN
     C                     MOVELCFDOC2    K#DOCK
     C           KEY2      CHAINABR2P011             92
      *
     C           *IN92     IFEQ *ON
     C           KEY2      SETLLABR2P011
     C           KEY21     REDPEABR2P011                 92
     C                     END
      *
     C           *IN92     IFEQ *ON
     C           F8DATE    IFLE CFSIDT
     C   OF                EXCPT#HED1
     C   OF                SETOF                     OF
     C                     EXCPT#DTL4
     C                     END
     C                     ITER
     C                     END
     C*
     C* SET AB#WP451(INPUT FILE FOR AB#R45)
     C                     MOVE 'AVRT'    WSIRE   4        SUPPLIER CODE
     C                     MOVE 'A'       WSIRK   1        FACTORY  CODE
      *
     C                     SELEC
     C           K#PLAN    WHEQ 'AIW01'
      * WIXOM
     C                     MOVE '2855'    WTOKU   4        CUSTOMER CODE
     C                     MOVE 2855      @TOKU   40       CUSTOMER CODE
     C                     MOVE '2855'    WNONY   4        DELIVERY CODE
     C           K#PLAN    WHEQ 'AIL01'
      * LOUISVILLE
     C                     MOVE '2856'    WTOKU   4        CUSTOMER CODE
     C                     MOVE 2856      @TOKU   40       CUSTOMER CODE
     C                     MOVE '2856'    WNONY   4        DELIVERY CODE
     C                     OTHER
     C                     MOVE *BLANK    WTOKU   4        CUSTOMER CODE
     C                     MOVE *ZERO     @TOKU   40       CUSTOMER CODE
     C                     MOVE *BLANK    WNONY   4        DELIVERY CODE
     C                     ENDSL
      *
     C                     MOVE '0'       WNKOJ   1        FACTORY  CODE
     C                     MOVELCFDOC2    WNUKE   4        RECEIVING   E
     C                     MOVE *BLANK    WSBAN   4        NUMBER      E
     C                     MOVE *BLANK    WMHIN
     C                     MOVELAFIPAR    WMHIN            PART NUMBER E
     C                     Z-ADDWSDAT     WNYMD   80       DELIVERY DATE
     C                     MOVELAFODRN    WODRN  10        ORDER #     E
     C                     MOVE '01'      WBIN    2
      *
     C                     Z-ADD99        K62     20       BIN
     C*
     C                     EXSR @SUM
     C*
     C* NOT WORKING DAY,RE-CULUCULATE
     C           *IN89     IFEQ '1'
     C           AFQTY2    SUB  AFYSQY    WQTY2            ORDERED QTY
     C                     SUB  WODRQ     WQTY2
     C                     MOVE WQTY2     WSURY   7
     C                     ELSE
     C* REQUESTED CUM - SHIPPED CUM
     C           AFQTY2    SUB  AFYSQY    WQTY2            ORDERED QTY
     C                     SUB  WODRQ     WQTY2
     C                     MOVE WQTY2     WSURY   7
     C                     END
     C*
     C* GET UNIT QUANTITY
     C           WQTY2     IFGT *ZERO
     C                     MOVELWTOKU     PTOKU   4
     C                     MOVELWNONY     PNONY   4
     C                     MOVELWNKOJ     PNKOJ   1
     C                     MOVELWNUKE     PNUKE   4
     C                     MOVELWMHIN     @MHIN  20
     C                     MOVELWMHIN     WMHIN  20
     C                     MOVEL*BLANK    @SHIN  12
     C                     MOVEL*BLANK    @FLG    1
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU
     C                     PARM           PNONY
     C                     PARM           PNKOJ
     C                     PARM           PNUKE
     C                     PARM           @MHIN
     C                     PARM           @SHIN
     C                     PARM           @FLG
     C* GET QTY./CONT. FROM PART MASTER
     C                     Z-ADD*ZERO     WSYOS            FOR ERROR
     C           KEY4      CHAINFCEPL011             94
     C           *IN94     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ELSE
     C           A2SSHZ    IFLE *DATE
     C                     Z-ADDA2SSYS    WSYOS   60
     C                     ELSE
     C                     Z-ADDA2KSYS    WSYOS
     C                     END
     C                     END
     C                     ELSE
     C   OF                EXCPT#HED1
     C   OF                SETOF                     OF
     C                     EXCPT#DTL2
     C                     END
     C*
     C* CHECK FRACTION OR NOT
     C           WSYOS     IFNE *ZERO
     C           WQTY2     DIV  WSYOS     WQTY2
     C                     MVR            WREST   40
     C           WREST     IFNE *ZERO
     C   OF                EXCPT#HED1
     C   OF                SETOF                     OF
     C                     EXCPT#DTL3
     C                     END
     C                     END
     C*
     C                     Z-ADD*ZERO     WNOTM   40       INVOICE TIME
     C                     Z-ADD*ZERO     WUSYS   60       USER QTY/CONT.
     C                     MOVELAFALFL    WALFL   4        FEED LINE
     C*
     C* GET INVOICE NUMBER(ROUTE + JULIAN DATE)
     C                     MOVEL'DAY'     WINV1
     C           KEY3      CHAINABFEP01              95
     C           *IN95     IFEQ '0'
     C           QB#DAY    ADD  WSDDDD    WINV2
     C                     ELSE
     C                     Z-ADD*ZERO     WINV2
     C                     END
     C*
     C                     MOVELAFRALF    WRLOC   4
     C                     Z-ADD20        W@DAT2
     C                     Z-ADDAFDATE    W@DAT3
     C                     MOVELW@DAT1    WCRTDT
     C*
     C                     WRITEABWP455R
     C                     SETON                     U1
      *
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C***********************************************************
     C* SUM (SUMMARY ALREADY ORDERED DATA)
     C***********************************************************
     C           @SUM      BEGSR
     C*
     C                     Z-ADD@TOKU     K61     40
     C                     Z-ADD*ZERO     WODRQ
     C                     Z-ADD2000      K63
     C                     ADD  WFLSDT    K63
     C                     MOVELCFDOC2    @NUKE   4        RECEIVING   E
     C                     EXSR @SUM2
     C*
     C                     MOVELWNONY     K#NONY
     C           K#GAD     SETLLGADPL11
     C           *IN97     DOUEQ*ON
     C           K#GAD     READEGADPL11                  97
     C           *IN97     IFEQ *OFF
     C           B5NUKE    ANDNECFDOC2
     C           B5SKJY    ANDEQ' '
     C                     MOVE B5NUKE    @NUKE
     C                     EXSR @SUM2
     C                     ENDIF
     C                     ENDDO
     C*
     C                     ENDSR
     C***********************************************************
     C* SUM (SUMMARY ALREADY ORDERED DATA)
     C***********************************************************
     C           @SUM2     BEGSR
     C*
     C           KEY6      SETGTAB#PL151
     C           KEY7      READEAB#PL151                 96
     C           *IN96     DOWEQ'0'
     C           BANDAT    ANDLTWRDAT
     C           BASKJY    IFEQ ' '
     C*
     C                     ADD  BASRYO    WODRQ
     C*
     C                     END
     C           KEY7      READEAB#PL151                 96
     C                     END
      *
     C                     ENDSR
     C***********************************************************
     C* END
     C***********************************************************
     C           @END      BEGSR
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C                     ENDSR
     C***********************************************************
     OQPRINT  E    2           #HED1
     O       OR        OF
     O                                    8 'AN#RF7'
     O                                   32 'ANDROID NIRVANA DATA'
     O                                   43 'ERROR LIST'
     O*
     O        E 1              #HED1
     O       OR        OF
     O                                  131 '.         .         .'
     O*
     O        E 1              #HED1
     O       OR        OF
     O                                   89 'TIME'
     O                         WTIME     98 '  :  :  '
     O                                  131 '.         .         .'
     O*
     O        E 1              #HED1
     O       OR        OF
     O                                   89 'DATE'
     O                         UDATE Y   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O                                  131 '.....................'
     O*
     O*       E 1              #DTL1
     O*                                  18 'NOT EXIST ADDRESS'
     O*                                  25 'MASTER'
     O*                        QAPLAN    40
     O*
     O        E 1              #DTL2
     O                                   16 'QTY./CONT ERROR'
     O                                   32 '(NO PART MASTER)'
     O                         K#PLAN    40
     O                         CFDOC2    45
     O                         CFPART    65
     O*
     O        E 1              #DTL3
     O                                   22 'FRACTIONS ENCOUNTERED'
     O                         K#PLAN    40
     O                         CFDOC2    45
     O                         CFPART    65
     O                                   77 'ORDER QTY.:'
     O                         WSURY     87
     O                                  100 'QTY./CONT.:'
     O                         WSYOS    110
     O*
     O        E 1              #DTL4
     O                                   21 'ABR2P01 ERROR.PLEASE'
     O                                   41 'CONTACT SYSTEM ADM.'
     O                         K#PLAN    46
     O                         CFDOC2    50
     O                         CFPART    65
     O                         CFSIDT    75
     O                         CFPOR#    85
     O                         WSDATE    95
     O                                  109 'RELEASED DATE'
     O                         WRDATE   119
