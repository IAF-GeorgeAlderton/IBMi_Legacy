     F** AKER04 ************************************
     F* .. COMPONENTS KANBAN M/F LIST CREATE .. *.
     F* I-HASADA                    93.07.26       *
     F************************************ AKER04 **
     FAKEWP04 IP  F     100            DISK
     FAKEWP05 O   F     100            DISK
     E                    HTR3       20  6               ﾃcﾈbﾍ] f]ﾌﾞ]
     E                    HTRP       20  6               ﾃcﾈbﾍ] xｮgf]ﾌﾞ]
     E                    HTRQ       20  6               ﾃcﾈbﾍ] n]rﾓf]ﾌﾞ]
     IAKEWP04 AA  01
     I                                        1  12 IKHIN L1
     I                                       13  18 ITKR3
     I                                       19  24 ITKRP
     I                                       25  30 ITKRQ
      *
     C           *INL1     IFEQ '1'
     C                     SETOF                     10
     C                     Z-ADD0         A       20
     C                     Z-ADD0         B       20
     C                     Z-ADD0         C       20
     C                     MOVE *BLANK    HTR3
     C                     MOVE *BLANK    HTRP
     C                     MOVE *BLANK    HTRQ
     C                     MOVE *BLANK    WTKR3   6
     C                     MOVE *BLANK    WTKRP   6
     C                     MOVE *BLANK    WTKRQ   6
     C                     END
      *
     C*------------------------*
     C*  ..構成品かんばん..  *
     C*------------------------*
     C           ITKR3     IFNE *BLANK
     C                     SETON                     10
     C                     ADD  1         A
     C                     MOVE ITKR3     HTR3,A
     C                     END
      *
     C*------------------------------*
     C*  ..構成品メッキかんばん..  *
     C*------------------------------*
     C           ITKRP     IFNE *BLANK
     C                     SETON                     10
     C                     ADD  1         B
     C                     MOVE ITKRP     HTRP,B
     C                     END
      *
     C*--------------------------------*
     C*  ..構成品トンネルかんばん..  *
     C*--------------------------------*
     C           ITKRQ     IFNE *BLANK
     C                     SETON                     10
     C                     ADD  1         C
     C                     MOVE ITKRQ     HTRQ,C
     C                     END
      *
     CL1 10                EXSR SUBR
      *
      *
     C*----------------------*
     C*  ..サブルーチン..  *
     C*  ..データ出力      *
     C*----------------------*
     C           SUBR      BEGSR
      *
     C                     Z-ADD1         D       20
     C           1         DO   20        D
     C                     SETOF                     11
      *
     C           HTR3,D    IFEQ *BLANK
     C           HTRP,D    ANDEQ*BLANK
     C           HTRQ,D    ANDEQ*BLANK
     C                     SETON                     11
     C                     ELSE
      *
     C*------------------------*
     C*  ..構成品かんばん..  *
     C*------------------------*
     C           HTR3,D    IFNE *BLANK
     C                     MOVE HTR3,D    WTKR3
     C                     END
      *
     C*------------------------------*
     C*  ..構成品メッキかんばん..  *
     C*------------------------------*
     C           HTRP,D    IFNE *BLANK
     C                     MOVE HTRP,D    WTKRP
     C                     END
      *
     C*--------------------------------*
     C*  ..構成品トンネルかんばん..  *
     C*--------------------------------*
     C           HTRQ,D    IFNE *BLANK
     C                     MOVE HTRQ,D    WTKRQ
     C                     END
      *
     C                     EXCPTDT
      *
     C                     END
     C  N11                END
      *
     C                     ENDSR
      *
     OAKEWP05 E                DT
     O                         IKHIN     12
     O                         WTKR3     18
     O                         WTKRP     24
     O                         WTKRQ     30
