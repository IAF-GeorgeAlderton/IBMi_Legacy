     H            Y.
     F** ABMRA5 *********************************************
     F*内示数異常リスト
     F* FORECAST QTY CHECK LIST                             *
     F*    HOTTA.               2018.08.28                  *
     F*******************************************************
     FABMWPA0 IF  E                    DISK
     FFGBPL01 IF  E           K        DISK
     FABMPRA5 O   E             55     PRINTER
      *
     I            DS
     I                                        1   80W@DATE
     I                                        1   40W@DAYY
     I                                        5   60W@DAMM
     I                                        7   80W@DADD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P@FNAM 30
      *
     C                     TIME           WTIME
      *
     C                     Z-ADDUDATE     @HYMD
     C                     MOVELP@FNAM    @TITL
     C                     SETON                     55
     C                     READ ABMWPA01                 87
     C           *IN87     DOWEQ'0'
     C           *IN55     IFEQ '1'
     C                     WRITEABMPRA51
     C                     SETOF                     55
     C                     ENDIF
     C                     MOVEL*BLANK    W@NONM 16
     C                     SETOF                     23
     C           W0NONY    CHAINFGBPL011             23
     C           *IN23     IFEQ '0'
     C                     MOVELB2SMEI    W@NONM
     C                     ENDIF
     C                     Z-ADD0         W4BOXD
     C           W0SSYS    IFNE 0
     C           W0HIKN    DIV  W0SSYS    W4BOXD  72
     C                     ENDIF
     C           W4BOXD    ADD  0.09      W@BOXD  61
     C                     EXSR #SB001
     C                     READ ABMWPA01                 87
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------*
      * FCEPP01                                          *
      *--------------------------------------------------*
     CSR         #SB001    BEGSR
      *
     C                     MOVELW0TOKU    P2TOKU
     C                     MOVELW0NONY    P2NONY
     C                     MOVELW0NKOJ    P2NKOJ
     C                     MOVELW0NUKE    P2NUKE
     C                     MOVELW0MHN1    P2MHN1
     C                     MOVELW0MHN2    P2MHN2
     C                     MOVELW0MHN3    P2MHN3
     C                     MOVELW0SHN1    P2SHN1
     C                     MOVELW0SHN2    P2SHN2
     C                     MOVELW0SHN3    P2SHN3
     C                     Z-ADDW0SSYS    P2SSYS
     C                     Z-ADDW0GEKN    P2GEKN
     C                     Z-ADDW0FSMN    P2FSMN
     C                     Z-ADDW0FSM1    P2FSM1
     C                     Z-ADDW0USM1    P2USM1
     C                     Z-ADDW0RITU    P2RITU
     C                     WRITEABMPRA52
      *
     CSR         ESB001    ENDSR
