     H            Y.
     F**RGAR90**************************************
     F* (TEMP) SET UP RGAPP12                      *
     F* J.WATANABE    2019.12.19                   *
     F**********************************************
     FRGAPL11 IF  E           K        DISK
     FRGAPP12 UF  E           K        DISK                      A
     I*
     I            DS
     I                                        1  140#SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ************************************************************
      *
     C                     TIME           #SDATE
      *
     C                     DO   *HIVAL
     C                     READ RGAPL11                  98
     C   98                LEAVE
      *
     C                     MOVELJ8PROF    I2      2
     C           J8PROF    CHAINRGAPP12              99
     C           *IN99     IFEQ *OFF
      *
     C           J9DPT     IFEQ '  '
     C           I2        ANDEQ'I3'
     C                     MOVEL'30'      J9DPT
     C                     UPDATRGAPP121
     C                     ENDIF
      *
     C                     ENDIF
      *
     C           *IN99     IFEQ *ON
     C                     CLEARRGAPP121
     C                     MOVELJ8SKJY    J9SKJY
     C                     MOVELJ8PROF    J9PROF
     C                     Z-ADDTODAY     J9CRHZ
     C                     Z-ADDNOW       J9CRTM
     C                     MOVEL#USER     J9CRUS
     C                     MOVEL#PGM      J9CRPG
     C                     WRITERGAPP121
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
