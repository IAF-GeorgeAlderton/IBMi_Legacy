     H            Y.
      ** ALGR40 **************************************
      *ヸ脋�Ġ�橑�硨Ĝ�ʗ�痱✦�▦�鯧�����
      *        LEC          2023.03.06               *
      ************************************************
     FRDBWP41 IF  E           K        DISK
     FRDBWP42 IF  E           K        DISK
     FALGPP01 O   E                    DISK                      A
     FALGPP11 O   E                    DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I            DS
     I                                        1   80CRDT
     I                                        1   40CRYY
     I                                        5   60CRMM
     I                                        7   80CRDD
      *
     I            DS
     I                                        1  14 R5HIN1
     I                                        7  11 R5HIN2
     I                                       13  14 R5HIN3
      *
     I            DS
     I                                        1  25 ABLOT0
     I                                        1   7 ABLOT1
     I                                        8   8 ABLOT2
      *
     I            DS
     I                                        1  11 W1KAN
     I                                        6   8 #LOT#
     I                                        9  10 #PAGE#
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     MOVEL'999'     #LOT#
      *
      * process header records...
     C                     READ RDBWP41                  50
     C           *IN50     DOWEQ*OFF
      *
     C                     CLEARALGPP011
     C                     MOVE R5CRDT    CRDT
     C                     Z-ADDCRYY      A1KOYY
     C                     Z-ADDCRMM      A1KOMM
     C                     Z-ADDCRDD      A1KODD
     C                     MOVE R5CRTM    A1KOTM
      *
     C                     Z-ADDR5TOHZ    CRDT
     C                     Z-ADDCRYY      A1SCYY
     C                     Z-ADDCRMM      A1SCMM
     C                     Z-ADDCRDD      A1SCDD
     C                     Z-ADDR5TOJI    A1SCTM
      *
      * get shift from scan time...
     C                     SELEC
     C           R5TOJI    WHGE 070000
     C           R5TOJI    ANDLE145959
     C                     MOVE '1'       A1SHFT
     C           R5TOJI    WHGE 150000
     C           R5TOJI    ANDLE225959
     C                     MOVE '2'       A1SHFT
     C                     OTHER
     C                     MOVE '3'       A1SHFT
     C                     ENDSL
      *
     C                     Z-ADDCRYY      A1TSQY
     C                     Z-ADDCRMM      A1TSQM
     C                     MOVE R5SYNO    A1TSQ#
      *
     C                     MOVELR5HIN1    A1SHN1
     C                     MOVELR5HIN2    A1SHN2
     C                     MOVELR5HIN3    A1SHN3
      *
     C                     MOVELR5ROBN    A1RONO
     C                     MOVE R5ROBN    A1LINE
     C                     MOVELR5SYOS    A1TMCD
     C                     MOVELW#PGM     A1PGID
     C                     MOVELR5ZASI    A1ZANM
     C                     Z-ADDR5YAJI    A1HOJI
     C                     Z-ADDR5YAMT    A1ONDO
     C                     Z-ADDR5YCO2    A1CO2P
     C                     Z-ADDR5HAJY    A1HKJR
     C                     Z-ADDR5HAKS    A1CONT
     C                     Z-ADDR5SJUR    A1TTLW
      *
      * pull page# from qr barcode...
     C           2         SUBSTR5KABA:14 #PAGE#
     C                     MOVELW1KAN     A1KAN
      *
     C                     WRITEALGPP011
      *
     C                     READ RDBWP41                  50
     C                     ENDDO
      *
      * process detail records...
     C                     READ RDBWP42                  51
     C           *IN51     DOWEQ*OFF
      *
     C                     CLEARALGPP111
     C                     MOVE R6CRDT    CRDT
     C                     Z-ADDCRYY      ABKOYY
     C                     Z-ADDCRMM      ABKOMM
     C                     Z-ADDCRDD      ABKODD
     C                     MOVE R6CRTM    ABKOTM
      *
     C                     Z-ADDR6TOHZ    CRDT
     C                     Z-ADDCRYY      ABSCYY
     C                     Z-ADDCRMM      ABSCMM
     C                     Z-ADDCRDD      ABSCDD
     C                     Z-ADDR6TOJI    ABSCTM
      *
     C                     Z-ADDCRYY      ABTSQY
     C                     Z-ADDCRMM      ABTSQM
     C                     MOVE R6SYNO    ABTSQ#
      *
     C                     MOVELR6ROBN    ABHEAT
     C                     MOVE R6ROBN    ABLINE
     C                     MOVELR6SYOS    ABUSER
     C                     MOVELW#PGM     ABPGID
     C                     MOVELR6LTAG    ABLOT0
      *
     C                     WRITEALGPP111
      *
     C                     READ RDBWP42                  51
     C                     ENDDO
      *
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
