     H            Y.
     F** AKBR10 *********************************
     F* PUBLICATION OF COMPONENTS KANBAN(DAILY) *
     F*   I-HASADA                97.05.02      *
     F********************************* AKBR10 **
     FAKBPP01 UP  E                    DISK
     I            DS
     I                                        1   80L1SKHZ
     I                                        1   40L1SKYY
     I                                        5   60L1SKMM
     I                                        7   80L1SKDD
     I            DS
     I                                        1   80L1STHZ
     I                                        1   40L1STYY
     I                                        5   60L1STMM
     I                                        7   80L1STDD
     I            DS
     I                                        1  12 L1SHIN
     I                                        1   5 L1SHN1
     I                                        6  10 L1SHN2
     I                                       11  12 L1SHN3
      *
     C           *ENTRY    PLIST
     C                     PARM           PUS    10
      *
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    IFLE *DATE
     C                     GOTO END
     C                     END
     C                     END
      *
     C           L1DTKO    IFEQ '2'
     C           L1DTKO    OREQ 'D'
     C                     GOTO END
     C                     END
      *
     C           L1SYOS    IFEQ 0
     C                     GOTO END
     C                     END
      *
     C           L1KOUT    IFNE 'Y'
     C                     GOTO END
     C                     END
      *
     C           L1KMIN    IFEQ L1KMAX
     C                     GOTO END
     C                     END
      *
     C           L1STHZ    IFNE 99999999
     C                     GOTO END
     C                     END
      *
     C                     MOVE L1KMIN    PKMIN   3
     C                     MOVE L1KMAX    PKMAX   3
     C                     MOVE L1SYOS    PSYOS   6
      *
     C                     CALL 'AAPR02'
     C                     PARM           PUS
     C                     PARM           L1KCD1
     C                     PARM           L1SHIN
     C                     PARM           PKMIN
     C                     PARM           PKMAX
     C                     PARM           L1ZETI
     C                     PARM           PSYOS
      *
     C                     MOVE *BLANK    L1KOUT
     C                     MOVE 'Y'       L1DOUT
     C                     MOVE '*'       L1DTHE
     C                     UPDATAKBPP011
      *
     C           END       TAG
