      *** INVRS3 *****************************************************
      *   GET PRIORITY LT
      *
      *     T.SAKASHITA                  2014.08.05
      ****************************************************************
      * PARM( '0111' 'HD' 'R52' 0 0 0)
      ****************************************************************
     H            Y/                                    1
     FINVPPS1 IF  E           K        DISK
     C           *ENTRY    PLIST
     C                     PARM           P@BMON  4
     C                     PARM           P@KOTE  3
     C                     PARM           P@KIBN  3
     C                     PARM           P@DAYS  20
     C                     PARM           P@HOUR  20
     C                     PARM           P@MINS  20
     C                     PARM           P@SHTG  2
      *
     C                     Z-ADD0         P@DAYS
     C                     Z-ADD0         P@HOUR
     C                     Z-ADD0         P@MINS
     C                     MOVE *BLANK    P@SHTG
      *
     C                     MOVE P@BMON    K@BMON
     C                     MOVE P@KOTE    K@KOTE
     C                     MOVE P@KIBN    K@KIBN
     C                     EXSR #INV
     C  N88                EXSR #END
      *
     C                     MOVE P@BMON    K@BMON
     C                     MOVE P@KOTE    K@KOTE
     C                     MOVE *BLANK    K@KIBN
     C                     EXSR #INV
     C  N88                EXSR #END
      *
     C                     MOVE P@BMON    K@BMON
     C                     MOVE *BLANK    K@KOTE
     C                     MOVE *BLANK    K@KIBN
     C                     EXSR #INV
     C  N88                EXSR #END
      *
     C                     EXSR #END
      *-----------------------------------------------------
     C           #INV      BEGSR
      *
     C           INVKEY    KLIST
     C                     KFLD           K@BMON  4
     C                     KFLD           K@KOTE  3
     C                     KFLD           K@KIBN  3
      *
     C           INVKEY    CHAININVPPS1              88
     C           *IN88     IFEQ '0'
     C           M@SKJY    ANDEQ'D'
     C                     SETON                     88
     C                     END
      *
     C           *IN88     IFEQ '0'
     C                     Z-ADDM@DAYS    P@DAYS
     C                     Z-ADDM@HOUR    P@HOUR
     C                     Z-ADDM@MINS    P@MINS
     C                     MOVE M@SHTG    P@SHTG
     C                     END
      *
     C           EINV      ENDSR
      *-----------------------------------------------------
     C           #END      BEGSR
     C                     SETON                     LR
     C                     RETRN
     C                     ENDSR
