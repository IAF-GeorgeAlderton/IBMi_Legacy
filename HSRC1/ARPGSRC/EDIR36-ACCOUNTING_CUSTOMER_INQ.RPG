     C                     WRITEDSP99
     C                     EXFMTCTL01
     C                     SETOF                     71
     C                     MOVEA'0'       *IN,99
     C                     Z-ADD$$RRN     DSPRRN
      *---------*
      * F3: END *
      *---------*
     C           *INKA     IFEQ *ON
     C           *INKC     OREQ *ON
     C           *INKL     OREQ *ON
     C                     MOVE '#END    '@STEP
     C                     GOTO XDSP1
     C                     ENDIF
      *-------------*
      * F5: REFRESH *
      *-------------*
     C           *INKE     IFEQ *ON
