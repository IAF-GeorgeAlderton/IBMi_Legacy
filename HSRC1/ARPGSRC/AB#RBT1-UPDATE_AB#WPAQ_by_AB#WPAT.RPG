     H            Y.
     F**AB#RBT1 ***********************************************
     F* CONVERT AB#WPAS TO AB#WPAS2                           *
     F* J.WATANABE  2021.06.16                                *
     F*------------------------------                         *
     F* * SET SIZE SEQ# (W#LN#)                               *
     F* * SET DATE TOTAL AS W#LV#=11                          *
     F*********************************************************
     FAB#WPAQ UF  E           K        DISK                      A
     FAB#WPAT IF  E           K        DISK
     F************************************************
     E                    SIZ     1  10  3   SRT     2
     E                    DAT        40  8 0
     E                    GQT        40  9 0
     E                    GBX        40  7 0
      *===============
      *  MAIN ROUTINE
      *===============
     C                     EXSR #INIT
      * UPDATE
     C                     EXSR #UPD
      * GEN
     C                     EXSR #GEN
      *
     C                     SETON                     LR
     C                     RETRN
      *************************************************************
      * UPDATE
      *************************************************************
     C           #UPD      BEGSR
      *
     C                     DO   *HIVAL
     C                     READ AB#WPAQ                  98
     C   98                LEAVE
      * SET LINE
     C                     Z-ADD1         IX
     C           W#SIZE    LOKUPSIZ,IX                   97
     C           *IN97     IFEQ *ON
     C                     MOVELSRT,IX    @SRT    20
     C                     ELSE
     C                     Z-ADD99        @SRT
     C                     ENDIF
     C                     Z-ADD@SRT      W#LN#
      * SET DATE
     C                     Z-ADD1         IX
     C           W#DATE    LOKUPDAT,IX                   97
     C           *IN97     IFEQ *ON
     C                     Z-ADDIX        W#DT#
     C                     ELSE
     C                     Z-ADD99        W#DT#
     C                     ENDIF
      * GEN
     C           W#LN#     IFNE 99
     C                     ADD  W#QTY     GQT,IX
     C                     ADD  W#BOX     GBX,IX
     C                     ENDIF
      *
     C                     MOVE *OFF      W#41
     C                     UPDATAB#WPAQ1
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************
      * GENERAL TOTAL
      *************************************************************
     C           #GEN      BEGSR
      *
     C           1         DO   31        IY      20
     C                     Z-ADD11        W#LN#
     C                     Z-ADDIY        W#DT#
     C                     Z-ADDDAT,IY    W#DATE
     C                     Z-ADDGQT,IY    W#QTY
     C                     Z-ADDGBX,IY    W#BOX
     C                     MOVE *ON       W#41
     C                     WRITEAB#WPAQ1
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************
      * INITIALIZE
      *************************************************************
     C           #INIT     BEGSR
     C                     Z-ADD0         IX      20
     C                     Z-ADD0         DAT
      * SET DATE TABLE
     C           *LOVAL    SETLLAB#WPAT
     C           1         DO   40        IX
     C                     READ AB#WPAT                  97
     C   97                LEAVE
      *
     C                     Z-ADDW#DATE    DAT,IX
     C                     ENDDO
      *
     C                     ENDSR
** SRT
NUT01
M8 02
M1003
M6 04
H/V05
TS 06
E/G07
INJ08
PRS09
AK 10
