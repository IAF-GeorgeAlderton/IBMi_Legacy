     FOAAPW21 CF  E                    WORKSTN
     FOAAPL21 UF  E           K        DISK                      A
     FALAPL02 IF  E           K        DISK
     E                    KOCD    1   3  1   KONM    8   UPDATE INSTRUCT
     E                    ER      1  14 60               ERROR MESSAGE
     I            DS
     I                                        1   80R5SKHZ
     I                                        1   40R5SKYY
     I                                        5   60R5SKMM
     I                                        7   80R5SKDD
     I            DS
     I                                        1   80R5KOHZ
     I                                        1   40R5KOYY
     I                                        5   60R5KOMM
     I                                        7   80R5KODD
     I            DS
     I                                        1   60WTIME
     I                                        1   20R5KOHH
     I                                        3   40R5KOSS
     C           *ENTRY    PLIST
     C                     PARM           PARM1  10        USER NAME
     C                     Z-ADD0         R5SKHZ
     C*
     C* fﾞx]-1
     C*
     C           @SCR1     TAG
     C                     EXFMTOAAPW211
     C                     SETOF                     020304
     C                     SETOF                     99
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C*
     C* ﾃcﾆ]hﾎﾞ]
     C*
     C                     MOVE *BLANK    @KONM   8
     C                     SETOF                     20
     C                     Z-ADD1         A       10
     C           @KOSN     LOKUPKOCD,A                   20
     C           *IN20     IFEQ '0'
     C                     SETON                     0299
     C                     MOVELER,01     MSG
     C                     GOTO @SCR1
     C                     END
     C                     MOVELKONM,A    @KONM
     C*
     C* RGﾃｰnﾞ
     C*
     C           @RGCD     IFEQ *BLANK
     C                     SETON                     0399
     C                     MOVELER,02     MSG
     C                     GOTO @SCR1
     C                     END
     C*
     C* nhbﾅgTPX
     C*
     C           @TOK6     IFEQ *BLANK
     C                     SETON                     0499
     C                     MOVELER,08     MSG
     C                     GOTO @SCR1
     C                     END
     C*
     C                     SETOF                     31
     C           @TOK6     CHAINALAPL021             31
     C           *IN31     IFEQ '1'
     C                     SETON                     0499
     C                     MOVELER,09     MSG
     C                     GOTO @SCR1
     C                     END
     C           KEY1      KLIST
     C                     KFLD           @RGCD
     C                     KFLD           @TOK6
     C*
     C* lbf
     C*
     C                     SETOF                     30
     C           KEY1      CHAINOAAPL211             30
     C           @KOSN     IFEQ '2'
     C           *IN30     IFEQ '0'
     C           R5SKJY    IFEQ 'D'
     C           R5SKHZ    ANDLE*DATE
     C                     GOTO @001
     C                     END
     C                     SETON                     020304
     C                     SETON                     99
     C                     MOVELER,03     MSG
     C                     GOTO @SCR1
     C                     END
     C                     END
     C*
     C* s]ﾃc
     C*
     C           @KOSN     IFEQ '1'
     C           *IN30     IFEQ '1'
     C                     SETON                     020304
     C                     SETON                     99
     C                     MOVELER,04     MSG
     C                     GOTO @SCR1
     C                     END
     C           R5SKJY    IFEQ 'D'
     C           R5SKHZ    ANDLE*DATE
     C                     SETON                     020304
     C                     SETON                     99
     C                     MOVELER,05     MSG
     C                     GOTO @SCR1
     C                     END
     C                     END
     C*
     C* nﾒiﾆ
     C*
     C           @KOSN     IFEQ '0'
     C           *IN30     IFEQ '1'
     C                     SETON                     020304
     C                     SETON                     99
     C                     MOVELER,06     MSG
     C                     GOTO @SCR1
     C                     END
     C           R5SKJY    IFEQ 'D'
     C           R5SKHZ    ANDLE*DATE
     C                     SETON                     020304
     C                     SETON                     99
     C                     MOVELER,07     MSG
     C                     GOTO @SCR1
     C                     END
     C                     END
     C           @001      TAG
     C*
     C                     MOVE R5AKI1    @AKI1
     C           @KOSN     IFEQ '2'
     C                     MOVE *BLANK    @AKI1
     C                     END
     C*
     C                     SETON                     70
     C*
     C* fﾞx]-2
     C*
     C           @SCR2     TAG
     C                     EXFMTOAAPW211
     C                     SETOF                     020399
     C           *INKC     IFEQ '1'
     C                     MOVE *BLANK    @KOSN
     C                     MOVE *BLANK    @RGCD
     C                     MOVE *BLANK    @TOK6
     C                     MOVE *BLANK    @AKI1
     C                     SETOF                     70
     C                     GOTO @SCR1
     C                     END
     C*
     C  NKE                GOTO @SCR2
     C*
     C                     MOVE @RGCD     R5RGCD
     C                     MOVE @TOK6     R5TOK6
     C                     MOVE @AKI1     R5AKI1
     C*
     C                     MOVE @KONM     MKOSN
     C                     MOVE @RGCD     MRGCD
     C                     MOVE @TOK6     MTOK6
     C*
     C           @KOSN     IFEQ '0'
     C                     MOVEL'D'       R5SKJY
     C                     Z-ADD*DATE     R5SKHZ
     C                     ELSE
     C                     MOVE *BLANK    R5SKJY
     C                     Z-ADD0         R5SKHZ
     C                     END
     C                     Z-ADD*DATE     R5KOHZ
     C                     TIME           WTIME
     C                     MOVELPARM1     R5KOME
     C           *IN30     IFEQ '0'
     C                     UPDATOAAPL211
     C                     ELSE
     C                     WRITEOAAPL211
     C                     END
     C*
     C                     MOVE *BLANK    @KOSN
     C                     MOVE *BLANK    @RGCD
     C                     MOVE *BLANK    @TOK6
     C                     MOVE *BLANK    @AKI1
     C                     SETOF                     70
     C                     GOTO @SCR1
     C*
**  (KOCD/KONM)
00-CANCEL
11-CHANGE
22-ADD
**  ER
E-01  UPDATE INSTRUCTION IS 0.1.2
E-02  RG CODE ISN'T INPUT
E-03  ADD WAS APPOINTED, BUT M/F EXISTS
E-04  A CHANGE WAS APPOINTED, BUT M/F DOESN'T EXIST
E-05  A CHANGE WAS APPOINTED, BUT M/F IS CANCELLED ALREADY
E-06  A CANCELLATION WAS APPOINTED, BUT M/F DOESN'T EXIST
E-07  A CANCELLATION WAS APPOINTED, BUT M/F IS CANCELLED
E-08  CUSTOMER TPX ISN'T INPUT
E-09  CUSTOMER TPX ISN'T REGISTERED WITH M/F
