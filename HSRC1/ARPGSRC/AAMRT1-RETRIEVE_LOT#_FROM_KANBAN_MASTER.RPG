     H            Y.                                                      DAD000
     F** AAMRT1 **********************************
     F*かんばんマスターから生産ロットをひく    *
     F* T.SAKASHITA 2014.08.04                   *
     F********************************************
     FAAFPL03 IF  E           K        DISK
     FAAHPL03 IF  E           K        DISK
     FABHPL03 IF  E           K        DISK
     FADHPL03 IF  E           K        DISK
     FAAPPL03 IF  E           K        DISK
      *
     I            DS
     I                                        1  100A3UKHB
     I                                        1   80A3UKHZ
     I                                        9  100A3UBIN
     I            DS
     I                                        1  100A3STHB
     I                                        1   80A3STHZ
     I                                        9  100A3SBIN
      *
     I            DS
     I                                        1  100L6UKHB
     I                                        1   80L6UKHZ
     I                                        9  100L6UBIN
     I            DS
     I                                        1  100L6STHB
     I                                        1   80L6STHZ
     I                                        9  100L6SBIN
      *
     I            DS
     I                                        1  100M6UKHB
     I                                        1   80M6UKHZ
     I                                        9  100M6UBIN
     I            DS
     I                                        1  100M6STHB
     I                                        1   80M6STHZ
     I                                        9  100M6SBIN
      *
     I            DS
     I                                        1  100J6UKHB
     I                                        1   80J6UKHZ
     I                                        9  100J6UBIN
     I            DS
     I                                        1  100J6STHB
     I                                        1   80J6STHZ
     I                                        9  100J6SBIN
      *
     I            DS
     I                                        1  100L5UKHB
     I                                        1   80L5UKHZ
     I                                        9  100L5UBIN
     I            DS
     I                                        1  100L5STHB
     I                                        1   80L5STHZ
     I                                        9  100L5SBIN
      *
     I            DS
     I                                        1  100K@DTBN
     I                                        1   80K@DATE
     I                                        9  100K@BIN
      *
     C           *ENTRY    PLIST
     C                     PARM           P@BAN1  1
     C                     PARM           P@BAN2  2
     C                     PARM           P@BAN3  2
     C                     PARM           P@BAN4  1
     C                     PARM           P@DATE  8
     C                     PARM           P@BIN   2
     C                     PARM           P@BARA  30
     C                     PARM           P@SSYS  70
     C                     PARM           P@SSYT  1
      *
     C                     Z-ADD0         P@BARA
     C                     Z-ADD0         P@SSYS  70
     C                     MOVE *BLANK    P@SSYT  1
      *
     C                     Z-ADD0         W@BARA  30
     C                     Z-ADD0         W@SSYS  70
     C                     MOVE *BLANK    W@SSYT  1
      *
     C                     MOVE P@BAN1    K@BAN1
     C                     MOVE P@BAN2    K@BAN2
     C                     MOVE P@BAN3    K@BAN3
     C                     MOVE P@BAN4    K@BAN4
     C                     MOVE P@DATE    K@DATE  80
     C                     MOVE P@BIN     K@BIN   20
      *
     C           BANKEY    KLIST
     C                     KFLD           K@BAN1  1
     C                     KFLD           K@BAN2  2
     C                     KFLD           K@BAN3  2
     C                     KFLD           K@BAN4  1
      *
     C                     EXSR #ABH
     C   77                GOTO @END
     C                     EXSR #ADH
     C   77                GOTO @END
     C                     EXSR #AAF
     C   77                GOTO @END
     C                     EXSR #AAH
     C   77                GOTO @END
     C                     EXSR #AAP
     C   77                GOTO @END
      *
     C                     Z-ADDW@BARA    P@BARA
     C                     Z-ADDW@SSYS    P@SSYS
     C                     MOVE W@SSYT    P@SSYT
      *
     C           @END      TAG
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
     C           #AAF      BEGSR
      *
     C           BANKEY    SETLLAAFPL03
     C                     DO   *HIVAL
     C           BANKEY    READEAAFPL03                  88
     C   88                LEAVE
     C           A3SKJY    IFEQ 'D'
     C                     ITER
     C                     END
      *
     C           K@DTBN    IFGE A3UKHB
     C           K@DTBN    ANDLTA3STHB
     C                     ELSE
     C                     ITER
     C                     END
      *
     C                     Z-ADDA3BARA    P@BARA
     C                     Z-ADDA3SSYS    P@SSYS
     C                     MOVE A3SSYT    P@SSYT
     C                     SETON                     77
      *
     C                     ENDDO
      *
     C           EAAF      ENDSR
      *-----------------------------------------------------
     C           #AAH      BEGSR
      *
     C           BANKEY    SETLLAAHPL03
     C                     DO   *HIVAL
     C           BANKEY    READEAAHPL03                  88
     C   88                LEAVE
     C           L6SKJY    IFEQ 'D'
     C                     ITER
     C                     END
      *
     C           K@DTBN    IFGE L6UKHB
     C           K@DTBN    ANDLTL6STHB
     C                     ELSE
     C                     ITER
     C                     END
      *
     C                     Z-ADDL6LOTO    P@BARA
     C                     Z-ADDL6SYOS    P@SSYS
     C                     MOVE L6SYOT    P@SSYT
     C                     SETON                     77
      *
     C                     ENDDO
      *
     C           EAAH      ENDSR
      *-----------------------------------------------------
     C           #ABH      BEGSR
      *
     C           BANKEY    SETLLABHPL03
     C                     DO   *HIVAL
     C           BANKEY    READEABHPL03                  88
     C   88                LEAVE
     C           M6SKJY    IFEQ 'D'
     C                     ITER
     C                     END
      *
     C           M6STHB    IFEQ 9999999999
     C                     Z-ADDM6LOTK    W@BARA
     C                     Z-ADDM6SYUY    W@SSYS
     C                     MOVE M6HSYU    W@SSYT
     C                     END
      *
     C           K@DTBN    IFGE M6UKHB
     C           K@DTBN    ANDLTM6STHB
     C                     ELSE
     C                     ITER
     C                     END
      *
     C                     Z-ADDM6LOTK    P@BARA
     C                     Z-ADDM6SYUY    P@SSYS
     C                     MOVE M6HSYU    P@SSYT
     C                     SETON                     77
      *
     C                     ENDDO
      *
     C           EABH      ENDSR
      *-----------------------------------------------------
     C           #ADH      BEGSR
      *
     C           BANKEY    SETLLADHPL03
     C                     DO   *HIVAL
     C           BANKEY    READEADHPL03                  88
     C   88                LEAVE
     C           J6SKJY    IFEQ 'D'
     C                     ITER
     C                     END
      *
     C           K@DTBN    IFGE J6UKHB
     C           K@DTBN    ANDLTJ6STHB
     C                     ELSE
     C                     ITER
     C                     END
      *
     C                     Z-ADDJ6LOTO    P@BARA
     C                     Z-ADDJ6SYOS    P@SSYS
     C                     MOVE J6SYOT    P@SSYT
     C                     SETON                     77
      *
     C                     ENDDO
      *
     C           EADH      ENDSR
      *-----------------------------------------------------
     C           #AAP      BEGSR
      *
     C           BANKEY    SETLLAAPPL03
     C                     DO   *HIVAL
     C           BANKEY    READEAAPPL03                  88
     C   88                LEAVE
     C           L5SKJY    IFEQ 'D'
     C                     ITER
     C                     END
      *
     C           K@DTBN    IFGE L5UKHB
     C           K@DTBN    ANDLTL5STHB
     C                     ELSE
     C                     ITER
     C                     END
      *
     C                     Z-ADDL5HKSU    P@BARA
     C           L5HKSU    IFEQ 0
     C                     Z-ADD1         P@BARA
     C                     END
     C                     Z-ADDL5SYOS    P@SSYS
     C                     MOVE L5SYOT    P@SSYT
     C                     SETON                     77
      *
     C                     ENDDO
      *
     C           EAAP      ENDSR
