     FT#TPW12 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN   KSFILE SFREC1
     FT#TWP11 IF  E           K        DISK
      *
     E                    ER      1  20 60
      *
     IINFDS       DS
     I                                    B 378 3790##RRN
     I****************************
     I****************************
     I            DS
     I                                        1  140W@TIME
     I                                        1   20W@HOUR
     I                                        3   40W@MIN
     I                                        5   60W@SEC
     I                                        1   60W@JIKA
     I                                        7  140W@YMD
     I                                        7  100W@YY
     I                                       11  120W@M
     I                                       13  140W@D
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
     C*
     C*
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C*  SFLCLR
     C                     SETON                     72
     C                     WRITESFCTL1
     C                     SETOF                     72
     C                     Z-ADD0         RRN     40
     C                     Z-ADD0         ENDRRN  40
     C                     MOVE *BLANK    @@UMU   1        データ有無
     C*
     C           *HIVAL    SETLLT#TWP111
     C*
     C                     DO   *HIVAL
     C                     READPT#TWP111                 90
     C   90                LEAVE
     C*
     C                     MOVELT2GROP    S1GROP
     C                     Z-ADDT2KSSU    S1KSSU
     C*
     C           T2KSSU    DIV  20        S1KSSD
     C*
     C*
     C*
     C                     ADD  1         RRN
     C                     WRITESFREC1
E1   C                     ENDDO
     C*-------------------------
     C           RRN       IFEQ 0
     C                     MOVE '#END    '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     Z-ADD1         DSPRRN
     C                     ENDIF
     C                     ENDSR
     C*===============================================================
      *画面１*
     C*===============================================================
     C           #DSP1     BEGSR
     C                     SETON                     71
     C                     WRITEDSP01
     C                     EXFMTSFCTL1
     C                     SETOF                     71
     C                     MOVEA'0'       *IN,99
     C                     MOVEL*BLANK    D3MSG
     C                     Z-ADD##RRN     DSPRRN
      *----*
      * F1 *
      *----*
     C           *IN01     IFEQ '1'
     C                     MOVE '#END    '@STEP
     C                     GOTO EDSP1
     C                     ENDIF
     C*
     C                     EXSR #SB600
     C*
     C           EDSP1     ENDSR
     C*****************************************************************
     C*Ｍ実行
     C           #SB600    BEGSR
     C*
     C                     Z-ADD0         @W      40
     C                     Z-ADD0         X       40
     C                     MOVEL*BLANK    SLCT    1
      *
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           X         CHAINSFREC1               88
     C   88                LEAVE
     C*
     C                     SETOF                     30
     C           S1SEL     IFEQ 'M'
     C           S1SEL     OREQ ' '
     C                     ELSE
     C                     MOVELER,4      D3MSG
     C                     SETON                     99
     C                     SETON                     30
     C                     END
     C*
     C           S1SEL     IFEQ 'M'
     C                     ADD  1         @W
     C                     MOVEL*BLANK    S1SEL
     C                     MOVEL'M'       SLCT
     C                     UPDATSFREC1
     C                     LEAVE
     C                     END
     C*
     C                     UPDATSFREC1
     C*
     C                     ENDDO
     C*
     C           @W        IFEQ 0
     C           *IN99     ANDEQ'0'
     C*                    MOVELER,1      D3MSG
     C*                    SETON                     99
     C                     END
     C*
     C           *IN99     IFEQ '1'
     C                     GOTO SB600E
     C                     END
     C*
     C           SLCT      IFEQ 'M'
     C                     EXSR #RUN
     C                     ENDIF
     C*
     C           SB600E    ENDSR
     C*****************************************************************
     C*詳細画面
     C           #RUN      BEGSR
     C*
     C           X         CHAINSFREC1               88
     C           *IN88     IFEQ '0'
     C                     CALL 'T#TR13'
     C                     PARM           S1GROP
     C                     ENDIF
     C*
     C           ERUN      ENDSR
     C*****************************************************************
