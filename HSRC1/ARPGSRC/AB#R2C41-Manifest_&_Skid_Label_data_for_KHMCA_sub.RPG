     H            Y.
     F** AB#R2C4 ************************************************************
     F*  MANIFEST & SKID LABEL DATA FOR KHMCA                               *
     F*                                                                     *
     F* TCHK1 11/20/07 CREATE(COPY FROM AB#R2C1)                            *
     F****************************************** AB#R2C *********************
     FAB#WP2IPIF  E           K        DISK
     E*****************************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I            DS
     I                                        1  51 W@KEY1
     I                                        1   4 P@DELY
     I                                        5  12 P@SHDT
     I                                       13  17 P@DUMY
     I                                       18  21 P@DOCK
     I                                       22  31 P@ORDR
     I                                       32  51 P@FLD1
     C***********************************************************************
     C                     EXSR @INZ
     C                     EXSR @MAIN
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C***********************************************************
     C* @INZ:INITIALIZE WORK AREA
     C***********************************************************
     C           @INZ      BEGSR
     C*
     C           *ENTRY    PLIST
     C                     PARM           P@MXPL  50
     C                     PARM           P@KEY1 51
     C                     PARM           P@PLNO  50
     C*
     C                     MOVELP@KEY1    W@KEY1
     C                     Z-ADD*ZERO     P@PLNO
     C*
     C                     Z-ADD*ZERO     W@CCNT  50
     C                     Z-ADD1         W@PLNO  50
     C*
     C                     ENDSR
     C***********************************************************
     C* @MAIN
     C***********************************************************
     C           @MAIN     BEGSR
     C*
     C           K#KEY1    KLIST
     C                     KFLD           P@DELY
     C                     KFLD           P@SHDT
     C                     KFLD           P@DUMY
     C                     KFLD           P@DOCK
     C                     KFLD           P@ORDR
     C                     KFLD           P@FLD1
     C           K#KEY1    SETLLAB#WP2IP
     C*
     C                     DO   *HIVAL
     C*
     C           K#KEY1    READEAB#WP2IP                 99
     C   99                LEAVE
     C*
     C                     ADD  1         W@CCNT
     C           W@CCNT    IFGT P@MXPL
     C                     Z-ADD1         W@CCNT
     C                     ADD  1         W@PLNO
     C                     END
     C*
     C                     ENDDO
     C*
     C                     Z-ADDW@PLNO    P@PLNO
     C*
     C                     ENDSR
