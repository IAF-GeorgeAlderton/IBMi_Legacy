     C                     TIME           JIKAN   60
     C                     MOVELJIKAN     HHMM    40
     C                     MOVELHHMM      CQTHJI
     C                     MOVE HHMM      CQTHPN
     C                     MOVE DABAN3    WKBAN
     C                     MOVE WKBAN1    CQSBKJ
     C                     MOVE WKBAN2    CQSBRO
     C                     MOVE WKBAN3    CQSBRT
     C                     MOVE WKBAN4    CQSBDN
     C                     Z-ADD1         CQCIC1
     C                     Z-ADD1         CQCIC2
     C                     Z-ADD1         CQCIC3
     C                     MOVE PARM2     CQYMD
     C                     MOVE CQYY      CQNOYY
     C                     MOVE CQMM      CQNOMM
     C                     MOVE CQDD      CQNODD
     C                     MOVE 01        CQNOBB
     C                     MOVE *BLANK    CQKJYN
     C                     MOVE 'G'       CQTHAI
     C                     MOVE 'K'       CQSKKB
     C           DAMAIS    MULT -1        CQHAKO
     C                     MOVE DASYUY    CQSYUY
     C                     MOVE *BLANK    CQSTAN
