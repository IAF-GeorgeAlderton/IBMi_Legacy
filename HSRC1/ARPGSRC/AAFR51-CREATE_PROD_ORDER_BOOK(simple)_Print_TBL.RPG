     C           *IN99     IFEQ '0'
     C                     OPEN AAFPR51
     C                     SETON                     99
     C                     END
     C*
     C                     MOVEL*OFF      *IN61
     C           INHIN3    IFNE *BLANK
     C                     MOVEL*ON       *IN61
     C                     END
      *
TCHK1C                     MOVELINMSG     P@MSG
      *
     C           HINKEY    KLIST
     C                     KFLD           INHIN1
     C                     KFLD           INHIN2
     C                     KFLD           INHIN3
      * parts master
     C           HINKEY    CHAINFCEPL011             11    ﾎﾞﾍ] ﾆﾞﾑctc
     C                     Z-ADD*ZERO     W@HSY   50
     C                     Z-ADD*ZERO     W@HNT   70
     C                     Z-ADD*ZERO     W@HHS   71
     C                     MOVEL*BLANK    WJOKNM 16
      *
     C           *IN11     IFEQ *OFF
      *
     C           A2SYHZ    IFGT *DATE
     C                     Z-ADDA2KSYS    W@HSY
     C                     ELSE
     C                     Z-ADDA2SSYS    W@HSY
     C                     END
     C*
     C                     Z-ADDA2GEKN    W@GEKN  90
     C           HINKEY    CHAINFCEPL11              94
     C           *IN94     IFEQ *OFF
     C           FCCD01    ANDNE*ZERO
     C           FCGK01    DIV  FCCD01    @@QTY   90
     C           @@QTY     MULT 20        W@GEKN
     C                     END
     C*
     C           W@GEKN    DIV  20        W@HNT
     C           W@HNT     DIV  W@HSY     W@HHS     H
     C*
     C           HINKEY    SETGTAAHTL06
     C                     DO   *HIVAL
     C           HINKEY    REDPEAAHTL061                 12
     C   12                LEAVE
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    ANDLE*DATE
     C                     ITER
     C                     END
     C                     SELEC
     C           L6JOK3    WHNE *BLANK
     C                     MOVELL6JOK3    W#JKN
     C           L6JOK2    WHNE *BLANK
     C                     MOVELL6JOK2    W#JKN
     C           L6JOK1    WHNE *BLANK
     C                     MOVELL6JOK1    W#JKN
     C                     ENDSL
     C                     MOVEL'E'       W#JKB
     C           K#AAP     KLIST
     C                     KFLD           W#JKN   2
     C                     KFLD           W#JKB   1
     C           K#AAP     CHAINAAAPL011             13
     C           *IN13     IFEQ '0'
     C           A5SKJY    ANDEQ'D'
     C           A5SKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,13
     C                     END
     C           *IN,13    IFEQ '0'
     C                     MOVELA5JOKM    WJOKNM
     C                     END
     C                     LEAVE
     C                     ENDDO
      *
     C                     END
      * AAUPL01
     C                     Z-ADD0         WOGEK   90
     C                     Z-ADD0         WKOSN   10
     C           HINKEY    CHAINAAUPL011             16
     C           *IN16     IFEQ '0'
     C           J1SKJY    ANDEQ'D'
     C           J1SKHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADDJ1OGEK    WOGEK
     C                     Z-ADDJ1KOSN    WKOSN
     C                     END
      *
     C                     MOVE *BLANK    WHI
     C                     MOVE *BLANK    WKT
     C                     Z-ADD0         WBM
     C                     MOVE *BLANK    WTR
     C                     MOVE *BLANK    WMN
     C                     Z-ADD0         BIN
     C                     MOVE *BLANK    KTI
     C                     MOVE *BLANK    WKJ
     C                     MOVE *BLANK    WKI
     C                     MOVE *BLANK    WKB
     C                     MOVE *BLANK    WBA
     C                     MOVE *BLANK    WCL
      *
     C           HINKEY    CHAINAAMPL111             10
      *
     C           *IN10     IFEQ '0'
     C                     Z-ADD0         A       20
      *
     C           1         DO   15        I       20
     C           CKT,I     IFNE *BLANK
     C                     ADD  1         A
     C                     MOVE CHI,I     WHI,A
     C                     MOVE CKT,I     WKT,A
     C                     Z-ADDCBM,I     WBM,A
     C                     MOVE CTR,I     WTR,A
     C                     MOVE CMN,I     WMN,A
     C                     Z-ADDCIN,I     BIN,A
     C                     MOVE CTI,I     KTI,A
     C                     END
     C                     ENDDO
      *
      * LOOP START
      *
     C           1         DO   12        I
     C           WBM,I     CHAINFGBPL011             20    ﾅbyh uﾇj-
     C  N20      B2SKJY    IFEQ 'D'
     C                     SETON                     20
     C                     END
      *
     C  N20                MOVELB2SMEI    WKJ,I
     C           KIKEY     KLIST
     C                     KFLD           WBM,I
     C                     KFLD           WMN,I
     C           KIKEY     CHAINMFAPL221             21    ﾈlﾍﾞ f]ﾒ uﾇjｰ
     C  N21      M@SKJY    IFEQ 'D'
     C                     SETON                     21
     C                     END
      *
     C  N21                MOVE M@KEIS    WKI,I
     C   21                MOVE *BLANK    M@BUKA
     C                     MOVELWKJ,I     WWWW    2
     C           WWWW      COMP 'F2'                     21
     C  N21      WWWW      COMP 'F3'                     21
     C  N21      WWWW      COMP 'F7'                     21
     C   21                MOVE '('       WK1
     C   21                MOVE ')  '     WK2
     C   21                MOVE '-'       WK3
     C   21                MOVE WKAK      WKJ,I
      *
     C                     MOVE *BLANK    WWKB
     C                     MOVE WKT,I     WWKT
     C                     MOVE WBM,I     WWBM
      *
     C           WBM,I     IFNE 0
     C                     MOVE '-'       WW1
     C                     END
      *
     C           WKT,I     IFEQ *BLANK
     C                     MOVE *BLANK    WWKB
     C                     END
      *
     C                     MOVE WWKB      WKB,I
      *
     C                     MOVE *BLANK    WWBA
      *
     C           WTR,I     IFNE *BLANK
     C                     MOVE '-'       WW2
     C                     MOVE '-'       WW3
     C                     MOVE '-'       WW4
     C                     END
      *
     C                     MOVE WTR,I     BANCHI
     C                     MOVE BAN1      WWBA1
     C                     MOVE BAN2      WWBA2
     C                     MOVE BAN3      WWBA3
     C                     MOVE BAN4      WWBA4
     C                     MOVE WWBA      WBA,I
     C                     MOVEL*BLANK    W#COLR  1
      *
     C                     DO
      *
     C           CKSKJY    IFNE *BLANK
     C                     LEAVE
     C                     END
     C*
     C           KTI,I     IFEQ 'A'
     C           KTI,I     OREQ 'B'
     C                     ELSE
     C                     LEAVE
     C                     END
      *
     C           K#COLR    KLIST
     C                     KFLD           INHIN1
     C                     KFLD           INHIN2
     C                     KFLD           INHIN3
     C                     KFLD           BAN1
     C                     KFLD           BAN2
     C                     KFLD           BAN3
     C                     KFLD           BAN4
      *
     C                     SELEC
     C           KTI,I     WHEQ 'A'
     C*          K#COLR    SETGTABHPL03
     C           K#COLR    SETGTABHTL06
     C                     DO   *HIVAL
     C*          K#COLR    REDPEABHPL03                  94
     C           K#COLR    REDPEABHTL06                  94
     C   94                LEAVE
     C           M6SKJY    IFEQ 'D'
     C           M6SKHZ    ANDLE*DATE
     C                     ITER
     C                     END
     C                     MOVEL*BLANK    W#COLR  1
     C                     SELEC
     C           M6IRO1    WHNE *BLANK
     C                     MOVELM6IRO1    W#COLR
     C           M6IRO2    WHNE *BLANK
     C                     MOVELM6IRO2    W#COLR
     C           M6IRO3    WHNE *BLANK
     C                     MOVELM6IRO3    W#COLR
     C           M6IRO4    WHNE *BLANK
     C                     MOVELM6IRO4    W#COLR
     C                     ENDSL
     C                     LEAVE
     C                     ENDDO
     C           KTI,I     WHEQ 'B'
     C           HINKEY    SETGTADHTL05
     C                     DO   *HIVAL
     C           HINKEY    REDPEADHTL05                  94
     C   94                LEAVE
     C           J6SKJY    IFEQ 'D'
     C           J6SKHZ    ANDLE*DATE
     C                     ITER
     C                     END
     C                     MOVEL*BLANK    W#COLR
     C                     SELEC
     C           J6HIR1    WHNE *BLANK
     C                     MOVELJ6HIR1    W#COLR
     C           J6HIR2    WHNE *BLANK
     C                     MOVELJ6HIR2    W#COLR
     C                     ENDSL
     C                     LEAVE
     C                     ENDDO
     C                     ENDSL
      *
     C                     Z-ADD1         Y       20
     C           W#COLR    LOKUPCMT3,Y                   94
     C   94                MOVELCMT4,Y    WCL,I
      *
     C                     ENDDO
      *
     C                     ENDDO
      *
      * LOOP END
      *
     C                     END
