     C   95                LEAVE
     C           A2GSKD    IFEQ *BLANK
     C           AFSKJY    IFEQ 'D'
     C           AFSKHZ    ANDLE*DATE
     C                     ITER
     C                     END
     C                     END
      *
     C                     SETON                     96
     C                     ADD  1         U
     C                     MOVE *BLANK    @KH1
     C                     MOVE *BLANK    @KH2
     C                     MOVE AFKHN1    @KHN1
     C                     MOVE AFKHN2    @KHN2
     C                     MOVE AFKHN3    @KHN3
     C           AFKHN2    IFNE *BLANK
     C                     MOVE '-'       @KH1
     C                     END
     C           AFKHN3    IFNE *BLANK
     C                     MOVE '-'       @KH2
     C                     END
     C                     MOVE @KHIN     @KH,U
      *
     C                     MOVE AFKOTI    @KT,U
     C                     MOVE AFKBMN    @KB,U
      *
     C           K#KBP     KLIST
     C                     KFLD           AFKHN1
     C                     KFLD           AFKHN2
     C                     KFLD           AFKHN3
     C                     MOVEL*BLANK    BANCHI
     C           K#KBP     CHAINAAMPL111             12
     C           *IN12     IFEQ *OFF
     C                     Z-ADD*ZERO     Z       20
     C                     DO   *HIVAL
     C                     ADD  1         Z
     C           Z         IFGT 15
     C           CTR,Z     OREQ *BLANK
     C                     LEAVE
     C                     END
     C                     MOVELCTR,Z     BANCHI
     C                     ENDDO
     C                     ELSE
     C           K#KBP     SETGTAKBPL07
     C                     DO   *HIVAL
     C           K#KBP     REDPEAKBPL07                  12
     C   12                LEAVE
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    ANDLE*DATE
     C                     ITER
     C                     END
     C                     MOVELL1TKRO    BANCHI
     C                     LEAVE
     C                     ENDDO
     C                     END
     C                     MOVELBAN1      WWBA1
     C                     MOVELBAN2      WWBA2
     C                     MOVELBAN3      WWBA3
     C                     MOVELBAN4      WWBA4
     C                     MOVEL'-'       WW2
     C                     MOVEL'-'       WW3
     C                     MOVEL'-'       WW4
     C                     MOVELWWBA      @KL,U
      *
     C                     ENDDO
