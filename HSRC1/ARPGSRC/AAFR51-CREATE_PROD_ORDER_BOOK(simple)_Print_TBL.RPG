     C*
     C                     EXSR #LIST
     C*
     C           *IN99     IFEQ '1'
     C                     CLOSEAAFPR51
     C                     END
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
      *
      *--------------------------------------------------------------*
      *  Initial set routine                                         *
      *--------------------------------------------------------------*
     C           *INZSR    BEGSR
     C*
     C                     MOVEL*OFF      *IN99
     C*
     C           #USER     CHAINRGAPL111             98
     C           *IN98     IFEQ *ON
     C           J8SKJY    ORNE *BLANK
     C                     MOVEL*BLANK    WUSNM  15
     C                     ELSE
     C                     MOVELJ8NAME    WUSNM
     C                     END
     C*
     C                     ENDSR
      *--------------------------------------------------------------*
      *  Print routine                                               *
      *--------------------------------------------------------------*
     C           #LIST     BEGSR
      *
TCHK1C                     Z-ADD*ZERO     T       30
TCHK1C*
TCHK1C                     DO   *HIVAL
TCHK1C*
TCHK1C                     ADD  1         T
TCHK1C           T         IFGT 94
TCHK1C                     LEAVE
TCHK1C                     END
TCHK1C*
TCHK1C                     MOVELP#,T      IDAT
TCHK1C*
