     C           *ENTRY    PLIST
     C                     PARM           P@MOJI 20         WORD
>    C                     PARM           P@RTN   1
      *
     C                     MOVE *ALL'0'   *IN
     C                     MOVELP@MOJI    D1KENS
     C                     MOVE ' '       P@RTN
      *-------------------*
      * DATA CREATE       *
      *-------------------*
      * @O=W@KENS    EXCEPT 0E 0F
     C                     MOVE *BLANK    W@KENS
     C                     Z-ADD0         X       20
      *--------------------------
S1   C           1         DO   20        Z       20
     C           @1K,Z     IFNE X'0E'
     C           @1K,Z     ANDNEX'0F'
     C                     ADD  1         X
     C                     MOVE @1K,Z     @O,X
     C                     ENDIF
E1   C                     ENDDO
      *
     C                     Z-ADD0         Y1      20
     C           ' '       CHEKRW@KENS    Y1
     C*-----------------------------------
      * SEARCH
     C*-----------------------------------
     C                     DO   *HIVAL
     C                     READ INPUT                    90
     C   90                LEAVE
      *
     C                     EXSR ##SCAN
     C           *IN20     IFEQ *ON
     C                     MOVE '*'       P@RTN
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *-----------------------------------
     C                     SETON                     LR
     C                     RETRN
      *================================================================
      *
      *================================================================
     C           ##SCAN    BEGSR
     C                     SETOF                     20
     C*
S1   C                     SELEC
     C           Y1        WHEQ 1
     C           W@KN01    SCAN $$TEXT                   20
     C           Y1        WHEQ 2
