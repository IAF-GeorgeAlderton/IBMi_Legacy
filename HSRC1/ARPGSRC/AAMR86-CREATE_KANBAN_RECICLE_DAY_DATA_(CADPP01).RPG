     H            Y.
     F** AAMR86 ********************************************
     F*かんばん回転日数データ作成(CADPP01)               *
     F*   MSK.                            2011.02.15       *
     F******************************************************
     FCADPP01 IF  E                    DISK
     FAAMWP80 O   E                    DISK                      A
      *
     I            DS
     I                                        1   80C2SKHZ
     I                                        1   40C2SKYY
     I                                        5   60C2SKMM
     I                                        7   80C2SKDD
      *
     I            DS
     I                                        1   80C2STHZ
     I                                        1   40C2STYY
     I                                        5   60C2STMM
     I                                        7   80C2STDD
      *
     I            DS
     I                                        1   3 C2JBN
     I                                        1   1 C2TKR1
     I                                        2   3 C2TKR2
      *
     I            DS
     I                                        1   3 WKF
     I                                        1   1 WKK1F
     I                                        2   3 WKT1F
      *
     I            DS
     I                                        1   3 WKT
     I                                        1   1 WKK1T
     I                                        2   3 WKT1T
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------*
      *   PLIST                                            *
      *----------------------------------------------------*
      *
     C           *ENTRY    PLIST
     C                     PARM           PBMON   4
     C                     PARM           PKOTE   3
     C                     PARM           PK1F    1
     C                     PARM           PK1T    1
     C                     PARM           PT1F    2
     C                     PARM           PT1T    2
     C                     PARM           POUT    1
     C                     PARM           PCMD    2
      *
     C           #ENTRY    PLIST
     C                     PARM           PARM01  2        LR ﾍｭcﾆg
     C                     PARM           PARM02  90       ﾍajﾒﾇcﾒｭc
     C                     PARM           PARM03  50       ﾆｬcﾑcﾇc
     C                     PARM           PARM04  41       TOTAL L.T
     C                     PARM           PARM05  20       xｮgﾌﾞﾛﾓA
     C                     PARM           PARM06  32       ﾌﾞ[lgibﾇc
     C                     PARM           PARM07  20       zgbﾛﾜｮn
    >C                     PARM           PARM08  40       MAXﾌﾃﾇc
     C                     PARM           PARM09  1        ﾆ]ﾆｫhﾎﾞ]
     C                     PARM           PARM10  20       ﾏｰﾅﾞｰjoﾌﾞ]ﾇc
     C                     PARM           PARM11  50       f]ﾌﾞ]ubﾇc
      *----------------------------------------------------*
      *   KLIST                                            *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     MOVE PBMON     WKBMON  40
     C                     MOVE PK1F      WKK1F   1
     C                     MOVE PK1T      WKK1T   1
     C           PK1T      IFEQ *BLANK
     C                     MOVEL*HIVAL    WKK1T
     C                     ENDIF
     C                     MOVE PT1F      WKT1F   2
     C                     MOVE PT1T      WKT1T   2
     C           PT1T      IFEQ *BLANK
     C                     MOVEL*HIVAL    WKT1T
     C                     ENDIF
      *
     C                     READ CADPP011                 81
     C           *IN81     DOWEQ'0'
     C           C2SKJY    IFEQ 'D'
     C           C2SKHZ    ANDLE*DATE
     C                     ELSE
     C           C2STHZ    IFEQ 99999999
     C                     EXSR #SB400
     C           WKOK      IFEQ '1'
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     READ CADPP011                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------*
      *データ判定                 *
      *-----------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEL'1'       WKOK    1
      *部門
     C           PBMON     IFNE *BLANK
     C           C2BMON    IFNE WKBMON
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C                     ENDIF
      *工程
     C           PKOTE     IFNE *BLANK
     C           C2KTEI    IFNE PKOTE
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C                     ENDIF
      *番地
     C           C2JBN     IFLT WKF
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C           C2JBN     IFGT WKT
     C                     MOVEL'0'       WKOK
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *-----------------------------*
      *データ出力                 *
      *-----------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAAMWP801
     C                     MOVELC2BMON    W0BMON
     C                     MOVELC2SHN1    W0SHN1
     C                     MOVELC2SHN2    W0SHN2
     C                     MOVELC2SHN3    W0SHN3
     C                     MOVELC2KTEI    W0KOTE
     C                     MOVELC2TKR1    W0TKR1
     C                     MOVELC2TKR2    W0TKR2
     C                     MOVELC2TKR3    W0TKR3
     C                     MOVELC2TKR4    W0TKR4
     C           C2KTSU    MULT 20        W0KTSU
     C           C2KSSU    MULT 20        W0KSSU
     C           C2SYOS    IFNE 0
     C           C2KSSU    DIV  C2KSSU    W0KHSU    H
     C                     ENDIF
     C                     Z-ADDC2SYOS    W0SYUY
     C                     Z-ADD0         W0LOTK
     C                     Z-ADD0         W0KJNK
     C                     Z-ADD0         W0SETO
     C                     Z-ADDC2KMAX    W0KMAX
     C                     MOVELC2KCD1    W0KCD1
     C                     MOVELC2KCD2    W0KCD2
      *
     C                     MOVE *BLANK    W0KSN1
     C                     MOVE *BLANK    W0KSN3
     C                     MOVE *BLANK    W0KSN2
     C                     Z-ADD0         W0HITO
     C                     Z-ADD0         W0TYLT
     C                     Z-ADDC2LTIM    W0LTIM
     C                     Z-ADDC2KEIS    W0KEIS
     C                     Z-ADDC2MAXH    W0MAXS
     C                     Z-ADD0         W0CYOU
     C*--------------------------*
     C*  ..かんばん枚数計算..  *
     C*--------------------------*
     C                     MOVE *BLANK    PARM01
     C                     Z-ADDC2KSSU    PARM02
     C                     Z-ADDC2SYOS    PARM03
     C           C2LTIM    ADD  C2LTIN    PARM04
     C                     Z-ADDC2BARA    PARM05
     C                     Z-ADDC2KEIS    PARM06
     C                     Z-ADDC2LOTO    PARM07
     C                     Z-ADDC2MAXH    PARM08
     C                     MOVE C2SKBN    PARM09
     C           C2TANA    IFEQ 0
     C                     MOVE *BLANK    @TANA   2
     C                     ELSE
     C                     MOVE C2TANA    @TANA
     C                     END
     C                     MOVE @TANA     PARM10
     C                     Z-ADD0         PARM11
      *
     C           C2SYOS    IFNE 0
     C                     CALL 'ABCR28'  #ENTRY
     C                     END
     C                     MOVE *BLANK    W0KKEY
     C                     MOVE PARM11    W0SMAX
     C                     MOVE PARM07    W0SLOT
     C                     MOVE *BLANK    W0SJNK
     C                     WRITEAAMWP801
      *
     CSR         ESB500    ENDSR
