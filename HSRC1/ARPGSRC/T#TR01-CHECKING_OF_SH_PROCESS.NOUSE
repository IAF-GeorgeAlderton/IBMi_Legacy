     C                     MOVELD1MHI1    KKMHN1  5
     C                     MOVELD1MHI2    KKMHN2  5
     C                     MOVELD1MHI3    KKMHN3  5
     C                     MOVELD1MHI4    KKMHN4  5
     C                     MOVELD1ODRN    KKODRN 10
