     C                     KFLD           KKNKOJ
     C                     KFLD           KKNUKE
     C                     KFLD           KKMHN1
     C                     KFLD           KKMHN2
     C                     KFLD           KKMHN3
     C                     KFLD           KKMHN4
     C                     KFLD           KKODRN
     C*
     C* SEACH DATA  EKLTNO IS NOT BLANK
     C*
