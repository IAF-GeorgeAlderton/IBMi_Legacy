     H            Y.
     F** ALCR70 *******************************************************
     F* REPLACE SCAN
     F*   KIRI                                               2019.09.16
     F*   LEC  -  DISPLAY OK SCREEN AFTER WRITE TO ALCPP70   2020.01.10
     F*****************************************************************
     FALCPW70 CF  E                    WORKSTN
      *
     FFCETL11 IF  E           K        DISK
     FABHPL07 IF  E           K        DISK
     FADHPL07 IF  E           K        DISK
     FAAFTL06 IF  E           K        DISK
     FAAHTL06 IF  E           K        DISK
     FAAPPL06 IF  E           K        DISK
     FAANPL06 IF  E           K        DISK
     FAKBPL06 IF  E           K        DISK
     FMRHPL25 IF  E           K        DISK
     FALCPP70 O   E                    DISK
      *================================================================
     E                    ER      1  25 60
      *================================================================
      *
      *---------------------------------------------
      *
     I$$BAR       DS
     I                                        1   1 BCTYPE
     I                                        1   3 QRTYPE
     I                                        5   5 QRKDAI
      *MEKI
     I                                        2   5 A@ZETI
     I                                        6   8 A@LOT#
      *PTKANBAN
     I                                       12  12 P@KCD1
      *INTER
     I                                        2   5 #2ZETI
     I                                        6   7 #2BMNA
     I                                        8   8 #2KDAI
     I                                        9  11 #2KOTI
     I                                       12  14 #2HKNO
      *
     I                                        1 256 $$BAR1
     I                                      257 512 $$BAR2
      *
     I                                        1  20 D1SBAR
      *  A-PICS
     I                                        2   5 D1SZET
     I                                        6   8 D1STEH
     I                                        9  10 D1SPAG
      *  INTRA PROC
     I                                        1   1 D1KSNK
     I                                        6   7 D1ATOH
     I                                        8   8 D1ATYP
     I                                        9  11 D1KOTE
     I                                       12  14 D1BPAG
     I                                       15  15 D1CD
      *
      *---------------------------------------------
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I            DS
     I                                        1   80A2TRHZ
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
      *
     I            DS
     I                                        1   80L7SKHZ
     I                                        1   40L7SKYY
     I                                        5   60L7SKMM
     I                                        7   80L7SKDD
      *
     I            DS
     I                                        1   80L7STHZ
     I                                        1   40L7STYY
     I                                        5   60L7STMM
     I                                        7   80L7STDD
      *
     I            DS
     I                                        1   80M1SKHZ
     I                                        1   40M1SKYY
     I                                        5   60M1SKMM
     I                                        7   80M1SKDD
      *
     I            DS
     I                                        1  12 W1SHN
     I                                        1   5 W1SHN1
     I                                        6  10 W1SHN2
     I                                       11  12 W1SHN3
     I            DS
     I                                        1  12 W2SHN
     I                                        1   5 W2SHN1
     I                                        6  10 W2SHN2
     I                                       11  12 W2SHN3
     I*
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTIME6
     I                                        7  140WDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *================================================================
     C           *ENTRY    PLIST
     C                     PARM           POPR    6
     C                     PARM           PITANT 20
     C                     PARM           PISECT  1
      *
      *----------------------------------------------------*
      * MAINLINE                                           *
      *----------------------------------------------------*
     C                     MOVEL'01'      DSPSW   2
     C                     TIME           WTIME
      *
     C           DSPSW     DOUEQ'99'
      *
     C                     SELEC
     C           DSPSW     WHEQ '01'
     C                     EXSR #SB100
     C           DSPSW     WHEQ '02'
     C                     EXSR #SB200
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *
      *================================================================
      * FIRST SCREEN - Display Screen for 1ST KANBAN Entry   *
      *================================================================
     CSR         #SB100    BEGSR
      *
     C                     EXFMTALCPW701
     C                     SETOF                     9931
     C                     MOVEL*BLANKS   D9ERR
      *
      * if any Function Key was hit other than F1, just display
      * screen 1 again.
     C                     SELEC
     C           *IN03     WHEQ '1'
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB100
     C           *IN01     WHEQ '1'
     C           *IN02     OREQ '1'
     C           *IN04     OREQ '1'
     C           *IN05     OREQ '1'
     C           *IN06     OREQ '1'
     C           *IN07     OREQ '1'
     C           *IN08     OREQ '1'
     C           *IN09     OREQ '1'
     C           *IN10     OREQ '1'
     C           *IN11     OREQ '1'
     C           *IN12     OREQ '1'
     C                     GOTO ESB100
     C                     OTHER
     C                     ENDSL
      *
     C           D1BAR     IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D1BAR
     C                     GOTO ESB100
     C                     ENDIF
      *
      * CHECK DIGIT - if check digit is not correct, display
      * error screen.
      *
     C                     MOVELD1BAR     $$BAR
     C                     EXSR ##BAR
     C   99                MOVEL*BLANK    D1BAR
     C   99                GOTO ESB100
      *
     C                     MOVELW$SHN1    W1SHN1  5
     C                     MOVELW$SHN2    W1SHN2  5
     C                     MOVELW$SHN3    W1SHN3  2
     C                     MOVELW$TBN1    W1TBN1  1
     C                     MOVELW$TBN2    W1TBN2  2
     C                     MOVELW$TBN3    W1TBN3  2
     C                     MOVELW$TBN4    W1TBN4  1
     C                     MOVELW$ZETI    W1ZETI  4
     C                     MOVELW$TEHI    W1TEHI  6
     C                     MOVELW$PAGE    W1PAGE  3
     C                     MOVELW$KCD     W1KCD   1
     C                     MOVELW$BAR     W1BAR 256
     C                     MOVELW$QR      W1QR    2
      *
      *
     C                     CALL 'APLR30'
     C                     PARM           W1SHN1  5
     C                     PARM           W1SHN2  5
     C                     PARM           W1SHN3  2
     C                     PARM           D2SHN  14
     C                     MOVEL*BLANK    D2BAR
     C                     MOVEL'02'      DSPSW
      *
     CSR         ESB100    ENDSR
      *------------------------------------------------------*
      * SECOND SCREEN - Display Screen for 2ND KANBAN Entry   *
      *------------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C                     EXFMTALCPW702
     C                     SETOF                     9931
     C                     MOVEL*BLANKS   D9ERR
     C*
      *
      *
      * if any Function Key was hit other than F1, just display
      * screen 2 again.
     C                     SELEC
     C           *IN03     WHEQ '1'
     C                     MOVEL'01'      DSPSW
     C                     MOVEL*BLANK    D1BAR
     C                     GOTO ESB200
     C           *IN01     WHEQ '1'
     C           *IN02     OREQ '1'
     C           *IN04     OREQ '1'
     C           *IN05     OREQ '1'
     C           *IN06     OREQ '1'
     C           *IN07     OREQ '1'
     C           *IN08     OREQ '1'
     C           *IN09     OREQ '1'
     C           *IN10     OREQ '1'
     C           *IN11     OREQ '1'
     C           *IN12     OREQ '1'
     C                     GOTO ESB200
     C                     OTHER
     C                     ENDSL
      *
      * if D2BAR is blank, display error and start over.
     C           D2BAR     IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D2BAR
     C                     GOTO ESB200
     C                     ENDIF
      *
     C                     MOVELD2BAR     $$BAR
     C                     EXSR ##BAR
     C   99                MOVEL*BLANK    D2BAR
     C   99                GOTO ESB200
      *
     C                     MOVELW$SHN1    W2SHN1  5
     C                     MOVELW$SHN2    W2SHN2  5
     C                     MOVELW$SHN3    W2SHN3  2
     C                     MOVELW$TBN1    W2TBN1  1
     C                     MOVELW$TBN2    W2TBN2  2
     C                     MOVELW$TBN3    W2TBN3  2
     C                     MOVELW$TBN4    W2TBN4  1
     C                     MOVELW$ZETI    W2ZETI  4
     C                     MOVELW$TEHI    W2TEHI  6
     C                     MOVELW$PAGE    W2PAGE  3
     C                     MOVELW$KCD     W2KCD   1
     C                     MOVELW$BAR     W2BAR 256
     C                     MOVELW$QR      W2QR    2
      *
      *-----------------------------------
      * check to make sure it's a match.
      *-----------------------------------
1    C           W2ZETI    IFEQ W1ZETI
|    C                     MOVEL'OK'      WKOKNG  2
|    C                     MOVE *BLANKS   ERRCOD  2
|    C                     EXSR #SB500
|    C                     MOVEL*BLANK    D1BAR
|    C                     MOVEL'01'      DSPSW
1    C                     ELSE
|    C** FOR PILOT KANBAN
|2   C           W1SHN     IFEQ W2SHN
||   C                     MOVEL'OK'      WKOKNG  2
||   C                     MOVE *BLANKS   ERRCOD  2
||   C                     EXSR #SB500
||   C                     MOVEL*BLANK    D1BAR
||   C                     MOVEL'01'      DSPSW
||   C*  NG
|2   C                     ELSE
||   C                     MOVEL'NG'      WKOKNG
||   C                     MOVE '05'      ERRCOD
||   C                     EXSR #SB500
||   C                     SETON                     99
||   C                     MOVELER,5      D9ERR
||   C                     EXSR #SB290
|2   C                     ENDIF
|     *
1    C                     ENDIF
      *
     C                     MOVEL*BLANK    D2BAR
      *
     CSR         ESB200    ENDSR
      *================================================================
      *================================================================
     C           ##BAR     BEGSR
     C                     MOVEL*BLANK    W$SHN1  5
     C                     MOVEL*BLANK    W$SHN2  5
     C                     MOVEL*BLANK    W$SHN3  2
     C                     MOVEL*BLANK    W$TBN1  1
     C                     MOVEL*BLANK    W$TBN2  2
     C                     MOVEL*BLANK    W$TBN3  2
     C                     MOVEL*BLANK    W$TBN4  1
     C                     MOVEL*BLANK    W$ZETI  4
     C                     MOVEL*BLANK    W$TEHI  6
     C                     MOVEL*BLANK    W$PAGE  3
     C                     MOVEL*BLANK    W$KCD   1
      **
     C                     MOVEL*BLANK    W$BAR 256
     C                     MOVEL*BLANK    W$QR    2
      *////////////////////////////////////////////////////
S1   C           QRTYPE    IFNE 'B01'                      :NE QRCODE
 1   C           QRTYPE    ANDNE'C01'                      :NE QRCODE
     C                     MOVEL$$BAR     W$BAR
      *                   *
      * CHECK DIGIT - call program to get check digit and compare
      *  to make sure it's correct.
      *
      *  if kanban barcode starts with an "I" then it's a Pass Thru
      *   kanban, so it will be 16 chars instead of 14 like the apics kanban
      *
     C           1         SUBST$$BAR:1   BCID    1
  S3 C           BCID      IFEQ 'I'
     C                     MOVEL$$BAR     PMAREA
     C                     MOVEL'016'     PMBYTE
     C           1         SUBST$$BAR:17  WKCHK   1
     C                     EXSR #SB600
  X3 C                     ELSE
     C                     MOVEL$$BAR     PMAREA
     C                     MOVEL'014'     PMBYTE
     C           1         SUBST$$BAR:15  WKCHK   1
     C                     EXSR #SB600
  E3 C                     ENDIF
      *
      * if check digits don't match, display error, go back to screen2.
  S3 C           WKCHK     IFNE PMCHK
     C                     SETON                     99
     C                     MOVELER,2      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D2BAR
     C                     GOTO E##BAR
  E3 C                     ENDIF
     C*
E1   C                     ENDIF
      *                   *
      *////////////////////////////////////////////////////
      *
      *
      * get part information from PART INFORMATION M/F
      *
     C           QRTYPE    IFEQ 'B01'
     C           QRTYPE    OREQ 'C01'
     C           4         SUBST$$BAR:7   W$ZETI           QR
     C                     ELSE
     C           4         SUBST$$BAR:2   W$ZETI
     C                     ENDIF
      *
     C                     MOVEL'0'       PRTCHK  1
      *
     C           W$ZETI    CHAINFCETL111             21
      *
S1   C           *IN21     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLEWDATE
     C                     SETON                     21
E1   C                     ENDIF
      *
      * part number found and not marked for delete.
S1   C           *IN21     IFEQ '0'
     C                     MOVEL'1'       PRTCHK
     C                     MOVELA2BHB1    W$SHN1
     C                     MOVELA2BHB2    W$SHN2
     C                     MOVELA2BHB3    W$SHN3
     C*
     C                     MOVELA2STRK    X@LOC1  1
     C                     MOVELA2STRT    X@LOC2  2
     C                     MOVELA2STRR    X@LOC3  2
     C                     MOVELA2STRD    X@LOC4  1
     C           A2TRHZ    IFGT WDATE
     C           A2KTRK    ANDNE*BLANK
     C                     MOVELA2KTRK    X@LOC1
     C                     MOVELA2KTRT    X@LOC2
     C                     MOVELA2KTRR    X@LOC3
     C                     MOVELA2KTRD    X@LOC4
     C                     ENDIF
E1   C                     ENDIF
      * PILOT
S1   C           *IN21     IFEQ '1'
|    C           W$ZETI    SETLLMRHPL251
|    C           W$ZETI    READEMRHPL251                 21
|S2  C           *IN21     DOWEQ'0'
||S3 C           EAGSJY    IFEQ 'D'
|||  C           EAGSHZ    ANDLEWDATE
||X3 C                     ELSE
|||  C                     MOVEL'1'       PRTCHK
|||  C                     MOVEL'P'       W$KCD
|||  C                     MOVELEASHN1    W$SHN1
|||  C                     MOVELEASHN2    W$SHN2
|||  C                     MOVELEASHN3    W$SHN3
|||  C           3         SUBST$$BAR:6   W$TEHI  6
|||  C           2         SUBST$$BAR:9   $$PAGE  2
|||  C                     MOVE '000'     W$PAGE
|||  C                     MOVE $$PAGE    W$PAGE
|||  C** PILOT CAN SKIP  KANBAN M/F CHECK
|||  C                     GOTO @@GETC
||E3 C                     ENDIF
||   C           W$ZETI    READEMRHPL251                 21
|E2  C                     ENDDO
E1   C                     ENDIF
      **
      **
     C                     MOVELD1KSNK    #KKSNK
     C                     MOVELD1SZET    #KZETI
     C                     MOVELD1ATOH    #KATOH
     C                     MOVELD1ATYP    #KATYP
     C           D1ATYP    IFEQ 'Y'
     C                     MOVEL'A'       #KATYP
     C                     ENDIF
     C                     MOVELD1KSNK    #KKSNK
     C                     MOVELD1SZET    #KZETJ
     C                     MOVELD1ATOH    #KBCOD
     C                     MOVELD1ATYP    #KKCD1
     C                     MOVELD1KOTE    #KATOK
      **
     C           KEYKAN    KLIST
     C                     KFLD           W$SHN1
     C                     KFLD           W$SHN2
     C                     KFLD           W$SHN3
      *
      *
     C                     MOVELD1KSNK    #KKSNK
     C                     MOVELD1SZET    #KZETI
     C                     MOVELD1ATOH    #KATOH
     C                     MOVELD1ATYP    #KATYP
      * QR
S1   C           QRTYPE    IFEQ 'B01'                      := QR
     C           QRTYPE    OREQ 'C01'                      := QR
     C                     GOTO @@QR
E1   C                     ENDIF
      *///////////////////////////////////
      * CODE 39
      *///////////////////////////////////
      * INTRA PROC
S1   C           BCTYPE    IFGE '0'
     C           BCTYPE    ANDLE'9'
     C                     MOVEL*BLANK    W$TEHI
     C                     MOVELD1BPAG    W$PAGE
     C                     MOVELD1KOTE    W$KOTE  3
     C                     MOVEL#2KDAI    W$KCD
     C                     SELEC
     C           #2KDAI    WHEQ 'A'
     C           #2KDAI    OREQ 'Y'
     C                     EXSR #ABH01
     C           #2KDAI    WHEQ 'B'
     C                     EXSR #ADH01
     C                     ENDSL
X1   C                     ELSE
      * A-PICS
     C           3         SUBST$$BAR:6   W$TEHI
     C           2         SUBST$$BAR:6   W$TEH2  2
     C           2         SUBST$$BAR:9   $$PAGE  2
     C                     MOVE '000'     W$PAGE
     C                     MOVE $$PAGE    W$PAGE
     C                     EXSR #AAF01
E1   C                     ENDIF
      * IMPORT
S1   C           BCTYPE    IFEQ 'I'
     C                     MOVELP@KCD1    W$KCD
     C           4         SUBST$$BAR:13  W$TEHI
     C                     MOVEL*BLANK    W$PAGE
     C                     SELEC
     C           P@KCD1    WHEQ '0'
     C                     EXSR #AAP01
     C           P@KCD1    WHEQ '6'
     C                     EXSR #AAN01
     C           P@KCD1    WHEQ '3'
     C                     EXSR #AKB01
     C                     ENDSL
E1   C                     ENDIF
      *
     C                     GOTO @@GETC
      *///////////////////////////////////
     C           @@QR      TAG
      *///////////////////////////////////
     C**
     C                     MOVEL'QR'      W$QR    2
     C                     MOVEL$$BAR1    @@BARA
     C                     MOVEL$$BAR2    @@BARB
     C                     MOVEL*BLANK    P9BAR  20
     C* CREATE CODE39
     C                     CALL 'UEXR13'
     C                     PARM           @@BARA256
     C                     PARM           @@BARB256
     C                     PARM           P9BAR
     C                     MOVELP9BAR     W$BAR
     C**
     C                     SELEC
      * A-PICS
     C           QRTYPE    WHEQ 'C01'                      := QR
     C                     MOVELQRKDAI    W$KCD
     C           1         SUBST$$BAR:42  W$TBN1           QR
     C           2         SUBST$$BAR:43  W$TBN2           QR
     C           2         SUBST$$BAR:45  W$TBN3           QR
     C           1         SUBST$$BAR:47  W$TBN4           QR
     C           3         SUBST$$BAR:53  $$TEHI  3        QR
     C                     MOVEL$$TEHI    W$TEHI
     C           3         SUBST$$BAR:13  W$PAGE           QR
      * INTRA-PROC
     C           QRKDAI    WHEQ 'A'
     C                     MOVELQRKDAI    W$KCD
     C           1         SUBST$$BAR:53  W$TBN1  1        QR
     C           2         SUBST$$BAR:54  W$TBN2  2        QR
     C           2         SUBST$$BAR:56  W$TBN3  2        QR
     C           1         SUBST$$BAR:58  W$TBN4  1        QR
     C           3         SUBST$$BAR:93  W$PAGE           QR
      * HEAT TREATMENT
     C           QRKDAI    WHEQ 'B'
     C                     MOVELQRKDAI    W$KCD
     C           1         SUBST$$BAR:53  W$TBN1           QR
     C           2         SUBST$$BAR:54  W$TBN2           QR
     C           2         SUBST$$BAR:56  W$TBN3           QR
     C           1         SUBST$$BAR:58  W$TBN4           QR
     C           3         SUBST$$BAR:93  W$PAGE           QR
      * PLATING
     C           QRKDAI    WHEQ 'C'
     C                     MOVEL'@'       W$KCD
     C           1         SUBST$$BAR:42  W$TBN1           QR
     C           2         SUBST$$BAR:43  W$TBN2           QR
     C           2         SUBST$$BAR:45  W$TBN3           QR
     C           1         SUBST$$BAR:47  W$TBN4           QR
     C           3         SUBST$$BAR:53  $$TEHI  3        QR
     C                     MOVEL$$TEHI    W$TEHI
     C           3         SUBST$$BAR:58  W$PAGE           QR
     C                     ENDSL
     C*
     C                     MOVE '1'       PRTCHK
      *
      *///////////////////////////////////
     C           @@GETC    TAG
S1   C           PRTCHK    IFEQ '0'
     C                     SETON                     99
     C                     MOVELER,10     D9ERR
     C                     EXSR #SB290
     C                     GOTO E##BAR
E1   C                     ENDIF
      *
      *-----------------------------------
     C           E##BAR    ENDSR
      *================================================================
      *----------------------------------------------------*
      * ABHPP01
      *----------------------------------------------------*
     CSR         #ABH01    BEGSR
      *
     C           KEYM6     KLIST
     C                     KFLD           #KKSNK  10
     C                     KFLD           #KZETI  4
     C                     KFLD           #KATOH  20
     C                     KFLD           #KATYP  1
      *
     C           KEYM6     SETGTABHPL071
     C           KEYM6     REDPEABHPL071                 87
     C           *IN87     DOWEQ'0'
     C           M6SKJY    IFEQ 'D'
     C           M6SKHZ    ANDLEWDATE
     C                     ELSE
     C***        M6UKHZ    IFLE WDATE
     C***        M6STHZ    ANDGTWDATE
     C           M6AKT1    IFEQ W$KOTE
     C           M6AKT2    OREQ W$KOTE
     C           M6AKT3    OREQ W$KOTE
     C           M6AKT4    OREQ W$KOTE
     C                     MOVELM6JBN1    W$TBN1  1
     C                     MOVELM6JBN2    W$TBN2  2
     C                     MOVELM6JBN3    W$TBN3  2
     C                     MOVELM6JBN4    W$TBN4  1
     C                     LEAVE
     C                     ENDIF
     C***                  ENDIF
     C                     ENDIF
     C           KEYM6     REDPEABHPL071                 87
     C                     ENDDO
      *
      *
      *
     CSR         EABH01    ENDSR
      *----------------------------------------------------*
      * ADHPP01
      *----------------------------------------------------*
     CSR         #ADH01    BEGSR
      *
     C           KEYJ6     KLIST
     C                     KFLD           #KKSNK  10
     C                     KFLD           #KZETJ  40
     C                     KFLD           #KBCOD  2
     C                     KFLD           #KKCD1  1
     C                     KFLD           #KATOK  3
      *
     C           KEYJ6     SETGTADHPL071
     C           KEYJ6     REDPEADHPL071                 87
     C           *IN87     DOWEQ'0'
     C           J6SKJY    IFEQ 'D'
     C           J6SKHZ    ANDLEWDATE
     C                     ELSE
     C***        J6UKHZ    IFLE WDATE
     C***        J6STHZ    ANDGTWDATE
     C                     MOVELJ6ATK1    W$TBN1  1
     C                     MOVELJ6ATK2    W$TBN2  2
     C                     MOVELJ6ATK3    W$TBN3  2
     C                     MOVELJ6ATK4    W$TBN4  1
     C                     LEAVE
     C***                  ENDIF
     C                     ENDIF
     C           KEYJ6     REDPEADHPL071                 87
     C                     ENDDO
      *
     CSR         EADH01    ENDSR
      *----------------------------------------------------*
      * AAFPP01
      *----------------------------------------------------*
     CSR         #AAF01    BEGSR
      *
     C                     SETOF                         83
     C           KEYKAN    SETGTAAFTL061
     C           KEYKAN    REDPEAAFTL061                 83
     C           *IN83     DOWEQ'0'
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLEWDATE
     C                     ELSE
     C***        A3STHZ    IFGT WDATE
     C           W$TEH2    IFEQ '99'
     C           A3ATK1    ANDEQ'1'
     C                     MOVEL'@'       W$KCD
     C                     MOVELA3ATK1    W$TBN1  1
     C                     MOVELA3ATK2    W$TBN2  2
     C                     MOVELA3ATK3    W$TBN3  2
     C                     MOVELA3ATK4    W$TBN4  1
     C                     LEAVE
     C                     ENDIF
     C           W$TEH2    IFNE '99'
     C           A3ATK1    ANDEQ'0'
     C                     MOVEL'C'       W$KCD
     C                     MOVELA3ATK1    W$TBN1  1
     C                     MOVELA3ATK2    W$TBN2  2
     C                     MOVELA3ATK3    W$TBN3  2
     C                     MOVELA3ATK4    W$TBN4  1
     C                     LEAVE
     C                     ENDIF
     C***                  ENDIF
     C                     ENDIF
     C           KEYKAN    REDPEAAFTL061                 83
     C                     ENDDO
      *
      *
     C           *IN83     IFEQ '1'
     C                     SETOF                         83
     C           KEYKAN    SETGTAAHTL061
     C           KEYKAN    REDPEAAHTL061                 83
     C           *IN83     DOWEQ'0'
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    ANDLEWDATE
     C                     ELSE
     C***        L6STHZ    IFGT WDATE
     C                     MOVEL'E'       W$KCD
     C                     MOVELL6ATK1    W$TBN1  1
     C                     MOVELL6ATK2    W$TBN2  2
     C                     MOVELL6ATK3    W$TBN3  2
     C                     MOVELL6ATK4    W$TBN4  1
     C                     LEAVE
     C***                  ENDIF
     C                     ENDIF
     C           KEYKAN    REDPEAAHTL061                 83
     C                     ENDDO
     C                     ENDIF
      *
     CSR         EAAF01    ENDSR
      *----------------------------------------------------*
      * AAPPP01
      *----------------------------------------------------*
     CSR         #AAP01    BEGSR
      *
     C                     SETOF                         83
     C           KEYKAN    SETGTAAPPL061
     C           KEYKAN    REDPEAAPPL061                 83
     C           *IN83     DOWEQ'0'
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    ANDLEWDATE
     C                     ELSE
     C***        L5STHZ    IFGT WDATE
     C                     MOVELL5TKR1    W$TBN1  1
     C                     MOVELL5TKR2    W$TBN2  2
     C                     MOVELL5TKR3    W$TBN3  2
     C                     MOVELL5TKR4    W$TBN4  1
     C                     LEAVE
     C***                  ENDIF
     C                     ENDIF
     C           KEYKAN    REDPEAAPPL061                 83
     C                     ENDDO
      *
     CSR         EAAP01    ENDSR
      *----------------------------------------------------*
      * AANPP01
      *----------------------------------------------------*
     CSR         #AAN01    BEGSR
      *
     C                     SETOF                         83
     C           KEYKAN    SETGTAANPL061
     C           KEYKAN    REDPEAANPL061                 83
     C           *IN83     DOWEQ'0'
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    ANDLEWDATE
     C                     ELSE
     C***        L7STHZ    IFGT WDATE
     C                     MOVELL7TKR1    W$TBN1  1
     C                     MOVELL7TKR2    W$TBN2  2
     C                     MOVELL7TKR3    W$TBN3  2
     C                     MOVELL7TKR4    W$TBN4  1
     C                     LEAVE
     C***                  ENDIF
     C                     ENDIF
     C           KEYKAN    REDPEAANPL061                 83
     C                     ENDDO
      *
     CSR         EAAN01    ENDSR
      *----------------------------------------------------*
      * AKBPP01  PT
      *----------------------------------------------------*
     CSR         #AKB01    BEGSR
      *
     C                     SETOF                         83
     C           W$ZETI    SETGTAKBPL061
     C           W$ZETI    REDPEAKBPL061                 83
     C           *IN83     DOWEQ'0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    ANDLEWDATE
     C                     ELSE
     C***        L1STHZ    IFGT WDATE
     C                     MOVELL1TKR1    W$TBN1  1
     C                     MOVELL1TKR2    W$TBN2  2
     C                     MOVELL1TKR3    W$TBN3  2
     C                     MOVELL1TKR4    W$TBN4  1
     C                     LEAVE
     C***                  ENDIF
     C                     ENDIF
     C           W$ZETI    REDPEAKBPL061                 83
     C                     ENDDO
      *
     CSR         EAKB01    ENDSR
      *----------------------------------------------------*
      * ALCPP70 - REPLACE SACN
      *----------------------------------------------------*
     C           #SB500    BEGSR
      * write to ALCPP70
     C                     TIME           WTIME
     C                     CLEARALCPP701
     C                     Z-ADDWDATE     A7KODT
     C                     Z-ADDWTIME6    A7KOTM
     C                     MOVELW#PGM     A7KOPG
     C                     MOVELPOPR      A7TACD
     C                     MOVELW#USER    A7KOME
      *
     C                     Z-ADDWDATE     A7SCDT           SCAN DATE
     C                     Z-ADDWTIME6    A7SCTM           SCAN TIME
     C                     MOVELWKOKNG    A7HNTE           OK/NG
      *=== 1ST KANBAN ======================================*
     C           W1QR      IFEQ 'QR'
     C                     MOVELW1BAR     A7BCD1           BARCODE 1
     C                     MOVELD1BAR     A7QR1            QR 1
     C                     ELSE
     C                     MOVELD1BAR     A7BCD1           BARCODE 1
     C                     ENDIF
     C                     MOVELD1BAR     A7UPD1           UPD INST1
     C           A7UPD1    IFGE '0'
     C           A7UPD1    ANDLE'9'
     C                     ELSE
     C                     MOVEL*BLANK    A7UPD1           UPD INST1
     C                     ENDIF
     C                     MOVELW1KCD     A7KCD1           KAN KIND
     C                     MOVELW1ZETI    A7ZET1           ABSO #
     C                     MOVELW1TEHI    A7THI1           LOT #
     C                     MOVELW1PAGE    A7PAG1           PAGE #
     C                     MOVELW1SHN1    A7PA11           PART #1
     C                     MOVELW1SHN2    A7PA12           PART #2
     C                     MOVELW1SHN3    A7PA13           PART #3
     C                     MOVELW1TBN1    A7LC11           LOC.1
     C                     MOVELW1TBN2    A7LC12           LOC.2
     C                     MOVELW1TBN3    A7LC13           LOC.3
     C                     MOVELW1TBN4    A7LC14           LOC.4
      *=== 2ND KANBAN ======================================*
     C           W2QR      IFEQ 'QR'
     C                     MOVELW2BAR     A7BCD2           BARCODE 2
     C                     MOVELD2BAR     A7QR2            QR 2
     C                     ELSE
     C                     MOVELD2BAR     A7BCD2           BARCODE 2
     C                     ENDIF
     C                     MOVELD2BAR     A7UPD2           UPD INST2
     C           A7UPD2    IFGE '0'
     C           A7UPD2    ANDLE'9'
     C                     ELSE
     C                     MOVEL*BLANK    A7UPD2           UPD INST2
     C                     ENDIF
     C                     MOVELW2KCD     A7KCD2           KAN KIND
     C                     MOVELW2ZETI    A7ZET2           ABSO #
     C                     MOVELW2TEHI    A7THI2           LOT #
     C                     MOVELW2PAGE    A7PAG2           PAGE #
     C                     MOVELW2SHN1    A7PA21           PART #1
     C                     MOVELW2SHN2    A7PA22           PART #2
     C                     MOVELW2SHN3    A7PA23           PART #3
     C                     MOVELW2TBN1    A7LC21           LOC.1
     C                     MOVELW2TBN2    A7LC22           LOC.2
     C                     MOVELW2TBN3    A7LC23           LOC.3
     C                     MOVELW2TBN4    A7LC24           LOC.4
     C                     WRITEALCPP701
      *
      *  if ok, then display ok screen...
     C           WKOKNG    IFEQ 'OK'
     C                     EXFMTALCPW70G
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      * Call Program to Get Check Digit                    *
      *----------------------------------------------------*
     C           #SB600    BEGSR
      *
     C                     CALL 'ALBRCC'
     C                     PARM           PMAREA100        INPUT DATA
     C                     PARM           PMBYTE  3        LENGTH
     C                     PARM           PMCHK   1        CHECKS DIGITS
     C                     PARM           PMRTCD  1        RETRN CODE
      *
     C                     ENDSR
      *
      *----------------------------------------------------*
      * ERROR SCREEN - Display Error on Screen             *
      *----------------------------------------------------*
     C           #SB290    BEGSR
      *
     C           D9ERR     IFEQ ER,5
      *
     C*  PASSWORD LOCK
     C                     MOVE PISECT    P1PGM
     C                     MOVELD9ERR     P1ERR
     C                     MOVELW#PGM     P1PID
     C                     MOVELPOPR      P1KOME    P
     C                     Z-ADD*ZERO     P1DTTM
     C                     CALL 'AM#R09'
     C                     PARM           P1PGM   20
     C                     PARM           P1ERR  25
     C                     PARM           P1PID  10
     C                     PARM           P1KOME 10
     C                     PARM           P1DTTM 140
     C                     MOVEL*ON       W@ERCK  1
      *
     C                     ELSE
      *
     C                     WRITEALCPW708
     C                     EXFMTALCPW709
      *
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      *----------------------------------------------------*
      *----------------------------------------------------*
      *----------------------------------------------------*
**
INPUT BARCODE/QR.
CHECK DIGIT ERROR.
PARTS MASTER ERROR.

PART DOES NOT MATCH.
FNC KEY ERROR.
DUPLICATE KANBAN.
APICS STOP ALERT.
PT STOP ALERT.
NO KANBAN M/F.
