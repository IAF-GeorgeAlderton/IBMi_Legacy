     I                                        1   80L1KODT
     I                                        1   40L1KOYY
     I                                        5   60L1KOMM
     I                                        7   80L1KODD
     C******************************************************
     C*  MAIN
     C******************************************************
     C                     EXSR @INT
     C*
     C                     EXSR @MAIN
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C******************************************************
     C*  INITIAL
     C******************************************************
     C           @INT      BEGSR
     C*
     C           *ENTRY    PLIST
     C                     PARM           P@PROC  1        PROCESS CODE
     C                     PARM           P@SUPP  4        SUPPLIER
     C                     PARM           P@RTNC  1        RETURN CODE
     C                     MOVEL*BLANK    P@RTNC
     C*
     C                     TIME           W@TIME
     C*
     C           P@PROC    IFEQ '1'
     C                     MOVEL*ON       *IN31
     C                     MOVEL*OFF      *IN32
     C                     ELSE
     C                     MOVEL*OFF      *IN31
     C                     MOVEL*ON       *IN32
     C                     END
     C*
     C                     ENDSR
     C******************************************************
     C*  MAIN
     C******************************************************
     C           @MAIN     BEGSR
     C*
     C                     MOVEL*BLANK    F1@ASJ
     C                     MOVEL*BLANK    F1@OK
     C                     SETOF                     414249
     C*
     C                     DO   *HIVAL
     C*
     C                     EXFMTFMT010
     C   KA                MOVEL'9'       P@RTNC
     C   KA                LEAVE
     C*
     C                     SETOF                     414249
     C                     MOVEL*BLANK    MSG
     C                     EXSR @F1CHK
     C           *IN49     IFEQ *ON
     C                     ITER
     C                     END
     C*
     C           *INKE     IFEQ *ON
     C                     EXSR @UPDF
     C                     MOVELK#SUPP    P@SUPP
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  FMT010 CHECK
     C******************************************************
     C           @F1CHK    BEGSR
     C*
     C                     DO
     C*
     C           F1@ASJ    IFEQ *BLANK
     C           F1@OK     ANDEQ*BLANK
JW1  C           F1@NSC    ANDEQ*BLANK
JW2  C           F1@CHR    ANDEQ*BLANK
JW3  C           F1@POS    ANDEQ*BLANK
JW3  C           F1@TSU    ANDEQ*BLANK
     C                     SETON                     414249
JW1  C                     SETON                     43
JW2  C                     SETON                     44
JW3  C                     SETON                     45
JW3  C                     SETON                     46
     C                     MOVELEMSG,6    MSG
     C                     LEAVE
     C                     ENDIF
      *
     C**JW2      F1@ASJ    IFNE *BLANK
     C**         F1@OK     ANDNE*BLANK
     C**                   SETON                     414249
     C**                   MOVELEMSG,1    MSG
     C**                   LEAVE
     C**                   ENDIF
      *
JW1  C**         F1@ASJ    IFNE *BLANK
 |   C**         F1@NSC    ANDNE*BLANK
 |   C**                   SETON                     414249
 |   C**                   MOVELEMSG,1    MSG
 |   C**                   LEAVE
JW1  C**                   ENDIF
      *
JW1  C**         F1@OK     IFNE *BLANK
 |   C**         F1@NSC    ANDNE*BLANK
 |   C**                   SETON                     414249
 |   C**                   MOVELEMSG,1    MSG
 |   C**                   LEAVE
JW1  C**                   ENDIF
     C*
      * AVOID MULTIPLE SELECTION
     C                     Z-ADD0         SCNT    10
     C           F1@ASJ    IFNE *BLANK
     C                     ADD  1         SCNT
     C                     ENDIF
     C           F1@OK     IFNE *BLANK
     C                     ADD  1         SCNT
     C                     ENDIF
     C           F1@NSC    IFNE *BLANK
     C                     ADD  1         SCNT
     C                     ENDIF
     C           F1@CHR    IFNE *BLANK
     C                     ADD  1         SCNT
     C                     ENDIF
JW3  C           F1@POS    IFNE *BLANK
 .   C                     ADD  1         SCNT
JW3  C                     ENDIF
JW3  C           F1@TSU    IFNE *BLANK
 .   C                     ADD  1         SCNT
JW3  C                     ENDIF
      *
JW1  C           SCNT      IFGT 1
 |   C                     SETON                     414243
 |   C                     SETON                     444549
 |   C                     MOVELEMSG,1    MSG
 |   C                     LEAVE
JW1  C                     ENDIF
      *
JW1  C                     SELEC
 |   C           F1@ASJ    WHNE *BLANK
 |   C                     MOVEL'8990'    K#SUPP  4
 |   C           F1@OK     WHNE *BLANK
 |   C                     MOVEL'4511'    K#SUPP
 |   C           F1@NSC    WHNE *BLANK
 |   C                     MOVEL'4530'    K#SUPP
 |   C           F1@CHR    WHNE *BLANK
 |   C                     MOVEL'4540'    K#SUPP
 |   C           F1@POS    WHNE *BLANK
 |   C                     MOVEL'4550'    K#SUPP
 |   C           F1@TSU    WHNE *BLANK
 |   C                     MOVEL'4560'    K#SUPP
JW1  C                     ENDSL
      *
     C           K#SUPP    CHAINGDLNP111             90
     C           *IN90     IFEQ *ON
     C           L1SKJY    ORNE *BLANK
     C           F1@ASJ    IFNE *BLANK
     C                     MOVEL*ON       *IN41
     C                     ELSE
     C                     MOVEL*ON       *IN42
     C                     END
     C                     MOVEL*ON       *IN49
     C                     MOVELEMSG,2    MSG
     C                     LEAVE
     C                     END
      * ALREADY PROCESSED
     C                     SELEC
     C           P@PROC    WHEQ '1'
     C           L1DATE    IFEQ W@DYMD
     C                     MOVEL*ON       *IN49
     C                     MOVELEMSG,3    MSG
     C                     MOVE '1'       MSG
     C                     LEAVE
     C                     END
      *
     C           P@PROC    WHEQ '2'
     C           L1DATE    IFEQ W@DYMD
     C           L1PC01    IFEQ *BLANK
     C                     MOVEL*ON       *IN49
     C                     MOVELEMSG,4    MSG
     C                     MOVE '1'       MSG
     C                     LEAVE
     C                     END
     C           L1PC02    IFNE *BLANK
     C                     MOVEL*ON       *IN49
     C                     MOVELEMSG,3    MSG
     C                     MOVE '2'       MSG
     C                     LEAVE
     C                     END
     C                     ELSE
     C                     MOVEL*ON       *IN49
     C                     MOVELEMSG,4    MSG
     C                     MOVE '2'       MSG
     C                     LEAVE
     C                     END
      *
     C                     OTHER
     C                     MOVEL*ON       *IN49
     C                     MOVELEMSG,5    MSG
     C                     LEAVE
     C                     ENDSL
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  Update control file
     C******************************************************
     C           @UPDF     BEGSR
     C*
     C           P@PROC    IFEQ '1'
     C                     Z-ADDW@DYMD    L1DATE
     C                     MOVEL'1'       L1PC01
     C                     MOVEL*BLANK    L1PC02
     C                     MOVEL*BLANK    L1PC03
     C                     MOVEL*BLANK    L1PC04
     C                     MOVEL*BLANK    L1PC05
     C                     END
     C           P@PROC    IFEQ '2'
     C                     MOVEL'1'       L1PC02
     C                     END
     C*
     C                     Z-ADDW@DYMD    L1KODT
     C                     Z-ADDW@TH      L1KOHH
     C                     Z-ADDW@TM      L1KOSS
     C                     MOVEL#PGM      L1KOPG
     C                     MOVEL#WSID     L1KOWS
     C                     MOVEL#USER     L1KOUS
     C*
     C                     UPDATGDLNP111
     C*
     C                     ENDSR
