     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1GEKN  90
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     Z-ADD*DATE     W@DATE
     C                     CLEARWYM
     C                     Z-ADD0         W@YM2M  60
     C                     Z-ADD0         W@YM3M  60
     C                     Z-ADD0         W@YM4M  60
     C                     Z-ADD0         W@YM5M  60
     C                     Z-ADD0         W@YM6M  60
     C                     Z-ADD0         W@YM7M  60
      * N-2
     C                     SUB  2         W@DTMM
     C           W@DTMM    IFGT 0
     C                     Z-ADDW@DTYM    W@YM2M
     C                     ELSE
     C                     SUB  1         W@DTYY
     C                     Z-ADD12        W@DTMM
     C                     Z-ADDW@DTYM    W@YM2M
     C                     ENDIF
      * N-3
     C                     SUB  1         W@DTMM
     C           W@DTMM    IFGT 0
     C                     Z-ADDW@DTYM    W@YM3M
     C                     ELSE
     C                     SUB  1         W@DTYY
     C                     Z-ADD12        W@DTMM
     C                     Z-ADDW@DTYM    W@YM3M
     C                     ENDIF
      * N-4
     C                     SUB  1         W@DTMM
     C           W@DTMM    IFGT 0
     C                     Z-ADDW@DTYM    W@YM4M
     C                     ELSE
     C                     SUB  1         W@DTYY
     C                     Z-ADD12        W@DTMM
     C                     Z-ADDW@DTYM    W@YM4M
     C                     ENDIF
      * N-5
     C                     SUB  1         W@DTMM
     C           W@DTMM    IFGT 0
     C                     Z-ADDW@DTYM    W@YM5M
     C                     ELSE
     C                     SUB  1         W@DTYY
     C                     Z-ADD12        W@DTMM
     C                     Z-ADDW@DTYM    W@YM5M
     C                     ENDIF
      * N-6
     C                     SUB  1         W@DTMM
     C           W@DTMM    IFGT 0
     C                     Z-ADDW@DTYM    W@YM6M
     C                     ELSE
     C                     SUB  1         W@DTYY
     C                     Z-ADD12        W@DTMM
     C                     Z-ADDW@DTYM    W@YM6M
     C                     ENDIF
      * N-7
     C                     SUB  1         W@DTMM
     C           W@DTMM    IFGT 0
     C                     Z-ADDW@DTYM    W@YM7M
     C                     ELSE
     C                     SUB  1         W@DTYY
     C                     Z-ADD12        W@DTMM
     C                     Z-ADDW@DTYM    W@YM7M
     C                     ENDIF
      *
     C           KEYAGD    KLIST
     C                     KFLD           WYY     40
     C                     KFLD           WMM     20
     C                     Z-ADD1         X       20
     C                     CLEARKD
     C           X         DOWLE6
     C                     Z-ADDWYM,X     W@DTYM
     C                     Z-ADDW@DTYY    WYY     40
     C                     Z-ADDW@DTMM    WMM     20
     C           KEYAGD    SETLLAGDPL121
     C           KEYAGD    READEAGDPL121                 37
     C           *IN37     DOWEQ'0'
     C           F8HIRU    IFEQ *BLANK
     C                     ADD  0.5       KD,X
     C                     ENDIF
     C           F8YORU    IFEQ *BLANK
     C                     ADD  0.5       KD,X
     C                     ENDIF
     C           KEYAGD    READEAGDPL121                 37
     C                     ENDDO
     C           KEYAGD    SETLLABMPPL11
     C           KEYAGD    READEABMPPL11                 37
     C           *IN37     DOWEQ'0'
     C                     Z-ADDLLKADO    KD,X
     C           KEYAGD    READEABMPPL11                 37
     C                     ENDDO
     C                     ADD  1         X
     C                     ENDDO
      *
     C           P1SHN1    IFEQ *BLANK
     C                     EXSR #SB200
     C                     ELSE
     C                     EXSR #SB201
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           *LOVAL    SETLLFCEPL011
     C                     READ FCEPL011                 20
     C           *IN20     DOWEQ'0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELA2BHB1    B2BHB1  5
     C                     MOVELA2BHB2    B2BHB2  5
     C                     MOVELA2BHB3    B2BHB3  2
     C                     EXSR #SB210
     C                     EXSR #SB211
     C                     EXSR #SB212
     C                     ENDIF
     C                     READ FCEPL011                 20
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB201    BEGSR
      *
     C           KEYFC     KLIST
     C                     KFLD           P1SHN1
     C                     KFLD           P1SHN2
     C                     KFLD           P1SHN3
     C           KEYFC     CHAINFCEPL011             20
     C           *IN20     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELA2BHB1    B2BHB1  5
     C                     MOVELA2BHB2    B2BHB2  5
     C                     MOVELA2BHB3    B2BHB3  2
     C                     Z-ADDP1GEKN    P@KTSU
     C                     Z-ADDP1GEKN    W1KTSU
     C                     EXSR #SB211
     C                     EXSR #SB212
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB201    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB202    BEGSR
      *
     C           KEYFC@    KLIST
     C                     KFLD           DFSHN1
     C                     KFLD           DFSHN2
     C                     KFLD           DFSHN3
     C           KEYFC@    CHAINFCEPL011             20
     C           *IN20     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ELSE
     C           A2BHB1    IFEQ P1SHN1
     C           A2BHB2    ANDEQP1SHN2
     C           A2BHB3    ANDEQP1SHN3
     C                     ELSE
     C                     MOVELA2BHB1    B2BHB1  5
     C                     MOVELA2BHB2    B2BHB2  5
     C                     MOVELA2BHB3    B2BHB3  2
     C                     EXSR #SB210
     C                     EXSR #SB211
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB202    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     MOVEL*DATE     P@DTYM
     C                     Z-ADD0         P@KSSU
     C                     Z-ADD0         P@KTSU
     C                     Z-ADD0         W1KTSU
     C                     CALL 'ABMR49'
     C                     PARM           P@DTYM  60
     C                     PARM           B2BHB1  5
     C                     PARM           B2BHB2  5
     C                     PARM           B2BHB3  2
     C                     PARM           P@KSSU  90
     C                     PARM           P@KTSU  90
     C*
     C           P@KTSU    MULT 20        W1KTSU  90
     C*
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      *実績                                              *
      *----------------------------------------------------*
     CSR         #SB211    BEGSR
      *
     C           KEYMBE    KLIST
     C                     KFLD           WYY     40
     C                     KFLD           B2BHB1
     C                     KFLD           B2BHB2
     C                     KFLD           B2BHB3
     C                     CLEARSR
     C                     Z-ADD1         X       20
     C           X         DOWLE6
     C                     Z-ADDWYM,X     W@DTYM
     C                     Z-ADDW@DTYY    WYY     40
     C                     Z-ADDW@DTMM    WMM     20
     C           KEYMBE    CHAINMBEPL051             36
     C           *IN36     IFEQ '0'
     C                     Z-ADDI6S,WMM   SR,X
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         ESB211    ENDSR
      *----------------------------------------------------*
      * GCQPL31                                            *
      *----------------------------------------------------*
     CSR         #SB212    BEGSR
      *
     C                     Z-ADDSR,1      @0SR2M  90
     C                     Z-ADDSR,2      @0SR3M  90
     C                     Z-ADDSR,3      @0SR4M  90
     C                     Z-ADDSR,4      @0SR5M  90
     C                     Z-ADDSR,5      @0SR6M  90
     C                     Z-ADDSR,6      @0SR7M  90
      *
     C           KEYW      KLIST
     C                     KFLD           P1SHN1
     C                     KFLD           P1SHN2
     C                     KFLD           P1SHN3
      *
     C           KEYW      SETLLGCQPL311
     C           KEYW      READEGCQPL311                 74
     C           *IN74     DOWEQ'0'
     C           DFSKJY    IFEQ 'D'
     C           DFSKHZ    ANDLE*DATE
     C                     ELSE
     C                     CLEARSR
     C                     Z-ADD@0SR2M    SR,1
     C                     Z-ADD@0SR3M    SR,2
     C                     Z-ADD@0SR4M    SR,3
     C                     Z-ADD@0SR5M    SR,4
     C                     Z-ADD@0SR6M    SR,5
     C                     Z-ADD@0SR7M    SR,6
     C                     Z-ADDP1GEKN    P@KTSU
     C                     Z-ADDP1GEKN    W1KTSU
     C                     EXSR #SB400
     C                     ENDIF
     C           KEYW      READEGCQPL311                 74
     C                     ENDDO
      *
     CSR         ESB212    ENDSR
      *----------------------------------------------------*
      * ABMPPK7除外マスター                              *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C           KEYWK     CHAINABMPPK71             20
     C           *IN20     IFEQ '0'
     C           CNSKJY    ANDEQ'D'
     C           CNSKHZ    ANDLE*DATE
     C                     SETON                     20
     C                     ENDIF
      *除外マスターなかったら
     C           *IN20     IFEQ '1'
     C                     EXSR #SB500
     C                     MOVELDFKATA    @FKATA 15
     C                     EXSR #SB410
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      *同じ型を使っている他の品番                        *
      *----------------------------------------------------*
     CSR         #SB410    BEGSR
      *
     C           @FKATA    SETLLGCQTL311
     C           @FKATA    READEGCQTL311                 76
     C           *IN76     DOWEQ'0'
     C           DFSKJY    IFEQ 'D'
     C           DFSKHZ    ANDLE*DATE
     C                     ELSE
     C           DFSHN1    IFEQ P1SHN1
     C           DFSHN2    ANDEQP1SHN2
     C           DFSHN3    ANDEQP1SHN3
     C                     ELSE
     C                     EXSR #SB202
     C                     ENDIF
     C                     ENDIF
     C           @FKATA    READEGCQTL311                 76
     C                     ENDDO
      *検索品番をパラメータの品番に戻すSB212
     C*********            MOVELP1SHN1    B2BHB1  5
     C*********            MOVELP1SHN2    B2BHB2  5
     C*********            MOVELP1SHN3    B2BHB3  2
      *
     CSR         ESB410    ENDSR
      *----------------------------------------------------*
      * GCQPL31                                            *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     MOVELB2BHB     @2BHB  12
     C           KEYWK     KLIST
     C                     KFLD           DFKAT1
     C                     KFLD           DFKAT2
     C           KEYWK     CHAINABMWPK01             22
     C           *IN22     IFEQ '0'
     C****                 ADD  P@KTSU    W0KTSU
     C                     ADD  W1KTSU    W0KTSU
     C                     ADD  SR,1      W0SR2M
     C                     ADD  SR,2      W0SR3M
     C                     ADD  SR,3      W0SR4M
     C                     ADD  SR,4      W0SR5M
     C                     ADD  SR,5      W0SR6M
     C                     ADD  SR,6      W0SR7M
     C                     ADD  1         W0CNT
     C                     UPDATABMWPK01
     C                     ELSE
     C                     CLEARABMWPK01
     C                     MOVELDFKATA    W0KATA
     C                     MOVELDFKAT1    W0KAT1
     C                     MOVELDFKAT2    W0KAT2
     C*****                Z-ADDP@KTSU    W0KTSU
     C                     Z-ADDW1KTSU    W0KTSU
     C                     Z-ADDWYM,1     W0YM2M
     C                     Z-ADDSR,1      W0SR2M
     C                     Z-ADDWYM,2     W0YM3M
     C                     Z-ADDSR,2      W0SR3M
     C                     Z-ADDWYM,3     W0YM4M
     C                     Z-ADDSR,3      W0SR4M
     C                     Z-ADDWYM,4     W0YM5M
     C                     Z-ADDSR,4      W0SR5M
     C                     Z-ADDWYM,5     W0YM6M
     C                     Z-ADDSR,5      W0SR6M
     C                     Z-ADDWYM,6     W0YM7M
     C                     Z-ADDSR,6      W0SR7M
     C                     Z-ADD1         W0CNT
     C                     Z-ADDKD,1      W0KD2M
     C                     Z-ADDKD,2      W0KD3M
     C                     Z-ADDKD,3      W0KD4M
     C                     Z-ADDKD,4      W0KD5M
     C                     Z-ADDKD,5      W0KD6M
     C                     Z-ADDKD,6      W0KD7M
     C                     EXSR #SB501
     C                     Z-ADDKS,1      W0KS2M
     C                     Z-ADDKS,2      W0KS3M
     C                     Z-ADDKS,3      W0KS4M
     C                     Z-ADDKS,4      W0KS5M
     C                     Z-ADDKS,5      W0KS6M
     C                     Z-ADDKS,6      W0KS7M
     C                     EXSR #SB503
     C                     WRITEABMWPK01
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      * ECSPL07                                            *
      *----------------------------------------------------*
     CSR         #SB501    BEGSR
      *
     C           KEYECS    KLIST
     C                     KFLD           DFKAT1
     C                     KFLD           DFKAT2
     C                     KFLD           WYY     40
     C                     KFLD           WMM     20
     C                     Z-ADD1         X       20
     C                     CLEARKS
     C           X         DOWLE6
     C                     Z-ADDWYM,X     W@DTYM
     C                     Z-ADDW@DTYY    WYY     40
     C                     Z-ADDW@DTMM    WMM     20
     C                     EXSR #SB502
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         ESB501    ENDSR
      *----------------------------------------------------*
      * ECSPL07                                            *
      *----------------------------------------------------*
     CSR         #SB502    BEGSR
      *
     C           KEYECS    SETLLECSPL071
     C           KEYECS    READEECSPL071                 37
     C           *IN37     DOWEQ'0'
     C           EQSKJY    IFEQ 'D'
     C           EQSKHZ    ANDLE*DATE
     C                     ELSE
     C                     ADD  EQKOSU    KS,X
     C                     ENDIF
     C           KEYECS    READEECSPL071                 37
     C                     ENDDO
      *
     CSR         ESB502    ENDSR
      *----------------------------------------------------*
      * GCQPL14                                            *
      *----------------------------------------------------*
     CSR         #SB503    BEGSR
      *
     C           KEYGCQ    KLIST
     C                     KFLD           DFKAT1
     C                     KFLD           DFKAT2
      *
     C                     MOVEL'0'       GET     1
     C           KEYGCQ    SETLLGCQPL141
     C           KEYGCQ    READEGCQPL141                 37
     C           *IN37     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           T6SKJY    IFEQ 'D'
     C           T6SKHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADDT6MAIS    W0MAIS
     C                     Z-ADDT6SYOS    W0SYOS
     C                     MOVEL'1'       GET     1
     C                     ENDIF
     C           KEYGCQ    READEGCQPL141                 37
     C                     ENDDO
      *
     CSR         ESB503    ENDSR
