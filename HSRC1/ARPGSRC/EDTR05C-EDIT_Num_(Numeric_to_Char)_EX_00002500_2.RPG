     H            Y.
     F** EDTR05C***********************************************************
     F*  CONVERT NUMERIC : (NUMERIC TO CHARACTER) / EDIT
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'EDTR05C'
     F*                    PARM           $IN     9
     F*                    PARM           $OUT   11
     F*   IN  $IN     9A   SOURCE (NUMERIC)   (EX.  1018 )
     F*   OUT $OUT   11A   TRUE   (CHARACTER) (EX. 1,018 )
     F*
     F*   ** INTEGER       SHOULD BE <= 9 DIGITS
     F*   ** MAX 999,999,999
     F*   ** MIN 0  OR BLANK
     F*   ** SIGN:NO, DECIMAL:NO, COMMA:YES
     F*   ** THIS IS FOR DISPLAYING QTY
     F*   EX BLANK      --> BLANK
     F*   EX 00000      --> __________0
     F*   EX __1000__   --> ______1,000
     F*   EX 99999999   --> 999,999,999
     F*********************************************************************
     I            DS
     I                                        1   90XINT
     I                                        1   30XINT1
     I                                        4   60XINT2
     I                                        7   90XINT3
     I            DS
     I                                        1  11 ZIN
     I                                        1   3 ZIN1
     I                                        4   4 CM1
     I                                        5   7 ZIN2
     I                                        8   8 CM2
     I                                        9  11 ZIN3
     F******************************************************************
     C                     EXSR #INIT
      *
     C           $IN       IFEQ *BLANK
     C                     GOTO ENDP
     C                     ENDIF
      * GET NUMERIC
     C                     MOVEL$IN       $IN1      P
     C                     CALL 'EDTR05'
     C                     PARM           $IN1   17
     C                     PARM           $NUM1  156
     C                     PARM           $RTN1   1
      *
     C           $RTN1     IFNE ' '
     C                     GOTO ENDP
     C                     ENDIF
      *
     C           $NUM1     IFEQ 0
     C                     MOVE '0'       $OUT
     C                     GOTO ENDP
     C                     ENDIF
      *
     C                     Z-ADD$NUM1     XINT
     C                     SELEC
     C           XINT1     WHNE 0
     C                     MOVE ','       CM1
     C                     MOVE ','       CM2
     C                     MOVELXINT2     ZIN2
     C                     MOVELXINT3     ZIN3
     C                     MOVELXINT1     PIN       P
     C                     CALL 'UTLR32D'
     C                     PARM           PIN    30
     C                     PARM           POUT   30
     C                     MOVELPOUT      ZIN1
      *
     C           XINT2     WHNE 0
     C                     MOVE ','       CM2
     C                     MOVELXINT3     ZIN3
     C                     MOVELXINT2     PIN       P
     C                     CALL 'UTLR32D'
     C                     PARM           PIN    30
     C                     PARM           POUT   30
     C                     MOVELPOUT      ZIN2
      *
     C                     OTHER
     C                     MOVELXINT3     PIN       P
     C                     CALL 'UTLR32D'
     C                     PARM           PIN    30
     C                     PARM           POUT   30
     C                     MOVELPOUT      ZIN3
     C                     ENDSL
      *
     C                     MOVELZIN       $OUT
      *
     C           ENDP      TAG
     C                     SETON                     LR
     C                     RETRN
      *==========================================================
      * INITIAL VALUE
      *==========================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $IN     9
     C                     PARM           $OUT   11
      *
     C                     MOVE *BLANK    $OUT
     C                     MOVE ' '       CM1
     C                     MOVE ' '       CM2
      *
     C                     ENDSR
