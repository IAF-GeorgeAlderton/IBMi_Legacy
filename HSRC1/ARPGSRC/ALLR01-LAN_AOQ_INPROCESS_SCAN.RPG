     C                     MOVELERR,4     F99ER1
JW1  C                     MOVE '03'      F2ERR
 "   C                     MOVE '03'      F99ER1
     C                     MOVELERR,7     F99ER2
     C                     LEAVE
     C                     END
     C*
     C* U1026-B1082,U1026-B1083,U1026-B1084
