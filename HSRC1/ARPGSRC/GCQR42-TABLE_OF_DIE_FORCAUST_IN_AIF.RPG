     H            Y.                                                      EER050
     F** GCQR42 ********************************************
     F* TABLE OF DIE FORCAUST IN AIF                       *           > *
     F* MSK.KUNIEDA                      1998.05.20        *
     F******************************************************
     FGCQWL41 IP  F     128            DISK
     FRGAPL11 IF  E           K        DISK
     FECSPL05 IF  E           K        DISK
     FGCQPR42 O   E             55     PRINTER                        UC
     FGCQPR43 O   E             56     PRINTER                        UC
     FGCQPR44 O   E             57     PRINTER                        UC
      *
     E                    HR1         6  6 0
      *
     IGCQWL41 AA
     I                                        1   2 INKAT1L1
     I                                        3   6 INKAT2L1
     I                                        7   7 INKAT3L1
     I                                        8   8 INKAT4L1
     I                                        9  13 INSHN1
     I                                       14  18 INSHN2
     I                                       19  20 INSHN3
     I                                       21  290INSETS
     I                                       30  320INMAIS
     I                                       33  370INSYOS
     *************                           38  421INMSRY
     I                                       43  510INNNNM
     I                                       52  600INN1NM
     I                                       61  690INN2NM
     I                                       70  730INNTYY
     I                                       74  750INNTMM
     I                                       76  900INWOK
     I            DS
     I                                        1  11 @KATA
     I                                        1   2 WKKAT1
     I                                        3   3 WKH1
     I                                        4   7 WKKAT2
     I                                        8   8 WKH2
     I                                        9   9 WKKAT3
     I                                       10  10 WKH3
     I                                       11  11 WKKAT4
      *
     I            DS
     I                                        1   80HYMD8
     I                                        1   40HYY
     I                                        5   60HMM
     I                                        7   80HDD
      *
     I            DS
     I                                        1   60WYM
     I                                        1   40WYY
     I                                        5   60WMM
     I            DS
     I                                        1   60EQHZ
     I                                        1   40EQYOYY
     I                                        5   60EQYOMM
     C           *ENTRY    PLIST
     C                     PARM           USER   10
      *--------------------*
      * KEY LIST           *
      *--------------------*
     C           KATKEY    KLIST
     C                     KFLD           #KAT1   2
     C                     KFLD           #KAT2   4
     C                     KFLD           #KAT3   1
      *-------------------*
      * HEADING           *
      *-------------------*
     C           OPNSW     IFEQ *BLANK
     C                     OPEN GCQPR42
     C                     OPEN GCQPR43
     C                     OPEN GCQPR44
     C                     TIME           @TIME
     C                     MOVE UDATE     @DATE
     C                     Z-ADD*DATE     HYMD8
     C                     EXSR $SB100
      *
     C                     SETOF                       21
     C                     MOVELUSER      @USER
     C           USER      CHAINRGAPL111             21
     C           *IN21     IFEQ '0'
     C                     MOVELJ8NAME    @USER
     C                     END
      *
     C                     Z-ADDINNTMM    @HM1
      *
     C           INNTMM    ADD  1         @HM2
     C           @HM2      IFGE 13
     C                     SUB  12        @HM2
     C                     END
      *
     C           INNTMM    ADD  2         @HM3
     C           @HM3      IFGE 13
     C                     SUB  12        @HM3
     C                     END
      *
     C                     WRITEGCQPR421
     C                     WRITEGCQPR431
     C                     WRITEGCQPR441
      *
     C                     MOVE '1'       OPNSW   1
     C                     END
      *
     C                     ADD  INSETS    WNSETS  90
      *
      *-------------------*
      * DETAILS           *
      *-------------------*
      * NUNBER PRODUCTS IN ADDITION
     C                     ADD  INNNNM    WKNNNM 110
     C                     ADD  INN1NM    WKN1NM 110
     C                     ADD  INN2NM    WKN2NM 110
     C                     ADD  INWOK     KOSU   150
      *
     CL1                   EXSR $SB900
     CL1         KOS       DIV  6         WKKOS   70H
      *
     CL1         KOSU      DIV  10000     SOU     61H
      *
     CL1         SOU       DIV  6         SOUS    61H
      *
     CL1                   Z-ADD0         INMSRY
     CL1         WKKOS     IFNE 0
     CL1         SOUS      DIV  WKKOS     INMSRY  51H
     CL1                   END
     CL1                   MOVE INKAT1    WKKAT1
     CL1                   MOVE INKAT2    WKKAT2
     CL1                   MOVE INKAT3    WKKAT3
     CL1                   MOVE INKAT4    WKKAT4
     CL1                   MOVE '-'       WKH1
     CL1                   MOVE '-'       WKH2
     CL1                   MOVE '-'       WKH3
     CL1                   MOVE WNSETS    @SETSU
     CL1                   MOVE INMAIS    @SMAIS
     CL1                   MOVE INSYOS    @LSYOS
     CL1                   MOVE INMSRY    @7MSRY
     CL1                   MOVE WKNNNM    @1SRYO
     CL1                   MOVE WKN1NM    @2SRYO
     CL1                   MOVE WKN2NM    @3SRYO
      *
     CL1                   Z-ADD0         CHKSU  151
     CL1         @SMAIS    MULT 0.25      CHKSU     H
     CL1         @SMAIS    ADD  CHKSU     OVERS  151
     CL1         @SMAIS    SUB  CHKSU     UNDRS  151
      *
      *-------------------*
      * CALCULATION       *
      *-------------------*
      * NUMBER OF DIE
     CL1                   Z-ADD0         WKKOS1  62
     CL1                   Z-ADD0         WKKOS2  62
     CL1                   Z-ADD0         WKKOS3  62
     CL1                   Z-ADD0         WKMSRY 111
     CL1         INMSRY    MULT 10000     WKMSRY
      *
     CL1         WKMSRY    IFNE *ZERO
     CL1         WKNNNM    DIV  WKMSRY    WKKOS1
     CL1         WKN1NM    DIV  WKMSRY    WKKOS2
     CL1         WKN2NM    DIV  WKMSRY    WKKOS3
     CL1                   END
      * RAISE
     CL1         WKKOS1    ADD  0.09      @1KOSU
     CL1         WKKOS2    ADD  0.09      @2KOSU
     CL1         WKKOS3    ADD  0.09      @3KOSU
      *
      * KANNBAN NUMBER
     CL1                   Z-ADD3         @1MAIS
     CL1                   Z-ADD3         @2MAIS
     CL1                   Z-ADD3         @3MAIS
     CL1                   Z-ADD3         W1MAIS  41
     CL1                   Z-ADD3         W2MAIS  41
     CL1                   Z-ADD3         W3MAIS  41
     CL1         WKKOS1    MULT 4         WKMAS1  51
     CL1         WKKOS2    MULT 4         WKMAS2  51
     CL1         WKKOS3    MULT 4         WKMAS3  51
     CL1         INSYOS    IFNE 0
     CL1         WKMAS1    DIV  INSYOS    W1MAIS
     CL1         WKMAS2    DIV  INSYOS    W2MAIS
     CL1         WKMAS3    DIV  INSYOS    W3MAIS
     CL1                   END
      * RAISE
     CL1         W1MAIS    ADD  0.9       @1MAIS
     CL1         W2MAIS    ADD  0.9       @2MAIS
     CL1         W3MAIS    ADD  0.9       @3MAIS
      *
     CL1         @1MAIS    IFLT 3
     CL1                   Z-ADD3         @1MAIS
     CL1                   END
     CL1         @2MAIS    IFLT 3
     CL1                   Z-ADD3         @2MAIS
     CL1                   END
     CL1         @3MAIS    IFLT 3
     CL1                   Z-ADD3         @3MAIS
     CL1                   END
      *UP/DWON
     CL1                   MOVE *BLANK    @1SIGN
     CL1                   MOVE *BLANK    @2SIGN
     CL1                   MOVE *BLANK    @3SIGN
     CL1                   Z-ADD0         @1UPDN
     CL1                   Z-ADD0         @2UPDN
     CL1                   Z-ADD0         @3UPDN
     CL1                   SETOF                     313233
     CL1         INMAIS    SUB  @1MAIS    @1UPDN       31  31 ON IS MINUS
     CL1         INMAIS    SUB  @2MAIS    @2UPDN       32  32 ON IS MINUS
     CL1         INMAIS    SUB  @3MAIS    @3UPDN       33  33 ON IS MINUS
     CL1         *IN31     IFEQ '1'
     CL1                   MOVE '-'       @1SIGN
     CL1                   END
     CL1         *IN32     IFEQ '1'
     CL1                   MOVE '-'       @2SIGN
     CL1                   END
     CL1         *IN33     IFEQ '1'
     CL1                   MOVE '-'       @3SIGN
     CL1                   END
      *-------------------*
      * DETAILS IS WRITE  *
      *-------------------*
     CL1                   SETON                       99
     CL1         @1MAIS    IFGE OVERS
     CL1         @1MAIS    ORLE UNDRS
     CL1         @2MAIS    ORGE OVERS
     CL1         @2MAIS    ORLE UNDRS
     CL1         @3MAIS    ORGE OVERS
     CL1         @3MAIS    ORLE UNDRS
     CL1                   SETOF                       99
     CL1                   END
      *
     CL1         *IN99     IFEQ '0'
     CL1         INMSRY    IFEQ 0
     CL1                   SETON                       99
     CL1                   END
     CL1                   END
      *
     CL1N99                WRITEGCQPR422
     CL1                   WRITEGCQPR432
     CL1                   WRITEGCQPR442
     CL1                   Z-ADD0         WNSETS
     CL1                   Z-ADD0         WKNNNM
     CL1                   Z-ADD0         WKN1NM
     CL1                   Z-ADD0         WKN2NM
     CL1                   Z-ADD0         KOSU
      *-------------------*
      * OVERFLOW          *
      *-------------------*
     CL1         *IN55     IFEQ '1'
     CL1                   WRITEGCQPR421
     CL1                   SETOF                       55
     CL1                   END
     CL1         *IN56     IFEQ '1'
     CL1                   WRITEGCQPR431
     CL1                   SETOF                       56
     CL1                   END
     CL1         *IN57     IFEQ '1'
     CL1                   WRITEGCQPR441
     CL1                   SETOF                       57
     CL1                   END
      *----------------------------------------------------*
      *   過去半年の期間を求める                         *
      *----------------------------------------------------*
     CSR         $SB100    BEGSR
     C                     Z-ADDHYY       WYY
     C                     Z-ADDHMM       WMM
     C                     MOVE WYM       HR1,6
     C                     Z-ADD6         X       20
     C                     DO   5
     C                     SUB  1         WMM
     C           WMM       IFLE 0
     C                     ADD  12        WMM
     C                     SUB  1         WYY
     C                     END
     C                     SUB  1         X
     C                     MOVE WYM       HR1,X
     C                     END
     CSR         $S100E    ENDSR
      *----------------------------------------------------*
      *   過去半年の個数を求める                         *
      *----------------------------------------------------*
     CSR         $SB900    BEGSR
     C                     Z-ADD*ZERO     KOS     80
     C                     MOVE INKAT1    #KAT1
     C                     MOVE INKAT2    #KAT2
     C                     MOVE INKAT3    #KAT3
      *
     C           KATKEY    SETLLECQPL051
     C                     DO   *HIVAL
     C                     SETOF                     30
     C           KATKEY    READEECQPL051                 30
     C           *IN30     IFEQ '0'
      *
     C           EQSKJY    IFEQ 'D'
     C           EQSKHZ    ANDLE*DATE
     C                     GOTO @END2
     C                     END
      *
     C                     SETOF                     40
     C                     Z-ADD1         J       50
     C           EQHZ      LOKUPHR1,J                    40
     C           *IN40     IFEQ '1'
     C                     ADD  EQKOSU    KOS
     C                     END
     C                     END
      *
     C           @END2     TAG
     C  N30                END
     CSR         $S900E    ENDSR
