     H            Y
     F**************************************************
     F* UNWORKINGDAY ATTENDANCE UNWORKING NIGHT ATTENDANCE KANBAN MAKING SALES /
     F* PRODUCT DEMAND FORECAST HANDLING *
     F**************************************************
     FADAPL30 IF  E           K        DISK
     FADAWP30 O   E                    DISK
     C**************************
     C*  初期値セット        *
     C**************************
     C           *ENTRY    PLIST
     C                     PARM           PARM6   6        *番地
     C                     PARM           PARM7   8        *Ｓ日付
     C                     PARM           PARM8   8        *Ｅ日付
     C                     PARM           PARM9   1        *前夜勤区
     C                     PARM           PARM10  6        *年月
     C                     PARM           PARM11  1        *旬
     C                     PARM           SAKUDT  8        *作成日
     C                     PARM           SAKUNO  2        *作成番号
     C                     MOVE SAKUDT    #SHYMD  80
     C                     MOVE SAKUNO    #SNO    20
     C                     MOVE *BLANK    FRSTSW  1
     C**************************
     C* 合成キー             *
     C**************************
     C           #KEY1     KLIST
     C                     KFLD           #SHYMD
     C                     KFLD           #SNO
      *
     C                     SETOF                       81
     C           #KEY1     SETLLADAPL301
     C                     DO   *HIVAL
     C           #KEY1     READEADAPL301                 81
     C           *IN81     IFEQ '0'
     C           DBSKJY    ANDEQ*BLANK
     C           FRSTSW    IFEQ *BLANK
     C                     MOVELDBTKRO    PARM6   6        *番地
     C                     MOVELDBKAHZ    PARM7   8        *Ｓ日付
     C                     MOVELDBSRHZ    PARM8   8        *Ｅ日付
     C                     MOVELDBMYKB    PARM9   1        *前夜勤区
     C                     MOVELDBNAYM    PARM10  6        *年月
     C                     MOVELDBNAJN    PARM11  1        *旬
     C                     MOVE '1'       FRSTSW
     C                     END
     C                     MOVEL*BLANK    DASKJY
     C                     MOVEL*ZERO     DASKYY
     C                     MOVEL*ZERO     DASKMM
     C                     MOVEL*ZERO     DASKDD
     C                     MOVEL*ZERO     DAKOYY
     C                     MOVEL*ZERO     DAKOMM
     C                     MOVEL*ZERO     DAKODD
     C                     MOVEL*ZERO     DAKOHH
     C                     MOVEL*ZERO     DAKOSS
     C                     MOVEL*ZERO     DAKOME
     C                     MOVELDBNONU    DANONU
     C                     MOVELDBKOJO    DAKOJO
     C                     MOVELDBUKEI    DAUKEI
     C                     MOVELDBBIN     DABIN
     C                     MOVELDBNIS     DANIS
     C                     WRITEADAWP301
     C                     END
     C  N81                END
      *
      *===  終了処理 ===*
     C   81                SETON                       LR
     CLR                   RETRN
