     H            Y/
     F***************************************************
     F*  COMPARISON OF NEW PRICES WITH THE CURRENT      *
     F*                                                 *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FGBFPW94 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FGBFPL51 IF  E           K        DISK
     FFBCPL05 IF  E           K        DISK
     FGBFWP90 IF  E           K        DISK
      *------------------------------------------------------------
     E                    CMD     1   3 78
     E                    ORD        10  6 0             ORDER #
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'00'      #SCRN0
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C           W@ID      CASEQ'03'      #SCRN3
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#KEY     KLIST
     C                     KFLD           D@CUST
     C                     KFLD           D@FACT
      *
     C           K#FBC1    KLIST
     C                     KFLD           D@CUST
     C                     KFLD           G9MHN1
     C                     KFLD           G9MHN2
     C                     KFLD           G9MHN3
     C           K#FBC2    KLIST
     C                     KFLD           D@CUST
     C                     KFLD           G9MHN1
     C                     KFLD           G9MHN2
      *
     C           K#GBF     KLIST
     C                     KFLD           D@CUST
     C                     KFLD           D@FACT
     C                     KFLD           S@PRT1
     C                     KFLD           S@PRT2
     C                     KFLD           S@PRT3
      *
     C                     MOVEL'00'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #SCRN0    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP00
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK0
     C           *IN99     IFEQ *OFF
     C                     MOVEL'01'      W@ID
     C                     EXSR #CAL
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK0     BEGSR
      *
     C                     EXSR #CLR
     C           K#KEY     CHAINGBFPL51              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ENDIF
      *
     C           D@OPTN    IFNE *BLANK
     C           D@OPTN    ANDNE'1'
     C                     SETON                     6299
     C                     ENDIF
      *
     C           D@OPTN    COMP '1'                      09
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR NEXT SCREEN
      *------------------------------------------------------
     C           #CAL      BEGSR
      *
     C                     Z-ADD*ZERO     D@NEWP
     C                     Z-ADD*ZERO     D@CURP
     C           K#KEY     SETLLGBFPL51
     C           *IN80     DOUEQ*ON
     C           K#KEY     READEGBFPL51                  80
     C           *IN80     IFEQ *OFF
     C           G9SKJY    ANDEQ*BLANK
     C           K#FBC1    CHAINGBFWP90              95
     C   95      K#FBC2    CHAINGBFWP90              95
     C           *IN95     IFEQ *ON
     C                     ITER
     C                     ENDIF
      *
     C           *IN09     IFEQ *ON
     C           G9KTNK    ANDNE*ZERO
     C                     ITER
     C                     ENDIF
      *
     C           GBNQTY    MULT G9MTAN    @@AMT  134
     C                     ADD  @@AMT     D@NEWP
      *
     C                     Z-ADD*ZERO     @@UPR
     C           K#FBC1    SETLLFBCPL05
     C           *IN90     DOUEQ*ON
     C           K#FBC1    READEFBCPL05                  90
     C           *IN90     IFEQ *OFF
     C           FBSKJY    ANDEQ*BLANK
     C           FBTSHZ    ANDGT*DATE
     C           FBTKHZ    ANDLE*DATE
     C           @@UPR     IFEQ *ZERO
     C                     Z-ADDFBNTAN    @@UPR
     C                     ELSE
     C           FBNTAN    IFLT @@UPR
     C                     Z-ADDFBNTAN    @@UPR
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           @@UPR     IFEQ *ZERO
     C           K#FBC2    SETLLFBCPL05
     C           *IN90     DOUEQ*ON
     C           K#FBC2    READEFBCPL05                  90
     C           *IN90     IFEQ *OFF
     C           FBSKJY    ANDEQ*BLANK
     C           FBTSHZ    ANDGT*DATE
     C           FBTKHZ    ANDLE*DATE
     C           @@UPR     IFEQ *ZERO
     C                     Z-ADDFBNTAN    @@UPR   74
     C                     ELSE
     C           FBNTAN    IFLT @@UPR
     C                     Z-ADDFBNTAN    @@UPR
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C           GBNQTY    MULT @@UPR     @@AMT
     C                     ADD  @@AMT     D@CURP
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           D@CURP    SUB  D@NEWP    @@BAL  134
     C           D@CURP    IFNE *ZERO
     C           @@BAL     DIV  D@CURP    @@PCN   64H
     C           @@PCN     MULT 100       D@PCNT
     C                     ELSE
     C                     Z-ADD*ZERO     D@PCNT
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'00'      W@ID
      *
     C           *INKE     WHEQ *ON
     C                     EXSR #SET1
     C                     MOVEL'02'      W@ID
      *
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR 2ND SCREEN
      *------------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
      *
     C           K#KEY     SETLLGBFPL51
     C           *IN80     DOUEQ*ON
     C           K#KEY     READEGBFPL51                  80
     C           *IN80     IFEQ *OFF
     C           G9SKJY    ANDEQ*BLANK
     C           G9SRYO    ANDNE*ZERO
      *
     C           K#FBC1    CHAINGBFWP90              95
     C   95      K#FBC2    CHAINGBFWP90              95
     C           *IN95     IFEQ *ON
     C                     ITER
     C                     ENDIF
      *
     C           *IN09     IFEQ *ON
     C           G9KTNK    ANDNE*ZERO
     C                     ITER
     C                     ENDIF
      *
     C                     CLEARSFL01
     C                     MOVE G9MHN1    S@PRT1
     C                     MOVE G9MHN2    S@PRT2
     C                     MOVE G9MHN3    S@PRT3
     C                     Z-ADDG9MTAN    S@NEWP
     C                     Z-ADDG9SRYO    S@NQTY
      *
     C           K#FBC1    SETLLFBCPL05
     C           *IN90     DOUEQ*ON
     C           K#FBC1    READEFBCPL05                  90
     C           *IN90     IFEQ *OFF
     C           FBSKJY    ANDEQ*BLANK
     C           FBTSHZ    ANDGT*DATE
     C           FBTKHZ    ANDLE*DATE
     C           S@CURP    IFEQ *ZERO
     C                     Z-ADDFBNTAN    S@CURP
     C                     ELSE
     C           FBNTAN    IFLT S@CURP
     C                     Z-ADDFBNTAN    S@CURP
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           S@CURP    IFEQ *ZERO
     C           K#FBC2    SETLLFBCPL05
     C           *IN90     DOUEQ*ON
     C           K#FBC2    READEFBCPL05                  90
     C           *IN90     IFEQ *OFF
     C           FBSKJY    ANDEQ*BLANK
     C           FBTSHZ    ANDGT*DATE
     C           FBTKHZ    ANDLE*DATE
     C           S@CURP    IFEQ *ZERO
     C                     Z-ADDFBNTAN    S@CURP
     C                     ELSE
     C           FBNTAN    IFLT S@CURP
     C                     Z-ADDFBNTAN    S@CURP
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C           S@CURP    SUB  S@NEWP    S@BALP
     C           S@CURP    IFNE *ZERO
     C           S@BALP    DIV  S@CURP    @@PCN   64H
     C           @@PCN     MULT 100       S@PCNT
     C                     ENDIF
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD1         #RCNO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   3RD SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVELCMD,3     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCNO
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK2
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     Z-ADD*ZERO     WRRN    40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           S@SLCT    ANDNE*BLANK
     C                     EXSR #SET2
     C                     MOVE '03'      W@ID
     C                     MOVE *BLANK    S@SLCT
     C                     UPDATSFL01
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SET DETAIIL
      *------------------------------------------------------
     C           #SET2     BEGSR
      *
     C                     MOVE S@PRT1    D@PRT1
     C                     MOVE S@PRT2    D@PRT2
     C                     MOVE S@PRT3    D@PRT3
      *
     C           K#GBF     CHAINGBFPL51              90
     C           *IN90     IFEQ *OFF
     C           G9SKJY    ANDEQ*BLANK
      *
     C                     Z-ADDG9SRYO    D@NQTY
     C                     Z-ADDG9MTAN    D@NUPR
     C                     MOVE G9KKO1    D@PR01
     C                     MOVE G9KKO2    D@PR02
     C                     MOVE G9KKO3    D@PR03
     C                     MOVE G9KKO4    D@PR04
     C                     MOVE G9KKO5    D@PR05
     C                     MOVE G9KKO6    D@PR06
     C                     MOVE G9KKO7    D@PR07
     C                     MOVE G9KKO8    D@PR08
     C                     MOVE G9KKO9    D@PR09
     C                     MOVE G9KO10    D@PR10
     C                     Z-ADDG9GEN1    D@PC01
     C                     Z-ADDG9GEN2    D@PC02
     C                     Z-ADDG9GEN3    D@PC03
     C                     Z-ADDG9GEN4    D@PC04
     C                     Z-ADDG9GEN5    D@PC05
     C                     Z-ADDG9GEN6    D@PC06
     C                     Z-ADDG9GEN7    D@PC07
     C                     Z-ADDG9GEN8    D@PC08
     C                     Z-ADDG9GEN9    D@PC09
     C                     Z-ADDG9GN10    D@PC10
     C                     Z-ADDG9KAKH    D@PTOT
     C                     MOVELG9ZCOD    D@MATC
     C                     Z-ADDG9SZIJ    D@MWIN
     C                     Z-ADDG9SZAJ    D@MWBL
     C                     Z-ADDG9KANJ    D@MWOT
     C                     Z-ADDG9KAIS    D@MYLD
     C                     Z-ADDG9SZIH    D@MUPR
     C                     Z-ADDG9ZAIH    D@MCST
     C                     MOVE G9KN11    D@CP11
     C                     MOVE G9KN12    D@CP12
     C                     MOVE G9KN13    D@CP13
     C                     MOVE G9KN21    D@CP21
     C                     MOVE G9KN22    D@CP22
     C                     MOVE G9KN23    D@CP23
     C                     MOVE G9KN31    D@CP31
     C                     MOVE G9KN32    D@CP32
     C                     MOVE G9KN33    D@CP33
     C                     MOVE G9KN41    D@CP41
     C                     MOVE G9KN42    D@CP42
     C                     MOVE G9KN43    D@CP43
     C                     MOVE G9KN51    D@CP51
     C                     MOVE G9KN52    D@CP52
     C                     MOVE G9KN53    D@CP53
     C                     Z-ADDG9SYO1    D@CPU1
     C                     Z-ADDG9SYO2    D@CPU2
     C                     Z-ADDG9SYO3    D@CPU3
     C                     Z-ADDG9SYO4    D@CPU4
     C                     Z-ADDG9SYO5    D@CPU5
     C                     Z-ADDG9TNK1    D@CPC1
     C                     Z-ADDG9TNK2    D@CPC2
     C                     Z-ADDG9TNK3    D@CPC3
     C                     Z-ADDG9TNK4    D@CPC4
     C                     Z-ADDG9TNK5    D@CPC5
     C                     Z-ADDG9KOUH    D@CPTT
     C                     MOVELG9SME1    D@SRF1
     C                     MOVELG9SME2    D@SRF2
     C                     MOVELG9SME3    D@SRF3
     C                     Z-ADDG9MMTN    D@SRCT
     C                     Z-ADDG9KTNK    D@PRCH
     C                     Z-ADDG9SGEN    D@CTOT
     C                     Z-ADDG9KANR    D@MGRT
     C                     Z-ADDG9KNRH    D@SGA
     C                     Z-ADDG9CHOU    D@PCKG
     C                     Z-ADDG9REKR    D@PFRT
     C                     Z-ADDG9RIEK    D@PRFT
     C                     MOVELG9MSYO    D@MSYO
     C                     Z-ADDG9TUSZ    D@TUSZ
     C                     Z-ADDG9KUBI    D@LENG
      *
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   LAST SCREEN
      *------------------------------------------------------
     C           #SCRN3    BEGSR
      *
     C                     MOVELCMD,3     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP02
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'02'      W@ID
      *
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
**  CMD
F1:END
F1:END    F5:DETAIL    F12:GO BACK
F1:END    F12:GO BACK
