      *
     C           DDT2      TAG
     C           *IN77     IFEQ '1'
     C           KEY1      SETLLGHCPL221
     C                     DO   *HIVAL
     C           KEY1      READEGHCPL22                  20
     C           *IN20     IFEQ '0'
     C                     SETOF                     25
     C                     Z-ADD@NEN      @JNEN
     C           KEY2      CHAINMBEPL051             25
     C           *IN25     IFEQ '0'
     C                     Z-ADD@TKI      W       20
     C                     ADD  SR,W      JISSE  100
     C                     END
     C                     END
     C  N20                ENDDO
      *
     C                     Z-ADD0         #T1    120
     C                     Z-ADD0         #T2    120
     C                     Z-ADD0         #T3     92
      *
     C           JISSE     IFNE 0
     C           JISSE     DIV  @KAD      JISEKI    H
     C                     ENDIF
      *
     C                     Z-ADD0         LLT
     C           M6KRU2    IFEQ 'D'
     C           M6SYUY    MULT M6LOTK    #T1
     C           #T1       MULT M6KMAX    #T2
     C           M6KMAX    IFGT 1
     C***        #T2       MULT .5        #T3
     C                     Z-ADD#T2       #T3
     C           JISEKI    IFNE 0
     C           #T3       DIV  JISEKI    #LTIME
     C                     END
     C                     ELSE
     C           JISEKI    IFNE 0
     C           #T2       DIV  JISEKI    #LTIME
     C                     END
     C                     END
     C                     EXSR IKO
     C                     EXCPTDT1
     C                     EXSR CLS
     C                     ELSE
      *
     C           M6KRU2    IFEQ 'F'
     C           M6SYUY    MULT M6LOTK    #T1
     C           JISEKI    IFNE 0
     C           #T1       DIV  JISEKI    #LTIME
     C                     END
     C                     EXSR IKO
     C                     EXCPTDT1
     C                     ELSE
     C           M6KRU2    IFEQ 'R'
     C           M6SYUY    MULT M6LOTK    #T1
     C           #T1       MULT M6KMAX    #T2
     C           M6KMAX    IFGT 1
     C***        #T2       MULT .5        #T3
     C                     Z-ADD#T2       #T3
     C           JISEKI    IFNE 0
     C           #T3       DIV  JISEKI    #LTIME
     C                     END
     C                     ELSE
     C           JISEKI    IFNE 0
     C           #T2       DIV  JISEKI    #LTIME
     C                     END
     C                     END
     C                     EXSR IKO
     C                     EXCPTDT1
     C                     ELSE
     C           M6KRU2    IFEQ 'G'
     C           M6SYUY    MULT M6LOTK    #T1
     C           #T1       MULT M6KMAX    #T2
     C           M6KMAX    IFGT 1
     C***        #T2       MULT .5        #T3
     C                     Z-ADD#T2       #T3
     C           JISEKI    IFNE 0
     C           #T3       DIV  JISEKI    #LTIME
     C                     END
     C                     ELSE
     C           JISEKI    IFNE 0
     C           #T2       DIV  JISEKI    #LTIME
     C                     END
     C                     END
     C                     EXSR IKO
     C                     EXCPTDT1
     C                     ELSE
     C           M6KRU2    IFEQ 'K'
     C           M6SYUY    MULT M6LOTK    #T1
     C           #T1       MULT M6KMAX    #T2
     C           M6KMAX    IFGT 1
     C***        #T2       MULT .5        #T3
     C                     Z-ADD#T2       #T3
     C           JISEKI    IFNE 0
     C           #T3       DIV  JISEKI    #LTIME
     C                     END
     C                     ELSE
     C           JISEKI    IFNE 0
     C           #T2       DIV  JISEKI    #LTIME
     C                     END
     C                     END
     C                     EXSR IKO
     C                     EXCPTDT1
     C                     END
     C                     END
     C                     END
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C                     END
     C                     END
     C                     END
     C                     END
     C                     END
     C           END1      TAG
     C  N15                ENDDO
     C                     END
