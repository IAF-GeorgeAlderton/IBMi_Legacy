     C                     KFLD           HIN3
     C                     KFLD           KOT     3
     C                     KFLD           BMN     40
     C                     KFLD           TKR1
     C                     KFLD           TKR2
     C                     KFLD           TKR3
     C                     KFLD           TKR4
      *
     C           KEY2      KLIST
     C                     KFLD           @JNEN   40
     C                     KFLD           MMJHN1
     C                     KFLD           MMJHN2
     C                     KFLD           MMJHN3
      *
     C           KEY3      KLIST
     C                     KFLD           #NEN    40
     C                     KFLD           #TKI    20
      *
     C           KEY4      KLIST
