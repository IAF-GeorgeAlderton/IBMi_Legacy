     C           @LST      IFEQ 'A'
     C           *LOVAL    SETLLABHTL01
     C                     DO   *HIVAL
     C                     SETOF                     15
     C                     READ ABHTL01                  15
     C           *IN15     IFEQ '0'
     C           M6SKJY    IFEQ 'D'
     C           M6SKHZ    ANDEQ*DATE
     C                     ELSE
     C           M6STHZ    IFEQ 99999999
     C                     Z-ADD0         KTSU    90
     C           M6KSSU    DIV  20        KTSU
     C                     Z-ADD0         JISEKI 100
     C                     Z-ADD0         JISSE  100
     C                     Z-ADD0         #LTIME  62
      *
     C                     Z-ADD1         Z       20
     C                     SETOF                     3077
     C           KEY4      CHAINAAMPL111             30
     C           *IN30     IFEQ '0'
     C           CKSKJY    IFEQ 'D'
     C           CKSKHZ    ANDEQ*DATE
     C                     ELSE
     C                     SETOF                     45
     C           BAN       LOKUPTK,Z                     45
      *
     C           *IN45     IFEQ '1'
     C           BM,Z      IFEQ @KOJ
     C           KB,Z      ANDEQ@KBN
TCHK1C           @KOT      IFEQ *BLANK
TCHK1C           KT,Z      LOKUP#KOT2                    23
TCHK1C           *IN23     IFEQ '0'
TCHK1C                     EXSR DDT
TCHK1C                     GOTO DDT2
TCHK1C                     END
TCHK1 ***
TCHK1C                     ELSE
     C                     SETOF                     20
     C           @KOT      LOKUP#KOT                     20
     C           *IN20     IFEQ '1'
     C                     SETOF                     21
     C           KT,Z      LOKUPRL1                      21
     C           *IN21     IFEQ '1'
     C                     EXSR DDT
     C                     GOTO DDT2
     C                     ELSE
     C                     SETOF                     22
     C           KT,Z      LOKUPLAN1                     22
     C           *IN22     IFEQ '1'
     C                     EXSR DDT
     C                     GOTO DDT2
     C                     END
     C                     END
     C                     ELSE
     C           KT,Z      IFEQ @KOT
     C                     EXSR DDT
     C                     GOTO DDT2
     C                     END
     C                     END
TCHK1C                     END
     C                     END
      *
     C*          Z         IFEQ 1
     C*                    GOTO END1
     C*                    END
      *
     C           Z         IFGT 1
     C           Z         SUB  1         X       20
     C                     Z-ADD1         Y       20
      *
     C                     DO   X         Y
     C                     SUB  1         Z
     C           TK,Z      IFNE '------'
     C           TK,Z      ANDNE'++++++'
     C                     GOTO END1
     C                     ELSE
     C           BM,Z      IFEQ @KOJ
     C           KB,Z      ANDEQ@KBN
TCHK1C           @KOT      IFEQ *BLANK
TCHK1C           KT,Z      LOKUP#KOT2                    23
TCHK1C           *IN23     IFEQ '0'
