      *青山稼働日数*
      *--------------*
     C                     EXSR CLS
     C           *INL1     IFEQ '1'
     C                     Z-ADD0         @KAD    31
     C                     Z-ADD@NEN      #NEN
     C                     Z-ADD@TKI      #TKI
     C           KEY3      SETLLAGDPL121
     C                     DO   *HIVAL
     C           KEY3      READEAGDPL12                  30
     C           *IN30     IFEQ '0'
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         @KAD
     C                     ENDIF
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ'*'
     C                     ADD  .5        @KAD
     C                     ENDIF
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  .5        @KAD
     C                     ENDIF
     C                     ENDIF
     C  N30                ENDDO
     C                     END
