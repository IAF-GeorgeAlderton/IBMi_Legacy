     FAJSPWCD CF  E                    WORKSTN
     FAJSPLCD UF  E           K        DISK                      A
     E                    KOS     1   3  1   KON     6   ﾃcﾆ]hﾎﾞ]
     E                    ER      1   7 60               d[ｰxｮﾈｰﾆﾞ
     I            DS
     I                                        1   80JASKHZ
     I                                        1   40JASKYY
     I                                        5   60JASKMM
     I                                        7   80JASKDD
     I            DS
     I                                        1   80JAKOHZ
     I                                        1   40JAKOYY
     I                                        5   60JAKOMM
     I                                        7   80JAKODD
     I            DS
     I                                        1   60WTIME
     I                                        1   20JAKOHH
     I                                        3   40JAKOSS
     C           KEY       KLIST
     C                     KFLD           WKCD
      *
     C           *ENTRY    PLIST
     C                     PARM           US     10        ﾏｰﾅﾞｰ xb
      *
      *********************************************************
      *                 DISPLAY 1 SCREEN                      *
      *********************************************************
     C           STP0      TAG
     C                     MOVE *BLANK    KBN
     C                     MOVE *BLANK    WKCD
      *
     C           STP1      TAG
     C                     EXFMTAJSPWCD1
     C                     SETOF                     010203
     C                     SETOF                     5099
      * F1: EXIT
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
JW1   * F10: INQ
 .   C           *INKJ     IFEQ '1'
 .   C                     MOVE *BLANK    $NAME
 .   C                     CALL 'INQR04'
 .   C                     PARM           $NAME   5
JW1  C                     ENDIF
      *
      *--------------------*
      *  CHECK OF KUBUN    *
      *--------------------*
     C           KBN       IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     ENDIF
      *
     C           KBN       IFEQ '0'
     C           KBN       OREQ '1'
     C           KBN       OREQ '2'
     C                     ELSE
     C                     SETON                     0199
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     ENDIF
      *
     C                     MOVE *BLANK    KBNNM
     C                     SETOF                     10
     C                     Z-ADD1         A       10
     C           KBN       LOKUPKOS,A                    10
     C                     MOVE KON,A     KBNNM
      *---------------------*
      *  CHECK OF WORKER CD *
      *---------------------*
     C           WKCD      IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     ENDIF
      *
      *--------*
      *FILE CHK*
      *--------*
     C                     SETOF                     90
     C           KEY       CHAINAJSPLCD1             90
      *******
      * ADD *
      *******
     C           KBN       IFEQ '2'
      *
     C                     MOVE *BLANK    NAME
     C           *IN90     IFEQ '0'
     C           JASKJY    IFEQ 'D'
     C           JASKHZ    ANDLE*DATE
     C                     ELSE
     C                     SETON                     0102
     C                     SETON                     99
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
      ********
      *CHANGE*
      ********
     C           KBN       IFEQ '1'
      *
     C                     MOVE JAWKNM    NAME
     C           *IN90     IFEQ '1'
     C                     SETON                     0102
     C                     SETON                     99
     C                     MOVE ER,5      MSG
     C                     GOTO STP1
     C                     ENDIF
     C           *IN90     IFEQ '0'
     C           JASKJY    IFEQ 'D'
     C           JASKHZ    ANDLE*DATE
     C                     SETON                     0102
     C                     SETON                     99
     C                     MOVE ER,6      MSG
     C                     GOTO STP1
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
      ********
      *DELETE*
      ********
     C           KBN       IFEQ '0'
      *
     C                     MOVE JAWKNM    NAME
     C           *IN90     IFEQ '1'
     C                     SETON                     0102
     C                     SETON                     99
     C                     MOVE ER,5      MSG
     C                     GOTO STP1
     C                     ENDIF
     C           *IN90     IFEQ '0'
     C           JASKJY    IFEQ 'D'
     C           JASKHZ    ANDLE*DATE
     C                     SETON                     0102
     C                     SETON                     99
     C                     MOVE ER,6      MSG
     C                     GOTO STP1
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     SETOF                     50
     C           KBN       IFEQ '0'
     C                     SETON                     50
     C                     ENDIF
      *********************************************************
      *                 DISPLAY 1 SCREEN                      *
      *********************************************************
     C           STP2      TAG
     C                     EXFMTAJSPWCD2
     C                     SETOF                     0399
      *
     C           *INKC     IFEQ '1'
     C                     GOTO STP0
     C                     ENDIF
      *
     C           NAME      IFEQ *BLANK
     C                     SETON                     0399
     C                     MOVE ER,7      MSG
     C                     GOTO STP2
     C                     ENDIF
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP2
     C                     ENDIF
      *
     C           KBN       IFEQ '0'
     C                     MOVE 'D'       JASKJY
     C                     Z-ADD*DATE     JASKHZ
     C                     ELSE
     C                     MOVE ' '       JASKJY
     C                     Z-ADD0         JASKHZ
     C                     ENDIF
      *
     C                     Z-ADD*DATE     JAKOHZ
     C                     TIME           WTIME
     C                     MOVELUS        JAKOME
     C                     MOVE WKCD      JAWKCD
     C                     MOVE NAME      JAWKNM
      *
     C           *IN90     IFEQ '0'
     C                     UPDATAJSPLCD1
     C                     ELSE
     C                     WRITEAJSPLCD1
     C                     END
      *
     C                     GOTO STP0
**  KOS.KON
0CANCEL
1CHANGE
2ADD
**  ERR
E-01 INPUT INSTRUCTION
E-02 UPDATE INSTRUCTION IS <0 1 2>
E-03 INPUT WORKER CD
E-04 THE DATA EXISTS
E-05 THERE IS NO DATA
E-06 THE DATA IS DELETED
E-07 INPUT WORKER NAME
