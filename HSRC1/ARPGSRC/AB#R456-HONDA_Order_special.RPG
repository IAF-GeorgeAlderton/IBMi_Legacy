     C                     MOVEL*BLANK    W@NONY  4
     C                     Z-ADD*ZERO     T@HAKO  30
     C           1         SETLLAB#WP452
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AB#WP452                 99
     C   99                LEAVE
     C*
     C                     MOVELINONY     I@NONY  4
     C           I@NONY    IFEQ '2021'
     C           I@NONY    OREQ '2022'
     C                     MOVELI@DAT     O@DAT 256
     C                     EXCPTDT
     C                     ITER
     C                     END
     C*
     C           I@NONY    IFNE W@NONY
     C                     MOVELI@NONY    W@NONY
     C                     Z-ADDINOBN     K@BIN   20
     C                     MOVELIINVN     W@ASNO 16
     C***                  EXSR @SUB2
     C           W@NONY    CHAINAB#PL90              90
     C           *IN90     IFEQ *ON
     C                     Z-ADD*ZERO     YAMXPL
     C                     END
     C                     END
     C*
     C           YAMXPL    IFEQ *ZERO
     C                     MOVELI@DAT     O@DAT 256
     C                     EXCPTDT
     C                     ITER
     C                     END
      *
     C           ISYOS     IFNE *ZERO
     C           ISRYO     DIV  ISYOS     W@HAKO  70
     C                     MVR            W@MVR   70
     C           W@MVR     IFNE *ZERO
     C                     ADD  1         W@HAKO
     C                     END
     C                     ELSE
     C                     ADD  1         W@HAKO
     C                     END
     C*
     C           W@HAKO    ADD  T@HAKO    WWHAKO  70
     C*
     C           WWHAKO    IFLT YAMXPL
     C                     Z-ADDWWHAKO    T@HAKO
     C                     MOVELI@DAT     W@SAVE
     C                     Z-ADDK@BIN     WNOBN
     C                     MOVELW@ASNO    WINVN
     C                     MOVELW@SAVE    O@DAT
     C                     EXCPTDT
     C                     ITER
     C                     END
     C*
     C                     EXSR @SUB1
     C*
     C                     ENDDO
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C* ----------------------------------------------------
     C           @SUB1     BEGSR
     C*
     C           YAMXPL    SUB  T@HAKO    W@HAK1  70
     C                     Z-ADDW@HAKO    W@HAK2  70
     C*
     C           W@HAK1    MULT ISYOS     W@SRYO  70
     C                     MOVELI@DAT     W@SAVE
     C                     Z-ADDK@BIN     WNOBN
     C                     Z-ADDW@SRYO    WSRYO
     C                     MOVELW@ASNO    WINVN
     C                     MOVELW@SAVE    O@DAT
     C                     EXCPTDT
     C*
     C                     DO   *HIVAL
     C*
     C                     SUB  W@HAK1    W@HAK2
     C*
     C           W@HAK2    IFLE YAMXPL
     C                     ADD  1         K@BIN
     C                     EXSR @SUB2
     C           W@HAK2    MULT ISYOS     W@SRYO
     C                     MOVELI@DAT     W@SAVE
     C                     Z-ADDK@BIN     WNOBN
     C                     Z-ADDW@SRYO    WSRYO
     C                     MOVELW@ASNO    WINVN
     C                     MOVELW@SAVE    O@DAT
     C                     EXCPTDT
     C                     Z-ADDW@HAK2    T@HAKO
     C                     LEAVE
     C                     END
     C*
     C                     ADD  1         K@BIN
     C                     EXSR @SUB2
     C           YAMXPL    MULT ISYOS     W@SRYO
     C                     MOVELI@DAT     W@SAVE
     C                     Z-ADDW@SRYO    WSRYO
     C                     Z-ADDK@BIN     WNOBN
     C                     MOVELW@SAVE    O@DAT
     C                     EXCPTDT
     C                     Z-ADDYAMXPL    W@HAK1
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C* ----------------------------------------------------
     C           @SUB2     BEGSR
     C*
     C           K#L1A     KLIST
     C                     KFLD           INOHZ
     C                     KFLD           K@BIN
     C                     KFLD           INONY
     C                     DO   *HIVAL
     C           K#L1A     CHAINAB#PL1A              91
     C           *IN91     IFEQ *OFF
     C                     ADD  1         K@BIN
     C                     ITER
     C                     END
     C                     LEAVE
     C                     ENDDO
     C*
     C           K#CNT     KLIST
     C                     KFLD           K@KWD1
     C                     KFLD           K@KWD2
     C                     MOVEL'HONDA'   K@KWD1  8 P
     C                     MOVEL'ASN# '   K@KWD2  8 P
     C           K#CNT     CHAINAB#PPCT              91
     C           *IN91     IFEQ *OFF
     C                     ADD  1         CTNBR1
     C           CTNBR1    IFGT 99999999
     C                     Z-ADD1         CTNBR1
     C                     ENDIF
     C                     UPDATAB#PPCT1
     C                     ELSE
     C                     CLEARAB#PPCT1
     C                     MOVELK@KWD1    CTKEY1
     C                     MOVELK@KWD2    CTKEY2
     C                     ADD  1         CTNBR1
     C                     WRITEAB#PPCT1
     C                     ENDIF
      *
