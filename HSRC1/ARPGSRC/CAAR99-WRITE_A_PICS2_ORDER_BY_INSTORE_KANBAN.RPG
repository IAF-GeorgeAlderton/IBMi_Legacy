     H            Y.                                    1
      ** CAAR99 **********************************
      * WRITE A-PICS2 ORDER BY INSTORE-KANBAN    *
      *               CREATE DATE : 2021.07.21   *
      *               AUTHOR      : T.SAKAKI     *
      ********************************** CAAR32 **
     FAH#PL1A IF  E           K        DISK
     FAH#WP1A O   E                    DISK
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I            DS
     I                                        1  140D#TIME
     I                                        1   60WTIME
     I                                        1   20WHOUR
     I                                        3   40WMINU
     I                                        7  140WDATE
     I*CHANGE DATE OF FCEPP01
     I            DS
     I                                        1   80A2DATE
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
     I            DS
     I                                        1   80C7KOHZ
     I                                        1   40C7KOYY
     I                                        5   60C7KOMM
     I                                        7   80C7KODD
     I            DS
     I                                        1   60C7KOTI
     I                                        1   20C7KOHH
     I                                        3   40C7KOSS
     I            DS
     I                                        1   80C7KEHZ
     I                                        1   40C7KEYY
     I                                        5   60C7KEMM
     I                                        7   80C7KEDD
      ****************************************************
      *  ENTRY  LIST
      ****************************************************
     C           *ENTRY    PLIST
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
      ****************************************************
      *  MAIN
      ****************************************************
      * INITIAL SETTING
     C                     TIME           D#TIME
      *
     C                     MOVE P@HIN1    K@HIN1  5
     C                     MOVE P@HIN2    K@HIN2  5
     C                     MOVE P@HIN3    K@HIN3  2
      *
     C           HINKEY    KLIST
     C                     KFLD           K@HIN1  5
     C                     KFLD           K@HIN2  5
     C                     KFLD           K@HIN3  2
      *
     C           HINKEY    CHAINCABPL01              88
     C           *IN88     IFEQ '0'
     C           C3SKJY    IFEQ 'D'
     C                     SETON                     88
     C                     ENDIF
     C                     ENDIF
      *
     C   88                GOTO @END
      *
     C                     CLEARCA#PP111
      *
     C                     Z-ADDWDATE     C7KOHZ
     C                     Z-ADDWHOUR     C7KOHH
     C                     Z-ADDWMINU     C7KOSS
     C                     MOVEL#USER     C7KOME
     C                     MOVEL#PGM      C7KOPG
     C                     MOVELK@HIN1    C7SHN1
     C                     MOVELK@HIN2    C7SHN2
     C                     MOVELK@HIN3    C7SHN3
      *
     C           HINKEY    CHAINFCEPL011             88
     C           *IN88     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C                     SETON                     88
     C                     END
     C                     END
      *
     C   88                GOTO @END
      *
     C           A2DATE    IFLT WDATE
     C                     Z-ADDA2SSYS    C7SYOS
     C                     ELSE
     C                     Z-ADDA2KSYS    C7SYOS
     C                     ENDIF
      *
      * 端数統合
     C           P@APPL    IFEQ '3'
     C                     Z-ADD1         C7HKSU
     C                     MOVE '32'      C7GYOM
     C                     ENDIF
      * 造り過ぎ（マイナス反映）
     C           P@APPL    IFEQ '4'
     C                     Z-SUB1         C7HKSU
     C                     MOVE '56'      C7GYOM
     C                     ENDIF
      *
     C                     Z-ADDWDATE     C7KEHZ
     C                     Z-ADDWHOUR     C7KEJI
     C                     Z-ADDWMINU     C7KEPN
      *
     C                     WRITECA#PP111
      *
     C           @END      TAG
      *
     C                     SETON                     LR
     C                     RETRN
