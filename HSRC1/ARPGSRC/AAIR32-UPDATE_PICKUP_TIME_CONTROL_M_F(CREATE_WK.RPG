     H            Y.
     F** AAIR32 *****************************************
     F* UPDATE PICKUP TIME CONTROL M/F(CREATE WK FILE)  *
     F*        ITS.         2012.11.05                  *
     F***************************************************
     FAAIPL11 IF  E           K        DISK
     FAAIPL31 IF  E           K        DISK
     FAAIWP31 O   E                    DISK                      A
     E                    BA         24  2 0             ncﾆﾞl ﾍﾞ]xb
     E                    BI         24  2 0             ncﾆﾞl ﾍﾞ]xb
      *
     I            DS
     I                                        1  48 BA
     I                                        1   20CDBI08
     I                                        3   40CDBI09
     I                                        5   60CDBI10
     I                                        7   80CDBI11
     I                                        9  100CDBI12
     I                                       11  120CDBI13
     I                                       13  140CDBI14
     I                                       15  160CDBI15
     I                                       17  180CDBI16
     I                                       19  200CDBI17
     I                                       21  220CDBI18
     I                                       23  240CDBI19
     I                                       25  260CDBI20
     I                                       27  280CDBI21
     I                                       29  300CDBI22
     I                                       31  320CDBI23
     I                                       33  340CDBI24
     I                                       35  360CDBI01
     I                                       37  380CDBI02
     I                                       39  400CDBI03
     I                                       41  420CDBI04
     I                                       43  440CDBI05
     I                                       45  460CDBI06
     I                                       47  480CDBI07
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   40WJFF
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
     I              '0123456789'          C         WKCKSU
     I              X'0E0F40'             C         WKCKCH
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1KOSN  1
     C                     PARM           P1BMON  4
     C                     PARM           PCMD    2
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     MOVELP1BMON    #KBMON  40
     C           #KBMON    CHAINAAIPL111             80
     C           *IN80     IFEQ '0'
     C                     EXSR #SB400
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *------------------------------------------------------*
      * CREATE WK                                            *
      *------------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEABA        BI
     C                     SORTABI
     C                     Z-ADD1         X       20
     C           X         DOWLE24
     C           BI,X      IFNE 0
     C                     EXSR #SB500
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *------------------------------------------------------*
      * CREATE WK                                            *
      *------------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYG21    KLIST
     C                     KFLD           #KBMON  40
     C                     KFLD           #KBIN   20
     C                     MOVELP1BMON    #KBMON
     C                     Z-ADDBI,X      #KBIN
     C                     Z-ADD0         WKTIME  40
     C                     Z-ADD0         WKADJS  10
     C                     MOVEL'0'       GET     1
     C           KEYG21    SETLLAAIPL311
     C           KEYG21    READEAAIPL311                 20
     C           *IN20     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           G2SKJY    IFEQ 'D'
     C           G2SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'1'       GET
     C                     Z-ADDG2TIME    WKTIME
     C                     Z-ADDG2ADJS    WKADJS
     C                     ENDIF
     C           KEYG21    READEAAIPL311                 20
     C                     ENDDO
      *
     C                     CLEARAAIWP311
     C                     MOVELP1BMON    W1BMON
     C                     Z-ADDBI,X      W1BIN
     C                     Z-ADDWKTIME    W1TIME
     C                     Z-ADDWKADJS    W1ADJS
     C                     WRITEAAIWP311
      *
     CSR         ESB500    ENDSR
