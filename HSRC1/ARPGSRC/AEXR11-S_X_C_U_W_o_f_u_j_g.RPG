     C                     Z-ADD0         WKADJU  30
     C           KEYB5     KLIST
     C                     KFLD           L1KCD1  1
     C                     KFLD           L1KCD2  1
     C                     MOVEL'0'       GET     1
     C           KEYB5     SETLLABMPPB51
     C           KEYB5     READEABMPPB51                 94
     C           *IN94     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           AHSKJY    IFEQ 'D'
     C           AHSKHZ    ANDLE*DATE
