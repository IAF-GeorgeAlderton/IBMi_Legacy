     C*****      L1KMAX    IFEQ 999
     C           L1KMAX    IFEQ 99999
     C                     CLEARABMWP301
     C                     MOVELERR03     ABTXT
     C                     EXSR #SB800
     C                     ELSE
     C***        AXNGEK    DIV  20        WKSRYO  90
     C                     Z-ADDAXNGEK    WKSRYO  90
     C                     EXSR #SB330
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYL11    REDPEAKBPL041                 82
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *---------------------------*
      *更新
      *---------------------------*
     CSR         #SB330    BEGSR
      *  PT WASHER
     C           L1BMON    IFEQ 8990
      *  UPDATE IF IT IS IN UNIT PRICE M/F
     C           GETGDK    IFEQ '1'
     C                     EXSR #SB410
     C                     ELSE
     C                     CLEARABMWP301
     C                     MOVELERR04     ABTXT
