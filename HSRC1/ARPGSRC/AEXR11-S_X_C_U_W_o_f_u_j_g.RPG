     C           *ENTRY    PLIST
     C                     PARM           P@DTYM  60
      *
     C           ACALL     PLIST
     C                     PARM           ASTLR            SETON LR ﾍｭcﾆg
     C                     PARM           WMAIS            f]ﾌﾞ]ubﾇc
     C                     PARM           L1KTSU           fhmbﾍajﾒﾇc
     C                     PARM           L1SYOS           ﾆｬcﾑcﾇc
     C                     PARM           L1LTIM           ﾒｰnﾞjbw
     C                     PARM           L1ROTO           ﾜｮn
     C                     PARM           L1KISU           ﾌﾞ[lgibﾇc
     C                     PARM           L1UZAR           kｭcﾈbubﾇc
     C                     PARM           L1HITO           anﾃcmbﾍgnﾒ
      *
     C                     TIME           WTIME
     C           1         SETLLAEXWP151
     C                     READ AEXWP151                 21
     C           *IN21     DOWEQ'0'
     C                     EXSR #SB150
     C                     EXSR #SB200
     C                     READ AEXWP151                 21
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * GDKPP01                                            *
      *----------------------------------------------------*
     CSR         #SB150    BEGSR
      *
     C                     MOVEL'0'       GETGDK  1
     C                     MOVELW2SHN     HINB   20
     C           HINB      SETLLGDKPL02
     C           HINB      READEGDKPL02                  74
     C           *IN74     DOWEQ'0'
     C           ISSKJY    IFEQ 'D'
     C           ISSKHZ    ANDLE*DATE
     C                     ELSE
     C           ISENHZ    IFEQ 99999999
     C                     MOVEL'1'       GETGDK
     C                     ENDIF
     C                     ENDIF
     C           HINB      READEGDKPL02                  74
     C                     ENDDO
