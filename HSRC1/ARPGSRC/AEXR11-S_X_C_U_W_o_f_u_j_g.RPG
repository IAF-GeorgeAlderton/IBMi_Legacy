     C                     ENDIF
      *  LOCAL WASHER
     C                     ELSE
     C                     EXSR #SB410
     C                     ENDIF
      *
     CSR         ESB330    ENDSR
      *---------------------------*
      *かんばん枚数計算         *
      *---------------------------*
     CSR         #SB410    BEGSR
      *
     C                     Z-ADDL1SYOS    @BSSYS
     C                     MOVELL1SYOT    @BSSYT
     C                     Z-ADDL1KTSU    @BKTSU
     C*                    Z-ADDL1KMAX    @BKMAX
     C                     MOVE *BLANK    ASTLR   2
     C                     Z-ADD0         WMAIS
     C                     CALL 'ABCR161' ACALL
     C                     Z-ADDWMAIS     @BKMAX
     C                     Z-ADDL1UZAR    @BMAXH
     C                     Z-ADDL1ROTO    @BKLOT
     C           L1ROTO    IFEQ 0
     C                     Z-ADD1         @BKLOT
     C                     ENDIF
     C                     Z-ADD0         @BPADJ
     C                     Z-ADDL1AUAJ    @BAUAJ
     C                     Z-ADD0         @BDUPH
     C                     Z-ADDL1OTHH    @BOTHH
      *
     C           L1DOUT    IFEQ 'Y'
     C                     Z-ADDL1KMAX    L1MAIS
     C                     END
      *
     C                     Z-ADDL1KMAX    WKMAX   50
     C                     Z-ADDL1KALL    WKALL   50
     C                     Z-ADDL1KMIN    WMIN    50
     C                     Z-ADDL1KMAX    WMAX    50
     C           L1KALL    IFLT L1KMAX
     C                     Z-ADDL1KMAX    WALL    50
     C                     ELSE
     C                     Z-ADDL1KALL    WALL
     C                     ENDIF
     C                     Z-ADDL1KSKB    KSKBN   10
     C*
     C           WKSRYO    DIV  20        L1KSSU
     C*
     C                     Z-ADDP@DTYM    P7DTYM
     C                     Z-ADD0         P@KSSU
     C                     Z-ADD0         P@KTSU
      *
     C           L1BMON    IFEQ 8990
     C                     CALL 'ABMR4I'
     C                     PARM           P7DTYM  60
     C                     PARM           L1SHN1  5
     C                     PARM           L1SHN2  5
     C                     PARM           L1SHN3  2
     C                     PARM           P@KSSU  90
     C                     PARM           P@KTSU  90
     C                     ELSE
     C                     CALL 'ABMR48'
     C                     PARM           P7DTYM  60
     C                     PARM           L1SHN1  5
     C                     PARM           L1SHN2  5
     C                     PARM           L1SHN3  2
     C                     PARM           P@KSSU  90
     C                     PARM           P@KTSU  90
     C                     ENDIF
      *
     C                     SELEC
     C           P@KTSU    WHLT L1KTSU
     C                     MOVEL'51'      L1STI1
     C           P@KTSU    WHGT L1KTSU
     C                     MOVEL'52'      L1STI1
     C                     ENDSL
      *
     C                     Z-ADDP@KTSU    L1KTSU
      *
     C           P@KTSU    MULT 20        WKSRYO
      *
     C                     Z-ADD@BKMAX    SVKMAX  50
      *
     C           WKSRYO    DIV  20        W@KSSU  90
     C                     Z-ADD0         W@HAKD  51
     C           L1SYOS    IFNE 0
     C           W@KSSU    DIV  L1SYOS    W@HAKD
     C                     ENDIF
     C           W@HAKD    IFEQ 0
     C                     Z-ADD0.1       W@HAKD
     C                     ENDIF
     C*
     C* CALCULATE ADJUSTMENT  FOR LOCAL WASHER
     C                     EXSR #SB710
      *
      ****
|    C           L1SYOS    IFEQ 0
|    C                     CLEARABMWP301
|    C                     MOVELERR02     ABTXT
|    C                     EXSR #SB800
|    C                     GOTO ESB410
|    C                     ENDIF
      *
     C                     MOVE *BLANK    ASTLR   2
     C                     MOVE L1HITO    WHITO   3
     C                     Z-ADD0         WMAIS   50
      *自動処理調整をゼロにする
     C                     Z-ADD0         W1MAIS  40
     C                     ADD  L1DAND    W1MAIS
     C                     ADD  L1KYOT    W1MAIS
     C                     ADD  L1FRYO    W1MAIS
     C                     ADD  L1SENY    W1MAIS
     C                     ADD  L11NAI    W1MAIS
     C                     ADD  L12NAI    W1MAIS
     C                     ADD  L1JISK    W1MAIS
     C                     ADD  L1OTHH    W1MAIS
     C                     Z-ADDW1MAIS    L1CMAI
     C                     Z-ADDW1MAIS    L1UZAR
     C********             SUB  L1AUAJ    L1CMAI
     C********             SUB  L1AUAJ    L1UZAR
     C                     Z-ADD0         L1AUAJ
     C                     CALL 'ABCR161' ACALL
     C******               ADD  L1UZAR    WMAIS
     C** FOR LOCAL WASHER
     C           L1BMON    IFNE 8990
     C                     EXSR #SB720
     C                     ENDIF
     C**
     C*****      WMAIS     IFGT 999
     C           WMAIS     IFGT 9999
     C                     CLEARABMWP301
     C                     MOVELERR01     ABTXT
     C                     EXSR #SB800
     C                     ENDIF
      *
     C                     Z-ADDWMAIS     L1KMAX
     C                     Z-ADDWMAIS     L1KMA4  50
     C           L1KMAX    IFEQ 1
     C                     ADD  1         L1AUAJ
     C                     ADD  1         L1CMAI
     C                     ADD  1         L1UZAR
     C           SVKMAX    IFEQ 1
     C           W@HAKD    ANDLT1.0
     C                     SUB  1         L1OTHH
     C                     SUB  1         L1CMAI
     C                     SUB  1         L1UZAR
     C                     MOVEL*BLANK    L1CMT1
     C                     MOVELCMT01     L1CMT1
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADDWMAIS     L1KMAX
     C                     Z-ADDWMAIS     L1KMA4  50
     C******               Z-ADDL1UZAR    L1KMAX
     C                     Z-ADDL1KMAX    WKMAX
     C           L1DTKO    IFEQ '2'
     C           L1DTKO    OREQ 'D'
     C                     GOTO CAE
     C                     ENDIF
     C           L1DOUT    IFNE *BLANK
     C                     Z-ADDWALL      L1KALL
     C                     Z-ADDWMAX      L1KMIN
     C                     ENDIF
     C           *YEAR     CABEQL1KOYY    CA2
     C           *YEAR     SUB  L1KOYY    WYY     40
     C           WYY       IFLE 0001
     C                     Z-ADD*MONTH    XXMM
     C                     Z-ADD*DAY      XXDD
     C           XXMD      CABLEL1KOMD    CA2
     C                     ENDIF
     C           L1KALL    CABLTL1KMIN    CA2
     C           L1KMIN    CABGE30        CA2
     C                     SETOF                     30
     C           L1STI1    COMP 01                     30
     C  N30      L1STI1    COMP 49                   30
     C           *IN30     IFEQ '1'
     C                     ENDIF
     C           CA2       TAG
     C                     Z-ADD0         L1SRMS
     C           L1DOUT    IFNE *BLANK
     C                     MOVE *BLANK    L1KSHK
     C                     Z-ADD0         L1ALHK
     C                     Z-ADD0         L1MXHK
     C                     ENDIF
     C           L1KSKB    IFEQ KSKBN
     C           L1DOUT    CABEQ'Y'       CAE
     C           L1KSHK    CABEQ*BLANK    CAE
     C                     Z-ADDL1ALHK    WKALL            f]ﾌﾞ]ubﾇc ALL
     C                     Z-ADDL1MXHK    WMAX                       MAX
     C                     ELSE
     C           L1KSHK    IFNE *BLANK
     C                     Z-ADDL1ALHK    WKALL
     C                     Z-ADDL1MXHK    WMAX
     C                     ENDIF
     C                     ENDIF
     C*******              Z-ADD0         L1KALL
     C********             Z-ADD0         L1KMIN
     C           WKALL     IFGT WMAX
     C           WKALL     SUB  WMAX      L1SRMS
     C                     ENDIF
     C           CAE       TAG
     C                     EXSR #KOSN
      *
     CSR         ESB410    ENDSR
     C*****************************************************
     C*   MO-NO  ﾎｦbﾓ ﾃcﾆ]
     C*****************************************************
     C           #KOSN     BEGSR
      *
     C           L1DTKO    IFNE '0'                        0-nﾒiﾆ
     C* ﾃcﾈbﾍ]f]ﾌﾞ]uﾇjｰ ﾃcﾆ]
     C           L1KCD2    IFNE 'Z'
     C           L1KSKB    IFEQ KSKBN
     C           L1DOUT    CABEQ'Y'       @005
     C           L1KSHK    CABEQ*BLANK    @005
     C                     ENDIF
     C           L1DOUT    IFNE *BLANK
     C                     MOVE 'H'       L1KSHK
     C                     Z-ADDWKALL     L1ALHK
     C                     Z-ADDWMAX      L1MXHK
     C                     ENDIF
     C           @005      TAG
     C           L1DTKO    IFNE '2'
     C           KSKBN     IFEQ L1KSKB
     C           L1KMIN    IFEQ L1KMAX
     C                     GOTO @006
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     MOVE *BLANK    L1DOUT
     C                     MOVE 'Y'       L1KOUT
     C           @006      TAG
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVEL'ZIDOU'   L1KOME    P
     C                     Z-ADD*YEAR     L1KOYY
     C                     Z-ADDUMONTH    L1KOMM
     C                     Z-ADDUDAY      L1KODD
     C                     Z-ADDWTITH     L1KOHH
     C                     Z-ADDWTITM     L1KOSS
      *
     C           L1DTKO    IFEQ '0'
     C                     ELSE
     C                     MOVE '1'       L1DTKO
     C                     MOVE '*'       L1DTHE
     C                     UPDATAKBPL041
     C                     EXSR #SB810
     C                     ENDIF
      *
     C           @007      ENDSR
      *---------------------------*
      * A-PICS 以外　調整枚数
      *---------------------------*
     CSR         #SB710    BEGSR
      *
     C                     Z-ADD0         WKADJU  30
     C           KEYB6     KLIST
     C                     KFLD           L1SHN1
     C                     KFLD           L1SHN2
     C                     KFLD           L1SHN3
     C           KEYB6     CHAINABMPPB61             94
     C           *IN94     IFEQ '0'
     C           AISKJY    ANDEQ'D'
     C           AISKHZ    ANDLE*DATE
     C                     SETON                     94
     C                     ENDIF
     C           *IN94     IFEQ '0'
