     C                     KFLD           #KSHN2  5
     C                     KFLD           #KSHN3  2
     C                     MOVELAXKHN1    #KSHN1
     C                     MOVELAXKHN2    #KSHN2
     C                     MOVELAXKHN3    #KSHN3
     C           KEYL11    SETGTAKBPL041
     C           KEYL11    REDPEAKBPL041                 82
     C           *IN82     DOWEQ'0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    ANDLE*DATE
     C                     ELSE
     C           L1KUKJ    IFEQ AXKBMN
     C           L1KUKE    ANDEQAXUKER
     C           L1STHZ    ANDEQ99999999
