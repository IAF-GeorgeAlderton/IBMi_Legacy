     H            Y.
     ** AB#RI3  **********************************
     *  ..EDI(850)  GENTRAN HONDA DUPLICATE CHECK
     *
     *  JW(SRA) 11/13/2015 MODIFIED AB#R0T1
     *                     INCLUDE UPID=1 OR 3 IN DUPLI-CONDITION
     ********************************** AB#RI3  **
     FAB#TL2C IF  E           K        DISK
      *---------------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           P@EDID
     C                     PARM           P@PLNT
     C                     PARM           P@SHCD
     C                     PARM           P@ODRN
     C                     PARM           P@PLSH
     C                     PARM           P@MHN1
     C                     PARM           P@MHN2
     C                     PARM           P@MHN3
     C                     PARM           P@MHN4
     C                     PARM           P@SHTM
     C                     PARM           P@DLTM
     C                     PARM           P@DERR  1
      *
     C           *LIKE     DEFN ACEDID    P@EDID
     C           *LIKE     DEFN ACPLNT    P@PLNT
     C           *LIKE     DEFN ACSHCD    P@SHCD
     C           *LIKE     DEFN ACODRN    P@ODRN
     C           *LIKE     DEFN ACPLSH    P@PLSH
     C           *LIKE     DEFN ACMHN1    P@MHN1
     C           *LIKE     DEFN ACMHN2    P@MHN2
     C           *LIKE     DEFN ACMHN3    P@MHN3
     C           *LIKE     DEFN ACMHN4    P@MHN4
     C           *LIKE     DEFN ACSHTM    P@SHTM
     C           *LIKE     DEFN ACDLTM    P@DLTM
      *
     C           K#KEY     KLIST
     C                     KFLD           P@EDID
     C                     KFLD           P@PLNT
     C                     KFLD           P@SHCD
     C                     KFLD           P@ODRN
     C                     KFLD           P@PLSH
     C                     KFLD           P@MHN1
     C                     KFLD           P@MHN2
     C                     KFLD           P@MHN3
     C                     KFLD           P@MHN4
     C                     KFLD           P@SHTM
     C                     KFLD           P@DLTM
      *
     C                     MOVEL*OFF      P@DERR
      *COUNTER FOR BLANK (ID)
     C                     Z-ADD0         B@CNT   40
      *COUNTER FOR OTHER THAN D/BLANK (ID)
     C                     Z-ADD0         N@CNT   40
      *
     C           K#KEY     SETLLAB#TL2C
      *
     C                     DO   *HIVAL
     C           K#KEY     READEAB#TL2C                  99
     C   99                LEAVE
     C           *IN99     IFEQ *OFF
      *
     C           ACUPID    IFEQ *BLANK
     C                     ADD  1         B@CNT
     C                     ELSE
     C           ACUPID    IFNE 'D'
     C                     ADD  1         N@CNT
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           B@CNT     IFNE 0
     C           N@CNT     ANDNE0
     C                     MOVEL*ON       P@DERR
     C                     ENDIF
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
