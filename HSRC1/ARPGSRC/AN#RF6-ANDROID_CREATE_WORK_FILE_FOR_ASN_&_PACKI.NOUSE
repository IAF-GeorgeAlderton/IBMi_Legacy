     H            Y.
     F** AN#RF6 ********************************************
     F*  ANDROID CREATE WORK FILE FOR ASN & PACKING LIST   *
     F*                                                    *
     F* TCHK1 07/18/06 CREATE(COPY FROM AB#RF6)            *
     F* TCHK2 10/07/09 CHG SINGLE TO MULTI PALLET          *
     F******************************************************
     FAN#WPFB IF  F     100            DISK
     FABR6L01 IF  E           K        DISK                           UC
     F            ABR6P011                          KRENAMEABR6L0X
     FABR6L02 UF  E           K        DISK                      A    UC
     FFCEPL01 IF  E           K        DISK
     FABRGP01 UF  E                    DISK                      A
     FABR4P01 UF  E           K        DISK                      A
     FABR6PW1 UF  E           K        DISK                      A
     FAB#PL90 IF  E           K        DISK
      ******************************************************
     E                    PLT       999  9 0
     E                    BOX       999  9 0
     E                    PLL       999  9 0
     E                    QTY       999  9 0
     E                    SRL       999 18
      ******************************************************
     IAN#WPFB AA  01
     I                                        1   80INOHZ
     I                                        1   40INOYY
     I                                        5   60INOMM
     I                                        7   80INODD
     I                                       11  120INOTM
     I                                       13  16 ISIRE
     I                                       17  17 ISIRK
     I                                       18  21 INUKE
     I                                       22  31 IODRN
     I                                       32  35 ISBAN
     I                                       36  40 IMHN1
     I                                       41  45 IMHN2
     I                                       46  50 IMHN3
     I                                       51  55 IMHN4
     I                                       36  55 IMHN
     I                                       36  36 WNO1
     I                                       36  42 WNO2
     I                                       43  55 WNO3
     I                                       36  39 WNO4
     I                                       40  44 WNO5
     I                                       45  55 WNO6
     I                                       56  650ISRYO
     I                                       66  710ISYOS
     I                                       72  76 ISHN1
     I                                       77  81 ISHN2
     I                                       82  83 ISHN3
     I                                       72  83 ISHN
     I                                       84  870ITOKU
     I                                       88  910IDELY
     I                                       93  950IHAKO
     I* CUSTOMER PART
     I            DS
     I                                        1  20 FCCPAR
     I                                        1   7 WCNO2
     I                                        8   8 WCNO3
     I                                        9  20 WCNO4
     I***                                     1   1 WCNO1
     I***                                     2   8 WCNO2
     I***                                     9   9 WCNO3
     I***                                    10  20 WCNO4
     I*
     I***                                     1   4 WCNO5
     I***                                     5   5 WCNO6
     I***                                     6  10 WCNO7
     I***                                    11  11 WCNO8
     I***                                    12  20 WCNO9
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     I            DS
     I                                        1   80A2TRHZ
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
     I            DS
     I                                        1   6 A2STKR
     I                                        1   1 A2STRK
     I                                        2   3 A2STRT
     I                                        4   5 A2STRR
     I                                        6   6 A2STRD
     I            DS
     I                                        1   6 A2KTKR
     I                                        1   1 A2KTRK
     I                                        2   3 A2KTRT
     I                                        4   5 A2KTRR
     I                                        6   6 A2KTRD
     I* MANIFEST NUMBER
     I            DS
     I* PART NUMBER
     I            DS
     I                                        1  20 KPART
     I                                        1  12 FCIPAR
     I* SYSTEM DATE
     I            DS
     I                                        1  120WKTIME
     I                                        1   20WWHH
     I                                        3   40WWNN
     I                                        7   80WWYY
     I                                        9  100WWMM
     I                                       11  120WWDD
     I* RELEASED DATE
     I            DS
     I                                        1   80WREDT
     I                                        1   40WREYY
     I                                        5   60WREMM
     I                                        7   80WREDD
     C*******************************************************
     C           *ENTRY    PLIST
     C                     PARM           PUSR   10
     C                     PARM           PSIRE   4
     C                     PARM           PNOHZ   80
     C                     PARM           PBIN    20
     C                     PARM           PMANI  11
     C                     PARM           PREDT   80
     C                     PARM           PDOCK   4
     C                     PARM           PPS#    60
      * FCEPL01
     C           KEY2      KLIST
     C                     KFLD           ISHN1
     C                     KFLD           ISHN2
     C                     KFLD           ISHN3
      * ABR4P01
     C           KEY3      KLIST
     C                     KFLD           WSIRE            DELIVERY
     C                     KFLD           PDOCK            DOCK
     C                     KFLD           WNOHZ            SHIP DATE
     C                     KFLD           WBIN             BIN
     C                     KFLD           WREYY            RELEASED YY
     C                     KFLD           WREMM
     C                     KFLD           WREDD
      * ABR6L02
     C           KEY4      KLIST
     C                     KFLD           INOHZ            SHIP DATE
     C                     KFLD           INOTM            BIN
     C                     KFLD           WREYY            RELEASED YY
     C                     KFLD           WREMM                     MM
     C                     KFLD           WREDD                     DD
     C                     KFLD           IDELY            DELIVERY
     C                     KFLD           K41              DOCK
     C                     KFLD           ISHN             PART
      *
     C           K#FW      KLIST
     C                     KFLD           FCDELY
     C                     KFLD           FCDOCK
     C                     KFLD           FCSHDT
     C                     KFLD           FCSHTM
     C                     KFLD           FCRYYY
     C                     KFLD           FCRMMM
     C                     KFLD           FCRDDD
     C                     KFLD           W##PLT
     C*******************************************************
     C                     EXSR @INT
     C                     EXSR @MAIN
     C                     EXSR @END
     C**************************************************************************
     C*  @INT : INITILIZE
     C**************************************************************************
     C           @INT      BEGSR
     C*
     C                     Z-ADD0         WPALET  20
     C                     Z-ADD0         WTBOX   60
     C                     Z-ADD0         WHAKO   30
     C                     Z-ADD0         W#LAY   60
     C                     Z-ADD0         WRST1   60
     C                     Z-ADD0         W#PLT   20
     C                     Z-ADD0         W##PLT  20
     C                     Z-ADD0         WRST2   60
     C                     Z-ADD0         WWHAKO  20
     C                     Z-ADD0         TEIGH   92
     C                     Z-ADD0         WTARE   82
     C                     Z-ADD0         I       30
     C                     Z-ADD0         J       30
     C                     Z-ADD0         M       30
     C                     Z-ADD0         N       30
     C                     Z-ADD0         WKRQTY  60
     C                     Z-ADD0         SVRQTY  60
     C                     MOVE *BLANK    KPART
     C                     TIME           WKTIME
     C                     MOVE PREDT     WREDT
     C                     MOVE PDOCK     K41     4
     C* GET SERIAL NUMBER
     C                     OPEN ABR6L01
     C           *HIVAL    SETGTABR6L0X
     C                     READPABR6L0X                  91
     C*
     C           *IN91     IFEQ '0'
     C                     Z-ADDFCSEQ#    WSEQ#   90
     C                     ELSE
     C                     Z-ADD*ZERO     WSEQ#
     C                     END
     C*
     C                     CLOSEABR6L01
     C                     OPEN ABR6L02
     C*
     C                     ENDSR
     C*
     C**************************************************************************
     C*  @MAIN : MAIN
     C**************************************************************************
     C           @MAIN     BEGSR
     C* MANIFEST # EXISTS     = AMENDED ORDER DATA
     C* MANIFEST # NOT EXISTS = FIRST ORDER DATA
     C                     MOVE PSIRE     WSIRE   40
     C                     MOVE PNOHZ     WNOHZ   80
     C                     Z-ADDPBIN      WBIN    20
     C           KEY3      CHAINABR4P011             92
     C*
     C           *IN92     IFEQ '0'
     C*
     C                     READ AN#WPFB                  90
     C           *IN90     DOWEQ'0'
     C                     Z-ADD*ZERO     M
     C                     Z-ADD*ZERO     N
     C                     EXSR @UPD1                      UPDATE ABF6P01
     C                     EXSR @MOVE1                     CREATE NEW ABF6
     C                     READ AN#WPFB                  90
     C                     END
     C*
     C                     ELSE
     C*
     C                     READ AN#WPFB                  90
     C           *IN90     DOWEQ'0'
     C                     Z-ADD*ZERO     M
     C                     Z-ADD*ZERO     N
     C                     EXSR @MOVE1                     CREATE NEW ABF6
     C                     READ AN#WPFB                  90
E02  C                     END
     C*
E01  C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*  @UPD1 : UPDATE ABR6P01 OF FIRST ORDER DATA
     C**************************************************************************
     C           @UPD1     BEGSR
     C*
     C                     CLEARPLT
     C                     CLEARBOX
     C                     CLEARPLL
     C                     CLEARSRL
     C                     CLEARQTY
     C                     Z-ADD*ZERO     I
     C                     Z-ADD*ZERO     J
     C*
     C           KEY4      SETLLABR6P011
     C*
     C                     DO   *HIVAL
     C*
     C           KEY4      READEABR6P011                 93
     C   93                LEAVE
     C           FCSKJY    IFEQ 'D'
     C           FCPRNT    OREQ 'C'
     C                     ITER
     C                     END
     C*
     C           FCPRNT    IFEQ 'P'
     C                     MOVE *ON       *IN86
     C                     ELSE
     C                     MOVE *OFF      *IN86
     C                     ENDIF
     C*
     C           FCPBCD    IFEQ 'S'
     C* QTY/CONT CHANGED
     C           ISYOS     IFEQ FCUQTY
     C                     SETOF                     89
     C                     ELSE
     C                     SETON                     89
     C                     END
     C                     END
     C*
     C* SAVE SEQUENCE NUMBER
B02  C           FCPBCD    IFEQ 'M'
     C* REQUESTED QTY WAS CHANGED
     C           ISRYO     IFEQ FCRQTY
     C                     SETOF                     88
     C                     ELSE
     C                     SETON                     88
     C                     END
     C                     ADD  1         I
     C                     Z-ADDFCSEQ#    PLT,I            MASTER SEQ.
     C                     Z-ADDFCRQTY    QTY,I            MASTER SEQ.
     C                     ELSE
     C                     ADD  1         J
     C                     Z-ADDFCSEQ#    BOX,J            CONT. SEQ.
     C                     Z-ADDFC#PLT    PLL,J            CONT. SEQ.
     C                     MOVE FCSERL    SRL,J
     C                     END
     C*
     C                     MOVE 'D'       FCSKJY           DELETE CODE
     C                     Z-ADD2000      FCSKYY
     C                     ADD  WWYY      FCSKYY           UPDATE YEAR
     C                     Z-ADDWWMM      FCSKMM                  MONTH
     C                     Z-ADDWWDD      FCSKDD                  DAY
     C                     MOVELPUSR      FCKOME                  USER
     C                     UPDATABR6P011
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C**************************************************************************
     C*  @MOVE1 : SET ABR6P01
     C**************************************************************************
     C           @MOVE1    BEGSR
     C*
     C                     MOVE ' '       WWNVNA  1
     C* ONLY KANSAN:MIXED PALLETE
TCHK2C*          PSIRE     IFEQ '2855'
TCHK2C*          PSIRE     OREQ '2856'
TCHK2C*                    MOVE 'N'       WWNVNA
TCHK2C*                    ENDIF
      *
     C           WWNVNA    IFEQ 'N'
     C                     Z-ADD0         WWHAKO
     C                     ADD  1         W##PLT
     C                     ELSE
     C           W##PLT    IFEQ *ZERO
     C                     ADD  1         W##PLT
     C                     ENDIF
     C                     END
     C*
     C                     SETON                     87
     C                     Z-ADD*ZERO     WKRQTY
     C                     ADD  IHAKO     WTBOX
     C*
     C* CUMULATIVE NET,TARE WEIGHT PER PART
     C*            FOR TOTAL WEIGHT OF MANIFEST # FILE
     C*
     C           KEY2      CHAINFCEPL011             94
     C           *IN94     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     94
     C                     END
     C*
     C           *IN94     IFEQ '0'
     C                     Z-ADDA2KASI    WKASI            FINISHED WEIGHT
     C                     ELSE
     C                     Z-ADD0         WKASI   72
     C                     END
     C*
     C                     Z-ADDISRYO     WSRYO   60
     C*
     C* CALUCULATE ONE PART TOTAL NET WEIGHT
     C* (UNIT WEIGHT * QTY)/1000*2.22
     C           ISRYO     MULT WKASI     WKOT1  102       NET
     C           WKOT1     DIV  1000      WKOT2   72       G --> KG
     C           WKOT2     MULT 2.2046    WKOT3   92H      KG --> LB
     C                     ADD  WKOT3     TEIGH
     C*
     C                     CLEARABR6P011
     C*
     C                     Z-ADD2000      FCKOYY
     C                     ADD  WWYY      FCKOYY           UPDATE YEAR
     C                     Z-ADDWWMM      FCKOMM                  MONTH
     C                     Z-ADDWWDD      FCKODD                  DAY
     C                     Z-ADDWWHH      FCKOHH                  HOUR
     C                     Z-ADDWWNN      FCKONN                  MINUTE
     C                     MOVELPUSR      FCKOME                  USER
     C*
     C                     Z-ADDINOHZ     FCSHDT           SHIP DATE
     C                     Z-ADDINOTM     FCSHTM                TIME
     C                     MOVE ISIRE     FCSUPP           SUPPLIER
     C                     MOVE ISIRK     FCSFCT           FACTORY
     C                     MOVE INUKE     FCDOCK           DOCK
     C                     MOVE IODRN     FCORD#           OTDER#
     C                     MOVE ISBAN     FC####           KANBAN #
     C                     Z-ADDISRYO     FCRQTY           REQ. QTY.
     C                     Z-ADDISRYO     SVRQTY           REQ. QTY.(SAVE)
     C                     Z-ADDISYOS     FCUQTY           QTY/CONT.
     C                     MOVELISHN      FCIPAR           INTERNAL PART
     C                     Z-ADDITOKU     FCCUST           CUSTOMER CODE
     C                     Z-ADDIDELY     FCDELY           DELIVERY CODE
     C                     Z-ADDWREYY     FCRYYY           RELEASED YY
     C                     Z-ADDWREMM     FCRMMM                    MM
     C                     Z-ADDWREDD     FCRDDD                    DD
     C* EDIT PART NUMBER
     C***        WNO1      IFEQ 'W'
     C***        WNO1      OREQ 'N'
     C                     MOVE WNO2      WCNO2
     C                     MOVEL'-'       WCNO3
     C                     MOVELWNO3      WCNO4
     C***                  ELSE
     C***                  MOVE WNO4      WCNO5
     C***                  MOVE WNO5      WCNO7
     C***                  MOVELWNO6      WCNO9
     C***                  END
     C*
     C                     Z-ADD*ZERO     @@BOX   30
     C                     Z-ADD45        WBOX#   20
     C                     MOVE IDELY     WDEL##  4        DELIVERY CODE
     C           WDEL##    CHAINAB#PL901             34
     C           *IN34     IFEQ '0'
     C           YASKJY    ANDEQ' '
     C                     Z-ADDYAMXPL    WBOX#
     C                     END
     C*
     C* SET CONTAINER LABEL DATA
     C           1         DO   IHAKO
     C                     ADD  1         WWHAKO
     C                     ADD  1         @@BOX
     C*
     C           WWHAKO    IFGT WBOX#
     C*
     C* SET MASTER LABEL DATA
     C           WKRQTY    IFNE *ZERO
     C                     MOVE 'M'       FCPBCD
     C                     EXSR @SEQM
     C                     MOVE PMANI     FCASN#
     C                     Z-ADDWKRQTY    FCRQTY
     C                     Z-ADD*ZERO     WKRQTY
     C           @@BOX     SUB  1         FC#CON           # OF HAKO
     C                     Z-ADD1         @@BOX
     C                     MOVE *BLANK    FCSERL
     C                     WRITEABR6P011
     C                     END
     C* PALLETE NUMBER
     C                     Z-ADD1         WWHAKO
     C                     ADD  1         W##PLT
     C                     END
     C*
     C                     MOVE 'S'       FCPBCD
     C                     EXSR @SEQS
     C                     MOVE PMANI     FCASN#
     C*
     C                     Z-ADD*ZERO     FC#CON           # OF HAKO
     C                     ADD  ISYOS     WKRQTY
     C                     Z-ADDW##PLT    FC#PLT
     C                     Z-ADDSVRQTY    FCRQTY
     C                     Z-ADDFCSEQ#    @@SEQ#  60
     C*
     C                     WRITEABR6P011
     C                     END
     C*
     C* SET MASTER LABEL DATA
     C           WKRQTY    IFNE *ZERO
     C                     MOVE 'M'       FCPBCD
     C                     EXSR @SEQM
     C                     MOVE PMANI     FCASN#
     C                     Z-ADDWKRQTY    FCRQTY
     C                     Z-ADD*ZERO     WKRQTY
     C                     MOVE *BLANK    FCSERL
     C                     Z-ADD@@BOX     FC#CON           # OF HAKO
     C                     WRITEABR6P011
     C                     END
     C*
     C           WWNVNA    IFEQ ' '
     C                     ADD  W##PLT    W#PLT
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*  @SEQM : SET SEQ # AS MASTER LABEL
     C**************************************************************************
     C           @SEQM     BEGSR
     C*
     C* GET THE SEQUENCE NUMBER
     C** FIRST ORDER DATA
     C           *IN92     IFEQ '1'
     C*
     C           WSEQ#     IFEQ 999999
     C                     Z-ADD1         WSEQ#
     C                     ELSE
     C                     ADD  1         WSEQ#
     C                     END
     C                     Z-ADDWSEQ#     FCSEQ#
     C** AMENDED ORDER DATA
     C                     ELSE
     C*
     C                     ADD  1         M
     C           PLT,M     IFEQ *ZERO
     C           PLT,M     ORLT @@SEQ#
     C           WSEQ#     IFEQ 999999
     C                     Z-ADD1         WSEQ#
     C                     ELSE
     C                     ADD  1         WSEQ#
     C                     END
     C                     Z-ADDWSEQ#     FCSEQ#
     C                     MOVE ' '       FCPRNT
     C                     ELSE
     C                     Z-ADDPLT,M     FCSEQ#
     C           *IN86     IFEQ *ON
     C           QTY,M     ANDNE*ZERO
     C           QTY,M     ANDEQWKRQTY
     C                     MOVE 'P'       FCPRNT
     C                     END
     C                     END
     C*
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*  @SEQS : SET SEQ # AS BOX
     C**************************************************************************
     C           @SEQS     BEGSR
     C*
     C* GET THE SEQUENCE NUMBER
     C** FIRST ORDER DATA
     C           *IN92     IFEQ '1'
     C*
     C           WSEQ#     IFEQ 999999
     C                     Z-ADD1         WSEQ#
     C                     ELSE
     C                     ADD  1         WSEQ#
     C                     END
     C                     Z-ADDWSEQ#     FCSEQ#
     C                     MOVE *BLANK    FCSERL
     C           K#FW      CHAINABR6PW1              96
     C           *IN96     IFEQ *ON
     C                     Z-ADDFCSHDT    WCSHDT
     C                     Z-ADDFCSHTM    WCSHTM
     C                     MOVE FCDOCK    WCDOCK
     C                     Z-ADDFCCUST    WCCUST
     C                     Z-ADDFCDELY    WCDELY
     C                     Z-ADDW##PLT    WC#PLT
     C                     MOVE *BLANK    WCPRNT
     C                     Z-ADDFCRYYY    WCRYYY
     C                     Z-ADDFCRMMM    WCRMMM
     C                     Z-ADDFCRDDD    WCRDDD
     C                     WRITEABR6PW11
     C                     ELSE
     C                     MOVE *BLANK    WCPRNT
     C                     UPDATABR6PW11
     C                     END
     C*
     C** AMENDED ORDER DATA
     C                     ELSE
     C*
     C                     ADD  1         N
     C           BOX,N     IFEQ *ZERO
     C*
     C           WSEQ#     IFEQ 999999
     C                     Z-ADD1         WSEQ#
     C                     ELSE
     C                     ADD  1         WSEQ#
     C                     END
     C                     Z-ADDWSEQ#     FCSEQ#
     C                     MOVE ' '       FCPRNT
     C                     MOVE *BLANK    FCSERL
     C           K#FW      CHAINABR6PW1              96
     C           *IN96     IFEQ *ON
     C                     Z-ADDFCSHDT    WCSHDT
     C                     Z-ADDFCSHTM    WCSHTM
     C                     MOVE FCDOCK    WCDOCK
     C                     Z-ADDFCCUST    WCCUST
     C                     Z-ADDFCDELY    WCDELY
     C                     Z-ADDW##PLT    WC#PLT
     C                     MOVE *BLANK    WCPRNT
     C                     Z-ADDFCRYYY    WCRYYY
     C                     Z-ADDFCRMMM    WCRMMM
     C                     Z-ADDFCRDDD    WCRDDD
     C                     WRITEABR6PW11
     C                     ELSE
     C                     MOVE *BLANK    WCPRNT
     C                     UPDATABR6PW11
     C                     ENDIF
     C                     ELSE
     C                     Z-ADDBOX,N     FCSEQ#
     C                     MOVE SRL,N     FCSERL
     C           PLL,N     IFNE W##PLT
     C           K#FW      CHAINABR6PW1              96
     C           *IN96     IFEQ *ON
     C                     Z-ADDFCSHDT    WCSHDT
     C                     Z-ADDFCSHTM    WCSHTM
     C                     MOVE FCDOCK    WCDOCK
     C                     Z-ADDFCCUST    WCCUST
     C                     Z-ADDFCDELY    WCDELY
     C                     Z-ADDW##PLT    WC#PLT
     C                     MOVE *BLANK    WCPRNT
     C                     Z-ADDFCRYYY    WCRYYY
     C                     Z-ADDFCRMMM    WCRMMM
     C                     Z-ADDFCRDDD    WCRDDD
     C                     WRITEABR6PW11
     C                     ELSE
     C                     MOVE *BLANK    WCPRNT
     C                     UPDATABR6PW11
     C                     END
     C                     END
     C           *IN89     IFEQ *ON
     C                     MOVE ' '       FCPRNT
     C                     ELSE
     C           SRL,N     IFNE *BLANK
     C                     MOVE 'P'       FCPRNT
     C                     ELSE
     C                     MOVE ' '       FCPRNT
     C                     END
     C                     END
     C                     END
     C*
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*  @END : END
     C**************************************************************************
     C           @END      BEGSR
     C*
     C                     CLOSEABR6L02
     C*
     C* WRITE OR UPDAT MANIFEST #
     C* (ASN NEEDS HAKO&WEIT, SO WRITE MANIFEST HERE AFTER PROCESS.)
     C                     Z-ADD2000      YBKOYY
     C                     ADD  WWYY      YBKOYY           UPDATE YEAR
     C                     Z-ADDWWMM      YBKOMM                  MONTH
     C                     Z-ADDWWDD      YBKODD                  DAY
     C                     Z-ADDWWHH      YBKOHH                  HOUR
     C                     Z-ADDWWNN      YBKOSS                  MINUTE
     C                     MOVELPUSR      YBKOME                  USER
     C                     Z-ADDWSIRE     YBSUPP           DELIVERY
     C                     Z-ADDWNOHZ     YBSHDT           SHIP DATE
     C                     Z-ADDWBIN      YBBIN                 BIN
     C                     MOVE PDOCK     YBDOCK           RECEVING
     C                     Z-ADDWTBOX     YBCONT           TOTAL # OF BOXES
     C                     Z-ADD*ZERO     YBNOHZ           INVOICE DATE
     C*
     C                     Z-ADDW##PLT    YB#PAL
     C*
      *
     C* CALUCULATE TARE
     C* (0.7 * HAKO) + (23.675 * PALLETE)
     C           0.7       MULT WTBOX     WEIGH   62
     C                     ADD  WEIGH     WTARE
     C           23.675    MULT YB#PAL    WEIGH
     C                     ADD  WEIGH     WTARE
     C*
     C                     Z-ADDTEIGH     YBWEIT           NET   WEIGHT
     C                     Z-ADDWTARE     YBTARE           TARE  WEIGHT
     C                     MOVE *BLANK    YBTRIL           TRAILER #
     C                     MOVE PMANI     YBMANI
     C                     Z-ADDWREYY     YBREYY           UPDATE YEAR
     C                     Z-ADDWREMM     YBREMM                  MONTH
     C                     Z-ADDWREDD     YBREDD                  DAY
     C*
     C* PRINT P/S AT THE FIRST TIME
     C           *IN92     IFEQ '1'
     C* GET PACKING SLIP NUMBER
     C                     READ ABRGP01R                 95
     C                     Z-ADD2000      QAKOYY
     C                     ADD  WWYY      QAKOYY           UPDATE YEAR
     C                     Z-ADDWWMM      QAKOMM                  MONTH
     C                     Z-ADDWWDD      QAKODD                  DAY
     C                     Z-ADDWWHH      QAKOHH                  HOUR
     C                     Z-ADDWWNN      QAKOSS                  MINUTE
     C                     MOVELPUSR      QAKOME                  USER
     C* SET P/S# TO PAKING SLIP NUMBER FILE
     C           *IN95     IFEQ '1'
     C                     Z-ADD1         QAPS#
     C                     WRITEABRGP01R
     C                     ELSE
     C                     ADD  1         QAPS#
     C                     UPDATABRGP01R
     C                     END
     C* IF  1ST.TIME,SET P/S#
     C* NOT 1ST.TIME,USE PRSENT P/S#
     C                     Z-ADDQAPS#     YBPS#
     C                     END
     C                     Z-ADDYBPS#     PPS#
     C   92                WRITEABR4P011
