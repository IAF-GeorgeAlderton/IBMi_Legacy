     C******************************************************
     C*  LET'S  PRINT-OUT                                  *
     C******************************************************
     C*
     C           KEY1      KLIST
     C                     KFLD           TOKU
     C                     KFLD           HIN1
     C                     KFLD           HIN2
     C                     KFLD           HIN3
     C*
     C           KEY2      KLIST
     C                     KFLD           HIN1
     C                     KFLD           HIN2
     C                     KFLD           HIN3
     C*
     C           KEY1      CHAINFMAPL011             10
     C           *IN,10    IFEQ '0'
     C           FMSKJY    ANDEQ'D'
     C           FMSKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,10
E001 C                     END
     C*
B001 C           *IN,10    IFEQ '0'
     C                     MOVELFMDESC    DESC   10
     C           FMSYOS    CABEQ0         @END
     C           NOSU      DIV  FMSYOS    XXX     30
E001 C                     END
     C*
     C                     Z-ADD0         CNT     20
B001 C                     DO   XXX       I       30
     C                     ADD  1         CNT
B002 C           CNT       IFEQ 1
     C                     MOVEA'0'       *IN,80
     C                     MOVELFMCHIN    CHIN1
     C                     Z-ADDFMSYOS    SYOS1
     C                     MOVELFMHIN1    HIN1A
     C                     MOVELFMHIN2    HIN1B
     C                     MOVELDESC      NAM1
     C                     Z-ADDNOYY      YY1
     C                     Z-ADDNOMM      MM1
     C                     Z-ADDNODD      DD1
