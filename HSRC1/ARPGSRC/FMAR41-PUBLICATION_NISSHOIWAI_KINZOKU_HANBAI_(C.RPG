     C                     MOVEL'/'       @AA
     C                     MOVEL'/'       @BB
     C                     Z-ADD@YMD      YMD1
     C                     MOVELFMNO      NO1
     C                     Z-ADDXXX       BNB1
     C                     Z-ADDI         X1
B003 C           FMYOR1    IFEQ '1'
     C                     MOVEL'YOR'     YOR1
X003 C                     ELSE
     C                     MOVE *BLANK    YOR1
E003 C                     END
     C*
B003 C           FMMII1    IFEQ '1'
     C                     MOVEL'M-II'    MI1
X003 C                     ELSE
     C                     MOVE *BLANK    MI1
E003 C                     END
     C*
     C                     MOVE *BLANK    SHN1
     C                     MOVELSHIN1     SHN1A
     C                     MOVELSHIN2     SHN1C
B003 C           SHN1C     IFNE *BLANK
     C                     MOVEL'-'       SHN1B
E003 C                     END
     C*
     C                     MOVE *BLANK    TKR1
     C           KEY2      CHAINFCEPL011             11
B003 C           *IN,11    IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,11
E003 C                     END
     C*
B003 C           *IN,11    IFEQ '0'
B004 C           A2TRHZ    IFGT *DATE
     C                     MOVELA2KTRK    TKR1A
     C                     MOVELA2KTRT    TKR1C
     C                     MOVELA2KTRR    TKR1E
     C                     MOVELA2KTRD    TKR1G
X004 C                     ELSE
     C                     MOVELA2STRK    TKR1A
     C                     MOVELA2STRT    TKR1C
     C                     MOVELA2STRR    TKR1E
     C                     MOVELA2STRD    TKR1G
E004 C                     END
B004 C           TKR1C     IFNE *BLANK
     C                     MOVEL'-'       TKR1B
E004 C                     END
     C*
B004 C           TKR1E     IFNE *BLANK
     C                     MOVEL'-'       TKR1D
E004 C                     END
     C*
B004 C           TKR1G     IFNE *BLANK
     C                     MOVEL'-'       TKR1F
E004 C                     END
E003 C                     END
     C*
     C                     MOVEL'*'       SW
E002 C                     END
     C*
B002 C           CNT       IFEQ 2
     C                     MOVEA'1'       *IN,80
     C                     MOVELFMCHIN    CHIN2
     C                     Z-ADDFMSYOS    SYOS2
     C                     MOVELFMHIN1    HIN2A
     C                     MOVELFMHIN2    HIN2B
