     C           *IN02     IFEQ '0'
     C                     SETON                     02
     C           *ENTRY    PLIST
     C                     PARM           PYM     6
     C                     MOVE PYM       WYM
     C                     Z-ADDWYM       KYM
      *
     C*----------------------------------*
     C*   ..Ｎ－１月　の　日付決定..   *
     C*----------------------------------*
     C           KMM       IFEQ 01
     C                     SUB  1         KYY
     C                     Z-ADD12        KMM
     C                     ELSE
     C                     SUB  1         KMM
     C                     END
     C                     END
      *
     C           *INL1     IFEQ '1'
     C                     Z-ADD0         N1
     C                     END
      *
     C           KYM       IFEQ ANOYM
     C                     Z-ADDANODD     A       20
     C                     ADD  ASURY     N1,A
     C                     END
      *
     CL1                   EXSR SUBRTN
      *
     C           SUBRTN    BEGSR
     C                     MOVE ASHIN     Q5SHIN
     C                     XFOOTN1        Q5N1NM
     C                     WRITEABBNP171
     C                     ENDSR
