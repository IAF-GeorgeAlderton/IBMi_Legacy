     H            Y.
      ** AB#RFU **********************************************
      *  FORD FABRICATION & RAW MATERIAL                     *
      *  K.KASHIWAGI 03.20.2001                              *
      *  K.KASHIWAGI 04.17.2001 ADD SCREEN FOR ENTERING PART#*
      ********************************* AB#RFU ***************
      * F3 - EXIT
      ********************************* AB#RFU ***************
     FABFPL30 IF  E           K        DISK
     FABFPL14 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *
     I            DS
     I                                        1   80DATE
     I                                        1   20W@CT
     I                                        3   40W@YY
     I                                        5   60W@MM
     I                                        7   80W@DD
     I            DS
     I                                        1   80DATE2
     I                                        1   40W@YY2
     I                                        5   60W@MM2
     I                                        7   80W@DD2
     I            DS
     I                                        1   80KDATE2
     I                                        1   40KW@YY
     I                                        5   60KW@MM
     I                                        7   80KW@DD
     I            DS
     I                                        1  120#TIME
     I                                        1   20W@HH
     I                                        3   40W@MIN
     I                                        5   60W@SS
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     C*
     C           KEY1      KLIST
     C                     KFLD           KIPAR  12        PART#
     C                     KFLD           KDOCK   5        DOCK
     C                     KFLD           KSIDT   60       SCHED DATE
     C                     KFLD           KREL#  10        RELEASE#
     C                     KFLD           KFIED   60       FAB END DATE
     C*
     C           KEY2      KLIST
     C                     KFLD           KIPAR  12        PART#
     C                     KFLD           KDOCK   5        DOCK
     C                     KFLD           KSIDT   60       SCHED DATE
     C                     KFLD           KREL#  10        RELEASE#
     C*
     C           KEY3      KLIST
     C                     KFLD           DPART  12        PART#
      *--------------*
      * MAIN ROUTINE *
      *--------------*
     C                     EXSR @INTR
     C                     EXSR @PRT
     C*
     C                     SETON                     LR
     C                     RETRN
      *---------------*
      * INITIALIZATION
      *---------------*
     C           @INTR     BEGSR
     C                     TIME           #TIME
     C                     MOVE *DATE     DATE
     C                     Z-ADD2000      W@YY4   40
     C                     ADD  W@YY      W@YY4
     C                     MOVE *ALL'-'   LINE  100
     C                     ENDSR
      *---------------*
      * WRITE SUBFILE
      *---------------*
     C           @PRT      BEGSR
     C           *IN90     DOUEQ*ON
     C                     READ ABFPP301                 90
     C           *IN90     IFEQ *OFF
     C* FOR KEY1
     C                     MOVELCGPART    KIPAR
     C                     MOVELCGDOCK    KDOCK
     C                     MOVE CGSIDT    KSIDT
     C                     MOVELCGPOR#    KREL#
     C                     MOVE *HIVAL    KFIED
     C*
     C                     SETOF                     85
     C           KEY1      SETGTABFPP101
     C           KEY2      REDPEABFPP101                 85
     C           *IN85     IFEQ '0'
     C*
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
     C  N98                MOVE *ON       *IN98
     C                     MOVELFBIPAR    SPART  12
     C                     MOVELFBDOCK    SDOCK   5
     C                     Z-ADDFBFIED    SFIED   80
     C           SFIED     IFNE 0
     C                     ADD  20000000  SFIED
     C                     ENDIF
     C                     Z-ADDFBFIQT    SFIQT  100
     C                     Z-ADDFBMTED    SMTED   80
     C           SMTED     IFNE 0
     C                     ADD  20000000  SMTED
     C                     ENDIF
     C                     Z-ADDFBMTQT    SMTQT  100
     C                     Z-ADDFBSHLD    SSHLD   80
     C           SSHLD     IFNE 0
     C                     ADD  20000000  SSHLD
     C                     ENDIF
     C                     Z-ADDFBSHQT    SSHQT  100
     C                     EXCPT@DTL
     C                     ENDIF
     C*
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C*
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                         UDATE Y  110
     O                                  112 'P.'
     O                         PAGE  Z  116
     O        E   02           @HED
     O                                   50 'FORD FABRICATION AND RAW'
     O                                   66 'MATERIAL REPORT'
     O        E   04           @HED
     O                                   45 '<<  FABRICATION  >>'
     O                                   95 '<<  RAW MATERIAL >>'
     O        E   05           @HED
     O                                    6 'PART #'
     O                                   19 'DOCK'
     O                                   31 'END DATE'
     O                                   45 'CUM QTY'
     O                                   57 'LAST SHIP'
     O                                   70 'SHIP CUM.'
     O                                   81 'END DATE'
     O                                   95 'CUM QTY'
     O        E   06           @HED
     O                         LINE     100
     O        E 1              @DTL
     O                         SPART  B  12
     O                         SDOCK  B  20
     O                         SFIED  B  32 '    /  /  '
     O                         SFIQT 1B  45
     O                         SSHLD  B  57 '    /  /  '
     O                         SSHQT 1B  70
     O                         SMTED  B  82 '    /  /  '
     O                         SMTQT 1B  95
