     H            Y.
     F***CHKR73*****************************************************************
     F*  PROGRAM    : PRINT SUBARU ADJUSTED FULL BOX QTY REPORT                *
     F*  WRITTEN    : 7/22/2019                                                *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#EL4S1IF  E           K        DISK
     FAB#PL10AIF  E           K        DISK
     FAB#EL62SIF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      **************************************************************************
     I            DS
     I                                        1  20 BAMHIN
     I                                        1   5 BAMHN1
     I                                        6  10 BAMHN2
     I                                       11  15 BAMHN3
     I                                       16  20 BAMHN4
     I            DS
     I                                        1   80BANOHZ
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I            DS
     I                                        1   80BAURHZ
     I                                        1   40BAURYY
     I                                        5   60BAURMM
     I                                        7   80BAURDD
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           K#EP40    SETLLAB#EL4S1
      *
     C                     DO   *HIVAL
     C                     READ AB#EL4S1                 98
     C   98                LEAVE
      *
     C                     MOVELEPRTNR    LTR6    6
     C           LTR6      IFNE 'SUBARU'
     C                     LEAVE
     C                     ENDIF
      * GET IAF ORDER QTY
     C                     EXSR #PP10A
      *
     C           @SHP      IFGE ESRYO
     C                     ITER
     C                     ENDIF
      *
     C           P10CNT    IFEQ 1
     C           @QTY      ANDGTESRYO
     C                     ADD  1         SEQ#
     C                     EXSR #PRINT
     C                     ENDIF
      *
     C           P10CNT    IFGE 2
     C                     EXSR #PP10B
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           SEQ#      IFGE 1
     C           SVDATE    ANDGETODAY
     C                     MOVE '*'       $PRNT
     C                     ELSE
     C                     MOVE ' '       $PRNT
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  GET ORDER TOTAL                                   *
      *----------------------------------------------------*
     C           #PP10A    BEGSR
      *
     C                     Z-ADD0         @SHP
     C                     Z-ADD0         @QTY
     C                     Z-ADD0         @BOX
     C                     Z-ADD0         P10CNT
      *
     C                     MOVELEODRN     K#ODRN
     C                     MOVELEMHIN     K#MHIN
     C                     Z-ADD3611      K#NONY
     C                     Z-ADDENDATE    K#NOHZ
     C           K#PP10    SETLLAB#PL10A
      *
     C                     DO   *HIVAL
     C           K#PP10    READEAB#PL10A                 96
     C   96                LEAVE
      *
     C           BASKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         P10CNT
     C                     ADD  BASRYO    @QTY
      *
     C           BAURYY    IFNE 0
     C                     ADD  BASRYO    @SHP
     C                     ENDIF
      *
     C           BASYOS    IFEQ 0
     C                     Z-ADD999       @BOX
     C                     ELSE
     C           BASRYO    DIV  BASYOS    WBOX    30
     C                     ENDIF
      *
     C                     ADD  WBOX      @BOX
     C                     MOVELBATOKU    WTOKU   4
     C                     MOVELBANONY    WNONY   4
     C                     MOVELBAMHIN    WMHIN  15
     C                     MOVELBANOHZ    WNOHZ
     C                     MOVELBANOBN    WBIN
     C                     Z-ADDBASYOS    WSYOS   60
     C                     MOVELBAODRN    WODRN
      *
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  DETAIL                                            *
      *----------------------------------------------------*
     C           #PP10B    BEGSR
      *
     C                     Z-ADD0         P10CNT
      *
     C                     MOVELEODRN     K#ODRN
     C                     MOVELEMHIN     K#MHIN
     C                     Z-ADD3611      K#NONY
     C                     Z-ADDENDATE    K#NOHZ
     C           K#PP10    SETLLAB#PL10A
      *
     C                     DO   *HIVAL
     C           K#PP10    READEAB#PL10A                 96
     C   96                LEAVE
      *
     C           BASKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADDBASRYO    @QTY
      *
     C           BASYOS    IFEQ 0
     C                     Z-ADD999       @BOX
     C                     ELSE
     C           BASRYO    DIV  BASYOS    @BOX
     C                     ENDIF
      *
     C                     ADD  1         P10CNT
      *
     C           P10CNT    IFEQ 1
     C                     MOVELBATOKU    WTOKU   4
     C                     MOVELBANONY    WNONY   4
     C                     MOVELBAMHIN    WMHIN  15
     C                     MOVELBAODRN    WODRN
     C                     ADD  1         SEQ#
     C                     ELSE
     C                     MOVEL'"'       WTOKU     P
     C                     MOVEL'"'       WNONY     P
     C                     MOVEL'"'       WMHIN     P
     C                     MOVEL'"'       WODRN     P
     C                     ENDIF
      *
     C                     MOVELBANOHZ    WNOHZ
     C                     MOVELBANOBN    WBIN
     C                     Z-ADDBASYOS    WSYOS   60
      *
     C                     EXSR #PRINT
      *
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      * GET ASN#
     C                     MOVE *BLANK    WSHID
      *
     C           WTOKU     IFEQ '"'
     C                     MOVEL'3611'    K1PRTN    P
     C                     MOVELBAODRN    K1ORDN
     C                     Z-ADDBAURHZ    K1CRDT
     C                     Z-ADDBASRYO    K1SRYO
     C                     ELSE
     C                     MOVEL'3611'    K1PRTN    P
     C                     MOVELWODRN     K1ORDN
     C                     Z-ADDWNOHZ     K1CRDT
     C                     Z-ADD@QTY      K1SRYO
     C                     ENDIF
      *
     C           K#EP62    CHAINAB#EL62S             99
     C           *IN99     IFEQ *OFF
     C                     MOVELE3SHID    WSHID
     C                     ENDIF
      * PRINT HEADER
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD5         LIN#
     C                     ENDIF
      * PRINT BREAK
     C           SODRN     IFNE *BLANK
     C           EODRN     ANDNESODRN
     C                     EXCPT@BRK
     C                     ADD  1         LIN#
     C                     ENDIF
      * PRINT DETAIL
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      * SAVE ORDER#
     C                     MOVELEODRN     SODRN
     C                     Z-ADDENDATE    SVDATE
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $DATE   8
     C                     PARM           $PRNT   1
      *
     C           K#EP40    KLIST
     C                     KFLD           @PTNR
     C                     KFLD           @DATE
      *
     C           K#EP62    KLIST
     C                     KFLD           K1PRTN 10
     C                     KFLD           K1ORDN 10
     C                     KFLD           K1CRDT  80
     C                     KFLD           K1SRYO  70
      *
     C           K#PP10    KLIST
     C                     KFLD           K#ODRN 10
     C                     KFLD           K#MHIN 20
     C                     KFLD           K#NONY  40
     C                     KFLD           K#NOHZ  80
      *
     C                     MOVEL'SUBARU  '@PTNR  10 P
     C                     MOVEL$DATE     @DATE   80
     C                     TIME           @SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     Z-ADD0         @QTY    70
     C                     Z-ADD0         @SHP    70
     C                     Z-ADD0         @BOX    30
     C                     Z-ADD0         P10CNT  20
     C                     Z-ADD0         WNOHZ   80
     C                     MOVE *BLANK    WODRN  10
     C                     MOVE *BLANK    WBIN    2
     C                     MOVE *BLANK    SODRN  10        SAVE ORD#
     C                     MOVE *BLANK    WSHID  10        ASN#
     C                     Z-ADD0         SVDATE  80
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** SUBARU ORDER QTY '
     O                                   60 '(ADJUSTED TO BE FULL'
     O                                   80 ' BOX QTY) **        '
     O                                   99 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                         PAGE  Z  109
     O                                  106 'P.'
     O        E   03           @HDR
     O                                   47 'EDI'
     O                                   60 'IAF'
     O                                   81 'EDI'
     O                                   94 'ADJUSTED'
     O                                  107 'IAF'
     O        E 1              @HDR
     O                                    5 'SEQ#'
     O                                   10 'CUST'
     O                                   15 'DELV'
     O                                   23 'ORDER#'
     O                                   38 'USER PART'
     O                                   52 'REQUIRED'
     O                                   64 'SHIPPED'
     O                                   72 'BIN#'
     O                                   81 'QTY'
     O                                   94 'QTY'
     O                                  100 'BOX'
     O                                  107 'Q/C'
     O                                  113 'ASN#'
     O        E 1              @HDR
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O                                  120 '--------------------'
     O                                  130 '----------'
     O        E 1              @DTL
     O                         SEQ#  Z +001
     O                         WTOKU   +001
     O                         WNONY   +001
     O                         WODRN   +002
     O                         WMHIN   +002
     O                         ENDATE  +000 '    /  /  '
     O                         WNOHZ   +003 '    /  /  '
     O                         WBIN    +002
     O                         ESRYO 1 +001
     O                                 +001 '-->'
     O                         @QTY  1 +000
     O                         @BOX  1 +003
     O                         WSYOS 1 +000
     O                         WSHID   +002
     O        E 1              @BRK
     O                                    1 '.'
