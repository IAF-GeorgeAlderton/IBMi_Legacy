     H            Y/
     F***************************************************
     F* MATERIAL ORDER INQUIRY  (LATEST 6 DAYS)         *
     F* JW     2018/10/09                               *
JW1  F* JW1    2021/03/18 ADD SUPP (POSCO, TSUSHO)      *
     F***************************************************
     FGDLPW76 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FGDLPL14 IF  E           K        DISK
     FGDLPL1B IF  E           K        DISK
     F            GDLPP101                          KRENAMEGDLPP1B1
     FIZAPL01 IF  E           K        DISK
      *------------------------------------------------------------
     E                    CMD     1   1 78
     E                    DT8         6  8 0
     E                    DT6         6  6 0
     E                    QTD         6  7 0
     E                    QTT         6  7 0
     E                    DAY         6  5
      *
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
      *
     I            DS
     I                                        1  30 DAYX
     I                                        1   5 D@DAY1
     I                                        6  10 D@DAY2
     I                                       11  15 D@DAY3
     I                                       16  20 D@DAY4
     I                                       21  25 D@DAY5
     I                                       26  30 D@DAY6
      *
     I            DS
     I                                        1   80LBODHZ
     I                                        1   40LBODRY
     I                                        5   60LBODRM
     I                                        7   80LBODRD
      *
     I            DS
     I                                        1   80@YMD
     I                                        1   40@YY
     I                                        5   60@MM
     I                                        7   80@DD
      *
     I            DS
     I                                        1   5 @DAY
     I                                        1   20@DMM
     I                                        3   3 @DP1
     I                                        4   50@DDD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C                     EXSR #INIT
      *
     C                     EXSR #SET
      * DISPLAY
     C           W@ID      DOWNE'99'
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     WRITEDSP98
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      * F2: GO BACK
     C           *INKB     IFEQ *ON
     C                     MOVEL'99'      W@ID
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *   SET DATA
      *------------------------------------------------------
     C           #SET      BEGSR
      * CLEAR SFL
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD0         RRN1
     C                     Z-ADD0         QTD
     C                     Z-ADD0         QTT
      *
     C           *LOVAL    SETLLIZAPL01
     C                     DO   *HIVAL
     C                     READ IZAPL01                  80
     C   80                LEAVE
      * SELECT
     C           ZCSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * SELECT
     C           ZCSTYY    IFNE 9999
     C                     ITER
     C                     ENDIF
      * SELECT
     C           D@SUPL    IFEQ *BLANK
     C           D@SUPL    ORNE *BLANK
     C           ZCKAKE    ANDEQP@SUPL
      *  GET QTY
     C                     Z-ADD0         QTD
     C                     MOVE 'N'       XFLG    1
     C           1         DO   6         IX
      * READ GDLPL14
     C                     Z-ADDDT8,IX    @YMD
     C                     MOVELZCZAIS    K@ZAIS
     C                     Z-ADDZCZAIK    K@ZAIK
     C                     Z-ADD@YY       K@ODRY
     C                     Z-ADD@MM       K@ODRM
     C                     Z-ADD@DD       K@ODRD
     C           K#GDL     SETLLGDLPL14
      *
     C                     DO   *HIVAL
     C           K#GDL     READEGDLPL14                  81
     C   81                LEAVE
      *
     C           LBSIRE    IFNE ZCKAKE
     C                     ITER
     C                     ENDIF
      *
     C           D@SUPL    IFNE *BLANK
     C           LBSIRE    ANDNEP@SUPL
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE 'Y'       XFLG
     C           LBMAIS    MULT ZCTKJR    WQTY    80
     C                     ADD  WQTY      QTD,IX
     C                     ADD  WQTY      QTT,IX
     C                     ENDDO                           READ GDLPL14
     C                     ENDDO                           6 TIMES
      * WRITE SFL
     C           XFLG      IFEQ 'Y'
     C           D@SUPL    IFEQ *BLANK
     C           D@SUPL    ORNE *BLANK
     C           ZCKAKE    ANDEQP@SUPL
     C                     EXSR #WRT
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO                           READ IZAPL01
      * SET TOTAL QTY
     C                     Z-ADDQTT,1     D@QTY1
     C                     Z-ADDQTT,2     D@QTY2
     C                     Z-ADDQTT,3     D@QTY3
     C                     Z-ADDQTT,4     D@QTY4
     C                     Z-ADDQTT,5     D@QTY5
     C                     Z-ADDQTT,6     D@QTY6
      * IF NO DATA...
     C           RRN1      IFEQ 0
     C                     CLEARSFL01
     C                     MOVEL'NO DATA!'S@ZAIS
     C                     Z-ADD1         RRN1
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  WRITE SFL
      *------------------------------------------------------
     C           #WRT      BEGSR
      *
     C                     CLEARSFL01
     C                     MOVELLBZAIS    S@ZAIS
     C                     Z-ADDLBZAIK    S@ZAIK
      * SUPPLIER
     C                     SELEC
     C           LBSIRE    WHEQ 8990
     C                     MOVEL'ASJ'     S@SUPL
     C           LBSIRE    WHEQ 4511
     C                     MOVEL'O&K'     S@SUPL
     C           LBSIRE    WHEQ 4530
     C                     MOVEL'NSC'     S@SUPL
JW1  C           LBSIRE    WHEQ 4540
 .   C                     MOVEL'CHT'     S@SUPL
 .   C           LBSIRE    WHEQ 4550
 .   C                     MOVEL'POS'     S@SUPL
 .   C           LBSIRE    WHEQ 4560
JW1  C                     MOVEL'TSU'     S@SUPL
     C                     OTHER
     C                     MOVE *BLANK    S@SUPL
     C                     ENDSL
      *
     C           ZCMKJR    DIV  20        S@SETG    H
      *
     C                     Z-ADDQTD,1     S@QTY1
     C                     Z-ADDQTD,2     S@QTY2
     C                     Z-ADDQTD,3     S@QTY3
     C                     Z-ADDQTD,4     S@QTY4
     C                     Z-ADDQTD,5     S@QTY5
     C                     Z-ADDQTD,6     S@QTY6
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
      *
     C                     ENDSR
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           D@SUPL  1
      *
     C           K#GDL     KLIST
     C                     KFLD           K@ZAIS 15
     C                     KFLD           K@ZAIK  52
     C                     KFLD           K@ODRY  40
     C                     KFLD           K@ODRM  20
     C                     KFLD           K@ODRD  20
      *
     C           K#1B      KLIST
     C                     KFLD           K@ODYY  40
     C                     KFLD           K@ODMM  20
     C                     KFLD           K@ODDD  20
      *
     C                     Z-ADD0         RRN1    40
     C                     MOVEL'01'      W@ID    2
     C                     MOVE '/'       @DP1
     C                     Z-ADD9999      K@ODYY
     C                     Z-ADD99        K@ODMM
     C                     Z-ADD99        K@ODDD
      * SET SUPPLIER
     C                     SELEC
     C           D@SUPL    WHEQ '1'
     C                     Z-ADD8990      P@SUPL  40       ASJ
     C                     MOVEL'8990'    D@SUPP
     C                     MOVE 'ASJ '    D@SUPP
      *
     C           D@SUPL    WHEQ '2'
     C                     Z-ADD4511      P@SUPL           O&K
     C                     MOVEL'4511'    D@SUPP
     C                     MOVE 'O&K '    D@SUPP
      *
     C           D@SUPL    WHEQ '3'
     C                     Z-ADD4530      P@SUPL           NSCI
     C                     MOVEL'4530'    D@SUPP
     C                     MOVE 'NSCI'    D@SUPP
      *
JW1  C           D@SUPL    WHEQ '4'
 .   C                     Z-ADD4540      P@SUPL           CHARTER
 .   C                     MOVEL'4540'    D@SUPP
 .   C                     MOVE 'CHRT'    D@SUPP
 .    *
 .   C           D@SUPL    WHEQ '5'
 .   C                     Z-ADD4550      P@SUPL           POSCO
 .   C                     MOVEL'4550'    D@SUPP
 .   C                     MOVE 'POSC'    D@SUPP
 .    *
 .   C           D@SUPL    WHEQ '6'
 .   C                     Z-ADD4560      P@SUPL           TSUSHO
 .   C                     MOVEL'4560'    D@SUPP
JW1  C                     MOVE 'TSHO'    D@SUPP
      *
     C                     OTHER
     C                     Z-ADD0         P@SUPL           ALL
     C                     MOVEL'*ALL'    D@SUPP
     C                     MOVE '    '    D@SUPP
     C                     ENDSL
      * GET LATEST 6 DAYS
     C                     EXSR #DAY
      *
     C                     ENDSR
      *------------------------------------------------------
      *   GET DATE
      *------------------------------------------------------
     C           #DAY      BEGSR
      *
     C                     Z-ADD0         IX      20
     C                     Z-ADD0         SVODHZ  80
     C           K#1B      SETGTGDLPL1B
      *
     C                     DO   *HIVAL
     C                     READPGDLPL1B                  98
     C   98                LEAVE
      * SELECT
     C           LBSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * SELECT
     C           D@SUPL    IFNE *BLANK
     C           LBSIRE    IFNE P@SUPL
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      *
     C           LBODHZ    IFNE SVODHZ
     C                     ADD  1         IX
     C                     Z-ADDLBODHZ    DT8,IX
     C                     Z-ADDLBODHZ    DT6,IX
     C                     Z-ADDLBODHZ    SVODHZ
     C                     ENDIF
      * END?
     C           IX        IFGE 6
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO                           READP GDLPL1B
      * CREATE HEADER
     C           1         DO   6         IX
     C                     Z-ADDDT8,IX    @YMD
     C                     Z-ADD@MM       @DMM
     C                     Z-ADD@DD       @DDD
     C                     MOVEL@DAY      DAY,IX
     C                     ENDDO
      *
     C                     MOVEADAY       DAYX
      *
     C                     ENDSR
      *------------------------------------------------------
**  CMD
F2:GO BACK,   PAGE UP/DOWN
