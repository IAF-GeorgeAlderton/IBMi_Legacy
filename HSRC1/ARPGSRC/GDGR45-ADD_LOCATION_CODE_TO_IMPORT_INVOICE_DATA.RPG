     H            Y/
     F***************************************************
     F*   ADD LOCATION CODE TO IMPORT INVOICE DATA      *
     F*           JAN/13/03                             *
     F*                                                 *
     F*                                                 *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FGDGPW45 CF  E                    WORKSTN
     F                                              KINFDS @INFDS
     FGINWP01 UF  E                    DISK
     FAAPTL01 IF  E           K        DISK
     FAANPL06 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FAKBPL04 IF  E           K        DISK
      *------------------------------------------------------------
     E                    AR1        30  1
     E                    AR2        30  1
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1  30 @@PRT
     I                                        1   5 K@PRT1
     I                                        6  10 K@PRT2
     I                                       11  12 K@PRT3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#KEY     KLIST
     C                     KFLD           K@PRT1  5
     C                     KFLD           K@PRT2  5
     C                     KFLD           K@PRT3  2
     C                     MOVEL'01'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C           *INKE     WHEQ *ON
     C                     EXSR #UPD
     C                     MOVEL'99'      W@ID
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   UPDATE
      *------------------------------------------------------
     C           #UPD      BEGSR
      *
     C           *IN90     DOUEQ*ON
      *
     C                     READ GINWP01                  90
     C           *IN90     IFEQ *OFF
      *
     C                     MOVE *BLANK    WLOC1
     C                     MOVE *BLANK    WLOC2
     C                     MOVE *BLANK    WLOC3
     C                     MOVE *BLANK    WLOC4
     C           WPART     IFNE *BLANK
     C                     MOVEAWPART     AR1
     C                     MOVE *BLANK    AR2
     C                     Z-ADD*ZERO     Y       20
     C           1         DO   30        X       20
     C           AR1,X     IFNE *BLANK
     C           AR1,X     ANDNE'-'
     C                     ADD  1         Y
     C                     MOVE AR1,X     AR2,Y
     C                     ENDIF
     C                     ENDDO
     C                     MOVEAAR2       @@PRT
      *
     C           K#KEY     SETLLFCEPL01
     C           *IN80     DOUEQ*ON
     C           K#KEY     READEFCEPL01                  80
     C           *IN80     IFEQ *OFF
     C           A2GSKD    ANDEQ*BLANK
     C                     MOVE A2STRK    WLOC1
     C                     MOVE A2STRT    WLOC2
     C                     MOVE A2STRR    WLOC3
     C                     MOVE A2STRD    WLOC4
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      * WASHER
     C           *IN80     IFEQ *ON
     C           K#KEY     SETLLAKBPL04
     C           *IN80     DOUEQ*ON
     C           K#KEY     READEAKBPL04                  80
     C           *IN80     IFEQ *OFF
     C           L1SKJY    ANDEQ*BLANK
     C           L1STYY    ANDEQ9999
     C                     MOVE L1TKR1    WLOC1
     C                     MOVE L1TKR2    WLOC2
     C                     MOVE L1TKR3    WLOC3
     C                     MOVE L1TKR4    WLOC4
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      * HALF PRODUCT
     C           *IN80     IFEQ *ON
     C           K#KEY     SETLLAANPL06
     C           *IN80     DOUEQ*ON
     C           K#KEY     READEAANPL06                  80
     C           *IN80     IFEQ *OFF
     C           L7SKJY    ANDEQ*BLANK
     C           L7STYY    ANDEQ9999
     C                     MOVE L7TKR1    WLOC1
     C                     MOVE L7TKR2    WLOC2
     C                     MOVE L7TKR3    WLOC3
     C                     MOVE L7TKR4    WLOC4
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      * PRODUCT
     C           *IN80     IFEQ *ON
     C           K#KEY     SETLLAAPTL01
     C           *IN80     DOUEQ*ON
     C           K#KEY     READEAAPTL01                  80
     C           *IN80     IFEQ *OFF
     C           L5SKJY    ANDEQ*BLANK
     C                     MOVE L5TKR1    WLOC1
     C                     MOVE L5TKR2    WLOC2
     C                     MOVE L5TKR3    WLOC3
     C                     MOVE L5TKR4    WLOC4
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDIF
     C                     UPDATGINWP011
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
