     H            Y.
      ** AHDR05 ********************************************
      *  PT ORDER BOX APART RATE MASTER UPDATE             *
      *                                                    *
      * TCHK  01/10/12 CREATE                              *
      * TCHK1 03/05/12 BUG FIX                             *
      ******************************************************
     FAHDPW05 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL010
     F                                              KINFDS @INFDS
     FAHDPP05 UF  E           K        DISK                      A
      *---------------------------------------------------
     E                    ERR     1  15 60
      *---------------------------------------------------
     I@INFDS      DS
     I                                     *STATUS  @STTS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME(6) + DATE(6)
     I            DS
     I                                        1  140WWTIME
     I                                        1   60WTIME
     I                                        1   40WTIM4
     I                                        1   20WTIMH
     I                                        3   40WTIMM
     I                                        7  120WSDATE
     I                                        9  120@@YM4
     I                                        7  120@@YM6
     I                                        7  140@@YMD
     I                                        7  100@@YY
     I                                       11  120@@MM
     I                                       13  140@@DD
      * ----------------------------------------------------
     C                     TIME           WWTIME
      ******************************************************
      *  MAIN
      ******************************************************
     C*
     C                     EXSR @S1INT
     C                     EXSR @S1SET
      *
     C                     DO   *HIVAL
      *
     C                     WRITEFMT090
     C                     Z-ADDW#RCN1    #RCN01
     C                     EXFMTCTL010
     C   KA                LEAVE
      *
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RCN1
     C                     END
      *
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      W#P1ER  1
      * add new
     C           *INKH     IFEQ *ON
     C                     EXSR @S2ADD
     C   KA                LEAVE
     C                     EXSR @S1INT
     C                     EXSR @S1SET
     C                     ITER
     C                     END
      * change
     C                     EXSR @S2CHG
     C   KA                LEAVE
     C                     EXSR @S1INT
     C                     EXSR @S1SET
     C                     ITER
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C*----------------------------------------------------*
      *  1ST SCREEN INITIALIZE
     C*----------------------------------------------------*
     C           @S1INT    BEGSR
      *
     C                     MOVEL*ON       *IN41
     C                     WRITECTL010
     C                     MOVEL*OFF      *IN41
      *
     C                     Z-ADD1         W#RCN1  40
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN69
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  SET
     C*----------------------------------------------------*
     C           @S1SET    BEGSR
      *
     C                     Z-ADD*ZERO     RRN1    40
     C           *LOVAL    SETLLAHDPP05
      *
     C                     DO   *HIVAL
      *
     C                     READ AHDPP05             N    98
     C   98                LEAVE
     C           AHSKJY    IFNE *BLANK
     C                     ITER
     C                     END
      *
     C                     CLEARSFL010
     C*
     C                     MOVELAHPTAN    S1PTAN
     C                     Z-ADDAHHTSU    S1HTSU
     C                     SELEC
     C           AHFUGO    WHEQ '1'
     C                     MOVEL'< '      S1FUGO
     C           AHFUGO    WHEQ '2'
     C                     MOVEL'> '      S1FUGO
     C           AHFUGO    WHEQ '3'
     C                     MOVEL'= '      S1FUGO
     C           AHFUGO    WHEQ '4'
     C                     MOVEL'<='      S1FUGO
     C           AHFUGO    WHEQ '5'
     C                     MOVEL'>='      S1FUGO
     C           AHFUGO    WHEQ '6'
     C                     MOVEL'<>'      S1FUGO
     C                     ENDSL
     C                     MOVELAHFUGO    H1FUGO
     C                     Z-ADDAHKISU    S1KISU
     C*
     C                     ADD  1         RRN1
     C                     WRITESFL010
     C*
     C                     ENDDO
     C*
     C           RRN1      IFEQ *ZERO
     C                     CLEARSFL010
     C                     Z-ADD1         RRN1
     C                     MOVEL*ON       *IN31
     C                     WRITESFL010
     C                     MOVEL*ON       *IN69
     C                     MOVELERR,1     MSG
     C                     MOVEL*OFF      *IN31
     C                     END
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  ADD NEW RECORD
     C*----------------------------------------------------*
     C           @S2ADD    BEGSR
      *
     C                     EXSR @S2INT
     C                     MOVEL'ADD'     F2ACTN    P
      *
     C                     DO   *HIVAL
      *
     C                     EXFMTFMT020
     C   KA
     COR KL                LEAVE
      *
     C                     MOVEL*OFF      *IN69
     C                     EXSR @S2CHK
     C           *IN69     IFEQ *OFF
     C           *INKE     IFEQ *ON
     C                     EXSR @ADDF
     C           *IN69     IFEQ *OFF
     C                     LEAVE
     C                     END
     C                     END
     C                     END
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  INITIAL SET TO FMT020
     C*----------------------------------------------------*
     C           @S2INT    BEGSR
     C*
     C                     SETOF                     515253
     C                     SETOF                     546162
     C                     SETOF                     636469
     C*
     C                     MOVEL*BLANK    F2PTAN
     C                     Z-ADD*ZERO     F2HTSU
     C                     MOVEL*BLANK    F2FUGO
     C                     Z-ADD*ZERO     F2KISU
     C*
     C                     MOVEL*BLANK    MSG
     C*
     C                     ENDSR
     C*----------------------------------------------------*
     C*  CHECK FMT020
     C*----------------------------------------------------*
     C           @S2CHK    BEGSR
     C*
     C                     SETOF                     515253
     C                     SETOF                     54
     C                     MOVEL*BLANK    MSG
     C*
     C                     DO
     C*
     C           F2PTAN    IFEQ *BLANK
     C                     SETON                     5169
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,2     MSG
     C                     END
     C                     END
     C*
     C           F2HTSU    IFEQ *ZERO
     C                     SETON                     5269
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,3     MSG
     C                     END
     C                     END
     C*
     C           F2FUGO    IFGE '1'
     C           F2FUGO    ANDLE'6'
     C                     ELSE
     C                     SETON                     5369
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,4     MSG
     C                     END
     C                     END
     C*
     C           F2KISU    IFEQ *ZERO
     C                     SETON                     5469
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,5     MSG
     C                     END
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  WRITE NEW RECORD
     C*----------------------------------------------------*
     C           @ADDF     BEGSR
      *
     C                     DO
      *
TCHK1C*          F2HTSU    CHAINAHDPP05              98
TCHK1C*          *IN98     IFEQ *OFF
TCHK1C*          AHSKJY    ANDEQ*BLANK
TCHK1C*
TCHK1C                     MOVEL*OFF      W@IN98  1
TCHK1C           F2HTSU    SETLLAHDPP05
TCHK1C                     DO   *HIVAL
TCHK1C           F2HTSU    READEAHDPP05                  98
TCHK1C   98                LEAVE
TCHK1C           F2FUGO    IFEQ AHFUGO
TCHK1C           F2KISU    ANDEQAHKISU
TCHK1C           AHSKJY    IFNE *BLANK
TCHK1C                     MOVEL*ON       W@IN98
TCHK1C                     MOVEL*ON       *IN98
TCHK1C                     END
TCHK1C                     LEAVE
TCHK1C                     END
TCHK1C                     ENDDO
TCHK1C           *IN98     IFEQ *OFF
     C                     SETON                     515253
     C                     SETON                     5469
     C                     MOVELERR,6     MSG
     C                     LEAVE
     C                     END
     C*
     C                     CLEARAHDPP051
     C*
     C                     EXSR @EDTF
      *
TCHK1C*          *IN98     IFEQ *OFF
TCHK1C           W@IN98    IFEQ *ON
     C                     UPDATAHDPP051
     C                     ELSE
     C                     WRITEAHDPP051
     C                     END
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  EDIT RECORD (NEW/CHANGE)
     C*----------------------------------------------------*
     C           @EDTF     BEGSR
     C*
     C                     TIME           WWTIME
     C                     Z-ADD@@YY      AHKOYY
     C                     Z-ADD@@MM      AHKOMM
     C                     Z-ADD@@DD      AHKODD
     C                     Z-ADDWTIMH     AHKOHH
     C                     Z-ADDWTIMM     AHKOSS
     C                     MOVEL#PGM      AHPGMN
     C                     MOVEL#USER     AHKOME
     C*
     C                     MOVELF2PTAN    AHPTAN
     C                     Z-ADDF2HTSU    AHHTSU
     C                     MOVELF2FUGO    AHFUGO
     C                     Z-ADDF2KISU    AHKISU
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  CHANGE/DELETE MAIN
     C*----------------------------------------------------*
     C           @S2CHG    BEGSR
      *
     C                     Z-ADD*ZERO     RRN1
      *
     C                     DO   *HIVAL
      *
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL010               98
     C   98                LEAVE
     C           S1SEL     IFEQ *BLANK
     C                     ITER
     C                     END
      *
     C                     EXSR @S2CDP
     C   KA                LEAVE
      *
     C                     MOVEL*BLANK    S1SEL
     C                     MOVEL*ON       *IN32
     C                     UPDATSFL010
     C                     MOVEL*OFF      *IN32
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  CHANGE/DELETE SET
     C*----------------------------------------------------*
     C           @S2CDP    BEGSR
      *
     C                     EXSR @S2INT
     C           S1SEL     IFEQ 'C'
     C                     MOVEL'CHANGE'  F2ACTN    P
     C                     SETON                     62
     C                     SETOF                     616364
     C                     ELSE
     C                     MOVEL'DELETE'  F2ACTN    P
     C                     SETON                     616263
     C                     SETON                     64
     C                     END
     C                     MOVELS1PTAN    F2PTAN
     C                     Z-ADDS1HTSU    F2HTSU
     C                     MOVELH1FUGO    F2FUGO
     C                     Z-ADDS1KISU    F2KISU
      *
     C                     DO   *HIVAL
      *
     C                     EXFMTFMT020
     C   KA
     COR KL                LEAVE
      *
     C           *INKE     IFEQ *ON
     C                     EXSR @CHGF
     C                     LEAVE
     C                     END
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  UPDAT
     C*----------------------------------------------------*
     C           @CHGF     BEGSR
      *
     C                     DO
      *
TCHK1C*          F2HTSU    CHAINAHDPP05              98
TCHK1C*          *IN98     IFEQ *ON
TCHK1C*                    LEAVE
TCHK1C*                    END
TCHK1C*
TCHK1C           F2HTSU    SETLLAHDPP05
TCHK1C                     DO   *HIVAL
TCHK1C           F2HTSU    READEAHDPP05                  98
TCHK1C   98                LEAVE
TCHK1C           AHSKJY    IFNE *BLANK
TCHK1C                     ITER
TCHK1C                     END
TCHK1C           S1PTAN    IFEQ AHPTAN
TCHK1C           H1FUGO    ANDEQAHFUGO
TCHK1C           S1KISU    ANDEQAHKISU
TCHK1C                     LEAVE
TCHK1C                     ELSE
TCHK1C                     ITER
TCHK1C                     END
TCHK1C                     ENDDO
TCHK1C   98                LEAVE
      *
     C           S1SEL     IFEQ 'D'
     C                     TIME           WWTIME
     C                     MOVEL'D'       AHSKJY
     C                     Z-ADD@@YY      AHSKYY
     C                     Z-ADD@@MM      AHSKMM
     C                     Z-ADD@@DD      AHSKDD
     C                     Z-ADD@@YY      AHKOYY
     C                     Z-ADD@@MM      AHKOMM
     C                     Z-ADD@@DD      AHKODD
     C                     Z-ADDWTIMH     AHKOHH
     C                     Z-ADDWTIMM     AHKOSS
     C                     MOVEL#PGM      AHPGMN
     C                     MOVEL#USER     AHKOME
     C                     ELSE
     C                     EXSR @EDTF
     C                     END
      *
     C                     UPDATAHDPP051
      *
     C                     ENDDO
      *
     C                     ENDSR
