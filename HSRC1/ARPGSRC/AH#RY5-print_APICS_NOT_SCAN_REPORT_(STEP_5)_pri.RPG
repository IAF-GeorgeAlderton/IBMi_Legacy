     H            Y.
      ** AH#RY5 ******************************************************
      *  PRINT APICS NOT SCAN REPORT                                 *
      *  J.WATANABE  2019.01.14                                      *
      ********************************************************
     FAH#WPY1 IF  E           K        DISK
     FAH#WPY2 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      ********************************************************
      *
     I            DS
     I                                        1  14 ISHIN
     I                                        1   5 ISHN1
     I                                        6   6 IS1
     I                                        7  11 ISHN2
     I                                       12  12 IS2
     I                                       13  14 ISHN3
     I            DS
     I                                        1  12 XSHIN
     I                                        1   5 XSHN1
     I                                        6  10 XSHN2
     I                                       11  12 XSHN3
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------------------*
      *     M  A  I  N  L  I  N  E                                *
      *-----------------------------------------------------------*
      *
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ AH#WPY1                  98
     C   98                LEAVE
      *
     C           IBOX1     MULT 100       @BOX    62
     C                     ADD  IBOX2     @BOX
     C                     DIV  100       @BOX
      *
     C           IRAT1     MULT 100       @RATIO  62
     C                     ADD  IRAT2     @RATIO
     C                     DIV  100       @RATIO
      *
     C                     MOVELIBIN      @BIN
     C                     MOVE '-'       @HI
      * CHECK SCAN SKIPPED
     C                     MOVELISHN1     XSHN1
     C                     MOVELISHN2     XSHN2
     C                     MOVELISHN3     XSHN3
     C                     MOVELXSHIN     PSHIN
     C                     MOVELIHTHZ     PHTHZ
     C                     MOVELITHAI     PTHNO
     C                     CALL 'UEXR06'
     C                     PARM           PSHIN  12
     C                     PARM           PHTHZ   8
     C                     PARM           PTHNO   3
     C                     PARM           PFLG    1
     C           PFLG      IFEQ 'Y'
     C                     MOVE '*'       @FIFO
     C                     ELSE
     C                     MOVE *BLANK    @FIFO
     C                     ENDIF
      * CHECK AH#WPY2 (LOG)
     C                     MOVELIHTHZ     K2HTHZ
     C                     MOVELISHIN     K2SHIN
     C                     MOVELILOCA     K2LOCA
     C                     MOVELITHAI     K2THAI
     C           K#WPY2    CHAINAH#WPY2              99
     C           *IN99     IFEQ *OFF
     C                     MOVE *BLANK    @AST
     C                     ELSE
     C                     MOVEL'*'       @AST
     C                     ENDIF
      *
     C                     EXSR #PRINT
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *************************************************************
      * PRINT OPTION
      *************************************************************
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 65
     C                     EXCPT@HDR
     C                     Z-ADD4         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *************************************************************
      * INITIALIZE
      *************************************************************
     C           #INIT     BEGSR
      *
     C           K#WPY2    KLIST
     C                     KFLD           K2HTHZ  80
     C                     KFLD           K2SHIN 14
     C                     KFLD           K2LOCA  9
     C                     KFLD           K2THAI  3
      *
     C                     Z-ADD88        LIN#    20
     C                     Z-ADD0         SEQ#    40
     C                     TIME           @SDATE
     C                     MOVE *BLANK    @AST    1
     C                     MOVE *BLANK    @HI     1
     C                     MOVE *BLANK    @BIN    2
     C                     MOVE *BLANK    @FIFO   1
      *
     C                     ENDSR
      *************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM       8
     O                         TODAY Y   69
     O                         NOW       79 '  :  :  '
     O                                   83 'P.'
     O                         PAGE  Z   86
     O        E   02           @HDR
     O                                   41 '** APICS NOT SCAN DA'
     O                                   61 'TA LIST **          '
     O        E   04           @HDR
     O                                    5 '#'
     O                                   18 'ISSUE DATE'
     O                                   26 'FIFO'
     O                                   32 'PART#'
     O                                   50 'PRV-LOC'
     O                                   58 'ABS#'
     O                                   63 'ORD#'
     O                                   68 'APCS'
     O                                   78 'BOX/DAY'
     O                                   90 'RATIO(%)'
      *
     O        E 1              @DTL
     O                         SEQ#  1 +  0
     O                         @AST    +  1
     O                         IHTHZ   +  1 '    /  /  '
     O                         @HI     +  0
     O                         @BIN    +  0
     O                         @FIFO   +  3
     O                         ISHIN   +  2
     O                         ILOCA   +  2
     O                         IZETI   +  2
     O                         ITHAI   +  2
     O                         IMAIS 1 +  2
     O                         @BOX  1 +  2
     O                         @RATIO1 +  2
