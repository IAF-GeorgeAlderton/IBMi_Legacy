     H            Y.
     F** UEXR41K ***********************************************
     F*  GET FORD YTD-PART-DEMAND BY SHIP DATE                 *
     F*  WRITTEN: JW (SRA) 2026.02.09                          *
     F*--------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UEXR41K'
     F*                    PARM           $NOHZ   8
     F*                    PARM           $NONY   4
     F*                    PARM           $MHIN  20
     F*                    PARM           $PLNT   5
     F*                    PARM           $YTDQ   9
     F*  IN: $NOHZ   8A  SHIP DATE
     F*      $NONY   4A  PDELIVERY CODE
     F*      $MHIN  20A  USER PART (NO BLANK)
     F*  OUT:$PLNT   5A  PLANT CODE
     F*      $YTDQ   9A  Y-T-D DEMAND
     F******************************************************
     FAB#PLF1HIF  E           K        DISK
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      *
     C           K#01      SETLLAB#PLF1H
     C                     DO   *HIVAL
     C           K#01      READEAB#PLF1H                 98
     C   98                LEAVE
      *
     C           F5DATE    IFGT SVDATE
     C                     MOVELF5STID    $PLNT
     C                     Z-ADDF5QTY2    @YTDQ
     C                     Z-ADDF5DATE    SVDATE
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEL@YTDQ     $YTDQ
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *===================================================
      * INITIAL SETTING
      *===================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NOHZ   8
     C                     PARM           $NONY   4
     C                     PARM           $MHIN  20
     C                     PARM           $PLNT   5
     C                     PARM           $YTDQ   9
      *
     C           K#01      KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#IPAR 20
     C                     KFLD           K#NOHZ  80
      *
     C                     MOVE *BLANK    $PLNT
     C                     MOVE *ALL'0'   $YTDQ
     C                     Z-ADD0         @YTDQ   90
      *
     C                     MOVEL$NONY     K#NONY
     C                     MOVEL$NOHZ     K#NOHZ
     C                     MOVEL$MHIN     K#IPAR
      *
     C                     Z-ADD0         SVDATE  80
      *
     C                     ENDSR
