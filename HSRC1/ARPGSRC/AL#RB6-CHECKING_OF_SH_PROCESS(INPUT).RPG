     H            Y.
     F** AL#RB6  *******************************************
     F* CHECKING OF SH PROCESS(INPUT)                      *
     F*      ITS.        2015.06.02                        *
     F******************************************************
     FAL#PL05 IF  E           K        DISK
     FAL#WPB6 IF  E           K        DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1FIXD  80
     C                     PARM           P1IAFB  3
     C                     PARM           P9CMD   2
      *
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      *
     C           P1FIXD    SETLLAL#PL051
     C           P1FIXD    READEAL#PL051                 81
     C           *IN81     DOWEQ'0'
     C           CASKJY    IFEQ 'D'
     C           CASKHZ    ANDLESDATE
     C                     ELSE
     C           CASHME    IFNE *BLANK
     C                     EXSR #SB400
     C                     ENDIF
     C                     ENDIF
     C           P1FIXD    READEAL#PL051                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AL#WPB1
      *-----------------------------------------------------
     CSR         #SB400    BEGSR
      *
     C                     MOVEL'0'       GET     1
     C           P1IAFB    IFEQ '000'
     C                     MOVEL'1'       GET
     C                     ELSE
     C           P1IAFB    IFEQ CAIAFB
     C                     MOVEL'1'       GET
     C                     ENDIF
     C                     ENDIF
     C           GET       IFEQ '1'
     C                     EXSR #SB500
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *-----------------------------------------------------
      *  AL#WPB6
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C           KEYW0     KLIST
     C                     KFLD           CASHME
      *
     C           KEYW0     CHAINAL#WPB61             22
     C           *IN22     IFEQ '1'
     C                     CLEARAL#WPB61
     C                     MOVELCASHME    W6SHME
     C                     Z-ADDCAFIXD    W6FIXD
     C                     Z-ADDCAFIXT    W6FIXT
     C                     Z-ADDCATIMS    W6TIMS
     C                     Z-ADDCAEXTR    W6EXTR
     C                     MOVELCAIAFB    W6IAFB
     C                     WRITEAL#WPB61
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
