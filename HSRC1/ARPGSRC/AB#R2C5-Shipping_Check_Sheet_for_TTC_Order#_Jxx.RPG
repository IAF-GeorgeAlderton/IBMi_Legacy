     H            Y.
     F** AB#R2C5 ************************************************************
     F*  SHIPPING CHECK SHEET FOR TTC ORDER#=JXXXXX                         *
     F*                                                                     *
     F* TCHK1 01/22/08 CREATE                                               *
     F****************************************** AB#R2C *********************
     FAB#WP2I IF  E                    DISK
     FAB#PL71 IF  E           K        DISK
     FAB#PL15 IF  E           K        DISK
     FAB#WP2IQIF  E           K        DISK                      A
     FAB#WP2IRO   E                    DISK
     E*****************************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I            DS
     I                                        1   8 W@SHDT
     I                                        1   4 W@SHYY
     I                                        5   6 W@SHMM
     I                                        7   8 W@SHDD
     I            DS
     I                                        1   8 K@SHDT
     I                                        1   40EKNOYY
     I                                        5   60EKNOMM
     I                                        7   80EKNODD
     I            DS
     I                                        1  20 W@SHIN
     I                                        1   5 W@SHN1
     I                                        6  10 W@SHN2
     I                                       11  12 W@SHN3
     C***********************************************************************
     C                     EXSR @INZ
     C                     EXSR @MAIN
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C***********************************************************
     C* @INZ:INITIALIZE WORK AREA
     C***********************************************************
     C           @INZ      BEGSR
     C*
     C           P2        PLIST
     C                     PARM           PIQTY  300       NUMERIC QTY
     C                     PARM           POQTY  30        CHAR    QTY
     C*
     C                     ENDSR
     C***********************************************************
     C* @MAIN
     C***********************************************************
     C           @MAIN     BEGSR
     C*
     C           1         SETLLAB#WP2I
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AB#WP2I                  99
     C   99                LEAVE
     C*
     C                     MOVELI2ORDR    W@OR#1  1
     C           W@OR#1    IFEQ 'J'
     C           W@OR#1    OREQ 'X'
     C                     ELSE
     C                     ITER
     C                     END
     C*
     C           I2SERL    CHAINAB#PL71              98
     C   98                ITER
     C*
     C           K#PL15    KLIST
     C                     KFLD           EKTOKU
     C                     KFLD           K@NONY  40
     C                     KFLD           EKNKOJ
     C                     KFLD           EKNUKE
     C                     KFLD           EKMHN1
     C                     KFLD           EKMHN2
     C                     KFLD           EKMHN3
     C                     KFLD           EKMHN4
     C                     KFLD           EKODRN
     C                     KFLD           EKNOYY
     C                     KFLD           EKNOMM
     C                     KFLD           EKNODD
     C                     KFLD           K@NOBN  20
     C                     MOVELEKNONY    K@NONY
     C                     MOVELEKNOBN    K@NOBN
     C           K#PL15    CHAINAB#PL15              97
     C   97                ITER
     C*
     C           K#2IQ     KLIST
     C                     KFLD           K@TOKU  4
     C                     KFLD           EKNONY
     C                     KFLD           EKNKOJ
     C                     KFLD           EKNUKE
     C                     KFLD           K@SHDT
     C                     KFLD           EKNOBN
     C                     KFLD           EKODRN
     C                     KFLD           EKMHN1
     C                     KFLD           EKMHN2
     C                     KFLD           EKMHN3
     C                     KFLD           EKMHN4
     C                     MOVELEKTOKU    K@TOKU
     C           K#2IQ     CHAINAB#WP2IQ             96
     C  N96                ITER
     C*
     C                     CLEARAB#WP2QR
     C*
     C                     MOVELBATOKU    IQTOKU
     C                     MOVELBANONY    IQDELY
     C                     MOVELBANKOJ    IQFACT
     C                     MOVELBANUKE    IQDOCK
     C                     MOVELBAMHN1    IQMHN1
     C                     MOVELBAMHN2    IQMHN2
     C                     MOVELBAMHN3    IQMHN3
     C                     MOVELBAMHN4    IQMHN4
     C                     MOVELBANOYY    W@SHYY
     C                     MOVELBANOMM    W@SHMM
     C                     MOVELBANODD    W@SHDD
     C                     MOVELW@SHDT    IQSHDT
     C                     MOVELBAODRN    IQORDR
     C                     MOVELBANOBN    IQNOBN
     C                     MOVEL*BLANK    W@SHIN
     C                     MOVELBASHN1    W@SHN1
     C                     MOVELBASHN2    W@SHN2
     C                     MOVELBASHN3    W@SHN3
     C                     MOVELW@SHIN    IQIPAR
     C*
     C           BAUSYS    IFNE *ZERO
     C                     Z-ADDBAUSYS    W@SYS   60
     C                     ELSE
     C           BASYOS    IFNE *ZERO
     C                     Z-ADDBASYOS    W@SYS
     C                     ELSE
     C                     Z-ADDBASRYO    W@SYS
     C                     END
     C                     END
     C           W@SYS     IFEQ *ZERO
     C                     Z-ADD1         W@CONT  50
     C                     ELSE
     C           BASRYO    DIV  W@SYS     W@CONT
     C                     MVR            W@MVR   60
     C           W@MVR     IFNE *ZERO
     C                     ADD  1         W@CONT
     C                     END
     C                     END
     C*
     C                     Z-ADDBASRYO    PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     IQQTY                        R
     C*
     C                     Z-ADDW@CONT    PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     IQCONT                       R
     C*
     C                     WRITEAB#WP2QR
     C*
     C                     ENDDO
     C*
     C           *LOVAL    SETLLAB#WP2IQ
     C                     DO   *HIVAL
     C                     READ AB#WP2IQ                 95
     C   95                LEAVE
     C                     CLEARAB#WP2RR
     C                     MOVELIQTOKU    IRTOKU
     C                     MOVELIQDELY    IRDELY
     C                     MOVELIQFACT    IRFACT
     C                     MOVELIQDOCK    IRDOCK
     C                     MOVELIQMHN1    IRMHN1
     C                     MOVELIQMHN2    IRMHN2
     C                     MOVELIQMHN3    IRMHN3
     C                     MOVELIQMHN4    IRMHN4
     C                     MOVELIQSHDT    IRSHDT
     C                     MOVELIQORDR    IRORDR
     C                     MOVELIQNOBN    IRNOBN
     C                     MOVELIQIPAR    IRIPAR
     C                     MOVELIQQTY     IRQTY
     C                     MOVELIQCONT    IRCONT
     C                     WRITEAB#WP2RR
     C                     ENDDO
     C*
     C                     ENDSR
