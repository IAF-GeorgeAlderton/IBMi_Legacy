E001 C                     END
      *
     C           #SET2E    ENDSR
      ******************************************************
     C           ROLLUP    BEGSR                           *
      ******************************************************
     C                     MOVE *BLANK    SW      1
     C                     Z-ADD*ZERO     CNTR    50
      *-----------------------------------
B001 C                     DO   *HIVAL
     C           KEY2      READEAJHPL251                 40
     C   40                LEAVE
     C           JDKEHT    IFGT EHIZT
     C                     LEAVE
     C                     ENDIF
      *
     C           JDSKJY    IFEQ 'D'
     C           JDSKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
      *
     C                     MOVEA'0'       *IN,21
     C                     MOVEA'0'       *IN,22
     C                     MOVEL*BLANK    HIN
     C                     MOVELJDHIN1    HIN1
     C                     MOVELJDHIN2    HIN2
     C                     MOVELJDHIN3    HIN3
     C           HIN2      IFNE *BLANK
     C                     MOVEL'-'       HINA
     C                     END
     C           HIN3      IFNE *BLANK
     C                     MOVEL'-'       HINB
     C                     END
     C                     MOVE HIN       @HIN
     C                     MOVELJDTHAI    @THI
     C                     MOVELJDPAG1    @PNO1
     C                     MOVELJDPAG2    @PNO2
     C                     MOVELJDPAG3    @PNO3
     C                     MOVELJDPAG4    @PNO4
     C                     Z-ADDJDMKSU    @KEIS
     C                     MOVELJDIROK    @IRO
     C                     Z-ADDJDWKHZ    @THIZ
     C                     Z-ADDJDWKTM    @TTIM
