     C                     MOVELJDTASY    #TISG
     C                     MOVELJDSYKO    #SYKB
     C                     MOVELJDHKBR    #HAKO
     C                     Z-ADDJDMKSU    #KEIS
     C                     MOVELJDIROK    #IRO
     C                     Z-ADDJDSYUY    #SYOS
     C                     MOVELJDHKFA    #MHKO
     C                     Z-ADDJDTANJ    #TANJ
     C                     Z-ADDJDWKHZ    #THIZ
     C                     Z-ADDJDWKTM    #TTIM
     C                     Z-ADDJDWMJY    #TNMJ
     C                     MOVE JDMKKB    #KIBN
     C                     Z-ADDJDKEHZ    #KHIZ
     C                     Z-ADDJDKETM    #KTIM
     C                     Z-ADDJDWAIT    #KEIJ
     C                     MOVE JDTOCD    #TOCD
     C                     SETOF                     90
     C           JDTOCD    CHAINAJSPLCD1             90
     C           JASKJY    IFEQ ' '
     C           *IN90     ANDEQ*OFF
     C                     MOVE JAWKNM    #TOCM
     C                     END
     C                     MOVE JDZBR1    #ZAI1
     C                     MOVE JDZBR2    #ZAI2
     C                     MOVE JDKECD    #KECD
     C                     SETOF                     91
     C           JDKECD    CHAINAJSPLCD1             91
     C           JASKJY    IFEQ ' '
     C           *IN91     ANDEQ*OFF
