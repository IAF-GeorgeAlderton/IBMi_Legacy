     C                     END
     C                     MOVE JDGAFR    #GAFR
     C                     MOVE JDNGFR    #NGFR
     C                     MOVE JDMKFR    #MKFR
     C                     Z-ADDJDSOKK    #SOKK
     C                     Z-ADDJDTMAI    #TMAI
     C                     MOVE JDSAIK    #SAIK
      *
     C           JDSAIK    IFEQ '0'
     C           JDSAIK    OREQ ' '
     C                     MOVEA'0'       *IN,21
     C                     ELSE
     C                     MOVEA'1'       *IN,21
     C                     END
      *
     C           JDGAFR    IFEQ '1'
     C           JDNGFR    OREQ '1'
     C           JDMKFR    OREQ '1'
     C                     MOVEA'1'       *IN,22
     C                     ELSE
     C                     MOVEA'0'       *IN,22
     C                     END
      *
     C                     ADD  1         RRN
     C                     ADD  1         CNTR
     C                     WRITEDSP2R
     C                     MOVEL'*'       SW
      * MAX mﾞｰj <15>
     C           CNTR      IFGE 15
     C                     LEAVE
     C                     ENDIF
E001 C                     ENDDO
