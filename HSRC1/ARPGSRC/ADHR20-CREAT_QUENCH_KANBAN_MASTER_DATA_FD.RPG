     F** ADHR20 ****************************
     F* CREAT QUENCH KANBAN MASTER DATA FD *
     F*  I-HASADA              2000.07.04  *
     F*
     F* TCHK1 03/15/07 CHG SELECT CONDITION
     F* TCHK2 03/22/07 CHG SELECT CONDITION
     F**************************** ADHR20 **
TCHK2FADHTL05 IF  E           K        DISK
     FCADTL03 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FADHWP20 O   F     128            DISK
      *
      *削除コード
     I            DS
     I                                        1   80J6SKH8
     I                                        1   40J6SKYY
     I                                        5   60J6SKMM
     I                                        7   80J6SKDD
      *削除コード
     I            DS
     I                                        1   80A2GSH8
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *有効日
     I            DS
     I                                        1   80J6UKH8
     I                                        1   40J6UKYY
     I                                        5   60J6UKMM
     I                                        7   80J6UKDD
      *失効日
     I            DS
     I                                        1   80J6STH8
     I                                        1   40J6STYY
     I                                        5   60J6STMM
     I                                        7   80J6STDD
     C**************************************************
     C* KEY LIST
     C**************************************************
     C           KEY1      KLIST
     C                     KFLD           J6SHN1
     C                     KFLD           J6SHN2
     C                     KFLD           J6SHN3
     C**************************************************
     C           *LOVAL    SETLLADHTL05
     C                     DO   *HIVAL
     C                     READ ADHTL05                  98
     C   98                LEAVE
      *削除データの為、終了
     C           J6SKJY    IFEQ 'D'
     C                     ITER
     C                     END
      *失効日
     C           J6STH8    IFLT *DATE
     C                     ITER
     C                     END
      *材料名
     C                     MOVE *BLANK    WZANM  15
     C                     SETOF                     10
     C           KEY1      CHAINFCEPL01              10
     C           *IN10     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSH8    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C                     END
     C           *IN10     IFEQ '0'
     C                     MOVELA2ZANM    WZANM
     C                     END
      *
     C                     Z-ADD0         WSOZI   52
     C                     Z-ADDJ6SOZI    WSOZI
     C                     Z-ADD0         WHKJR   41
     C                     Z-ADDJ6HKJR    WHKJR
      *ワークファイルに出力
     C                     EXCPTDT
      *
     C                     ENDDO
     C**************************************************
     C           *LOVAL    SETLLCADTL03
     C                     DO   *HIVAL
     C                     READ CADTL03                  98
     C   98                LEAVE
      *削除データの為、終了
     C           C2SKJY    IFEQ 'D'
     C                     ITER
     C                     END
      *失効日
     C           C2STHZ    IFLT *DATE
     C                     ITER
     C                     END
      * 熱処理無し
     C           C2RONO    IFEQ *BLANK
     C           C2HOJI    ANDEQ0
     C           C2ONDO    ANDEQ0
     C                     ITER
     C                     END
      *材料名
     C                     MOVE *BLANK    WZANM  15
     C                     SETOF                     10
     C           KEY1      CHAINFCEPL01              10
     C           *IN10     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSH8    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C                     END
     C           *IN10     IFEQ '0'
     C                     MOVELA2ZANM    WZANM
     C                     Z-ADDA2SOZI    WSOZI
     C                     END
      *
     C                     Z-ADD0         WHKJR   41
     C                     Z-ADDC2HKJR    WHKJR
     C                     MOVELC2RONO    WRONO   3
      *ワークファイルに出力
     C                     EXCPTDT2
      *
     C                     ENDDO
     C**************************************************
      *
     C                     SETON                     LR
     C                     RETRN
      **************************************************
     OADHWP20 E                DT
