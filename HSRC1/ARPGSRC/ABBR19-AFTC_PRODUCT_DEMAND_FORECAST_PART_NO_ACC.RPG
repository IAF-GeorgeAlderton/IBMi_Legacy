     H            Y.
     F** ABBR19 **************************************
     F* .. AFTC PRODUCT DEMAND FORECAST PART NO ACCUMULATION FILE CREATE || *.
     F* I-HASADA                        88.03.24     *
     F************************************** ABBR19 **
     FNBBPP01 IP  E                    DISK
     FABBPL21 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FNBBPL11 UF  E           K        DISK                      A
     E                    HIZ         6  6 0             日付
     E                    HCD         6  3 1             稼動日数
     I            DS
     I                                        1   80NBSKHZ
     I                                        1   40NBSKYY
     I                                        5   60NBSKMM
     I                                        7   80NBSKDD
     I            DS
     I                                        1   60WYM
     I                                        1   40WYY
     I                                        5   60WMM
     C           KEY       KLIST
     C                     KFLD           NBSHN1
     C                     KFLD           NBSHN2
     C                     KFLD           NBSHN3
     C                     KFLD           IYM
      *
     C           KEY1      KLIST
     C                     KFLD           WYY
     C                     KFLD           WMM
      *
     C           *IN02     IFEQ '0'
     C                     SETON                     02
     C           *ENTRY    PLIST
     C                     PARM           PHIZ    6
     C                     MOVE PHIZ      IYM     60
     C                     Z-ADDIYM       WYM
     C                     Z-ADD0         HIZ
     C                     Z-ADD0         HCD
      *
     C*------------------*
     C*   ..後日付..   *
     C*------------------*
     C                     Z-ADDWYM       HIZ,1
     C                     Z-ADD1         A       10
     C           2         DO   6         A
     C           WMM       IFEQ 12
     C                     ADD  1         WYY
     C                     Z-ADD01        WMM
     C                     ELSE
     C                     ADD  1         WMM
     C                     END
     C                     Z-ADDWYM       HIZ,A
     C                     END
      *
     C*--------------------------*
     C*   ..後日付稼動日数..   *
     C*--------------------------*
     C                     Z-ADD1         A
     C           1         DO   6         A
      *
     C                     Z-ADDHIZ,A     WYM
     C                     Z-ADD0         WCD     31
     C           KEY1      SETLLAGDPL121
      *
     C                     DO   *HIVAL
     C                     SETOF                     01
     C           KEY1      READEAGDPL121                 01
     C           *IN01     IFEQ '0'
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         WCD
     C                     ELSE
      *
     C                     ADD  0.5       WCD
     C                     END
      *
     C                     END
     C                     END
     C  N01                END
      *
     C                     Z-ADDWCD       HCD,A
     C                     END
     C                     END
      *
     C           NBSKJY    IFEQ 'D'
     C           NBSKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     Z-ADD0         WS1     90
     C                     Z-ADD0         WS2     90
     C                     Z-ADD0         WS3     90
     C                     Z-ADD0         WS4     90
     C                     Z-ADD0         WS5     90
     C                     Z-ADD0         WS6     90
      *
     C*------------------------------------*
     C*   ..予想３月フアイル　内示数..   *
     C*------------------------------------*
     C                     SETOF                     01
     C           KEY       CHAINABBPL211             01
     C           *IN01     IFEQ '0'
      *
     C           U1NGKB    IFEQ 'N'
     C                     Z-ADDU1NNNM    WS1
     C                     Z-ADDU1N1NM    WS2
     C                     Z-ADDU1N2NM    WS3
     C                     ELSE
     C                     Z-ADDU1SNNM    WS1
     C                     Z-ADDU1S1NM    WS2
     C                     Z-ADDU1S2NM    WS3
     C                     END
      *
     C           WS2       IFEQ 0
     C                     Z-ADDWS1       WS2
     C                     END
     C           WS3       IFEQ 0
     C                     Z-ADDWS2       WS3
     C                     END
     C                     END
      *
     C           WS3       DIV  HCD,3     WSRY1   90
     C           WSRY1     MULT HCD,4     WS4
     C           WSRY1     MULT HCD,5     WS5
     C           WSRY1     MULT HCD,6     WS6
      *
     C*----------------------------------------*
     C*   ..ＡＦＴＣ内示品番累積フアイル..   *
     C*----------------------------------------*
     C                     SETOF                     01
     C           KEY       CHAINNBBPL111             01
     C                     MOVE NBSHN1    NCSHN1
     C                     MOVE NBSHN2    NCSHN2
     C                     MOVE NBSHN3    NCSHN3
     C                     Z-ADDWS1       NCSRY1
     C                     Z-ADDWS2       NCSRY2
     C                     Z-ADDWS3       NCSRY3
     C                     Z-ADDWS4       NCSRY4
     C                     Z-ADDWS5       NCSRY5
     C                     Z-ADDWS6       NCSRY6
     C                     Z-ADDIYM       NCNTYM
     C           *IN01     IFEQ '1'
     C                     WRITENBBPL111
     C                     ELSE
     C                     UPDATNBBPL111
     C                     END
     C                     END
