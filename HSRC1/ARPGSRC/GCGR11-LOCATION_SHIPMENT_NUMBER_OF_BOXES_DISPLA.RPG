      *----------------------------------*
      * 所番地出荷箱数表示ラベル　発行 *
      *----------------------------------*
     C  NL1                GOTO LR
     C  N56                GOTO LR
     C           *IN55     IFEQ '0'
     C                     MOVE '.'       CNM
     C                     Z-ADD1         J       10
     C                     EXSR SYOKI
     C                     SETON                     5560
     C                     END
     C           *IN60     IFEQ '1'
     C                     SETOF                     60
     C                     Z-ADD1         H       20
     C           1         DO   20        H
     C                     MOVE '0'       *IN,H
     C                     END
     C                     END
     C                     EXSR KANJI
     C                     MOVE STOKOR    TKOB,J
     C                     Z-ADDSTOKI     TOKI,J
     C                     Z-ADDSBAR      BARA,J
     C                     Z-ADDSMAXH     MAXH,J
      *
     C                     Z-ADD0         XPAS    40
     C           SPAS      SUB  100       XPAS
     C                     Z-ADDXPAS      ZPAS,J
     C           XPAS      IFLT 0
     C                     MOVEL'－'    ZZOG,J
     C                     ELSE
     C                     MOVEL'＋'    ZZOG,J
     C                     END
      *
     C           SBAR      IFNE *ZERO
     C                     Z-ADD0         BA      20
     C           10        ADD  J         BA
     C                     MOVE '1'       *IN,BA
     C                     END
     C           SHAKO     IFEQ 0
     C                     MOVE '1'       *IN,J
     C                     ADD  1         J
     C                     GOTO END
     C                     END
     C           SSENY     IFEQ 'S'
     C                     Z-ADD0         H
     C           J         ADD  5         H
     C                     MOVE '1'       *IN,H
     C                     END
     C           SMAXH     IFNE 0
     C           J         ADD  15        MA      20
     C                     MOVE '1'       *IN,MA
     C                     END
      *
     C                     MOVELSHAKO     HK1
     C                     MOVE SHAKO     HK2
     C           HK11      IFEQ '0'
     C                     MOVE *BLANK    HK11
     C           HK12      IFEQ '0'
     C                     MOVE *BLANK    HK12
     C                     END
     C                     END
     C                     MOVE HK        HAKO,J
      *
     C                     MOVE SMISU     MISU,J
     C                     ADD  1         J
     C           END       TAG
     C           J         IFEQ 6
     C                     SETON                     60
     C                     Z-ADD1         J       10
     C                     EXSR TOKRO
     C                     WRITEGCGPR111
     C                     EXSR SYOKI
     C                     END
     C           LR        TAG
      *
     C**L1                   SETON                     60
     C**L1                   Z-ADD1         J       10
     C**L1                   EXSR TOKRO
     C**L1                   WRITEGCGPR111
     C**L1                   EXSR SYOKI
      *
     CLR                   EXSR OWARI
      *--------------------------*
      * 漢字入力　サブルーチン *
      *--------------------------*
     C           KANJI     BEGSR
     C                     MOVE KTO,1     CTOK,J
     C                     MOVE KHK,1     CHIA,J
     C                     MOVE KHA,1     CHAK,J
     C                     MOVE KKN,1     CKAN,J
     C                     MOVE KMI,1     CMAI,J
     C           SZGN      IFEQ '+'
     C                     MOVEL'　'    ZOGN,J
     C                     ELSE
     C                     MOVEL'　'    ZOGN,J
     C                     END
     C                     ENDSR
      *--------------*
      * 初期値設定 *
      *--------------*
     C           SYOKI     BEGSR
     C                     MOVE *BLANK    TKOB
     C                     MOVE *BLANK    CTOK
     C                     Z-ADD0         BARA
     C                     MOVE *BLANK    CHIA
     C                     MOVE *BLANK    CHAK
     C                     MOVE *BLANK    CKAN
     C                     MOVE *BLANK    CMAI
     C                     MOVE *BLANK    ZOGN
     C                     MOVE *BLANK    HAKO
     C                     MOVE *BLANK    MISU
     C                     Z-ADD0         TOKI
     C                     Z-ADD0         MAXH
     C                     Z-ADD0         ZPAS
     C                     MOVE *BLANK    ZZOG
     C                     ENDSR
      *------------------*
      * 所番地ゼロ消去 *
      *------------------*
     C           TOKRO     BEGSR
     C                     Z-ADD1         L       10
     C           1         DO   5         L
     C                     MOVE *BLANK    ZTOK
     C                     MOVELTKOB,L    ZZTOK
      *
     C                     Z-ADD1         M       20
     C           1         DO   9         M
      *
     C           M         IFEQ 3
     C           M         OREQ 6
     C           ZTOK,M    IFEQ '0'
     C                     MOVE *BLANK    ZTOK,M
     C                     END
     C                     END
      *
     C           M         IFEQ 9
     C           ZTOK,M    IFEQ '0'
     C                     MOVE '-'       ZTOK,M
     C                     END
     C                     END
      *
     C                     END
     C                     MOVE *BLANK    TKOB,L
     C                     MOVEAZZTOK     TKOB,L
      *
     C                     END
     C                     ENDSR
      *------------------------*
      * 終了　サブ・ルーチン *
      *------------------------*
     C           OWARI     BEGSR
     C           TKOB,1    IFNE *BLANK
     C                     Z-ADD0         K       20
     C                     Z-ADD1         H
     C                     SETOF                     77
     C           1         DO   5         H
     C           TKOB,H    IFEQ *BLANK
     C                     SETON                     77
     C                     END
     C  N77                END
     C                     ADD  5         H
     C           H         DO   10        K
     C                     MOVE '0'       *IN,K
     C                     END
     C                     EXSR TOKRO
     C                     WRITEGCGPR111
     C                     END
     C                     ENDSR
