     H            Y.
      ***ALDR6X*****************************************************************
      * UPDATE OUTSTANDING FILE  **TEMP**                                      *
      *        05/15/2018    T.SAKAKI
      **************************************************************************
     FALDPW6X CF  E                    WORKSTN
     FALDPP65 UF  E           K        DISK
     **==============================================================**
     E                    @MS     1  18 53                ERR MSG
     **==============================================================**
     I            DS
     I                                        1  140S@TIME
     I                                        1   60S@HMS
     I                                        1   20S@TMHH
     I                                        3   40S@TMMM
     I                                        5   60S@TMSS
     I                                        7  140S@YYMD
     I                                        7  100S@DYYY
     I                                       11  120S@DYMM
     I                                       13  140S@DYDD
     I           SDS
     I                                     *PROGRAM S@PGID
     I                                      244 253 S@WSID
     I                                      254 263 S@USID
     I                                      264 269 S@JBID
     **==============================================================**
     **                    MAIN ROUTINE                              **
     **==============================================================**
     C                     TIME           S@TIME
     C                     MOVEL'SET10'   W@NEXT  5
      *
     C           W@NEXT    DOUEQ'END  '
      * SCREEN1
     C           W@NEXT    CASEQ'SET10'   #SET10
     C           W@NEXT    CASEQ'PNL10'   #PNL10
     C           W@NEXT    CASEQ'CHK10'   #CHK10
     C           W@NEXT    CASEQ'UPD10'   #UPD10
      *
     C                     END
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-------------------------------------------------------------------------
      * SET INITIAL VALUE FOR SCREEN1
      *-------------------------------------------------------------------------
     C           #SET10    BEGSR
      *
     C                     SETOF                     518899
     C                     MOVEL*BLANK    D1MSG            * ERR MSG
      *
      * NEXT-CONTROL
     C                     MOVEL'PNL10'   W@NEXT           G1-PNL
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      * SCREEN1 PROCESS
      *-------------------------------------------------------------------------
     C           #PNL10    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SETOF                     518899
     C                     MOVEL*BLANK    D1MSG            * ERR MSG
      *
      * F01: END
     C           *INKA     IFEQ *ON
     C                     MOVEL'END  '   W@NEXT
     C                     GOTO XPNL10
     C                     ENDIF
      * ENTER
     C                     MOVEL'CHK10'   W@NEXT
      *
     C           XPNL10    ENDSR
      *-------------------------------------------------------------------------
      *  CHECK FIELDS OF SCREEN1
      *-------------------------------------------------------------------------
     C           #CHK10    BEGSR
      *
     C           D1UPDT    IFEQ 0
     C  N99                MOVEL@MS,01    D1MSG     P
     C  N99                SETON                     5199
     C                     GOTO XCHK10
     C                     ENDIF
      *
      * NEXT-CONTROL
     C           XCHK10    TAG
     C                     MOVEL'PNL10'   W@NEXT
     C           *IN99     IFEQ *ON
     C                     MOVEL'PNL10'   W@NEXT
     C                     ELSE
     C           *INKE     IFEQ *ON
     C                     MOVEL'UPD10'   W@NEXT
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      * UPDATE RECORD
      *-------------------------------------------------------------------------
     C           #UPD10    BEGSR
      *
     C                     Z-ADD0         CNT1    50
      *
     C           *LOVAL    SETLLALDPP65
     C                     DO   *HIVAL
     C                     READ ALDPP65                  88
     C   88                LEAVE
      *
     C           AFODAT    IFLE D1UPDT
     C           AFRDAT    ANDEQ0
     C                     Z-ADDS@YYMD    AFDATE
     C                     Z-ADDS@HMS     AFTIME
     C                     MOVELS@PGID    AFPGID
     C                     MOVELS@USID    AFUSER
     C                     MOVELS@USID    AFRTMC
     C                     Z-ADD99999999  AFRDAT
     C                     Z-ADD999999    AFRTIM
     C                     UPDATALDPP651
     C                     ADD  1         CNT1
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           CNT1      IFGT 0
     C                     SETON                     88
     C                     ENDIF
      *
     C                     MOVEL'PNL10'   W@NEXT           G1-PNL
      *
     C                     ENDSR
**  @MS  ( ERR MSG )
ER01 INPUT CORRECT DATE.
