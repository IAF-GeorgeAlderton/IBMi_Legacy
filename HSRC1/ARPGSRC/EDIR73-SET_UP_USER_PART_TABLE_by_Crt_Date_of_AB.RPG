     H            Y/                                    1
     H** EDIR73 *******************************************************
     H*  SET UP USER PART TABLE BY CREATE DATE OF ABF2P01             *
     H*  RUN IN FCKC00 (10:10AM BY JOBSCDE)                           *
     H*  JW  2019.10.09                                               *
     H*****************************************************************
     FABF2L08 IF  E           K        DISK
     FABFDL03 IF  E           K        DISK
     FEDIPP45 UF  E           K        DISK                      A
      *================================================================
     E                    CHR        20  1
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I            DS
     I                                        1  20 @MHIN
     I                                        1   5 @MHN1
     I                                        6  10 @MHN2
     I                                       11  15 @MHN3
     I                                       16  20 @MHN4
     I           SDS
     I                                     *PROGRAM #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I                                      264 269 #JBNO
     C*===============================================================
     C*  MAIN PROGRAM
     C*===============================================================
     C                     EXSR #INIT
     C*
     C           @@DAT3    SETLLABF2L08
     C                     DO   *HIVAL
     C                     READ ABF2L08                  90
     C   90                LEAVE
      * SKIP IF QTY=0
     C           AFQTY2    IFEQ 0
     C           AFYSQY    ANDEQ0
     C                     ITER
     C                     ENDIF
      * CHECK EDIPP45
     C                     MOVELAFPART    MHIN20 20
     C                     MOVELAFIPAR    @MHIN
     C           MHIN20    IFNE @MHIN
     C                     EXSR #NONY
     C           @NONY     IFNE 0
     C                     MOVEL@NONY     K#NONY
     C                     MOVEL@MHN1     K#MHN1
     C                     MOVEL@MHN2     K#MHN2
     C                     MOVEL@MHN3     K#MHN3
     C                     MOVEL@MHN4     K#MHN4
     C           K#PP45    CHAINEDIPP45              96
     C           *IN96     IFEQ *ON
     C                     CLEAREDIPP451
     C                     MOVEL@MHN1     E5MHN1
     C                     MOVEL@MHN2     E5MHN2
     C                     MOVEL@MHN3     E5MHN3
     C                     MOVEL@MHN4     E5MHN4
     C                     MOVEL@NONY     E5NONY
     C                     MOVELMHIN20    E5UPRT
     C                     Z-ADDTODAY     E5CRHZ
     C                     Z-ADDNOW       E5CRTM
     C                     MOVEL#USER     E5CRME
     C                     MOVEL#PGM      E5CRPG
     C                     WRITEEDIPP451
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << GET NONY >>
     C*===============================================================
     C           #NONY     BEGSR
      *
     C                     Z-ADD0         @NONY   40
     C                     MOVELAFSTID    K#PLAN
     C                     MOVELAFDOCK    K#DOCK
     C                     MOVELAFICCD    K#ICCD
     C           K#DL03    CHAINABFDL03              99
     C           *IN99     IFEQ *OFF
     C                     Z-ADDQANONY    @NONY
     C                     ELSE
     C                     Z-ADD0         @NONY
     C                     ENDIF
      *
     C                     ENDSR
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
      *
     C           K#PP45    KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#MHN1  5
     C                     KFLD           K#MHN2  5
     C                     KFLD           K#MHN3  5
     C                     KFLD           K#MHN4  5
      *
     C           K#DL03    KLIST
     C                     KFLD           K#PLAN  5
     C                     KFLD           K#DOCK  4
     C                     KFLD           K#ICCD  5
      *
     C                     TIME           SDATE
      * 3 DAYS BACK
     C                     MOVELTODAY     $DT8
     C                     MOVE '-'       $SIGN
     C                     MOVEL'0003'    $DAYS
     C**                   MOVEL'0365'    $DAYS
     C                     MOVE 'Y'       $IAF
     C                     CALL 'UTLR10'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN    1
     C                     MOVE $TGT8     @@DAT3  60
      *
     C                     ENDSR
      *===============================================================
