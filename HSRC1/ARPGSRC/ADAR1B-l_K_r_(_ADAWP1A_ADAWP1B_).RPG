     C           CASKJY    CABNE*BLANK    @END
      * MASTER CHECK
     C                     SETOF                     99
     C*
     C*--------------------------------*
     C*  出荷マスターから出荷手配日  *
     C*--------------------------------*
     C           CANOBB    IFLE 0
     C                     Z-ADD1         CANOBB
     C                     ELSE
     C           CANOBB    IFGT 4
     C                     Z-ADD1         CANOBB
     C                     END
     C                     END
      *
     C                     SETOF                     11
     C           SYKEY     CHAINGADPL111             11
     C           *IN11     IFEQ '1'
     C           CATEHZ    IFLE 0
     C                     Z-ADD*DATE     CATEHZ
     C                     Z-ADDTETI      CATETI
     C                     Z-ADD0         CASAI1
     C                     Z-ADD0         CASAI2
     C                     Z-ADD0         CASAI3
     C                     END
     C                     GOTO STEP01
     C                     ELSE
      *
     C           B5SKJY    IFEQ 'D'
     C           B5SKHZ    ANDLE*DATE
      *
     C           CATEHZ    IFLE 0
     C                     Z-ADD*DATE     CATEHZ
     C                     Z-ADDTETI      CATETI
     C                     Z-ADD0         CASAI1
     C                     Z-ADD0         CASAI2
     C                     Z-ADD0         CASAI3
     C                     END
     C                     GOTO STEP01
     C                     END
     C                     END
      *
     C                     Z-ADDB5HIZK    CASAI1
     C                     Z-ADDB5KAIS    CASAI2
     C                     Z-ADDB5NBIN    CASAI3
     C*---------------------------*
     C*  分割調整ファイルあり   *
     C*---------------------------*
     C*
     C* MINUS DATA(CANCEL OR  DELETE) SKIPPED
     C*
     C           #APP8     TAG
     C           SYKEY     CHAINADAPP80              90
     C*
     C           *IN90     IFEQ '0'
     C           AHSKJY    ANDEQ*BLANK
     C******     AHSKJY    IFEQ 'D'
     C*******              GOTO #APP8
     C*******              END
     C                     Z-ADDB5HIZK    CNT              CYCLE DAY
     C                     Z-ADDB51STI    CATETI           SHIP TIME
%0001 *
     C           CANOBB    IFEQ 1
     C                     Z-ADDB51STI    CATETI           SHIP TIME
     C                     END
     C           CANOBB    IFEQ 2
     C                     Z-ADDB52STI    CATETI           SHIP TIME
     C                     END
     C           CANOBB    IFEQ 3
     C                     Z-ADDB53STI    CATETI           SHIP TIME
     C                     END
     C           CANOBB    IFEQ 4
     C                     Z-ADDB54STI    CATETI           SHIP TIME
     C                     END
%0001 *
     C           CASAI1    IFEQ *ZERO
     C                     Z-ADD5         CASAI1           CYCLE DAY
     C                     Z-ADD1         CASAI1                 BY
     C                     Z-ADD1         CASAI1                 BIN
     C                     END
     C*
     C                     SETON                     99
     C                     GOTO @D01
     C                     END
     C*
     C*
     C*------------------*
     C*  分割区分＝Ｂ  *
     C*------------------*
     C           CABNKA    IFEQ 'B'
     C                     Z-ADD1         CABNSI
     C                     Z-ADD1         CABNBO
     C                     EXCPTF01
     C                     GOTO @END
     C                     END
      *
     C*----------------------*
     C*  かんばん種類＝Ｋ  *
     C*----------------------*
     C           CASKKB    IFEQ 'K'
     C                     Z-ADD1         CABNSI
     C                     Z-ADD1         CABNBO
     C                     EXCPTF01
     C                     GOTO @END
     C                     END
      *
      *
     C*------------------------------------------*
     C*  ユーザー納入便が１便の時の出荷手配日  *
     C*------------------------------------------*
     C           CANOBB    IFEQ 1
     C                     Z-ADDB51STI    CATETI
     C           CLKEY     SETGTAGDPL121
     C                     ADD  1         B51SCH
     C                     Z-ADD0         CNTXX   50
      *
     C                     DO   *HIVAL
     C                     SETOF                     12
     C                     READPAGDPL121                 12
     C           *IN12     IFEQ '0'
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     GOTO @A01
     C                     END
     C                     END
      *
     C           *IN12     IFEQ '1'
     C                     Z-ADD*DATE     CATEHZ
     C                     Z-ADDTETI      CATETI
     C                     ELSE
     C                     Z-ADDF8KAYY    CATEYY
     C                     Z-ADDF8KAMM    CATEMM
     C                     Z-ADDF8KADD    CATEDD
     C                     ADD  1         CNTXX
     C           CNTXX     IFGE B51SCH
     C                     SETON                     12
     C                     END
     C                     END
      *
     C           @A01      TAG
     C  N12                END
     C                     END
      *
     C*------------------------------------------*
     C*  ユーザー納入便が２便の時の出荷手配日  *
     C*------------------------------------------*
     C           CANOBB    IFEQ 2
     C                     Z-ADDB52STI    CATETI
