     C                     ADD  1         B52SCH
     C                     Z-ADD0         CNTXX
      *
     C                     DO   *HIVAL
     C                     SETOF                     12
     C                     READPAGDPL121                 12
     C           *IN12     IFEQ '0'
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     GOTO @A02
     C                     END
     C                     END
      *
     C           *IN12     IFEQ '1'
     C                     Z-ADD*DATE     CATEHZ
     C                     Z-ADDTETI      CATETI
     C                     ELSE
     C                     Z-ADDF8KAYY    CATEYY
     C                     Z-ADDF8KAMM    CATEMM
