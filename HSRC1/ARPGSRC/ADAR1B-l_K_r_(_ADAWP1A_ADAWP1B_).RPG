     C           @A04      TAG
     C  N12                END
     C                     END
      *
     C           CATEHZ    IFLE 0
     C                     Z-ADD*DATE     CATEHZ
     C                     Z-ADDTETI      CATETI
     C                     END
     C           STEP01    TAG
      *
     C           CANOHZ    IFLE 0
     C                     Z-ADD*DATE     CANOHZ
     C                     END
      *
     C*--------------------------------------------------*
     C*  テーブルの得意先・納入先　　－－＞出荷手配日  *
     C*  　　　　　　　　　　　　以外－－＞納期        *
     C*--------------------------------------------------*
     C*
     C                     SETOF                     30
     C                     Z-ADDCANOHZ    WNTHZ   80
     C           WTKNY     LOKUPHTN                      30
     C           *IN30     IFEQ '1'
     C                     Z-ADDCATEHZ    WNTHZ
     C                     END
      *
     C*------------------------------------------------*
     C*  システム日付＋１から出荷手配日迄の稼動日数  *
     C*  システム日付＋１から納期迄の稼動日数        *
     C*------------------------------------------------*
     C                     Z-ADD0         CNT     50
     C                     Z-ADD*DATE     YMD
     C           KEY3      SETGTAGDPL121
      *
     C                     DO   *HIVAL
     C                     SETOF                     10
     C                     READ AGDPL121                 10
     C           *IN10     IFEQ '0'
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     GOTO @B01
     C                     END
     C                     END
      *
     C           *IN10     IFEQ '0'
     C           F8KAHZ    IFLT WNTHZ
     C                     ADD  1         CNT
     C                     ELSE
     C                     SETON                     10
     C                     END
     C                     END
      *
     C           @B01      TAG
     C  N10                END
      *
      *
     C*----------------------------------------------------*
     C*  平準化ファイルより　＜　バレル×収容数＝？　＞  *
     C*----------------------------------------------------*
     C           @D01      TAG
      *
     C                     SETOF                     10
     C           KEY4      CHAINAGAPL411             10
     C           CBSKJY    IFEQ 'D'
     C           CBSKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
      *
     C           *IN10     IFEQ '0'
     C                     Z-ADDCBBARL    BAL     20
     C                     ELSE
     C                     Z-ADD1         BAL
     C                     Z-ADD1         CBSYUY
     C                     END
      *
     C           BAL       MULT CBSYUY    TANI   100
      *
     C*------------------*
     C*  部品マスター  *
     C*------------------*
     C                     SETOF                     10
     C           KEY4      CHAINFCEPL011             10
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
      *
     C           *IN10     IFEQ '1'
     C                     Z-ADD0         A2KSYS
     C                     Z-ADD0         A2SSYS
     C                     Z-ADD0         A2SYHZ
     C                     MOVE *BLANK    A2KTRK
     C                     MOVE *BLANK    A2KTRT
     C                     MOVE *BLANK    A2KTRR
     C                     MOVE *BLANK    A2KTRD
     C                     MOVE *BLANK    A2STRK
     C                     MOVE *BLANK    A2STRT
     C                     MOVE *BLANK    A2STRR
     C                     MOVE *BLANK    A2STRD
     C                     Z-ADD0         A2TRHZ
     C                     END
      *
     C                     Z-ADD1         CAHAKO
     C                     Z-ADD0         CASYUY
     C           *DATE     IFLT A2SYHZ
     C                     Z-ADDA2KSYS    CASYUY
     C                     ELSE
     C                     Z-ADDA2SSYS    CASYUY
     C                     END
      *
     C           CAHAKO    IFLE 0
     C           CASYUY    IFGT 0
     C           CAOSRY    DIV  CASYUY    CAHAKO
     C                     MVR            AMAR    70
     C           AMAR      IFGT 0
     C                     ADD  1         CAHAKO
     C                     END
     C                     END
     C                     END
      *
     C           *DATE     IFLT A2TRHZ
     C                     MOVELA2KTRK    CABAN1
     C                     MOVELA2KTRT    CABAN2
     C                     MOVELA2KTRR    CABAN3
     C                     MOVELA2KTRD    CABAN4
     C                     ELSE
     C                     MOVELA2STRK    CABAN1
     C                     MOVELA2STRT    CABAN2
     C                     MOVELA2STRR    CABAN3
     C                     MOVELA2STRD    CABAN4
     C                     END
      *
     C* IF DIVISION MASTER EXISTS, MINUS DATA WILL BE DIVIDED
     C           *IN99     IFEQ '0'
     C           CAOSRY    IFLE TANI
     C                     Z-ADD1         CNT
     C                     END
      *
     C           CNT       IFEQ 0
     C                     Z-ADD1         CNT
     C                     END
      *
     C                     END
      *
     C                     MOVE *BLANK    CASKJY
     C                     Z-ADD0         CABNSI
     C                     Z-ADDCNT       CABNBO
      *
     C           CNT       IFEQ 1
     C                     Z-ADD1         CABNSI
     C                     EXCPTF01
     C                     GOTO @END
     C                     END
      *
      *
     C*----------------------------------------------------*
     C*  分割調整ファイルあり                            *
     C*  稼動日数の日当り受注数                        *
     C*  分割データ作成                                  *
     C*----------------------------------------------------*
      *
     C           *IN99     IFEQ '1'
     C                     Z-ADD0         ANS
     C                     Z-ADD0         MVR
     C                     Z-ADDCNT       WCNT
     C           WCNT      IFEQ *ZERO
     C                     Z-ADD1         CNT
     C                     Z-ADD1         WCNT
     C                     END
     C*
     C* QTY PER ONE DAY = REQUEST QTY / CYCLE DAY
     C           CAOSRY    DIV  WCNT      ANS
     C                     MVR            MVR
     C*
     C* CREATE DIVISION DATA FROM SHIP DATE(DELIVERY DATE)
     C*                      TO (SHIP DATE + CYCLE DAY)
     C* IF NOT WORKING DAY, SFIT TO NEXT DAY
     C*
     C           CLKEY     SETLLAGDPL121
     C                     READ AGDPL121                 10
     C           CNT       DOUEQ*ZERO
     C           *IN10     IFEQ '0'
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     GOTO @F01
     C                     END
     C                     END
      *
     C           *IN10     IFEQ '0'
     C           CNT       IFEQ 1
     C           ANS       ADD  MVR       CANSRY
     C                     ELSE
     C                     Z-ADDANS       CANSRY
     C                     END
      *
     C                     Z-ADDF8KAYY    CATEYY
     C                     Z-ADDF8KAMM    CATEMM
     C                     Z-ADDF8KADD    CATEDD
     C                     ADD  1         CABNSI
     C                     EXCPTF01
      *
     C                     SUB  1         CNT
     C                     END
      *
     C           @F01      TAG
     C                     READ AGDPL121                 10
     C  N10                END
      *
     C                     GOTO @END
     C                     END
      *
     C*----------------------------*
     C*  稼動日数の日当り受注数  *
     C*----------------------------*
     C                     Z-ADD0         ANS     70
     C                     Z-ADD0         MVR     70
     C                     Z-ADDCNT       WCNT    50
      *
     C                     SETOF                     30
     C           WTKNY     LOKUPHTN                      30
     C           *IN30     IFEQ '1'
     C                     ELSE
      *
     C           CNT       IFGE 5
     C                     Z-ADD5         WCNT
     C                     END
     C                     END
      *
     C           CAOSRY    DIV  WCNT      ANS
     C                     MVR            MVR
      *
     C                     SETOF                     30
     C           WTKNY     LOKUPHTN                      30
     C           *IN30     IFEQ '1'
      *
     C           KEY3      SETGTAGDPL121
     C                     ELSE
      *
     C*----------------------------------------------*
     C*  ５日以上の稼動日数の場合の出荷手配日計算  *
     C*----------------------------------------------*
     C           CNT       IFGE 5
     C                     Z-ADD0         WTEHZ
     C                     Z-ADD0         @CNT    50
     C           KEY1      SETLLAGDPL121
      *
     C                     DO   *HIVAL
     C                     SETOF                     10
     C                     READPAGDPL121                 10
     C           *IN10     IFEQ '0'
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
     C                     ADD  1         @CNT
     C                     Z-ADDF8KAHZ    WTEHZ
     C           @CNT      IFGE 5
     C                     SETON                     10
     C                     END
     C                     END
     C                     END
     C  N10                END
      *
     C           KEY2      SETGTAGDPL121
     C                     ELSE
      *
     C           KEY3      SETGTAGDPL121
     C                     END
     C                     END
      *
     C*--------------------*
     C*  分割データ作成  *
     C*--------------------*
     C                     Z-ADD0         CNT2    50
     C                     DO   *HIVAL
     C                     SETOF                     10
     C                     READ AGDPL121                 10
     C           *IN10     IFEQ '0'
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     GOTO @C01
     C                     END
     C                     END
      *
     C           *IN10     IFEQ '0'
     C                     ADD  1         CNT2
     C           WCNT      IFEQ CNT2
     C           ANS       ADD  MVR       CANSRY
     C                     ELSE
     C                     Z-ADDANS       CANSRY
     C                     END
      *
     C                     Z-ADDF8KAYY    CATEYY
     C                     Z-ADDF8KAMM    CATEMM
     C                     Z-ADDF8KADD    CATEDD
     C                     ADD  1         CABNSI
     C                     EXCPTF01
      *
     C           CNT2      IFGE WCNT
     C                     SETON                     10
     C                     END
     C                     END
      *
     C           @C01      TAG
     C  N10                END
      *
     C           @END      TAG
