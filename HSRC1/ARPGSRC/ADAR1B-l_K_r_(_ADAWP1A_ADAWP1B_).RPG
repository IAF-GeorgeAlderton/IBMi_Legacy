      *
     C           @A02      TAG
     C  N12                END
     C                     END
      *
     C*------------------------------------------*
     C*  ユーザー納入便が３便の時の出荷手配日  *
     C*------------------------------------------*
     C           CANOBB    IFEQ 3
     C                     Z-ADDB53STI    CATETI
     C           CLKEY     SETGTAGDPL121
     C                     ADD  1         B53SCH
     C                     Z-ADD0         CNTXX
      *
     C                     DO   *HIVAL
     C                     SETOF                     12
     C                     READPAGDPL121                 12
     C           *IN12     IFEQ '0'
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     GOTO @A03
