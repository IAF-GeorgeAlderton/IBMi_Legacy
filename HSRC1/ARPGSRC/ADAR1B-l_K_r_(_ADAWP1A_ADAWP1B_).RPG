     C*------------------------------------------*
     C           CANOBB    IFEQ 4
     C                     Z-ADDB54STI    CATETI
     C           CLKEY     SETGTAGDPL121
     C                     ADD  1         B54SCH
     C                     Z-ADD0         CNTXX
      *
     C                     DO   *HIVAL
     C                     SETOF                     12
     C                     READPAGDPL121                 12
     C           *IN12     IFEQ '0'
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     GOTO @A04
     C                     END
     C                     END
      *
     C           *IN12     IFEQ '1'
     C                     Z-ADD*DATE     CATEHZ
     C                     Z-ADDTETI      CATETI
     C                     ELSE
     C                     Z-ADDF8KAYY    CATEYY
     C                     Z-ADDF8KAMM    CATEMM
     C                     Z-ADDF8KADD    CATEDD
     C                     ADD  1         CNTXX
     C           CNTXX     IFGE B54SCH
     C                     SETON                     12
     C                     END
     C                     END
