     H            Y.                                    1
      ** GDLR99 ********************************************************
      *  CONTROL LOCK                                                  *
      *  N.HYOTO  2001.03.19                                           *
      *                                                                *
      *  P1=1 :LOCK START                                              *
      *    =2 :LOCK RELEASE                                            *
      *  P2=  :OK                                                      *
      *    =1 :SOMEBODY IS USING(LOCK ERROR)                           *
      *    =2 :THIS EXECUTION IS SECIND TIME TODAY                     *
      *    =3 :OTHER EROOR                                             *
      ******************************************************* GDLR99 ***
     FGDLNP10 UF  E           K        DISK
     F******************************************************* GDLR99 ***
     I            DS
     I                                        1  120WKDTTM
     I                                        7  120WKDATE
     I            DS
     I                                        2   80LNDATE
     I                                        1   40LNKOYY
     I                                        5   60LNKOMM
     I                                        7   80LNKODD
     I            DS
     I                                        1   80LNSKHZ
     I                                        1   40LNSKYY
     I                                        5   60LNSKMM
     I                                        7   80LNSKDD
      *------*
      * PARM *
      *------*
     C           *ENTRY    PLIST
     C                     PARM           P1      1        PROCESS CODE
     C                     PARM           P2      1        RESULT CODE
     C*
     C                     TIME           WKDTTM
     C*
     C                     MOVE ' '       P2
     C*
     C* PARAMETER ERROR ?
     C           P1        IFNE '1'
     C           P1        ANDNE'2'
     C                     MOVE '3'       P2
     C                     GOTO #END
     C                     END
      *
     C           'ORDER '  CHAINGDLNP101             90
     C           *IN90     IFEQ '0'
     C*
     C* ALREADY DELETED ?
     C           LNSKJY    IFEQ 'D'
     C           LNSKHZ    ANDLE*DATE
     C                     MOVE '3'       P2
     C                     GOTO #END
     C                     END
     C*
     C* SOMEBODY IS USING ?
     C           P1        IFEQ '1'
     C           LNFLAG    IFEQ '1'
     C                     MOVE '1'       P2
     C                     GOTO #END
     C                     END
     C                     END
      *
     C* THE EXECUTION IS ONCE IN A DAY.
     C           P1        IFEQ '1'
     C           WKDATE    ANDEQLNDATE
     C                     MOVE '2'       P2
     C                     GOTO #END
     C                     END
      *
     C* NOT EXIST FILE
     C                     ELSE
     C                     MOVE '3'       P2
     C                     GOTO #END
     C                     END
      *
     C* PROCESS P1=1(START=SET LOCK)
     C*           =2(END=RELEASE LOCK)
     C           P1        IFEQ '1'
     C                     MOVE '1'       LNFLAG
     C                     UPDATGDLNP101
     C*
     C                     ELSE
     C                     MOVE ' '       LNFLAG
     C                     UPDATGDLNP101
     C                     END
      *
     ******************************************************************
     C           #END      TAG
     C                     SETON                     LR
     C                     RETRN
