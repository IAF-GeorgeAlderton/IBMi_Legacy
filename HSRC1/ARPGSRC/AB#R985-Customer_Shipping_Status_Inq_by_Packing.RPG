     H            Y.
      **AB#R985 ***********************************************
      * CUSTOMER SHIPPING STATUS INQ BY PACKING LIST#         *
      * JW       2022.09.26                                   *
      *********************************************************
     FAB#PW985CF  E                    WORKSTN
     F                                        RRN3  KSFILE SFL03
     FAB#PL76 IF  E           K        DISK
     FAB#PL1N IF  E           K        DISK
     F**AB#PL78 IF  E           K        DISK
     FAB#PLAJ IF  E           K        DISK
     FAB#HL12 IF  E           K        DISK
      *********************************************************
     E                    ERR     1  10 70
     I            DS
     I                                        1   80BANOHZ
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I            DS
     I                                        1  20 BAMHIN
     I                                        1   5 BAMHN1
     I                                        6  10 BAMHN2
     I                                       11  15 BAMHN3
     I                                       16  20 BAMHN4
     I            DS
     I                                        1  14 S3MHIN
     I                                        1   5 S3MHN1
     I                                        6  10 S3MHN2
     I                                       11  14 S3MHN3
     I            DS
     I                                        1  12 S3SHIN
     I                                        1   5 S3SHN1
     I                                        6  10 S3SHN2
     I                                       11  12 S3SHN3
     I            DS
     I                                        1   80PUNOHZ
     I                                        1   40PUNOYY
     I                                        5   60PUNOMM
     I                                        7   80PUNODD
     I            DS
     I                                        1   80K#NOHZ
     I                                        1   40K#NOYY
     I                                        5   60K#NOMM
     I                                        7   80K#NODD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140STIME
     I                                        1   60NOW
     I                                        1   40TODAY
     C******************************************************
     C*  MAIN
     C******************************************************
      *
     C                     EXSR #INIT
      *
     C           *IN99     IFEQ *OFF
     C           PUSKJY    ANDEQ' '
     C                     EXSR #F3RTN
     C                     ENDIF
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C******************************************************
     C*  F3 SCREEN
     C******************************************************
     C           #F3RTN    BEGSR
     C*
     C                     EXSR #F3SET
     C                     Z-ADD1         W#RNP3  40
     C*
     C                     DO   *HIVAL
     C                     MOVEL*ON       *IN48
     C                     MOVEL*OFF      *IN47
     C                     WRITEFMT099
     C                     Z-ADDW#RNP3    #RCN03
     C                     EXFMTCTL03
      * F3/12 END
     C           *INKA     IFEQ *ON
     C           *INKL     OREQ *ON
     C                     MOVE *OFF      *IN49
     C                     MOVE *BLANK    MSG
     C                     LEAVE
     C                     ENDIF
      *
     C  NKJ                MOVELN#MODE    *IN63
      *
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  SET SFL03 DATA
     C******************************************************
     C           #F3SET    BEGSR
     C* CLEAR SFL03
     C                     MOVEL*ON       *IN61
     C                     WRITECTL03
     C                     MOVEL*OFF      *IN61
     C                     MOVEL*OFF      *IN62
     C                     Z-ADD*ZERO     RRN3    40
      *
     C                     MOVEL*ON       *IN63
     C                     MOVEL*ON       N#MODE
      *
     C           K#L1ND    KLIST
     C                     KFLD           K#NOYY  40
     C                     KFLD           K#NOMM  20
     C                     KFLD           K#NODD  20
     C                     KFLD           K#NOBN  20
     C                     KFLD           K#TOKU  40
     C                     KFLD           K#NONY  40
     C                     KFLD           K#NKOJ  1
     C                     KFLD           K#NUKE  4
      *
     C                     Z-ADDPUNOHZ    K#NOHZ
     C                     Z-ADDPUBINN    K#NOBN
     C                     Z-ADDPUCUST    K#TOKU
     C                     Z-ADDPUNONY    K#NONY
     C                     MOVELPUNKOJ    K#NKOJ
     C                     MOVELPUNUKE    K#NUKE
      *
     C           K#L1ND    SETLLAB#PL1N
      *
     C                     DO   *HIVAL
     C           K#L1ND    READEAB#PL1N                  91
     C   91                LEAVE
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           PUODRN    IFNE *BLANK
     C           PUODRN    ANDNEBAODRN
     C                     ITER
     C                     ENDIF
     C* CREATE SUB-FILE
     C                     CLEARSFL03
     C                     MOVELBAMHN1    S3MHN1
     C                     MOVELBAMHN2    S3MHN2
     C                     MOVELBAMHN3    S3MHN3
     C                     MOVELS3MHIN    H3MHIN
     C                     MOVELBASHN1    S3SHN1
     C                     MOVELBASHN2    S3SHN2
     C                     MOVELBASHN3    S3SHN3
      * GET SBAN
     C                     MOVELBANONY    $NONY
     C                     MOVELBANKOJ    $NKOJ
     C                     MOVELBANUKE    $NUKE
     C                     MOVELBAMHIN    $MHIN
     C                     MOVELBANOHZ    $NOHZ
     C                     CALL 'UTLR33A'
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $MHIN  20
     C                     PARM           $NOHZ   8
     C                     PARM           $SBAN   6
     C                     MOVEL$SBAN     S3SBAN
      *
     C           BASYOS    IFNE 0
     C                     Z-ADDBASYOS    S3SYOS
     C                     ELSE
     C                     Z-ADDBAUSYS    S3SYOS
     C                     ENDIF
      *
     C                     Z-ADDBASRYO    S3SRYO
     C                     MOVELBAINVN    S3INVN
     C                     MOVELBAODRN    S3ODRN
     C                     MOVELBAODRN    X3ODRN  10
     C                     MOVELBAEDIK    S3EDIK
      * VW SPECIAL
     C           BANONY    IFEQ 8450
     C           BAEDIK    ANDEQ'E'
     C                     MOVEL'000001'  S3ODRN    P
     C                     ENDIF
      * CHECK BILLED
     C           BAURYY    IFEQ 0
     C                     MOVE *ON       *IN55
     C                     ELSE
     C                     MOVE *OFF      *IN55
     C                     ENDIF
     C                     MOVE *IN55     H3IN55
      *
      * RETIEVE CREATE DATE
     C           K#PLAJ    KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#NKOJ  1
     C                     KFLD           K#NUKE  4
     C                     KFLD           K#NOHZ  80
     C                     KFLD           K#NOBN  20
     C                     KFLD           K#ODRN 10
     C                     KFLD           K#MHIN 20
      *
     C                     MOVELPUNONY    K#NONY
     C                     MOVELPUNKOJ    K#NKOJ
     C                     MOVELPUNUKE    K#NUKE
     C                     Z-ADDPUNOHZ    K#NOHZ
     C                     Z-ADDPUBINN    K#NOBN
     C                     MOVELPUODRN    K#ODRN
     C                     MOVELH3MHIN    K#MHIN    P
      *
     C           K#PLAJ    SETLLAB#PLAJ
     C                     DO   *HIVAL
     C           K#PLAJ    READEAB#PLAJ                  99
     C   99                LEAVE
     C           BASKJY    IFEQ ' '
     C                     Z-ADDBACRHZ    S3CRHZ
     C                     MOVELBACRTM    S3CRTM
     C                     MOVELBACRME    S3CRUS
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      * ADJUST USER
     C           S3EDIK    IFEQ 'E'
     C                     MOVEL'EDI'     S3CRUS    P
     C                     ENDIF
      * GET ORIGINAL QTY
     C                     EXSR #ORG
     C                     Z-ADD@OGQT     S3OGQT
     C           S3SRYO    IFEQ S3OGQT
     C                     MOVE *OFF      *IN56
     C                     ELSE
     C                     MOVE *ON       *IN56
     C                     ENDIF
     C                     MOVE *IN56     H3IN56
      *
     C                     ADD  1         RRN3
     C                     WRITESFL03
      *
     C           RRN3      IFEQ 9999
     C                     LEAVE
     C                     END
      *
     C                     ENDDO
      *
     C           RRN3      IFEQ *ZERO
     C                     CLEARSFL03
     C                     Z-ADD1         RRN3
     C                     WRITESFL03
     C                     MOVEL*ON       *IN49
     C                     MOVELERR,2     MSG
     C                     END
     C*
     C           RRN3      IFEQ 9999
     C                     MOVEL*ON       *IN49
     C                     MOVELERR,3     MSG
     C                     END
     C*
     C                     ENDSR
     C******************************************************
     C* GET ORIGINAL QTY
     C******************************************************
     C           #ORG      BEGSR
      *
     C           K#HL12    KLIST
     C                     KFLD           BANOYY
     C                     KFLD           BANOMM
     C                     KFLD           BANODD
     C                     KFLD           BANOBN
     C                     KFLD           BASHN1
     C                     KFLD           BASHN2
     C                     KFLD           BASHN3
     C                     KFLD           BANONY
     C                     KFLD           BANUKE
     C                     KFLD           BAODRN
      *
     C                     Z-ADD0         @OGQT   70
     C           K#HL12    SETLLAB#HL12
     C                     DO   *HIVAL
     C           K#HL12    READEAB#HL12                  99
     C   99                LEAVE
      *
     C                     Z-ADDAHQTY1    @OGQT
     C                     LEAVE
     C                     ENDDO
      *
     C           @OGQT     IFEQ 0
     C                     Z-ADDS3SRYO    @OGQT
     C                     ENDIF
      *
     C                     ENDSR
     C******************************************************
     C*  INITTIAL SET
     C******************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SERL   9
      *
     C                     TIME           STIME
      * CHECK PACKING LIST#
     C           $SERL     CHAINAB#PL76              99
     C           *IN99     IFEQ *OFF
     C                     Z-ADDPUNOHZ    C3SHDT
     C                     MOVELPUCUST    C3CUST
     C                     MOVELPUNONY    C3NONY
     C                     MOVELPUNKOJ    C3NKOJ
     C                     MOVELPUNUKE    C3NUKE
     C                     Z-ADDPUBINN    C3BINN
     C                     MOVELPUSERL    C3SERL
      * GET DELIVERY NAME
     C                     MOVELPUNONY    $DLV
     C                     CALL 'UTLR62'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTN    1
     C                     MOVEL$NAME2    C3SHNM
     C                     MOVE $NAME1    LTR17  17
     C                     MOVELLTR17     F2NAME
     C                     MOVEL'='       F2NAME
     C                     MOVE '='       F2NAME
     C                     ENDIF
      *
     C                     ENDSR
