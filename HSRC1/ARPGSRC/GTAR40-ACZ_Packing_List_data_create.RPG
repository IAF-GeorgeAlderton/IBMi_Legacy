     H            Y/                                    1
     H** GTAR40 ********************************************
     H*  PACKING LIST DATA CREATE
     H*
     H* TCHK  08/27/12 CREATE
     H******************************************************
     FGTAPW40 CF  E                    WORKSTN
     FGTAPL12 IF  E           K        DISK
     FGTAWP40 IF  E           K        DISK                      A
     FGTAWP41 UF  E           K        DISK                      A
     E******************************************************
     E                    ERR     1  10 20
     I******************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60WSSTM6
     I                                        1   40WSSTM4
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  140WSSDAT
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I            DS
     I                                        1  17 W1BARC
     I                                        1   4 W1CASE
     I                                        5   8 W1CANY
     I                                        9  16 W1CAHK
     I                                       17  17 W1CACK
     C******************************************************
     C* MAIN
     C******************************************************
     C                     EXSR #INIT
     C*
     C                     EXSR #DISP
     C*
     C                     SETON                     LR
     C                     RETRN
     C******************************************************
     C* INIT
     C******************************************************
     C           #INIT     BEGSR
     C*
     C           *ENTRY    PLIST
     C                     PARM           P@TMID  6
     C*
     C                     TIME           WSDT
     C*
     C                     ENDSR
     C******************************************************
     C* DISP
     C******************************************************
     C           #DISP     BEGSR
     C*
     C                     DO   *HIVAL
     C*
     C                     EXFMTFMT100
     C   KC                LEAVE
     C                     MOVEL*BLANK    F1ERR
     C                     MOVEL*OFF      *IN61
     C*
     C                     EXSR #CHK
     C           *IN61     IFEQ *ON
     C                     ITER
     C                     END
     C*
     C                     EXSR #WOUT
     C                     MOVEL*BLANK    F1CASE
     C*
     C           *INKE     IFEQ *ON
     C                     EXSR #CRT
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C* CHECK
     C******************************************************
     C           #CHK      BEGSR
     C*
     C                     DO
     C*
     C           *INKE     IFEQ *ON
     C                     LEAVE
     C                     END
     C*
     C           F1CASE    IFEQ *BLANK
     C                     MOVELERR,1     F1ERR
     C                     MOVEL*ON       *IN61
     C                     LEAVE
     C                     END
     C*
     C                     MOVELF1CASE    W1BARC
     C           W1CASE    CHAINGTAPL12              98
     C           *IN98     IFEQ *ON
     C                     MOVELERR,2     F1ERR
     C                     MOVEL*ON       *IN61
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C* OUT WORK KEY FILE
     C******************************************************
     C           #WOUT     BEGSR
     C*
     C                     DO
     C*
     C           G1CASE    CHAINGTAWP40              97
     C           *IN97     IFEQ *OFF
     C                     LEAVE
     C                     END
     C*
     C                     CLEARGTAWP401
     C                     MOVELG1CASE    W0CASE
     C                     MOVELG1CANY    W0CANY
     C                     MOVELG1CAHK    W0CAHK
     C                     MOVELG1CACK    W0CACK
     C                     WRITEGTAWP401
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C* CREATE PACKING DETAIL DATA
     C******************************************************
     C           #CRT      BEGSR
     C*
     C           *LOVAL    SETLLGTAWP40
     C*
     C                     DO   *HIVAL
     C*
     C                     READ GTAWP40                  96
     C   96                LEAVE
     C*
     C           W0CASE    SETLLGTAPL12
     C*
     C                     DO   *HIVAL
     C*
     C           W0CASE    READEGTAPL12                  95
     C   95                LEAVE
     C           G1SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C*
     C           K#411     KLIST
     C                     KFLD           G1CASE
     C                     KFLD           K@CANY  4
     C                     KFLD           K@CAHK  8
     C                     KFLD           G1CACK
     C                     KFLD           G1ODR1
     C                     KFLD           G1ODR2
     C                     KFLD           G1ODR3
     C                     KFLD           G1IHN1
     C                     KFLD           G1IHN2
     C                     KFLD           G1IHN3
     C                     KFLD           G1IHN4
     C                     MOVELG1CANY    K@CANY
     C                     MOVELG1CAHK    K@CAHK
     C           K#411     CHAINGTAWP41              94
     C           *IN94     IFEQ *ON
     C                     CLEARGTAWP411
     C                     MOVELG1CASE    W1CASE
     C                     MOVELG1CANY    W1CANY
     C                     MOVELG1CAHK    W1CAHK
     C                     MOVELG1CACK    W1CACK
     C                     Z-ADDG1ODR1    W1ODR1
     C                     Z-ADDG1ODR2    W1ODR2
     C                     MOVELG1ODR3    W1ODR3
     C                     MOVELG1ITEM    W1ITEM
     C                     MOVELG1IHN1    W1IHN1
     C                     MOVELG1IHN2    W1IHN2
     C                     MOVELG1IHN3    W1IHN3
     C                     MOVELG1IHN4    W1IHN4
     C                     MOVELG1ITK1    W1ITK1
     C                     MOVELG1ITK2    W1ITK2
     C                     MOVELG1ITK3    W1ITK3
     C                     MOVELG1ITK4    W1ITK4
     C                     Z-ADDG1ISYS    W1QPC
     C                     END
     C*
     C                     ADD  G1ISYS    W1SRYO
     C                     ADD  1         W1BOXS
     C*
     C   94                WRITEGTAWP411
     C  N94                UPDATGTAWP411
     C*
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C                     ENDSR
** ERR
CASE LABEL# ERROR.
CASE LABEL# INVALID.








