     H            Y.
     F** GDSR02 *********************************************
     F*IAF INVOICE NO. CHANGING BY CSV FILE FOR DIES      *
     F*    NAMSU.KIM                       2022.05.18       *
     F****************************************** GDSR02 *****
     FGDSWP02 IF  E                    DISK
     FGDIPL25 UF  E           K        DISK
     FGDSPP02 O   E                    DISK
      *
     I            DS
     I                                        1  140W$TIME
     I                                        1   20W$TIJJ
     I                                        3   40W$TIHH
     I                                        5   60W$TIBB
     I                                        7  140W$TIHZ
     I                                        7  100W$TIYY
     I                                       11  120W$TIMM
     I                                       13  140W$TIDD
     I            DS
     I                                        1  15 G@ODNO
     I                                        1  12 G@ODN1
     I                                       13  15 G@ODN2
     I                                        5   60G@ODR1
     I                                        8   90G@ODR2
     I                                       11  120G@ODR3
     I            DS
     I                                        1   60G#ODER
     I                                        1   20G#ODR1
     I                                        3   40G#ODR2
     I                                        5   60G#ODR3
     I            DS
     I                                        1   7 G@ITM7
     I                                        1   1 G@SKBN
     I                                        3   70G@ITEM
     I            DS
     I                                        1   7 G@INV7
     I                                        1   2 G@INV1
     I                                        4   7 G@INV2
     I            DS
     I                                        1   7 G#INVO
     I                                        1   2 G#INV1
     I                                        3   6 G#INV2
     I            DS
     I                                        1   6 IKINVO
     I                                        1   2 IKINV1
     I                                        3   6 IKINV2
     I            DS
     I                                        1   7 PINVNA
     I                                        1   2 PINVN1
     I                                        3   3 PINVN2
     I                                        4   7 PINVN3
     I            DS
     I                                        1   7 PINVNB
     I                                        1   2 PINVN4
     I                                        3   3 PINVN5
     I                                        4   7 PINVN6
     I            DS
     I                                        1   7 PINVNC
     I                                        1   2 PINVN7
     I                                        3   3 PINVN8
     I                                        4   7 PINVN9
     I           SDS
     I                                      254 263 @@USER
     C           *ENTRY    PLIST
     C                     PARM           PISIRE  4
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
     C           KEYA11    KLIST
     C                     KFLD           G#ODER  60
     C                     KFLD           G#ITEM  50
      *----------------------------------------------------*
      * MAIN ROUTINE                                       *
      *----------------------------------------------------*
     C                     EXSR $SB100
     C                     EXSR $SB200
     C                     EXSR $SB900
      *----------------------------------------------------*
      *初期処理                                          *
      *----------------------------------------------------*
     CSR         $SB100    BEGSR
      *
     C                     TIME           W$TIME
     C                     Z-ADD0         G#NONY  40
     C           PISIRE    IFNE *BLANK
     C                     MOVE PISIRE    G#NONY
     C                     END
      *
     CSR         $S100E    ENDSR
      *----------------------------------------------------*
      *主処理                                            *
      *----------------------------------------------------*
     CSR         $SB200    BEGSR
      *
     C                     DO   *HIVAL
     C                     READ GDSWP021                 90
      *
     C           *IN90     IFEQ '1'
     C                     LEAVE
     C                     END
      * ORDER NO.
     C                     MOVEL*BLANK    G@ODNO 15
     C                     MOVELA@04      G@ODNO
      *
     C           G@ODN2    IFNE *BLANK
     C                     ITER
     C                     END
      *
     C                     Z-ADD0         G#ODER
     C                     Z-ADDG@ODR1    G#ODR1
     C                     Z-ADDG@ODR2    G#ODR2
     C                     Z-ADDG@ODR3    G#ODR3
      *
      * ITEM NO.
     C                     MOVEL*BLANK    G@ITM7  7
     C                     MOVEL*BLANK    G#SKBN  1
     C                     Z-ADD0         G#ITEM  50
     C                     MOVELA@05      G@ITM7
     C                     MOVELG@SKBN    G#SKBN
     C                     Z-ADDG@ITEM    G#ITEM
      *
      * CASE NO.->PALLETE NO.
     C                     MOVEL*BLANK    G#PARE  4
     C                     MOVELA@02      G#PARE
      *
      * BOX NO.
     C                     Z-ADD0         G#BOXN  40
     C                     MOVE A@03      G#BOXN
      *
      * INOVICE NO.
     C                     MOVEL*BLANK    G@INV7  7
     C                     MOVEL*BLANK    G#INV1  2
     C                     MOVEL*BLANK    G#INV2  4
     C                     MOVELA@01      G@INV7
     C                     MOVELG@INV1    G#INV1
     C                     MOVELG@INV2    G#INV2
      *
     C                     EXSR $SB210
      *
     C           GETFLG    IFEQ '1'
     C                     EXSR $SB220
     C                     END
      *
     C                     ENDDO
      *
     CSR         $S200E    ENDSR
      *----------------------------------------------------*
      *対象データの検索                                  *
      *----------------------------------------------------*
     CSR         $SB210    BEGSR
      *
     C                     MOVE *BLANK    GETFLG  1
     C                     Z-ADD0         KSCNT   60
      *
     C           KEYA11    SETLLGDIPL251
     C                     SETOF                     91
      *
     C                     DO   *HIVAL
     C           KEYA11    READEGDIPL251                 91
     C   91                LEAVE
     C           IKSKJY    IFEQ 'D'
     C           IKSKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
      *
     C           G#PARE    IFNE IKPARE
     C                     ITER
     C                     END
      *
     C           G#BOXN    IFNE IKBXNO
     C                     ITER
     C                     END
      *
      *
     C           G#INVO    IFEQ IKINVO
     C                     ITER
     C                     END
      *
     C                     MOVE IKINV1    PINVN1
     C                     MOVE '-'       PINVN2
     C                     MOVE IKINV2    PINVN3
      *
     C                     Z-ADDW$TIYY    IKKOYY
     C                     Z-ADDW$TIMM    IKKOMM
     C                     Z-ADDW$TIDD    IKKODD
     C                     Z-ADDW$TIJJ    IKKOHH
     C                     Z-ADDW$TIHH    IKKOSS
     C                     MOVEL@@USER    IKKOME
     C                     MOVELG#INVO    IKINVO
     C                     UPDATGDIPL251
      *
     C                     MOVE '1'       GETFLG
     C                     ADD  1         KSCNT
      *
     C                     ENDDO
      *
     CSR         $S210E    ENDSR
      *----------------------------------------------------*
      *更新対象記録　　　                                *
      *----------------------------------------------------*
     CSR         $SB220    BEGSR
      *
     C                     CLEARGDSPP021
      *
     C                     Z-ADDW$TIYY    A@KOYY
     C                     Z-ADDW$TIMM    A@KOMM
     C                     Z-ADDW$TIDD    A@KODD
     C                     Z-ADDW$TIJJ    A@KOJJ
     C                     Z-ADDW$TIHH    A@KOHH
     C                     Z-ADDW$TIBB    A@KOBB
     C                     MOVEL'GDSR02'  A@PGMN
     C                     MOVEL@@USER    A@KOME
      *
     C                     MOVELPINVNA    A@PINV
     C                     MOVELA@01      A@INV7
     C                     MOVELA@02      A@CAS4
     C                     MOVELA@03      A@BOXN
     C                     MOVELA@04      A@ODNO
     C                     MOVELA@05      A@ITM7
     C                     MOVELA@06      A@DIEN
     C                     MOVELA@07      A@ADIE
     C                     MOVELA@08      A@ADRS
     C                     MOVELA@09      A@PTNM
     C                     Z-ADDKSCNT     A@KSRN
      *
     C                     WRITEGDSPP021
      *
     CSR         $S220E    ENDSR
      *----------------------------------------------------*
      *終了処理                                          *
      *----------------------------------------------------*
     CSR         $SB900    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         $S900E    ENDSR
