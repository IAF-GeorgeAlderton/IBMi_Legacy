     H            Y.
     F** FBER03 ********************************************
     F*  DISPLAY ERROR MSG - PROCESS COST UPLOAD           *
     F*  J.W     2021.08.24                                *
     F******************************************************
     FFBEPW03 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN   KSFILE SFL01
     FFBEWP03 IF  E           K        DISK
      *
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        7  120@TODAY
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
      *
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C* INITIAL SETTINGS
     C*===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
JW   C                     TIME           SDATE
     C*  SFLCLR
     C                     SETON                     82
     C                     WRITECTL01
     C                     SETOF                     82
     C                     Z-ADD0         RRN     40
     C                     Z-ADD0         ENDRRN  40
     C*
     C*-------------------------
S1   C                     DO   *HIVAL
     C                     READ FBEWP03                  90
     C   90                LEAVE
      *
     C                     Z-ADDSEQ       S1SEQ
     C                     Z-ADDLINE#     S1LIN
     C                     MOVELT4MCN#    S1MCN
     C                     MOVELT4PROC    S1PRC
     C                     MOVELT4SHN1    S1SHN1
     C                     MOVELT4SHN2    S1SHN2
     C                     MOVELT4SHN3    S1SHN3
     C                     Z-ADDT4COST    S1CST
     C                     MOVELXMSG      S1MSG
      *
     C                     ADD  1         RRN
     C                     WRITESFL01
E1   C                     ENDDO
     C*-------------------------
     C           RRN       IFEQ 0
     C                     MOVE '#END    '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     Z-ADD1         DSPRRN
     C                     ENDIF
     C                     ENDSR
     C*===============================================================
      * DSPLAY SCREEN 1
     C*===============================================================
     C           #DSP1     BEGSR
     C                     SETON                     71
     C                     WRITEDSP99
     C                     EXFMTCTL01
     C                     SETOF                     71
     C                     MOVEA'0'       *IN,99
     C                     Z-ADD$$RRN     DSPRRN
      *----*
      * F3 *
      *----*
     C   KC                MOVE '#END    '@STEP
     C   KC                GOTO XDSP1
      *
     C           XDSP1     ENDSR
