     H            Y.
     F** ALDR6C2 ***************************************************************
     F*  SHORTAGE SUMMARY DATA WORK FILE (CSV)                                 *
     F*  JW    2022.06.07                                                      *
     F**************************************************************************
     FALDWL6C IF  E           K        DISK
     FALDWP6C2O   E                    DISK
     F****************************************************************
     I            DS
     I                                        1  12 W$SHIN
     I                                        1   5 W$LPR1
     I                                        6  10 W$LPR2
     I                                       11  12 W$LPR3
     I            DS
     I                                        1   6 W$LOC
     I                                        1   1 W$LOC1
     I                                        2   3 W$LOC2
     I                                        4   5 W$LOC3
     I                                        6   6 W$LOC4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I**************************************************************
      *
     C                     EXSR #INIT
      *
     C**         *LOVAL    SETLLALDWL6C
     C                     DO   *HIVAL
     C                     READ ALDWL6C                  98
     C   98                LEAVE
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     EXSR #HEAD
     C                     ENDIF
      *
     C                     EXSR #DTL
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------------
      * SET HEADER
      *------------------------------------------------------------
     C           #HEAD     BEGSR
      *
     C                     MOVEL'IAF_PART'W2SHIN    P
     C                     MOVEL'LOCATION'W2LOC     P
     C                     MOVEL'BOXES   'W2BOXS    P
     C                     MOVEL'TOYOTA  'W2BOX1    P
     C                     MOVEL'HONDA   'W2BOX2    P
     C                     MOVEL'FORD    'W2BOX3    P
     C                     MOVEL'TIER1   'W2BOX4    P
     C                     MOVEL#PGM      W2NOTE    P
     C                     WRITEALDW6C21
      *
     C                     ENDSR
      *------------------------------------------------------------
      * SET DETAIL
      *------------------------------------------------------------
     C           #DTL      BEGSR
      *
     C                     MOVELW$SHIN    $SHIN     P
     C                     CALL 'EDTR02'
     C                     PARM           $SHIN  12
     C                     PARM           $SHIN2 14
     C                     MOVEL$SHIN2    W2SHIN    P
      *
     C                     MOVELW$LOC     $LOC6
     C                     CALL 'EDTR06B'
     C                     PARM           $LOC6   6
     C                     PARM           $LOC9   9
     C                     MOVEL$LOC9     W2LOC     P
      *
     C                     MOVELW$BOXS    W2BOXS    P
     C                     MOVELW$BOX1    W2BOX1    P
     C                     MOVELW$BOX2    W2BOX2    P
     C                     MOVELW$BOX3    W2BOX3    P
     C                     MOVELW$BOX4    W2BOX4    P
     C                     MOVE *BLANK    W2NOTE
      *
     C                     WRITEALDW6C21
      *
     C                     ENDSR
      *------------------------------------------------------------
      * INITIAL SETTING
      *------------------------------------------------------------
     C           #INIT     BEGSR
      *
     C                     MOVE 'Y'       FIRST   1
      *
     C                     ENDSR
