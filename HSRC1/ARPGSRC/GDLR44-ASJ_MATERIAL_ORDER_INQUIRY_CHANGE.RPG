      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#GL1     KLIST
     C                     KFLD           K@ZAIS 15
     C                     KFLD           K@ZAIK  52
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#GL      KLIST
     C                     KFLD           K@ZAIS 15
     C                     KFLD           K@ZAIK  52
     C           K#ABB     KLIST
TCHK1C                     KFLD           K@KAKE  40
     C                     KFLD           K@ZAIS
     C                     KFLD           K@ZAIK
     C                     KFLD           K@YM
      * PREVIOUS WORKING DAY
     C                     Z-ADD*ZERO     RRN1    40
     C                     MOVEL'01'      W@ID    2
     C                     Z-ADD*DATE     K@YMD
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     Z-ADDF8KYMD    D@TO
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
      *
     C                     WRITEDSP99
     C                     EXFMTDSP01
     C                     SELEC
      * F3
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET
     C           *IN99     IFEQ *OFF
     C           RRN1      IFGT 0
     C                     MOVE '02'      W@ID
     C                     ELSE
     C                     MOVE MSG,1     D@MSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
