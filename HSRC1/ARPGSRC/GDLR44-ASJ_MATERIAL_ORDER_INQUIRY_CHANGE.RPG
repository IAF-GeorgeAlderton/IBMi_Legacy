      *   2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
      *
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCNO1
      *
     C                     SELEC
      * F3
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * GO BACK
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      W@ID
      *
TCHK2C*                    OTHER
TCHK2C*                    EXSR #CHK2
TCHK2C*          *IN99     IFEQ *OFF
TCHK2C*          *INKE     ANDEQ*ON
TCHK2C*                    EXSR #UPD
TCHK2C*                    MOVE '01'      W@ID
TCHK2C*                    ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
