TCHK2C*                    MVR            @@MVR   52
TCHK2C*          @@MVR     IFNE *ZERO
TCHK2C*                    MOVE *ON       *IN62
TCHK2C* N99                MOVE MSG,2     D@MSG
TCHK2C*                    MOVE *ON       *IN99
TCHK2C*                    ENDIF
TCHK2C*                    ENDIF
TCHK2C*                    ELSE
TCHK2C*                    MOVE *BLANK    S@CONF
TCHK2C*                    ENDIF
TCHK2 *
