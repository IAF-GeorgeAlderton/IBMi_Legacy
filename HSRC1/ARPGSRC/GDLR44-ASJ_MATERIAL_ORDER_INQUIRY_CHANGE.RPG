TCHK2C*                    Z-ADD*ZERO     WRRN    40
TCHK2C*          *IN90     DOUEQ*ON
TCHK2C*                    ADD  1         WRRN
TCHK2C*          WRRN      CHAINSFL01                90
TCHK2C*          *IN90     IFEQ *OFF
TCHK2C*                    MOVEA'00'      *IN,61
TCHK2C*                    Z-ADD*ZERO     S@NXQT
TCHK2C*          S@TDQT    IFNE H@TDQT
TCHK2C*          S@CONF    ANDNE'Y'
TCHK2C*                    MOVE *ON       *IN61
TCHK2C*                    MOVE *ON       *IN99
TCHK2C*                    MOVE MSG,3     D@MSG
TCHK2C*                    ENDIF
TCHK2 *
TCHK2C*          S@CONF    IFEQ 'Y'
