      *   CHECK
      *------------------------------------------------------
     C           #CHK      BEGSR
      * DATE CHECK
     C                     SETOF                     6199
     C                     MOVE *BLANK    D@MSG
     C                     Z-ADDD@TO      K@YMD
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR SUB FILE
      *------------------------------------------------------
     C           #SET      BEGSR
      * DATE SET
     C                     EXSR #DATE
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1
      *
     C           *LOVAL    SETLLGDLPL14
      *
     C           *IN80     DOUEQ*ON
     C                     READ GDLPL14                  80
     C           *IN80     IFEQ *OFF
     C           LBSKJY    ANDEQ*BLANK
TCHK3C*TCHK1     LBSIRE    ANDEQ0002
TCHK3C           LBSIRE    ANDEQ8990
     C                     MOVE LBZAIS    K@ZAIS
     C                     Z-ADDLBZAIK    K@ZAIK
TCHK1C                     Z-ADDLBSIRE    K@KAKE
     C                     Z-ADDDAT,5     K@YMD
     C                     EXSR #SET1
     C           *IN99     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C           K#GL      SETGTGDLPL14
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     Z-ADD1         #RCNO1
      *
     C                     ENDSR
      *------------------------------------------------------
      *   DATE SET
      *------------------------------------------------------
     C           #DATE     BEGSR
      *
     C                     Z-ADD*ZERO     DT
     C                     Z-ADD*ZERO     DAT
     C                     Z-ADD*ZERO     X       30
     C           K#AGD     SETGTAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     ADD  1         X
     C                     Z-ADDF8KYMD    DAT,X
     C                     Z-ADDF8KADD    DT,X
     C                     Z-ADDF8YOBI    W       10
     C                     MOVE DAY,W     DY,X
     C           X         IFEQ 5
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      * TODAY
     C                     Z-ADD*DATE     K@YMD
     C           K#AGD     CHAINAGDPL12              90
     C                     Z-ADDF8KYMD    D@DATT
     C                     Z-ADDF8KYMD    W@DATT  80
     C                     Z-ADDF8YOBI    W       10
     C                     MOVE DAY,W     D@DYT
      * NEXT WORKING DAY
     C           K#AGD     SETGTAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READ AGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     Z-ADDF8KYMD    D@DATN
     C                     Z-ADDF8KYMD    W@DATN  80
     C                     Z-ADDF8YOBI    W       10
     C                     MOVE DAY,W     D@DYN
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR SUB FILE
      *------------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     CLEARSFL01
      *
     C           K#GL1     SETLLGDLPL14
     C           *IN81     DOUEQ*ON
     C           K#GL      READEGDLPL14                  81
     C           *IN81     IFEQ *OFF
     C           LBSKJY    ANDEQ*BLANK
     C           LBYMD     IFGT D@TO
     C                     LEAVE
     C                     ENDIF
TCHK3C*TCHK1     LBSIRE    IFNE 0002
TCHK3C           LBSIRE    IFNE 8990
TCHK1C                     ITER
TCHK1C                     END
      *
     C                     Z-ADD1         X
     C           LBYMD     LOKUPDAT,X                    10
     C   10                ADD  LBMAIS    QT,X
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     XFOOTQT        S@TOTL
      * TODAY'S ORDER
      *    PLANNED
     C                     Z-ADD*DATE     K@YMD
     C                     Z-ADD*DAY      X
     C           K#ABB     SETLLBTBPL06
     C           *IN90     DOUEQ*ON
     C           K#ABB     READEBTBPL06             N    90
     C           *IN90     IFEQ *OFF
     C           BTSKJY    ANDEQ*BLANK
     C           #ZM,X     IFNE *BLANK
     C*****                MOVE MSG,4     D@MSG
     C******               MOVE *ON       *IN99
     C******               LEAVE
     C                     ELSE
     C                     ADD  #PH,X     S@ORTT
     C                     SUB  #MH,X     S@ORTT
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *  SCANNED
     C           K#GL      SETLLGDLPL04
     C           *IN90     DOUEQ*ON
     C           K#GL      READEGDLPL04             N    90
     C           *IN90     IFEQ *OFF
     C           LASKJY    ANDEQ*BLANK
TCHK3C*TCHK1     LASIRE    ANDEQ0002
TCHK3C           LASIRE    ANDEQ8990
     C                     ADD  LAMAIS    S@ORTT
     C                     ENDIF
     C                     ENDDO
      *  ADJUSTED
     C           K#GL      SETLLBTBPL41
     C           *IN90     DOUEQ*ON
     C           K#GL      READEBTBPL41                  90
     C           *IN90     IFEQ *OFF
     C           B4SKJY    ANDEQ*BLANK
TCHK3C*TCHK1     B4SIRE    ANDEQ0002
TCHK3C           B4SIRE    ANDEQ8990
     C                     SUB  B4MAIS    S@ORTT
     C                     ENDIF
     C                     ENDDO
      *
     C           S@TOTL    IFGT *ZERO
     C           S@ORTT    ORGT *ZERO
      * VALUES IN THE MATERIAL MASTER FILE.
     C           K#GL      SETLLIZAPL01
     C           *IN90     DOUEQ*ON
     C           K#GL      READEIZAPL01                  90
     C           *IN90     IFEQ *OFF
     C           ZCSKJY    ANDEQ*BLANK
     C           ZCYMD     ANDEQ99999999
TCHK3C*TCHK1     ZCKAKE    ANDEQ0002
TCHK3C           ZCKAKE    ANDEQ8990
      *
     C           ZCMKJR    DIV  20        @@MKJR  92H
     C           ZCTKJR    IFNE *ZERO
     C           @@MKJR    DIV  ZCTKJR    S@SETW    H
     C                     ENDIF
     C                     Z-ADDZCLOTO    S@LOT
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      * INVENTORY DAYS
TCHK2C*          S@ORTT    DIV  S@SETW    S@INVD
TCHK2C*                    MVR            @@MVR   52
TCHK2C*          @@MVR     IFGT *ZERO
TCHK2C*                    ADD  1         S@INVD
TCHK2C*                    ENDIF
      *
TCHK2C*          S@INVD    IFGT 3
TCHK2C*                    MOVE *ON       *IN01
TCHK2C*                    MOVE '*'       S@ASTR
TCHK2C*                    ELSE
TCHK2C*                    MOVE *OFF      *IN01
TCHK2C*                    MOVE *BLANK    S@ASTR
TCHK2C*                    ENDIF
      *
     C           S@ORTT    IFGE S@LOT
     C                     MOVE '*'       S@AST2
     C           S@LOT     IFNE *ZERO
     C           S@ORTT    DIV  S@LOT     @@ANS   30
     C           @@ANS     MULT S@LOT     S@TDQT
     C           S@ORTT    SUB  S@TDQT    S@NXQT
     C           S@NXQT    IFLT *ZERO
     C                     Z-ADD*ZERO     S@NXQT
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     ADD  1         RRN1
     C                     MOVELK@ZAIS    S@ZAIS
     C                     Z-ADDK@ZAIK    S@ZAIK
     C                     MOVELK@ZAIS    H@ZAIS
     C                     Z-ADDK@ZAIK    H@ZAIK
     C                     Z-ADDS@TDQT    H@TDQT
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     ENDSR
