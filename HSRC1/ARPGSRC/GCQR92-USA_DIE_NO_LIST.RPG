     F********************* GCQR92 **
     FGCQWP91 IP  F     100            DISK
     FFCQPL21 IF  E           K        DISK
     FFCQPL31 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
     IGCQWP91 AA  01
     I                                        1  15 IFKATAL1
     I                                        1   2 IKAT1
     I                                        4   7 IKAT2
     I                                       16  220ITANK
     I                                       23  260IKOCD
     I                                       27  33 ITKRO
     I                                       27  27 ITKR1
     I                                       28  29 ITKR2
     I                                       30  31 ITKR3
     I                                       32  32 ITKR4
     I                                       33  33 ITKR5
     I                                       34  360ISYOS
     I                                       37  450ISRYO
      *
     C           KEY1      KLIST
     C                     KFLD           IKAT1
     C                     KFLD           IKAT2
      *
     C                     SETOF                     80
      *
     C           *IN81     IFEQ '0'
     C                     SETON                     8081
     C                     TIME           TIME    60
     C                     END
      *
     C           *INL1     IFEQ '1'
     C                     ADD  1         WKDAT   50
      *
     C                     SETOF                     11
     C                     Z-ADD0         WKNO1   51
     C           KEY1      CHAINFCQPL311             11
     C           *IN11     IFEQ '0'
     C           Q4SKJY    IFEQ *BLANK
     C                     Z-ADDQ4KNO1    WKNO1
     C                     END
     C                     END
      *
     C                     Z-ADD0         @TANK   70
      *
     C                     END
      *
     C           @TANK     IFEQ 0
     C                     Z-ADDITANK     @TANK
     C                     ELSE
     C           ITANK     IFLT @TANK
     C                     Z-ADDITANK     @TANK
     C                     END
     C                     END
      *
     C                     MOVE *BLANK    WMEISY 10
     C                     SETOF                     10
     C           IKAT1     CHAINFCQPL211             10
     C           *IN10     IFEQ '0'
     C           O9SKJY    ANDEQ*BLANK
     C                     MOVE O9KANM    WMEISY
     C                     END
      *
     C                     MOVE *BLANK    WKATNM 16
     C                     SETOF                     10
     C           IKOCD     CHAINFGBPL011             10
     C           *IN10     IFEQ '0'
     C                     MOVELB2SMEI    WKATNM
     C                     END
      *
     C           ISRYO     DIV  10000     WSRYO   61
      *
     C                     Z-ADD0         WGEKN
     C           WKNO1     IFNE 0
     C           WSRYO     DIV  WKNO1     WGEKN   61H
     C                     END
      *
     CL1         WGEKN     IFNE 0
     CL1         @TANK     MULT WGEKN     @KTHI1 150
     CL1                   ADD  @KTHI1    @KTHI  150
     CL1                   END
      *
     OQPRINT  H    2   80
     O       OR        OF
     O                                  191 '+----------------------+'
     O        H    3   80
     O       OR        OF
     O                                  191 '|          |           |'
     O        H    4   80
