     H            Y.
     FCA#PWC1 CF  E                    WORKSTN
     E                    ER      1   6 20
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20WTIJJ
     I                                        3   40WTIHH
     I                                        5   60WTIBB
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     C           *ENTRY    PLIST
     C                     PARM           P@USRC  6
      *
     C                     CALL 'MRHR79'
     C                     PARM           P@USRC  6
     C                     PARM           P@OPNM 20
      *
     C           P@OPNM    IFNE *BLANK
     C                     MOVE P@USRC    F1USRC
     C                     END
      *
     C           @DSP01    TAG
      *
     C                     EXFMTFMT100
      *
     C                     MOVEL*BLANK    F1ERR
      *
     C           *INKC     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           F1BARC    IFEQ *BLANK
     C                     MOVELER,01     F1ERR
     C                     SETON                     99
     C                     GOTO @DSP01
     C                     END
      *
     C                     MOVELF1BARC    Q@BARC 20
     C                     CALL 'BARR81'
     C                     PARM           Q@BARC 20
     C                     PARM           Q@KRKB  1
     C                     PARM           Q@ZETI  4
     C                     PARM           Q@TEHI  3
     C                     PARM           Q@PAGN  2
     C                     PARM           Q@BCKA  1
     C                     PARM           Q@BCTK  1
     C                     PARM           Q@BCYK  1
     C                     PARM           Q@BCHK  1
     C                     PARM           Q@BCKD  1
      *
     C                     MOVELF1BARC    PMAREA
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
      *
     C                     CALL 'CHKR01'
     C                     PARM           PMAREA100        *フィールド
     C                     PARM '014'     PMBYTE  3        *有効桁数
     C                     PARM           PMCHK   1        * KｨｭHMﾞpﾞｭN
     C                     PARM           PMRTCD  1        * xJｰmｰNﾞ
      *
     C           Q@BCKD    IFNE PMCHK
     C                     MOVELER,02     F1ERR
     C                     SETON                     99
     C                     GOTO @DSP01
     C                     END
      *
     C                     MOVELF1BARC    Q#BARC
     C                     CALL 'CA#RC5'
     C                     PARM           Q#BARC 20
     C                     PARM           Q#KOT   3
     C                     PARM           Q#BMN  16
     C                     PARM           Q#KBN   3
     C                     PARM           Q#HAK   1
     C                     PARM           Q#NYD   80
     C                     PARM           Q#NYB   20
     C                     PARM           Q#NO    20
      *
     C           Q#NO      IFEQ 91
     C                     MOVELER,03     F1ERR
     C                     SETON                     99
     C                     GOTO @DSP01
     C                     END
      *
     C           Q#NO      IFEQ 0
     C                     MOVELER,04     F1ERR
     C                     SETON                     99
     C                     GOTO @DSP01
     C                     END
      *
     C           @F150     TAG
      *
     C                     EXFMTFMT150
      *
     C                     MOVEL*BLANK    F1ERR
      *
     C           *INKC     IFEQ '1'
     C                     GOTO @DSP01
     C                     END
      *
     C           Q#PCNO    IFEQ 0
     C                     MOVELER,05     F1ERR
     C                     SETON                     99
     C                     GOTO @F150
     C                     END
      *
     C           Q#PCNO    IFNE Q#NO
     C                     MOVE Q#NO      W#NO    2
     C                     MOVELER,06     F1ERR
     C                     CAT  W#NO:0    F1ERR
     C                     SETON                     99
     C                     GOTO @F150
     C                     END
      *
     C           @DSP02    TAG
      *
     C                     EXFMTFMT200
      *
     C                     MOVEL*BLANK    F1ERR
      *
     C           *INKC     IFEQ '1'
     C                     GOTO @F150
     C                     END
      *
     C                     TIME           WTIME
      *
     C                     Z-ADDWTIHZ     P@KND   80
     C                     Z-ADDWJFB      P@KNT   60
     C                     MOVELP@USRC    P@KNN  10
     C                     CALL 'CA#RC6'
     C                     PARM           Q#BARC 20
     C                     PARM           Q#NO
     C                     PARM           P@KND   80
     C                     PARM           P@KNT   60
     C                     PARM           P@KNN  10
      *
     C                     SETON                     LR
     C                     RETRN
** ER
INPUT BARCODE
CHECK DIGIT ERR
DATA NOT FOUND
NO DATE BLANK
INPUT
CURRENT NO.
