     H            Y.
     F** GDLR5F ****************************************************************
     F*  PROGRAM    : TSUSHO PRINT MATERIAL ORDER RECEIVE REPORT               *
     F*  WRITTEN    : 12/3/2020 COPIED FROM GLDR4F                             *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F*  FUNCTION   : READ GDLWP4D AND OUTPUT TO QPRINT                        *
     F**************************************************************************
JW   FGDLWP5D IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     I            DS
     I                                        3  10 ORD#
     I                                        1   40GDDTYY
     I                                        5   5 HI1
     I                                        6   70GDDTMM
     I                                        8   8 HI2
     I                                        9  100GDDTDD
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR @INIT
      *
     C           *IN98     DOWEQ*OFF
JW   C                     READ GDLWP5D                  98
     C           *IN98     IFEQ *OFF
     C                     EXSR @PRINT
     C                     ENDIF
     C                     ENDDO
      * PRINT FOOT
     C                     EXCPT@FOT
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           @PRINT    BEGSR
      *
     C           LINE#     IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LINE#
     C                     ENDIF
      *PRINT BLANK
     C           LINE#     IFNE 0
     C           SVORD#    ANDNE*BLANK
     C           SVORD#    ANDNEORD#
     C                     ADD  1         LINE#
     C                     EXCPT@BLANK
     C                     ENDIF
      *CONVERT
     C                     MOVELGDCIL#    XDCIL#  30
      *
     C                     ADD  1         SEQ#
     C                     ADD  1         LINE#
     C                     EXCPT@DTL
     C                     MOVELORD#      SVORD#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           @INIT     BEGSR
      *
     C                     Z-ADD*DATE     @DATE   80
     C                     TIME           @TIME   60
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LINE#   30
     C                     MOVE '-'       HI1     1
     C                     MOVE '-'       HI2     1
     C                     MOVE *BLANK    SVORD#  8
      * PRINT HEADER
     C                     EXCPT@HDR
     C                     Z-ADD3         LINE#
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                         #USER     21
     O                                   40 '** MATERIAL ORDER RE'
JW   O                                   60 'CEIVE REPORT ** (TOY'
     O                                   80 'OTA TSUSHO)         '
     O                                   99 'DATE'
     O                         @DATE    102 '    .  .  '
     O                         @TIME    112 '  :  :  '
     O                                  117 'P.'
     O                         PAGE  Z  121
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   13 'ORDER#'
     O                                   21 'WIRE'
     O                                   40 'DIAMETER'
     O                                   46 'TYPE'
     O                                   64 'HEAT#'
     O                                   81 'WEIGHT'
     O                                   85 'M#'
     O                                   98 'COIL#'
     O        E 1              @DTL
     O                         SEQ#  Z +001
     O                         ORD#    +002
     O                         GDZAIS  +002
     O                         GDZAIK1 +002
     O                         GDTYPE  +002
     O                         GDHEAT  +002
     O                         GDWHT 1 +002
     O                         GDM#    +002
     O                         XDCIL#1 +002
     O        E 1              @BLANK
     O                                    1 ' '
     O        E 1              @FOT
     O                                   19 '** END OF REPORT **'
