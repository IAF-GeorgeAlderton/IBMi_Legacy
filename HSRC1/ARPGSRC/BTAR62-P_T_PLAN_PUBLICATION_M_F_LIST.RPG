     C                     MOVE PSTDT     @STDT
     C                     MOVE PEDST     @EDDT
     C                     EXSR #BCHK
     CL1         WBTAK     IFEQ '1'
     CL1                   EXCPTODAT
     CL1                   END
     CL1                   MOVE *BLANK    WBTAK   1
      *----------------------------------------------------*
      *  パラメータＴＲＡＮＣＦＥＲ                      *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           PCMD    2
     C                     PARM           PSTDT   8
     C                     PARM           PEDST   8
     C                     PARM           PCFLG   1
     C                     PARM           PTFLG   1
     C*--------------------------------------------------------------*
     C*初期化処理
     C*--------------------------------------------------------------*
     C           *INZSR    BEGSR
     C*
     C                     MOVE *BLANK    WBTAK
     C*
     C                     ENDSR
      *----------------------------------------------------*
      *ＢＴＡ存在チェック                                *
      *----------------------------------------------------*
     CSR         #BCHK     BEGSR
      *
 S2  C           BTSKJY    IFEQ 'D'
     C           BTSKHZ    ANDLE*DATE
 X2  C                     ELSE
  S3 C           BTKEYM    IFGE @STYM
     C           BTKEYM    ANDLE@EDYM
      *
     C                     Z-ADD1         #A      20
     C                     Z-ADD31        #B      20
     C           BTKEYM    IFEQ @STYM
     C                     Z-ADD@STDD     #A
     C                     END
     C           BTKEYM    IFEQ @EDYM
     C                     Z-ADD@EDDD     #B
     C                     END
     C           #A        DO   #B        #A
     C           #PH,#A    IFEQ 0
     C           #MH,#A    ANDEQ0
     C                     ELSE
     C                     MOVE '1'       WBTAK
     C                     END
     C                     ENDDO
  E3 C                     END
 E2  C                     END
      *
     CSR         EBCHK     ENDSR
     OBTAWP60 E                ODAT
