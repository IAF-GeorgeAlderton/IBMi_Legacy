%9999C           #ECK05    ENDSR
      ******************************
      * GTCPP41 --> UPDAT  GTBPP10 *
      ******************************
%9999C           #CK41     BEGSR
      *
     C           KEY03     KLIST
     C                     KFLD           G4SHN1
     C                     KFLD           G4SHN2
     C                     KFLD           G4SHN3
      *
     C           *LOVAL    SETLLGTCPP41
     C                     DO   *HIVAL
     C                     SETOF                     90
     C                     READ GTCPP411                 90
     C           *IN90     IFEQ '0'
      *
     C           G4SKJY    IFEQ 'D'
     C           G4SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     SETOF                     50
     C                     Z-ADD0         @MAIS   50
     C           KEY03     CHAINGTBPL101             50
     C           *IN50     IFEQ '0'
     C           IBSKJY    IFEQ 'D'
     C           IBSKHZ    ANDLE*DATE
     C                     SETON                     50
     C                     END
     C                     END
      *
 S1  C           *IN50     IFEQ '0'
     C           IBMAIS    SUB  G4MAIS    @MAIS
     C           @MAIS     IFEQ 0
     C                     MOVEL'D'       IBSKJY
     C                     Z-ADD*DATE     IBSKHZ
     C                     Z-ADD*DATE     IBKOHZ
     C                     Z-ADD@TIME     IBKOTM
     C                     MOVELPPUSER    IBKOME
     C                     UPDATGTBPL101
     C                     DELETGTCPP411
      *--------------------*
      * 2004.11.08 MSK     *
      *--------------------*
     C           IBMAIS    MULT -1        @@MAIS  50
     C                     Z-ADD0         WKSEQN  50
     C                     MOVEL'7'       @@NYKB  1
     C                     MOVEL*BLANK    @@DEL   1
     C                     EXCPTFILE
     C                     Z-ADD0         @@MAIS  50
     C                     MOVEL*BLANK    @@NYKB
      *
     C                     END
      *
     C           @MAIS     IFGT 0
     C           @MAIS     SUB  IBMAIS    @@MAIS
     C                     MOVEL*BLANK    IBSKJY
     C                     Z-ADD0         IBSKHZ
     C                     Z-ADD*DATE     IBKOHZ
     C                     Z-ADD@TIME     IBKOTM
     C                     Z-ADD@MAIS     IBMAIS
     C           IBSYOS    MULT @MAIS     IBSURY
     C                     MOVELPPUSER    IBKOME
     C                     UPDATGTBPL101
     C                     DELETGTCPP411
      *--------------------*
      * 2004.11.08 MSK     *
      *--------------------*
     C                     Z-ADD0         WKSEQN  50
     C                     MOVEL'7'       @@NYKB  1
     C                     MOVEL*BLANK    @@DEL   1
     C                     EXCPTFILE
     C                     Z-ADD0         @@MAIS  50
     C                     MOVEL*BLANK    @@NYKB
      *
     C                     END
      *
     C           @MAIS     IFLT 0
     C                     MOVEL'D'       IBSKJY
     C                     Z-ADD*DATE     IBSKHZ
     C                     Z-ADD*DATE     IBKOHZ
     C                     Z-ADD@TIME     IBKOTM
     C                     MOVELPPUSER    IBKOME
     C                     UPDATGTBPL101
     C                     Z-SUB@MAIS     G4MAIS
     C                     UPDATGTCPP411
      *--------------------*
      * 2004.11.08 MSK     *
      *--------------------*
     C           IBMAIS    MULT -1        @@MAIS  50
     C                     Z-ADD0         WKSEQN  50
     C                     MOVEL'7'       @@NYKB  1
     C                     MOVEL*BLANK    @@DEL   1
     C                     EXCPTFILE
     C                     Z-ADD0         @@MAIS  50
     C                     MOVEL*BLANK    @@NYKB
      *
     C                     END
 S1  C                     END
      *
     C                     END
     C                     END
     C  N90                ENDDO
