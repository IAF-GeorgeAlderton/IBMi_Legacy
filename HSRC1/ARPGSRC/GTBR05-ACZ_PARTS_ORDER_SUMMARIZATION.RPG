 E2  C                     END
      *
 S3  C           IAMAIS    IFGT 0
     C           IAMAIS    SUB  G4MAIS    WMAIS   30
 S4  C           WMAIS     IFEQ 0
     C                     DELETGTCPP411
     C                     Z-ADD0         WWMAIS
     C                     GOTO #ECHG
 E4  C                     END
 S5  C           WMAIS     IFGT 0
     C                     DELETGTCPP411
     C                     Z-ADDWMAIS     WWMAIS
     C                     GOTO #ECHG
 E5  C                     END
 S6  C           WMAIS     IFLT 0
     C                     MOVEL*BLANK    G4SKJY
     C                     MOVEL*BLANK    G4SKHZ
     C                     MOVEL*DATE     G4KOHZ
     C                     MOVELPPUSER    G4KOME
     C                     Z-ADD@TIME     G4KOTM
     C                     Z-SUBWMAIS     G4MAIS
     C                     UPDATGTCPP411
     C                     Z-ADD0         WWMAIS
     C                     GOTO #ECHG
 E6  C                     END
 E3  C                     END
      *
     C                     END
      *
 E1  C                     END
     C           *IN70     IFEQ '1'
      *
 S7  C           IAMAIS    IFLT 0
     C           WKOSN     IFEQ *BLANK
