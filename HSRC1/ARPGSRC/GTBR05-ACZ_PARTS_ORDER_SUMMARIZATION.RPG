     C                     MOVELGTSHN1    IBHIN1
     C                     MOVELGTSHN2    IBHIN2
     C                     MOVELGTSHN3    IBHIN3
     C                     Z-ADD@@PLUS    @@MAIS  50
     C                     Z-ADD0         WKSEQN  50
