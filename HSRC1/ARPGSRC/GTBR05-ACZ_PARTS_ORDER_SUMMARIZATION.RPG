%9999C           #KOSN     BEGSR
     C           @MAIS     IFEQ 0
     C           @KOSN     IFEQ '*'
     C                     MOVEL'D'       IBSKJY
     C                     Z-ADD*DATE     IBSKHZ
     C                     Z-ADD*DATE     IBKOHZ
     C                     Z-ADD@TIME     IBKOTM
