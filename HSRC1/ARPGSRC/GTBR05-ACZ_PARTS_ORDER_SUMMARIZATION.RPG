     C                     MOVEL*BLANK    @@DEL   1
     C                     EXCPTFILE
     C                     Z-ADD0         @@MAIS  50
     C                     MOVEL*BLANK    @@NYKB
      *
     C                     Z-ADD@@MINS    @@MAIS  50
     C                     Z-ADD0         WKSEQN  50
     C                     MOVEL'6'       @@NYKB  1
     C                     MOVEL*BLANK    @@DEL   1
     C                     EXCPTFILE
     C                     Z-ADD0         @@MAIS  50
     C                     MOVEL*BLANK    @@NYKB
      *
     C                     END
     C           @MAIS     IFGT 0
     C           @KOSN     IFEQ '*'
     C                     MOVEL*BLANK    IBSKJY
     C                     Z-ADD0         IBSKHZ
     C                     Z-ADD*DATE     IBKOHZ
     C                     Z-ADD@TIME     IBKOTM
     C                     MOVELPPUSER    IBKOME
     C                     Z-ADD@MAIS     IBMAIS
     C           IBSYOS    MULT IBMAIS    IBSURY
     C                     UPDATGTBPL101
      *--------------------*
      * 2004.11.08 MSK     *
      *--------------------*
     C                     Z-ADD@@PLUS    @@MAIS  50
     C                     Z-ADD0         WKSEQN  50
     C                     MOVEL'5'       @@NYKB  1
     C                     MOVEL*BLANK    @@DEL   1
     C                     EXCPTFILE
     C                     Z-ADD0         @@MAIS  50
     C                     MOVEL*BLANK    @@NYKB
      *
     C                     Z-ADD@@MINS    @@MAIS  50
     C                     Z-ADD0         WKSEQN  50
     C                     MOVEL'6'       @@NYKB  1
     C                     MOVEL*BLANK    @@DEL   1
     C                     EXCPTFILE
     C                     Z-ADD0         @@MAIS  50
     C                     MOVEL*BLANK    @@NYKB
      *
     C                     ELSE
      *
     C                     MOVE *BLANK    IBZETI
     C                     MOVE *BLANK    IBSEIH
     C                     MOVE GTSHN1    IBHIN1
     C                     MOVE GTSHN2    IBHIN2
     C                     MOVE GTSHN3    IBHIN3
      *KANBAN TYPE
     C                     Z-ADD0         IBSYOS
     C                     EXSR #TYPE
      *
     C           IBSYOS    IFEQ 0
      *
     C                     SETOF                     53
     C           KEY02     CHAINFCEPL011             53
     C           *IN53     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     53
     C                     END
     C           *IN53     IFEQ '0'
     C                     MOVELA2ZETI    IBZETI
     C           A2SYHZ    IFGT *DATE
     C                     Z-ADDA2KSYS    IBSYOS
     C                     ELSE
     C                     Z-ADDA2SSYS    IBSYOS
     C                     END
     C                     ELSE
      *
     C                     SETOF                     53
     C           KEY02     CHAINAKCPL011             53
     C           *IN53     IFEQ '0'
     C           M1SKJY    ANDEQ'D'
     C           M1SKHZ    ANDLE*DATE
     C                     SETON                     53
     C                     END
     C           *IN53     IFEQ '0'
     C           M1SYHZ    IFGT *DATE
     C                     Z-ADDM1KSYS    IBSYOS
     C                     ELSE
     C                     Z-ADDM1SSYS    IBSYOS
     C                     END
     C                     END
     C                     END
      *
     C                     END
      *
     C                     MOVEL*BLANK    IBSKJY
     C                     Z-ADD0         IBSKHZ
     C                     Z-ADD*DATE     IBKOHZ
     C                     Z-ADD@TIME     IBKOTM
     C                     MOVELPPUSER    IBKOME
     C                     Z-ADD@MAIS     IBMAIS
     C           IBSYOS    MULT IBMAIS    IBSURY
      *
     C                     WRITEGTBPL101
      *--------------------*
      * 2004.11.08 MSK     *
      *--------------------*
     C                     Z-ADD@@PLUS    @@MAIS  50
     C                     Z-ADD0         WKSEQN  50
     C                     MOVEL'5'       @@NYKB  1
     C                     MOVEL*BLANK    @@DEL   1
     C                     EXCPTFILE
