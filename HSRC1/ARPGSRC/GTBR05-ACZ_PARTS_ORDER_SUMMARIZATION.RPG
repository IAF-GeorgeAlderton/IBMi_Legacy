     C                     MOVEL'6'       @@NYKB  1
     C                     MOVEL*BLANK    @@DEL   1
     C                     EXCPTFILE
     C                     Z-ADD0         @@MAIS  50
     C                     MOVEL*BLANK    @@NYKB
      *
      *
     C                     END
