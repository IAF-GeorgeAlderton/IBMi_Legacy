     C                     Z-ADD*DATE     @WYMD
     C           @WMM      IFEQ 01
     C                     SUB  1         @WYY
     C                     Z-ADD12        @WMM
     C                     ELSE
     C                     SUB  1         @WMM
     C                     END
      *
     C           1         SETLLGTCPP05
     C                     DO   *HIVAL
     C                     SETOF                     9052
     C                     READ GTCPP051                 90
     C           *IN90     IFEQ '0'
      *
     C           GTSKJY    IFEQ 'D'
     C           GTSKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     MOVEL*BLANK    @KOSN   1
     C                     SETOF                     50
     C                     Z-ADD0         @MAIS   50
     C           KEY02     CHAINGTBPL101             50
     C           *IN50     IFEQ '0'
     C                     MOVEL'*'       @KOSN
     C           IBSKJY    IFEQ 'D'
     C           IBSKHZ    ANDLE*DATE
     C                     SETON                     50
     C                     END
     C                     END
     C           *IN50     IFEQ '0'
     C                     Z-ADDIBMAIS    @MAIS
     C                     END
      *
     C           @WYM      IFEQ GTKEYM
      *
     C                     Z-ADD0         @@PLUS  50
     C                     Z-ADD0         @@MINS  50
     C                     Z-ADD1         U
     C           1         DO   31        U
     C           HTZ,U     IFEQ *BLANK
     C           HTP,U     IFNE 0
     C           HTM,U     ORNE 0
     C                     SETON                     52
     C                     ADD  HTP,U     @@PLUS
     C                     ADD  HTP,U     @MAIS
     C                     ADD  HTM,U     @@MINS
     C                     SUB  HTM,U     @MAIS
     C                     MOVE '*'       HTZ,U
     C                     END
     C                     END
     C                     ENDDO
      *
     C           *IN52     IFEQ '1'
     C                     UPDATGTCPP051
     C                     EXSR #CHG1
     C                     EXSR #KOSN
     C                     END
      *
     C                     END
      *
     C           $WYM      IFEQ GTKEYM
     C                     Z-ADD0         @@PLUS  50
     C                     Z-ADD0         @@MINS  50
      *
     C                     Z-ADD1         U
     C           1         DO   $WDD      U
     C           HTZ,U     IFEQ *BLANK
     C           HTP,U     IFNE 0
     C           HTM,U     ORNE 0
     C                     SETON                     52
     C                     ADD  HTP,U     @@PLUS
     C                     ADD  HTP,U     @MAIS
     C                     ADD  HTM,U     @@MINS
     C                     SUB  HTM,U     @MAIS
     C                     MOVE '*'       HTZ,U
     C                     END
     C                     END
     C                     ENDDO
      *
     C           *IN52     IFEQ '1'
     C                     UPDATGTCPP051
     C                     EXSR #CHG1
     C                     EXSR #KOSN
     C                     END
      *
     C                     END
      *
     C                     END
     C                     END
     C  N90                ENDDO
