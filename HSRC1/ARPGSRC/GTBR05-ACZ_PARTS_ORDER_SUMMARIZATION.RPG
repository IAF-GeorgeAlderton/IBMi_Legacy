     C*
     C           ETYPE     ENDSR
     ****************************************************************
     C           #LST      BEGSR
     ****************************************************************
     C*
     C           KEY04     KLIST
     C                     KFLD           L5SHN1  5
     C                     KFLD           L5SHN2  5
     C                     KFLD           L5SHN3  2
     C*
     C                     CLOSEGTBPL10
     C                     SETOF                     91
     C                     OPEN GTBPL10
     C                     READ GTBPL10                  91
     C           *IN91     DOWEQ'0'
     C*
     C           IBSKJY    IFEQ 'D'
     C           IBSKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELIBHIN1    L5SHN1
     C                     MOVELIBHIN2    L5SHN2
     C                     MOVELIBHIN3    L5SHN3
     C                     SETOF                     20
     C           KEY04     SETGTAAPTL01                    TO GET DFNQTY
     C           #AP       TAG
     C           KEY04     REDPEAAPTL01                  20TO GET DFNQTY
     C           *IN20     IFEQ '0'
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    ANDLE*DATE
     C                     GOTO #AP
     C                     END
     C*
     C           L5STHZ    IFNE 99999999
     C                     GOTO #AP
     C                     END
     C*
     C                     MOVE L5TKR1    @LOC1   1
     C                     MOVE L5TKR2    @LOC2   2
     C                     MOVE L5TKR3    @LOC3   2
     C                     MOVE L5TKR4    @LOC4   1
      *
     C                     Z-ADD0         WKSURY  92
     C           L5KTSU    IFEQ L5KSSU
     C           L5KTSU    MULT 5         WKSURY  92H
     C                     ELSE
     C           L5KSSU    MULT 5         WKSURY    H
     C                     ENDIF
      *
     C                     Z-ADD0         W1SURY  92H
     C                     Z-ADD0         W2SURY  92H
     C           WKSURY    MULT 1.5       W1SURY  92H
     C           WKSURY    MULT 0.5       W2SURY  92H
     C           W1SURY    IFLE IBSURY
     C           W2SURY    ORGE IBSURY
     C*
     C           *IN21     IFEQ '0'
     C           *INOF     OREQ '1'
     C                     SETON                     21
     C                     TIME           @@TIME
     C                     EXCPTHD
     C                     ENDIF
     C*
     C                     MOVEL*BLANKS   IBDIFF  1        PLUS OR MINUS
     C           W1SURY    IFLE IBSURY
     C                     MOVEL'+'       IBDIFF           PLUS OR MINUS
     C                     ENDIF
     C*
     C           W2SURY    IFGE IBSURY
     C                     MOVEL'-'       IBDIFF           PLUS OR MINUS
     C                     ENDIF
     C*
     C                     Z-ADDWKSURY    DFNQTY  70       OUTFLD DFNQTY
     C                     Z-ADDW1SURY    IBMAX   70       MAX. QTY
     C                     Z-ADDW2SURY    IBMIN   70       MIN. QTY
      *
     C           IBSYOS    IFNE *ZERO
     C           IBMIN     DIV  IBSYOS    MINBOX  50
     C                     MVR            @@MVR   50
     C           @@MVR     IFNE *ZERO
     C                     ADD  1         MINBOX
     C                     ENDIF
     C           DFNQTY    DIV  IBSYOS    DFNBOX  50
     C                     MVR            @@MVR   50
     C           @@MVR     IFNE *ZERO
     C                     ADD  1         DFNBOX
     C                     ENDIF
     C           IBMAX     DIV  IBSYOS    MAXBOX  50
     C                     MVR            @@MVR   50
     C           @@MVR     IFNE *ZERO
     C                     ADD  1         MAXBOX
     C                     ENDIF
     C                     ELSE
     C                     Z-ADD*ZERO     MINBOX
     C                     Z-ADD*ZERO     DFNBOX
     C                     Z-ADD*ZERO     MAXBOX
     C                     ENDIF
      *
     C           DFNBOX    SUB  IBMAIS    BOX1    50 111213
     C           MAXBOX    SUB  IBMAIS    BOX2    50 313233
      * ACTUAL
     C                     MOVE IBHIN1    K@HIN1
     C                     MOVE IBHIN2    K@HIN2
     C                     MOVE IBHIN3    K@HIN3
     C                     EXSR #ACT
      * LAST ORDER
     C                     EXSR #ORD
      *
     C                     EXCPTDT
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C*
     C                     READ GTBPL10                  91
     C                     ENDDO
     C                     CLOSEGTBPL10
     C                     ENDSR
      *-----------------------------------------------------------
      *  ACTUAL
      *-----------------------------------------------------------
     C           #ACT      BEGSR
      *
     C                     Z-ADD@@DAT1    K@YMD
     C                     Z-ADD*DATE     WWYMD   80
     C                     EXSR #ACT1
      *
     C           IBSYOS    IFNE *ZERO
     C           @SHQY     DIV  IBSYOS    @ABOX5    H
     C                     ELSE
     C                     Z-ADD*ZERO     @ABOX5  72
     C                     ENDIF
      *
     C                     Z-ADD@ABOX5    W@ABX5  50
     C                     MOVE @ABOX5    W@2     20
     C           W@2       IFNE *ZERO
     C                     ADD  1         W@ABX5
     C                     ENDIF
      *
     C                     Z-ADD@@DAT2    K@YMD
     C                     Z-ADD@@DAT1    WWYMD   80
     C                     EXSR #ACT1
      *
     C           IBSYOS    IFNE *ZERO
     C           @SHQY     DIV  IBSYOS    @ABOXB    H
     C                     ELSE
     C                     Z-ADD*ZERO     @ABOXB  72
     C                     ENDIF
      *
     C                     Z-ADD@ABOXB    W@ABXB  50
     C                     MOVE @ABOXB    W@2     20
     C           W@2       IFNE *ZERO
     C                     ADD  1         W@ABXB
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *  ACTUAL
      *-----------------------------------------------------------
     C           #ACT1     BEGSR
     C                     Z-ADD*ZERO     @SHQY  110
     C           K#AB      SETLLAB#PL18
     C           *IN95     DOUEQ*ON
     C           K#ABX     READEAB#PL18                  95
     C           *IN95     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           ABYMD     IFGE WWYMD
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  BASRYO    @SHQY
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *  LAST ORDER
      *-----------------------------------------------------------
     C           #ORD      BEGSR
      *
