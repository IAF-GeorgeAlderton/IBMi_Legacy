     C                     ADD  M1KSTI    GK08    50
     C                     ADD  M1TSTI    GK09    40
     C                     ADD  M1KADU    GK10    51
     C                     ADD  DEKI      GK11    80
     C                     ADD  M1DNKI    GK12    30
     C                     ADD  MUHN      GK13    70
      * 係合計 *
     C                     ADD  M1DNTI    GR01    50
     C                     ADD  M1TYTI    GR02    50
     C                     ADD  M1DMTI    GR03    50
     C                     ADD  M1ZITI    GR04    50
     C                     ADD  M1ZMTI    GR05    50
