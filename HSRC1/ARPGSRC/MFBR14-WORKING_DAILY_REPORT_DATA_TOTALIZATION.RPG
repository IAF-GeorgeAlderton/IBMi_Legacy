     C                     KFLD           M1KIBN
     C                     KFLD           M1KIHS
      **************
      * 初期設定 *
      **************
     C           *IN11     IFEQ '0'
     C                     Z-ADD0         KITN1   95
     C                     Z-ADD0         KITN2   95
     C                     MOVEL@HIZU     HIZU    80
     C                     TIME           WTIME   60
     C                     MOVE *BLANK    KMEI   18
     C           M1KJCD    CHAINFGBPL011             30
     C           *IN30     IFEQ '0'
     C                     MOVELB2SMEI    KMEI
     C                     END
     C                     EXCPTMI
     C                     SETON                     11
     C                     END
      ****************
      * リスト作成 *
      ****************
      * 機番 *
     C                     SETOF                     20
     C           M1KIHS    IFEQ *BLANK
     C                     SETON                     20
     C                     END
      * 昼夜区分 *
     C                     MOVE *BLANK    HYK     6
     C           M1HYKU    IFEQ 'H'
     C                     MOVEL'DAY '    HYK
     C                     ELSE
     C                     MOVE 'NGHT'    HYK
     C                     END
      * 停止時間Ａ *
     C                     Z-ADD0         DAMI    40
     C                     ADD  M1KSTI    DAMI
     C                     ADD  M1DNTI    DAMI
     C                     ADD  M1TYTI    DAMI
     C                     ADD  M1ZITI    DAMI
     C           DAMI      DIV  60        TISA    85
      * 停止時間Ｂ *
     C                     Z-ADD0         DAMI
     C                     ADD  M1KTTI    DAMI
     C                     ADD  M1ZMTI    DAMI
     C                     ADD  M1DMTI    DAMI
     C                     ADD  M1KNTI    DAMI
     C           DAMI      DIV  60        TISB    85
      * 稼動時間－Ａ－Ｂ *
     C           M1KADU    SUB  TISA      TISC    85
     C                     SUB  TISB      TISC
      * 稼動時間－Ｂ *
     C           M1KADU    SUB  TISB      TISD    85
      * Ｆ *
     C                     SETOF                     70
     C                     Z-ADD0         FFFF    95
     C           KEY1      CHAINMFAPL221             70
     C   70      KEY1      CHAINMFAPL261             70
     C           *IN70     IFEQ '0'
     C           M1DEKI    SUB  M1MUHN    XX1     70
     C           XX1       DIV  M@RPMH    FFFF
     C                     ADD  FFFF      KITN1
     C                     ADD  FFFF      KITN2
     C                     END
      * 性能稼動率 *
     C                     Z-ADD0         SKRT    62
     C           TISC      IFEQ 0
     C                     Z-ADD0         XX2
     C                     ELSE
     C           FFFF      DIV  TISC      XX2     74H
     C                     END
     C           XX2       MULT 100       SKRT
      * 時間稼動率 *
     C                     Z-ADD0         JKRT    62
     C           TISD      IFEQ 0
     C                     Z-ADD0         TISE
     C                     Z-ADD0         XX3
     C                     ELSE
     C           TISC      DIV  TISD      TISE    85
     C           TISC      DIV  TISD      XX3     74H
     C                     END
     C           XX3       MULT 100       JKRT
      * 設備総合効率 *
     C                     Z-ADD0         KART    52
     C           TISE      MULT XX2       XX4     74H
     C           XX4       MULT 100       KART
     C           KART      COMP 0                      21
      * ？＊倍数 *
     C           M1DEKI    MULT M1BISU    DEKI    70
     C           M1MUHN    MULT M1BISU    MUHN    70
      * 倍数の表示
     C                     MOVE *BLANK    BIKO    2
     C           M1BISU    IFNE 1
     C           M1BISU    LOKUPTAB1      TAB2           70
     C   70                MOVELTAB2      BIKO
     C                     END
      * 課合計 *
     C                     ADD  M1DNTI    GK01    50
     C                     ADD  M1TYTI    GK02    50
     C                     ADD  M1DMTI    GK03    50
     C                     ADD  M1ZITI    GK04    50
