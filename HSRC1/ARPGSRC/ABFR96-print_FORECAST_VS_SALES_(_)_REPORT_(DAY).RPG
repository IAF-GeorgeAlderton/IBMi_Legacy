     H            Y/
     F** ABFR96 **********************************************
     F*  PRINT "FORECAST VS SALES (%) REPORT" (DAY)          *
     F*  J.WATANABE 2018.07.27                               *
     F********************************************************
     FABFWP82SIF  E           K        DISK
     FGADTL17 IF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
     F********************************************************
     E                    DLV     1  10  4
     I            DS
     I                                        1  102C8FBOX
     I                                        1   80INT1
     I                                        9  100DCM1
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ ABFWP82S                 98
     C   98                LEAVE
      * CHECK DELIVERY CODE
     C                     MOVELC2NONY    XNONY   4
     C           XNONY     LOKUPDLV                      99
     C  N99                ITER
      * BREAK?
     C           SVNONY    IFNE 0
     C           SVNONY    ANDNEC2NONY
     C                     EXCPT#BLANK
     C                     ENDIF
     C                     Z-ADDC2NONY    SVNONY
      *
     C           C2NONY    CHAINGADTL17              99
     C   99                MOVE *BLANK    @NAME
     C  N99                MOVELB5KMEI    @NAME
     C                     EXSR #PRINT
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 64
     C                     EXCPT@HDR
     C                     Z-ADD4         LIN#
     C                     ENDIF
      *
     C                     EXCPT@DTL1
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $TGTYM  6
      *
     C                     TIME           SDATE
     C                     Z-ADD0         SVNONY  40
     C                     Z-ADD88        LIN#    30
     C                     MOVE *BLANK    @NAME  15
     C                     MOVEL$TGTYM    LTR4    4
     C                     MOVE $TGTYM    LTR2    2
     C                     MOVEL'    /  ' XTGTYM  7
     C                     MOVELLTR4      XTGTYM
     C                     MOVE LTR2      XTGTYM
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   30 '** FORECAST VS SALES'
     O                                   50 ' (%) REPORT **  AS OF '
     O                         XTGTYM    57
     O                                   66 '==DAY=='
     O                                   99 'DATE'
     O                         TODAY    102 '    .  .  '
     O                         NOW      112 '  :  :  '
     O                                  116 'P.'
     O                         PAGE  Z  120
     O        E   03           @HDR
     O                                    6 'DELIV'
     O                                   12 'NAME'
     O                                   30 'MONTH'
     O                                   45 'FORECAST'
     O                                   59 'SALES'
     O                                   75 'FORECAST'
     O                                   89 'SALES'
     O        E   04           @HDR
     O                                   45 '   (QTY)'
     O                                   59 ' (QTY)'
     O                                   75 '   (BOX)'
     O                                   89 ' (BOX)'
     O                                  102 'BOX RATE%'
      *
     O        E 1              @DTL1
     O                         C2NONY  +002
     O                         @NAME   +002
     O                         C2FCYM  +002 '    /  '
     O                         C2FQTYJ +002
     O                         C2SQTYJ +002
     O                         C2FBOXJ +002
     O                         C2SBOXJ +002
     O                         C2RATEJ +004
      *
     O        E 1              #BLANK
     O                                    1 '.'
      *
** DELIVERY CODE
3347
3428
3481
3504
3764
3804
3851
3931


