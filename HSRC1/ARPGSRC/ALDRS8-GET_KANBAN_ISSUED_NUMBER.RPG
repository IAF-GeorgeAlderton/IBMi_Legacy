     H            Y
     F*** ALDRS8 ******************************************************
     F*  GET KANBAN ISSUED NUMBER                                     *
     F*---------------------------------------------------------------*
     F*   DATE   |CO.LTD| NAME     | THE CONTENTS                     *
     F*---------------------------------------------------------------*
     F*2021.01.21|DCS   |T.MITSUI  |INITIAL VERSION                   *
     F*****************************************************************
     F*        INPUT/OUTPUT DEFINED                       *
     F*****************************************************
     F*==< SHIPPING SCAN RESULT FILE. <APICS KANBAN> >==*
     FALDPL30 IF  E           K        DISK
     F*
     F*==< 3PT SERVICE PART SCAN RESULTS FILE >==*
     FALSPL01 IF  E           K        DISK
     F*
     F*==< CREFORM MATERIAL PULL SCAN RESULT FILE >==*
     FALJPL10 IF  E           K        DISK
     F*
     F*==<つるべ生産指示PRODUCTION REORDER AND OVER MADE ACCUMLATION FILE >==*
     FADAPL90 IF  E           K        DISK
     F*
     I*****************************************************
     I*        DATA STRUCTURE DEFINED                     *
     I*****************************************************
     I*==< ALDPL30 >==*
     I*         ( OUT-GOING DATE )
     I            DS
     I                                        1   80A3SYDT
     I                                        1   40A3SYYY
     I                                        5   60A3SYMM
     I                                        7   80A3SYDD
     I*==< ADAPL90 >==*
     I*         ( UPDATE WORK DATE )
     I            DS
     I                                        1   80ADKODT
     I                                        1   40ADKOYY
     I                                        5   60ADKOMM
     I                                        7   80ADKODD
     I*
     C*****************************************************
     C*          PARAMETER DEFINED                        *
     C*****************************************************
     C           *ENTRY    PLIST
     C*                   ( IN )
     C                     PARM           P#CHYU  1
     C                     PARM           P#ZENO  4
     C                     PARM           P#THNO  3
     C                     PARM           P#HTHZ  80
     C*                   ( OUT )
     C                     PARM           P#MAIS  50
     C*
     C*****************************************************
     C*          KEY ITEM DEFINED                         *
     C*****************************************************
     C*==< ALDPL30,ALSPL01,ALJPL10 >==*
     C           K@KEY1    KLIST
     C                     KFLD           K@ZENO  4
     C                     KFLD           K@THNO  3
     C*
     C*==< ADAPL90 >==*
     C           K@KEY2    KLIST
     C                     KFLD           K@CHYU  1
     C                     KFLD           K@ZENO  4
     C                     KFLD           K@THNO  3
     C*
     C*****************************************************
     C*          MAIN ROUTINE                             *
     C*****************************************************
     C                     Z-ADD*ZERO     P#MAIS
     C*
     C                     MOVELP#CHYU    K@CHYU
     C                     MOVELP#ZENO    K@ZENO
     C                     MOVELP#THNO    K@THNO
     C*
     C* ALDPP30  -----------------------------------------*
     C*                    ____________
     C           K@KEY1    SETLLALDPL30
     C           K@KEY1    READEALDPL30                  91
     C*                    ~~~~~~~~~~~~
D----C           *IN91     DOWEQ'0'
|I---C           A3SYDT    IFGE P#HTHZ
||   C                     ADD  1         P#MAIS
|E---C                     ENDIF
|    C*                    ____________
|    C           K@KEY1    READEALDPL30                  91
|    C*                    ~~~~~~~~~~~~
E----C                     ENDDO
     C*
     C* ALSPP01  -----------------------------------------*
     C*                    ____________
     C           K@KEY1    SETLLALSPL01
     C           K@KEY1    READEALSPL01                  92
     C*                    ~~~~~~~~~~~~
D----C           *IN92     DOWEQ'0'
|I---C           ASSKJY    IFEQ 'D'
||   C           ASSKDT    ANDLE*DATE
|+---C                     ELSE
||I--C           ASCODT    IFGE P#HTHZ
|||  C           ASOKNG    ANDEQ'OK'
|||  C                     ADD  1         P#MAIS
||E--C                     ENDIF
|E---C                     ENDIF
|    C*                    ____________
|    C           K@KEY1    READEALSPL01                  92
|    C*                    ~~~~~~~~~~~~
E----C                     ENDDO
     C*
     C* ALJPP10  -----------------------------------------*
     C*                    ____________
     C           K@KEY1    SETLLALJPL10
     C           K@KEY1    READEALJPL10                  93
     C*                    ~~~~~~~~~~~~
D----C           *IN93     DOWEQ'0'
|I---C           B0DATE    IFGE P#HTHZ
||   C                     ADD  1         P#MAIS
|E---C                     ENDIF
|    C*                    ____________
|    C           K@KEY1    READEALJPL10                  93
|    C*                    ~~~~~~~~~~~~
E----C                     ENDDO
     C*
     C* ADAPP90  -----------------------------------------*
     C*                    ____________
     C           K@KEY2    SETLLADAPL90
     C           K@KEY2    READEADAPL90                  94
     C*                    ~~~~~~~~~~~~
D----C           *IN94     DOWEQ'0'
|I---C           ADKODT    IFGE P#HTHZ
||   C                     ADD  1         P#MAIS
|E---C                     ENDIF
|    C*                    ____________
|    C           K@KEY2    READEADAPL90                  94
|    C*                    ~~~~~~~~~~~~
E----C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
