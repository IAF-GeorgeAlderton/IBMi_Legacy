     H            Y.
     F** MRHR15 ******************************************
     F* PILOT LOCATION LIST                              *
     F*   ITS.    2014.05.16                             *
     F****************************************************
     FMRHPL11 IF  E           K        DISK
     FMRHPL51 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FFCEPL30 IF  E           K        DISK
     FMRHWP13 O   E                    DISK                      A
     I*<<システム日時>>
     I            DS
     I                                        1  140S@TIME
     I                                        1   60S@HMS
     I                                        1   20S@TMHH
     I                                        3   40S@TMMM
     I                                        5   60S@TMSS
     I                                        7  140S@YYMD
     I                                        7  100S@DYYY
     I                                       11  120S@DYMM
     I                                       13  140S@DYDD
      *
     I            DS
     I                                        1  12 SBHIN
     I                                        1   5 SBHIN1
     I                                        6  10 SBHIN2
     I                                       11  12 SBHIN3
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1DVKB  1
     C                     PARM           P1CMD   2
      *-------------------*
      * INIT              *
      *-------------------*
     C                     READ MRHPL111                 81
     C           *IN81     DOWEQ'0'
     C                     EXSR #SB400
     C                     READ MRHPL111                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-------------------*
      * DETAIL            *
      *-------------------*
     CSR         #SB400    BEGSR
      *
     C                     CLEARMRHWP131
     C                     MOVELSBBAN1    W0BAN1
     C                     MOVELSBBAN2    W0BAN2
     C                     MOVELSBBAN3    W0BAN3
     C                     MOVELSBBAN4    W0BAN4
     C                     Z-ADDSBHAKO    W0HAKO
     C                     MOVELSBHIN1    W0HIN1
     C                     MOVELSBHIN2    W0HIN2
     C                     MOVELSBHIN3    W0HIN3
     C                     MOVELSBLNO1    W0LNO1
     C                     MOVELSBLNO2    W0LNO2
     C                     Z-ADDSBSCHZ    W0SCHZ
     C                     Z-ADDSBGRHZ    W0GRHZ
     C                     Z-ADDSBGRTM    W0GRTM
     C                     MOVELSBGRPG    W0GRPG
     C                     MOVELSBGRNM    W0GRNM
      *
     C                     MOVELSBBAN1    W0KEY1
     C                     MOVELSBBAN2    W0KEY2
     C                     MOVELSBBAN3    W0KEY3
     C                     MOVELSBBAN4    W0KEY4
      *
     C           KEY51     KLIST
     C                     KFLD           SBLNO1
     C                     KFLD           SBLNO2
     C                     MOVEL'0'       GET     1
     C           KEY51     SETGTMRHPL511
     C           KEY51     REDPEMRHPL511                 84
     C           *IN84     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           STGSJY    IFEQ 'D'
     C           STGSHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'1'       GET     1
     C                     MOVELSTDVKB    W0DVKB
     C                     MOVELSTDVNM    W0DVNM
     C                     MOVELSTDPNM    W0DPNM
     C                     ENDIF
     C           KEY51     REDPEMRHPL511                 84
     C                     ENDDO
      *
     C           KEYFCE    KLIST
     C                     KFLD           SBHIN1
     C                     KFLD           SBHIN2
     C                     KFLD           SBHIN3
     C                     MOVEL'0'       GET     1
     C           KEYFCE    SETGTFCEPL011
     C           KEYFCE    REDPEFCEPL011                 84
     C           *IN84     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'1'       GET     1
     C                     MOVELA2STRK    W2STRK
     C                     MOVELA2STRT    W2STRT
     C                     MOVELA2STRR    W2STRR
     C                     MOVELA2STRD    W2STRD
     C                     ENDIF
     C           KEYFCE    REDPEFCEPL011                 84
     C                     ENDDO
      *
     C                     MOVEL'0'       GET     1
     C           KEYFCE    SETGTFCEPP301
     C           KEYFCE    REDPEFCEPP301                 84
     C           *IN84     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           F3GSKD    IFEQ 'D'
     C           F3GSDT    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'1'       GET     1
     C                     MOVELF3STRK    W3STRK
     C                     MOVELF3STRT    W3STRT
     C                     MOVELF3STRR    W3STRR
     C                     MOVELF3STRD    W3STRD
     C                     ENDIF
     C           KEYFCE    REDPEFCEPP301                 84
     C                     ENDDO
      *
     C                     EXSR #SB410
     C           SEL       IFEQ '1'
     C                     WRITEMRHWP131
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *-------------------*
      * SELECT            *
      *-------------------*
     CSR         #SB410    BEGSR
      *
     C                     MOVEL'0'       SEL     1
     C                     SELEC
     C           P1DVKB    WHEQ ' '
     C                     MOVEL'1'       SEL     1
     C           P1DVKB    WHEQ '5'
     C           SBHIN     IFNE *BLANK
     C                     MOVEL'1'       SEL     1
     C                     ENDIF
     C           P1DVKB    WHEQ W0DVKB
     C                     MOVEL'1'       SEL     1
     C                     ENDSL
      *
     CSR         ESB410    ENDSR
