     H            Y.
     F** EDTR05A***********************************************************
     F*  CONVERT NUMERIC : (NUMERIC TO CHARACTER) / EDIT
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'EDTR05B'
     F*                    PARM           $IN    156
     F*                    PARM           $TRUE  17
     F*   IN  $IN    15,6  SOURCE NUMBER    (EX.  1.018- )
     F*   OUT $TRUE  17A   TRUE (CHARACTER) (EX. -1.018 )
     F*
     F*   ** DECIMAL POINT SHOULD BE <= 6 DIGITS
     F*   ** INTEGER       SHOULD BE <= 9 DIGITS
     F*   ** MAX 999,999,999.999999
     F*   ** MIN 0.000001 (+/-)
     F*   ** SIGN WILL BE SET AT FRONT POSITION
     F*********************************************************************
     E                    IN         15  1
     E                    OT         17  1
     F******************************************************************
     C                     EXSR #INIT
      *
     C           $IN       IFEQ 0
     C                     MOVEL'0'       $TRUE
     C                     GOTO ENDP
     C                     ENDIF
      *
     C                     Z-ADD0         IY
     C                     Z-ADD0         IZ
      * MOVE INTEGER
     C           1         DO   9         IX
      *
     C           IX        IFEQ 1
     C           @SIGN     ANDNE*BLANK
     C                     ADD  1         IY
     C                     MOVE @SIGN     OT,IY
     C                     ENDIF
      *
     C           IN,IX     IFEQ *BLANK
     C                     ITER
     C                     ENDIF
      *
     C           FIRST0    IFEQ 'Y'
     C           IN,IX     ANDEQ'0'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE 'N'       FIRST0
     C                     ADD  1         IY
     C                     MOVELIN,IX     OT,IY
     C                     ENDDO
      * PUT 0
     C           FIRST0    IFEQ 'Y'
     C                     ADD  1         IY
     C                     MOVE '0'       OT,IY
     C                     ENDIF
      * PUT DECIMAL POINT
     C                     ADD  1         IY
     C                     MOVE '.'       OT,IY
      *
      * MOVE DECIMAL
     C           10        DO   15        IX
      *
     C           IN,IX     IFEQ *BLANK
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         IY
     C                     MOVELIN,IX     OT,IY
     C                     ENDDO
      *
     C                     Z-ADD16        IX
      * DELETE 0 FROM LAST
     C                     DO   15
     C                     SUB  1         IX
     C           OT,IX     IFEQ *BLANK
     C                     ITER
     C                     ENDIF
      *
     C           LAST0     IFEQ 'Y'
     C           OT,IX     ANDEQ'0'
     C                     MOVE *BLANK    OT,IX
     C                     ITER
     C                     ENDIF
      *
     C           LAST0     IFEQ 'Y'
     C           OT,IX     ANDEQ'.'
     C                     MOVE 'N'       FIRST0
     C                     MOVE *BLANK    OT,IX
     C                     LEAVE
     C                     ENDIF
      *
     C                     LEAVE
     C                     ENDDO
      *
     C                     MOVEAOT        $TRUE
      *
     C           ENDP      TAG
     C                     SETON                     LR
     C                     RETRN
      *==========================================================
      * INITIAL VALUE
      *==========================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $IN    156
     C                     PARM           $TRUE  17
      *
     C                     MOVE *BLANK    $TRUE
      * SIGN
     C           $IN       IFGE 0
     C                     MOVE ' '       @SIGN   1
     C                     Z-ADD$IN       @IN    156
     C                     ELSE
     C                     MOVE '-'       @SIGN
     C           $IN       MULT -1        @IN
     C                     ENDIF
      *
     C                     MOVEL@IN       INX    15
     C                     MOVEAINX       IN
     C                     Z-ADD0         IX      20
     C                     Z-ADD0         IY      20
     C                     Z-ADD0         IZ      20
     C                     Z-ADD0         ZSCNT   20       ZERO SUPLESS
     C                     MOVE 'Y'       FIRST0  1
     C                     MOVE 'Y'       LAST0   1
      *
     C                     ENDSR
