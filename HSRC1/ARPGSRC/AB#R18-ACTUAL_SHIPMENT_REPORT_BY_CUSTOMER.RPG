     O                                  120 '( ) = BOXES/DAY'
     O        E   04           @HED
     O                                    9 'IAF PART#'
     O                                   23 'USER PART#'
     O                                   38 'DELV'
     O                         LMN,1     51
     O                         LMN,2     69
     O                         LMN,3     87
     O                         LMN,4    105
     O                         LMN,5    123
     O        E   05           @HED
     O                         @@LIN    132
     O        E 1              @DTL
     O                      N11BASHIN    12
     O                      N11BAMHIN    33
