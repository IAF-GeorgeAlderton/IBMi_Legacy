     H            Y.
     F** AO#R03  *******************************************
     F*トラック便ごとのパレット種類を集計                *
     F*      ITS.        2015.05.19                        *
     F******************************************************
     FAL#PL11 IF  E           K        DISK
     FAO#WP10 UF  E           K        DISK                      A
     FAO#WP11 O   E                    DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      *
     C                     READ AL#PL111                 81
     C           *IN81     DOWEQ'0'
     C           C1SKJY    IFEQ 'D'
     C           C1SKHZ    ANDLESDATE
     C                     ELSE
     C                     EXSR #SB500
     C                     EXSR #SB501
     C                     ENDIF
     C                     READ AL#PL111                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AO#WP10  トラック便、納入先ごとのパレット種類の合計
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C           KEYW0     KLIST
     C                     KFLD           C1TRKB
     C                     KFLD           C1SURT
     C                     KFLD           KKPPUL  1
     C                     KFLD           KKNONY  40
     C           C1PPUL    IFEQ '1'
     C                     MOVELC1PPUL    KKPPUL
     C                     ELSE
     C                     MOVEL'2'       KKPPUL
     C                     ENDIF
     C                     Z-ADDC1NONY    KKNONY
      *パレットプーリングは納入先混在
     C           C1PPUL    IFEQ '1'
     C                     Z-ADD0         KKNONY
     C                     ENDIF
      *
     C           KEYW0     CHAINAO#WP101             22
     C           *IN22     IFEQ '0'
     C                     ADD  1         W0KPLT
     C                     UPDATAO#WP101
     C                     ELSE
     C                     CLEARAO#WP101
     C                     MOVELC1SURT    W0SURT
     C                     MOVELKKPPUL    W0PPUL
     C                     MOVELKKNONY    W0NONY
     C                     Z-ADDC1EXTR    W0EXTR
     C                     Z-ADDC1FIXD    W0FIXD
     C                     Z-ADDC1FIXT    W0FIXT
     C                     Z-ADD1         W0KPLT
     C                     MOVELC1TRKB    W0TRKB
     C                     WRITEAO#WP101
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
      *-----------------------------------------------------
      *  AO#WP11パレットごとの箱数
      *-----------------------------------------------------
     CSR         #SB501    BEGSR
      *
     C                     CLEARAO#WP111
     C                     MOVELC1NONY    W1NONY
     C                     MOVELC1NKOJ    W1NKOJ
     C                     MOVELC1NUKE    W1NUKE
     C                     MOVELC1ORD#    W1ORD#
     C                     MOVELC1SHID    W1SHID
     C                     MOVELC1SHIT    W1SHIT
     C                     MOVELC1SURT    W1SURT
     C                     Z-ADDC1EXTR    W1EXTR
     C                     Z-ADDC1FIXD    W1FIXD
     C                     Z-ADDC1FIXT    W1FIXT
     C                     MOVELC1PALT    W1PALT
     C                     Z-ADDC1BOX     W1BOX
     C                     MOVELC1TRKB    W1TRKB
     C                     Z-ADDC1PRT     W1PRT
     C                     MOVELC1PPUL    W1PPUL
     C                     MOVELC1SAT     W1SAT
     C                     MOVELC1SHN1    W1SHN1
     C                     MOVELC1SHN2    W1SHN2
     C                     MOVELC1SHN3    W1SHN3
     C                     Z-ADDC1NONY    W1KNON
      *パレットプーリングは納入先混在
     C           C1PPUL    IFEQ '1'
     C                     Z-ADD0         W1KNON
     C                     ENDIF
     C                     WRITEAO#WP111
      *
     CSR         ESB501    ENDSR
