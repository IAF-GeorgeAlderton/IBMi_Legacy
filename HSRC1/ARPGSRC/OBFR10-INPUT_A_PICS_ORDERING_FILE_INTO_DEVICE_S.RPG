     H            Y.
     F** OBFR10 ********************************
     F* INPUT  A-PICS ORDERING FILE INTO DEVICE STOCK F
     F* C:N.HAYAKAWA                 92.03.06  *
     F********************** COPY FROM AFAR15 **
     FAFAWP14 IP  F     250            DISK
     FOABPL02 IF  E           K        DISK
     FOACPL01 IF  E           K        DISK
     FOBFPL10 UF  E           K        DISK                      A
     FOBFPL11 IF  E           K        DISK
     FOBFPP30 O   E                    DISK                      A
     FQPRINT  O   F     132            PRINTER
     IAFAWP14 AA  01
     I                                        1   1 CFSKJY
     I                                       18  27 CFKOME
     I                                       28  39 CFSHIN
     I                                       28  32 CFHIN1
     I                                       33  37 CFHIN2
     I                                       38  39 CFHIN3
     I                                       40  40 CFKDAI
     I                                       41  430CFMAIS
     I                                       44  470CFHTYY
     I                                       48  490CFHTMM
     I                                       50  510CFHTDD
     I                                       52  530CFHTBB
     I                                       54  570CFSYYY
     I                                       58  590CFSYMM
     I                                       60  610CFSYDD
     I                                       62  630CFSYBB
     I                                       64  670CFMKYY
     I                                       68  690CFMKMM
     I                                       70  710CFMKDD
     I                                       72  730CFMKBB
     I                                       74  770CFKAYY
     I                                       78  790CFKAMM
     I                                       80  810CFKADD
     I                                       82  830CFKABB
     I                                       84  87 CFZENO
     I                                       88  90 CFTHNO
     I                                       91  940CFBMON
     I                                       95  96 CFBLOK
     I                                       95  95 CFBLK
     I                                       97 1000CFMBMN
     I                                      101 101 CFTYPE
     I                                      102 105 CFMEK1
     I                                      106 107 CFMEK2
     I                                      108 108 CFMEK3
     I                                      109 1111CFBARL
     I                                      112 1141CFMKLT
     I                                      115 115 CFCOLR
     I                                      116 1170CFSIZE
     I                                      118 1200CFKUBI
     I                                      121 1250CFSYUY
     I                                      126 126 CFCHYU
     I                                      127 1280CFCIHI
     I                                      129 1300CFCIBI
     I                                      131 1320CFCIOK
     I                                      133 133 CFOFFL
     I                                      134 134 CFMNKB
     I                                      135 1370CFMHKO
     I                                      138 1400CFBHK1
     I                                      141 1440CFBYY1
     I                                      145 1460CFBMM1
     I                                      147 1480CFBDD1
     I                                      149 1500CFBBB1
     I                                      151 1530CFBHK2
     I                                      154 1570CFBYY2
     I                                      158 1590CFBMM2
     I                                      160 1610CFBDD2
     I                                      162 1630CFBBB2
     I                                      164 166 CFKBAN
     I                                      167 167 CFKBNC
     I                                      168 1710CFKHAK
     I                                      172 172 CFBAN1
     I                                      173 174 CFBAN2
     I                                      175 176 CFBAN3
     I                                      177 177 CFBAN4
     I                                      178 1810CFTOKU
     I                                      182 1850CFNOYY
     I                                      186 1870CFNOMM
     I                                      188 1890CFNODD
     I                                      190 1910CFNOBB
     I                                      192 192 CFHKAN
     I                                      193 193 CFMLIN
     I                                      194 195 CFJYKN
     I            DS
     I                                        1  140WTODAY
     I                                        1   20WJI
     I                                        3   40WFN
     I                                        5   60WBY
     I                                        7  140WDATE
     I                                        7  100WYYY
     I                                       11  120WMMM
     I                                       13  140WDDD
     C******************
     C*１回のみの処理*
     C******************
     C           *IN09     IFEQ '0'
     C                     SETON                     09
     C                     TIME           WTODAY 140
     C                     END
     C**********************************
     C*ＡＲＲＳマスターで対象チェック*
     C**********************************
     C                     MOVE CFZENO    KEY1    4
     C                     SETOF                     10
     C           KEY1      CHAINOABPL02              10
     C           *IN10     IFEQ '1'
     C                     GOTO END
     C                     ELSE
     C           OBSKJY    IFEQ 'D'
     C           OBSKHZ    IFLE WDATE
     C                     GOTO END
     C                     END
     C                     END
     C                     END
     C**************************************************
     C*在庫基準マスターで有効チェック（履歴管理有り）*
     C**************************************************
     C           KEY2      KLIST
     C                     KFLD           CFHIN1
     C                     KFLD           CFHIN2
     C                     KFLD           CFHIN3
     C           KEY2      SETLLOACPL01
     C*在庫基準をリード*
     C           @READ     TAG
     C                     SETOF                     12
     C                     READ OACPL011                 12
     C           *IN12     IFEQ '1'
     C                     GOTO END
     C                     ELSE
     C           OASKJY    IFEQ 'D'
     C           OASKHZ    ANDLEWDATE
     C                     GOTO @READ
     C                     END
     C                     END
     C*品番違う時終了（該当レコード無し）*
     C           OASHIN    IFNE CFSHIN
     C                     GOTO END
     C                     END
     C*有効日よりも小さい時再リード*
     C           OAUKHZ    CABGTWDATE     @READ
     C*失効日よりも大きい時再リード*
     C           OASTHZ    CABLEWDATE     @READ
     C************************************
     C*かんばん枚数でページ番号の計算と*
     C*仕掛け管理ファイルに追加        *
     C************************************
     C                     Z-ADD0         WPAGE   40
     C           LOOP1     TAG
     C                     ADD  1         WPAGE
     C           WPAGE     CABGTCFMAIS    EXIT1
     C* HEADER MOVE *
     C                     MOVE *BLANK    T4SKJY
     C                     Z-ADD0         T4SKYY
     C                     Z-ADD0         T4SKMM
     C                     Z-ADD0         T4SKDD
     C                     Z-ADDWYYY      T4KOYY
     C                     Z-ADDWMMM      T4KOMM
     C                     Z-ADDWDDD      T4KODD
     C                     Z-ADDWJI       T4KOHH
     C                     Z-ADDWFN       T4KOSS
     C                     MOVEL'OBFR10'  T4KOME
     C* FIELD MOVE *
     C                     MOVE CFHIN1    T4SHN1
     C                     MOVE CFHIN2    T4SHN2
     C                     MOVE CFHIN3    T4SHN3
     C                     MOVE CFZENO    T4ZETI
     C                     MOVE CFTHNO    T4TEHI
     C                     MOVE WPAGE     T4PAGN
     C                     MOVE CFCHYU    T4KRKB
     C                     Z-ADDCFHTYY    T4KHAY
     C                     Z-ADDCFHTMM    T4KHAM
     C                     Z-ADDCFHTDD    T4KHAD
     C                     Z-ADDCFHTBB    T4KHAB
     C* WRITE *
     C                     WRITEOBFPP301
     C                     GOTO LOOP1
     C* EXIT1 *
     C           EXIT1     TAG
     C************************************
     C* 仕掛け在庫ファイルに追加、更新 *
     C************************************
     C                     SETOF                     11
     C           KEY1      CHAINOBFPL10              11
     C           *IN11     IFEQ '1'
     C* FIELD MOVE *
     C                     Z-ADD0         T2TJHK
     C                     Z-ADD0         T2SJHK
     C                     Z-ADD0         T2RJHK
     C                     Z-ADD0         T2MYHK
     C                     Z-ADD0         T2ZIGO
     C*
     C                     MOVE CFHIN1    T2SHN1
     C                     MOVE CFHIN2    T2SHN2
     C                     MOVE CFHIN3    T2SHN3
     C                     MOVE CFZENO    T2ZETI
     C                     MOVE CFTHNO    T2SITH
     C                     MOVE CFMAIS    T2SIPG
     C                     ELSE
     C           T2SKJY    IFEQ 'D'
     C           OBSKHZ    IFLE WDATE
     C                     Z-ADD0         T2TJHK
     C                     Z-ADD0         T2SJHK
     C                     Z-ADD0         T2RJHK
     C                     Z-ADD0         T2MYHK
     C                     Z-ADD0         T2ZIGO
     C*
     C                     MOVE CFHIN1    T2SHN1
     C                     MOVE CFHIN2    T2SHN2
     C                     MOVE CFHIN3    T2SHN3
     C                     MOVE CFZENO    T2ZETI
     C                     MOVE CFTHNO    T2SITH
     C                     MOVE CFMAIS    T2SIPG
     C                     END
     C                     END
     C                     END
     C*通常在庫*
     C           CFCHYU    IFEQ 'A'
     C                     ADD  CFMAIS    T2TJHK
     C                     END
     C*指示在庫*
     C           CFCHYU    IFEQ 'S'
     C                     ADD  CFMAIS    T2SJHK
     C                     END
     C*臨時在庫*
     C           CFCHYU    IFEQ 'R'
     C                     ADD  CFMAIS    T2RJHK
     C                     END
     C*前夜勤在庫*
     C           CFCHYU    IFEQ 'M'
     C                     ADD  CFMAIS    T2MYHK
     C                     END
     C*総在庫*
     C                     ADD  CFMAIS    T2ZIGO
     C*最新手配、ページ番号*
     C                     MOVE CFTHNO    T2SITH
     C                     MOVE CFMAIS    T2SIPG
     C* HEADER MOVE *
     C                     MOVE *BLANK    T2SKJY
     C                     Z-ADD0         T2SKYY
     C                     Z-ADD0         T2SKMM
     C                     Z-ADD0         T2SKDD
     C                     Z-ADDWYYY      T2KOYY
     C                     Z-ADDWMMM      T2KOMM
     C                     Z-ADDWDDD      T2KODD
     C                     Z-ADDWJI       T2KOHH
     C                     Z-ADDWFN       T2KOSS
     C                     MOVEL'OBFR10'  T2KOME
     C*品番にて仕掛け在庫ファイルの重複キーチェック*
     C           *IN11     IFEQ '1'
     C*
     C                     SETOF                     13
     C           KEY2      CHAINOBFPL11              13
     C           *IN13     IFEQ '0'
     C                     EXCPTERR
     C                     GOTO END
     C                     END
     C*
     C                     END
     C***************
     C* WRITE,UPDAT *
     C***************
     C           *IN11     IFEQ '1'
     C                     WRITEOBFPL101
     C                     ELSE
     C                     UPDATOBFPL101
     C                     END
     C* 終了 *
     C           END       TAG
     OQPRINT  E  102           ERR
     O                                   17 'REPETITION'
     O                                   24 'ZETI='
     O                         CFZENO    28
     O                                   34 'HINB='
     O                         CFHIN1    39
     O                         CFHIN2    44
     O                         CFHIN3    49
     O                                  129 'THIS LIST HAND TO HAYAKA'
     O                                  131 'WA'
