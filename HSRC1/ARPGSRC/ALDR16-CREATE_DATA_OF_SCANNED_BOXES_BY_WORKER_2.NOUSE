     H            Y.
     F** ALDR16 ********************************************************
     F*   CREATE DATA OF SCANNED BOXES BY WORKER                       *
     F*                                                                *
     F*  TCH OCT/10/13                                                 *
     F*                                                                *
     F* *IN90=1(NOT READ ALDPP20)                                      *
     F* *IN91=1(NOT READ ALDPP30)                                      *
     F* *IN92=1(NOT READ ALDPP40)                                      *
     F* *IN93=1(NOT READ ALBPL30)                                      *
     F********************************************  ALDR15 *************
     FALDWP15 IP  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FALDWP16 O   E                    DISK
      ******************************************************************
     IALDWP151
     I                                              D5OPERL2
     I                                              D5YYYYL1
     I                                              D5MMMML1
     I                                              D5DDDDL1
     I            DS
     I                                        1   40D5TIME
     I                                        1   20D5HH
     I                                        3   40D5MN
     I            DS
     I                                        1   80D5DATE
     I                                        1   40D5YYYY
     I                                        5   60D5MMMM
     I                                        7   80D5DDDD
     I            DS
     I                                        1   80D6DATE
     I                                        1   40D6YYYY
     I                                        5   60D6MMMM
     I                                        7   80D6DDDD
     I            DS
     I                                        1   80K@DATE
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80F8DATE
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *---------------------------------------------------------------
     C*                    MAIN ROUTINE
      *---------------------------------------------------------------
      *
     C                     SELEC
     C           D5TIME    WHGE 0630
     C           D5TIME    ANDLE1430
     C                     Z-ADD1         D6SHFT
     C           D5TIME    WHGE 1430
     C           D5TIME    ANDLE2030
     C                     Z-ADD2         D6SHFT
     C                     OTHER
     C                     Z-ADD3         D6SHFT
     C                     ENDSL
      *
     C                     ADD  1         D6BOX
      *
     C                     EXSR #WRT
      *---------------------------------------------------------------
     C           *INZSR    BEGSR
      *---------------------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           P@SDT   8
     C                     PARM           P@EDT   8
      *
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
      *
     C                     MOVE P@EDT     W@END   80
     C                     MOVE P@SDT     W@SDT   80
     C                     CLEARALDWP161
      *
     C                     Z-ADDW@SDT     K@DATE
     C           K#AGD     SETGTAGDPL12
     C                     READ AGDPL12                  90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDF8DATE    W@DAT1  80
     C                     ENDIF
      *
     C                     ENDSR
      *---------------------------------------------------------------
     C           #WRT      BEGSR
      *
     C                     Z-ADDD5DATE    D6DATE
     C           D6SHFT    IFEQ 3
     C           D5HH      ANDGE20
     C           D5DATE    IFEQ W@SDT
     C                     Z-ADDW@DAT1    D6DATE
     C                     ELSE
     C                     ADD  1         D6DDDD
     C                     ENDIF
     C                     ENDIF
      *
     C                     WRITEALDWP161
      *
     C                     Z-ADD*ZERO     D6BOX
     C                     MOVE *OFF      *IN99
      *
     C                     ENDSR
      *---------------------------------------------------------------
