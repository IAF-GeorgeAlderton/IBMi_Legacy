     H            Y.
     F** ALFR02 ********************************************
     F*  CONVEYANCE WASHER PULL SCAN ERROR LOG LIST        *
     F*                                                    *
     F* TCHK1 10/20/10 CREATE(COPY FROM ALCR02)            *
     F* TCHK2 09/25/12 ADD RK-METAL                        *
     F******************************************************
     FALFPP01 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FALBPL30 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     F*
     E                    TBL     1   1 50
     I*
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
     I            DS
     I                                        1   80W@SCDT
     I                                        1   40W@SCYY
     I                                        5   60W@SCMM
     I                                        7   80W@SCDD
     I            DS
     I                                        1   80W@ECDT
     I                                        1   40W@ECYY
     I                                        5   60W@ECMM
     I                                        7   80W@ECDD
     I            DS
     I                                        1  14 W@PRT
     I                                        1   5 W@PRT1
     I                                        6   6 W@PRTA
     I                                        7  11 W@PRT2
     I                                       12  12 W@PRTB
     I                                       13  14 W@PRT3
     I            DS
     I                                        1  15 W8BRC@
     I                                        2  15 W8BRC4
     C*
     C           K#01      KLIST
     C                     KFLD           W@SCDT
     C                     KFLD           W@STTM
     C           K#01      SETLLALFPP01
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ALFPP01                  99
     C   99                LEAVE
     C*
     C           A8ERR     IFEQ *BLANK
     C                     ITER
     C                     END
     C*
     C           A8DATE    IFEQ W@ECDT
     C           A8TIME    ANDGTW@EDTM
     C                     LEAVE
     C                     END
     C*
     C           W@1STP    IFEQ *ON
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     MOVEL*OFF      W@1STP
     C                     END
     C*
     C                     MOVELA8TMCD    K@TMCD  60
     C           K@TMCD    CHAINALBPL30              97
     C  N97                MOVELALWKNM    P@WKNM 20
     C   97                MOVEL*BLANK    P@WKNM
     C*
     C                     MOVEL*BLANK    W@PRT
     C                     MOVELA8PRT1    W@PRT1
     C                     MOVELA8PRT2    W@PRT2
     C                     MOVELA8PRT3    W@PRT3
     C           A8PRT2    IFNE *BLANK
     C                     MOVEL'-'       W@PRTA
     C                     END
     C           A8PRT3    IFNE *BLANK
     C                     MOVEL'-'       W@PRTB
     C                     END
     C                     MOVELW@PRT     P@PRT1 14
     C*
     C           A8DKND    IFEQ 'A'
     C                     MOVELA8BRC2    W@BRC2 17 P
     C                     MOVEL*BLANK    W@BRC3 15 P
     C                     MOVEL'ASJ '    P@KND   4
     C                     ELSE
     C                     MOVELA8BRC3    W@BRC2    P
     C                     MOVELA8BRC4    W8BRC@
     C                     MOVELW8BRC4    W@BRC3    P
TCHK2C           A8DKND    IFEQ 'F'
     C                     MOVEL'FRWY'    P@KND
TCHK2C                     ELSE
TCHK2C           A8DKND    IFEQ 'R'
TCHK2C                     MOVEL'RKMT'    P@KND
TCHK2C                     END
TCHK2C                     END
     C                     END
     C*
     C                     EXCPT@DTL
     C                     MOVEL*ON       PMRFLG
     C*
     C                     ENDDO
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C*-----------------------------------------------------
     C* INITIAL SET
     C*-----------------------------------------------------
     C           *INZSR    BEGSR
     C*
     C           *ENTRY    PLIST
     C                     PARM           PMSHFT  1
     C                     PARM           PMSCDT  8
     C                     PARM           PMRFLG  1
     C                     MOVEL*OFF      PMRFLG
     C*
     C                     TIME           WSDT
     C*
     C           PMSCDT    IFNE *BLANK
     C                     MOVELPMSCDT    W@SCDT
     C                     MOVELPMSCDT    W@ECDT
     C                     ELSE
     C                     MOVELWSSDAT    W@SCDT
     C                     MOVELWSSDAT    W@ECDT
     C                     END
     C*
     C                     SELEC
     C           PMSHFT    WHEQ '1'
     C                     Z-ADD070000    W@STTM  60
     C                     Z-ADD145959    W@EDTM  60
     C           PMSHFT    WHEQ '2'
     C                     Z-ADD150000    W@STTM
     C                     Z-ADD225959    W@EDTM
     C           PMSHFT    WHEQ '3'
     C           K#AGDP    KLIST
     C                     KFLD           W@SCYY
     C                     KFLD           W@SCMM
     C                     KFLD           W@SCDD
     C           K#AGDP    CHAINAGDPL12              98
     C           *IN98     IFEQ *OFF
     C                     READPAGDPL12                  98
     C           *IN98     IFEQ *OFF
     C                     Z-ADDF8KAYY    W@SCYY
     C                     Z-ADDF8KAMM    W@SCMM
     C                     Z-ADDF8KADD    W@SCDD
     C                     END
     C                     END
     C                     Z-ADD230000    W@STTM
     C                     Z-ADD065959    W@EDTM
     C                     OTHER
     C                     Z-ADD000000    W@STTM
     C                     Z-ADD000000    W@EDTM
     C                     ENDSL
     C*
     C                     MOVEL*ON       W@1STP  1
     C*
     C                     ENDSR
      *
     OQPRINT  E   01           @HED
     O                         #PGM      10
     O                         TBL,1     72
     O                                   87 'DATE'
     O                         WSSDATY   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O        E   02           @HED
     O                                   87 'TIME'
     O                         WSSTM6    98 '  :  :  '
     O        E   03           @HED
     O                                   15 'SCANNED DATE AT'
     O                         W@SCDTY   26
     O                                   36 'SHIFT#:'
     O                         PMSHFT    38
     O        E   05           @HED
     O                                    4 'TIME'
     O                                   20 'TEAM MEMBER'
     O                                   38 'LOCATION'
     O                                   49 'KIND'
TCHK2O*                                  61 'ASJ/FREEWAY'
TCHK2O                                   64 'ASJ/FRWY/RKMTL'
     O                                   79 'RETRIEVAL'
     O                                  101 'ERROR MESSAGE'
     O        E 1              @DTL
     O                         A8TIME     8 ' 0:  :  '
     O                         P@WKNM    29
     O                         A8BRC1    40
     O                         P@KND     49
     O                         W@BRC2    67
     O                         A8BRC5    85
     O                         A8EM01   108
     O        E 1              @DTL
     O                         P@PRT1    44
     O                         W@BRC3    65
     O                         A8EM02   108
** TBL
