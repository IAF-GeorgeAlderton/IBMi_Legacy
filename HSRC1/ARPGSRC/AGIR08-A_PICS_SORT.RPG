     C                     Z-ADD0         WKYOHZ  80
     C                     Z-ADD0         WKCIBI  20
     C                     MOVELF04       HHMM1
     C           0111      CHAINAAIPL111             44
     C           *IN44     IFEQ '0'
     C                     Z-ADDCDTOHZ    WKTOHZ
     C                     Z-ADDCDYOHZ    WKYOHZ
