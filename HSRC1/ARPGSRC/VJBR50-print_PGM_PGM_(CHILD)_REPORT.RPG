     H            Y.                                    1
     F** VJBR50 ****************************
     F*   PRINT PGM-PGM (CHILD) REPORT     *
     F*   JW    4/5/2016                   *
     F**************************************
     FVVVPPB0 IF  E           K        DISK
     FVVVPLC2 IF  E           K        DISK
     FVVVPLC3 IF  E           K        DISK
     FVVVPLC4 IF  E           K        DISK
     FVVVPLC5 IF  E           K        DISK
     FVVVPLC6 IF  E           K        DISK
     FVVVPLC7 IF  E           K        DISK
     FVVVPLC8 IF  E           K        DISK
     FVVVPLC9 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      **************************************
     C           *ENTRY    PLIST
     C                     PARM           XPGM    8
      *
     C                     Z-ADD*DATE     @DATE   80
     C                     TIME           @TIME   60
     C                     Z-ADD99        LIN     30
     C                     EXSR #F0
     C                     MOVELXPGM      K@VV1  10
      *
     C           K@VV1     SETLLVVVPPB0
      *
     C           *IN80     DOWEQ*OFF
     C           K@VV1     READEVVVPPB0                  80
     C                     MOVELVWFNAM    TEMP    4
     C                     MOVE TEMP      SRID    1
     C           *IN80     IFEQ *OFF
     C           SRID      ANDEQ'C'
     C           *IN80     OREQ *OFF
     C           SRID      ANDEQ'R'
     C                     MOVELVWPNAM    @PGM    8
     C                     MOVELVWFNAM    @LINK1    P
     C                     MOVEL@LINK1    K@VV2  10
     C                     EXSR #F2
     C                     ENDIF
     C                     ENDDO
      * PRINT FOOTER
     C           LIN       IFEQ 99
     C                     EXCPT@HDR
     C                     EXCPT@FOT
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *******************
      * F0: INITIALIZE  *
      *******************
     C           #F0       BEGSR
     C                     MOVE *BLANK    @LINK1  9
     C                     MOVE *BLANK    @LINK2  9
     C                     MOVE *BLANK    @LINK3  9
     C                     MOVE *BLANK    @LINK4  9
     C                     MOVE *BLANK    @LINK5  9
     C                     MOVE *BLANK    @LINK6  9
     C                     MOVE *BLANK    @LINK7  9
     C                     MOVE *BLANK    @LINK8  9
     C                     MOVE *BLANK    @LINK9  9
     C                     ENDSR
      *******************
      * F2              *
      *******************
     C           #F2       BEGSR
     C                     MOVE 'Y'       @C2     1
     C                     MOVE *OFF      *IN82
     C           K@VV2     SETLLVVVPLC2
     C           *IN82     DOWEQ*OFF
     C           K@VV2     READEVVVPLC2                  82
     C                     MOVELVWFNAM    TEMP
     C                     MOVE TEMP      SRID
     C           *IN82     IFEQ *OFF
 J   C           SRID      IFEQ 'C'
 J   C           SRID      OREQ 'R'
     C                     MOVELVWFNAM    @LINK2    P
     C                     MOVEL@LINK2    K@VV3  10
     C                     EXSR #F3
     C                     MOVE ' '       @C2
     C                     MOVE *BLANK    @LINK2
 J   C                     ELSE
 J   C                     ITER
 J   C                     ENDIF
     C                     ELSE
     C           @C2       IFEQ 'Y'
     C                     EXSR #PRINT
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C                     ENDSR
      *******************
      * F3              *
      *******************
