     C                     EXSR #PRINT
     C                     ENDIF
      *
     C                     ENDSR
      *******************
      * PRINT           *
      *******************
     C           #PRINT    BEGSR
     C           LIN       IFGT 60
     C                     Z-ADD0         LIN
     C                     EXCPT@HDR
     C                     ENDIF
      *
     C                     ADD  1         LIN
     C                     EXCPT@DTL
      *
     C                     ENDSR
      **************************************
     OQPRINT  E   01           @HDR
     O                                    7 'VJBR50'
     O                                   50 '** PGM-PGM (CHILD) R'
     O                                   60 'EPORT **  '
     O                                   99 'DATE'
     O                         @DATE    102 '    .  .  '
     O                         @TIME    112 '  :  :  '
     O                                  115 'P.'
     O                         PAGE  Z  119
     O        E   02           @HDR
     O                                    9 'PROGRAM'
     O                                   17 'CHILD1'
     O                                   27 'CHILD2'
     O                                   37 'CHILD3'
     O                                   47 'CHILD4'
     O                                   57 'CHILD5'
     O                                   67 'CHILD6'
     O                                   77 'CHILD7'
     O                                   87 'CHILD8'
     O                                   97 'CHILD9'
      *
     O        E 1              @DTL
     O                         @PGM      10
     O                         @LINK1    20
     O                         @LINK2    30
     O                         @LINK3    40
     O                         @LINK4    50
     O                         @LINK5    60
     O                         @LINK6    70
     O                         @LINK7    80
     O                         @LINK8    90
     O                         @LINK9   100
      *
     O        E 1              @FOT
     O                         XPGM      10
     O                                   34 ': THERE IS NO CHILD '
     O                                   54 'PROGRAM! OR NOT UPDA'
     O                                   74 'TED VVVPPB0!        '
