     C                     SETON                     91
     C*
     C           *LOVAL    SETLLABFBP011
     C                     READ ABFBP011                 90
     C*
B01  C           *IN90     DOWEQ'0'
     C* SCHEDULE ISSUES DATE BREAKEC?
     C* SHIP TO ID CODE(DOCK #) BREAKE ?
B02  C           FBSIDT    IFNE WFSIDT
     C           FBSTID    ORNE WFSTID
     C* NOT 1ST. RECORD
B03  C           *IN91     IFEQ '1'
     C                     SETOF                     91
     C                     ELSE
     C                     EXCPT#DTL
     C                     Z-ADD1         I
     C                     MOVE *ZERO     IQY
     C                     MOVE *ZERO     DAT
     C                     MOVEAWWQTY1    IQY,I
     C                     MOVEAWWDLDT    DAT,I
E03  C                     END
     C*
     C                     Z-ADDFBSIDT    WFSIDT
     C                     MOVELFBSTID    WFSTID
     C                     MOVELFBPART    WFPART 20
     C                     MOVELFBUBM1    WFUBM1  2
     C* PAGE HEADER SET & PRINT
     C                     EXCPT#HED1
     C*
     C                     ELSE
     C*
B03  C           FBPART    IFNE WFPART
     C* PAGE HEADER SET & PRINT
     C   OF                EXCPT#HED1
     C   OF                SETOF                     OF
     C                     EXCPT#DTL
     C                     Z-ADD1         I
     C                     MOVE *ZERO     IQY
     C                     MOVE *ZERO     DAT
     C                     MOVEAWWQTY1    IQY,I
     C                     MOVEAWWDLDT    DAT,I
     C                     MOVELFBPART    WFPART 20
     C                     Z-ADDFBSIDT    WFSIDT  80
     C                     MOVELFBUBM1    WFUBM1  2
     C*
     C                     ELSE
     C                     ADD  1         I
     C                     MOVEAWWQTY1    IQY,I
     C                     MOVEAWWDLDT    DAT,I
     C*
E03  C                     END
E02  C                     END
     C*
     C                     READ ABFBP011                 90
E01  C                     END
     C                     EXCPT#DTL
     C*
     C                     SETON                     LR
     C                     RETRN
