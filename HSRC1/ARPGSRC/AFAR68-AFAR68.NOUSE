     H            Y
     F*AFAR68************************************************
     F* COMBINED PARTIAL CONTAINERS (DELETE)                *
     F*                                                     *
     F*                                 2001.11.29          *
     F************************************************AFAR65*
     F*  *INKC = 1(CF03)
     F*  *INKE = 1(CF05)
     F*  *INKI = 1(CF09)
     F*  *INKL = 1(CF12)
     F*  *IN30 = 0(FIRST DISPLAY)     1(NOT FIRST)
     F*  *IN31 = 0(PART NUMBER INPUT) 1(NO PART NUMBER INPUT)
     F*  *IN32 = 0(ABS NUM INPUT)     1(NO ABS NUM INPUT)
     F*  *IN33 = 0(START/END DATE INPUT)  1(NO START/END DATE INPUT)
     F*  *IN90 = 1(NOT READ AFAPP60)
     F*  *IN91 = 1(NOT READ FCETL13)
     F*  *IN92 = 1(NOT READ FCEPL01)
     F**********************************************************
     FAFAPW68 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL01
     F                                              KINFDS @INFDS
     FFCETL11 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FAFAPL62 IF  E           K        DISK
     F            AFAPP601                          KRENAMEAFAPL621
     F                                              KINFDS @INFDA
     FAFAPP60 UF  E                    DISK
     F**********************************************************
     E                    ERR     1   4 60
     E**********************************************************
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I@INFDA      DS
     I                                    B 397 4000@@RCA
     I* SYSTEM DATE
     I            DS
     I                                        1  120WTIME
     I                                        1   60SYTM1
     I                                        7  120SYDT1
     I* START DATE
     I            DS
     I                                        1   80DSSTRD
     I                                        1   40#STRY
     I                                        5   60#STRM
     I                                        7   80#STRD
     I* END DATE
     I            DS
     I                                        1   80DSENDD
     I                                        1   40#ENDY
     I                                        5   60#ENDM
     I                                        7   80#ENDD
     I* PART NUMBER
     I            DS
     I                                        1  12 DSPART
     I                                        1   5 #PAR1
     I                                        6  10 #PAR2
     I                                       11  12 #PAR3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I****************************************************************
     C                     TIME           WTIME
     C* DEFINE KEY1 FIELD
     C           KEY2      KLIST
     C                     KFLD           DSZETI
     C*
     C           KEY3      KLIST
     C                     KFLD           #PAR1
     C                     KFLD           #PAR2
     C                     KFLD           #PAR3
     C*
     C           KEY4      KLIST
     C                     KFLD           DSZETI
     C                     KFLD           DSSTRD
     C*
     C                     MOVE 00000000  DSSTRD
     C                     MOVE 99999999  DSENDD
     C                     MOVE *BLANK    DSPART
      *
     C                     MOVE '01'      @@ID    2
      *
     C           @@ID      DOUEQ'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C           @@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *--------------------------------------------
     C           #SCRN1    BEGSR
      *--------------------------------------------
     C                     WRITEAFAPW651
     C                     EXFMTAFAPW652
      *
     C           *INKC     IFEQ *ON
     C                     MOVE '99'      @@ID
     C                     ELSE
     C                     EXSR @CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET
     C           RRN       IFNE *ZERO
     C                     MOVE '02'      @@ID
     C                     ELSE
     C                     SETON                     99
     C                     MOVEAERR,2     @MSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
     C*************************************************************
     C*    @CHK1
     C*************************************************************
     C           @CHK1     BEGSR
      *
     C                     SETOF                     99
     C                     MOVE *BLANK    @MSG
     C           DSPART    IFEQ *BLANK
     C           DSZETI    IFEQ *BLANK
     C                     SETON                     323199
     C                     MOVEAERR,2     @MSG
     C                     ELSE
     C           KEY2      CHAINFCETL11              91
     C           *IN91     IFEQ '1'
     C                     SETON                     3299
     C                     MOVEAERR,1     @MSG
     C                     END
     C                     END
     C                     ELSE
     C           KEY3      CHAINFCEPL01              92
     C           *IN92     IFEQ '1'
     C                     SETON                     3199
     C                     MOVEAERR,2     @MSG
     C                     ELSE
     C                     MOVE A2ZETI    DSZETI
     C                     END
     C                     END
     C*
     C*
     C           *IN99     IFEQ '1'
     C                     GOTO #CHK1
     C                     END
     C*
     C*
     C           DSSTRD    IFEQ *ZERO
     C                     ELSE
     C           #STRM     IFGE 1
     C           #STRM     ANDLE12
     C                     ELSE
     C                     SETON                     3399
     C                     MOVEAERR,3     @MSG
     C                     GOTO #CHK1
     C                     END
     C           #STRD     IFGE 1
     C           #STRD     ANDLE31
     C                     ELSE
     C                     SETON                     3399
     C                     MOVEAERR,3     @MSG
     C                     GOTO #CHK1
     C                     END
     C                     END
     C           DSENDD    IFEQ 99999999
     C                     ELSE
     C           #ENDM     IFGE 1
     C           #ENDM     ANDLE12
     C                     ELSE
     C                     SETON                     3399
     C                     MOVEAERR,3     @MSG
     C                     GOTO #CHK1
     C                     END
     C           #ENDD     IFGE 1
     C           #ENDD     ANDLE31
     C                     ELSE
     C                     SETON                     3399
     C                     MOVEAERR,3     @MSG
     C                     GOTO #CHK1
     C                     END
     C                     END
     C*
     C           #CHK1     ENDSR
     C**************************************************************
     C*  @SFL
     C**************************************************************
     C           #SET      BEGSR
      *
     C                     Z-ADD*ZERO     RRN     40
     C                     SETON                       71
     C                     WRITESFLCTL
     C                     SETOF                       71
      *
     C           KEY4      SETLLAFAPL62
     C           KEY2      READEAFAPL62                  90
     C           AADATE    IFLE DSENDD
     C           *IN90     DOUEQ'1'
     C           AADATE    ORGT DSENDD
     C           AASKJY    IFEQ *BLANK
     C                     ADD  1         RRN     40
     C                     CLEARSFL01
     C                     MOVE AANLOT    @NLOT
     C                     MOVE AADATE    @UPDAY
     C                     MOVELAAKOME    @MEMB
     C                     MOVE AAKAN1    @KAN1
     C                     MOVE AAKAN2    @KAN2
     C                     MOVE AAKAN3    @KAN3
     C                     MOVE AALOT1    @LOT1
     C                     MOVE AALOT2    @LOT2
     C                     MOVE AALOT3    @LOT3
     C                     MOVE AAKAN4    @KAN4
     C                     MOVE AAKAN5    @KAN5
     C                     MOVE AAKAN6    @KAN6
     C                     MOVE AALOT4    @KAN4
     C                     MOVE AALOT5    @KAN5
     C                     MOVE AALOT6    @KAN6
     C                     Z-ADD@@RCA     @RECA
      *
     C                     WRITESFL01
     C                     ENDIF
     C           KEY2      READEAFAPL62                  90
     C                     END
     C                     END
     C*
     C                     ENDSR
      *--------------------------------------------
     C           #SCRN2    BEGSR
      *--------------------------------------------
     C* SECOND SCREEN
     C                     WRITEAFAPW699
     C                     WRITEAFAPW652
     C                     SETON                         70
     C                     EXFMTSFLCTL
     C                     SETOF                         70
      *
     C                     SELEC
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      @@ID
     C           *INKI     WHEQ *ON
     C                     EXSR #ALL
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
     C                     MOVE '01'      @@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #ALL      BEGSR
      *-----------------------------------------------------
     C                     Z-ADD*ZERO     @@RRN   40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         @@RRN
     C           @@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C                     MOVE 'D'       @SLCT
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #CHK2     BEGSR
      *-----------------------------------------------------
     C                     MOVE *OFF      *IN99
     C                     Z-ADD*ZERO     @@CONT  50
     C                     Z-ADD*ZERO     @@RRN   40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         @@RRN
     C           @@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           @SLCT     IFNE *BLANK
     C                     ADD  1         @@CONT
     C                     ENDIF
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDDO
      *
     C           @@CONT    IFEQ *ZERO
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #UPD      BEGSR
      *-----------------------------------------------------
     C                     Z-ADD*ZERO     @@CONT  50
     C                     Z-ADD*ZERO     @@RRN   40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         @@RRN
     C           @@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           @SLCT     IFNE *BLANK
     C           @RECA     CHAINAFAPP60              95
     C           *IN95     IFEQ *OFF
     C                     MOVE 'D'       AASKJY
     C                     Z-ADD*YEAR     AASKYY
     C                     Z-ADD*MONTH    AASKMM
     C                     Z-ADD*DAY      AASKDD
     C                     UPDATAFAPP601
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C*
     C                     ENDSR
     C**************************************************************
** ERROR MESSAGE
PART NUMBER IS NOT FOUND IN M/F.
ENTER ABSOLUTE NUMBER OR PART NUMBER
WRONG DATE ENTERED
NO DATA
