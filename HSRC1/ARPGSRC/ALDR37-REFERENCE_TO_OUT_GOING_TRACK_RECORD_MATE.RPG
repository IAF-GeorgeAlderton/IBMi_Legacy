     C           K#ABF6    KLIST
     C                     KFLD           K@YMD8
     C                     KFLD           K@BIN   20
     C                     KFLD           EKRLYY
     C                     KFLD           EKRLMM
     C                     KFLD           EKRLDD
     C                     KFLD           K@DELY  40
     C                     KFLD           EKNUKE
     C                     KFLD           K@IPAR
     C           K#30      KLIST
     C                     KFLD           J2ZETI
     C                     KFLD           J2THAI
     C                     KFLD           K@PAG   2
     C           K#37      KLIST
     C                     KFLD           A3SYHZ
     C                     KFLD           A3SYJI
     C                     KFLD           A3SYFN
     C                     KFLD           A3SHN1
     C                     KFLD           A3SHN2
     C                     KFLD           A3SHN3
     C                     KFLD           A3TEHI
     C                     KFLD           A3PAGE
      *
     C                     MOVE '01'      W@ID    2
      *
     C                     ENDSR
      *--------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE KEY,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C           RRN1      IFEQ *ZERO
     C                     MOVE ERR,1     D@MSG
     C                     ELSE
     C                     MOVE '02'      W@ID
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *--------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     SETOF                     6199
      *
     C           D@BARC    IFEQ *BLANK
     C           D@5       OREQ *BLANK
     C                     MOVE ERR,2     D@MSG
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------
     C           #SET1     BEGSR
      *
     C           D@BARC    CAT  '999999':0@@BAC   8 P
      *
     C                     CLOSEALDWP37                99
     C                     MOVELCMD,1     P@CMD     P
     C                     Z-ADD30        P@LEN
     C                     CALL 'QCMDEXC' P#CMD        99
     C                     OPEN ALDWP37
      *
     C           D@BARC    SETLLAJSPL28
     C           *IN80     DOUEQ*ON
     C                     READ AJSPL28                  80
     C  N80      J2ZBR1    COMP @@BAC                80
     C           *IN80     IFEQ *OFF
     C           J2SKJY    ANDEQ*BLANK
     C                     MOVELJ2ZBR1    @@MAT   8
     C                     EXSR #WRT
     C                     ENDIF
     C                     ENDDO
      *
     C           D@BARC    SETLLAJSPL29
     C           *IN80     DOUEQ*ON
     C                     READ AJSPL29                  80
     C  N80      J2ZBR2    COMP @@BAC                80
     C           *IN80     IFEQ *OFF
     C           J2SKJY    ANDEQ*BLANK
     C                     MOVELJ2ZBR2    @@MAT   8
     C                     EXSR #WRT
     C                     ENDIF
     C                     ENDDO
      *
     C                     CLOSEALDWP37                99
     C                     OPEN ALDWP37                99
     C                     EXSR #SET2
      *
     C                     ENDSR
      *--------------------------------------------
     C           #WRT      BEGSR
      *
     C           1         DO   4         X       20
     C           PAG,X     IFNE *BLANK
     C                     MOVE PAG,X     K@PAG
     C           K#30      SETGTALDPL30
     C           *IN90     DOUEQ*ON
     C           K#30      REDPEALDPL30                  90
     C           *IN90     IFEQ *OFF
     C           A3SYHZ    ANDGTJ2YMD
      *
     C           K#37      CHAINALDWP37              91
     C           *IN91     IFEQ *ON
     C                     WRITEALDWP371
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *--------------------------------------------
     C           #SET2     BEGSR
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
      *
     C           *LOVAL    SETLLALDWP37
     C           *IN80     DOUEQ*ON
     C                     READ ALDWP37                  80
     C           *IN80     IFEQ *OFF
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     MOVE A3SHN1    S@PRT1
     C                     MOVE A3SHN2    S@PRT2
     C                     MOVE A3SHN3    S@PRT3
     C                     MOVE A3ZETI    S@ZETI
     C                     MOVE A3TEHI    S@LOTN
     C                     MOVE A3PAGE    S@PAGE
     C                     MOVE A3NONY    S@SHIP
     C                     MOVE WTKR      S@LOC
     C                     Z-ADDA3SYHZ    S@SDAT
     C           A3SYJI    MULT 100       S@STIM
     C                     ADD  A3SYFN    S@STIM
     C                     MOVE @@MAT     S@MATC
      *
     C                     WRITESFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *--------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVE KEY,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C           *INKC     WHEQ *ON
     C                     MOVE '01'      W@ID
     C                     OTHER
     C                     EXSR #SET3
     C                     ENDSL
      *
     C                     ENDSR
      *--------------------------------------------
     C           #SET3     BEGSR
      *
     C                     MOVE '02'      W@ID
     C                     Z-ADD*ZERO     @@RRN   40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         @@RRN
     C           @@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           S@SLCT    ANDNE*BLANK
     C                     MOVE *BLANK    S@SLCT
     C                     UPDATSFL01
     C                     EXSR #SET33
     C                     MOVE '03'      W@ID
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
%0001 *
%0001C                     ENDSR
      *--------------------------------------------
     C           #SET33    BEGSR
      *
     C           KEYC      CHAINALDWP37              97
     C           A3KANS    IFEQ 'A'
     C                     MOVE 'I'       KAN     1
     C                     GOTO JUMP
     C                     ENDIF
     C           A3KANS    IFEQ 'A'
     C           A3KANS    OREQ 'S'
     C           A3KANS    OREQ 'R'
     C           A3KANS    OREQ 'M'
     C           A3KANS    OREQ 'Y'
     C                     MOVE 'A'       KAN
     C                     GOTO JUMP
     C                     ENDIF
     C                     MOVE '1'       KAN
     C           JUMP      TAG
     C                     SETOF                     95
     C                     MOVE *BLANK    KANB
     C           KAN       LOKUPTAB1      TAB2           95
     C   95                MOVELTAB2      KANB
     C                     SETOF                     95
     C                     MOVE *BLANK    TYP
     C           A3SALE    LOKUPTAB3      TAB4           95
     C   95                MOVELTAB4      TYP
     C                     MOVE A3ZETI    IDNO
     C                     MOVE A3TEHI    LOTN
     C                     MOVE A3PAGE    PAGN
     C                     MOVE A3KANS    CONT
     C                     MOVE A3TASY    OBJE
     C                     MOVE A32KAK    SECN
     C                     MOVE A3HASY    CNTY
     C                     MOVE WTKR      ADR
     C                     MOVE '-'       HIF7
     C                     MOVE '-'       HIF8
     C                     MOVE '-'       HIF9
     C                     MOVE '-'       HIF13
     C                     MOVE '-'       HIF14
     C                     MOVE WUSR      UHN
     C                     Z-ADDA3SYHZ    WYMD
     C                     Z-ADDWY        WWYY
     C                     Z-ADDWM        WWMM
     C                     Z-ADDWD        WWDD
     C                     Z-ADDA3SYJI    WWJI    20
     C                     Z-ADDA3SYFN    WWFN
     C                     MOVE A3SERL    SERL
     C                     MOVE A3OPER    OPER    60
     C                     SETOF                     70
     C           KEY2      CHAINALBPL30              70
     C           *IN70     IFEQ '0'
     C           ALSKJY    IFEQ 'D'
     C           ALSKHZ    ANDLE*DATE
     C                     SETON                     70
     C                     ENDIF
     C                     ENDIF
     C                     MOVE *BLANK    OPEN
     C           *IN70     IFEQ '0'
     C                     MOVE ALWKNM    OPEN
     C                     ENDIF
     C                     Z-ADDA3SSYS    SSYS
     C                     Z-ADDA3USYS    USYS
     C                     Z-ADDA3NONY    NONY
     C                     MOVE A3NKOJ    PLNT
     C                     MOVE A3NUKE    RECV
      *
     C                     MOVE *BLANK    FSEQ#
      * FORD SERL#
     C           SERL      IFNE *BLANK
     C           SERL      CHAINAB#PL71              70
     C           *IN70     IFEQ *OFF
     C                     MOVE EKNOBN    K@BIN
     C                     MOVE EKNONY    K@DELY
     C           K#ABF6    SETLLABF6L02
     C           *IN70     DOUEQ*ON
     C           K#ABF6    READEABF6L02                  70
     C           *IN70     IFEQ *OFF
     C           FCSKJY    ANDEQ*BLANK
     C           FCSERL    ANDEQEKSERL
     C                     MOVE FCSEQ#    FSEQ#
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVE A3TOPX    TKEY    6
     C                     MOVE *BLANK    DELN
     C                     SETOF                     70
     C           KEY1      CHAINALAPL02              70
     C           *IN70     IFEQ '1'
