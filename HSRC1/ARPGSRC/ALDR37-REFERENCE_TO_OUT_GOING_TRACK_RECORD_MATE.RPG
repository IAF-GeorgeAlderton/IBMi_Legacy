     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C           W@ID      CASEQ'03'      #SCRN3
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
      *------*
      * KEYS *
      *<<DETAIL>>
     C           KEYC      KLIST
     C                     KFLD           S@SDAT
     C                     KFLD           @@SYJI
     C                     KFLD           @@SYFN
     C                     KFLD           S@PRT1
     C                     KFLD           S@PRT2
     C                     KFLD           S@PRT3
     C                     KFLD           S@LOTN
     C                     KFLD           S@PAGE
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
     C           KEY1      KLIST
     C                     KFLD           TKEY
      *<<WORKER CODE>
     C           KEY2      KLIST
