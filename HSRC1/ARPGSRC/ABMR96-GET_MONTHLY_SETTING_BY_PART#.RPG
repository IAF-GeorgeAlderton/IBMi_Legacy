     H            Y.
     F** ABMR96 **********************************
     F*月間必要数の取得                        *
     F*    HOTTA.       2018.08.08               *
     F********************************************
     FFCEPL11 IF  E           K        DISK
     E                    FKH        10  8 0             更新作業日
     E                    FGK        10  9 0             月間必要数
     E                    FGH        10  8 0             月間数切替日
     E                    FCD        10  3 1             稼働日数
     E                    FKM        10 10               更新作業者
      *
     I            DS
     I                                        1  800FKH
     I                                        1   80FCKH01
     I                                        9  160FCKH02
     I                                       17  240FCKH03
     I                                       25  320FCKH04
     I                                       33  400FCKH05
     I                                       41  480FCKH06
     I                                       49  560FCKH07
     I                                       57  640FCKH08
     I                                       65  720FCKH09
     I                                       73  800FCKH10
      *
     I            DS
     I                                        1  900FGK
     I                                        1   90FCGK01
     I                                       10  180FCGK02
     I                                       19  270FCGK03
     I                                       28  360FCGK04
     I                                       37  450FCGK05
     I                                       46  540FCGK06
     I                                       55  630FCGK07
     I                                       64  720FCGK08
     I                                       73  810FCGK09
     I                                       82  900FCGK10
      *
     I            DS
     I                                        1  800FGH
     I                                        1   80FCGH01
     I                                        9  160FCGH02
     I                                       17  240FCGH03
     I                                       25  320FCGH04
     I                                       33  400FCGH05
     I                                       41  480FCGH06
     I                                       49  560FCGH07
     I                                       57  640FCGH08
     I                                       65  720FCGH09
     I                                       73  800FCGH10
      *
     I            DS
     I                                        1  301FCD
     I                                        1   31FCCD01
     I                                        4   61FCCD02
     I                                        7   91FCCD03
     I                                       10  121FCCD04
     I                                       13  151FCCD05
     I                                       16  181FCCD06
     I                                       19  211FCCD07
     I                                       22  241FCCD08
     I                                       25  271FCCD09
     I                                       28  301FCCD10
      *
     I            DS
     I                                        1 100 FKM
     I                                        1  10 FCKM01
     I                                       11  20 FCKM02
     I                                       21  30 FCKM03
     I                                       31  40 FCKM04
     I                                       41  50 FCKM05
     I                                       51  60 FCKM06
     I                                       61  70 FCKM07
     I                                       71  80 FCKM08
     I                                       81  90 FCKM09
     I                                       91 100 FCKM10
      *
     I            DS
     I                                        1   80FCSKHZ
     I                                        1   40FCSKYY
     I                                        5   60FCSKMM
     I                                        7   80FCSKDD
      *
     I            DS
     I                                        1  140WDATE
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I            DS
     I                                        1   80W3DATE
     I                                        1   40W3DTYY
     I                                        5   60W3DTMM
     I                                        7   80W3DTDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P9GEKN 120
     C                     PARM           P9HIKN 120
     C                     PARM           P9KAD   31
     C                     PARM           P9YMD3  80
     C                     PARM           P9KOS3  1
      *３ヶ月前
     C                     Z-ADD*DATE     W3DATE
     C           W3DTMM    IFGE 4
     C                     SUB  3         W3DTMM
     C                     ELSE
     C                     SUB  1         W3DTYY
     C                     ADD  9         W3DTMM
     C                     ENDIF
      *
     C                     TIME           WDATE
     C                     Z-ADD0         P9GEKN
     C                     Z-ADD0         P9HIKN
     C                     Z-ADD0         P9KAD
     C                     Z-ADD0         P9YMD3
     C                     MOVEL'0'       P9KOS3
     C           KEYSHN    KLIST
     C                     KFLD           P1SHN1
     C                     KFLD           P1SHN2
     C                     KFLD           P1SHN3
     C           KEYSHN    CHAINFCEPL111             22
     C           *IN22     IFEQ '0'
     C           FCSKJY    ANDEQ'D'
     C           FCSKHZ    ANDLE*DATE
     C                     SETON                     22
     C                     ENDIF
     C           *IN22     IFEQ '0'
     C                     EXSR #SB400
     C                     EXSR #SB490
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------*
      *月間必要数切替日が当日以前       *
      *-----------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     Z-ADD1         X       30
     C                     MOVEL'0'       GET     1
     C           X         DOWLE10
     C           GET       ANDEQ'0'
     C           FGH,X     IFNE 0
     C           FGH,X     ANDLE*DATE
     C                     EXSR #SB401
     C                     MOVEL'1'       GET     1
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *-----------------------------------*
      *月間必要数　２０日稼働           *
      *-----------------------------------*
     CSR         #SB401    BEGSR
      *
     C                     Z-ADD0         XXGEKN 120
     C                     Z-ADD0         XXCD    31
     C                     Z-ADD0         YYHIKN 120
     C                     Z-ADDFGK,X     XXGEKN 120
     C                     Z-ADDFCD,X     XXCD    31
     C           XXCD      IFNE 0
     C                     Z-ADDXXCD      P9KAD
     C           XXGEKN    DIV  XXCD      YYHIKN 120
     C                     Z-ADDYYHIKN    P9HIKN
     C           YYHIKN    MULT 20        P9GEKN
     C                     ENDIF
      *
     CSR         ESB401    ENDSR
      *-----------------------------------*
      *３ヶ月以内の手動更新があるか     *
      *未来の切替日があるか             *
      *-----------------------------------*
     CSR         #SB490    BEGSR
      *
     C                     Z-ADD1         X       30
     C           X         DOWLE10
     C           FKH,X     IFNE 0
     C           FKH,X     ANDGEW3DATE
     C           FKM,X     ANDNE'ZIDOU'
     C                     Z-ADDFKH,X     P9YMD3
     C                     MOVEL'1'       P9KOS3
     C                     ENDIF
     C           P9KOS3    IFEQ '0'
     C           FGH,X     IFGT *DATE
     C                     Z-ADDFGH,X     P9YMD3
     C                     MOVEL'1'       P9KOS3
     C                     ENDIF
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         ESB490    ENDSR
