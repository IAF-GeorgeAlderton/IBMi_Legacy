     C******************************************************
     C*  MAIN
     C******************************************************
     C                     EXSR @F1INT
     C*
     C                     DO   *HIVAL
     C*
     C                     EXFMTFMT010
     C   KC                LEAVE
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      W#P1ER  1
     C                     EXSR @F1CHK
     C*
     C           W#P1ER    IFEQ *ON
     C                     ITER
     C                     END
     C                     Z-ADD*ZERO     W@UCNT  50
     C                     EXSR @F1SET
     C                     Z-ADDW@UCNT    F1INV2
     C           F1SHN1    IFNE W1SHN1
     C           F1SHN2    ORNE W1SHN2
     C           F1SHN3    ORNE W1SHN3
     C                     MOVELF1SHN1    W1SHN1
     C                     MOVELF1SHN2    W1SHN2
     C                     MOVELF1SHN3    W1SHN3
     C                     ITER
     C                     END
     C*
     C           *INKE     IFEQ *ON
     C                     EXSR @ADDF
     C                     EXSR @F1INT
     C                     END
      *
     C                     ENDDO
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
      *=====================================================
     C           *INZSR    BEGSR
      *
     C                     TIME           WWTIME
      *
     C                     Z-ADD@@YMD     W@SLDT
     C                     SUB  3         W@SLDM
     C           W@SLDM    IFLE *ZERO
     C                     SUB  1         W@SLDY
     C                     ADD  12        W@SLDM
     C                     END
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  1ST SCREEN INITIALIZE
     C*----------------------------------------------------*
     C           @F1INT    BEGSR
     C*
     C                     MOVEL*BLANK    F1SHN1
     C                     MOVEL*BLANK    F1SHN2
     C                     MOVEL*BLANK    F1SHN3
     C                     Z-ADD*ZERO     F1INVD
     C                     Z-ADD*ZERO     F1INV1
     C                     Z-ADD*ZERO     F1INV2
     C*
     C                     MOVEL*BLANK    MSG
     C                     Z-ADD@@YMD     F1INVD
     C*
     C                     MOVEL*BLANK    W1SHN1  5
     C                     MOVEL*BLANK    W1SHN2  5
     C                     MOVEL*BLANK    W1SHN3  2
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  CHECK FMT010
     C*----------------------------------------------------*
     C           @F1CHK    BEGSR
     C*
     C                     SETOF                     515253
     C                     SETOF                     69
     C                     MOVEL*BLANK    MSG
     C*
     C                     DO
     C*
     C           F1SHN1    IFEQ *BLANK
     C                     SETON                     5169
     C                     MOVELERR,2     MSG
     C                     LEAVE
     C                     END
     C*
     C           F1INVD    IFEQ *ZERO
     C           F1INVD    ORGT @@YMD
     C                     SETON                     5269
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,4     MSG
     C                     END
     C                     LEAVE
     C                     END
     C*
     C                     Z-ADDF1INVD    W@KDT
     C           K#AGD     KLIST
     C                     KFLD           W@KDTY
     C                     KFLD           W@KDTM
     C                     KFLD           W@KDTD
     C           K#AGD     CHAINAGDPL12              97
     C           *IN97     IFEQ *ON
     C                     SETON                     5269
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,4     MSG
     C                     END
     C                     LEAVE
     C                     END
      * APICS LEVELED
     C           K#KEY     KLIST
     C                     KFLD           F1SHN1
     C                     KFLD           F1SHN2
     C                     KFLD           F1SHN3
     C           K#KEY     CHAINAGAPL31              97
     C           *IN97     IFEQ *ON
     C           CBSKJY    ORNE *BLANK
     C           MSG       IFEQ *BLANK
     C                     SETON                     5169
     C                     MOVELERR,3     MSG
     C                     END
     C                     LEAVE
     C                     END
     C*
     C           W1SHN1    IFNE *BLANK
     C           W1SHN2    ORNE *BLANK
     C           W1SHN3    ORNE *BLANK
     C           F1INV1    IFEQ *ZERO
     C                     SETON                     5369
     C                     MOVELERR,5     MSG
     C                     LEAVE
     C                     END
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  SET LOGICAL INVENTORY
     C*----------------------------------------------------*
     C           @F1SET    BEGSR
     C*
     C           K#KEY     SETLLAH#TL18
      *
     C                     DO   *HIVAL
      *
     C           K#KEY     READEAH#TL18                  97
     C   97                LEAVE
     C           CFSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           CFHTHZ    IFLT W@SLDT
     C                     LEAVE
     C                     END
     C*
     C                     CLEARPG
     C*
     C           K#L381    KLIST
     C                     KFLD           CFZENO
     C                     KFLD           CFTHNO
     C                     KFLD           CFHTYY
     C                     KFLD           CFHTMM
     C                     KFLD           CFHTDD
