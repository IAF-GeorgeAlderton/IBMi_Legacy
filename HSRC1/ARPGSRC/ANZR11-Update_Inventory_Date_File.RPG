     C                     MOVE A3PAGE    I
     C           I         IFGT CFMAIS
     C                     ITER
     C                     END
      *
     C                     MOVEL'*'       PG,I
     C*
     C                     ENDDO
     C*
     C                     Z-ADD*ZERO     I
     C                     Z-ADD*ZERO     J       30
     C*
     C                     DO   *HIVAL
     C                     ADD  1         I
     C           I         IFGT CFMAIS
     C                     LEAVE
     C                     END
     C           PG,I      IFEQ *BLANK
     C                     ADD  1         J
     C           K#AD01    KLIST
     C                     KFLD           K@KSKB  1
     C                     KFLD           CFZENO
     C                     KFLD           CFTHNO
     C                     MOVEL'A'       K@KSKB
     C           K#AD01    SETLLADAPL01
     C                     DO   *HIVAL
     C           K#AD01    READEADAPL01                  91
     C   91                LEAVE
     C           ADDTKB    IFNE 'S'
     C                     ITER
     C                     END
     C                     MOVE I         W@A2@1  2
     C                     MOVELADPGNO    W@A2@2  2
     C           W@A2@1    IFNE W@A2@2
     C                     ITER
     C                     END
     C           CFHTHZ    IFGT ADKODT
     C                     ITER
     C                     END
     C                     LEAVE
     C                     ENDDO
     C           *IN91     IFEQ *ON
     C                     ADD  1         W@UCNT
     C                     END
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C                     ENDSR
