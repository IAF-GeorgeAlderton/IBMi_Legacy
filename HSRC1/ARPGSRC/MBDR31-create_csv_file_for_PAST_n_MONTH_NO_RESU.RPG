     H            Y.
     F** MBDR31 *********************************************************
     F*  PROGRAM    : CREATE CSV FILE FOR PAST N MONTH NO RESULT LIST   *
     F*             : (STEP1)                                           *
     F*  WRITTEN    : 02/09/2016                                        *
     F*  WRITTEN BY : JW (SRA)                                          *
     F*  FUNCTION   : READ FCEPL01 AND CHAIN TO DELIVERY DATA (MBDPL14) *
     F*             : AND OUTPUT MBDWP31                                *
     F*-----------------------------------------------------------------*
JW1  F*  J.WATANABE 05/10/2016 MODIFY PAST MONTH ACCEPT 0 (MONTH)       *
     F*******************************************************************
     FFCEPL01 IF  E           K        DISK
     FMBDPL14 IF  E           K        DISK
     FMBDWP31 UF  E           K        DISK                      A
     E                    XQ         12  7 0
     I            DS
     I                                        1   9 XLOC
     I                                        1   1 MTKR1
     I                                        2   2 H1A
     I                                        3   4 MTKR2
     I                                        5   5 H1B
     I                                        6   7 MTKR3
     I                                        8   8 H1C
     I                                        9   9 MTKR4
     I            DS
     I                                        1   80A2TRHZ
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     I            DS
     I                                        1   60A2TAYM
     I                                        1   40A2TAYY
     I                                        5   60A2TAMM
     I            DS
     I                                        1   60@TDY
     I                                        1   40@TDYYY
     I                                        5   60@TDYMM
     I            DS
     I                                        1   60@TO
     I                                        1   40@TOYY
     I                                        5   60@TOMM
     I            DS
     I                                        1   60@FRM
     I                                        1   40@FRMYY
     I                                        5   60@FRMMM
     I            DS
     I                                        1   60@LAST
     I                                        1   40@LSYY
     I                                        5   60@LSMM
     I            DS
     I                                        1   60XYYMM
     I                                        1   40XYY
     I                                        5   60XMM
     I            DS
     I                                        1   60WKYYMM
     I                                        1   40WKYY
     I                                        5   60WKMM
     I            DS
     I                                        1  840XQ
     I                                        1   70F4TS01
     I                                        8  140F4TS02
     I                                       15  210F4TS03
     I                                       22  280F4TS04
     I                                       29  350F4TS05
     I                                       36  420F4TS06
     I                                       43  490F4TS07
     I                                       50  560F4TS08
     I                                       57  630F4TS09
     I                                       64  700F4TS10
     I                                       71  770F4TS11
     I                                       78  840F4TS12
      *----------------------------------------------------------
      *
     C                     EXSR #INZ
      *
     C           *IN95     DOWEQ*OFF
     C                     READ FCEPL01                  95
     C           *IN95     IFEQ *OFF
      * SKIP IF DELETED
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
      * SKIP IF LOCATION ORDER TYPE=G
     C           A2TEHI    IFNE 'G'
     C                     ITER
     C                     ENDIF
      * SKIP IF START DATE > TODAY
     C           A2TAYM    IFGT @PHYM
     C                     ITER
     C                     ENDIF
      * LOCATION
     C           A2TRHZ    IFGT *DATE
     C                     MOVELA2KTRK    MTKR1
     C                     MOVELA2KTRT    MTKR2
     C                     MOVELA2KTRR    MTKR3
     C                     MOVELA2KTRD    MTKR4
     C                     ELSE
     C                     MOVELA2STRK    MTKR1
     C                     MOVELA2STRT    MTKR2
     C                     MOVELA2STRR    MTKR3
     C                     MOVELA2STRD    MTKR4
     C                     ENDIF
      * SKIP IF MTKR1=1 (LOCATION)
     C           MTKR1     IFEQ '1'
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #SALES
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-------------------------------------------------------------------
      *                    COUNT PAST NO SALES MONTH
      *-------------------------------------------------------------------
     C           #SALES    BEGSR
      *
     C                     MOVE 'N'       DLTFLG  1
     C                     MOVE 'Y'       FIRST
      *
     C                     MOVE *OFF      *IN96
     C           KEY1      SETGTMBDPL14
     C           *IN96     DOWEQ*OFF
     C                     READPMBDPL14                  96
     C           *IN96     IFEQ *OFF
      * END?
     C           F4SHN1    IFNE A2BHB1
     C           F4SHN2    ORNE A2BHB2
     C           F4SHN3    ORNE A2BHB3
     C                     MOVE *ON       *IN96
     C                     LEAVE
     C                     ENDIF
      * SKIP IF NEN-YEAR > @TO-YEAR
     C           F4TNEN    IFGT @TOYY
     C                     ITER
     C                     ENDIF
      * SKIP IF NEN > @FROM
     C           F4TNEN    IFGT @FRMYY
     C           F4NONY    ANDEQSVNONY
     C                     ITER
     C                     ENDIF
      * SKIP IF DELIVERY#=0323
     C           F4NONY    IFEQ 0323
     C                     ITER
     C                     ENDIF
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     Z-ADDF4NONY    SVNONY  40
     C                     Z-ADD0         @LAST
     C                     ENDIF
      * BREAK?
     C           F4NONY    IFNE SVNONY
     C                     EXSR #BREAK
     C                     ENDIF
      * DETAIL
     C                     Z-ADD0         WKYYMM
     C                     Z-ADD13        IX
     C           1         DO   12
     C                     SUB  1         IX
     C           XQ,IX     IFNE 0
     C                     Z-ADDF4TNEN    WKYY
     C                     Z-ADDIX        WKMM
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           @LAST     IFLT WKYYMM
     C                     Z-ADDWKYYMM    @LAST
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      * LAST BREAK?
     C           FIRST     IFEQ 'N'
     C                     EXSR #BREAK
     C                     ENDIF
      * DELETE PART
     C           DLTFLG    IFEQ 'Y'
     C                     EXSR #DLTP
     C                     ENDIF
      *
     C           ESALES    ENDSR
      *-------------------------------------------------------------------
      *                    WRITE WORK FILE
      *-------------------------------------------------------------------
     C           #BREAK    BEGSR
      * CALCULATE @PAST FROM @LAST & @TO
     C                     EXSR #CALC
      * SET DELETE FLAG
     C**JW1      @PAST     IFEQ 0
     C**JW1      @PAST     ORLT PAST#
JW1  C           @PAST     IFLT PAST#
     C                     MOVE 'Y'       DLTFLG
     C                     ENDIF
      * WRITE
     C**JW1      @PAST     IFNE 0
     C**JW1      @PAST     ANDGEPAST#
JW1  C           @PAST     IFGE PAST#
     C                     CLEARMBDWP311
     C                     MOVELA2BHB1    M1SHN1
     C                     MOVELA2BHB2    M1SHN2
     C                     MOVELA2BHB3    M1SHN3
     C                     MOVELXLOC      M1LOC
     C                     Z-ADDSVNONY    M1NONY
     C                     Z-ADD@LAST     M1LAST
     C                     Z-ADD@PAST     M1PAST
     C                     WRITEMBDWP311
     C                     ENDIF
      *
     C                     Z-ADDF4NONY    SVNONY
     C                     Z-ADD0         @LAST
     C                     Z-ADD0         @PAST
      *
     C           EBREAK    ENDSR
      *-------------------------------------------------------------------
      *                    CALCULATE @PAST FROM @LAST & @TO
      *-------------------------------------------------------------------
     C           #CALC     BEGSR
      *
     C                     Z-ADD@LAST     XYYMM
     C                     Z-ADD0         @PAST
      * ADD 1 MONTH
     C                     ADD  1         XMM
     C           XMM       IFGE 13
     C                     Z-ADD1         XMM
     C                     ADD  1         XYY
     C                     ENDIF
      *
     C           @TO       IFGT XYYMM
     C           1         DO   101
     C                     ADD  1         XMM
     C           XMM       IFGE 13
     C                     Z-ADD1         XMM
     C                     ADD  1         XYY
     C                     ENDIF
      *
     C                     ADD  1         @PAST
      *LEAVE
     C           @PAST     IFGE 100
     C                     Z-ADD99        @PAST
     C                     LEAVE
     C                     ENDIF
      *LEAVE
     C           @TO       IFLE XYYMM
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
     C                     ENDIF
      *
     C           ECALC     ENDSR
      *-------------------------------------------------------------------
      *                    DELETE PART
      *-------------------------------------------------------------------
     C           #DLTP     BEGSR
      *
     C                     MOVE *OFF      *IN97
     C           KEY1      SETLLMBDWP31
     C           *IN97     DOWEQ*OFF
     C           KEY1      READEMBDWP31                  97
     C           *IN97     IFEQ *OFF
     C                     DELETMBDWP311
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-------------------------------------------------------------------
      *                    INITIALIZE
      *-------------------------------------------------------------------
     C           #INZ      BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           PHYM    6
     C                     PARM           PAST#   20
      *
     C           KEY1      KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
      *
     C                     MOVELPHYM      @PHYM   60
     C                     Z-ADD0         @PAST   30
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         IX      20
     C                     MOVE '-'       H1A
     C                     MOVE '-'       H1B
     C                     MOVE '-'       H1C
      *
     C                     Z-ADD*DATE     @TODAY  80
     C                     MOVEL@TODAY    @TDY
     C                     MOVEL@TODAY    @TO
      * GET MONTH: TO
     C*          @TDY      SUB  1         @TO
     C*          @TOMM     IFLE 0
     C*                    Z-ADD12        @TOMM
     C*          @TDYYY    SUB  1         @TOYY
     C*                    ENDIF
      * GET MONTH: FROM
     C                     Z-ADD@TO       @FRM
     C**         PAST#     SUB  1         IX
     C                     Z-ADDPAST#     IX
     C           IX        IFNE 0
     C           1         DO   IX
     C                     SUB  1         @FRMMM
     C           @FRMMM    IFLE 0
     C                     Z-ADD12        @FRMMM
     C           @FRMYY    SUB  1         @FRMYY
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDSR
