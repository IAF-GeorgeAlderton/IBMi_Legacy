     H            Y.                                                      EER030
     F** GBFR21 ********************************************
     F* SUPPLIER PROCESSING PRIMITIVE COST M/F UPDATE FROM DISPLAY  *
     F*             M-OKUDA          1985.11.07            *
     F******************************************************
     FGBFPW21 CF  E                    WORKSTN
     FFGBPL01 IF  E           K        DISK
     FGBFPL21 UF  E           K        DISK                      A
     E                    ER      1  20 60               ERR MSG
     I            DS
     I                                        1   80SHIZK
     I                                        1   40G7SKYY
     I                                        5   60G7SKMM
     I                                        7   80G7SKDD
     I            DS
     I                                        1   80KHIZK
     I                                        1   40G7KOYY
     I                                        5   60G7KOMM
     I                                        7   80G7KODD
     I            DS
     I                                        1   60WTIME
     I                                        1   20G7KOJI
     I                                        3   40G7KOFN
     I                                        5   60BIYO
     C******************************************************
     C* M-NO               ﾌﾟ[x-j- ﾉ cinﾒ                  *
     C******************************************************
     C           *ENTRY    PLIST
     C                     PARM           PUS    10
     C                     PARM           PTOKU   4
     C                     PARM           PTKOJ   1
     C                     MOVE PTOKU     UTOKU   40
     C                     MOVE *BLANK    TMEIG  16
     C/SPACE 1
     C                     SETOF                     01
     C           UTOKU     CHAINFGBPL011             04
     C           *IN04     IFEQ '0'
     C           B2SKJY    IFNE 'D'
     C                     MOVELB2SMEI    TMEIG
     C                     END
     C                     END
     C/SPACE 1
     C           STEP01    TAG
     C                     EXFMTGBFPW211
     C                     SETOF                     010203
     C                     SETOF                     909192
     C                     SETOF                     939989
     C                     SETOF                     505153
     C/SPACE 1
     C           *INKA     CABEQ'1'       END
     C/SPACE 1
     C           MENT      IFEQ '0'
     C                     SETON                     01
     C                     MOVE 'CANCEL'  CMNT    6
     C                     GOTO STEP02
     C                     ELSE
     C           MENT      IFEQ '1'
     C                     SETON                     02
     C                     MOVE 'CHANGE'  CMNT    6
     C                     GOTO STEP02
     C                     ELSE
     C           MENT      IFEQ '2'
     C                     SETON                     03
     C                     MOVE 'ADD'     CMNT    6
     C                     GOTO STEP02
     C                     ELSE
     C                     SETON                     9990
     C                     MOVE ER,1      MSG    60
     C                     GOTO STEP01
     C                     END
     C                     END
     C                     END
     C           STEP02    TAG
     C/SPACE 1
     C           G7MEK1    IFEQ *BLANK
     C                     SETON                     9991
     C                     MOVE ER,2      MSG
     C                     GOTO STEP01
     C                     END
     C           G7MEK1    IFEQ '****'
     C                     SETON                     9991
     C                     MOVE ER,3      MSG
     C                     GOTO STEP01
     C                     END
     C           G7MEK2    IFEQ *BLANK
     C                     SETON                     9992
     C                     MOVE ER,4      MSG
     C                     GOTO STEP01
     C                     END
     C           G7MEK2    IFEQ '**'
     C                     SETON                     9992
     C                     MOVE ER,5      MSG
     C                     GOTO STEP01
     C                     END
     C           G7MEK3    IFEQ *BLANK
     C                     SETON                     9989
     C                     MOVE ER,17     MSG
     C                     GOTO STEP01
     C                     END
     C           G7MEK3    IFNE '*'
     C                     SETON                     9989
     C                     MOVE ER,18     MSG
     C                     GOTO STEP01
     C                     END
     C/SPACE 1
     C           G7SAIZ    IFEQ 0
     C                     SETON                     9993
     C                     MOVE ER,6      MSG
     C                     GOTO STEP01
     C                     END
     C/SPACE 1
     C           MENT      IFEQ '2'
     C           XTOKU     IFEQ *BLANK
     C           XNKOJ     ANDEQ*BLANK
     C                     ELSE
     C/SPACE 1
     C           KEY       KLIST
     C                     KFLD           XTOK
     C                     KFLD           XNKOJ
     C                     KFLD           G7MEK1
     C                     KFLD           G7MEK2
     C                     KFLD           G7MEK3
     C                     KFLD           G7SAIZ
     C                     MOVE XTOKU     XTOK    40
     C                     SETOF                     52
     C           KEY       CHAINGBFPL211             52
     C           *IN52     IFEQ '0'
     C                     SETON                     53
     C                     Z-ADDG7HTNK    ZHTNK   75
     C                     MOVE G7HTNI    ZHTNI   1
     C                     MOVE G7MCOD    ZMCOD  10
     C                     MOVE G7MMEI    ZMMEI  25
     C                     END
     C                     END
     C                     ELSE
     C/SPACE 1
     C           XTOKU     IFNE *BLANK
     C                     SETON                     5099
     C                     MOVE ER,19     MSG
     C                     GOTO STEP01
     C                     END
     C           XNKOJ     IFNE *BLANK
     C                     SETON                     5199
     C                     MOVE ER,20     MSG
     C                     GOTO STEP01
     C                     END
     C                     END
     C/SPACE 1
     C           MKEY      KLIST
     C                     KFLD           UTOKU
     C                     KFLD           PTKOJ
     C                     KFLD           G7MEK1
     C                     KFLD           G7MEK2
     C                     KFLD           G7MEK3
     C                     KFLD           G7SAIZ
     C                     SETOF                     05
     C           MKEY      CHAINGBFPL211             05
     C******************************************************
     C* M-NO               ﾃcﾆ]hﾎﾞ] n uﾇj- ﾉ f]ib kdlh     *
     C******************************************************
     C           MENT      IFEQ '0'
     C           *IN05     IFEQ '0'
     C           G7SKJY    IFEQ 'D'
     C                     SETON                     9990
     C                     MOVELER,7      MSG
     C                     GOTO STEP01
     C                     END
     C                     ELSE
     C                     SETON                     9990
     C                     MOVELER,8      MSG
     C                     GOTO STEP01
     C                     END
     C                     END
     C           MENT      IFEQ '1'
     C           *IN05     IFEQ '0'
     C           G7SKJY    IFEQ 'D'
     C                     SETON                     9990
     C                     MOVELER,9      MSG
     C                     GOTO STEP01
     C                     END
     C                     ELSE
     C                     SETON                     9990
     C                     MOVELER,10     MSG
     C                     GOTO STEP01
     C                     END
     C                     END
     C           MENT      IFEQ '2'
     C           *IN05     IFEQ '0'
     C           G7SKJY    IFNE 'D'
     C                     SETON                     9990
     C                     MOVELER,11     MSG
     C                     GOTO STEP01
     C                     END
     C                     END
     C                     END
     C/SPACE 1
     C           MENT      IFEQ '2'
     C                     Z-ADD0         G7HTNK
     C                     MOVE *BLANK    G7HTNI
     C                     MOVE *BLANK    G7MCOD
     C                     MOVE *BLANK    G7MMEI
     C           *IN53     IFEQ '1'
