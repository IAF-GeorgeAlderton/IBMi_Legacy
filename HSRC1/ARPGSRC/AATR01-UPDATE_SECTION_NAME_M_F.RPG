     H            Y.                                                      EER030
     F** AATR01 ****************************
     F*    UPDATE OF SECTION NAME M/F      *
     F*            H.ITO      86.10.15     *
     F**************************** AATR01 **
     FAATPL01 UF  E           K        DISK                      A
     FFGBPL01 IF  E           K        DISK
     FAATPW01 CF  E                    WORKSTN
     FAIANP04 O   F     256            DISK                      A
     E                    KOCD    1   3  1   KONM    6   更新区分
     E                    ER      1  12 60               エラーＭＳＧ
     E                    HBM         4  1               部門コード
     I            DS
     I                                        1   4 HBM
     I                                        1   4 BMON
     I            DS
     I                                        1  20 DCNAMK
     I                                        2  19 WNAMK
     I            DS
     I                                        1   80DCSKHZ
     I                                        1   40DCSKYY
     I                                        5   60DCSKMM
     I                                        7   80DCSKDD
     I            DS
     I                                        1   80DCKOHZ
     I                                        1   40DCKOYY
     I                                        5   60DCKOMM
     I                                        7   80DCKODD
     I            DS
     I                                        1   60WTIME
     I                                        1   20DCKOHH
     I                                        3   40DCKOSS
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
     I            DS
     I                                        1   6 WNAME
     I                                        1   4 WBMON
     I                                        5   5 H1
     I                                        6   6 DCTAIP
     C           *ENTRY    PLIST
     C                     PARM           US     10
     C                     Z-ADD0         DCSKHZ
     C                     MOVE '-'       H1
     C*----------------*
     C*   画面－１   *
     C*----------------*
     C           STP1      TAG
     C                     EXFMTAATPW011
     C                     SETOF                     010203
     C                     SETOF                     99
     C*
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C*----------------*
     C*   更新区分   *
     C*----------------*
     C                     SETOF                     30
     C                     Z-ADD1         A       10
     C           KOSN      LOKUPKOCD,A                   30
     C           *IN30     IFEQ '0'
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
     C                     MOVE KONM,A    WKOSN
     C*------------------*
     C*   部門コード   *
     C*------------------*
     C           BMON      IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
     C*
     C                     Z-ADD1         A       10
     C           1         DO   4         A
     C           HBM,A     IFGE '0'
     C           HBM,A     IFLE '9'
     C                     GOTO ATP1
     C                     END
     C                     END
     C                     SETON                     0299
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C           ATP1      TAG
     C                     END
     C                     MOVE BMON      WBMON
     C*--------------------*
     C*   細目マスター   *
     C*--------------------*
     C                     MOVE BMON      DCBMON
     C                     SETOF                     30
     C           DCBMON    CHAINFGBPL011             30
     C           *IN30     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '1'
     C                     SETON                     0299
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     END
     C*----------------------------*
     C*    部門コード・タイプ    *
     C*----------------------------*
     C           DCTAIP    IFEQ *BLANK
     C                     SETON                     0399
     C                     MOVE ER,5      MSG
     C                     GOTO STP1
     C                     END
     C*---------------------*
     C*   追加　の　場合  *
     C*---------------------*
     C           KEY1      KLIST
     C                     KFLD           DCBMON
     C                     KFLD           DCTAIP
     C                     SETOF                     30
     C           KEY1      CHAINAATPL011             30
     C           KOSN      IFEQ '2'
     C           *IN30     IFEQ '0'
     C           DCSKJY    IFEQ 'D'
     C           DCSKHZ    ANDLE*DATE
     C                     GOTO SP1
     C                     END
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,6      MSG
     C                     GOTO STP1
     C                     END
     C                     END
     C*---------------------*
     C*   変更　の　場合  *
     C*---------------------*
     C           KOSN      IFEQ '1'
     C           *IN30     IFEQ '1'
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,7      MSG
     C                     GOTO STP1
     C                     END
     C           DCSKJY    IFEQ 'D'
     C           DCSKHZ    ANDLE*DATE
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,8      MSG
     C                     GOTO STP1
     C                     END
     C                     END
     C*---------------------*
     C*   取消　の　場合  *
     C*---------------------*
     C           KOSN      IFEQ '0'
     C           *IN30     IFEQ '1'
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,9      MSG
     C                     GOTO STP1
     C                     END
     C           DCSKJY    IFEQ 'D'
     C           DCSKHZ    ANDLE*DATE
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,10     MSG
     C                     GOTO STP1
     C                     END
     C                     END
     C           SP1       TAG
     C*
     C           KOSN      IFEQ '2'
     C                     MOVE *BLANK    DCSKJY
     C                     Z-ADD0         DCSKHZ
     C                     MOVE *BLANK    DCNAMK
     C                     MOVE *BLANK    DCNAMN
     C                     END
     C*----------------*
     C*   画面－２   *
     C*----------------*
     C           STP2      TAG
     C                     EXFMTAATPW012
     C                     SETOF                     010299
     C*
     C           *INKC     IFEQ '1'
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C                     END
     C*
     C*----------------------*
     C*   かんばん種類名   *
     C*----------------------*
     C*          WNAMK     IFEQ *BLANK
     C*                    SETON                     0199
     C*                    MOVE ER,11     MSG
     C*                    GOTO STP2
     C*                    END
     C           DCNAMN    IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVE ER,12     MSG
     C                     GOTO STP2
     C                     END
     C*
     C           *INKE     IFEQ '0'
     C                     GOTO STP2
     C                     END
     C*
     C                     MOVE WKOSN     MNAME
     C                     MOVE BMON      MBMON
     C                     MOVE DCTAIP    MTAIP
     C                     Z-ADD*DATE     DCKOHZ
     C                     TIME           WTIME
     C                     MOVELUS        DCKOME
     C           KOSN      IFEQ '0'
     C                     MOVE 'D'       DCSKJY
     C                     Z-ADD*DATE     DCSKHZ
     C                     ELSE
     C                     MOVE *BLANK    DCSKJY
     C                     Z-ADD0         DCSKHZ
     C                     END
     C           *IN30     IFEQ '0'
     C                     UPDATAATPL011
     C                     ELSE
     C                     WRITEAATPL011
     C                     END
     C                     EXCPTDT
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C*------------------------------*
     C*   画面－１　の　クリアー   *
     C*------------------------------*
     C           SUBRTN    BEGSR
     C                     MOVE *BLANK    KOSN
     C                     MOVE *BLANK    BMON
     C                     MOVE *BLANK    DCTAIP
     C                     ENDSR
     OAIANP04 EADD             DT
     O                                    2 'BM'
     O                         DCSKJY     3
     O                         DCSKYY     7
     O                         DCSKMM     9
     O                         DCSKDD    11
     O                         DCKOYY    15
     O                         DCKOMM    17
     O                         DCKODD    19
     O                         DCKOHH    21
     O                         DCKOSS    23
     O                         DCKOME    33
     O                         DCBMON    37
     O                         DCTAIP    38
     O                         DCNAMN    58
     O                         DCNAMK    78
**  (KOCD/KONM)
0CANCEL
1CHANGE
2ADD
**  ER
E-01 UPDATE INSTRUCTION IS ERROR < 0=CANCEL.1=CHANGE.2=ADD >
E-02 SECTION CODE ISN'T INPUT
E-03 DEPARTMENT CODE TURNS INTO NUMBER ITEM
E-04 DEPARTMENT CODE IS NOT IN DETAILS M/F
E-05 DEPARTMENT CODE TYPE ISN'T INPUT
E-06 ADD WAS APPOINTED, BUT M/F EXISTS
E-07 CHANGE WAS APPOINTED, BUT M/F DOESN'T EXIST
E-08 CHANGE WAS APPOINTED, BUT M/F IS CANCELLED ALREADY
E-09 CANCEL WAS APPOINTED, BUT M/F DOESN'T EXIST
E-10 CANCEL WAS APPOINTED, BUT M/F IS CANCELLED ALREADY
E-11 KANBAN KIND NAME (KANJI) ISN'T INPUT
E-12 KANBAN KIND NAME (KANA) ISN'T INPUT
