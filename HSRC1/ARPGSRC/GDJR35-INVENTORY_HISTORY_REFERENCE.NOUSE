     C****************************************************************
     C*           KLIST                            *
     C****************************************************************
     C*** joeﾜﾆ ﾓbﾈg ﾎｦbﾓ ***
     C           IQ@KEY    KLIST
     C                     KFLD           K@HIN1  5
     C                     KFLD           K@HIN2  5
     C                     KFLD           K@HIN3  2
     C****************************************************************
     C*           MAIN ROUTINE                                       *
     C****************************************************************
     C                     EXSR #INIT
     C*** DSP01 ***
     C           @DSP01    TAG
     C                     MOVE *OFF      *IN20
     C                     WRITEDSP02
     C                     EXFMTDSP01
     C                     MOVE '0'       *IN11
     C                     MOVEL'0'       *IN99
     C                     MOVE *BLANK    D#MSG
     C*
     C           *INKA     CABEQ'1'       @END
     C*
     C                     EXSR #D1CHK
     C           *IN99     CABEQ'1'       @DSP01
     C*
     C                     EXSR #SFSET
     C                     MOVEA'1'       *IN,51
     C*** SFL01 ***
     C           @SFL01    TAG
     C                     MOVE *ON       *IN20
     C                     MOVEA'11'      *IN,81
     C                     WRITEDSP02
     C   51                EXFMTCTL01
     C  N51                EXFMTCTL02
     C                     MOVEA'00'      *IN,81
     C*
     C           *INKA     CABEQ'1'       @END
     C           *INKC     CABEQ'1'       @DSP01
     C           *INKG     IFEQ '1'
     C           *IN51     IFEQ '1'
     C                     MOVEL'0'       *IN,51
     C                     ELSE
     C                     MOVEL'1'       *IN,51
     C                     END
     C                     GOTO @SFL01
     C                     END
     C*
     C           *IN25     CASEQ'1'       #ROLUP
     C                     END
     C*
     C                     GOTO @SFL01
     C**
     C           @END      TAG
     C                     SETON                     LR
     C                     RETRN
     C****************************************************************
     C*          #INIT                                               *
     C****************************************************************
     C           #INIT     BEGSR                                     *
     C                     MOVE '0'       *IN11
     C                     MOVEL'0'       *IN99
     C                     MOVE *BLANK    D#MSG
     C                     MOVEA*ZERO     SRY
     C                     MOVEA*ZERO     TAN
     C                     ENDSR
     C****************************************************************
     C*          #D1CHK   DSP1 CHECK                                 *
     C****************************************************************
     C           #D1CHK    BEGSR                                     *
     C*** joeﾜﾆ ﾓbﾈg ﾎｦbﾓ ***
     C                     MOVELD1HIN1    K@HIN1  5
     C                     MOVELD1HIN2    K@HIN2  5
     C                     MOVELD1HIN3    K@HIN3  2
     C           IQ@KEY    SETLLGDJPP251                 91
     C           *IN91     IFEQ *OFF
     C                     MOVE '1'       *IN11
     C  N99                MOVELMSG,1     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     END
     C                     ENDSR
     C****************************************************************
     C*          #SFSET   SFL1 SET                                   *
     C****************************************************************
     C           #SFSET    BEGSR                                     *
     C                     MOVE *ON       *IN40
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     RRN2    40
     C                     MOVE *ON       *IN83
     C                     WRITECTL01                      (SFLCLR)
     C                     WRITECTL02                      (SFLCLR)
     C                     MOVE *OFF      *IN83
     C*
     C                     DO   *HIVAL
     C           IQ@KEY    READEGDJPP251                 91
     C           *IN91     IFEQ *ON
     C                     LEAVE
     C                     END
     C*
     C           *IN40     IFEQ *ON
     C                     Z-ADDIQYYM     W@YYM   40
     C                     Z-ADDIQMM      W@MM    20
     C                     MOVE *OFF      *IN40
     C                     ENDIF
     C*
     C           IQYYM     IFNE W@YYM
     C           IQMM      ORNE W@MM
     C                     Z-ADDIQYYM     W@YYM   40
     C                     Z-ADDIQMM      W@MM    20
     C*
     C                     ADD  1         RRN1
     C                     ADD  1         RRN2
     C                     WRITESFL01
     C                     WRITESFL02
     C                     CLEARSFL01
     C                     CLEARSFL02
     C                     ENDIF
     C*
     C                     EXSR #SET
     C                     ENDDO
     C**
     C           *IN40     IFEQ *OFF
     C                     ADD  1         RRN1
     C                     ADD  1         RRN2
     C                     WRITESFL01
     C                     WRITESFL02
     C                     CLEARSFL01
     C                     CLEARSFL02
     C                     ENDIF
     C**
     C                     Z-ADDRRN1      W@RRN   40
     C                     Z-ADD1         RRN1
     C                     Z-ADD1         RRN2
     C**
     C                     ENDSR
     C****************************************************************
     C*          #ROLUP   NEXT PAGE SET                              *
     C****************************************************************
     C           #ROLUP    BEGSR                                     *
     C                     MOVE *ON       *IN40
     C                     Z-ADDW@RRN     RRN1    40
     C                     Z-ADDW@RRN     RRN2    40
     C*
     C                     DO   *HIVAL
     C           IQ@KEY    READEGDJPP251                 91
     C           *IN91     IFEQ *ON
     C                     LEAVE
     C                     END
     C*
     C           *IN40     IFEQ *ON
     C                     Z-ADDIQYYM     W@YYM   40
     C                     Z-ADDIQMM      W@MM    20
     C                     MOVE *OFF      *IN40
     C                     ENDIF
     C*
     C           IQYYM     IFNE W@YYM
     C           IQMM      ORNE W@MM
     C                     ADD  1         RRN1
     C                     ADD  1         RRN2
     C                     WRITESFL01
     C                     WRITESFL02
     C                     CLEARSFL01
     C                     CLEARSFL02
     C*
     C                     Z-ADDIQYYM     W@YYM   40
     C                     Z-ADDIQMM      W@MM    20
     C                     ENDIF
     C*
     C                     EXSR #SET
     C                     ENDDO
     C**
     C           *IN40     IFEQ *OFF
     C                     ADD  1         RRN1
     C                     ADD  1         RRN2
     C                     WRITESFL01
     C                     WRITESFL02
     C                     Z-ADDRRN1      W@RRN   40
     C                     CLEARSFL01
     C                     CLEARSFL02
     C                     END
     C**
     C                     Z-ADDW@RRN     RRN1
     C                     Z-ADDW@RRN     RRN2
     C                     ENDSR
     C****************************************************************
     C*          #SET     FIELD SET                                  *
     C****************************************************************
     C           #SET      BEGSR
