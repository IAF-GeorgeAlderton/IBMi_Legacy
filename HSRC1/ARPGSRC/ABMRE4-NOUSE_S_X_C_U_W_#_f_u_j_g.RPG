      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
      *
     I              '0123456789'          C         WKCKSU
      *
     C           *ENTRY    PLIST
     C                     PARM           P@DTYM  60
      *
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C           1         SETLLABMWP311
     C                     READ ABMWP311                 21
     C           *IN21     DOWEQ'0'
     C           @AKERR    IFEQ '*'
     C           @BKCD1    ANDEQ'6'
     C                     EXSR #SB200
     C                     ENDIF
     C                     READ ABMWP311                 21
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------*
      *半製品かんばん検索       *
      *---------------------------*
     CSR         #SB200    BEGSR
      *
     C           KEYL71    KLIST
     C                     KFLD           #K1HB5  5
     C                     KFLD           #K2HB5  5
     C                     KFLD           #K3HB2  2
      *
     C                     MOVEL@BJHN1    #K1HB5
     C                     MOVEL@BJHN2    #K2HB5
     C                     MOVEL@BJHN3    #K3HB2
     C           KEYL71    SETGTAANPL061
     C           KEYL71    REDPEAANPL061                 82
     C           *IN82     DOWEQ'0'
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    ANDLE*DATE
     C                     ELSE
     C           L7STHZ    IFEQ 99999999
     C                     MOVEL'ZIDOU'   L7KOME    P
     C                     Z-ADD*DATE     L7KOHZ
     C                     EXSR #SB400
     C                     Z-ADDWKSRYD    L7KSSU
     C                     UPDATAANPL061
     C                     ENDIF
     C                     ENDIF
     C           KEYL71    REDPEAANPL061                 82
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *---------------------------*
      * GHCPP21より設定数       *
      *---------------------------*
     CSR         #SB400    BEGSR
      *
     C                     SETOF                     99
     C           KEYMD1    KLIST
     C                     KFLD           #KMBN1  1
     C                     KFLD           #KMBN2  2
     C                     KFLD           #KMBN3  2
     C                     KFLD           #KMBN4  1
     C                     KFLD           #KMHN1  5
     C                     KFLD           #KMHN2  5
     C                     KFLD           #KMHN3  2
      *
     C                     MOVELL7TKR1    #KMBN1
     C                     MOVELL7TKR2    #KMBN2
     C                     MOVELL7TKR3    #KMBN3
     C                     MOVELL7TKR4    #KMBN4
     C                     MOVELL7SHN1    #KMHN1
     C                     MOVELL7SHN2    #KMHN2
     C                     MOVELL7SHN3    #KMHN3
     C                     MOVEL'0'       FGET2   1
     C                     Z-ADD0         WKSRYO  90
     C           KEYMD1    SETLLGHCTL211
     C           KEYMD1    READEGHCTL211                 83
     C           *IN83     DOWEQ'0'
     C                     EXSR #SB405
     C                     MOVEL'1'       FGET2
     C           KEYMD1    READEGHCTL211                 83
     C                     ENDDO
      *
     C           WKSRYO    DIV  20        WKSRYD  90
      *
     CSR         ESB400    ENDSR
      *---------------------------*
      * ABMPL21より設定数       *
      *---------------------------*
     CSR         #SB405    BEGSR
      *
     C           KEY21     KLIST
     C                     KFLD           W2NTYM  60
     C                     KFLD           MDJHN1
     C                     KFLD           MDJHN2
     C                     KFLD           MDJHN3
     C                     Z-ADDP@DTYM    W2NTYM
     C                     Z-ADD0         W@FFF   90
     C           KEY21     CHAINABMPL211             48
     C           *IN48     IFEQ '0'
      *
     C           S4OMIT    IFEQ '0'
     C                     Z-ADDS4NSRY    W@FFF
     C           S4FSMN    IFGT W@FFF
     C                     Z-ADDS4FSMN    W@FFF
     C                     ENDIF
     C           S4FSM1    IFGT W@FFF
     C                     Z-ADDS4FSM1    W@FFF
     C                     ENDIF
     C                     ELSE
     C                     Z-ADDMDSETI    W@FFF
     C                     SETON                     99
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ADD  W@FFF     WKSRYO
      *
     CSR         ESB405    ENDSR
