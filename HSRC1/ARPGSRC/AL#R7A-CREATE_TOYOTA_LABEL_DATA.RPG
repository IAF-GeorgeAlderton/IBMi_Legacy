     H            Y.
     F** AL#R7A  *******************************************
     F*  TOYOTA LABEL ISSUE DATA                           *
     F*      ITS.        2015.06.02                        *
     F******************************************************
     FAL#WP73 IF  F     256            DISK
     FAL#PPA1 O   E                    DISK                      A
      *
     IAL#WP73 AA  01
     I                                        1 256 IALL
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
     C           *ENTRY    PLIST
     C                     PARM           P7FIXD  80
     C                     PARM           P7FIXT  60
     C                     PARM           P7TIMS  20
     C                     PARM           P7TRKB  2
     C                     PARM           P7IAFB  3
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
     C                     READ AL#WP73                  90
     C           *IN90     DOWEQ'0'
     C                     EXSR #SB500
     C                     READ AL#WP73                  90
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AL#PPA1
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C                     CLEARAL#PPA11
      *
     C                     Z-ADDSDATE     CRKOHZ
     C                     Z-ADDSTIME     CRKOTI
     C                     MOVELW#USER    CRKOME
     C                     MOVELIALL      CRDATA
      *
     C                     Z-ADDP7FIXD    CRFIXD
     C                     Z-ADDP7FIXT    CRFIXT
     C                     Z-ADDP7TIMS    CRTIMS
     C                     MOVELP7TRKB    CRTRKB
     C                     MOVELP7IAFB    CRIAFB
      *
     C                     WRITEAL#PPA11
      *
     CSR         ESB500    ENDSR
