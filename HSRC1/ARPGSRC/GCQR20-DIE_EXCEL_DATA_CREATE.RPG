     H            Y
     F** GCQR20 ********************************************
     F* DIE EXCEL DATA CREATE                              *
     F*      MSK         2005.04.02                        *
     F* TCHK1  10/29/05  CREATE(COPY FROM GCQR10)          *
     F* TCHK2  02/06/06  CHG OUTPUT FILE FORMAT
     F******************************************** GCQR20 **
     FGCQPL14 IF  E           K        DISK
     FECSPL07 IF  E           K        DISK
     FGCQWP20 O   E                    DISK
      *
     E                    WMM         6  6
     E                    CKK    21  21  2
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I            DS
     I                                        1  140W@TIME
     I                                        1   20W@TH
     I                                        3   40W@TM
     I                                        5   60W@TS
     I                                        7  100W@DY
     I                                       11  120W@DM
     I                                       13  140W@DD
     I            DS
     I                                        1   7 W@KATA
     I                                        1   2 T6KAT1
     I I            '-'                       3   3 W@KATH
     I                                        4   7 T6KAT2
     I            DS
     I                                        1  11 W@LOC
     I                                        1   1 T6TKR1
     I                                        2   2 W@LOCA
     I                                        3   4 T6TKR2
     I                                        5   5 W@LOCB
     I                                        6   7 T6TKR3
     I                                        8   8 W@LOCC
     I                                        9   9 T6TKR4
     I                                       10  10 W@LOCD
     I                                       11  11 T6TKR5
     I            DS
     I                                        1   80T6SKHZ
     I                                        1   40T6SKYY
     I                                        5   60T6SKMM
     I                                        7   80T6SKDD
     I            DS
     I                                        1   94W@94@
     I                                        1   50W@94@1
     I                                        6   90W@94@2
     C******************************************************
     C*  Main                                              *
     C******************************************************
     C*
     C           *LIKE     DEFN T6KAT1    K6KAT1
     C           *LIKE     DEFN T6KAT2    K6KAT2
     C                     MOVEL*BLANK    K6KAT1
     C                     MOVEL*BLANK    K6KAT2
     C           K#PL14    KLIST
     C                     KFLD           K6KAT1
     C                     KFLD           K6KAT2
     C           K#PL14    SETGTGCQPL14
     C*
     C                     DO   *HIVAL
     C*
     C                     READ GCQPL14                  99
     C   99                LEAVE
     C*
     C           T6SKJY    IFEQ 'D'
     C           T6SKHZ    ANDLE*DATE
     C                     ITER
     C                     END
     C*
     C                     MOVELT6KAT1    K6KAT1
     C                     MOVELT6KAT2    K6KAT2
     C*
     C                     EXSR @INTF
     C*
     C                     MOVELW@KATA    Q0KAT
      *
     C           T6TKR2    IFNE *BLANK
     C                     MOVEL'-'       W@LOCA
     C                     ELSE
     C                     MOVEL*BLANK    W@LOCA
     C                     END
     C           T6TKR3    IFNE *BLANK
     C                     MOVEL'-'       W@LOCB
     C                     ELSE
     C                     MOVEL*BLANK    W@LOCB
     C                     END
     C           T6TKR4    IFNE *BLANK
     C                     MOVEL'-'       W@LOCC
     C                     ELSE
     C                     MOVEL*BLANK    W@LOCC
     C                     END
     C           T6TKR5    IFNE *BLANK
     C                     MOVEL'-'       W@LOCD
     C                     ELSE
     C                     MOVEL*BLANK    W@LOCD
     C                     END
     C                     MOVELW@LOC     Q0LOC
      *
     C                     Z-ADDT6KIHZ    Q0KIDT
     C                     Z-ADDT6SRYO    Q0SRYO
     C                     Z-ADDT6MAIS    Q0MAIS
     C                     Z-ADDT6SYOS    Q0SYOS
     C*
     C                     Z-ADD*ZERO     W@SUMS  50
     C                     EXSR @GETD
     C           Q0SYOS    MULT 20        W@SYOS  50
     C           W@SUMS    DIV  W@MCNT    W@AVRS  72
     C           W@AVRS    MULT 1.25      W@9V4   94
     C           W@9V4     DIV  W@SYOS    W@9V4A  94
     C           W@9V4A    MULT 30        W@9V4B  94
     C           W@AVRS    DIV  Q0SYOS    W@9V4C  94
     C           W@9V4B    ADD  W@9V4C    W@94@
     C           W@94@2    IFNE *ZERO
     C           W@94@     ADD  1         W@7V0   50
     C                     ELSE
     C                     Z-ADDW@94@     W@7V0
     C                     END
     C*
     C                     Z-ADD1         I       20
     C           T6KAT1    LOKUPCKK,I                    81
     C           *IN81     IFEQ *ON
     C           W@7V0     IFLT 2
     C                     Z-ADD2         Q0MAI1
     C                     ELSE
     C                     Z-ADDW@7V0     Q0MAI1
     C                     END
     C                     ELSE
     C           W@7V0     IFLT 1
     C                     Z-ADD1         Q0MAI1
     C                     ELSE
     C                     Z-ADDW@7V0     Q0MAI1
     C                     END
     C                     END
     C*
     C           Q0MAIS    SUB  Q0MAI1    Q0MAI2
     C*
     C                     Z-ADDW@AVRS    Q0AVRS
     C*
     C                     WRITEGCQWP20R
     C*
     C           K#PL14    SETGTGCQPL14
     C*
     C                     ENDDO
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C*---------------------------------------------------*
     C*  Detail get                                       *
     C*---------------------------------------------------*
     C           @GETD     BEGSR
     C*
     C           K#ECS1    KLIST
     C                     KFLD           T6KAT1
     C                     KFLD           T6KAT2
     C                     KFLD           K#YY    40
     C                     KFLD           K#MM    20
     C                     KFLD           K#DD    20
     C           K#ECS2    KLIST
     C                     KFLD           T6KAT1
     C                     KFLD           T6KAT2
     C           K#ECS1    SETLLECSPL071
     C*
     C                     DO   *HIVAL
     C*
     C           K#ECS2    READEECSPL071                 98
     C   98                LEAVE
     C*
     C           EQSKJY    IFEQ 'D'
     C           EQSKHZ    ANDLE*DATE
     C                     ITER
     C                     END
     C*
     C                     MOVELEQYOYY    W@YYMM  6 P
     C                     MOVE EQYOMM    W@YYMM
     C                     Z-ADD1         J       10
     C           W@YYMM    LOKUPWMM,J                    82
     C           *IN82     IFEQ *ON
     C                     ADD  EQKOSU    W@SUMS
     C                     SELEC
     C           J         WHEQ 1
     C                     ADD  EQKOSU    Q0DTL1
     C           J         WHEQ 2
     C                     ADD  EQKOSU    Q0DTL2
     C           J         WHEQ 3
     C                     ADD  EQKOSU    Q0DTL3
     C           J         WHEQ 4
     C                     ADD  EQKOSU    Q0DTL4
     C           J         WHEQ 5
     C                     ADD  EQKOSU    Q0DTL5
     C           J         WHEQ 6
     C                     ADD  EQKOSU    Q0DTL6
     C                     ENDSL
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*---------------------------------------------------*
     C*  Outfile initial                                  *
     C*---------------------------------------------------*
     C           @INTF     BEGSR
     C*
     C                     CLEARGCQWP20R
     C*
TCHK2C*                    MOVEL','       Q0#01
TCHK2C*                    MOVEL','       Q0#02
TCHK2C*                    MOVEL','       Q0#03
TCHK2C*                    MOVEL','       Q0#04
TCHK2C*                    MOVEL','       Q0#05
TCHK2C*                    MOVEL','       Q0#06
TCHK2C*                    MOVEL','       Q0#07
TCHK2C*                    MOVEL','       Q0#08
TCHK2C*                    MOVEL','       Q0#09
TCHK2C*                    MOVEL','       Q0#10
TCHK2C*                    MOVEL','       Q0#11
TCHK2C*                    MOVEL','       Q0#12
TCHK2C*                    MOVEL','       Q0#13
TCHK2C*                    MOVEL','       Q0#14
     C*
     C                     ENDSR
     C******************************************************
     C*  Initial                                           *
     C******************************************************
     C           *INZSR    BEGSR
     C*
     C           *ENTRY    PLIST
     C                     PARM           PMMCNT  1
     C                     MOVELPMMCNT    W@MCNT  10
     C*
     C                     TIME           W@TIME
     C           W@DM      SUB  W@MCNT    W@@DM   20
     C           W@@DM     IFLE *ZERO
     C           W@DY      SUB  1         W@@DY   40
     C                     ADD  12        W@@DM
     C                     ELSE
     C                     Z-ADDW@DY      W@@DY
     C                     END
     C                     MOVELW@@DY     W@SDYM  60
     C                     MOVE W@@DM     W@SDYM
     C                     Z-ADDW@@DY     K#YY
     C                     Z-ADDW@@DM     K#MM
     C                     Z-ADD*ZERO     K#DD
     C*
     C                     CLEARWMM
     C                     Z-ADD1         I
     C                     DO   *HIVAL
     C                     MOVELW@SDYM    WMM,I
     C                     ADD  1         I
     C           I         IFGT W@MCNT
     C                     LEAVE
     C                     END
     C                     ADD  1         W@@DM
     C           W@@DM     IFGT 12
     C                     SUB  12        W@@DM
     C                     ADD  1         W@@DY
     C                     END
     C                     MOVELW@@DY     W@SDYM
     C                     MOVE W@@DM     W@SDYM
     C                     ENDDO
     C*
     C                     ENDSR
