     H            Y/
     F***************************************************
     F*   SALES REPORT DIFFERENCES IN PRICES              *
     F*                                                 *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FMBDPW80 CF  E                    WORKSTN
     FAB#PL0M IF  E           K        DISK
     F*ADPL24 IF  E           K        DISK
     FGADPL15 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     FMBDWP   O   E                    DISK
      *------------------------------------------------------------
      *
     E*                   ER      1   4 25
      *------------------------------------------------------------
     I            DS
     I                                        1  20 PART#
     I                                        1   5 Y1MHN1
     I                                        6  10 Y1MHN2
     I                                       11  15 Y1MHN3
     I                                       16  20 Y1MHN4
     I            DS
     I                                        1   80LEVEL
     I                                        1   40B1TOKU
     I                                        5   80B1NONY
     I            DS
     I                                        1   80LEVELX
     I                                        1   40X1TOKU
     I                                        5   80X1NONY
     I            DS
     I                                        1   60YYMM
     I                                        1   40YY
     I                                        5   60MM
     I            DS
     I                                        1   60KEY3
     I                                        1   40B1NOYY
     I                                        5   60B1NOMM
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
      *  DISPLAY SCREEN
     C           TOBU      TAG
     C                     EXFMTMBDPW801
     C   KA                SETON                     LR
     C   KA                GOTO END
     C                     SETOF                     99
      *
     C           STEP1     TAG
      *  ------------------------------------ *
     C                     Z-ADDN1        YYMM
      *
     C           KEY1      SETLLAB#PL0M
     C           KEY1      READEAB#PL0M                  80
B1    *  1--------------------------------------------1
     C           *IN80     DOWEQ'0'
B2   C           B1SKJY    IFEQ ' '
     C*          B1NONY    ANDEQ3804
      *
      * FIRST TIME
     C           X         IFEQ ' '
     C                     Z-ADDB1TOKU    X1TOKU
     C                     Z-ADDB1NONY    X1NONY
     C                     MOVE 'X'       X       1
     C                     ENDIF
      *
B3    *       -------------------------------------
     C           LEVEL     IFEQ LEVELX
     C*          B1NONY    IFEQ X1NONY
      *
     C                     ADD  B1SRYO    QTY     80
      * SALES MONTH AMT.
     C           B1SRYO    MULT B1TANK    AMT     92
     C                     ADD  AMT       AMTTOT  92
     C                     ADD  AMTTOT    AMTTOX  92
      * SPECIFIED MONTH AMT.
     C                     MOVE B1NKOJ    X1NKOJ
     C                     MOVE B1NUKE    X1NUKE
     C                     MOVE B1MHN1    X1MHN1
     C                     MOVE B1MHN2    X1MHN2
     C                     MOVE B1MHN3    X1MHN3
     C                     MOVE B1MHN4    X1MHN4
     C                     EXSR #FIND
     C           B1SRYO    MULT WTANK     SMT     92
     C                     ADD  SMT       SMTTOT  92
     C                     ADD  SMTTOT    SMTTOX  92
      *
 X3  C                     ELSE
      *
     C                     EXSR #PRT
      * PREPARE FOR NEXT
      * SALES MONTH AMT.
     C                     Z-ADD0         AMTTOT
     C           B1SRYO    MULT B1TANK    AMT     92
     C                     ADD  AMT       AMTTOT  92
     C                     ADD  AMTTOT    AMTTOX
      * SPECIFIED MONTH AMT.
     C                     Z-ADD0         SMTTOT
     C                     EXSR #FIND
     C           B1SRYO    MULT WTANK     SMT     92
     C                     ADD  SMT       SMTTOT  92
     C                     ADD  SMTTOT    SMTTOX
      *
     C                     Z-ADDB1SRYO    QTY     80
     C* MOVE KEY
     C                     Z-ADDB1TOKU    X1TOKU
     C                     Z-ADDB1NONY    X1NONY
     C                     MOVE B1NKOJ    X1NKOJ  1
     C                     MOVE B1NUKE    X1NUKE  4
     C                     MOVE B1MHN1    X1MHN1  5
     C                     MOVE B1MHN2    X1MHN2  5
     C                     MOVE B1MHN3    X1MHN3  5
     C                     MOVE B1MHN4    X1MHN4  5
      *
B2   C                     ENDIF
     C                     ENDIF
B3    *       -------------------------------------
      *
     C           KEY1      READEAB#PL0M                  80
      *
E1   C                     ENDDO
B1    *  1--------------------------------------------1
      *
     C                     EXSR #PRT
     C                     ADD  AMTTOT    AMTTOX
     C                     ADD  SMTTOT    SMTTOX
     C                     EXCPT@TOT
      *
     C           END       TAG
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  #FIND UNIT PRICE
      *-------------------------------------------------------
     C           #FIND     BEGSR
      *
      *----- DATA SET   ---*
     C                     SETON                     04
      *
     C                     MOVE X1TOKU    @TOKU   4        CUST
     C                     MOVE X1NONY    @NONY   4        DELIVERY
     C                     MOVE X1NKOJ    @NKOJ   1        FACTORY
     C                     MOVE X1NUKE    @NUKE   4        DOC
      *MOVE PART#                                          PART#
     C                     MOVE X1MHN1    Y1MHN1
     C                     MOVE X1MHN2    Y1MHN2
     C                     MOVE X1MHN3    Y1MHN3
     C                     MOVE X1MHN4    Y1MHN4
     C                     MOVE PART#     @MHIN  20        PART#
     C                     MOVE N2        N1Y     6
     C           N1Y       CAT  '01'      N1X     8
     C                     MOVE N1X       @HIZK   8        EFFEC DATE
     C                     Z-ADD0         @TANK  105       U. PRICE
     C                     MOVE *BLANK    @CHEK   1
      *
     C                     CALL 'FBCR10'
     C                     PARM           @TOKU
     C                     PARM           @NONY
     C                     PARM           @NKOJ
     C                     PARM           @NUKE
     C                     PARM           @MHIN
     C                     PARM           @HIZK
     C                     PARM           @TANK
     C                     PARM           @CHEK
      *
     C                     Z-ADD@TANK     WTANK  115
     C                     ENDSR
      *------------------------------------------------------
      *  PRINT
      *-------------------------------------------------------
     C           #PRT      BEGSR
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     TIME           @TIME   60
     C                     EXCPT@HED
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
      *
     C*                    MOVE @ER       A       10
      *
      * FIND NAME
     C                     CLEARNAME
     C           X1NONY    CHAINGADPL15              23
     C*          3804      CHAINGADPL15              23
     C           *IN23     IFEQ '0'
     C                     MOVELB5KMEI    NAME   15
     C                     ENDIF
     C                     EXCPT@DTL
     C                     WRITEMBDWP1
      *
     C                     ENDSR
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           KEY1      KLIST
     C                     KFLD           YY
     C                     KFLD           MM
      *
     C           KEY2      KLIST
     C                     KFLD           B1TOKU
     C                     KFLD           B1NONY
     C                     KFLD           B1NUKE
      *
     C                     MOVE *ALL'-'   @LINE 110
      *
     C                     ENDSR
      *------------------------------------------------------
     OQPRINT  E   02           @HED
     O                         #PGM       9
     O                         UDATE Y   60
     O                         @TIME     69 '  :  :  '
     O                                   72 'P.'
     O                         PAGE  Z   76
     O        E   03           @HED
     O                                   50 'PRICE COMPARISION LIST'
     O        E  102           @HED
     O                                   70 '  SALES DATE:'
     O                         N1        85 '    /  '
     O        E   02           @HED
     O                                   70 'UNIT P. DATE:'
     O                         N2        85 '    /  '
     O        E   04           @HED
     O                                    6 'CUST.'
     O                                   12 'DEL.'
     O                                   30 'QTY'
     O                                   35 'NAME'
     O                                   70 'AMOUNT (SALES MONTH)'
     O                                  110 'AMOUNT (UNIT PRICE)'
     O        E   05           @HED
     O                         @LINE    110
     O        E 1              @DTL
     O                         X1TOKU    06
     O                         X1NONY    12
     O                         QTY   J   30
     O                         NAME      50
     O                         AMTTOTJ   70
     O                         SMTTOTJ  110
     O        E 1              @TOT
