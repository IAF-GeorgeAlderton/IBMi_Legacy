     H            Y/
     F***************************************************
     F*  TOYOTA LABEL DATA MAINTENANCE                  *
JW1  F*  JW  2017.09.12 SYNCHRONIZING AB#PPA1           *
     F***************************************************
     FAB#PWA8 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FAB#PL40 UF  E           K        DISK                      A
     FFCEPL01 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FAB#PL13 UF  E           K        DISK
     FEDIPL40 IF  E           K        DISK
      *------------------------------------------------------------
     E                    CMD     1   2 78
     E                    ERR     1   2 78
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@NOYY
     I                                        5   60K@NOMM
     I                                        7   80K@NODD
     I            DS
     I                                        1  140W@TIM
     I                                        1   20W@HH
     I                                        3   40W@MM
     I                                        5   60W@SS
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C           W@ID      CASEQ'02'      #DSP02
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#AB13    KLIST
     C                     KFLD           K@NONY  40
     C                     KFLD           K@NOYY  40
     C                     KFLD           K@NOMM  20
     C                     KFLD           K@NODD  20
     C                     KFLD           K@DOCK  4
     C           K#AB40    KLIST
     C                     KFLD           K@NONY  40
     C                     KFLD           K@NOYY  40
     C                     KFLD           K@NOMM  20
     C                     KFLD           K@NODD  20
     C                     KFLD           K@DOCK  4
     C                     KFLD           S@MHN1
     C                     KFLD           S@MHN2
     C                     KFLD           H@MHN3
     C                     KFLD           H@MHN4
     C                     KFLD           D@BIN
     C                     KFLD           K@ORDR 15
     C           K#FC01    KLIST
     C                     KFLD           H@SHN1
     C                     KFLD           H@SHN2
     C                     KFLD           H@SHN3
     C           K#ABUP    KLIST
     C                     KFLD           K@NONY  40
     C                     KFLD           K@NOYY  40
     C                     KFLD           K@NOMM  20
     C                     KFLD           K@NODD  20
     C                     KFLD           K@DOCK  4
     C                     KFLD           S@MHN1
     C                     KFLD           S@MHN2
     C                     KFLD           H@MHN3
     C                     KFLD           H@MHN4
     C                     KFLD           H@ORDR
     C                     KFLD           D@BIN
      *
     C                     MOVEL'01'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET
     C           RRN1      IFEQ *ZERO
     C                     MOVE ERR,1     D@MSG
     C                     ELSE
     C                     MOVEL'02'      W@ID
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C           D@NONY    IFEQ *BLANK
     C                     SETON                     6199
     C                     ENDIF
      *
     C           D@DOCK    IFEQ *BLANK
     C                     SETON                     6299
     C                     ENDIF
      *
     C           D@SHDT    IFEQ *ZERO
     C                     SETON                     6399
     C                     ENDIF
      *
     C           D@BIN     IFEQ *ZERO
     C                     SETON                     6499
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR 2ND SCREEN
      *------------------------------------------------------
     C           #SET      BEGSR
      *
     C                     Z-ADDD@SHDT    K@YMD
     C                     MOVE D@NONY    K@NONY
     C                     MOVE D@DOCK    K@DOCK
     C                     Z-ADD*ZERO     RRN1    40
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
      *
     C           K#AB13    SETLLAB#PL13
     C           *IN80     DOUEQ*ON
     C           K#AB13    READEAB#PL13             N    80
     C           *IN80     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BANOBN    ANDEQD@BIN
      *
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     MOVELBAMHN1    S@MHN1
     C                     MOVELBAMHN2    S@MHN2
     C                     MOVELBAMHN3    S@MHN3
     C                     MOVELBAMHN3    H@MHN3
     C                     MOVELBAMHN4    H@MHN4
     C                     MOVELBASHN1    H@SHN1
     C                     MOVELBASHN2    H@SHN2
     C                     MOVELBASHN3    H@SHN3
     C                     MOVELBAODRN    H@ORDR
     C                     Z-ADDBANOTM    S@SHTM
     C                     MOVELBAINVN    K@ORDR
     C                     MOVELBAINVN    S@ORDR
     C           K#AB40    CHAINAB#PL40              90
     C           *IN90     IFEQ *OFF
     C                     MOVE DASTAD    S@STAD
     C                     MOVE DALIAD    S@LNAD
     C                     MOVE DAMAN#    S@MAIN
     C                     MOVE DAMANC    S@MRT#
     C                     MOVELDAORDN    S@ORDR
     C                     MOVE DASUB#    S@SUBR
     C                     ENDIF
     C                     WRITESFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD1         #RCNO1
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #DSP02    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCNO1
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
     C           *INKE     WHEQ *ON
     C                     EXSR #UPD
     C                     MOVE '01'      W@ID
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   UPDATE
      *------------------------------------------------------
     C           #UPD      BEGSR
      *
     C                     MOVE '0111'    @@4     4
     C           @@4       CHAINEDIPL40              90
     C           *IN90     IFEQ *OFF
     C                     MOVELE4ADD1    W@NAM  20
     C                     ENDIF
     C           K@NONY    CHAINFGBPL01              91
     C           *IN91     IFEQ *OFF
     C                     MOVELB2SMEI    DACUNM
     C                     ENDIF
      *
     C                     TIME           W@TIM
     C                     Z-ADD*ZERO     W@RRN   40
     C           *IN80     DOUEQ*ON
     C                     ADD  1         W@RRN
     C           W@RRN     CHAINSFL01                80
     C           *IN80     IFEQ *OFF
     C                     MOVELS@ORDR    K@ORDR    P
     C           K#AB40    CHAINAB#PL40              90
     C                     Z-ADD*YEAR     DAKOYY
     C                     Z-ADD*MONTH    DAKOMM
     C                     Z-ADD*DAY      DAKODD
     C                     Z-ADDW@HH      DAKOHH
     C                     Z-ADDW@MM      DAKOSS
     C                     MOVEL#USER     DAKOME
     C                     MOVE S@STAD    DASTAD
     C                     MOVE S@LNAD    DALIAD
     C                     MOVE S@MAIN    DAMAN#
     C                     MOVE S@MRT#    DAMANC
     C                     MOVELS@ORDR    DAORDN
     C                     MOVE S@SUBR    DASUB#
     C           *IN90     IFEQ *OFF
     C                     UPDATAB#PP401
     C                     ELSE
     C                     Z-ADDK@NONY    DANONY
     C                     MOVE '0'       DANKOJ
     C                     MOVE K@DOCK    DANUKE
     C                     Z-ADDK@NOYY    DANOYY
     C                     Z-ADDK@NOMM    DANOMM
     C                     Z-ADDK@NODD    DANODD
     C                     Z-ADDD@BIN     DANOBN
     C                     MOVELS@MHN1    DAMHN1
     C                     MOVELS@MHN2    DAMHN2
     C                     MOVELH@MHN3    DAMHN3
     C                     MOVE H@MHN4    DAMHN4
     C           K#FC01    CHAINFCEPL01              91
     C           *IN91     IFEQ *OFF
     C                     MOVELA2SMEI    DAPANM
     C                     ENDIF
     C                     MOVELB2SMEI    DACUNM
     C                     MOVELW@NAM     DASUNM
     C                     WRITEAB#PP401
     C                     ENDIF
      *
     C           K#ABUP    SETLLAB#PL13
     C           *IN90     DOUEQ*OFF
     C           K#ABUP    READEAB#PL13                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BAINVN    IFEQ *BLANK
     C           S@ORDR    ANDNE*BLANK
     C           BANOTM    OREQ *ZERO
     C           S@SHTM    ANDNE*ZERO
     C                     MOVELS@ORDR    BAINVN
     C                     Z-ADDS@SHTM    BANOTM
     C                     UPDATAB#PL131
JW1   * SYNCHRONIZING AB#PPA1
 |   C                     MOVEL'U'       POPT
 |   C                     Z-ADDBANONY    PANONY
 |   C                     MOVELBANKOJ    PANKOJ
 |   C                     MOVELBANUKE    PANUKE
 |   C                     Z-ADDBANOHZ    PANOHZ
 |   C                     Z-ADDBANOBN    PANOBN
 |   C                     MOVELBAODRN    PAODRN
 |   C                     MOVELBAMHIN    PAMHIN
 |   C                     MOVEL'AB#RA8  'PAFROM
 |   C                     MOVELBANOTM    PAFIL1
 |   C                     MOVELBAINVN    PAFIL2
 |   C                     CALL 'UEXR02'
 |   C                     PARM           POPT    1
 |   C                     PARM           PANONY  40
 |   C                     PARM           PANKOJ  1
 |   C                     PARM           PANUKE  4
 |   C                     PARM           PANOHZ  80
 |   C                     PARM           PANOBN  20
 |   C                     PARM           PAODRN 10
 |   C                     PARM           PAMHIN 20
 |   C                     PARM           PAFROM 10
 |   C                     PARM           PAFIL1 10
 |   C                     PARM           PAFIL2 20
 |   C                     PARM           PAFIL3 20
JW2  C                     PARM           PRTN    1
      *
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
**  CMD
F1:EXIT
F1:EXIT    F5:UPDATE    F12:PREV
**  ERR
NO DATA
