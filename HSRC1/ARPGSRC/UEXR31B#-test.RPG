     H            Y.
     F** UEXR31B ********************************************
     F*  PROGRAM: CHECK & GET HONDA BIN#                    *
     F*  WRITTEN: JW (SRA) 2021.10.20                       *
     F*-----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UEXR31B'
     F*                    PARM           $NONY   4
     F*                    PARM           $PLSH   8
     F*                    PARM           $BIN1   2
     F*                    PARM           $ODRN  20
     F*                    PARM           $BIN2   2
     F*  IN  $NONY :  4A DELIVERY#
     F*      $PLSH :  8A SHIP DATE
     F*      $BIN1 :  2A BIN#
     F*      $ODRN : 20A PO#
     F*  OUT $BIN2 :  2A BIN (SHOULD BE)
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      * CHECK PO#
     C                     DO   *HIVAL
     C                     ADD  1         @BIN1
     C                     MOVEL@BIN1     $BINX
     C                     CALL 'UEXR31A#'
     C                     PARM           $NONY   4
     C                     PARM           $PLSH   8
     C                     PARM           $BINX   2
     C                     PARM           $ODRN  20
     C                     PARM           $RTN    1        0:ORD NOT EXIST
      *                                                    Y:ORD EXIST -SAME PO#
      * NO ORDER EXISTS --> OK                             N:ORD EXIST -DIFF PO#
      * SAME PO EXISTS  --> OK
     C           $RTN      IFEQ '0'
     C           $RTN      OREQ 'Y'
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEL@BIN1     $BIN2
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4
     C                     PARM           $PLSH   8
     C                     PARM           $BIN1   2
     C                     PARM           $ODRN  20
     C                     PARM           $BIN2   2
      *
     C                     MOVEL$BIN1     $BIN2
     C                     MOVEL$BIN1     @BIN1   20
     C           @BIN1     IFGE 01
     C                     SUB  1         @BIN1
     C                     ENDIF
      *
     C                     ENDSR
