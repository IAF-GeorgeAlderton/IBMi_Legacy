     C                     MOVE 'D'       CQSKJY
     C                     MOVE *YEAR     CQSKYY
     C                     MOVE UMONTH    CQSKMM
     C                     MOVE UDAY      CQSKDD
     C                     Z-ADDTIMHH     CQKOHH                       )
     C                     Z-ADDTIMSS     CQKOSS                       )
     C                     MOVELUSER      CQKOME
     C                     UPDATAU#PL111
     C                     SETON                     6790
     C           Z         ADD  05        IN      20
     C                     MOVEA'1'       *IN,IN
     C                     END
     C  N85N67             END
      * 取消時カウンターマイナス
     C                     SUB  1         CTRX
      *
     C                     SETOF                       05
     C                     MOVE *BLANK    KR1,Z
     C                     GOTO $S900A
     C                     END
      *
     C           @TYPE     IFEQ '2'
     C                     SETOF                     8567
     C           KEY2      SETLLAD#PL111
     C                     Z-ADD0         WKCNT
     C                     DO   *HIVAL
     C           KEY2      READEAD#PL111                 85
     C           *IN85     IFEQ '0'
