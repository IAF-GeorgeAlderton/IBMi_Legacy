     C                     MOVE CATEHZ    ER1,X
     C                     MOVE CANOHZ    FR1,X
     C                     Z-ADDCANSRY    GR1,X
     C                     MOVE *BLANK    HR1,X
     C           CASKKB    IFEQ 'S'
     C                     MOVEL$CMN,4    HR1,X
     C                     END
     C           CASKKB    IFEQ 'K'
     C                     MOVEL$CMN,3    HR1,X
     C                     END
     C                     MOVE CAGYOM    IR1,X
     C                     MOVE *BLANK    JR1,X
     C                     SETOF                         88
     C           CAGYOM    LOKUPTAB3      TAB4           88
     C           *IN,88    IFEQ '1'
     C                     MOVELTAB4      JR1,X
     C           CANSRY    IFLT 0
     C           CAGYOM    IFEQ '13'
     C                     MOVEL' T -  '  JR1,X
     C                     END
     C           CAGYOM    IFEQ '14'
     C                     MOVEL' P -  '  JR1,X
     C                     END
     C           CAGYOM    IFEQ '15'
     C                     MOVEL' R -  '  JR1,X
     C                     END
     C           CAGYOM    IFEQ '16'
     C                     MOVEL' S -  '  JR1,X
     C                     END
     C                     END
     C                     END
     C                     MOVE CATEHF    #R2,X
     C                     MOVE CNT       #R3,X
     C           AR1,X     IFNE *BLANK
     C                     ADD  X         SW
     C                     MOVEA'1'       *IN,SW
     C                     END
     C           CASKJY    IFEQ 'D'
     C           X         ADD  05        XN      20
     C                     MOVEA'1'       *IN,XN
     C                     SETON                       9067
     C                     END
      *最終レコード
     C                     MOVE CASHN1    WKSHN1  5
     C                     MOVE CASHN2    WKSHN2  5
     C                     MOVE CASHN3    WKSHN3  2
     C                     MOVE CATEYY    WKTEYY  40
     C                     MOVE CATEMM    WKTEMM  20
     C                     MOVE CATEDD    WKTEDD  20
     C                     MOVE CATEHH    WKTEHH  20
     C                     MOVE CATEFN    WKTEFN  20
     C                     Z-ADDCNT       SAVCNT  40
      *
     C           X         IFEQ 14
     C                     SETON                       66
     C                     END
     CSR         $S410E    ENDSR
      *--------------------------------------------------*
      *　ワークアリアクリアー                          *
      *--------------------------------------------------*
     CSR         $SB420    BEGSR
     C                     MOVE *BLANK    AR1
     C                     MOVE *BLANK    BR1
     C                     MOVE *BLANK    CR1
     C                     MOVE *BLANK    DR1
     C                     Z-ADD0         ER1
     C                     Z-ADD0         FR1
     C                     Z-ADD0         GR1
