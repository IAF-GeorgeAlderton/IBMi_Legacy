     C                     MOVE 'D'       CASKJY
     C                     UPDATAD#PL111
     C           Z         ADD  05        IN      20
     C                     MOVEA'1'       *IN,IN
     C                     SETON                       9067
     C                     END
     C  N85N67             END
      * 取消時カウンターマイナス
     C*                    SUB  1         CTRX
      *
     C                     SETOF                       05
     C                     MOVE *BLANK    KR1,Z
     C                     GOTO $S900A
     C                     END
      *
     C                     END
     C                     GOTO $900S
     C           $S900A    TAG
     C           @TYPE     IFEQ '1'
