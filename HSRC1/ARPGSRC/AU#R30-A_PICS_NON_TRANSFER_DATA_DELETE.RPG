     C           *IN82     IFEQ '0'
     C                     MOVELB2SMEI    @NONNM
     C                     END
     C                     SETOF                     82
     C           $900S     TAG
     C                     EXFMTAU#PW304
      * CMD-3
     C           *IN03     IFEQ '1'
     C                     MOVE *BLANK    @TOKCD
     C                     MOVE *BLANK    @NONCD
     C                     MOVE *BLANK    @KOJCD
     C                     MOVE *BLANK    @UKECD
     C                     MOVE *ZERO     @SYMD
     C                     MOVE *ZERO     @NYMD
     C                     MOVE *ZERO     @SURYO
     C                     MOVEL*BLANK    @JYUNM
     C                     MOVE *BLANK    @GYOCD
     C                     MOVE *BLANK    @GYONM
