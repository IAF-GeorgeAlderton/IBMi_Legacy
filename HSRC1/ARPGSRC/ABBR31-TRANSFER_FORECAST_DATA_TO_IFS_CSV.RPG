     C                     MOVEL'MONTHVOL'W0MSET           MONTH SET
     C                     MOVEL'Q/C'     W0QPC            Q/C
     C                     MOVELW9YM01    W0FQ01           FC QTY01
     C                     MOVELW9YM02    W0FQ02           FC QTY02
     C                     MOVELW9YM03    W0FQ03           FC QTY03
     C                     MOVELW9YM04    W0FQ04           FC QTY04
     C                     MOVELW9YM05    W0FQ05           FC QTY05
     C                     MOVELW9YM06    W0FQ06           FC QTY06
     C                     MOVELW9YM07    W0FQ07           FC QTY07
     C                     MOVELW9YM08    W0FQ08           FC QTY08
     C                     MOVELW9YM09    W0FQ09           FC QTY09
JW1   *
 .   C                     MOVEL'3M AVR'  W03M
 .   C                     MOVEL'LOCATION'W0LOC
 .   C                     MOVEL'PRT TYPE'W0SVC
 .   C                     MOVEL'INVENTOR'W0INV
JW1  C                     MOVE 'Y '      W0INV
      * PGM NOTE
     C                     MOVELTTL,1     LTR26  26
     C                     MOVE TODAY     LTR26
     C                     MOVELLTR26     W0PGM
     C                     MOVE NOW       W0PGM
