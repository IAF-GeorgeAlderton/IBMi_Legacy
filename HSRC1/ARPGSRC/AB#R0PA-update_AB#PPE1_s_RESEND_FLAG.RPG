     H            Y.
     F** AB#R0PA ******************************************************
     F*  PROGRAM    : UPDATE AB#PPE1'S RESEND FLAG                    *
     F*  WRITTEN    : JW (SRA) 2024.05.21                             *
     F*****************************************************************
     FAB#EL59UIF  E           K        DISK
     FAB#PLE1 UF  E           K        DISK
      *****************************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           @DATE     SETLLAB#EL59U
     C                     DO   *HIVAL
     C           @DATE     READEAB#EL59U                 98
     C   98                LEAVE
      *
     C                     MOVELE1ASN     @SHID  15 P
     C                     EXSR #PPE1
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * UPDATE PPE1                                        *
      *----------------------------------------------------*
     C           #PPE1     BEGSR
      *
     C           @SHID     SETLLAB#PLE1
     C                     DO   *HIVAL
     C           @SHID     READEAB#PLE1                  97
     C   97                LEAVE
      * SELECT1
     C           M6PTRN    IFNE 'HONDA'
     C***        M6CRDT    OREQ TODAY
     C           M6ACKC    ORNE 'TR'
     C           M6RSUS    ORNE *BLANK
     C                     ITER
     C                     ENDIF
      * SELECT2
     C           M6CRDT    IFEQ TODAY
     C                     MOVELM6CRTM    $TM1
     C                     MOVELE1TIME    $TM2
     C                     CALL 'UTLR19'
     C                     PARM           $TM1    6
     C                     PARM           $TM2    6
     C                     PARM           $MIN    6
     C                     PARM           $SIGN   1
     C                     MOVEL$MIN      @MIN    60
     C           @MIN      IFLE 120
     C           $SIGN     ANDEQ'+'
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      * UPDATE
     C                     MOVEL'RESEND'  M6RSUS    P
     C                     Z-ADDE1CRDT    M6RSDT
     C                     Z-ADDE1CRTM    M6RSTM
     C                     MOVELE1SHID    M6RSID
     C                     UPDATAB#PPE11
     C                     ADD  1         UCNT
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      * INITIAL SETTING                                    *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $DATE   8
      *
     C                     TIME           SDATE
      *
     C           $DATE     IFEQ *BLANK
     C           $DATE     OREQ *ZERO
     C                     Z-ADDTODAY     @DATE   80
     C                     ELSE
     C                     MOVEL$DATE     @DATE
     C                     ENDIF
      *
     C                     Z-ADD0         UCNT    30
      *
     C                     ENDSR
