     F**FCER26************************************
     F* ...LOCATION & ACCOMODATED QUANTITY CHANGE LIST ... *
     F* SYSTEM DATE + 1 -- PARM DATE... * IT
     F*        I-HASADA         83.03.10         *
     F************************************FCER26**
     FAGDPL11 IF  E           K        DISK
     I            DS
     I                                        1   80F8KAHZ
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I                                        9  160UHIZK
     I                                        9  120UHIYY
     I                                       13  140UHIMM
     I                                       15  160UHIDD
     C           *ENTRY    PLIST
     C                     PARM           PHIZK   8
     C                     Z-ADD*DATE     UHIZK
     C           KEY       KLIST
     C                     KFLD           UHIYY
     C                     KFLD           UHIMM
     C                     KFLD           UHIDD
     C           KEY       CHAINAGDPL111             01
     C   01                GOTO STP1
     C                     READ AGDPL111                 02
     C   02                MOVE *BLANK    PHIZK
     C   02                GOTO END
     C                     MOVE F8KAHZ    PHIZK
     C                     GOTO END
     C           STP1      TAG
     C                     Z-ADD01        UHIDD
     C           KEY       SETLLAGDPL111
     C           STP2      TAG
     C                     SETOF                     03
     C                     READ AGDPL111                 03
     C   03                MOVE *BLANK    PHIZK
     C   03                GOTO END
     C           F8KAHZ    CABLE*DATE     STP2
     C                     MOVE F8KAHZ    PHIZK
     C           END       TAG
     C                     SETON                     LR
     C                     RETRN
