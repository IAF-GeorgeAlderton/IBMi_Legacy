     H            Y.
     F** AB#R91 *********************************************************
     F*   PRINT 2 POINT SCAN CHECK LIST                                 *
     F*         JUL/31/01                                               *
     F*                                                                 *
     F********************************************* AB#R30 **************
     FALDWL90 IF  E           K        DISK
     FEDIPL40 IF  E           K        DISK
     FFCCTL12 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     I            DS
     I                                        1   80WNOHZ
     I                                        1   40WNOYY
     I                                        5   60WNOMM
     I                                        7   80WNODD
     I            DS
     I                                        1   80W@DAT8
     I                                        1   40W@YY
     I                                        5   60W@MM
     I                                        7   80W@DD
     I            DS
     I                                        1  20 IMHN
     I                                        1   5 IMHN1
     I                                        6  10 IMHN2
     I                                       11  15 IMHN3
     I                                       16  20 IMHN4
     I            DS
     I                                        1  20 IMHNA
     I                                        1   5 IMMH1
     I                                        6   8 IMMH2
     I                                        9  12 IMMH3
     I                                       13  14 IMMH4
     I            DS
     I                                        1  12 BAHIN
     I                                        1   5 BASHN1
     I                                        6  10 BASHN2
     I                                       11  12 BASHN3
     I            DS
     I                                        1  12 A9HIN
     I                                        1   5 A9SHN1
     I                                        6  10 A9SHN2
     I                                       11  12 A9SHN3
     C************************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PDATE   6        INV DATE
     C                     PARM           PHIN1   5
     C                     PARM           PHIN2   5
     C                     PARM           PHIN3   2
     C************************************************************************
     C* FIXED ORDER FILE(AB#PL13)
     C           KEY1      KLIST
     C                     KFLD           W@NONY
     C                     KFLD           W@YY
     C                     KFLD           W@MM
     C                     KFLD           W@DD
     C*
     C           K#WP90    KLIST
     C                     KFLD           W@YY
     C                     KFLD           W@MM
     C                     KFLD           W@DD
      *
     C           K#FCC     KLIST
     C                     KFLD           W@MM
     C                     KFLD           A9SHN1
     C                     KFLD           A9SHN2
     C                     KFLD           A9SHN3
      *
     C           *LIKE     DEFN A9NONY    W@NONY
     C                     MOVE *ALL'-'   LINE   78
     C************************************************************************
      *
     C                     MOVE PDATE     W@DAT6  60
     C                     Z-ADDW@DAT6    W@DAT8
     C                     ADD  20000000  W@DAT8
     C                     Z-ADD*ZERO     CONT    30
     C                     MOVE *BLANK    WZETI   4
     C                     Z-ADD*ZERO     W@NONY
      *
     C           K#WP90    SETLLALDWL90
     C           *IN90     DOUEQ*ON
     C           K#WP90    READEALDWL90                  90
     C           *IN90     IFEQ *OFF
      *
     C           PHIN1     IFNE *BLANK
     C           A9SHN1    ANDNEPHIN1
     C                     ITER
     C                     ENDIF
      *
     C           PHIN2     IFNE *BLANK
     C           A9SHN2    ANDNEPHIN2
     C                     ITER
     C                     ENDIF
      *
     C           PHIN3     IFNE *BLANK
     C           A9SHN3    ANDNEPHIN3
     C                     ITER
     C                     ENDIF
      *
     C           W@NONY    IFNE A9NONY
     C                     MOVE A9NONY    WNONY   4
     C           WNONY     CHAINEDIPL401             10
     C                     EXCPT@HED
     C                     ENDIF
      *
     C                     MOVE *BLANK    WWSBAN
     C           K#FCC     SETLLFCCTL12
     C           *IN91     DOUEQ*ON
     C           K#FCC     READEFCCTL12                  91
     C           *IN91     IFEQ *OFF
     C           A9NONY    ANDEQB4NONY
     C                     MOVE B4SBAN    WWSBAN  4
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C   OF                EXCPT@HED
     C           A9SHN3    COMP *BLANK                   11
     C                     EXCPT@DTL
      *
     C                     Z-ADDA9NONY    W@NONY
      *
     C                     ENDIF
     C                     ENDDO
      *
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
     OQPRINT  E  202           @HED
     O                                   50 '2-POINT SCAN CHECK LIST'
     O        E  1             @HED
     O                                    8 'SHIP TO:'
     O                         A9NONY4   13
     O                      N10E4ADD1    64
     O        E  2             @HED
     O                                   13 'INVOICE DATE:'
     O                         W@DAT8    24 '    -  -  '
     O        E  1             @HED
     O                                    6 'KANBAN'
     O                                   70 'CHECK'
     O        E  1             @HED
     O                                    6 'NUMBER'
     O                                   10 'LOT'
     O                                   14 'PAG'
     O                                   28 'PARTS NUMBER'
     O                                   40 'QTY'
     O        E  1             @HED
     O                         LINE      78
     O        E  1             @DTL
     O                         WWSBAN     5
     O                         A9LOT     10
     O                         A9PAG     14
     O                         A9SHN1    21
     O                                   22 '-'
     O                         A9SHN2    27
     O                      N11          28 '-'
     O                         A9SHN3    33
     O                         A9SSYS1   40
     O                                   69 '(  )'
      *
