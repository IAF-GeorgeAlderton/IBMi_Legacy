     C           KEY3      CHAINAKGPL011             15
      *
     C                     MOVE *BLANK    E1SKJY
     C                     Z-ADD0         E1SKHZ
     C                     Z-ADD*DATE     E1KOHZ
     C                     TIME           E1TIME
     C                     MOVE PUS       E1KOME
     C                     MOVE PTKBI     E1TKBI
     C                     Z-ADD@UKHZ     E1UKHZ
     C                     Z-ADD@UBIN     E1UBIN
     C                     Z-ADD99999999  E1STHZ
     C                     Z-ADD99        E1SBIN
     C                     MOVE WTKR1     E1ATK1
     C                     MOVE WTKR2     E1ATK2
     C                     MOVE WTKR3     E1ATK3
     C                     MOVE WTKR4     E1ATK4
     C                     MOVE PKOTI     E1KKTI
     C                     Z-ADD@KBMN     E1UKOJ
     C                     MOVE PUKER     E1UKER
      *
     C*------------------------------------*
     C*  ..構成品かんばん切替マスター..  *
     C*------------------------------------*
     C                     SETOF                     10
     C                     MOVE PRECD     I
     C                     MOVE *BLANK    E1ATOK
     C                     Z-ADD0         E1ATOB
     C                     MOVE 0         E1SHIN
     C                     MOVE *BLANK    E1MAEK
     C                     Z-ADD0         E1MAKB
     C                     MOVE *BLANK    E1MTKR
      *
     C           KEY4      CHAINAKEPL011             10
     C           *IN10     IFEQ '0'
     C           M3SKJY    ANDEQ'D'
     C           M3SKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '0'
     C                     MOVE HKO,I     E1ATOK
     C                     Z-ADDHBM,I     E1ATOB
     C                     MOVE HHN,I     E1SHIN
      *
     C                     SETOF                     11
     C                     DO   *HIVAL
     C           I         SUB  1         I
     C           I         IFEQ 0
     C                     SETON                     11
     C                     ELSE
      *
     C           HBN,I     IFNE *BLANK
     C           HBN,I     IFNE '------'
     C           HBN,I     ANDNE'++++++'
     C                     MOVE HKO,I     E1MAEK
     C                     Z-ADDHBM,I     E1MAKB
     C                     MOVE HBN,I     E1MTKR
     C                     SETON                     11
     C                     END
     C                     END
      *
     C                     END
     C  N11                END
     C                     END
      *
     C*------------------------------*
     C*  ..構成部品情報マスター..  *
     C*------------------------------*
     C                     SETOF                     10
     C                     MOVE *ZERO     E1ZETI
     C                     Z-ADD0         E1KASI
     C                     MOVE *BLANK    E1MEKI
      *
     C           KEY5      CHAINAKCPL011             10
     C           *IN10     IFEQ '0'
     C                     Z-ADDM1KASI    E1KASI
     C                     MOVE M1MEKI    E1MEKI
     C                     MOVE M1ZENO    E1ZETI
     C                     END
      *
     C                     Z-ADD@GEKN     E1KSSU
     C                     MOVE '6'       E1DTKO
     C                     MOVE *BLANK    E1DTHE
     C                     MOVE *BLANK    E1KCD1
     C                     MOVE *BLANK    E1KCD2
      *
     C*------------------------------*
     C*  ..工程内所番地マスター..  *
     C*------------------------------*
     C                     MOVE *BLANK    WKCD1
     C                     MOVE *BLANK    WKCD2
     C           KEY2      SETGTAAJPL111
     C                     SETOF                     10
     C           KEY2      REDPEAAJPL111                 10
      *
     C           *IN10     IFEQ '0'
     C                     MOVE CJKDAI    WKCD1
     C                     MOVE CJKSYO    WKCD2
     C                     Z-ADD0         CJAKYY
     C                     Z-ADD0         CJAKMM
     C                     Z-ADD0         CJAKDD
     C                     MOVE E1SHN1    CJHIN1
     C                     MOVE E1SHN2    CJHIN2
     C                     MOVE E1SHN3    CJHIN3
     C                     MOVE E1MTK1    CJMBN1
     C                     MOVE E1MTK2    CJMBN2
     C                     MOVE E1MTK3    CJMBN3
     C                     MOVE E1MTK4    CJMBN4
     C                     UPDATAAJPL111
     C                     END
      *
     C                     MOVE WKCD1     E1KCD1
     C                     MOVE WKCD2     E1KCD2
      *
     C           *IN15     IFEQ '0'
     C                     UPDATAKGPL011
     C                     ELSE
     C                     WRITEAKGPL011
     C                     END
      *
     C                     END
     C                     ENDSR
      *
     C*---------------------------------------------------------------*
     C* #KUBN -->処理区分                                           *
     C* 5->新所番地が変わった時、旧所番地が失効日・新所番地が追加   *
     C*---------------------------------------------------------------*
     C           #SBR5     BEGSR
      *
     C*------------------*
     C*  ..旧所番地..  *
     C*------------------*
     C           POTKR     IFNE *BLANK
     C                     MOVE POTKR     WTKRO
      *
     C*--------------------------------------*
     C*  ..構成品メッキかんばんマスター..  *
     C*--------------------------------------*
     C           KEY1      SETGTAKGPL011
      *
     C                     SETOF                     16
     C           KEY1      REDPEAKGPL011                 16
     C           *IN16     IFEQ '0'
     C           E1SKJY    ANDEQ'D'
     C           E1SKHZ    ANDLE*DATE
     C                     SETON                     16
     C                     END
      *
     C           *IN16     IFEQ '0'
     C                     Z-ADDE1UKBI    E1TKBI
     C                     MOVE E1TKBI    PTKBI
     C                     Z-ADD@UKHZ     E1STHZ
     C                     Z-ADD@UBIN     E1SBIN
     C                     MOVE '7'       E1DTKO
     C                     MOVE *BLANK    E1DTHE
     C                     Z-ADD*DATE     E1KOHZ
     C                     TIME           E1TIME
     C                     MOVE PUS       E1KOME
     C                     UPDATAKGPL011
     C                     END
      *
     C*------------------------------*
     C*  ..工程内所番地マスター..  *
     C*------------------------------*
     C           KEY2      SETGTAAJPL111
     C                     SETOF                     10
     C           KEY2      REDPEAAJPL111                 10
      *
     C           *IN10     IFEQ '0'
     C                     Z-ADD@UKHZ     CJAKHZ
     C                     UPDATAAJPL111
     C                     END
     C                     END
      *
     C*----------------------------*
     C*  ..新所番地　追加処理..  *
     C*----------------------------*
     C           PNTKR     IFNE *BLANK
     C                     EXSR #SBR2
     C                     END
      *
     C                     ENDSR
