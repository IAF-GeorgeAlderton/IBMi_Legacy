     C           *ENTRY    PLIST
     C                     PARM           PUS    10         ﾏｰﾅﾞｰﾎﾟﾜﾎｧｰ
     C                     PARM           PKUBN   1        更新区分
     C                     PARM           PKHIN  12        構成品番
     C                     PARM           PKOTI   3        組付工程
     C                     PARM           PKBMN   4        受入工場
     C                     PARM           PUKER   4        受入
     C                     PARM           POTKR   6        旧所番地
     C                     PARM           PNTKR   6        新所番地
     C                     PARM           PUKHZ   8        有効日
     C                     PARM           PUBIN   2        便
     C                     PARM           PGEKN   9        月間必要数
     C                     PARM           PRECD   2        工程№
     C                     PARM           PTKBI  10        前失効日
      *
     C                     MOVE PKHIN     @KHIN
     C                     MOVE PKBMN     @KBMN   40
     C                     MOVE PUKHZ     @UKHZ
     C                     MOVE PUBIN     @UBIN
     C                     MOVE PGEKN     @GEKN   90
      *
     C*---------------------------------------------------------------*
     C* #KUBN -->処理区分                                           *
     C* 1->更新区分が＇０＇の時は、取消処理                         *
     C* 2->　　　　　＇１＇の時は、追加処理                         *
     C* 3->新所番地と有効日－便が変わらない時、月間必要数変更       *
     C* 4->新所番地が変わらず有効日－便が変わった時、有効日－便変更 *
     C* 5->新所番地が変わった時、旧所番地が失効日・新所番地が追加   *
     C*---------------------------------------------------------------*
     C           PKUBN     CASEQ'1'       #SBR1
     C           PKUBN     CASEQ'2'       #SBR2
     C           PKUBN     CASEQ'3'       #SBR3
     C           PKUBN     CASEQ'4'       #SBR4
     C           PKUBN     CASEQ'5'       #SBR5
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *
     C*---------------------------------------------------------------*
     C* #KUBN -->処理区分                                           *
     C* 1->更新区分が＇０＇の時は、取消処理                         *
     C*---------------------------------------------------------------*
     C           #SBR1     BEGSR
      *
     C                     Z-ADD1         X       10
     C           1         DO   2         X
      *
     C           X         IFEQ 1
     C           POTKR     IFEQ *BLANK
     C                     GOTO #STP1
     C                     END
     C                     MOVE POTKR     WTKRO
     C                     ELSE
     C           PNTKR     IFEQ *BLANK
     C                     GOTO #STP1
     C                     END
     C                     MOVE PNTKR     WTKRO
     C                     END
      *
     C*--------------------------------------*
     C*  ..構成品メッキかんばんマスター..  *
     C*--------------------------------------*
     C           KEY1      SETLLAKGPL011
     C                     DO   *HIVAL
     C                     SETOF                     11
     C           KEY1      READEAKGPL011                 11
      *
     C           *IN11     IFEQ '0'
     C           E1SKJY    IFEQ 'D'
     C           E1SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     MOVE 'D'       E1SKJY
     C                     Z-ADD*DATE     E1SKHZ
     C                     Z-ADD*DATE     E1KOHZ
     C                     TIME           E1TIME
     C                     MOVE PUS       E1KOME
     C                     MOVE '0'       E1DTKO
      *
     C           E1STHZ    IFNE 99999999
     C                     MOVE '*'       E1DTHE
     C                     ELSE
     C                     MOVE *BLANK    E1DTHE
     C                     Z-ADD@UKHZ     E1STHZ
     C                     Z-ADD@UBIN     E1SBIN
     C                     END
     C                     UPDATAKGPL011
      *
     C                     END
     C                     END
     C  N11                END
      *
     C*------------------------------*
     C*  ..工程内所番地マスター..  *
     C*------------------------------*
     C           KEY2      SETGTAAJPL111
     C                     SETOF                     10
     C           KEY2      REDPEAAJPL111                 10
     C           *IN10     IFEQ '0'
      *
     C           @UKHZ     IFGT *DATE
     C                     Z-ADD@UKHZ     CJAKHZ
     C                     ELSE
     C                     Z-ADD*DATE     CJAKHZ
     C                     END
      *
     C                     MOVE *BLANK    CJHIN1
     C                     MOVE *BLANK    CJHIN2
     C                     MOVE *BLANK    CJHIN3
     C                     Z-ADD0         CJSYUY
     C                     MOVE *BLANK    CJMBN1
     C                     MOVE *BLANK    CJMBN2
     C                     MOVE *BLANK    CJMBN3
     C                     MOVE *BLANK    CJMBN4
     C                     Z-ADD0         CJSLOT
     C                     UPDATAAJPL111
     C                     END
      *
     C           #STP1     TAG
     C                     END
      *
     C                     ENDSR
      *
