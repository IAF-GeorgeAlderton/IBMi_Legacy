     C                     ELSE
     C                     MOVE *BLANK    IGSKJY
     C                     Z-ADD0         IGSKYY
     C                     Z-ADD0         IGSKMM
     C                     Z-ADD0         IGSKDD
     C                     Z-ADD*DATE     IGKOHZ
     C                     Z-ADD@TIME     IGKOHS
     C                     MOVELPPUSER    IGKOME
     C                     UPDATGDIPL021
     C                     END
      *
E01  C                     ENDDO
