     C                     MOVEL*BLANK    IGCD
     C                     Z-ADDW1SYOS    IGSYOS
     C                     Z-ADDD3MAIS    IGMAIS
     C                     Z-ADDD3HAHZ    IGHAHZ
      *
     C           IGRENB    IFEQ *BLANK
      *
     C                     SETOF                     80
     C           1         CHAINGDINP011             80
      *
     C           *IN80     IFEQ '1'
     C                     Z-ADD1         IHRECD
     C                     MOVE IHRECD    IGRENB
     C                     WRITEGDINP011
     C                     ELSE
      *
     C           IHRECD    IFEQ 999
     C                     Z-ADD0         IHRECD
     C                     END
     C                     ADD  1         IHRECD
     C                     MOVE IHRECD    IGRENB
     C                     UPDATGDINP011
     C                     END
     C                     END
      *
     C                     WRITEGDIPL021
      *
