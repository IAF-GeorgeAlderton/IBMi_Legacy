      *-------------*
      * SYSTEM TIME *
      *-------------*
     I            DS
     I                                        1  140WTIME
     I                                        1   20WJI
     I                                        3   40WFN
      *--------*
      *  KEYS  *
      *--------*
     C           *ENTRY    PLIST
     C                     PARM           PUS    10
     C                     PARM           PRTFLG  1
      *
     C           KEY1      KLIST
     C                     KFLD           ZETI
     C                     KFLD           ORDR
     C                     KFLD           SEHI
     C                     KFLD           LOTN
     C                     KFLD           SYYY
     C                     KFLD           SYMM
     C                     KFLD           SYDD
     C                     KFLD           SYJI
     C                     KFLD           SYFN
      *--------------------*
      *  ALDR22 EXECUSION  *
     C*--------------------*
     C           *IN80     IFEQ '0'
     C                     SETON                     80
     C                     MOVE PUS       US     10
     C                     ENDIF
      *
     C                     MOVE *BLANK    EROR    1
     C                     SETOF                     50
     C           KEY1      CHAINALDPL201             50
     C           *IN50     IFEQ '0'
     C                     MOVE '*'       PRTFLG  1
     C                     MOVE '1'       EROR
     C                     EXSR LSTSUB
     C                     GOTO EXT
     C                     ENDIF
     C                     EXSR OUTSUB
     C           EXT       TAG
     CLR                   RETRN
      *----------*
      *  OUTSUB  *
      *----------*
     C           OUTSUB    BEGSR
     C                     Z-ADD*YEAR     A1KSYY
     C                     Z-ADD*MONTH    A1KSMM
     C                     Z-ADD*DAY      A1KSDD
     C                     TIME           WTIME
     C                     Z-ADDWJI       A1KSJI
     C                     Z-ADDWFN       A1KSPN
     C                     MOVE US        A1KSNA
     C                     MOVE SHN1      A1SHN1
     C                     MOVE SHN2      A1SHN2
     C                     MOVE SHN3      A1SHN3
     C                     Z-ADDSYYY      A1SYYY
     C                     Z-ADDSYMM      A1SYMM
     C                     Z-ADDSYDD      A1SYDD
     C                     Z-ADDSYJI      A1SYJI
     C                     Z-ADDSYFN      A1SYFN
     C                     MOVE KANS      A1KANS
     C                     MOVE ZETI      A1ZETI
     C                     MOVE ORDR      A1ORDR
     C                     MOVE SEHI      A1SEHI
     C                     Z-ADDLOTN      A1LOTN
     C                     MOVE TKR1      A1TKR1
     C                     MOVE TKR2      A1TKR2
     C                     MOVE TKR3      A1TKR3
     C                     MOVE TKR4      A1TKR4
     C                     MOVE OPER      A1OPER
     C                     MOVE MHN1      A1MHN1
     C                     MOVE MHN2      A1MHN2
     C                     MOVE MHN3      A1MHN3
     C                     MOVE MHN4      A1MHN4
     C                     Z-ADDSSYS      A1SSYS
     C                     Z-ADDUSYS      A1USYS
     C                     Z-ADDNONY      A1NONY
     C                     MOVE NKOJ      A1NKOJ
     C                     MOVE NUKE      A1NUKE
     C                     MOVE TOPX      A1TOPX
     C                     MOVE EFF       A1SALE
     C                     MOVE UPAG      A1UPAG
     C                     WRITEALDPP201
     C                     ENDSR
      *----------*
      *  LSTSUB  *
      *----------*
     C           LSTSUB    BEGSR
     C                     EXCPTDAT
     C                     ENDSR
      **********************************************************
