     H            Y.
     F** ABMR44 *********************************************
     F* SALES DATA
     F*    HOTTA.               2018.08.08                  *
     F*******************************************************
     FAB#PL09 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     E                    NDT        93  8 0             納入日
     E                    HAK        93  8 2             納入箱
      *
     I            DS
     I                                        1   80W@DATE
     I                                        1   60W@DTYM
     I                                        1   40W@DTYY
     I                                        5   60W@DTMM
     I                                        7   80W@DTDD
      *
     I            DS
     I                                        1   60W@M1YM
     I                                        1   40W@M1YY
     I                                        5   60W@M1MM
      *
     I            DS
     I                                        1   60W@M2YM
     I                                        1   40W@M2YY
     I                                        5   60W@M2MM
      *
     I            DS
     I                                        1   60W@M3YM
     I                                        1   40W@M3YY
     I                                        5   60W@M3MM
      *
     I            DS
     I                                        1   80F8KAHZ
     I                                        1   60F8KAYM
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
      *
     I            DS
     I                                        1   80WKYMD
     I                                        1   60WKYM
     I                                        7   80WKDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P9NOHZ  80
     C                     PARM           P9HAKO  90
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
     C                     Z-ADD*DATE     W@DATE
      * N-1
     C           W@DTMM    IFEQ 1
     C                     SUB  1         W@DTYY
     C                     Z-ADD12        W@DTMM
     C                     ELSE
     C                     SUB  1         W@DTMM
     C                     ENDIF
     C                     Z-ADDW@DTYM    W@M1YM
      * N-2
     C                     Z-ADDW@M1YM    W@M2YM
     C           W@M1MM    IFEQ 1
     C                     SUB  1         W@M2YY
     C                     Z-ADD12        W@M2MM
     C                     ELSE
     C                     SUB  1         W@M2MM
     C                     ENDIF
      * N-3
     C                     Z-ADDW@M2YM    W@M3YM
     C           W@M2MM    IFEQ 1
     C                     SUB  1         W@M3YY
     C                     Z-ADD12        W@M3MM
     C                     ELSE
     C                     SUB  1         W@M3MM
     C                     ENDIF
      *
     C                     CLEARNDT
     C                     CLEARHAK
     C                     Z-ADD0         X       30
     C           KEYF8     KLIST
     C                     KFLD           W@M3YY
     C                     KFLD           W@M3MM
     C           KEYF8     SETLLAGDPL121
     C                     READ AGDPL121                 81
     C           *IN81     DOWEQ'0'
     C           F8KAYM    ANDLEW@M1YM
     C                     ADD  1         X
     C           X         IFLE 93
     C                     Z-ADDF8KAHZ    NDT,X
     C                     ENDIF
     C                     READ AGDPL121                 81
     C                     ENDDO
      *
     C                     MOVELP1SHN1    Q5SHN1
     C                     MOVELP1SHN2    Q5SHN2
     C                     MOVELP1SHN3    Q5SHN3
     C                     Z-ADDW@M3YY    W@DTYY
     C                     Z-ADDW@M3MM    W@DTMM
     C                     EXSR #SB411
     C                     EXSR #SB420
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------------------------*
      * SALES DATA                                  *
      *---------------------------------------------*
     CSR         #SB411    BEGSR
      *
     C           KEYB11    KLIST
     C                     KFLD           Q5SHN1  5
     C                     KFLD           Q5SHN2  5
     C                     KFLD           Q5SHN3  2
     C                     KFLD           W@DTYY  40
     C                     KFLD           W@DTMM  20
      *
     C           KEYB12    KLIST
     C                     KFLD           Q5SHN1  5
     C                     KFLD           Q5SHN2  5
     C                     KFLD           Q5SHN3  2
     C                     MOVEL'0'       FORD    1
     C           KEYB11    SETLLAB#PL09
     C           KEYB12    READEAB#PL09                  82
     C           *IN82     DOWEQ'0'
     C           B1SKJY    IFEQ 'D'
     C           B1SKHZ    ANDLE*DATE
     C                     ELSE
     C           B1TOKU    IFEQ 5149
     C                     MOVEL'1'       FORD    1
     C                     ENDIF
     C                     EXSR #SB412
     C                     ENDIF
     C           KEYB12    READEAB#PL09                  82
     C                     ENDDO
      *
     CSR         ESB411    ENDSR
      *---------------------------------------------*
      * SALES DATA                                  *
      *---------------------------------------------*
     CSR         #SB412    BEGSR
      *
     C           B1SYUY    IFEQ 0
     C                     Z-ADD1         WKHAK   82
     C                     ELSE
     C           B1SRYO    DIV  B1SYUY    WKHAK   82
     C                     ENDIF
      *
     C                     Z-ADD1         X
     C           B1NOHZ    LOKUPNDT,X                    29
     C           *IN29     IFEQ '1'
     C                     ADD  WKHAK     HAK,X
     C                     ENDIF
      *
     CSR         ESB412    ENDSR
      *---------------------------------------------*
      * SALES DATA  MAX                             *
      *---------------------------------------------*
     CSR         #SB420    BEGSR
      *
     C                     Z-ADD0         P9NOHZ
     C                     Z-ADD0         P9HAKO
     C                     Z-ADD1         X
     C           FORD      IFEQ '0'
     C                     Z-ADDW@M1YM    WKYM
     C                     Z-ADD1         WKDD
     C                     ELSE
     C                     Z-ADDW@M3YM    WKYM
     C                     Z-ADD1         WKDD
     C                     ENDIF
      *
     C           X         DOWLE93
     C           HAK,X     IFGT P9HAKO
     C           NDT,X     ANDGEWKYMD
     C                     Z-ADDNDT,X     P9NOHZ
     C                     Z-ADDHAK,X     P9HAKO
     C                     ADD  0.999     P9HAKO
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         ESB420    ENDSR
