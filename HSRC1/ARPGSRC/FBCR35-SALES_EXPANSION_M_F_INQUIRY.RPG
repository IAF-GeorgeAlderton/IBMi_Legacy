     H            Y.
     F** FBCR35 ********************************************
     F*  SALES EXPANSION M/F INQUIRY                     *
     F*  T.SAKAKI                           2016.07.20     *
JW1  F*  J.W   ADD EXP_DATE                 2019.06.05     *
JW2  F*  J.W   ADD F7 TO DOWNLOAD CSV       2020.06.10     *
     F******************************************************
     FFBCPW35 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN   KSFILE SFREC1
     FGADPL11 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FFBCPL21 IF  E           K        DISK
JW2  FFBCWP35 O   E           K        DISK                           UC
      *
     IINFDS       DS
     I                                    B 378 3790$$RRN
     I****************************
     I*プログラム状況データ構造*
     I****************************
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
     I            DS
     I                                        1   80SBSKHZ
     I                                        1   40SBSKYY
     I                                        5   60SBSKMM
     I                                        7   80SBSKDD
JW1  I            DS
     I                                        1  23 @MHIN
     I                                        1   5 @MHN1
     I                                        6   6 PH1
     I                                        7  11 @MHN2
     I                                       12  12 PH2
     I                                       13  17 @MHN3
     I                                       18  18 PH3
     I                                       19  23 @MHN4
JW1  I            DS
     I                                        1  20 $MHIN
     I                                        1   5 $MHIN1
     I                                        6  10 $MHIN2
     I                                       11  15 $MHIN3
     I                                       16  20 $MHIN4
JW1  I            DS
     I                                        1  14 @SHIN
     I                                        1   5 @SHN1
     I                                        6   6 PS1
     I                                        7  11 @SHN2
     I                                       12  12 PS2
     I                                       13  14 @SHN3
JW1  I            DS
     I                                        1  12 #SHIN
     I                                        1   5 #SHN1
     I                                        6  10 #SHN2
     I                                       11  12 #SHN3
JW1  I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        7  120@TODAY
     I              ''''                  C         @A
     C*===============================================================
     C* ENTRY LIST
     C*===============================================================
     C           *ENTRY    PLIST
     C                     PARM           PSLSP  10
     C*===============================================================
     C* KEY LIST
     C*===============================================================
     C           K#GAD     KLIST
     C                     KFLD           F2TOKU
     C                     KFLD           F2NONY
     C           K#GAD1    KLIST
     C                     KFLD           F2TOKU
     C                     KFLD           F2NONY
     C                     KFLD           F2NKOJ
     C           K#GAD2    KLIST
     C                     KFLD           F2TOKU
     C                     KFLD           F2NONY
     C                     KFLD           F2NKOJ
     C                     KFLD           F2NUKE
     C*===============================================================
     C*
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C* INITIAL SETTINGS
     C*===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
JW   C                     TIME           SDATE
     C*  SFLCLR
     C                     SETON                     82
     C                     WRITESFCTL1
     C                     SETOF                     82
     C                     Z-ADD0         RRN     40
     C                     Z-ADD0         ENDRRN  40
     C                     MOVE *BLANK    @@UMU   1        データ有無
     C*
     C***        PSLSP     IFEQ *BLANK
     C           *LOVAL    SETLLFBCPL21
     C                     SETON                     91
     C***                  ELSE
     C***        PSLSP     SETLLFBCPL21
     C***                  SETON                     92
     C***                  ENDIF
     C*-------------------------
S1   C                     DO   *HIVAL
     C   91                READ FBCPL21                  90
     C***92      PSLSP     READEFBCPL21                  90
     C   90                LEAVE
 S2  C           F2SKJY    IFEQ 'D'
     C           F2SYMD    ANDLE*DATE
     C                     ITER
 E2  C                     ENDIF
     C**
     C                     MOVEL*BLANK    @CNAM
     C                     SELEC
     C           F2NONY    WHEQ *ZERO
     C           F2TOKU    CHAINFGBPL01              93
     C           *IN93     IFEQ *OFF
     C           B2SKJY    ANDEQ*BLANK
     C                     MOVELB2SMEI    @CNAM
     C                     ENDIF
     C           F2NKOJ    WHEQ *BLANK
     C           K#GAD     CHAINGADPL11              93
     C  N93                MOVELB5KMEI    @CNAM
     C           F2NUKE    WHEQ *BLANK
     C           K#GAD1    CHAINGADPL11              93
     C  N93                MOVELB5KMEI    @CNAM
     C                     OTHER
     C           K#GAD2    CHAINGADPL11              93
     C  N93                MOVELB5KMEI    @CNAM
     C                     ENDSL
     C*
     C                     MOVELF2TOKU    @TOKU
     C                     MOVELF2NONY    @NONY
     C                     MOVELF2NKOJ    @NKOJ
     C                     MOVELF2NUKE    @NUKE
     C                     MOVELF2MHN1    @MHN1
     C                     MOVELF2MHN2    @MHN2
     C                     MOVELF2MHN3    @MHN3
     C**                   MOVELF2MHN4    @MHN4
     C                     MOVELF2SHN1    @SHN1
     C                     MOVELF2SHN2    @SHN2
     C                     MOVELF2SHN3    @SHN3
     C                     Z-ADDF2UPRC    @UPRC
     C                     MOVELF2SLSP    @SLSP
JW1  C                     Z-ADDF2STYM    @EFC
 |   C                     Z-ADDF2ENYM    @EXP
 |   C                     Z-ADDF2CLAS    @CLAS
 |   C                     MOVELF2RMK1    @RMK1
 |   C                     MOVELF2RMK2    @RMK2
 |   C                     Z-ADDF2KYMD    @KYMD
 |   C                     Z-ADDF2KTIM    @KTIM
 |   C                     MOVELF2KOME    @KOME
 |    * COLOR
 |   C           @EXP      IFLT @TODAY
 |   C                     MOVE *ON       *IN41
 |   C                     ELSE
 |   C                     MOVE *OFF      *IN41
JW1  C                     ENDIF
      *
     C                     ADD  1         RRN
     C                     WRITESFREC1
E1   C                     ENDDO
     C*-------------------------
     C           RRN       IFEQ 0
     C                     MOVE '#END    '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     Z-ADD1         DSPRRN
     C                     ENDIF
     C                     ENDSR
     C*===============================================================
      * DSPLAY SCREEN 1
     C*===============================================================
     C           #DSP1     BEGSR
     C                     SETON                     71
     C                     WRITEDSP99
     C                     EXFMTSFCTL1
     C                     SETOF                     71
     C                     MOVEA'0'       *IN,99
     C                     Z-ADD$$RRN     DSPRRN
      *----*
      * F3 *
      *----*
     C   KC                MOVE '#END    '@STEP
     C   KC                GOTO XDSP1
JW2   *----*
 |    * F7 *
 |    *----*
 |   C           *INKG     IFEQ *ON
 |   C                     EXSR #OUT
 |   C                     MOVE '#END    '@STEP
JW2  C                     ENDIF
      *
     C           XDSP1     ENDSR
     C*===============================================================
JW2   * DOWNLOAD TO CSV
 |   C*===============================================================
 |   C           #OUT      BEGSR
 V    * CLEAR WORK FILE
     C                     CALL 'FBCC351'
      *
     C                     OPEN FBCWP35
      * OUT HEADER
     C                     EXSR #HDR1
      * OUT DETAIL
     C                     EXSR #DTL1
      *
     C                     CLOSEFBCWP35
 |    * DOWNLOAD CSV
 |   C                     CALL 'FBCC352'
 V    *
JW2  C                     ENDSR
     C*===============================================================
      * WRITE HEADER
     C*===============================================================
     C           #HDR1     BEGSR
      *
     C                     CLEARFBCWP351
     C                     MOVEL'CUST#'   W2TOKU
     C                     MOVEL'DELIV#'  W2NONY
     C                     MOVEL'FACTORY' W2NKOJ
     C                     MOVEL'DOCK'    W2NUKE
     C                     MOVEL'NAME'    W2NAME
     C                     MOVEL'USR PART'W2MHIN
     C                     MOVEL'IAF PART'W2SHIN
     C                     MOVEL'PRICE'   W2UPRC
     C                     MOVEL'SALES'   W2SLSP
     C                     MOVEL'EFT DATE'W2STYM
     C                     MOVEL'EXP DATE'W2ENYM
     C                     MOVEL'CLASS'   W2CLAS
     C                     MOVEL'REMARK 1'W2RMK1
     C                     MOVEL'REMARK 2'W2RMK2
     C                     MOVEL'UPD DATE'W2KYMD
     C                     MOVEL'UPD TIME'W2KTIM
     C                     MOVEL'UPD USER'W2KOME
      *
     C                     WRITEFBCWP351
      *
     C                     ENDSR
     C*===============================================================
      * WRITE DEATIL
     C*===============================================================
     C           #DTL1     BEGSR
      *
     C                     Z-ADD0         RRN
      *
     C                     DO   *HIVAL
     C                     ADD  1         RRN
     C           RRN       CHAINSFREC1               98
     C   98                LEAVE
      *
     C                     CLEARFBCWP351
     C**         @A        CAT  @TOKU     W2TOKU
     C                     MOVEL@TOKU     $IN       P
     C                     MOVEL'04'      $LONG
     C                     CALL 'UTLR32A'
     C                     PARM           $IN    10
     C                     PARM           $LONG   2
     C                     PARM           $OUT   11
     C           @TOKU     IFEQ 0
     C                     MOVE *BLANK    W2TOKU
     C                     ELSE
     C                     MOVEL$OUT      W2TOKU
     C                     ENDIF
      *
     C**         @A        CAT  @NONY     W2NONY
     C                     MOVEL@NONY     $IN       P
     C                     MOVEL'04'      $LONG
     C                     CALL 'UTLR32A'
     C                     PARM           $IN
     C                     PARM           $LONG
     C                     PARM           $OUT
     C           @NONY     IFEQ 0
     C                     MOVE *BLANK    W2NONY
     C                     ELSE
     C                     MOVEL$OUT      W2NONY
     C                     ENDIF
      *
     C**         @A        CAT  @NKOJ     W2NKOJ
     C                     MOVEL@NKOJ     $IN       P
     C                     MOVEL'01'      $LONG
     C                     CALL 'UTLR32A'
     C                     PARM           $IN
     C                     PARM           $LONG
     C                     PARM           $OUT
     C                     MOVEL$OUT      W2NKOJ
      *
     C**         @A        CAT  @NUKE     W2NUKE
     C                     MOVEL@NUKE     $IN       P
     C                     MOVEL'02'      $LONG
     C                     CALL 'UTLR32A'
     C                     PARM           $IN
     C                     PARM           $LONG
     C                     PARM           $OUT
     C                     MOVEL$OUT      W2NUKE
      *
     C                     MOVEL@CNAM     W2NAME
      * USER PART
     C           @MHN2     IFEQ *BLANK
     C                     MOVE ' '       PH1
     C                     ELSE
     C                     MOVE '-'       PH1
     C                     ENDIF
     C           @MHN3     IFEQ *BLANK
     C                     MOVE ' '       PH2
     C                     ELSE
     C                     MOVE '-'       PH2
     C                     ENDIF
     C           @MHN4     IFEQ *BLANK
     C                     MOVE ' '       PH3
     C                     ELSE
     C                     MOVE '-'       PH3
     C                     ENDIF
     C                     MOVEL@MHIN     W2MHIN
      * IF IAF PART = BLANK
     C           @SHN1     IFEQ *BLANK
     C           @SHN2     ANDEQ*BLANK
     C           @SHN3     ANDEQ*BLANK
     C           @NONY     IFEQ 0
     C                     MOVEL@TOKU     $NONY
     C                     ELSE
     C                     MOVEL@NONY     $NONY
     C                     ENDIF
      *
     C                     MOVEL@NKOJ     $NKOJ
     C                     MOVEL@NUKE     $NUKE
     C                     MOVEL@MHN1     $MHIN1
     C                     MOVEL@MHN2     $MHIN2
     C                     MOVEL@MHN3     $MHIN3
     C                     MOVE *BLANK    $MHIN4
     C                     CALL 'UTLR61'
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $MHIN  20
     C                     PARM           #TOKU   40
     C                     PARM           #MHIN  20
     C                     PARM           #SHIN  12
     C                     PARM           #RTN    1
     C                     MOVEL#SHN1     @SHN1
     C                     MOVEL#SHN2     @SHN2
     C                     MOVEL#SHN3     @SHN3
     C                     ENDIF
      *
     C           @SHN2     IFEQ *BLANK
     C                     MOVE ' '       PS1
     C                     ELSE
     C                     MOVE '-'       PS1
     C                     ENDIF
     C           @SHN3     IFEQ *BLANK
     C                     MOVE ' '       PS2
     C                     ELSE
     C                     MOVE '-'       PS2
     C                     ENDIF
      *
     C                     MOVEL@SHIN     W2SHIN
      * PRICE
     C                     Z-ADD@UPRC     $IN2
     C                     CALL 'UTLR64'
     C                     PARM           $IN2   156
     C                     PARM           $TRUE  17
     C                     PARM           $RTN    1
     C                     MOVEL$TRUE     W2UPRC
      *
     C                     MOVEL@SLSP     W2SLSP
     C                     MOVEL@EFC      W2STYM
     C                     MOVEL@EXP      W2ENYM
     C                     MOVEL@CLAS     W2CLAS
     C                     MOVEL@RMK1     W2RMK1
     C                     MOVEL@RMK2     W2RMK2
     C                     MOVEL@KYMD     W2KYMD
     C                     MOVEL@KTIM     W2KTIM
     C                     MOVEL@KOME     W2KOME
      *
     C                     WRITEFBCWP351
     C                     ENDDO
      *
     C                     ENDSR
