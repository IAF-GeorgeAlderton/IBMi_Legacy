     H            Y.
     F** UTLR21K **********************************************
     F*  PROGRAM: LINE UP LOCATION (FIRST-->LAST) - AAMPP11   *
     F*  WRITTEN: JW (SRA)  2023.08.11                        *
     F*-------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR21K'
IN   F*                    PARM           $SHIN  12
"    F*                    PARM           $DATE   8
OUT  F*                    PARM           $LOC1   6
"    F*                    PARM           $LOC2   6
"    F*                    PARM           $LOC3   6
"    F*                    PARM           $LOC4   6
"    F*                    PARM           $LOC5   6
"    F*                    PARM           $LOC6   6
"    F*                    PARM           $LOC7   6
"    F*                    PARM           $LOC8   6
"    F*                    PARM           $RTN    1
     F*  IN  $SHIN : 12A  IAF PART
     F*      $DATE :  8A  TARGET DATE  (YYYYMMDD) : BLANK = TODAY
     F*  OUT $LOC1 :  6A  CURRENT LOCATION 1  (FIRST)
     F*      $LOC2 :  6A  CURRENT LOCATION 2
     F*      $LOC3 :  6A  CURRENT LOCATION 3
     F*      $LOC4 :  6A  CURRENT LOCATION 4
     F*      $LOC5 :  6A  CURRENT LOCATION 5
     F*      $LOC6 :  6A  CURRENT LOCATION 6
     F*      $LOC7 :  6A  CURRENT LOCATION 7
     F*      $LOC8 :  6A  CURRENT LOCATION 8
     F*      $RTN  :  1A  RETURN CODE (BLANK/*)
     F******************************************************
     FAAMPL11 IF  E           K        DISK
     F******************************************************
     E                    LOC        15  6
     E                    LCX        15  6
     E                    CHG        15 10 0
     E                    $LC        15  6
      * LOCATION NEW
     I            DS
     I                                        1  90 LOC
     I                                        1   6 CKNB01
     I                                        7  12 CKNB02
     I                                       13  18 CKNB03
     I                                       19  24 CKNB04
     I                                       25  30 CKNB05
     I                                       31  36 CKNB06
     I                                       37  42 CKNB07
     I                                       43  48 CKNB08
     I                                       49  54 CKNB09
     I                                       55  60 CKNB10
     I                                       61  66 CKNB11
     I                                       67  72 CKNB12
     I                                       73  78 CKNB13
     I                                       79  84 CKNB14
     I                                       85  90 CKNB15
      * LOCATION OLD
     I            DS
     I                                        1  90 LCX
     I                                        1   6 CKQT01
     I                                        7  12 CKQT02
     I                                       13  18 CKQT03
     I                                       19  24 CKQT04
     I                                       25  30 CKQT05
     I                                       31  36 CKQT06
     I                                       37  42 CKQT07
     I                                       43  48 CKQT08
     I                                       49  54 CKQT09
     I                                       55  60 CKQT10
     I                                       61  66 CKQT11
     I                                       67  72 CKQT12
     I                                       73  78 CKQT13
     I                                       79  84 CKQT14
     I                                       85  90 CKQT15
      * CHG DATE
     I            DS
     I                                        1 1500CHG
     I                                        1  100CKHZ01
     I                                       11  200CKHZ02
     I                                       21  300CKHZ03
     I                                       31  400CKHZ04
     I                                       41  500CKHZ05
     I                                       51  600CKHZ06
     I                                       61  700CKHZ07
     I                                       71  800CKHZ08
     I                                       81  900CKHZ09
     I                                       91 1000CKHZ10
     I                                      101 1100CKHZ11
     I                                      111 1200CKHZ12
     I                                      121 1300CKHZ13
     I                                      131 1400CKHZ14
     I                                      141 1500CKHZ15
      * CHG DATE
     I            DS
     I                                        1  100@CHG
     I                                        1   80@CHG8
      * LOCATION (OUT)
     I            DS
     I                                        1  90 $LC
     I                                        1   6 $LC1
     I                                        7  12 $LC2
     I                                       13  18 $LC3
     I                                       19  24 $LC4
     I                                       25  30 $LC5
     I                                       31  36 $LC6
     I                                       37  42 $LC7
     I                                       43  48 $LC8
     I                                       49  54 $LC9
     I                                       55  60 $LC10
     I                                       61  66 $LC11
     I                                       67  72 $LC12
     I                                       73  78 $LC13
     I                                       79  84 $LC14
     I                                       85  90 $LC15
     I            DS
     I                                        1  12 @SHIN
     I                                        1   5 @SHIN1
     I                                        6  10 @SHIN2
     I                                       11  12 @SHIN3
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        1   20WSHH
     I                                        3   40WSMN
     I                                        5   60WSSS
     I                                        7  100WSYY
     I                                       11  120WSMM
     I                                       13  140WSDD
     I                                        1   40WSTM4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
     C                     EXSR #INIT
      *
     C                     EXSR #AAM
      *
     C           *IN85     IFEQ *ON
     C                     MOVE '*'       $RTN
     C                     ELSE
     C                     MOVEL$LC1      $LOC1
     C                     MOVEL$LC2      $LOC2
     C                     MOVEL$LC3      $LOC3
     C                     MOVEL$LC4      $LOC4
     C                     MOVEL$LC5      $LOC5
     C                     MOVEL$LC6      $LOC6
     C                     MOVEL$LC7      $LOC7
     C                     MOVEL$LC8      $LOC8
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *=============================================================
      * GET DATA FROM AAMPP11
      *=============================================================
     C           #AAM      BEGSR
      *
     C           KEY1      CHAINAAMPL11              98
     C           *IN98     IFEQ *OFF
      * LAST VALUE
     C           1         DO   15        IX      20
     C                     Z-ADDCHG,IX    @CHG
      *
     C           @CHG8     IFLE @DATE
     C           LOC,IX    IFNE *BLANK
     C                     MOVELLOC,IX    $LC,IX
     C                     MOVE *OFF      *IN85
     C                     ENDIF
     C                     ENDIF
      *
     C           @CHG8     IFGT @DATE
     C           LCX,IX    IFNE *BLANK
     C                     MOVELLCX,IX    $LC,IX
     C                     MOVE *OFF      *IN85
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDSR
      *=============================================================
      * INITIAL PROCESS
      *=============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SHIN  12
     C                     PARM           $DATE   8
     C                     PARM           $LOC1   6
     C                     PARM           $LOC2   6
     C                     PARM           $LOC3   6
     C                     PARM           $LOC4   6
     C                     PARM           $LOC5   6
     C                     PARM           $LOC6   6
     C                     PARM           $LOC7   6
     C                     PARM           $LOC8   6
     C                     PARM           $RTN    1
      *
     C           KEY1      KLIST
     C                     KFLD           @SHIN1
     C                     KFLD           @SHIN2
     C                     KFLD           @SHIN3
      * RETRIEVE SYSTEM TIME
     C                     TIME           WSDT
      *
     C           $DATE     IFEQ *BLANK
     C           $DATE     OREQ '00000000'
     C                     MOVELTODAY     @DATE   80
     C                     ELSE
     C                     MOVEL$DATE     $DATE
     C                     ENDIF
      *
     C                     CLEAR$LOC1
     C                     CLEAR$LOC2
     C                     CLEAR$LOC3
     C                     CLEAR$LOC4
     C                     CLEAR$LOC5
     C                     CLEAR$LOC6
     C                     CLEAR$LOC7
     C                     CLEAR$LOC8
     C                     CLEAR$RTN
      *
     C                     MOVEL$SHIN     @SHIN
     C                     MOVE *ON       *IN85
      *
     C                     ENDSR
