     H            Y.
     F** AM#R001 ********************************************
     F* SHIPPING PULL SCAN MENU
     F*    ITS.             2020.12.22                      *
     F*******************************************************
     FAM#PW001CF  E                    WORKSTN
     E                    ER      1  11 65
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  14 SDATE
     I                                        1   6 STIME
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           WORKER  6
     C                     PARM           WUSRNM 20
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     MOVELWORKER    USRCD
     C                     Z-ADD0         D1SEL
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTDSP01
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     3199
      *
     C                     TIME           WTIME
     C           *IN03     IFEQ *ON
     C                     MOVEL'99'      DSPSW   2
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     MOVE WORKER    POPR    6        SET WORKER ID
      *
     C                     SELEC
      * SHIPPING PULL SCAN
     C           D1SEL     WHEQ 1
     C                     MOVEL'ALDR2Z'  WPGM   10
     C                     EXSR #SBLOG
     C                     CALL 'ALDR2Z'
     C                     PARM           WORKER
     C                     PARM           WUSRNM
      * FINAL STORAGE LOC SCAN
     C           D1SEL     WHEQ 2
     C                     MOVEL'ALDR98'  WPGM
     C                     EXSR #SBLOG
     C                     CALL 'ALDR98'
     C                     PARM           WORKER
     C                     PARM           WUSRNM
      *
      * CREFORM PULL SCAN
     C           D1SEL     WHEQ 3
     C                     MOVEL'ALJR10'  WPGM
     C                     EXSR #SBLOG
     C                     CALL 'ALJR10'
     C                     PARM           WORKER
     C                     PARM           W#USER
      *
      *
     C* * *      D1SEL     WHEQ 4
     C* * *                MOVEL'AJHCS5'  WPGM
     C* * *                EXSR #SBLOG
     C* * *                CALL 'AJHCS5'
      *
     C                     OTHER
      *
     C                     SETON                     3199
     C                     MOVELER,1      MSG
     C                     EXSR #SB999
     C                     GOTO ESB210
     C                     ENDSL
      *
     C                     Z-ADD0         D1SEL
      *
      * DELETE SIGN-ON INFO
     C                     CALL 'ALDRZ7'
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
      *
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * ERR                                                *
      *----------------------------------------------------*
     CSR         #SB999    BEGSR
      *
     C                     MOVELMSG       P1ERR
     C                     CALL 'AM#R08'
     C                     PARM           P1ERR  25
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
      *
     CSR         ESB999    ENDSR
      *----------------------------------------------------*
      *  CREATE SIGN-ON INFO
      *----------------------------------------------------*
     CSR         #SBLOG    BEGSR
      *
     C                     MOVELWPGM      P2PGM  10
     C                     MOVE WORKER    P2WKR   6
     C                     MOVELWUSRNM    P2WKN  20
     C                     CALL 'ALDRZ6'
     C                     PARM           P2PGM
     C                     PARM           P2WKR
     C                     PARM           P2WKN
      *
     CSR                   ENDSR
      *----------------------------------------------------*
**
INPUT NO. ERR




