     C                     TIME           WTIME
     C                     Z-ADDWTIHZ     W@DATE
      * WORK DAY
     C           KEYAG1    KLIST
     C                     KFLD           W@DAYY
     C                     KFLD           W@DAMM
     C                     Z-ADD0         W@KAD   31
     C           KEYAG1    SETLLAGDPL121
     C           KEYAG1    READEAGDPL121                 87
     C           *IN87     DOWEQ'0'
     C           F8HIRU    IFEQ *BLANK
     C                     ADD  0.5       W@KAD
     C                     ENDIF
     C           F8YORU    IFEQ *BLANK
     C                     ADD  0.5       W@KAD
     C                     ENDIF
     C           KEYAG1    READEAGDPL121                 87
     C                     ENDDO
      *
     C           KEYAG1    SETLLABMPPL11
     C           KEYAG1    READEABMPPL11                 87
     C           *IN87     DOWEQ'0'
