      *FCEPP11 UPDATE
      *----------------------------------------------*
     C           #FC11     BEGSR
      *
     C                     SETOF                     60
     C           KEY1      CHAINFCEPL111             60
      *
     C           *IN60     IFEQ '0'
     C           FCSKJY    IFEQ 'D'
     C           FCSKHZ    ANDLE*DATE
     C                     SETON                     60
     C                     ENDIF
     C           *IN60     IFEQ '1'
     C                     Z-ADD0         FKH
     C                     MOVE *BLANK    FKM
     C                     Z-ADD0         FGK
     C                     Z-ADD0         FGH
     C                     Z-ADD0         FCD
     C                     ELSE
     C                     Z-ADD1         N       20
     C                     Z-ADD10        O       20
     C                     Z-ADD11        P       20
     C           1         DO   9         N
     C                     SUB  1         O
     C                     SUB  1         P
     C                     Z-ADDFKH,O     FKH,P
     C                     MOVE FKM,O     FKM,P
     C                     Z-ADDFGK,O     FGK,P
     C                     Z-ADDFGH,O     FGH,P
     C                     Z-ADDFCD,O     FCD,P
     C                     ENDDO
     C                     ENDIF
