     C                     ENDIF
      *
     C                     READ ABMWP211                 87
     C           *IN87     DOWEQ'0'
     C           W2OMIT    IFEQ '0'
     C           W2PAS     ANDEQ'0'
     C                     EXSR #SB001
     C                     ENDIF
     C                     READ ABMWP211                 87
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------*
      * FCEPP01                                          *
      *--------------------------------------------------*
     CSR         #SB001    BEGSR
      *
     C           KEY1      KLIST
     C                     KFLD           W2SHN1
     C                     KFLD           W2SHN2
     C                     KFLD           W2SHN3
      *Ｎ月内示と実績の多い方
     C**         W2FSDN    MULT 20        W2FS20 100
     C**                   Z-ADD0         W2USD  100
     C**                   Z-ADDW2USD1    W2USD
     C**                   ADD  W2USD2    W2USD
     C**                   ADD  W2USD3    W2USD
     C**         W2USD     DIV  3         W2US20 100
     C**         W2US20    MULT 20        W2US20
     C**                   Z-ADD0         W@NSRY 100
     C**         W2FS20    IFGE W2US20
     C**                   Z-ADDW2FS20    W@NSRY
     C**                   ELSE
     C**                   Z-ADDW2US20    W@NSRY
     C**                   ENDIF
      *
     C***                  Z-ADD0         WXNSRY 100
     C***                  Z-ADD0         WYNSRY 100
     C***        W2NSRY    DIV  W@KAD     WXNSRY
     C***                  ADD  0.09      WXNSRY
     C***        WXNSRY    MULT 20        WYNSRY
     C                     Z-ADDW2NSRY    W@NSRY 100
      *
     C           KEY1      CHAINFCEPL01              44
     C           *IN44     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
