     H            Y.
     F*** TSTR01 *********************************
     F* MAMIYA JOB                               *
     F* Y.SAMEJIMA                  2020.09.24   *
     F********************************************
     FTSTPP02 UF  E                    DISK
     FNZUPL01 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
      *
     I*
     I            DS
     I                                        1  12 T1HINB
     I                                        1   5 HIN1
     I                                        6  10 HIN2
     I                                       11  12 HIN3
     I*
      * SYSTEM TIME(6) + DATE(8)
     I            DS
     I                                        1  140WSDT
     I                                        1   60WSSTM6
     I                                        1   40WSSTM4
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  140WSSDAT
     I                                        7  120WSSYM
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I*
     I*
     C                     TIME           WSDT
     C*
     C           1         SETLLTSTPP021
     C                     DO   *HIVAL
     C                     READ TSTPP021                 99
     C   99                LEAVE
     C                     EXSR #SB100
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*-------------------------------------------------------------------------
     C           #SB100    BEGSR
     C*
     C                     MOVEL*BLANK    #ZETI   4
     C*
     C           KEY1      KLIST
     C                     KFLD           HIN1
     C                     KFLD           HIN2
     C                     KFLD           HIN3
     C*
     C                     SETOF                     98
     C           KEY1      CHAINFCEPL01              98
     C           *IN98     IFEQ '0'
     C                     MOVELA2ZETI    #ZETI
     C                     ENDIF
     C*
     C           KEY2      KLIST
     C                     KFLD           #ZETI
     C                     KFLD           T1TEHA
     C                     KFLD           T1PAGE
     C*
     C                     SETOF                     97
     C           KEY2      SETGTNZUPL011
     C                     DO   *HIVAL
     C           KEY2      REDPENZUPL011                 97
     C   97                LEAVE
     C           N2HAHZ    IFLE T1SHIP
     C           N2SKJY    IFNE ' '
     C                     Z-ADDN2KOHZ    T1REI1
     C                     Z-ADDN2KOTI    T1RET1
     C                     UPDATTSTPP021
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADD0         SAKA    10
     C                     ENDDO
     C*
     C           ESB100    ENDSR
