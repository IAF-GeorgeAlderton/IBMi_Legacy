      ********************* MYCR00 **
     FMYCPW00 CF  E                    WORKSTN
      *
     E                    TM1     1   5  2 0 TN1     6   ﾎﾟﾜhﾞ[wNO.
     E                    ER      1   2 70               d[ｰxｮﾈｰﾆﾞ
      *
     C                     CLEARMYCPW001
      *
      **********
      * 画面 *
      **********
     C           STP1      TAG
     C                     EXFMTMYCPW001
     C                     SETOF                     5199
      *
      *======
      *  F1
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
      *--------------*
      * メニュー№ *
      *--------------*
     C           IMENO     IFEQ 0
     C                     SETON                     5199
     C                     MOVELER,1      MSG
     C                     GOTO STP1
     C                     END
      *
     C                     SETOF                     01
     C                     Z-ADD1         A       20
     C                     MOVE *BLANK    WPGMN   6
     C           IMENO     LOKUPTM1,A                    01
     C           *IN01     IFEQ '0'
     C                     SETON                     5199
     C                     MOVELER,2      MSG
     C                     GOTO STP1
     C                     ELSE
     C                     MOVELTN1,A     WPGMN
     C                     END
      *
      *------------------*
      * プログラム実行 *
      *------------------*
     C                     CALL WPGMN
      *
     C                     Z-ADD0         IMENO
     C                     GOTO STP1
