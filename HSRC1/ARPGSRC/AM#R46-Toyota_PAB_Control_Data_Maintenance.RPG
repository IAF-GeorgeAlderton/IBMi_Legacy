     H            Y/
     F***************************************************
     F*  TOTYOTA PRODUCTION ANALYSIS BOARD              *
     F*  CONTROL DATA MAINTENANCE                       *
     F*                                                 *
     F*  LEC   2020.03.24                               *
     F*  LEC   2020.0625  ADD # SELECTORS TO CONTROL FL *
     F***************************************************
     FAM#PW46 CF  E                    WORKSTN
     FAM#PP46 UF  E           K        DISK                      A
      *------------------------------------------------------------
     E                    ERR     1  10 78
      *------------------------------------------------------------
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@NOYY
     I                                        5   60K@NOMM
     I                                        7   80K@NODD
     I            DS
     I                                        1  140W@DTTM
     I                                        1   60W@TIME
     I                                        7  140W@DATE
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *
     IHDRS        DS
     I I            '** PALLET UNLOAD  **'    1  20 PRDSC
     I I            '**    SHIPPING    **'   21  40 SHDSC
      *
     C           *ENTRY    PLIST
     C                     PARM           PSECT   3
      *
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C           W@ID      CASEQ'02'      #DSP02
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#46      KLIST
     C                     KFLD           PSECT
     C                     KFLD           D@SHFT
      *
     C                     MOVEL'01'      W@ID    2
      *
     C                     SELEC
     C           PSECT     WHEQ 'PR'
     C                     MOVELPRDSC     D@SECT
     C                     MOVE *ON       *IN22
     C           PSECT     WHEQ 'SHP'
     C                     MOVELSHDSC     D@SECT
     C                     OTHER
     C                     MOVEL'99'      W@ID
     C                     ENDSL
      *
     C                     CALL 'UTLR31'
     C                     PARM           #USER
     C                     PARM           $NAME  15
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     MOVE *OFF      *IN61
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANKS   D@MSG
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET
     C                     MOVEL'02'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK SCREEN 1
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     DO
      *
     C           D@SHFT    IFNE 1
     C           D@SHFT    ANDNE2
     C           D@SHFT    ANDNE3
     C                     MOVELERR,1     D@MSG
     C                     MOVE *ON       *IN61
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C           K#46      CHAINAM#PP46             N51
     C           *IN51     IFEQ *ON
     C                     MOVELPSECT     T1SECT
     C                     Z-ADDD@SHFT    T1SHFT
     C                     WRITEAM#PP461
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR 2ND SCREEN
      *------------------------------------------------------
     C           #SET      BEGSR
      *
     C                     Z-ADDT1QTY1    D@QTY1
     C                     Z-ADDT1QTY2    D@QTY2
     C                     Z-ADDT1QTY3    D@QTY3
     C                     Z-ADDT1QTY4    D@QTY4
     C           T1Q1ST    DIV  100       D@ST01
     C           T1Q2ST    DIV  100       D@ST02
     C           T1Q3ST    DIV  100       D@ST03
     C           T1Q4ST    DIV  100       D@ST04
     C           T1Q1ET    DIV  100       D@ET01
     C           T1Q2ET    DIV  100       D@ET02
     C           T1Q3ET    DIV  100       D@ET03
     C           T1Q4ET    DIV  100       D@ET04
     C                     Z-ADDT1SELT    D@SEL#
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #DSP02    BEGSR
      *
     C                     EXFMTDSP02
     C                     MOVEA'0000'    *IN,71
     C                     MOVEA'0000'    *IN,81
     C                     MOVEA'00000'   *IN,91
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANKS   D@MSG
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
     C                     OTHER
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
     C                     MOVEL'01'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK SCREEN 2
      *------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     DO
      *
     C           D@QTY1    IFEQ *ZERO
     C                     MOVELERR,3     D@MSG
     C                     MOVE *ON       *IN71
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C           D@QTY2    IFEQ *ZERO
     C                     MOVELERR,3     D@MSG
     C                     MOVE *ON       *IN72
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C           D@QTY3    IFEQ *ZERO
     C                     MOVELERR,3     D@MSG
     C                     MOVE *ON       *IN73
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C           D@QTY4    IFEQ *ZERO
     C                     MOVELERR,3     D@MSG
     C                     MOVE *ON       *IN74
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C           D@SHFT    IFNE 3
     C           D@ST01    IFGT D@ET01
     C                     MOVELERR,4     D@MSG
     C                     MOVE *ON       *IN81
     C                     MOVE *ON       *IN91
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
     C                     ELSE
     C           D@ET01    IFGT D@ST01
     C                     MOVELERR,4     D@MSG
     C                     MOVE *ON       *IN81
     C                     MOVE *ON       *IN91
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C           D@ST02    IFGT D@ET02
     C                     MOVELERR,4     D@MSG
     C                     MOVE *ON       *IN82
     C                     MOVE *ON       *IN92
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C           D@ST03    IFGT D@ET03
     C                     MOVELERR,4     D@MSG
     C                     MOVE *ON       *IN83
     C                     MOVE *ON       *IN93
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C           D@ST04    IFGT D@ET04
     C                     MOVELERR,4     D@MSG
     C                     MOVE *ON       *IN84
     C                     MOVE *ON       *IN94
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C           D@ET01    IFGE D@ST02
     C                     MOVELERR,5     D@MSG
     C                     MOVE *ON       *IN82
     C                     MOVE *ON       *IN91
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C           D@ET02    IFGE D@ST03
     C                     MOVELERR,5     D@MSG
     C                     MOVE *ON       *IN83
     C                     MOVE *ON       *IN92
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C           D@ET03    IFGE D@ST04
     C                     MOVELERR,5     D@MSG
     C                     MOVE *ON       *IN84
     C                     MOVE *ON       *IN93
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C           D@SEL#    IFEQ *ZERO
     C           *IN22     ANDEQ*OFF
     C                     MOVELERR,6     D@MSG
     C                     MOVE *ON       *IN95
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
      *
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   UPDATE FILE WITH NEW VALUES
      *------------------------------------------------------
     C           #UPD      BEGSR
      *
     C           K#46      CHAINAM#PP46              51
     C           *IN51     IFEQ *OFF
      *
     C                     TIME           W@DTTM
     C                     Z-ADDW@DATE    T1UPHZ
     C                     Z-ADDW@TIME    T1UPTI
     C                     MOVEL#USER     T1WKCD
     C                     MOVEL$NAME     T1WKNM
     C                     Z-ADDD@QTY1    T1QTY1
     C                     Z-ADDD@QTY2    T1QTY2
     C                     Z-ADDD@QTY3    T1QTY3
     C                     Z-ADDD@QTY4    T1QTY4
     C           D@ST01    MULT 100       T1Q1ST
     C           D@ST02    MULT 100       T1Q2ST
     C           D@ST03    MULT 100       T1Q3ST
     C           D@ST04    MULT 100       T1Q4ST
     C           D@ET01    MULT 100       T1Q1ET
     C           D@ET02    MULT 100       T1Q2ET
     C           D@ET03    MULT 100       T1Q3ET
     C           D@ET04    MULT 100       T1Q4ET
     C                     ADD  59        T1Q1ET
     C                     ADD  59        T1Q2ET
     C                     ADD  59        T1Q3ET
     C                     ADD  59        T1Q4ET
     C                     Z-ADDD@SEL#    T1SELT
      *
     C                     UPDATAM#PP461
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
**  ERR
ENTER SHIFT 1, 2, OR 3
SHIFT INFORMATION NOT FOUND
QUARTER SHIFT QUANTITY CANNOT BE ZERO
INVALID TIME RANGE
INVALID TIME OVERLAP
# OF SELECTORS CANNOT BE ZERO
7
8
9
10
