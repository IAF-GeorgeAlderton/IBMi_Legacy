      *** AAHRS9 *****************************************************
      *条件コードで条件グループ所属確認
      * J:JC/KRO
      * S:SORT
      * #:SORT #
      *     T.SAKASHITA                  2014.08.05
      ****************************************************************
      * PARM('J' 'LC' 'C' ' ')
      ****************************************************************
     H            Y/                                    1
     FAAHPPS1 IF  E           K        DISK
     C           *ENTRY    PLIST
     C                     PARM           P@KUBN  1
     C                     PARM           P@JOKN  2
     C                     PARM           P@KANB  1
     C                     PARM           P@FLG   1
      *
     C                     MOVE *BLANK    P@FLG
      *
     C                     MOVE P@KUBN    K@KUBN  1
     C                     MOVE P@JOKN    K@JOKN  2
     C                     MOVE P@KANB    K@KANB  1
     C                     EXSR #MAST
     C  N88                EXSR #END
      *
     C                     MOVE *BLANK    K@KANB  1
     C                     EXSR #MAST
     C                     EXSR #END
      *-----------------------------------------------------
     C           #MAST     BEGSR
      *
     C           KEY       KLIST
     C                     KFLD           K@KUBN
     C                     KFLD           K@JOKN
     C                     KFLD           K@KANB
      *
     C           KEY       CHAINAAHPPS1              88
     C           *IN88     IFEQ '0'
     C           H@SKJY    IFEQ 'D'
     C                     SETON                     88
     C                     END
     C                     END
     C           *IN88     IFEQ '0'
     C                     MOVE '*'       P@FLG
     C                     END
      *
     C           EMAST     ENDSR
      *-----------------------------------------------------
     C           #END      BEGSR
     C                     SETON                     LR
     C                     RETRN
     C           EEND      ENDSR
