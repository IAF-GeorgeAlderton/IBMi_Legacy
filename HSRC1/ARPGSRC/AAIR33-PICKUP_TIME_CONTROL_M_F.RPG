     C           #KCODE    READEFGBPL011                 20
     C           *IN20     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE*DATE
     C                     ELSE
