     C                     ELSE
     C                     MOVELCMT2      D1CMT
     C                     ENDIF
      *
     C                     MOVEABI        D1BI
     C                     MOVEATI        D1TI
     C                     MOVEAAJ        D1AJ
      *
     CSR         ESB110    ENDSR
