     C                     ENDIF
      *
     C                     MOVEL*BLANK    D1CMT
     C                     Z-ADD1         X       20
     C           WKRRN     SETLLAAIWP311
     C                     READ AAIWP311                 89
     C           *IN89     DOWEQ'0'
     C           X         ANDLE12
     C                     MOVE W1BIN     BI,X
