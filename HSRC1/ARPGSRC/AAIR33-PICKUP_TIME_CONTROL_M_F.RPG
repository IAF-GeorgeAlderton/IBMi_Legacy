      *----------------------------------------------------*
      * 1ST.                                             *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTAAIPW331
     C                     SETOF                     313233
     C                     SETOF                     111213
     C                     SETOF                     141516
     C                     SETOF                     171819
     C                     SETOF                     202122
     C                     SETOF                     232425
     C                     SETOF                     269930
     C                     SETOF                     232425
     C                     SETOF                     262728
     C                     SETOF                     293031
     C                     SETOF                     323334
     C                     MOVEL*BLANK    D1ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVE '03'      PCMD
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     EXSR #SB400
     C           *IN99     IFEQ '1'
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     EXSR #SB410
     C           *IN99     IFEQ '1'
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     Z-ADD1         X       20
     C           X         DOWLE12
     C                     EXSR #SB402
     C                     ADD  1         X
     C                     ENDDO
      *
     C           *IN91     IFEQ '1'
     C           *IN89     IFEQ '0'
     C                     ADD  1         WKPAG
     C                     EXSR #SB110
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN92     IFEQ '1'
     C           WKPAG     IFNE 0
     C                     SUB  1         WKPAG
     C                     EXSR #SB110
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN99     IFEQ '1'
