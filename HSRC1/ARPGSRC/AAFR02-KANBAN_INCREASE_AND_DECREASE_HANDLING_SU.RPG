     C           ADTKO     IFNE 'E'
     C           ASTI1     IFEQ 02
     C           ASTI1     OREQ 04
      *
     C*------------------------*
     C*  ..日当り必要箱数..  *
     C*------------------------*
     C           AKTSU     DIV  ASYOS     AA      91
     C           AA        ADD  0.9       XHAKO   90       ﾍajﾒﾍlﾑcﾌﾃﾇc
     C           AA        IFEQ 0
     C                     Z-ADD1         XHAKO
     C                     END
      *
     C*--------------------------*
     C*  ..分割かんばん枚数..  *
     C*--------------------------*
     C           ABARA     IFNE 0
     C           XHAKO     DIV  ABARA     BB      92
     C           BB        ADD  0.09      CC      91
     C           CC        ADD  0.9       DD      90
     C           DD        MULT ABARA     XMAIS   90       ﾎﾞ]flf]ﾌﾞ]ubﾇc
     C                     ELSE
      *
     C           XHAKO     DIV  1         BB
     C           BB        ADD  0.09      CC
     C           CC        ADD  0.9       DD
     C           DD        MULT 1         XMAIS
     C                     END
      *
     C*----------------------------------*
     C*  ..出荷手配日　＆　分割数量..  *
     C*----------------------------------*
     C                     Z-ADDAKMAX     XKAIS   50
     C                     MOVE *BLANK    ER1     1
     C           KKEY      SETLLAGDPL111
      *
     C                     DO   *HIVAL
     C                     SETOF                     30
     C                     READ AGDPL111                 30
     C           *IN30     IFEQ '1'
     C                     GOTO END
     C                     END
      *
     C           ER1       IFEQ *BLANK
     C                     MOVE '*'       ER1
     C           XMAIS     MULT ASYOS     XSRYO
     C                     Z-ADDF8KAHZ    XKAHZ
      *
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C                     END
      *
     C                     SUB  XMAIS     XKAIS
      *
     C           XKAIS     IFGE XMAIS
     C           XMAIS     MULT ASYOS     XSRYO   70       ﾉcpｬcﾇcﾒｭc
     C                     Z-ADDF8KAHZ    XKAHZ   80       ﾆｬｮfmﾌbﾍﾞ
      *
     C                     EXSR SUBRTN
     C                     ELSE
      *
     C           XKAIS     MULT ASYOS     XSRYO
      *
     C           XSRYO     IFNE 0
     C                     Z-ADDF8KAHZ    XKAHZ
      *
     C                     EXSR SUBRTN
     C                     END
      *
     C                     GOTO END
     C                     END
      *
     C           STP1      TAG
     C                     END
     C                     GOTO END
      *
     C                     END
     C                     END
