     C           AMAIS     ANDNEAKMAX
     C           AKMAX     SUB  AMAIS     ZMAIS   50       ﾞciﾞ]ubﾇc
     C           ZMAIS     MULT ASYOS     ZSRYO   90       ﾞciﾞ]ﾇcﾒｭc
     C                     ELSE
      *
     C           AKALL     IFNE 0
     C           AKMIN     ANDNE0
     C           AKMIN     ANDNEAKMAX
     C           AKMAX     SUB  AKMIN     ZMAIS
     C           ZMAIS     MULT ASYOS     ZSRYO
     C                     ELSE
      *
     C                     GOTO END
     C                     END
     C                     END
     C                     END
