     C                     READ AGDPL111                 30
     C           *IN30     IFEQ '1'
     C                     GOTO END
     C                     END
      *
     C                     Z-ADDZSRYO     XSRYO
     C                     Z-ADDF8KAHZ    XKAHZ
      *
     C                     EXSR SUBRTN
     C                     GOTO END
     C                     ELSE
      *
     C                     Z-ADD1         M       20
     C           1         DO   WNISU     M
     C                     SETOF                     30
     C                     READ AGDPL111                 30
     C           *IN30     IFEQ '1'
     C                     GOTO END
     C                     END
      *
     C           M         IFEQ 1
     C           ZSRYO     DIV  WNISU     XSRYO
     C           XSRYO     MULT WNISU     WKTE    70
     C           ZSRYO     SUB  WKTE      XAMRI   70
     C                     END
      *
     C           M         IFEQ WNISU
     C                     ADD  XAMRI     XSRYO
     C                     END
     C                     Z-ADDF8KAHZ    XKAHZ
      *
     C                     EXSR SUBRTN
      *
     C                     END
     C                     END
     C           END       TAG
