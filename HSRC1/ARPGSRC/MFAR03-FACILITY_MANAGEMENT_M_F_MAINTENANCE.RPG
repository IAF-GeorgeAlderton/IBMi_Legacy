     C           *ENTRY    PLIST
     C                     PARM           US     10        USER NAME
     C                     MOVELUS        @US
     C                     Z-ADD0         M@SKHZ
     C*
     C                     MOVE *BLANK    KTYPE
     C                     MOVE *BLANK    NO1
     C                     MOVE *BLANK    NO2
     C******************************************************
     C*  EXFMT  <SCREEN 1>                                 *
     C******************************************************
     C           STP1      TAG
     C                     EXFMTMFAPW031
     C                     MOVEA'000'     *IN,01
     C                     MOVEA'0'       *IN,33
     C                     MOVEA'0'       *IN,99
     C*  CMD-1
     C           *INKA     IFEQ '1'
     C                     MOVEL'1'       *INLR
     C                     RETRN
     C                     END
     C*  CMD-12
     C           *INKL     IFEQ '1'
     C                     CALL 'MFARS1'
     C                     PARM           @MCNO   3
     C                     PARM           @KGUN   3
     C                     PARM           @COS1   2
     C                     PARM           @COS2   2
     C                     PARM           @COS3   2
     C                     PARM           NO1     4
     C                     PARM           NO2     4
     C                     GOTO STP1
     C                     END
     C******************************************************
     C*  <SCREEN 1 CHECK>                                  *
     C******************************************************
     C*
     C*  UPDATE DIVISION CHECK
     C*
     C                     MOVEA'0'       *IN,91
     C                     Z-ADD1         A       10
     C           KTYPE     LOKUPKOS,A                    91
     C           *IN91     IFEQ '0'
     C                     MOVEA'1'       *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,1     ERR
     C                     GOTO STP1
     C                     END
     C*
     C                     MOVE KON,A     WNAME            UPDATE NAME
     C*
     C*          ATM       IFNE 'A3'
     C*          KTYPE     IFEQ '0'
     C*                    MOVEA'1'       *IN,01
     C*                    MOVEA'1'       *IN,99
     C*                    MOVELMSG,15    ERR
     C*                    GOTO STP1
     C*                    END
     C*                    END
      *
     C*
     C*
     C*  NO CHECK
     C*
     C           KTYPE     IFNE '2'
     C           NO1       IFEQ *BLANK
     C           NO2       ANDEQ*BLANK
     C                     MOVEA'11'      *IN,02
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,2     ERR
     C                     GOTO STP1
     C                     END
     C                     ELSE
      * CONTINUOUS NUMBER PUTTING *
     C           NO1       IFEQ *BLANK
     C                     MOVEA'1'       *IN,02
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,2     ERR
     C                     GOTO STP1
     C                     END
     C           NO2       IFEQ '000'
     C                     MOVEA'1'       *IN,03
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,25    ERR
     C                     GOTO STP1
     C                     END
     C           NO2       IFEQ *BLANK
     C                     Z-ADD0         WNO2    40
     C                     MOVE *BLANK    SW      1
     C                     MOVEA'0'       *IN,90
     C           NO1       SETLLMFAPL211
     C                     DO   *HIVAL
     C           NO1       READEMFAPL211                 90
     C           *IN,90    IFEQ '0'
     C                     MOVE M@SYS2    WNO2
     C                     MOVE '*'       SW
     C                     END
     C  N90                END
     C           SW        IFEQ *BLANK
     C                     MOVE '001'     NO2
     C                     ELSE
     C                     ADD  1         WNO2
     C                     MOVE WNO2      NO2
     C                     END
     C                     END
     C                     END
     C*
     C                     MOVE *BLANK    NO
     C                     MOVELNO1       @NO1
     C                     MOVELNO2       @NO2
     C           @NO2      IFNE *BLANK
     C                     MOVEL'-'       @NOA
     C                     END
     C*
     C           KEY1      KLIST
     C                     KFLD           NO1
     C                     KFLD           NO2
     C*
     C           KEY2      KLIST
     C                     KFLD           M@KOJY
     C                     KFLD           M@KBN1
     C                     KFLD           M@KBN2
     C*
     C           KEY3      KLIST
     C                     KFLD           M@KOJY
     C                     KFLD           M@YOCD
     C*
     C           KEY4      KLIST
     C                     KFLD           M@SYS1
     C                     KFLD           M@SYS2
     C*
     C*  ADD
     C*
     C                     MOVEA'0'       *IN,90
     C           KEY1      CHAINMFAPL211             90
     C           KTYPE     IFEQ '2'
     C           *IN90     IFEQ '0'
     C           M@SKJY    IFEQ 'D'
     C           M@SKHZ    ANDLE*DATE
     C                     GOTO STP2
     C                     END
     C                     MOVEA'111'     *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,3     ERR
     C                     GOTO STP1
     C                     END
     C                     END
     C*
     C*  CHANGE
     C*
     C           KTYPE     IFEQ '1'
     C           *IN90     IFEQ '1'
     C                     MOVEA'111'     *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,4     ERR
     C                     GOTO STP1
     C                     END
     C           M@SKJY    IFEQ 'D'
     C           M@SKHZ    ANDLE*DATE
     C                     MOVEA'111'     *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,5     ERR
     C                     GOTO STP1
     C                     END
     C                     END
     C*
     C*  CANCEL
     C*
     C           KTYPE     IFEQ '0'
     C           *IN90     IFEQ '1'
     C                     MOVEA'111'     *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,6     ERR
     C                     GOTO STP1
     C                     END
     C           M@SKJY    IFEQ 'D'
     C           M@SKHZ    ANDLE*DATE
     C                     MOVEA'111'     *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,7     ERR
     C                     GOTO STP1
     C                     END
     C                     END
     C*
     C*  ADD
     C*
     C           STP2      TAG
     C           KTYPE     IFEQ '2'
     C                     MOVE *BLANK    M@SKJY
     C                     Z-ADD0         M@SKYY
     C                     Z-ADD0         M@SKMM
     C                     Z-ADD0         M@SKDD
     C                     Z-ADD0         M@KOYY
     C                     Z-ADD0         M@KOMM
     C                     Z-ADD0         M@KODD
     C                     Z-ADD0         M@KOHH
     C                     Z-ADD0         M@KOSS
     C                     MOVE *BLANK    M@KOME
     C                     Z-ADD0         M@KOJY
     C                     MOVE *BLANK    M@BUKA
     C                     MOVE *BLANK    M@KAKA
     C                     MOVE *BLANK    M@COS1
     C                     MOVE *BLANK    M@COS2
     C                     MOVE *BLANK    M@COS3
     C                     MOVE *BLANK    M@KGUN
     C                     MOVE *BLANK    M@KBN1
     C                     MOVE *BLANK    M@KBN2
     C                     MOVE *BLANK    M@KOTE
     C                     MOVE *BLANK    M@KEIS
     C                     Z-ADD0         M@RPMH
     C                     Z-ADD0         M@YOKW
     C                     Z-ADD0         M@YOLL
     C                     MOVE *BLANK    M@YOCD
     C                     Z-ADD0         M@GASM
     C                     MOVE *BLANK    M@GACD
     C                     Z-ADD0         M@ROT1
     C                     Z-ADD0         M@ROT2
     C                     Z-ADD0         M@ROT3
     C                     Z-ADD0         M@ROT4
     C                     Z-ADD0         M@ROT5
     C                     Z-ADD0         M@KJN1
     C                     Z-ADD0         M@KJN2
     C                     Z-ADD0         M@KJN3
     C                     Z-ADD0         M@KJN4
     C                     Z-ADD0         M@KJN5
     C                     MOVE *BLANK    M@SKBN
     C                     MOVE *BLANK    M@BSYO
     C                     MOVE *BLANK    M@SYS1
     C                     MOVE *BLANK    M@SYS2
     C                     Z-ADD0         M@HIZU
     C                     MOVE *BLANK    M@OKB1
     C                     MOVE *BLANK    M@OKB2
     C                     MOVE *BLANK    M@KSNO
     C                     Z-ADD0         M@STHZ
     C                     MOVE *BLANK    M@JTKB
     C                     Z-ADD0         M@MEKA
     C                     Z-ADD0         M@QKJY
     C                     MOVE *BLANK    M@NAME
     C                     MOVE *BLANK    M@QBKA
     C                     MOVE *BLANK    M@QKAK
     C                     MOVE *BLANK    M@QCS1
     C                     MOVE *BLANK    M@QCS2
     C                     MOVE *BLANK    M@QCS3
     C                     MOVE *BLANK    M@QKGN
     C                     MOVE *BLANK    M@HJY1
     C                     MOVE *BLANK    M@HJY2
     C                     MOVE *BLANK    M@HJY3
     C                     MOVE *BLANK    JTNM
     C                     MOVE *BLANK    SKNM
     C                     ELSE
     C                     MOVE *BLANK    JTNM
     C           M@JTKB    LOKUPTAB5      TAB6           75
     C   75                MOVELTAB6      JTNM
     C*
     C                     MOVE *BLANK    SKNM
     C           M@SKBN    LOKUPTAB3      TAB4           76
     C   76                MOVELTAB4      SKNM
     C*
     C                     END
     C******************************************************
     C*  EXFMT  <SCREEN 2>                                 *
     C******************************************************
     C*
     C           STP3      TAG
     C           KTYPE     IFEQ '0'
     C                     MOVEA'1'       *IN,33           DSPATR(PR)
     C                     END
     C*
     C                     EXFMTMFAPW032
     C                     MOVEA'00000'   *IN,01
     C                     MOVEA'00000'   *IN,06
     C                     MOVEA'00000'   *IN,11
     C                     MOVEA'00000'   *IN,16
     C                     MOVEA'00000'   *IN,21
     C                     MOVEA'00000'   *IN,26
     C                     MOVEA'00'      *IN,31
     C                     MOVEA'000'     *IN,34
     C                     MOVEA'000'     *IN,37
     C                     MOVEA'0'       *IN,99
     C*  CMD-3
     C           *INKC     IFEQ '1'
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C                     END
     C*
     C*  HELP
     C           *IN,80    IFEQ '1'
     C           STP4      TAG
     C                     EXFMTMFAPW033
     C   KC                GOTO STP3
     C           STP5      TAG
     C                     EXFMTMFAPW034
     C   KC                GOTO STP4
     C           STP6      TAG
     C                     EXFMTMFAPW035
     C   KC                GOTO STP5
     C           STP7      TAG
     C                     EXFMTMFAPW036
     C   KC                GOTO STP6
     C                     GOTO STP7
     C                     END
     C* CANCEL *
     C           KTYPE     IFEQ '0'
     C                     GOTO @@@XX
     C                     END
     C******************************************************
     C*  <SCREEN 2 CHECK>                                  *
     C******************************************************
     C*
     C*  STATE DIVISION
     C*
     C           M@JTKB    IFNE '1'
     C           M@JTKB    ANDNE'2'
     C           M@JTKB    ANDNE'3'
     C           M@JTKB    ANDNE'4'
     C                     MOVEA'1'       *IN,99
     C                     MOVEA'1'       *IN,34
     C                     MOVELMSG,16    ERR
     C                     GOTO STP3
     C                     END
     C*
     C                     MOVE *BLANK    JTNM
     C           M@JTKB    LOKUPTAB5      TAB6           75
     C   75                MOVELTAB6      JTNM
     C*
     C*  EQUIPMENT DIVISION
     C*
     C           M@SKBN    IFNE '1'
     C           M@SKBN    ANDNE'2'
     C                     MOVEA'1'       *IN,99
     C                     MOVEA'1'       *IN,01
     C                     MOVELMSG,8     ERR
     C                     GOTO STP3
     C                     END
     C*
     C                     MOVE *BLANK    SKNM
     C           M@SKBN    LOKUPTAB3      TAB4           76
     C   76                MOVELTAB4      SKNM
     C*
     C*  CONTROL SECTION CODE
     C*
     C           M@BSYO    IFEQ *BLANK
     C                     MOVEA'1'       *IN,99
     C                     MOVEA'1'       *IN,02
     C                     MOVELMSG,10    ERR
     C                     GOTO STP3
     C                     END
     C*
     C*  FACTORY CODE
     C*
     C           M@KOJY    IFEQ 0
     C                     MOVEA'1'       *IN,99
     C                     MOVEA'1'       *IN,03
     C                     MOVELMSG,10    ERR
     C                     GOTO STP3
     C                     END
     C*
     C                     MOVE *BLANK    KBN     1
     C           M@JTKB    IFEQ '1'
     C           M@SKBN    ANDEQ'1'
     C                     MOVEL'1'       KBN
     C                     END
     C*
     C           M@JTKB    IFEQ '1'
     C           M@SKBN    ANDEQ'2'
     C                     MOVEL'2'       KBN
     C                     END
     C*
     C           M@JTKB    IFEQ '2'
     C           M@JTKB    OREQ '4'
     C           M@SKBN    IFEQ '1'
     C                     MOVEL'3'       KBN
     C                     END
     C                     END
     C*
     C           M@JTKB    IFEQ '2'
     C           M@JTKB    OREQ '4'
     C           M@SKBN    IFEQ '2'
     C                     MOVEL'4'       KBN
     C                     END
     C                     END
     C*
     C           M@JTKB    IFEQ '3'
     C           M@SKBN    ANDEQ'1'
     C                     MOVEL'5'       KBN
     C                     END
     C*
     C           M@JTKB    IFEQ '3'
     C           M@SKBN    ANDEQ'2'
     C                     MOVEL'6'       KBN
     C                     END
     C*
     C*  AT ONE
     C*
     C           KBN       IFEQ '1'
     C*  SECTION CODE
     C           ATM       IFNE 'B7'
     C           M@BUKA    IFEQ *BLANK
     C                     MOVEA'1'       *IN,04
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,10    ERR
     C                     GOTO STP3
     C                     END
     C*  CHARGE CODE
     C           M@KAKA    IFEQ *BLANK
     C                     MOVEA'1'       *IN,05
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,10    ERR
     C                     GOTO STP3
     C                     END
     C                     END
     C*  COST CENTER
     C                     MOVE M@COS1    M@COSA
     C                     MOVE M@COS2    M@COSB
     C                     MOVE M@COS3    M@COSC
      *
     C           ATM       IFNE 'B7'
     C           M@CSA1    IFEQ *BLANK
     C           M@CSA2    OREQ *BLANK
     C                     MOVEA'1'       *IN,06
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,10    ERR
     C                     GOTO STP3
     C                     END
     C           M@CSB1    IFEQ *BLANK
     C           M@CSB2    OREQ *BLANK
     C                     MOVEA'1'       *IN,07
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,10    ERR
     C                     GOTO STP3
     C                     END
     C           M@CSC1    IFEQ *BLANK
     C           M@CSC2    OREQ *BLANK
     C                     MOVEA'1'       *IN,08
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,10    ERR
     C                     GOTO STP3
     C                     END
     C*  MACHINE GROUP
     C           M@KGUN    IFEQ *BLANK
     C                     MOVEA'1'       *IN,09
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,10    ERR
     C                     GOTO STP3
     C                     END
     C*  MACHINE NUMBER
     C           M@KBN1    IFEQ *BLANK
     C                     MOVEA'1'       *IN,10
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,10    ERR
     C                     GOTO STP3
     C                     END
     C*
     C           KTYPE     IFNE '0'
     C           KEY2      CHAINMFAPL221             45
     C           *IN,45    IFEQ '0'
     C           @SKJY     ANDEQ'D'
     C           @SKHZ     ANDLE*DATE
     C                     MOVEA'1'       *IN,45
     C                     END
     C*
     C           *IN,45    IFEQ '0'
     C           M@SYS1    IFEQ @SYS1
     C           M@SYS2    ANDEQ@SYS2
     C                     GOTO @@@XX2
     C                     END
     C*
     C                     MOVEA'1'       *IN,99
     C                     MOVEA'1'       *IN,03
     C                     MOVEA'11'      *IN,10
     C                     MOVELMSG,13    ERR
     C                     GOTO STP3
     C                     END
     C                     END
     C           @@@XX2    TAG
     C*  CHANGE DATE
     C           M@HIZU    IFEQ 0
     C                     MOVEA'1'       *IN,12
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,10    ERR
     C                     GOTO STP3
     C                     END
     C*  PROCESS
     C           M@KOTE    IFEQ *BLANK
     C                     MOVEA'1'       *IN,15
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,10    ERR
     C                     GOTO STP3
     C                     END
     C                     END
     C*  FORMER FACTORY CHECK
     C           M@QKJY    IFNE 0
     C           ATM       IFNE 'B7'
     C           M@QBKA    IFEQ *BLANK
     C           M@QKAK    OREQ *BLANK
     C           M@QCS1    OREQ *BLANK
     C           M@QCS2    OREQ *BLANK
