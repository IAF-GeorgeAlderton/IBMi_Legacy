     C           K#23X     SETGTALDPL23
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN98     IFEQ *OFF
     C                     EXCPT@HED
     C                     EXCPT@MSG
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
      *  CHECK SCANNED DATA
