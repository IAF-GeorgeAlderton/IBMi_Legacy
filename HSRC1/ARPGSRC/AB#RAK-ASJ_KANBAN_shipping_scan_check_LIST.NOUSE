     C           A1SYFN    ANDEQZ1SYFN
     C           A1SERL    ANDEQZ1SERL
     C                     LEAVE
     C                     ENDIF
      *
     C           A1SERL    CHAINAB#PL71              90
     C           *IN90     IFEQ *OFF
     C           EKSKJY    ANDNE*BLANK
     C                     ITER
     C                     ENDIF
      *
     C           A1SERL    LOKUP@SEL                     10
     C   10                ITER
      *
     C                     ADD  1         @CNT
     C                     ADD  1         A
     C           A         IFGT 300
     C                     LEAVE
     C                     ENDIF
     C                     Z-ADDA1YMD     @DT,A
     C                     Z-ADDA1HM      @TM,A
     C                     Z-ADDA1NONY    @SH,A
     C                     Z-ADDA1SSYS    @QT,A
     C                     MOVE ' '       @AS,A
     C                     MOVE A1SERL    @SEL,A
     C                     ENDIF
     C                     ENDDO
      *
     C           @CNT      IFEQ *ZERO
     C                     Z-ADD0         @DT,A
     C                     Z-ADD0         @TM,A
     C                     Z-ADD0         @SH,A
     C                     Z-ADD0         @QT,A
     C                     MOVE ' '       @AS,A
     C                     SUB  1         A
     C                     ENDIF
      *
     C                     ADD  @CNT      QT1,X
      *
     C                     ENDSR
