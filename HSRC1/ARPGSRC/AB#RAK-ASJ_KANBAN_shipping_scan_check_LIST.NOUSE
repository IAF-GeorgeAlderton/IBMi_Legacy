     C                     MOVE *BLANK    @SEL
     C                     MOVE *BLANK    @ORD
     C                     MOVE *BLANK    @LOT
     C                     Z-ADD*ZERO     A       30
     C           1         DO   7         X       30
     C                     Z-ADDDAT,X     K@YMD
     C           K#23      SETLLALDPL23
     C           *IN82     DOUEQ*ON
     C           K#23      READEALDPL23                  82
     C           *IN82     IFEQ *OFF
