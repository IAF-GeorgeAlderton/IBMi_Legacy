     C           #CHK      BEGSR
      *
     C                     Z-ADD*ZERO     @CNT    40
     C                     ADD  1         A
     C                     Z-ADDZ1YMD     @DT,A
     C                     Z-ADDZ1HM      @TM,A
     C                     Z-ADDZ1NONY    @SH,A
     C                     Z-ADDZ1SSYS    @QT,A
     C                     MOVE Z1SERL    @SEL,A
     C                     MOVE '*'       @AS,A
     C                     MOVE Z1ORDR    @ORD,A
     C                     MOVE Z1LOTN    @LOT,A
     C           K#20      SETLLALDPL20
     C           *IN85     DOUEQ*ON
     C           K#20      READEALDPL20                  85
     C           *IN85     IFEQ *OFF
      *
     C           A1SYYY    IFEQ Z1SYYY
     C           A1SYMM    ANDEQZ1SYMM
     C           A1SYDD    ANDEQZ1SYDD
