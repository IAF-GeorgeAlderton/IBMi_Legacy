      * DATE
      *------------------------------------------------------------
     C           #DATE     BEGSR
      *
     C                     Z-ADD*DATE     K@YMD
     C                     Z-ADD*ZERO     DAT
     C           K#AGD     SETLLAGDPL12
     C                     Z-ADD*ZERO     M       30
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDF8KAYY    K@YY
     C                     Z-ADDF8KAMM    K@MM
     C                     Z-ADDF8KADD    K@DD
     C           K#AGD     CHAINALDPL24              95
     C           *IN95     IFEQ *ON
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         M
     C                     Z-ADDK@YMD     DAT,M
     C           M         IFEQ 7
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     SORTADAT
      *
     C                     Z-ADDDAT       DT4
      *
     C                     ENDSR
