     H            Y.
     F** ABMR42 **********************************
     F*前工程情報の取得                        *
     F*    HOTTA.    2018.08.08                  *
     F********************************************
     FABHPL03 IF  E           K        DISK
     FAANPL03 IF  E           K        DISK
     E                    OKT        15  3               工程
     E                    OTK        15  6               所番地
     E                    OSY        15  1               か種
     E                    OBM        15  4               部門
      *
     I            DS
     I                                        1   6 WKTKR
     I                                        1   1 WKTKR1
     I                                        2   3 WKTKR2
     I                                        4   5 WKTKR3
     I                                        6   6 WKTKR4
      *
     I            DS
     I                                        1  100WKAP
     I                                        1   80WKAPHZ
     I                                        9  100WKAPBN
      *
     I            DS
     I                                        1  140WDATE
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C                     TIME           WDATE
     C           *ENTRY    PLIST
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P9BMON  40
     C                     PARM           P9PROC  3
     C                     PARM           P9PASS  1
      *
     C                     Z-ADD0         P9BMON
     C                     MOVEL*BLANK    P9PROC
     C                     MOVEL'0'       P9PASS
     C                     MOVEL'1'       OPNCLS
      *
     C                     EXSR #SB390
      *
     C           OPNCLS    IFEQ '0'
     C                     MOVE '9'       OPNCLS
     C                     CALL 'AAMRS0'
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           INYMDB 10
     C                     PARM           OPNCLS  1
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------*
      *工程情報                         *
      *-----------------------------------*
     CSR         #SB390    BEGSR
      *
     C                     CLEAROKT
     C                     CLEAROTK
     C                     CLEAROSY
     C                     CLEAROBM
     C                     MOVELP1SHN1    CBSHN1  5
     C                     MOVELP1SHN2    CBSHN2  5
     C                     MOVELP1SHN3    CBSHN3  2
     C                     MOVEL*DATE     INYMDB
     C                     MOVE '01'      INYMDB
     C                     CALL 'AAMRS0'
      *入力パラメータ
     C                     PARM           CBSHN1
     C                     PARM           CBSHN2
     C                     PARM           CBSHN3
     C                     PARM           INYMDB 10
     C                     PARM           OPNCLS  1
      *出力パラメータ
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
     C                     MOVEL'0'       OPNCLS
     C           STATUS    IFEQ '9'
     C                     GOTO ESB390
     C                     ENDIF
      *
     C                     MOVEAPKOT      OKT
     C                     MOVEAPTKR      OTK
     C                     MOVEAPSHR      OSY
     C                     MOVEAPBMN      OBM
      *
     C           OKT,1     IFEQ 'HN '
     C                     MOVELOKT,1     P9PROC
      *前工程
     C                     EXSR #SB391
      *
     C                     ENDIF
      *
     CSR         ESB390    ENDSR
      *----------------------------------------------------*
      *前工程
      *----------------------------------------------------*
     CSR         #SB391    BEGSR
      *工程内かんばんから前番地
     C                     MOVELOTK,1     WKTKR
     C           KEYTKR    KLIST
     C                     KFLD           WKTKR1
     C                     KFLD           WKTKR2
     C                     KFLD           WKTKR3
     C                     KFLD           WKTKR4
     C           KEYTKR    SETGTABHPL031
     C           KEYTKR    REDPEABHPL031                 88
     C           *IN88     DOWEQ'0'
     C           M6SKJY    IFEQ 'D'
     C           M6SKHZ    ANDLE*DATE
     C                     ELSE
     C           M6STHZ    IFEQ 99999999
     C                     MOVELM6MTKR    WKTKR
     C                     ENDIF
     C                     ENDIF
     C           KEYTKR    REDPEABHPL031                 88
     C                     ENDDO
      *前番地で半製品かんばん検索
     C           KEYTKR    SETGTAANPL031
     C           KEYTKR    REDPEAANPL031                 88
     C           *IN88     DOWEQ'0'
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    ANDLE*DATE
     C                     ELSE
     C           L7STHZ    IFEQ 99999999
     C                     MOVELL7BMON    P9BMON
     C                     ENDIF
     C                     ENDIF
     C           KEYTKR    REDPEAANPL031                 88
     C                     ENDDO
      *
     C           P9PROC    IFEQ 'HN'
     C           P9BMON    IFEQ 8990
     C                     MOVEL'2'       P9PASS
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB391    ENDSR
