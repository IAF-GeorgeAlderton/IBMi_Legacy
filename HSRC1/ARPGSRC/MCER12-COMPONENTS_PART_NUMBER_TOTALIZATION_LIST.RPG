     C                     MOVE KHB2      MCKHN2
     C                     MOVE KHB3      MCKHN3
     C                     Z-ADDWKSU      MCSRYO
     C                     Z-ADDWKSU      MCKOSU
     C                     WRITEMCENP131
     C                     Z-ADD0         WSRYO
     C                     Z-ADD0         WKSU
      *
     C                     MOVE *BLANK    TMEI   15
     C                     SETOF                     16
     C           THAI      CHAINFGBPL011             16
     C  N16                MOVELB2SMEI    TMEI   15
     C   16                MOVELTHAI      TMEI
      *
     C                     XFOOTTO        WGOK    90
     C                     SETON                     17
     C                     ENDSR
      *
     C           TANKA     BEGSR
     C                     MOVELKHIN      KSHIN  20
     C                     Z-ADD0         TAN    145
     C                     SETOF                     88
     C           KSHIN     SETLLGDKPL021             88
     C                     DO   *HIVAL
     C           KSHIN     READEGDKPL021                 88
     C           *IN88     IFEQ '0'
     C           ISSKJY    IFEQ 'D'
     C           ISSKHZ    ANDLE*DATE
     C                     GOTO NDAT
     C                     ELSE
     C           HIZU      IFGE ISSTHZ
     C           HIZU      ANDLEISENHZ
     C           ISTKP1    IFNE 0
     C                     Z-ADDISTKP1    TAN
     C                     ELSE
     C                     Z-ADDISTKP2    TAN
     C                     END
     C                     SETON                     88
     C                     END
     C                     END
     C                     END
     C           NDAT      TAG
     C  N88                ENDDO
     C                     ENDSR
