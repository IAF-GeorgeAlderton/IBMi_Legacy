     C                     KFLD           OHB3
      *
     C           *ENTRY    PLIST
     C                     PARM           PHIZK   8
      *
     C           *IN06     IFEQ '0'
     C                     SETON                     06
     C                     MOVE PHIZK     UHIZK
     C                     MOVE PHIZK     HIZU    80
     C                     MOVE UNEN      NEN     40
     C                     MOVE UTUK      TUK     20
     C                     Z-ADD0         TSRYO   90
     C                     Z-ADD0         TGOKE   90
     C                     Z-ADD0         QSRYO   90
     C                     Z-ADD0         QGOKE   90
     C                     Z-ADD0         QKHAK1  60
     C                     Z-ADD0         QKHAK2  60
     C                     Z-ADD0         TKIN   130
     C                     Z-ADD0         GKIN   130
     C                     END
      *
     C           *INL2     IFEQ '1'
     C                     Z-ADD0         GSRYO   90
     C                     Z-ADD0         GGOKE   90
     C                     Z-ADD0         NSRYO   90
     C                     Z-ADD0         NGOKE   90
     C                     Z-ADD0         WKHAK1  60
     C                     Z-ADD0         WKHAK2  60
     C                     Z-ADD0         KIN    110
     C                     Z-ADD0         GKIN   130
     C                     EXSR TANKA
     C                     END
      *
     C           *INL1     IFEQ '1'
     C                     Z-ADD0         DSRYO   70
     C                     Z-ADD0         SGOKE   70
     C                     Z-ADD0         SKIN   110
     C                     END
      *
     C                     ADD  SRYO      DSRYO
     C                     ADD  SRYO      GSRYO
     C                     ADD  SRYO      TSRYO
     C           SRYO      DIV  2         W#SRYO  70
     C                     ADD  W#SRYO    NSRYO
     C                     ADD  W#SRYO    QSRYO
     C                     ADD  KSU       SGOKE
     C                     ADD  KSU       GGOKE
     C                     ADD  KSU       TGOKE
     C           KSU       DIV  2         W#SRYO
     C                     ADD  W#SRYO    NGOKE
     C                     ADD  W#SRYO    QGOKE
      *
     C           TAN       MULT SRYO      KIN
     C                     ADD  KIN       SKIN
     C                     ADD  KIN       GKIN
     C                     ADD  KIN       TKIN
      *
     C                     SETOF                     10
     C                     MOVE *BLANK    WKIRI   1
     C           KEY2      CHAINAFBPP201             10
     C           *IN10     IFEQ '0'
     C           CGSKJY    ANDEQ'D'
     C           CGSKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '0'
     C                     MOVE CGKIRI    WKIRI
     C                     END
      *
     C                     SETOF                     81
     C  N80                SETON                     8081
     C   17                SETOF                     2117
      *
     C   L2N21
     COR 81N21
     CORN81 OFN21          SETON                     21
      *
     C           TKBN      IFEQ '1'
     C                     Z-ADD1         I       10
     C                     GOTO STEP01
     C                     ELSE
      *
     C                     Z-ADD2         I
     C                     GOTO STEP01
     C                     END
     C           STEP01    TAG
      *
     C           MS,I      ADD  KSU       MS,I
     C           TO,I      ADD  KSU       TO,I
     C           KENS      ADD  1         KENS    50
     C                     ADD  SRYO      WSRYO   80
     C                     ADD  KSU       WKSU    90
      *
     C           *INL2     IFEQ '1'
     C                     Z-ADD0         #SYOS   60
     C                     Z-ADD0         #BMON   40
     C           KEY1      SETGTAKBPL041
      *
B1   C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY1      REDPEAKBPL041                 10
B2   C           *IN10     IFEQ '0'
B3   C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    ANDLE*DATE
     C                     ELSE
      *
B4   C           L1STHZ    IFGT *DATE
     C                     Z-ADDL1SYOS    #SYOS
     C                     Z-ADDL1BMON    #BMON
B5   C           L1SYOS    IFNE 0
     C           L1BMON    ANDNE0
     C                     SETON                     10
E5   C                     END
E4   C                     END
      *
E3   C                     END
E2   C                     END
E1   C  N10                END
      *
     C           #SYOS     IFEQ *ZERO
     C           KEY1      SETLLFCEPL01
     C           #READ     TAG
     C           KEY1      READEFCEPL011                 90
     C           *IN90     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C                     GOTO #READ
     C                     END
     C                     Z-ADDA2SSYS    #SYOS
     C                     END
     C*
     C                     END
      *
     C                     MOVE *BLANK    $KEMI  16
     C           #BMON     IFNE 0
     C                     SETOF                     10
     C           #BMON     CHAINFGBPL011             10
     C           *IN10     IFEQ '0'
     C                     MOVELB2SMEI    $KEMI
     C                     END
     C                     END
      *
     C                     END
      *
     CL1                   EXSR SUBRTN
     CL2                   EXSR SUBRT2
