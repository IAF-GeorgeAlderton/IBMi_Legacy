     H            Y.
      ** EDIR80  *********************************************
      *  EDI862 ORDER INQUIRY BY DELIVERY CODE               *
      *  J.WATANABE 2024.02.11                               *
      ********************************************************
     FEDIPW80 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                        RRN2  KSFILE SFL02
     FAB#EL4S6IF  E           K        DISK
      ********************************************************
     E                    MSG     1  12 60
      *
     I            DS
     I                                        1   80P8NOHZ
     I                                        1   40P8NOYY
     I                                        5   60P8NOMM
     I                                        7   80P8NODD
      *
     I            DS
     I                                        1   80K#NOHZ
     I                                        1   40K#NOYY
     I                                        5   60K#NOMM
     I                                        7   80K#NODD
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *-----------------------------------------------------------*
      *     M  A  I  N  L  I  N  E      SFL1                      *
      *-----------------------------------------------------------*
      *
     C                     EXSR #INIT
      *
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP1
     C           W@ID      CASEQ'02'      #SFL1
     C           W@ID      CASEQ'03'      #SFL2
     C                     ENDCS
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *************************************************************
      * DISPLAY 1ST SCREEN
      *************************************************************
     C           #DSP1     BEGSR
      *
     C                     EXFMTDSP01
     C                     MOVEL*BLANKS   XMSG
     C                     MOVE *OFF      *IN85
     C                     MOVE *OFF      *IN41
     C                     MOVE *OFF      *IN42
     C                     MOVE *OFF      *IN43
      * F1/F3: EXIT
     C           *INKA     IFEQ *ON
     C           *INKC     OREQ *ON
     C           *INKL     OREQ *ON
     C                     MOVEL'99'      W@ID
     C                     GOTO XDSP1
     C                     ENDIF
      *
     C                     EXSR #CHK1
      *
     C           *IN85     IFEQ *OFF
     C                     MOVEL'02'      W@ID
     C                     ENDIF
      *
     C           XDSP1     ENDSR
      *************************************************************
      *  CHECK ENTRY DATA
      *************************************************************
     C           #CHK1     BEGSR
      * DELIVERY#
     C           XNONY     IFEQ 0
     C                     MOVELMSG,8     XMSG
     C                     SETON                     4185
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     MOVELXNONY     $DLV
     C                     CALL 'UTLR62'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTN    1
     C           $RTN      IFEQ '*'
     C                     MOVELMSG,9     XMSG
     C                     SETON                     4185
     C                     GOTO XCHK1
     C                     ENDIF
     C                     MOVEL$NAME1    XNAME
      * CHECK DATE FROM
     C           XFROM     IFEQ *BLANK
     C                     MOVELMSG,6     XMSG
     C                     SETON                     4185
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     MOVE XFROM     $SRC
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$TRUE1    @FROM   80
     C                     MOVEL$TRUE2    XFROM
     C                     ELSE
     C                     MOVELMSG,1     XMSG
     C                     SETON                     4285
     C                     GOTO XCHK1
     C                     ENDIF
      * CHECK DATE TO
     C           XTO       IFEQ *BLANK
     C                     MOVELXFROM     XTO
     C                     ENDIF
      *
     C           XTO       IFEQ '99999999'
     C                     Z-ADD99999999  @TO     80
     C                     ELSE
     C                     MOVE XTO       $SRC
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$TRUE1    @TO     80
     C                     MOVEL$TRUE2    XTO
     C                     ELSE
     C                     MOVELMSG,2     XMSG
     C                     SETON                     4385
     C                     GOTO XCHK1
     C                     ENDIF
     C                     ENDIF
      *
     C           @FROM     IFGT @TO
     C                     MOVELMSG,3     XMSG
     C                     SETON                     424385
     C                     ENDIF
      * IF NO ERROR
     C           *IN85     IFEQ *OFF
     C                     EXSR #SET1
      *
     C           RCNT1     IFGT 0
     C                     MOVEL'02'      W@ID
     C                     ELSE
     C                     MOVELMSG,4     XMSG
     C                     SETON                     424385
     C                     ENDIF
     C                     ENDIF
      *
     C           XCHK1     ENDSR
      ************************************************************
      *  SET DATA FOR SFL01
      ************************************************************
     C           #SET1     BEGSR
      *
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         TSRYO   70
     C                     EXSR #CLRS1
      *
     C                     MOVELXNONY     K#NONY
     C                     Z-ADD@FROM     K#CRDT
     C                     Z-ADD0         K#CRTM
     C           K#40S     SETLLAB#EL4S6
     C                     DO   *HIVAL
     C           K#NONY    READEAB#EL4S6                 97
     C   97                LEAVE
      * END?
     C           ECRDT     IFGT @TO
     C                     LEAVE
     C                     ENDIF
      * IGNORE
     C           ESRYO     IFEQ 0
     C                     ADD  1         ZCNT1
     C                     ITER
     C                     ENDIF
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     Z-ADDECRDT     SCRDT   80
     C                     Z-ADDECRTM     SCRTM   60
     C                     MOVELEMHIN     SMHIN  20
     C                     ENDIF
      * BREAK?
     C           ECRDT     IFNE SCRDT
     C           ECRTM     ORNE SCRTM
     C           EMHIN     ORNE SMHIN
     C                     EXSR #BRK1
     C                     ENDIF
      * PROCESS
     C                     ADD  ESRYO     TSRYO
     C                     ENDDO
      * LAST BREAK
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK1
     C                     ENDIF
      *
     C                     Z-ADDRRN1      RCNT1
      *
     C                     ENDSR
      ************************************************************
      *  BREAK 1
      ************************************************************
     C           #BRK1     BEGSR
      * BLANK LINE
     C           SCRDT     IFNE XCRDT
     C           XCRDT     ANDNE0
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     CLEARSFL01
     C                     Z-ADDSCRDT     S1RCHZ
     C                     Z-ADDSCRTM     S1RCTM
     C                     MOVELSMHIN     S1MHIN
     C                     Z-ADDTSRYO     S1QTY
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     Z-ADDSCRDT     XCRDT
      * RESET
     C                     Z-ADDECRDT     SCRDT
     C                     Z-ADDECRTM     SCRTM
     C                     MOVELEMHIN     SMHIN
     C                     Z-ADD0         TSRYO
      *
     C                     ENDSR
      ************************************************************
      *  DSPLAY 2ND SCREEN
      ************************************************************
     C           #SFL1     BEGSR
      *
     C                     EXSR #SET1
      *
     C                     WRITEDSP99
     C                     MOVE *ON       *IN70
     C                     EXFMTCTL01
     C                     MOVEL*BLANKS   XMSG
     C                     MOVE *OFF      *IN85
     C                     MOVE *OFF      *IN70
      *
     C                     SELEC
      * F3: EXIT
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * F12: BACK
     C           *INKL     WHEQ *ON
     C                     EXSR #SEL1
     C                     MOVE '01'      W@ID
      * ENTER
     C                     OTHER
     C                     EXSR #SEL1
     C           S1SELX    IFEQ 'P'
     C                     MOVEL'99'      W@ID
     C                     ELSE
     C           S1SELX    IFNE *BLANK
     C**                   CALL 'AB#R985'                  PL INQ
     C**                   PARM           $SERL
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************
      * CLEAR SUB FILE 01
      *************************************************************
     C           #CLRS1    BEGSR
      *
     C                     SETON                     71
     C                     WRITECTL01
     C                     SETOF                     71
     C                     Z-ADD0         RRN1
     C                     Z-ADD0         ZCNT1   60
     C                     Z-ADD0         XCRDT   80
      *
     C                     ENDSR
      *************************************************************
      * CHECK SELECTION
      *************************************************************
     C           #SEL1     BEGSR
      *
     C                     MOVE *BLANK    S1SELX  1
     C           1         DO   RCNT1     RRN1
      *
     C           RRN1      CHAINSFL01                50
     C           *IN50     IFEQ *OFF
     C           S1SEL     ANDNE' '
     C                     MOVE S1SEL     S1SELX
     C                     MOVE *BLANK    S1SEL
     C                     UPDATSFL01
     C                     EXSR #SFL2
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      ************************************************************
      *  DSPLAY 3RD SCREEN
      ************************************************************
     C           #SFL2     BEGSR
      *
     C                     EXSR #SET2
      *
     C           STR2      TAG
     C                     WRITEDSP99
     C                     MOVE *ON       *IN70
     C                     EXFMTCTL02
     C                     MOVEL*BLANKS   XMSG
     C                     MOVE *OFF      *IN85
     C                     MOVE *OFF      *IN70
      *
     C                     SELEC
      * F3: EXIT
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * F12: BACK
     C           *INKL     WHEQ *ON
     C                     MOVE '02'      W@ID
      * ENTER
     C                     OTHER
     C                     GOTO STR2
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************
      * CLEAR SUB FILE 02
      *************************************************************
     C           #CLRS2    BEGSR
      *
     C                     SETON                     71
     C                     WRITECTL02
     C                     SETOF                     71
     C                     Z-ADD0         RRN2
     C                     Z-ADD0         ZCNT2   60
      *
     C                     ENDSR
      ************************************************************
      *  SET DATA FOR SFL02
      ************************************************************
     C           #SET2     BEGSR
      *
     C                     EXSR #CLRS2
      *
     C                     MOVELXNONY     K#NONY
     C                     Z-ADDS1RCHZ    K#CRDT
     C                     Z-ADD0         K#CRTM
     C           K#40S     SETLLAB#EL4S6
     C                     DO   *HIVAL
     C           K#NONY    READEAB#EL4S6                 97
     C   97                LEAVE
      * END?
     C           ECRDT     IFNE S1RCHZ
     C                     LEAVE
     C                     ENDIF
      * IGNORE
     C           EMHIN     IFNE S1MHIN
     C                     ITER
     C                     ENDIF
      * IGNORE
     C           ESRYO     IFEQ 0
     C                     ADD  1         ZCNT2
     C                     ITER
     C                     ENDIF
      *
     C                     CLEARSFL02
     C                     Z-ADDECRDT     S2RCHZ
     C                     Z-ADDECRTM     S2RCTM
     C                     MOVELEMHIN     S2MHIN
     C                     Z-ADDENDATE    S2NOHZ
     C                     Z-ADDESRYO     S2QTY
     C                     MOVELEMKDO     S2INVN
      * PAST DUE
     C           S2RCHZ    IFGT S2NOHZ
     C                     MOVE *ON       *IN51
     C                     ELSE
     C                     MOVE *OFF      *IN51
     C                     ENDIF
      *
     C                     ADD  1         RRN2
     C                     WRITESFL02
      *
     C                     ENDDO
      *
     C                     Z-ADDRRN2      RCNT2
      *
     C                     ENDSR
      *************************************************************
      * INITIAL SETTING
      *************************************************************
     C           #INIT     BEGSR
      *
     C**         *ENTRY    PLIST
     C**                   PARM           $SERL   9        OUT
      *
     C           K#40S     KLIST
     C                     KFLD           K#NONY  4
     C                     KFLD           K#CRDT  80
     C                     KFLD           K#CRTM  60
      *
     C                     TIME           SDATE
     C                     MOVEL*BLANKS   XMSG
     C                     MOVEL'01'      W@ID    2
     C                     MOVELTODAY     XFROM     P
     C                     MOVELTODAY     XTO       P
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         RRN2    40
     C                     Z-ADD0         RCNT1   40
     C                     Z-ADD0         RCNT2   40
     C                     Z-ADD0         K#CRTM
      *
     C                     ENDSR
      *************************************************************
** (ERR) (60A).....2.........3.........4.........5.........6
FROM_DATE IS INCORRECT !                                     01
TO_DATE IS INCORRECT !                                       02
FROM_DATE > TO_DATE !                                        03
NO DATA FOUND !                                              04
PRESS F5 TO PROCESS...                                       05
ENTER FROM_DATE !                                            06
ENTER TO_DATE !                                              07
ENTER DELIVERY CODE!                                         08
DELIVERY CODE NOT FOUND IN MASTER!                           09
                                                             10
                                                             11
                                                             12
