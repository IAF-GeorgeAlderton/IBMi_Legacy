     C           *IN10     IFEQ '0'
     C                     SETON                     10
     C                     TIME           WTIME   60
     C                     EXCPTHD
     C                     END
      *
     C           A2GSKD    IFEQ *BLANK
      *
     C                     MOVE *BLANK    WBHB3   1
     C           A2BHB3    IFNE *BLANK
     C                     MOVEL'-'       WBHB3
     C                     END
      *
     C                     MOVE *BLANK    W2HB5   1
     C                     MOVE *BLANK    W3HB2   1
     C           A22HB5    IFNE *BLANK
     C                     MOVEL'-'       W2HB5
     C                     END
     C           A23HB2    IFNE *BLANK
     C                     MOVEL'-'       W3HB2
     C                     END
      *
     C                     MOVE *BLANK    W5HB5   1
     C                     MOVE *BLANK    W6HB2   1
     C           A25HB5    IFNE *BLANK
     C                     MOVEL'-'       W5HB5
     C                     END
     C           A26HB2    IFNE *BLANK
     C                     MOVEL'-'       W6HB2
     C                     END
      *
     C                     MOVE *BLANK    W8HB5   1
     C                     MOVE *BLANK    W9HB2   1
     C           A28HB5    IFNE *BLANK
     C                     MOVEL'-'       W8HB5
     C                     END
     C           A29HB2    IFNE *BLANK
     C                     MOVEL'-'       W9HB2
     C                     END
      *
     C                     MOVE *BLANK    W11H5   1
     C                     MOVE *BLANK    W12H2   1
     C           A211H5    IFNE *BLANK
     C                     MOVEL'-'       W11H5
     C                     END
     C           A212H2    IFNE *BLANK
     C                     MOVEL'-'       W12H2
     C                     END
      *
     C                     MOVEAA2MMEI    HMEI
     C           1         DO   30        A       20
     C           HMEI,A    IFEQ ','
     C                     MOVE *BLANK    HMEI,A
     C                     END
     C                     END
     C                     MOVEAHMEI      A2MMEI
      *
     C                     MOVEAA2SMEI    HSMI
     C           1         DO   15        A
     C           HSMI,A    IFEQ ','
     C                     MOVE *BLANK    HSMI,A
     C                     END
     C                     END
     C                     MOVEAHSMI      A2SMEI
      *
     C                     Z-ADD50        B       20
     C                     MOVEA'00000000'*IN,51
     C                     MOVEA'0000000' *IN,59
     C           1         DO   15        A
     C                     ADD  1         B
     C           HKOT,A    IFNE *BLANK
     C                     MOVEL'1'       *IN,B
     C                     END
     C                     END
      *
     C                     EXCPTDT
     C                     END
