     H            Y.                                    1
     H** ALDR00 ****************************************************************
     H* MATCHING SHIPPING SYSTEM IN IAF(MAIN MENU)                             *
     H* TCH(N.HYOTO) SEP.01.99                                                 *
     H* TCH(N.HYOTO) JUN.02.00 ADD AFAR60                                      *
     H* TCH(N.HYOTO) JUN.16.00 CHANGE FROM ALDR01 TO ALDC03                    *
     H* TCH(N.HYOTO) AUG.11.00 ADD GDLR20                                      *
     H* TCH(N.HYOTO) SEP.25.00 ADD OUT SOURCE ORDER                            *
     H* TCH(H.AMANO) JUL.31.01 ADD 2-POINT SCAN                                *
     H* TCH(H.AMANO) JAN.20.03 ADD SERVICE PART SCAN                           *
     H*
     H* TCHK1 03/24/10 RMV OPTION 6 & 9
     H* TCHK2 03/26/10 CHG OPTION S TO 6
     H* TCHK3 01/10/14 ADD OPTION 7
%0001H* TUCKER        06/27/17 REMOVE #1, #5
%0002H* TUCKER        10/11/19 ADD PARAMTER LIST
     H**************************************************************************
     H*
     H* *IN03 = 1(CF03)
     H* *IN30 = ERROR
     H* *IN31 = WORKER CODE ERROR
     H* *IN32 = PROCESS CODE ERROR
     H*
     H**************************************************************************
     FALDPW00 CF  E                    WORKSTN
     FALBPL30 IF  E           K        DISK
     F**************************************************************************
     E                    ERR     1  15 15
     I**************************************************************************
     I            DS
     I                                        1   80WSDATE
     I                                        1   4 WSYYYY
     I                                        5   6 WSMM
     I                                        7   8 WSDD
     F**************************************************************************
     E* ENTRY LIST
     I**************************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PUSR   10
     F**************************************************************************
     E* PARAMETER LIST
     I**************************************************************************
     C           P1        PLIST
     C                     PARM           POPR
     C                     PARM           PUSR   10
     C* %0002
     C           P2        PLIST
     C                     PARM           POPR
     C                     PARM           PUSR2  20
     C*
     C**************************************************************************
     C*                    MAIN ROUTINE
     C**************************************************************************
     C                     EXSR @INT
     C                     EXSR @MAIN
     C                     EXSR @END
     C**************************************************************************
     C*                    @INT
     C**************************************************************************
     C           @INT      BEGSR
     C*
     C                     SETOF                     303132
     C                     MOVEL*BLANK    MSG
     C                     Z-ADD*DATE     WSDATE
     C                     MOVELPUSR      PUSR2            NAME
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @MAIN
     C**************************************************************************
     C           @MAIN     BEGSR
     C*
     C           *IN03     DOWEQ'0'
     C                     EXFMTALDPW001
     C                     SETOF                     303132
     C                     MOVEL*BLANK    MSG
     C* F3=END
     C           *IN03     IFEQ '1'
     C* ENTER
     C                     ELSE
     C* WORKER CODE CHECK
     C           USRCD     CHAINALBPL301             90
     C           *IN90     IFEQ '0'
     C           ALSKJY    ANDNE'D'
     C*
     C                     MOVE ALWKCD    POPR    6        SET WORKER ID
     C                     MOVEL*BLANK    PUSR2            NAME
     C                     MOVELALWKNM    PUSR2            SET NAME
     C*
     C                     SELEC
     C* OLD SERVICE PARTS PGM
     C           SNO       WHEQ '1'
     C                     CALL 'ALDR2SB' P2
     C* COMBINED
     C           SNO       WHEQ '2'
     C                     CALL 'AFAR60'
     C                     PARM           POPR
     C* MATERIAL RECEIVING
     C           SNO       WHEQ '3'
     C                     CALL 'GDLR20'
     C                     PARM           POPR
     C* OUT SOURCE SYSTEM
     C           SNO       WHEQ '4'
     C                     CALL 'AFAR80'  P1
     C* 2-POINT SCAN
%0001C****       SNO       WHEQ '5'
     C****                 CALL 'ALDR90'  P1
      * SERVICE
%0002C           SNO       WHEQ '6'
     C                     CALL 'ALDC02B' P2
     C* CREFORM MATERIAL SHIP
TCHK3C           SNO       WHEQ '7'
TCHK3C                     CALL 'ALJR10'  P1
     C* SERVICE PARTS SCAN
     C           SNO       WHEQ '8'
     C                     CALL 'ALSR01'  P1
     C** OTHERS
     C                     OTHER
     C                     SETON                     3032
     C                     MOVEAERR,2     MSG
     C                     ENDSL
     C**
     C*NOT READ WORKER CODE MASTER
     C                     ELSE
     C                     SETON                     3031
     C                     MOVEAERR,1     MSG
     C                     END
     C                     END
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @END
     C**************************************************************************
     C           @END      BEGSR
