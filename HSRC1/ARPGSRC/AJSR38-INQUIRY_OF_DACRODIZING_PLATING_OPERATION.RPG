     C                     MOVEA'0'       *IN,92
      *
     C           KEY1      SETLLAJSPL821
      *  ’Šģ’ŠÄ’Š×’ŠÄ’Į”b’Šō ’Šø’Šā’Į░n’Š× CLR
     C                     Z-ADD*ZERO     @STHZ
     C                     Z-ADD*ZERO     @STTM
     C                     Z-ADD*ZERO     @EDHZ
     C                     Z-ADD*ZERO     @EDTM
     C                     Z-ADD*ZERO     @ADBL
     C                     Z-ADD*ZERO     @COBL
     C                     Z-ADD*ZERO     @AUTO
     C                     Z-ADD*ZERO     @HAND
     C                     Z-ADD*ZERO     #STHZ
     C                     Z-ADD*ZERO     #STTM
     C                     Z-ADD*ZERO     #EDHZ
     C                     Z-ADD*ZERO     #EDTM
     C                     Z-ADD*ZERO     #ADBL
     C                     Z-ADD*ZERO     #COBL
     C                     Z-ADD*ZERO     #AUTO
     C                     MOVE *BLANK    #HAND
      *
B001 C                     DO   *HIVAL
     C           MORE1     TAG
     C                     READ AJSPL821                 40
     C   40                GOTO @@@
      *
     C           J8SKJY    IFEQ 'D'
     C           J8SKHZ    IFLE *DATE
     C                     GOTO MORE1
     C                     END
     C                     END
      *
B002 C           *IN,40    IFEQ '0'
     C                     MOVEA'0'       *IN,21
     C           J8WKHZ    CABLTSHIZ      @END
     C           J8WKHZ    CABGTEHIZ      @@@
     C                     Z-ADDJ8WKHZ    @STHZ
     C                     Z-ADDJ8WKTM    @STTM
     C                     Z-ADDJ8KEHZ    @EDHZ
     C                     Z-ADDJ8KETM    @EDTM
     C                     Z-ADDJ8AUTO    @AUTO
     C                     Z-ADDJ8TBAL    @ADBL
     C                     Z-ADDJ8KBAL    @COBL
     C                     Z-ADDJ8JYUR    @HAND
      *
     C                     ADD  1         RRN
     C                     ADD  1         CNTR
     C                     WRITEDSP2R
      * MAX m’Š×’Į░j <15>
     C           CNTR      CABEQ15        @@@
E002 C                     END
     C           @END      TAG
E001 C  N40                END
      *
     C           @@@       TAG
      *  f’Š×bnc m’Š×’Į░j o’Šå
B001 C           RRN       IFEQ 0
     C                     MOVEA'111'     *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,2     ERR
     C                     END
      *
     C                     ENDSR
      ******************************************************
     C           ROLLUP    BEGSR                           *
      ******************************************************
     C                     MOVE *BLANK    SW      1
B001 C                     DO   *HIVAL
     C                     READ AJSPL821                 40
     C           MORE2     TAG
     C   40                GOTO @ROLE
      *
     C           J8SKJY    IFEQ 'D'
     C           J8SKHZ    IFLE *DATE
     C                     GOTO MORE2
     C                     END
     C                     END
      *
B002 C           *IN,40    IFEQ '0'
     C           J8WKHZ    CABLTSHIZ      @END1
     C           J8WKHZ    CABGTEHIZ      @ROLE
     C                     MOVEL'*'       SW
     C                     Z-ADDJ8WKHZ    @STHZ
     C                     Z-ADDJ8WKTM    @STTM
     C                     Z-ADDJ8KEHZ    @EDHZ
     C                     Z-ADDJ8KETM    @EDTM
     C                     Z-ADDJ8AUTO    @AUTO
     C                     Z-ADDJ8TBAL    @ADBL
     C                     Z-ADDJ8KBAL    @COBL
     C                     Z-ADDJ8JYUR    @HAND
      *
     C                     ADD  1         RRN
     C                     ADD  1         CNTR
     C                     WRITEDSP2R
     C           CNTR      CABEQ15        @ROLE
E002 C                     END
     C           @END1     TAG
E001 C  N40                END
      *
     C           @ROLE     TAG
      *  ’Šā’Šøb’Šå’Š×’ĮŁc m’Š×’Į░j o’Šå
B001 C           SW        IFEQ *BLANK
