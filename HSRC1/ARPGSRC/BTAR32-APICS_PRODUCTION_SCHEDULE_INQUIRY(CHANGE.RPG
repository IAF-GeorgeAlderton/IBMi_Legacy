     H            Y.
     F** BTAR32 *******************************
     F* APICS PRODUCTION SCHEDULE INQUIRY     *
     F*    ADDED BY PC                        *
     F*            2002/07/29
     F******************************* BTAR32 **
     FBTAPW32 CF  E                    WORKSTN
     F                                        RRN0  KSFILE SFL00
     F                                        RRN1  KSFILE SFL01
     F                                        RRN2  KSFILE SFL02
     F                                              KINFDS @INFDS
     FRGAPL11 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FBTAWL32 IF  E           K        DISK
     FBTAWL33 IF  E           K        DISK
     F            BTAWP321                          KRENAMEBTAWL3R
      *------------------------------------------------------------
     E                    CMD     1   2 78
     E                    ER      1   1 78
     E                    WD      7   7  3
      *------------------------------------------------------------
     E                    DAT         5  8 0
     E                    QT          5  3 0
     E                    D@D         5  4 0
     E                    D@W         5  3
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I            DS
     I                                        1  40 DAT
     I                                        1   80WPDAT1
     I                                        9  160WPDAT2
     I                                       17  240WPDAT3
     I                                       25  320WPDAT4
     I                                       33  400WPDAT5
     I            DS
     I                                        1  20 D@D
     I                                        1   40D@DAT1
     I                                        5   80D@DAT2
     I                                        9  120D@DAT3
     I                                       13  160D@DAT4
     I                                       17  200D@DAT5
     I            DS
     I                                        1  15 D@W
     I                                        1   3 D@WDY1
     I                                        4   6 D@WDY2
     I                                        7   9 D@WDY3
     I                                       10  12 D@WDY4
     I                                       13  15 D@WDY5
     I            DS
     I                                        1  15 QT
     I                                        1   30S@QTY1
     I                                        4   60S@QTY2
     I                                        7   90S@QTY3
     I                                       10  120S@QTY4
     I                                       13  150S@QTY5
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'00'      #SCRN0
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C           W@ID      CASEQ'03'      #SCRN3
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIAL SET
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
      *
     C           K#KEY     KLIST
     C                     KFLD           @USER
     C                     KFLD           D@DATE
     C           K#KEYX    KLIST
     C                     KFLD           @USER
     C                     KFLD           K@DATE  80
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#GW3     KLIST
     C                     KFLD           K@PRT1  5
     C                     KFLD           K@PRT2  5
     C                     KFLD           K@PRT3  2
     C                     KFLD           K@FRM   80
     C           K#GW3X    KLIST
     C                     KFLD           K@PRT1
     C                     KFLD           K@PRT2
     C                     KFLD           K@PRT3
      *
     C                     Z-ADD*ZERO     RRN0    40
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     D@D
     C                     MOVE '00'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *  1ST SCREEN
      *------------------------------------------------------
     C           #SCRN0    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK0
     C           *IN99     IFEQ *OFF
     C           D@PRT1    IFEQ *BLANK
     C                     EXSR #SET0
     C           RRN0      IFNE *ZERO
     C                     MOVE '01'      W@ID
     C                     ELSE
     C                     MOVE ER,1      D@MSG
     C                     ENDIF
     C                     ELSE
     C                     MOVE D@PRT1    K@PRT1
     C                     MOVE D@PRT2    K@PRT2
     C                     MOVE D@PRT3    K@PRT3
     C                     Z-ADDD@FRM     K@FRM
     C                     Z-ADDD@TO      W@TO    80
     C                     EXSR #SET01
     C           RRN2      IFNE *ZERO
     C                     MOVE W@ID      @@ID    2
     C                     MOVE '03'      W@ID
     C                     ELSE
     C                     MOVE ER,1      D@MSG
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK0     BEGSR
      *
     C                     EXSR #CLR
      *
     C           D@FRM     IFGT D@TO
     C                     SETON                     616299
     C                     ENDIF
      *
     C           D@FRM     IFEQ *ZERO
     C           D@TO      ANDEQ*ZERO
     C                     SETON                     616299
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SET 1ST SCREEN
      *------------------------------------------------------
     C           #SET0     BEGSR
      *
     C                     Z-ADD*ZERO     RRN0
     C                     MOVE *ON       *IN52
     C                     WRITECTL00
     C                     MOVE *OFF      *IN52
      *
     C           *LOVAL    SETLLBTAWL32
     C           *IN80     DOUEQ*ON
     C                     READ BTAWL32                  80
     C           *IN80     IFEQ *OFF
      *
     C                     MOVE WPUPPS    @USER  10
     C                     Z-ADDD@FRM     K@DATE
     C           K#KEYX    SETLLBTAWL32
     C           *IN90     DOUEQ*ON
     C           @USER     READEBTAWL32                  90
     C           *IN90     IFEQ *OFF
     C           *IN90     IFEQ *ON
     C           *IN90     OREQ *OFF
     C           WPUPDT    ANDGTD@TO
     C           @USER     SETGTBTAWL32
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  1         RRN0
     C                     MOVEL@USER     S@PRCD
     C           @USER     CHAINRGAPL11              95
     C  N95                MOVELJ8NAME    S@PNAM
     C                     Z-ADDWPUPDT    S@DATE
     C                     WRITESFL00
     C                     Z-ADDWPUPDT    K@DATE
     C           K#KEYX    SETGTBTAWL32
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SET 3RD SCREEN
      *------------------------------------------------------
     C           #SET01    BEGSR
      *
     C                     Z-ADD*ZERO     RRN2    40
     C                     MOVE *ON       *IN56
     C                     WRITECTL02
     C                     MOVE *OFF      *IN56
      *
     C           K#GW3     SETLLBTAWL33
     C           *IN90     DOUEQ*ON
     C           K#GW3X    READEBTAWL33                  90
     C           *IN90     IFEQ *OFF
     C           WPUPDT    IFGT W@TO
     C                     LEAVE
     C                     ENDIF
      *
     C                     CLEARSFL02
     C                     ADD  1         RRN2
     C           WPUPPS    CHAINRGAPL11              95
     C  N95                MOVELJ8NAME    S@NAME
     C                     Z-ADDWPUPDT    S@UPDT
     C                     Z-ADDWPDAT1    S@DAT1
     C                     Z-ADDWPDAT2    S@DAT2
     C                     Z-ADDWPDAT3    S@DAT3
     C                     Z-ADDWPDAT4    S@DAT4
     C                     Z-ADDWPDAT5    S@DAT5
     C                     Z-ADDWPQTY1    S@QTY1
     C                     Z-ADDWPQTY2    S@QTY2
     C                     Z-ADDWPQTY3    S@QTY3
     C                     Z-ADDWPQTY4    S@QTY4
     C                     Z-ADDWPQTY5    S@QTY5
     C                     Z-ADDWPAA      S@AA
     C                     Z-ADDWPFF      S@FF
     C                     Z-ADDWPJJ      S@JJ
     C                     Z-ADDWPBB      S@BB
     C                     Z-ADDWPDD      S@DD
     C                     Z-ADDWPEE      S@EE
     C                     Z-ADDWPGG      S@GG
     C           S@AA      ADD  S@FF      W@ANS   72
     C                     SUB  S@JJ      W@ANS
     C                     SUB  S@BB      W@ANS
     C                     SUB  S@DD      W@ANS
     C                     SUB  S@EE      W@ANS
     C                     SUB  S@GG      W@ANS
     C                     Z-ADDW@ANS     S@TOT
     C           W@ANS     IFGT *ZERO
     C                     MOVE W@ANS     @@2     2
     C           @@2       IFNE '00'
     C                     ADD  1         S@TOT
     C                     ENDIF
     C                     ENDIF
      *
     C                     WRITESFL02
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL00
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVE '00'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C           RRN1      IFNE *ZERO
     C                     MOVE '02'      W@ID
     C                     ELSE
     C                     MOVE ER,1      D@MSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C                     MOVE *ON       *IN99
     C                     Z-ADD*ZERO     @RRN    40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         @RRN
     C           @RRN      CHAINSFL00                90
     C           *IN90     IFEQ *OFF
     C           S@SLCT    ANDNE*BLANK
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    S@SLCT
     C                     UPDATSFL00
     C                     MOVE S@PRCD    @USER
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    D@MSG
     C                     MOVEA'00000000'*IN,61
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SET DATA FOR 2ND SCREEN
      *------------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     Z-ADD*ZERO     RRN1
     C                     MOVE *ON       *IN54
     C                     WRITECTL01
     C                     MOVE *OFF      *IN54
      *
     C                     MOVE S@PNAM    D@PNAM
     C                     Z-ADDS@DATE    D@DATE
      *
     C           K#KEY     SETLLBTAWL32
     C           *IN92     DOUEQ*ON
     C           K#KEY     READEBTAWL32                  92
     C           *IN92     IFEQ *OFF
      *
     C           WPQTY1    IFNE *ZERO
     C           WPQTY2    ORNE *ZERO
     C           WPQTY3    ORNE *ZERO
     C           WPQTY4    ORNE *ZERO
     C           WPQTY5    ORNE *ZERO
      * SET CALENDAR
     C           RRN1      IFEQ *ZERO
     C                     EXSR #DAT2
     C                     ENDIF
      *
     C                     ADD  1         RRN1
      *
     C                     MOVE WPPRT1    S@PRT1
     C                     MOVE WPPRT2    S@PRT2
     C                     MOVE WPPRT3    S@PRT3
     C                     MOVE WPLOC1    S@LOC1
     C                     MOVE WPLOC2    S@LOC2
     C                     MOVE WPLOC3    S@LOC3
     C                     MOVE WPLOC4    S@LOC4
     C                     Z-ADDWPQTY1    S@QTY1
     C                     Z-ADDWPQTY2    S@QTY2
     C                     Z-ADDWPQTY3    S@QTY3
     C                     Z-ADDWPQTY4    S@QTY4
     C                     Z-ADDWPQTY5    S@QTY5
     C                     XFOOTQT        S@TOTL
     C                     WRITESFL01
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SET DATE
      *------------------------------------------------------
     C           #DAT2     BEGSR
      *
     C                     MOVE *BLANK    D@W
     C           1         DO   5         X       30
     C                     Z-ADDDAT,X     D@D,X
     C           DAT,X     IFNE *ZERO
     C                     Z-ADDDAT,X     K@YMD
     C           K#AGD     CHAINAGDPL12              95
     C           *IN95     IFEQ *OFF
     C                     Z-ADDF8YOBI    Y       30
     C                     MOVE WD,Y      D@W,X
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  2NC SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN53
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN53
      *
     C                     MOVE W@ID      @@ID
      *
     C                     SELEC
      * END
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
      * GO BACK
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK2
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     EXSR #CLR
     C                     MOVE *ON       *IN99
     C                     Z-ADD*ZERO     @RRN    40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         @RRN
     C           @RRN      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           S@SLCT    ANDNE*BLANK
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    S@SLCT
     C                     UPDATSFL01
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN99     IFEQ *OFF
     C                     MOVE S@PRT1    K@PRT1
     C                     MOVE S@PRT2    K@PRT2
     C                     MOVE S@PRT3    K@PRT3
     C                     Z-ADDD@DATE    K@FRM
     C                     Z-ADDD@DATE    W@TO    80
     C                     EXSR #SET01
     C           RRN2      IFNE *ZERO
     C                     MOVE '03'      W@ID
     C                     ELSE
     C                     MOVE ER,1      D@MSG
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  3RD SCREEN
      *------------------------------------------------------
     C           #SCRN3    BEGSR
      *
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN55
     C                     EXFMTCTL02
     C                     MOVE *OFF      *IN55
      *
     C                     SELEC
      * END
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
      * GO BACK
     C           *INKL     WHEQ *ON
     C                     MOVE @@ID      W@ID
     C                     OTHER
     C           @@ID      IFEQ '02'
     C                     EXSR #CHK2
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
** CMD
F1:END
F1:END   F12:GO BACK
** ER
 NO DATA.
** WD
MONTUEWEDTHUFRISATSUN
