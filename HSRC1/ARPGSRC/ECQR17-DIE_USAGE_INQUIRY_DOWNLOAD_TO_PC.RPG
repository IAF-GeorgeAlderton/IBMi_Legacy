     H            Y.
     F** ECQR17 **********************************
     F* DIE USAGE INQUIRY/DOWNLOAD TO PC
     F* PROGRAM ID. : ECQR17. <RPG> *
     F* CREATE DATE. : MAY.15.02                 *
     F* AUTHOR.         : TCH                    *
     F********************************** ECQR15 **
     FECQPW17 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FECSPL05 IF  E           K        DISK
     FGCQTL31 IF  E           K        DISK
     FMBEPL05 IF  E           K        DISK
     FFCQPL31 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FAAMPL11 IF  E           K        DISK
     FAB#PPCT UF  E           K        DISK                      A
     FECQWP17 O   E                    DISK                           UC
      *-----------------------------------------------------------
     E                    CMD     1   2 78
     E                    KWD     1   1 70
     E                    MSG     1   1 78
     E                    I6S        12  9 0
     E                    YM         50  6 0
      *-----------------------------------------------------------
     I@INFDS      DS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I            DS
     I                                        1 1080I6S
     I                                        1   90I6SRO1
     I                                       10  180I6SRO2
     I                                       19  270I6SRO3
     I                                       28  360I6SRO4
     I                                       37  450I6SRO5
     I                                       46  540I6SRO6
     I                                       55  630I6SRO7
     I                                       64  720I6SRO8
     I                                       73  810I6SRO9
     I                                       82  900I6SROA
     I                                       91  990I6SROB
     I                                      100 1080I6SROC
     I            DS
     I                                        1   60D@MMYY
     I                                        1   20D@MM
     I                                        3   60D@YY
     I            DS
     I                                        1   40@@MMYY
     I                                        1   20@@MM
     I                                        3   40@@YY
     I            DS
     I                                        1   60WYYMM
     I                                        1   40WYY
     I                                        5   60WMM
     I            DS
     I                                        1  15 DFKATA
     I                                        1   2 #KAT1
     I I            '-'                       3   3 #AAA
     I                                        4   7 #KAT2
     I                                        8   8 #BBB
     I                                        9   9 #KAT3
     I            DS
     I                                        1   60F8YYMM
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I            DS
     I                                        1   7 D@DIE
     I                                        1   2 D@DIE1
     I                                        3   6 D@DIE2
     I                                        7   7 D@DIE3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------
      *  MAIN ROUTINE
      *--------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *  LOCK CHECK
     C                     MOVEL'ECQR17'  K@KWD1
     C           K#ABCT    CHAINAB#PPCT              90
     C           *IN90     IFEQ *OFF
     C                     MOVE *BLANK    CTCHR1
     C                     UPDATAB#PPCT1
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *------------------------------------------------------
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      *
     C           KATKEX    KLIST
     C                     KFLD           D@DIE1
     C                     KFLD           D@DIE2
     C                     KFLD           D@DIE3
     C                     KFLD           WYY
     C                     KFLD           WMM
      *
     C           KEY1      KLIST
     C                     KFLD           D@DIE1
     C                     KFLD           D@DIE2
      *
     C           KEY       KLIST
     C                     KFLD           WYY
     C                     KFLD           DFSHN1
     C                     KFLD           DFSHN2
     C                     KFLD           DFSHN3
     C           K#AAP     KLIST
     C                     KFLD           DFSHN1
     C                     KFLD           DFSHN2
     C                     KFLD           DFSHN3
      *
     C           K#AGD     KLIST
     C                     KFLD           D@YY
     C                     KFLD           D@MM
      *
     C           K#ABCT    KLIST
     C                     KFLD           K@KWD1  8
      *
     C                     MOVE '01'      W@ID    2
     C                     Z-ADD*YEAR     D@YY
     C                     Z-ADD*MONTH    D@MM
     C                     SUB  1         D@MM
     C           D@MM      IFLE 0
     C                     ADD  12        D@MM
     C                     SUB  1         D@YY
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SCRN1    BEGSR
      *-----------------------------------------------------
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK
     C           *IN99     IFEQ *OFF
     C           *INKE     IFEQ *OFF
     C                     EXSR #SET1
     C           RRN1      IFGT *ZERO
     C                     MOVE '02'      W@ID
     C                     ELSE
     C                     MOVE MSG,1     D@MSG
     C                     ENDIF
      *
     C                     ELSE
      * CREATE FILE FOR DOWNLOADING
     C                     MOVE *ON       *IN50
     C                     WRITEDSP01
      *
     C                     EXSR #LCK
     C                     EXSR #WRT
     C                     MOVE '99'      W@ID
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #CHK      BEGSR
      *-----------------------------------------------------
     C                     SETOF                     616299
     C                     Z-ADDD@FRM     D@MMYY
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ELSE
     C                     Z-ADDD@YY      WYY
     C                     Z-ADDD@YY      WYY1    40
     C                     Z-ADDD@MM      WMM
     C                     Z-ADDD@MM      M1      20
     C                     Z-ADDWYYMM     W@FRM   60
     C                     ENDIF
      *
     C           D@TO      IFEQ *ZERO
     C                     Z-ADDD@FRM     D@TO
     C                     ENDIF
     C                     Z-ADDD@TO      D@MMYY
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6299
     C                     ELSE
     C                     Z-ADDD@YY      WYY
     C                     Z-ADDD@YY      WYY2    40
     C                     Z-ADDD@MM      M2      20
     C                     Z-ADDD@MM      WMM
     C                     Z-ADDWYYMM     W@TO    60
     C                     ENDIF
      *
     C           W@TO      IFLT W@FRM
     C                     SETON                     616299
     C                     ENDIF
      *
     C           *INKE     IFEQ *OFF
     C           D@DIE     ANDEQ*BLANK
     C                     SETON                     6399
     C                     ENDIF
      *
     C           D@DIE     IFNE *BLANK
     C           KEY1      CHAINFCQPL31              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6399
     C                     ENDIF
     C                     ENDIF
      * PERIOD
     C           *IN99     IFEQ *OFF
     C                     Z-ADD*ZERO     YM
     C                     Z-ADD*ZERO     X       20
     C                     Z-ADDW@FRM     WYYMM
     C           1         DO   50        X
     C                     Z-ADDWYYMM     YM,X
     C           WYYMM     IFEQ W@TO
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  1         WMM
     C           WMM       IFGT 12
     C                     Z-ADD1         WMM
     C                     ADD  1         WYY
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SET1     BEGSR
      *-----------------------------------------------------
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @RRN1   40
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
      *
     C                     MOVE D@DIE1    #KAT1
     C                     MOVE D@DIE2    #KAT2
     C                     MOVE D@DIE3    #KAT3
     C           D@DIE3    IFNE *BLANK
     C                     MOVE '-'       #BBB
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     W@TOT  130
     C                     Z-ADD*ZERO     W@CNT   50
      *
     C           1         DO   50        X
     C           YM,X      IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
      *
     C                     CLEARSFL01
      *
     C                     Z-ADD*ZERO     @@QTY  110
     C                     Z-ADD*ZERO     @@CNT   30
     C                     Z-ADDYM,X      WYYMM
     C                     Z-ADDWYY       @@YY
     C                     Z-ADDWMM       @@MM
     C                     Z-ADD@@MMYY    S@MMYY
     C                     MOVE *BLANK    @HIN   12
     C           DFKATA    SETLLGCQTL311
     C           *IN95     DOUEQ*ON
     C           DFKATA    READEGCQTL311                 95
     C           *IN95     IFEQ *OFF
     C           DFSKJY    ANDEQ*BLANK
      *
     C           K#AAP     CHAINAAMPL11              90
     C           *IN90     IFEQ *ON
     C           CKSKJY    ORNE *BLANK
     C                     ITER
     C                     ENDIF
      * SHP QTY
     C           DFSHIN    IFNE @HIN
     C                     EXSR #SHP
     C                     ENDIF
     C                     MOVELDFSHIN    @HIN
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD@@QTY     S@QTY1
     C                     ADD  S@QTY1    W@TOT
      *
     C                     EXSR #USG
     C                     Z-ADD@@CNT     S@CONT
     C                     ADD  S@CONT    W@CNT
     C                     ADD  1         RRN1
     C                     WRITESFL01
      *
     C                     ENDDO
      *
     C           W@TOT     DIV  10000     D@SHQT    H
     C                     Z-ADDW@CNT     D@CONT
     C           W@CNT     IFNE *ZERO
     C           W@TOT     DIV  W@CNT     W@AVR  130H
     C                     ELSE
     C                     Z-ADD*ZERO     W@AVR
     C                     ENDIF
      *
     C           W@AVR     DIV  10000     D@AVSP    H
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SHP      BEGSR
      *-----------------------------------------------------
     C           KEY       CHAINMBEPL051             65
     C           *IN65     IFEQ *OFF
     C                     ADD  I6S,WMM   @@QTY
      *
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #USG      BEGSR
      *-----------------------------------------------------
      * SETTING USAGE
      *
     C           KATKEX    SETLLECSPL05
     C           *IN20     DOUEQ*ON
     C           KATKEX    READEECSPL05                  20
     C           *IN20     IFEQ *OFF
     C           EQSKJY    ANDEQ*BLANK
     C           EQBMON    ANDEQ0111
      *
     C                     ADD  EQKOSU    @@CNT
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   LOCK CHECK
      *------------------------------------------------------
     C           #LCK      BEGSR
      *  LOCK CHECK
     C                     MOVEL'ECQR17'  K@KWD1
     C           K#ABCT    CHAINAB#PPCT              90
     C           *IN90     IFEQ *OFF
     C           CTCHR1    IFNE *BLANK
     C                     EXFMTDSPWN
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C                     ELSE
     C                     MOVEL#USER     CTCHR1
     C                     UPDATAB#PPCT1
     C                     ENDIF
     C                     ELSE
     C                     CLEARAB#PPCT1
     C                     MOVELK@KWD1    CTKEY1
     C                     MOVEL#USER     CTCHR1
     C                     WRITEAB#PPCT1
     C                     ENDIF
      *
     C                     MOVELKWD,1     P@CMD
     C                     Z-ADD70        P@LEN
     C                     CALL 'QCMDEXC' P#CMD
      *
     C                     OPEN ECQWP17
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CREATE DATA FOR DOWNLOADING
      *------------------------------------------------------
     C           #WRT      BEGSR
      *
     C           *LOVAL    SETLLFCQPL31
     C           *IN80     DOUEQ*ON
     C                     READ FCQPL31                  80
     C           *IN80     IFEQ *OFF
     C           Q4SKJY    ANDEQ*BLANK
     C                     CLEARECQWP171
      *
     C                     MOVE Q4KAT1    #KAT1
     C                     MOVE Q4KAT2    #KAT2
     C                     MOVE *BLANK    #KAT3
     C                     MOVE #KAT1     D@DIE1
     C                     MOVE #KAT2     D@DIE2
     C                     MOVE #KAT3     D@DIE3
     C                     Z-ADD*ZERO     W@TOT  130
     C                     Z-ADD*ZERO     W@CNT   50
      *
     C           1         DO   50        X
     C           YM,X      IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
      *
     C                     Z-ADDYM,X      WYYMM
     C                     Z-ADD*ZERO     @@QTY
     C                     Z-ADD*ZERO     @@CNT
      *
     C                     MOVE *BLANK    @HIN   12
     C           DFKATA    SETLLGCQTL311
     C           *IN95     DOUEQ*ON
     C           DFKATA    READEGCQTL311                 95
     C           *IN95     IFEQ *OFF
      * SHP QTY
     C           K#AAP     CHAINAAMPL11              90
     C           *IN90     IFEQ *ON
     C           CKSKJY    ORNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C           DFSHIN    IFNE @HIN
     C                     EXSR #SHP
     C                     ENDIF
     C                     MOVELDFSHIN    @HIN
     C                     ENDIF
     C                     ENDDO
      *
     C                     ADD  @@QTY     W@TOT
     C                     EXSR #USG
     C                     ADD  @@CNT     W@CNT
     C                     ENDDO
      *
     C*******    W@TOT     IFEQ *ZERO
     C           W@CNT     IFEQ *ZERO
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELDFKATA    EQDIE#
     C           W@TOT     DIV  10000     EQSHPQ    H
     C                     Z-ADDW@CNT     EQCONT
     C           W@CNT     IFNE *ZERO
     C           W@TOT     DIV  W@CNT     W@AVR  130H
     C           W@AVR     DIV  10000     EQAVRS    H
     C                     ENDIF
      *
     C                     WRITEECQWP171
     C                     ENDIF
     C                     ENDDO
      *
      *  LOCK RELEASE
     C                     MOVEL'ECQR17'  K@KWD1
     C           K#ABCT    CHAINAB#PPCT              90
     C           *IN90     IFEQ *OFF
     C                     MOVE *BLANK    CTCHR1
     C                     UPDATAB#PPCT1
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
** CMD
  F1:END     F5:MAKE DATA FOR DOWNLOADING
  F1:END     F12:GO BACK
** KWD
CLRPFM ECQWP17
** MSG
NO DATA
