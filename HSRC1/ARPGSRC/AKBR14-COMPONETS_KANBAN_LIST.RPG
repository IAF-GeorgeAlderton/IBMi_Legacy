     F*          |     |          |          EXPANSION OF THE "KANBAN"*
     F******************************************************* KABR14 **
     FAKBPW14 CF  E                    WORKSTN
     FAKBPL01 IF  E           K        DISK
     FGCKPL21 IF  E           K        DISK
     FAAAPL01 IF  E           K        DISK
     FAKBWP11AO   F     100            DISK
      *------------------------------------------------------------
     E                    CMD     1   1 78
     E                    MSG     1   2 78
      *------------------------------------------------------------
      *
     I            DS
     I                                        1  16 WKNAME
     I            DS
     I                                        1  15 WKBARC
     I                                        1   1 STRBAR
     I                                        2  14 BARSET
     I                                       15  15 ENDBAR
     I            DS
     I                                        1  13 WKEDIT
     I                                        1   10WKKSKB
     I                                        2   5 L1ZETI
     I                                        6   90L1BMON
     I                                       10  10 L1KCD1
     I                                       11  130WKSTNO
      *
     I            DS
     I                                        1   80HYMD8
     I                                        1   40HY
     I                                        5   60HM
     I                                        7   80HD
      *
     I            DS
     I                                        1   60@TIME
     I                                        1   20TIMEH
     I                                        3   40TIMES
      *
     I            DS
     I                                        1  14 @SHIN
     I                                        1   5 L1SHN1
     I                                        6   6 WKF1
     I                                        7  11 L1SHN2
     I                                       12  12 WKF2
     I                                       13  14 L1SHN3
     I            DS
     I                                        1   9 D@LOC
     I                                        1   1 D@LOC1
     I I            '-'                       2   2 D@1
     I                                        3   4 D@LOC2
     I I            '-'                       5   5 D@2
     I                                        6   7 D@LOC3
     I I            '-'                       8   8 D@3
     I                                        9   9 D@LOC4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------------*
      *   INITIAL  SET                                     *
      *----------------------------------------------------*
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@END   1
      *
     C                     MOVE '1'       P@END
      *
     C           KEYT21    KLIST
     C                     KFLD           #KBMON  40
     C                     KFLD           #KTAIP  1
     C           K#AAP     KLIST
     C                     KFLD           L1JOK6
     C                     KFLD           L1KCD1
      *----------------------------------------------------*
     C                     TIME           @TIME   60
     C                     Z-ADD*DATE     HYMD8   80
      *----------------------------------------------------*
     C           K#KEY     KLIST
     C                     KFLD           D@LOC1
     C                     KFLD           D@LOC2
     C                     KFLD           D@LOC3
     C                     KFLD           D@LOC4
      *
     C                     MOVEL'01'      W@ID    2
      *
     C                     ENDSR
      *--------------------------------------------------------
      *   1ST SCREEN
      *--------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #OUT
     C           D@LOC     CAT  MSG,2:1   D@MSG     P
     C                     MOVE *BLANK    D@LOC1
     C                     MOVE *BLANK    D@LOC2
     C                     MOVE *BLANK    D@LOC3
     C                     MOVE *BLANK    D@LOC4
     C                     Z-ADD*ZERO     D@KAN
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *--------------------------------------------------------
      *   CHECK
      *--------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     MOVEA'00'      *IN,61
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    D@MSG
      *
     C           K#KEY     SETLLAKBPL01
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAKBPL01                  90
     C           *IN90     IFEQ *OFF
     C           L1SKJY    ANDEQ*BLANK
     C           L1STHZ    ANDEQ99999999
     C****       L1KMIN    ANDLTL1KMAX
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     MOVE *ON       *IN61
     C                     MOVE *ON       *IN99
     C                     MOVE MSG,1     D@MSG
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      * COMPONENTS  KANBAN DATA                            *
      *----------------------------------------------------*
     C           #OUT      BEGSR
      *
     C                     SETOF                     21
     C                     Z-ADDL1BMON    #KBMON
     C                     MOVE L1TAIP    #KTAIP
     C           KEYT21    CHAINGCKPL211             21
     C           *IN21     IFEQ '0'
     C           T2SKJY    ANDEQ'D'
     C           T2SKHZ    ANDLEHYMD8
     C                     SETON                     21
     C                     END
     C           *IN21     IFEQ '0'
     C                     MOVELT2NAMN    WKNAME
     C                     END
      *
     C                     MOVE '-'       WKF1
     C                     MOVE '-'       WKF2
     C           L1SHN3    IFEQ *BLANK
     C                     MOVE *BLANK    WKF2
     C                     END
     C                     Z-ADDL1SYOS    WKSYOS  60
     C                     Z-ADDL1LTIM    WKLTIM  31
     C                     MOVE L1SYOT    WKSYOT  1
     C                     MOVE L1TKRO    WKTKRO  6
      * A CIRCULATION
     C                     Z-ADDL1KMIN    WKHKNO  50
     C           L1KMIN    IFEQ 0
     C                     Z-ADD1         WKHKNO
     C                     END
      *
     C           D@KAN     IFEQ *ZERO
     C           L1KMAX    SUB  L1KMIN    WKHMAS  50
     C                     ELSE
     C                     Z-ADDD@KAN     WKHMAS
     C                     ENDIF
      *
     C           WKHMAS    IFNE *ZERO
     C                     MOVE '1'       WKCON   1
     C                     MOVE *BLANK    NAME   16
     C                     Z-ADD1         WKSTNO  30
     C                     Z-ADD1         WKEDNO  30
     C                     MOVE *BLANK    WKBARC
     C                     EXCPTFILE
     C                     MOVE *BLANK    WKCON
     C                     SETON                       U1
     C                     END
      *
      *DIVIDE BY KANBAN SHEETS
     C                     SETOF                       22
     C                     DO   *HIVAL
     C                     MOVE WKNAME    NAME   16
     C                     MOVE '2'       WKCON   1
     C                     SUB  1         WKHMAS         22
     C                     Z-ADDWKHKNO    WKSTNO
     C                     Z-ADDL1KMAX    WKEDNO
      *
     C                     MOVE *BLANK    BARSET
      *
     C                     Z-ADDL1KSKB    WKKSKB
      *
     C                     MOVE WKEDIT    BARSET
     C                     MOVE '*'       STRBAR
     C                     MOVE '*'       ENDBAR
      *
     C                     MOVE *BLANK    W22    22
     C           L1JOK6    IFNE *BLANK
     C           K#AAP     CHAINAAAPL01              90
     C           *IN90     IFEQ *OFF
     C           '('       CAT  A5JOKM:1  W22       P
     C           W22       CAT  ')':1     W22       P
     C                     ENDIF
     C                     ENDIF
      *
     C                     EXCPTFILE
     C                     MOVE *BLANK    P@END
     C                     ADD  1         WKHKNO
     C  N22                END
      *
     C                     MOVE *BLANK    WKCON
      *
     C                     ENDSR
      *----------------------------------------------------*
     OAKBWP11AE                FILE
     O                         WKCON      1
     O                         WKSTNO     4
     O                         WKEDNO     7
     O                         NAME      23
     O                         @SHIN     37
     O                         WKBARC    52
     O                         WKLTIM    55
     O                         WKSYOS    61
     O                         WKSYOT    62
     O                         WKTKRO    68
     O                         HYMD8     76
     O                         W22       98
