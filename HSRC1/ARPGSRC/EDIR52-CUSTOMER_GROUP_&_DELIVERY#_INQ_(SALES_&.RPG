     H            Y/                                    1
     H** EDIR52 *******************************************************
     H*  CUSTOMER GROUP/DELIVERY INQUIRY (SALES & SORT)               *
     H*  JW    2017.09.6                                              *
     F*---------------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'EDIR52'
     F*                    PARM           $GRP    3
     F*                    PARM           $TYP    1
     F*   IN  $GRP :  3A CUSTOMER GROUP
     F*       $TYP    1A 1=SALES GROUP, 2=SORTING GROUP
     H*****************************************************************
     FEDIPW52 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN1  KSFILE SFL01
     FEDIPL43 IF  E           K        DISK
JW1  FEDIPL45 IF  E           K        DISK
 "   F            EDIPP421                          KRENAMEEDIPP451
     FEDIPP43 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
      *================================================================
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *     <<
      *
     I           SDS
     I                                     *PROGRAM W@PGM
     I                                      244 253 W@WSID
     I                                      254 263 W@USER
     I                                      264 269 W@JBNO
     C*===============================================================
     C           *ENTRY    PLIST
     C                     PARM           P@GRP   3
     C                     PARM           P@TYP   1
      *
     C           P@TYP     IFEQ '1'
     C                     MOVEL'(SALES)' D1TYP     P
     C                     ENDIF
     C           P@TYP     IFEQ '2'
     C                     MOVEL'(SORT) ' D1TYP     P
     C                     ENDIF
     C*===============================================================
     C*  START  PROGRAM
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
     C                     TIME           @TIME
     C                     MOVEA*ALL'0'   *IN
      *
     C* SFLCLR
     C                     SETON                     72
     C                     WRITECTL01
     C                     SETOF                     72
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         ENDRRN  40
      *
     C           P@GRP     SETLLEDIPP43
      *-----------------------------------
     C                     DO   *HIVAL
     C                     READ EDIPP43                  90
     C   90                LEAVE
      *
     C           E3SKJY    IFEQ 'D'                        DELETE CODE
     C           E3SKHZ    ANDLE@SYSHZ                     DELETE DATE
     C                     ITER
     C                     ENDIF
     C*
     C                     MOVELE3GRP     S1GRP
     C                     MOVELE3GPNM    S1NAME
      * READ DELIVERY
     C**JW1      E3GRP     SETLLEDIPL43
      *
JW1  C           P@TYP     IFEQ '1'
 |   C           E3GRP     SETLLEDIPL43
 |   C                     ELSE
 |   C           E3GRP     SETLLEDIPL45
JW1  C                     ENDIF
      *
     C                     MOVE *OFF      *IN81
     C           *IN81     DOWEQ*OFF
      *
     C**JW1      E3GRP     READEEDIPL43                  81
      *
JW1  C           P@TYP     IFEQ '1'
 |   C           E3GRP     READEEDIPL43                  81
 |   C                     ELSE
 |   C           E3GRP     READEEDIPL45                  81
JW1  C                     ENDIF
      *
     C           *IN81     IFEQ *OFF
     C                     MOVELE4NONY    S1NONY
     C           E4NNY2    CHAINFGBPL01              99
     C           *IN99     IFEQ *OFF
     C                     MOVELB2SMEI    S1NNAM
     C                     ELSE
     C                     MOVE *BLANK    S1NNAM
     C                     ENDIF
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDDO
      *-----------------------------------
     C                     Z-ADDRRN1      ENDRRN
     C                     Z-ADD1         RRN1             ERROR
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
      *===============================================================
      *   DISPLAY SCREEN 1
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     SETON                     70
     C           ENDRRN    IFNE 0
     C                     SETON                     71
     C                     ENDIF
     C                     WRITEDSP01
     C                     EXFMTCTL01
     C                     SETOF                     707199
     C                     Z-ADD$$RRN     RRN1
     C*----------
     C                     SELEC
     C* < F3 > END
     C           *INKA     WHEQ *ON
     C           *INKC     OREQ *ON
     C   KC                MOVE '#END    '@STEP
     C* < PAGE UP/DOWN >
     C           *IN73     WHEQ *ON
     C           *IN73     OREQ *ON
     C                     MOVE '#DSP1   '@STEP
     C* <    >
     C                     OTHER
     C           $RRN      IFNE 0
     C           $RRN      CHAINSFL01                95
     C           *IN95     IFEQ *OFF
     C                     MOVELS1GRP     P@GRP
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
     C                     ENDSR
      *===============================================================
