     C                     PARM           P@TNSU 100
      *内示月度
     C                     MOVELP@NTYM    F@NTYM
     C                     CALL 'AGDRS1'
     C                     PARM           F@NTYM  6
     C                     PARM           F@DAYS  2
     C                     MOVE F@DAYS    F#DAYS  20
      * %0001 STOP
      *７月はトヨタの稼働に合わせて-5
     C                     MOVE F@NTYM    F@NTMM  2
     C**         F@NTMM    IFEQ '07'
     C**                   SUB  5         F#DAYS
     C**                   END
JW6   * 2020/04 SPECIAL
 |   C           F#DAYS    IFEQ 0
 |   C           P@NTYM    ANDEQ202004
 |   C                     Z-ADD22        F#DAYS
JW6  C                     ENDIF
      *
     C           P@NNNM    DIV  F#DAYS    F@NNNM 100
      * N/N+1/N+2を求める
     C                     CALL 'ABBRSD'
     C                     PARM           F@NTYM
     C                     PARM           F@N1
     C                     PARM           F@N2
      * N+1の稼働日
     C                     CALL 'AGDRS1'
     C                     PARM           F@N1    6
     C                     PARM           F@DAY1  2
     C                     MOVE F@DAY1    F#DAY1  20
      * %0001 STOP
      *７月はトヨタの稼働に合わせて-5
     C                     MOVE F@N1      F@N1MM  2
     C**         F@N1MM    IFEQ '07'
     C**                   SUB  5         F#DAY1
     C**                   END
      *
     C           P@1NNM    DIV  F#DAY1    F@1NNM 100
      * N+2の稼働日
     C                     CALL 'AGDRS1'
     C                     PARM           F@N2    6
     C                     PARM           F@DAY2  2
     C                     MOVE F@DAY2    F#DAY2  20
      * %0001 STOP
      *７月はトヨタの稼働に合わせて-5
     C                     MOVE F@N2      F@N2MM  2
     C***        F@N2MM    IFEQ '07'
     C***                  SUB  5         F#DAY2
     C***                  END
      *
     C           P@2NNM    DIV  F#DAY2    F@2NNM 100
      *実績- ALL
     C                     CALL 'MBERS1'
     C                     PARM           O@HIN1  5
     C                     PARM           O@HIN2  5
     C                     PARM           O@HIN3  2
     C                     PARM           P@GOKE  80
      *
     C                     Z-ADD0         P@GOKG  80
%0002 * LAST MONTH'S SHIPPING RESULT - TOYOTA
     C                     MOVEL'TYT'     P@GRP   3
     C                     CALL 'MBERS2'
     C                     PARM           O@HIN1  5
     C                     PARM           O@HIN2  5
     C                     PARM           O@HIN3  2
     C                     PARM           P@GRP   3
     C                     PARM           P@GOK2  80
     C                     ADD  P@GOK2    P@GOKG
      *
      * LAST MONTH'S SHIPPING RESULT - SIA
     C                     MOVEL'SIA'     P@GRP   3
     C                     CALL 'MBERS2'
     C                     PARM           O@HIN1  5
     C                     PARM           O@HIN2  5
     C                     PARM           O@HIN3  2
     C                     PARM           P@GRP   3
     C                     PARM           P@GOK2  80
     C                     ADD  P@GOK2    P@GOKG
      *
      * LAST MONTH'S SHIPPING RESULT - AWNC
     C                     MOVEL'AIS'     P@GRP   3
     C                     CALL 'MBERS2'
     C                     PARM           O@HIN1  5
     C                     PARM           O@HIN2  5
     C                     PARM           O@HIN3  2
     C                     PARM           P@GRP   3
     C                     PARM           P@GOK2  80
     C                     ADD  P@GOK2    P@GOKG
      *
      * LAST MONTH'S SHIPPING RESULT - FORD
     C                     MOVEL'FRD'     P@GRP   3
     C                     CALL 'MBERS2'
     C                     PARM           O@HIN1  5
     C                     PARM           O@HIN2  5
     C                     PARM           O@HIN3  2
     C                     PARM           P@GRP   3
     C                     PARM           P@GOK2  80
     C                     ADD  P@GOK2    P@GOKG
      *
      *実績月度
     C                     CALL 'MCEC00'
     C                     PARM           R@DATE  8
     C                     MOVELR@DATE    R@YYMM  6
      *実績月度の稼働日
     C                     CALL 'AGDRS1'
     C                     PARM           R@YYMM  6
     C                     PARM           R@DAYS  2
     C                     MOVE R@DAYS    R#DAYS  20
      * %0001 STOP
      *７月はトヨタの稼働に合わせて-5
     C                     MOVE R@YYMM    R@MM    2
     C***        R@MM      IFEQ '07'
     C***                  SUB  5         R#DAYS
     C***                  END
      * ALL QTY.
     C           R#DAYS    IFNE *ZERO
     C           P@GOKE    DIV  R#DAYS    R@GOKE  80
     C                     ENDIF
      *
%0002 * SPECIFIC GROUP
     C           R#DAYS    IFNE *ZERO
     C           P@GOKG    DIV  R#DAYS    R@GOKG  80
     C                     ENDIF
      * OTHERS
     C           P@GOKE    SUB  P@GOKG    P@GOKO  80
     C           R#DAYS    IFNE *ZERO
     C           P@GOKO    DIV  R#DAYS    R@GOKO  80
     C                     ENDIF
      *
      *内示なし実績
     C           R#DAYS    IFNE *ZERO
     C           P@TNSU    DIV  R#DAYS    R@TNSU  80
     C                     ENDIF
      * N
     C                     ADD  R@TNSU    F@NNNM
      * N+1
     C                     ADD  R@TNSU    F@1NNM
      * N+2
     C                     ADD  R@TNSU    F@2NNM
