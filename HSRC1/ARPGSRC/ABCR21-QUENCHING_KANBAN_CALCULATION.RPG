     H            Y.
     F** ABCR21 ********************
     F* QUENCHING KANBAN CALCULATION *
     F*
     F* TCHK  07/05/11 RE-MAKE
     F* %0001 T.SAKAKI 2020.02.18 ADD PARAMETER
     F*                           CHANGE # OF KANBAN TO 5
     F******************** ABCR21 **
      *有効日*
     I            DS
     I                                        1   80@UHZ
     I                                        1   40WUKYY
     I                                        5   60WUKMM
     I                                        7   80WUKDD
      *所番地*
     I            DS
     I                                        1   6 @ATK
     I                                        1   1 WATK1
     I                                        2   3 WATK2
     I                                        4   5 WATK3
     I                                        6   6 WATK4
      ****************************************************************
      *  PARM                                                        *
      ****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PKEI1   1        計算区分１
     C                     PARM           PKEI2   1        　　　　２
     C                     PARM           PKTSU   9        確定設定数
     C                     PARM           PSYOS   7        自工程収容数
     C                     PARM           PKAKE   2        かける位置
     C                     PARM           PSHN1   5        品番　１
     C                     PARM           PSHN2   5        　　　２
     C                     PARM           PSHN3   2        　　　３
     C                     PARM           PATOB   4        部門
     C                     PARM           PATOK   3        工程
     C                     PARM           PATK1   1        所番地　１
     C                     PARM           PATK2   2        所番地　２
     C                     PARM           PATK3   2        所番地　３
     C                     PARM           PATK4   1        所番地　４
     C                     PARM           PHKLT   2        引取ロット
     C                     PARM           PLOTO   4        焼入ロット
     C                     PARM           PTOLT   3        合計ﾒｰnﾞjbw
     C                     PARM           PANZR   3        安全率
     C                     PARM           PSETO   2        セット
     C                     PARM           PBRAH   2        バラツキ箱数
     C                     PARM           PUKYY   4        有効年
     C                     PARM           PUKMM   2        　　月
     C                     PARM           PUKDD   2        　　日
     C                     PARM           PUBIN   2        　　便
     C                     PARM           PMAKB   4        前工程部門
     C                     PARM           PMTYP   1        　　タイプ
%0001C                     PARM           PRONO   3         FURNACE TURN #
%0001C                     PARM           PHOJI   20        MAINTENANCE TIME
%0001C                     PARM           PONDO   30        TEMPERATURE
%0001C                     PARM           PCO2P   32        CO 2
%0001C                     PARM           PSSKB   1         KANBAN TYPE
      *
%0001C                     PARM           PMISU   5        かんばん枚数
      *
     C                     PARM           PERR    1        エラー
      *
     C                     MOVELPKEI1     WKEI1   1
     C                     MOVELPKEI2     WKEI2   1
     C                     MOVELPKTSU     WKTSU   90
     C                     MOVELPSYOS     WSYOS   70
     C                     MOVELPKAKE     WKAKE   20
     C                     MOVELPSHN1     WSHN1   5
     C                     MOVELPSHN2     WSHN2   5
     C                     MOVELPSHN3     WSHN3   2
     C                     MOVELPATOB     WATOB   40
     C                     MOVELPATOK     WATOK   3
     C                     MOVELPATK1     WATK1   1
     C                     MOVELPATK2     WATK2   2
     C                     MOVELPATK3     WATK3   2
     C                     MOVELPATK4     WATK4   1
     C                     MOVELPHKLT     WHKLT   20
     C                     MOVELPLOTO     WLOTO   20
     C                     MOVELPTOLT     WTOLT   31
     C                     MOVELPANZR     WANZR   32
     C                     MOVELPSETO     WSETO   20
     C                     MOVELPBRAH     WBRAH   20
     C                     MOVELPUKYY     WUKYY   40
     C                     MOVELPUKMM     WUKMM   20
     C                     MOVELPUKDD     WUKDD   20
     C                     MOVELPUBIN     WUBIN   20
     C                     MOVELPMAKB     WMAKB   40
     C                     MOVELPMTYP     WMTYP   1
     C                     MOVE PMISU     WMISU   50
     C                     MOVELPERR      WERR    1
      ****************************************************************
      *                    MAIN
      ****************************************************************
     C*
     C                     EXSR ISUB
     C*
      ****************************************************************
      * （セット枚数ー１）を足す
      ****************************************************************
     C                     Z-ADD0         XSET    30
     C           WSETO     IFGE 1
     C           WSETO     SUB  1         XSET
     C                     ENDIF
     C           WMISU     ADD  XSET      WMISU
      ****************************************************************
      * MOVE *
     C                     MOVELWKEI1     PKEI1
     C                     MOVELWKEI2     PKEI2
     C                     MOVELWKTSU     PKTSU
     C                     MOVELWSYOS     PSYOS
     C                     MOVELWKAKE     PKAKE
     C                     MOVELWSHN1     PSHN1
     C                     MOVELWSHN2     PSHN2
     C                     MOVELWSHN3     PSHN3
     C                     MOVELWATOB     PATOB
     C                     MOVELWATOK     PATOK
     C                     MOVELWATK1     PATK1
     C                     MOVELWATK2     PATK2
     C                     MOVELWATK3     PATK3
     C                     MOVELWATK4     PATK4
     C                     MOVELWHKLT     PHKLT
     C                     MOVELWLOTO     PLOTO
     C                     MOVELWTOLT     PTOLT
     C                     MOVELWANZR     PANZR
     C                     MOVELWSETO     PSETO
     C                     MOVELWBRAH     PBRAH
     C                     MOVELWUKYY     PUKYY
     C                     MOVELWUKMM     PUKMM
     C                     MOVELWUKDD     PUKDD
     C                     MOVELWUBIN     PUBIN
     C                     MOVELWMAKB     PMAKB
     C                     MOVELWMTYP     PMTYP
     C                     MOVE WMISU     PMISU
     C                     MOVELWERR      PERR
      *
     C                     SETON                     LR
     C                     RETRN
      *==============================================================*
      *                                                              *
      * ＩＡＦの計算                                      SUB-5    *
      *                                                              *
      *==============================================================*
     C           ISUB      BEGSR
     C           WKEI2     IFEQ 'Z'
     C                     GOTO IEND1
     C                     END
     C                     Z-ADD0         WMISU
      *日当り箱数*
     C                     Z-ADD0         IWRK1  103
     C                     Z-ADD0         @D     113
     C           WKTSU     DIV  20        IWRK1
     C           WSYOS     IFNE 0
     C           IWRK1     DIV  WSYOS     @D        H
     C                     END
      ****************************************************************
      *計算区分（１）＝＂Ｅ＂＂Ｆ＂                                *
      ****************************************************************
     C           WKEI1     IFEQ 'E'
     C           WKEI1     OREQ 'F'
      *
     C                     Z-ADD0         IWRK2   31
     C                     Z-ADD0         IWRK3   20
     C                     Z-ADD0         IWRK3A  20
     C                     Z-ADD0         IWRK4  113
     C                     Z-ADD0         IWRK5  114
      *
     C                     Z-ADDWTOLT     IWRK2
     C                     Z-ADDWLOTO     IWRK3
     C           IWRK3     SUB  4         IWRK3A
      *
     C           @D        MULT IWRK2     IWRK4
     C                     MULT WANZR     IWRK4
     C           WLOTO     IFGE 4
     C                     ADD  IWRK3A    IWRK4
     C                     END
      *
     C           IWRK3     IFNE 0
     C           IWRK4     DIV  IWRK3     WMISU
     C                     MVR            IWRK5
     C           IWRK5     IFNE 0
     C                     ADD  1         WMISU
     C                     END
     C                     END
      *
     C           WLOTO     IFLT 4
     C           WMISU     ANDLE1
     C                     Z-ADD2         WMISU
     C                     END
      *
     C                     END
      *
     C           IEND1     ENDSR
