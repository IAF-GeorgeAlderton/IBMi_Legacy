     F********************************** CAGR02 **
     FCA#PP51 IP  E                    DISK
     FALAPP06 IF  E           K        DISK
     FCAGWP02 O   F     100            DISK
     I            DS
     I                                        1   80C7SKHZ
     I                                        1   40C7SKYY
     I                                        5   60C7SKMM
     I                                        7   80C7SKDD
     I            DS
     I                                        1   80C7KEHZ
     I                                        1   40C7KEYY
     I                                        5   60C7KEMM
     I                                        7   80C7KEDD
     I            DS
     I                                        1   80TQSKHZ
     I                                        1   40TQSKYY
     I                                        5   60TQSKMM
     I                                        7   80TQSKDD
      *
     C           KEY       KLIST
     C                     KFLD           C7TKR1
     C                     KFLD           C7TKR2
      *
     C           C7SKJY    IFEQ 'D'
     C           C7SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     SETOF                     10
     C                     MOVE '1'       WKUBN   1
     C           KEY       CHAINALAPP061             10
     C           *IN10     IFEQ '0'
     C           TQSKJY    ANDEQ'D'
     C           TQSKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '0'
     C           TQYSCD    IFEQ '2'
     C                     MOVE TQYSCD    WKUBN
     C                     END
     C                     END
      *
     C                     SETON                     U1
     C                     EXCPTF01
      *
     C                     END
      *
     OCAGWP02 E                F01
     O                         C7ZMIS     3
     O                         C7KMIS     6
     O                         C7TKR1     7
