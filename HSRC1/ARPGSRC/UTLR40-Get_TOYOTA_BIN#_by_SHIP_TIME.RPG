      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
     C                     EXSR #INIT
      *
     C           #SDATE    SETGTAB#PP80
     C                     READPAB#PP80                  98
     C           *IN98     IFEQ *OFF
      ***
     C           A8FRDT    IFGE 20080519
     C           1         DO   30        IX      20
     C           #STIME    IFGE FM,IX
     C           #STIME    ANDLETO,IX
     C                     Z-ADDIX        #BIN
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     ELSE
      *
     C           1         DO   30        IX      20
     C           #STIME    IFLE TO,IX
     C                     Z-ADDIX        #BIN
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVEL#BIN      $BIN
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------------
      * INITIAL SETTING
      *--------------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SDATE  8
     C                     PARM           $STIME  6
     C                     PARM           $BIN    2
     C                     PARM           $RTN    1
      *
     C                     MOVEL$SDATE    #SDATE  80
     C                     MOVEL$STIME    #STIME  40
     C                     MOVE '00'      $BIN
     C                     MOVE *BLANK    $RTN
     C                     Z-ADD0         #BIN    20
      *
     C                     ENDSR
