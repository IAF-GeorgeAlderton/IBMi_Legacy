      *
     C* CALUCULATE THE TOTAL WEIGHT PAR PART
     C* (QTY/CONTAINER) * (FINISHED WEIGHT) = NET WEIGHT PER BOX(G)
     C* (NET WEIGHT PER BOX) / 1000      = TOTAL WEIGHT / PART(KG)
     C* TOTAL WEIGHT / PART(KG) X 2.2046 = TOTAL WEIGHT / PART(LBS)
     C* TOTAL WEIGHT / PART(LBS) + 2.3 (CONTAINER WIGHT WITHOUT PART) = TOT
     C           WSYS      MULT A2KASI    WKOT1   92
     C           WKOT1     DIV  1000      WKOT2   92
     C           WKOT2     MULT 2.2046    WKOT2     H
     C                     ADD  2.3       WKOT2
     C                     Z-ADDWKOT2     PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     I2WEIT           QTY
      *
     C                     Z-ADDWSYS      PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     I2QTY            QTY
     C*
     C                     MOVELPOQTY     I2UNIT           QTY/CONT
     C           I2SBN5    IFEQ *BLANK
     C                     MOVELBASBAN    I2SBN5
     C                     ENDIF
     C*
     C           K#43      CHAINAB#PP43              97
     C           *IN97     IFEQ *OFF
     C                     MOVELDASBAN    I2SBN5    P
     C                     MOVELDASTRA    I2ADDR
      * TTAI
JWH  C           PNONY     IFEQ '3511'
 |   C           PNONY     OREQ '3512'
 |   C           PNONY     OREQ '3513'
 |   C           PNONY     OREQ '3550'
 |   C           PNONY     OREQ '3556'
 |   C           PNONY     OREQ '3571'
JWP  C           PNONY     OREQ '4022'                     YKTA(TTAI)
     C           BASYOS    IFNE *ZERO
     C           BASRYO    DIV  BASYOS    ##CONT  40
     C                     ELSE
     C                     Z-ADD*ZERO     ##CONT
     C                     ENDIF
 |   C                     MOVELBANOTM    I2SBN5
 |   C                     MOVELDASBAN    I2SB10
 |   C                     MOVELBAINVN    I2FLD1
     C                     MOVELDAECS     I2ADDR
     C                     MOVELDAFLD3    I2RELS
     C                     MOVELDASNAM    I2CNAM
     C                     MOVELDASUNM    I2FLDA
     C                     MOVELDALIAD    I2TTL1
     C                     MOVEL##CONT    I2ZETI
      *
JWZ  C           PNONY     IFEQ '3550'
 .   C           PNONY     OREQ '3556'
 .   C                     MOVELDAFLD4    I2FLDB    P
JWZ  C                     ENDIF
      *
JWH  C                     ENDIF
