      ***********************************************************
      * 3611M: SIA SUBARU MASTER LABEL
      ***********************************************************
     C           @3611M    BEGSR
      *
     C                     Z-ADD*ZERO     @@CNTM  60
     C  N88      KEY1      SETLLAB#PL131
     C  N88      KEY1      READEAB#PL131                 93
      *
     C   88      KEY6      SETLLAB#PL131
     C   88      KEY6      READEAB#PL131                 93
     C           *IN93     DOWEQ'0'
     C           BASKJY    IFNE ' '
     C                     GOTO #RED4M
     C                     ENDIF
      * ORDER# SELECTED ?
     C           PORD#     IFNE *BLANK
     C           PORD#     ANDNEBAODRN
     C                     GOTO #RED4M
     C                     ENDIF
      *
     C           BIN       IFNE 0
     C           BIN       ANDNEBANOBN
     C                     GOTO #RED4M
     C                     ENDIF
      *
     C           PNUKE     IFNE *BLANK
     C           BANUKE    ANDNEPNUKE
     C                     GOTO #RED4M
     C                     ENDIF
      *
      * currently only edi orders have the information necessary for master
      * pallet labels.
     C           BAEDIK    IFNE 'E'
     C                     GOTO #RED4M
     C                     ENDIF
      *
     C                     CLEARAB#WP2L1
      *
     C                     ADD  1         @@CNTM
      *
      * get asn sequence number ===========================
     C           @@CNTM    IFEQ 1
     C**                   CALL 'RTVR02'
     C**                   PARM           @@SQ#
JXC   * GET ASN#
 .   C                     MOVELPNOHZ     $NOHZ2
 .   C                     CALL 'UEXR57 '
 .   C                     PARM           $NOHZ2  8
JXC  C                     PARM           $ASN   12
     C                     ENDIF
      *====================================================
      *
     C                     MOVELBANONY    H2NONY
     C                     MOVELBATOKU    L2TOKU
     C                     MOVELBANKOJ    H2NKOJ
     C                     MOVELWMHIN     L2MHIN           PART
     C                     MOVELBAODRN    L2ODRN           ORDER #
     C                     MOVELPNOHZ     L2NYMD           SHIP DATE
      *
     C                     MOVE BAMHN1    WAMHN1
     C                     MOVE BAMHN2    WAMHN2
     C                     MOVE BAMHN3    WAMHN3
     C                     MOVE BAMHN4    WAMHN4
      *
     C           K#43      SETLLAB#PP43
     C                     DO   *HIVAL
     C           K#43      READEAB#PP43                  97
     C   97                LEAVE
      *
     C           DASKJY    IFNE *BLANK
JX1  C           DALDC     OREQ *BLANK
     C                     ITER
     C                     ENDIF
      *
     C           BAODRN    IFEQ DADEL#
     C                     MOVELDASUNM    L2SIRE
JW   C                     MOVELDAPANM    L2MNAM    P
JW   C                     MOVELDAECS     H2CNAM    P
     C                     MOVELDAMANC    H2NUKE           DOCK CODE
     C                     MOVELDALDC     L2WHLC    P      UNIQUE PALLET KEY1
     C                     MOVELDASUB#    L2FTLC    P      UNIQUE PALLET KEY2
     C                     MOVELDAODCD    L2SERI           SUBARU ORDER CODE
      *
      * build ASN# for Master Label.
     C**JW                 MOVELL2SIRE    @@SUPC
     C**                   MOVEL@@ASN#    H2SERL
JXC  C                     MOVEL$ASN      H2SERL
      *
      * update file with subaru asn# so it can print on label & be sent via edi
     C**                   MOVEL@@ASN#    DAREL#    P
JXC  C                     MOVEL$ASN      DAREL#    P
      *
     C                     UPDATAB#PP431
      *
      ***  use destination name to retrieve destination code.
     C                     Z-ADD1         X
     C           DAMANI    LOKUPDEST1,X                  97
     C           *IN97     IFEQ *ON
     C                     MOVELDEST2,X   JW1    10
     C                     ELSE
     C                     MOVE *BLANKS   JW1
     C                     ENDIF
      *
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
      * QTY/CONTAINERS
     C                     Z-ADDBASRYO    PIQTY
      *
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     H2SYOS
      *
     C           BAUSYS    IFNE *ZERO
     C                     Z-ADDBAUSYS    WSYS
     C                     ELSE
     C           BASYOS    IFNE *ZERO
     C                     Z-ADDBASYOS    WSYS
     C                     ELSE
     C                     Z-ADDBASRYO    WSYS
     C                     ENDIF
     C                     ENDIF
     C*
      * USER ONLY MARKED
      *
     C           BASRYO    DIV  WSYS      Q
     C                     MVR            WRST
     C           WRST      IFNE *ZERO
     C                     ADD  1         Q
     C                     ENDIF
      *
     C                     Z-ADDQ         PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     L2SBAN
     C                     MOVE *OFF      *IN66
      *
     C           1         DO   Q
      *
      * SERIAL# SELECTED ?
     C           SER3F     IFNE *ZERO
     C           WSEQ##    IFLT SER3F
     C           WSEQ##    ORGT SER3T
     C                     GOTO #RED4M
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     WRITEAB#WP2L1
%2   C*
