     C* QTY/CONTAINERS
     C           BAUSYS    IFNE *ZERO
     C                     Z-ADDBAUSYS    WSYS    60
     C*
     C                     ELSE
     C           BASYOS    IFNE *ZERO
     C                     Z-ADDBASYOS    WSYS
     C                     ELSE
     C                     Z-ADDBASRYO    WSYS
     C                     ENDIF
     C                     ENDIF
      *
      *  calculate container weight
      *
      * (QTY/CONTAINER) * (FINISHED WEIGHT) = NET WEIGHT PER BOX(G)
      * (NET WEIGHT PER BOX) / 1000      = TOTAL WEIGHT / PART(KG)
      * TOTAL WEIGHT / PART(KG) X 2.2046 = TOTAL WEIGHT / PART(LBS)
      * TOTAL WEIGHT / PART(LBS) + 2.3 (CONTAINER WIGHT WITHOUT PART) = TOT
     C           WSYS      MULT PCSWGT    WKOT1
     C           WKOT1     DIV  1000      WKOT2
     C           WKOT2     MULT 2.2046    WKOT2     H
     C                     ADD  2.3       WKOT2
     C                     Z-ADDWKOT2     PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     @Q21
      *
      *
     C                     Z-ADDWSYS      PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     G2QTY            QTY
     C                     MOVE WSYS      @Q8
     C                     Z-ADD*ZERO     @KSNO   40
      *=============================================
      * PRINT WHEN *IN88 = *ON
      *=============================================
 B2  C           *IN88     IFEQ '1'
     C*
     C* USER SELECTED NUMBER OF LABEL
     C                     Z-ADD*ZERO     @@Q     40
  B3 C           @#LAB     IFNE *ZERO
     C                     Z-ADD@#LAB     Q
   B4C           1         DO   Q
      *
     C                     ADD  1         WSEQ##
     C                     EXSR @NMBR
      *
     C                     MOVE N3NMBR    G2SERL
     C                     MOVELPNONY     G2SERL
     C                     MOVE G2SERL    G2FILR
     C                     EXSR #PP70
     C                     ADD  1         @KSNO
     C                     MOVE @KSNO     G2KSEQ
     C                     ADD  1         @@Q
     C                     MOVE @@Q       @Q9
     C                     MOVEL@@QR      G2QRCD
      *
     C                     EXSR QR0492
     C                     MOVELQRCODE    G2QRCD
      *
   B5C                     DO   W#LAB
     C                     WRITEAB#WP2G1
   E5C                     ENDDO
     C*
     C                     MOVEL'AB#WP2G 'IXWRKF    P
     C                     MOVE '-2'      IXWRKF
     C                     EXSR #XP01                      =>AB#XP01
     C*
  E4 C                     ENDDO
      *
     C                     GOTO #READW
     C*
     C                     ELSE
     C           @FLAG     IFEQ *BLANK
     C                     GOTO #READW
     C                     END
     C*
  E3 C                     ENDIF
 E2  C                     ENDIF
     C*= #3 ==============
     C* PRINT EACH LABEL
     C*===================
     C           BASRYO    DIV  WSYS      Q
     C                     MVR            WRST
     C           WRST      IFNE *ZERO
     C                     ADD  1         Q
     C                     END
     C*
     C                     MOVE *OFF      *IN66
     C                     Z-ADD*ZERO     @@Q     40
 B2  C           1         DO   Q
     C*
     C                     ADD  1         WSEQ##
     C                     ADD  1         @@Q
     C                     MOVE @@Q       @Q9
     C* SERIAL# SELECTED ?
  B3 C           SER3F     IFNE *ZERO
   B4C           WSEQ##    IFLT SER3F
     C           WSEQ##    ORGT SER3T
     C                     GOTO #READW
   E4C                     END
  E3 C                     END
      *
     C                     EXSR @NMBR
      *
     C                     MOVE N3NMBR    G2SERL
     C                     MOVELPNONY     G2SERL
     C                     MOVE G2SERL    G2FILR
      *
     C                     EXSR #PP70
     C                     ADD  1         @KSNO
     C                     MOVE @KSNO     G2KSEQ
     C                     MOVE @@QR      G2QRCD
      *
     C                     EXSR QR0492
     C                     MOVELQRCODE    G2QRCD
      *
  B3 C                     DO   W#LAB
     C                     WRITEAB#WP2G1
  E3 C                     ENDDO
     C*
     C                     MOVEL'AB#WP2G 'IXWRKF    P
     C                     MOVE '-3'      IXWRKF
     C                     EXSR #XP01                      =>AB#XP01
     C*
 E2  C                     ENDDO
