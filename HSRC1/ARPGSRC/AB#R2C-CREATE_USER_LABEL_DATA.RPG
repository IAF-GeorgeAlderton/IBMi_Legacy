     C* QTY/BOX CHECK
     C***********************************************************
     C           #SYSCH    BEGSR
      *
     C                     Z-ADD*ZERO     RRN2    40
     C                     MOVE *ON       *IN54
     C                     WRITECTL02
     C                     MOVE *OFF      *IN54
      *
     C                     Z-ADD*ZERO     @ITM    30
      *
     C           KEY1      SETLLAB#PL13
     C           *IN93     DOUEQ*ON
     C           KEY1      READEAB#PL131                 93
     C           *IN93     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           PORD#     IFNE *BLANK
     C           PORD#     ANDNEBAODRN
     C                     ITER
     C                     ENDIF
     C           BIN       IFNE *ZERO
     C           BANOBN    ANDNEBIN
     C                     ITER
     C                     ENDIF
     C           PNUKE     IFNE *BLANK
     C           BANUKE    ANDNEPNUKE
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         @ITM
      *
     C           BASYOS    IFEQ *ZERO
     C                     MOVE BATOKU    PTOKU
     C                     MOVE BANONY    PNONY
     C                     MOVE *BLANK    @SHIN
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           BANKOJ
     C                     PARM           BANUKE  4
     C                     PARM           WMHIN
     C                     PARM           @SHIN
     C                     PARM           @FLG    1
     C                     MOVE @SHN1     BASHN1
     C                     MOVE @SHN2     BASHN2
     C                     MOVE @SHN3     BASHN3
     C           KEY2      CHAINFCEPL011             91
     C           *IN91     IFEQ *OFF
     C                     Z-ADDA2SSYS    BASYOS
     C                     ENDIF
     C                     ENDIF
      *
     C           BASYOS    IFNE *ZERO
     C           BASRYO    DIV  BASYOS    @@BOX   50
     C                     MVR            @@MVR   50
     C           @@MVR     IFNE *ZERO
     C                     ADD  1         RRN2
     C                     MOVE BASHN1    S@PRT1
     C                     MOVE BASHN2    S@PRT2
     C                     MOVE BASHN3    S@PRT3
     C                     Z-ADDBAUSYS    S@BOX1
     C                     Z-ADDBASYOS    S@BOX2
     C                     Z-ADDBASRYO    S@QTY
     C                     MOVE INF,2     S@MSG
     C                     WRITESFL02
     C                     ENDIF
     C                     ENDIF
      *
     C           BAUSYS    IFNE BASYOS
     C           BAUSYS    ANDNE*ZERO
     C           BASYOS    ANDNE*ZERO
     C                     ADD  1         RRN2
     C                     MOVE BASHN1    S@PRT1
     C                     MOVE BASHN2    S@PRT2
     C                     MOVE BASHN3    S@PRT3
     C                     Z-ADDBAUSYS    S@BOX1
     C                     Z-ADDBASYOS    S@BOX2
     C                     Z-ADDBASRYO    S@QTY
     C                     MOVE INF,1     S@MSG
     C                     WRITESFL02
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
