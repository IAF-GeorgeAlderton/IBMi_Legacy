     H            Y.
     F** AAMR82 ********************************************
     F*かんばん回転日数データ作成(ADHPP01)               *
     F*   MSK.                            2011.02.15       *
     F* %0001 02/18/20 ADD PARAMETER FOR ABCR21
     F*                CHANGE # OF KANBAN TO 4
     F******************************************************
     FADHPP01 IF  E                    DISK
     FAAMWP80 O   E                    DISK                      A
      *
     I            DS
     I                                        1   80J6SKHZ
     I                                        1   40J6SKYY
     I                                        5   60J6SKMM
     I                                        7   80J6SKDD
      *
     I            DS
     I                                        1   80J6STHZ
     I                                        1   40J6STYY
     I                                        5   60J6STMM
     I                                        7   80J6STDD
      *
     I            DS
     I                                        1   3 J6JBN
     I                                        1   1 J6ATK1
     I                                        2   3 J6ATK2
      *
     I            DS
     I                                        1   3 WKF
     I                                        1   1 WKK1F
     I                                        2   3 WKT1F
      *
     I            DS
     I                                        1   3 WKT
     I                                        1   1 WKK1T
     I                                        2   3 WKT1T
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------*
      *   PLIST                                            *
      *----------------------------------------------------*
      *
     C           *ENTRY    PLIST
     C                     PARM           PBMON   4
     C                     PARM           PKOTE   3
     C                     PARM           PK1F    1
     C                     PARM           PK1T    1
     C                     PARM           PT1F    2
     C                     PARM           PT1T    2
     C                     PARM           POUT    1
     C                     PARM           PCMD    2
     C*****************************************************************
     C           ACALL     PLIST
     C                     PARM           J6KEI1
     C                     PARM           J6KEI2
     C                     PARM           WKTSU
     C                     PARM           WSYOS
     C                     PARM           WKAKE
     C                     PARM           J6SHN1
     C                     PARM           J6SHN2
     C                     PARM           J6SHN3
     C                     PARM           WATOB
     C                     PARM           J6ATOK
     C                     PARM           J6ATK1
     C                     PARM           J6ATK2
     C                     PARM           J6ATK3
     C                     PARM           J6ATK4
     C                     PARM           WHKLT
     C                     PARM           WLOTO
     C                     PARM           WTOLT
     C                     PARM           WANZR
     C                     PARM           WSETO
     C                     PARM           WBRAH
     C                     PARM           WUKYY
     C                     PARM           WUKMM
     C                     PARM           WUKDD
     C                     PARM           WUBIN
     C                     PARM           WMAKB
     C                     PARM           J6MTYP
%0001C                     PARM           J6RONO
%0001C                     PARM           J6HOJI
%0001C                     PARM           J6ONDO
%0001C                     PARM           J6CO2P
%0001C                     PARM           J6SSKB
     C                     PARM           WMISU
     C                     PARM           WERR
      *----------------------------------------------------*
      *   KLIST                                            *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     MOVE PBMON     WKBMON  40
     C                     MOVE PK1F      WKK1F   1
     C                     MOVE PK1T      WKK1T   1
     C           PK1T      IFEQ *BLANK
     C                     MOVEL*HIVAL    WKK1T
     C                     ENDIF
     C                     MOVE PT1F      WKT1F   2
     C                     MOVE PT1T      WKT1T   2
     C           PT1T      IFEQ *BLANK
     C                     MOVEL*HIVAL    WKT1T
     C                     ENDIF
      *
     C                     READ ADHPP011                 81
     C           *IN81     DOWEQ'0'
     C           J6SKJY    IFEQ 'D'
     C           J6SKHZ    ANDLE*DATE
     C                     ELSE
     C           J6STHZ    IFEQ 99999999
     C                     EXSR #SB400
     C           WKOK      IFEQ '1'
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     READ ADHPP011                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------*
      *データ判定                 *
      *-----------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEL'1'       WKOK    1
      *部門
     C           PBMON     IFNE *BLANK
     C           J6ATOB    IFNE WKBMON
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C                     ENDIF
      *工程
     C           PKOTE     IFNE *BLANK
     C           J6ATOK    IFNE PKOTE
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C                     ENDIF
      *番地
     C           J6JBN     IFLT WKF
     C                     MOVEL'0'       WKOK
     C                     ENDIF
     C           J6JBN     IFGT WKT
     C                     MOVEL'0'       WKOK
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *-----------------------------*
      *データ出力                 *
      *-----------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAAMWP801
     C                     MOVELJ6ATOB    W0BMON
     C                     MOVELJ6SHN1    W0SHN1
     C                     MOVELJ6SHN2    W0SHN2
     C                     MOVELJ6SHN3    W0SHN3
     C                     MOVELJ6ATOK    W0KOTE
     C                     MOVELJ6ATK1    W0TKR1
     C                     MOVELJ6ATK2    W0TKR2
     C                     MOVELJ6ATK3    W0TKR3
     C                     MOVELJ6ATK4    W0TKR4
     C                     Z-ADDJ6KTSU    W0KTSU
     C                     Z-ADDJ6KSSU    W0KSSU
     C           J6KSSU    DIV  20        DMY6   103
     C           J6SYOS    IFNE 0
     C           DMY6      DIV  J6SYOS    W0KHSU    H
     C                     ENDIF
     C                     Z-ADDJ6SYOS    W0SYUY
     C                     Z-ADDJ6LOTO    W0LOTK
     C                     Z-ADDJ6KAKE    W0KJNK
     C                     Z-ADDJ6SETO    W0SETO
     C                     Z-ADDJ6KMAX    W0KMAX
     C                     MOVELJ6KCD1    W0KCD1
     C                     MOVELJ6KCD2    W0KCD2
      *
     C                     MOVE J6KEI1    W0KSN1
     C                     MOVE *BLANK    W0KSN3
     C                     MOVE J6KEI2    W0KSN2
     C                     Z-ADDJ6HKLT    W0HITO
     C                     Z-ADDJ6TYLT    W0TYLT
     C                     Z-ADDJ6TOLT    W0LTIM
     C                     Z-ADDJ6ANZR    W0KEIS
     C                     Z-ADD0         W0MAXS
     C                     Z-ADDJ6TSEI    W0CYOU
     C                     MOVE *BLANK    W0KKEY
      ****************************************************************
      *　かんばん枚数　の　計算                              MAIN  *
      ****************************************************************
     C                     MOVE '00000'   WMISU   5
     C                     MOVELJ6KSSU    WKTSU   9
     C                     MOVELJ6SYOS    WSYOS   7
     C                     MOVELJ6KAKE    WKAKE   2
     C                     MOVELJ6NKOJ    WATOB   4
     C                     MOVELJ6HKLT    WHKLT   2
     C                     MOVELJ6LOTO    WLOTO   2
     C                     MOVELJ6TOLT    WTOLT   3
     C                     MOVELJ6ANZR    WANZR   3
     C                     MOVELJ6SETO    WSETO   2
     C                     MOVELJ6BRAH    WBRAH   2
     C                     MOVELJ6UKYY    WUKYY   4
     C                     MOVELJ6UKMM    WUKMM   2
     C                     MOVELJ6UKDD    WUKDD   2
     C                     MOVELJ6UBIN    WUBIN   2
     C                     MOVELJ6MAKB    WMAKB   4
     C                     MOVEL*BLANK    WERR    1
      *
     C                     CALL 'ABCR21'  ACALL
     C                     MOVE WMISU     W@SMAX  50
     C           J6TSEI    IFNE 0
     C           W@SMAX    ADD  J6TSEI    W0SMAX
     C                     ELSE
     C                     MOVE W@SMAX    W0SMAX
     C                     END
     C                     MOVE WLOTO     W0SLOT
     C                     MOVE W0KJNK    W0SJNK
      *
     C                     WRITEAAMWP801
      *
     CSR         ESB500    ENDSR
