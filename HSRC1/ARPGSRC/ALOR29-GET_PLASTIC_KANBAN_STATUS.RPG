     C                     Z-ADDA8DATE    Q@DATE
     C                     Z-ADDA8TIME    Q@TIME
      *
     C           Q@DTTM    IFGE W2DTTM
     C                     Z-ADDQ@DATE    W2DATE
     C                     Z-ADDQ@TIME    W2TIME
     C                     ENDIF
      *
     C                     ADD  4         WMAIS   40       # OF PRELOAD
      *
      * GET # OF LOADING BOXES
     C                     SELEC
     C           P1PPR2    WHEQ 'BZ'
     C                     EXSR #SB110                     BZ
     C           P1PPR2    WHEQ 'DS'
     C                     EXSR #SB120                     DS
     C                     OTHER
     C           PHAFLG    IFEQ '1'
     C                     EXSR #SB130                     JC3,4
     C                     ELSE
     C                     EXSR #SB140                     OTHERS
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     Z-ADDW2DATE    P9LPLD
     C                     Z-ADDW2TIME    P9LPLT
      *
      * GET # OF LOADING BOXES
     C                     SELEC
     C           P1PPR2    WHEQ 'BZ'
