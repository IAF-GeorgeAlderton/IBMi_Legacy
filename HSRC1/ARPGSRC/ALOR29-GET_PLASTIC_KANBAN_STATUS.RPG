     C                     KFLD           P1SHN2
     C                     KFLD           P1SHN3
     C                     KFLD           WW10YY
     C                     KFLD           WW10MM
     C                     KFLD           WW10DD
     C                     KFLD           WW10JJ
     C                     KFLD           WW10FF
      *----------------------------------------------------*
      * MAIN                                             *
      *--------------------------------------------------*
     C                     Z-ADDP1SDAT    W1SDAT
     C                     Z-ADDP1STIM    W1STIM
     C                     Z-ADD0         P9BZK
     C                     Z-ADD0         P9DSK
     C                     Z-ADD0         P9JCK
     C                     Z-ADD0         P9BZI
     C                     Z-ADD0         P9DSI
     C                     Z-ADD0         P9JCI
     C                     Z-ADD0         P9PLBZ
     C                     Z-ADD0         P9PLDS
     C                     Z-ADD0         P9PLJC
     C                     Z-ADD0         P9LPLD
     C                     Z-ADD0         P9LPLT
     C                     Z-ADD0         W2DTTM
     C*
     C                     MOVELP1PPRC    P1PPR2  2
     C*
     C** BZ/DS
     C                     MOVEL'0'       PHBFLG  1
     C**  CHECK DS PROCESS
     C                     MOVEL*BLANK    KB1     1
     C           P1PPRC    IFEQ 'DS '
     C                     MOVELP1PMCN    KB1
     C           KB1       IFEQ 'G'                        DS1
     C           KB1       OREQ 'H'                        DS2
     C           KB1       OREQ 'J'                        DS3
     C           KB1       OREQ 'K'                        DS4
     C                     MOVEL'1'       PHBFLG  1
     C                     ENDIF
     C                     ENDIF
     C** JC
     C                     MOVEL'0'       PHAFLG  1
     C           P1PMCN    IFEQ 'JC3'
     C           P1PMCN    OREQ 'JC4'
     C                     MOVEL'1'       PHAFLG  1
     C                     ENDIF
      ** SB
     C                     MOVEL'0'       PHSBFL  1
      *
     C                     Z-ADD0         WMAIS   40
      * PRELOAD -> LOADING
     C                     EXSR #SB100
      * LOADING -> UNLOADING
     C                     Z-ADD0         WMAIS
     C                     SELEC
     C           P1PPR2    WHEQ 'BZ'
     C                     EXSR #SB200
     C           P1PPR2    WHEQ 'DS '
     C                     EXSR #SB300
     C                     OTHER
     C           PHAFLG    IFEQ '1'
     C                     EXSR #SB400                     JC3,4
     C                     ENDIF
      *
     C                     ENDSL
      ****
     C                     SETON                     LR
     C                     RETRN
      *====================================================
      * CHECK PRELOAD SCAN                               *
      *--------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C           KEYCF1    SETLLALCPP011
     C                     DO   *HIVAL
     C           KEYCF2    READEALCPP011                 21
     C   21                LEAVE
      *
     C           A8SKJY    IFEQ 'D'
     C           A8ERR     ORNE *BLANK
     C           A8BRC3    ORNE *BLANK
     C           A8KIND    ORNE 'P'                        PLASTIC
     C                     ITER
     C                     ENDIF
      *BARCODE 2
     C                     MOVEL*BLANK    WBK12   2
     C                     MOVEL*BLANK    WBK15   5
     C                     MOVEL*BLANK    WBK31   1
     C           2         SUBSTA8BRC2:1  WBK12
     C           5         SUBSTA8BRC2:1  WBK15
     C           1         SUBSTA8BRC2:3  WBK31
      *
     C                     SELEC
     C           P1PPR2    WHEQ 'BZ'
     C           P1PPR2    OREQ 'DS'
     C           WBK12     IFNE P1PPR2
     C                     ITER
     C                     ENDIF
      * JC
     C                     OTHER
     C           WBK31     IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C                     ENDSL
      *
      *  BARCODE 1
     C                     MOVEL*BLANK    WAK11   1
     C                     MOVEL*BLANK    WAK24   4
     C                     MOVEL*BLANK    WAK63   3
     C                     MOVEL*BLANK    WAK92   2
     C           1         SUBSTA8BRC1:1  WAK11
     C           4         SUBSTA8BRC1:2  WAK24
     C           3         SUBSTA8BRC1:6  WAK63
     C           2         SUBSTA8BRC1:9  WAK92
