      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1PPRC  3
     C                     PARM           P1PMCN  3
     C                     PARM           P1SDAT  80
     C                     PARM           P1STIM  60
     C* OUT
     C                     PARM           P9BZK   40        BZ計量済み
     C                     PARM           P9DSK   40        DS計量済み
     C                     PARM           P9JCK   40        JC計量済み
     C* IN
     C                     PARM           P9BZI   40        BZ投入中
     C                     PARM           P9DSI   40        DS投入中
     C                     PARM           P9JCI   40        JC投入中
     C* PRELOAD
     C                     PARM           P9PLBZ  40        BZ PRELOAD
     C                     PARM           P9PLDS  40        DS PRELOAD
     C                     PARM           P9PLJC  40        JC PRELOAD
     C* LAST PRELOAD
     C                     PARM           P9LPLD  80        LAST PL DATE
     C                     PARM           P9LPLT  60        LAST PL TIME
JW1  C* P/T STATUS
"    C                     PARM           P9PLPD  80        PT BF OUT DATE
"    C                     PARM           P9PLPS  40        PT SHIP PRELOAD
      *----------------------------------------------------*
      * KEY LIST                                           *
      *----------------------------------------------------*
     C           KEYCF1    KLIST
     C                     KFLD           P1SHN1
     C                     KFLD           P1SHN2
     C                     KFLD           P1SHN3
     C                     KFLD           P1SDAT
     C                     KFLD           P1STIM
      *
     C           KEYCF2    KLIST
     C                     KFLD           P1SHN1
     C                     KFLD           P1SHN2
     C                     KFLD           P1SHN3
     C*
     C           KEYCF3    KLIST
