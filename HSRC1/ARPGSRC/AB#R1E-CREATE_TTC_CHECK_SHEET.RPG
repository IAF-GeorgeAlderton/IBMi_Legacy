      ******************************************* AB#R1E **
     FAB#PW1E CF  E                    WORKSTN
     FAB#PL12 IF  E           K        DISK
     FAB#WP1E O   E           K        DISK
      *----------------------------------------------------------
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------------
      *    MAIN
      *-----------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------------
     C           K#KEY     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C                     KFLD           D@CUST
     C                     KFLD           D@NONY
      *
     C                     MOVE '01'      W@ID    2
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SCRN1    BEGSR
      *-----------------------------------------------------
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #WRT
     C                     MOVE '99'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #CHK1     BEGSR
      *-----------------------------------------------------
     C                     MOVE *OFF      *IN99
     C                     MOVEA'0000'    *IN,61
      *
     C                     Z-ADDD@SHDT    K@YMD
     C           K#KEY     CHAINAB#PL12              90
     C           *IN90     IFEQ *ON
     C                     MOVEA'1111'    *IN,61
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #WRT      BEGSR
      *-----------------------------------------------------
     C           K#KEY     SETLLAB#PL12
     C           *IN80     DOUEQ*ON
     C           K#KEY     READEAB#PL12                  80
     C           *IN80     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
      *
     C           BANOBN    IFNE D@BIN
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELBAMHN1    E1PRT1
     C                     MOVELBAMHN2    E1PRT2
     C                     MOVELBAMHN3    E1PRT3
