     H            Y
     F*** ALCRS3 ******************************************************
     F*  GET KANBAN ISSUE ADMITTABLE DATE/TIME                        *
     F*---------------------------------------------------------------*
     F*   DATE   |CO.LTD| NAME     | THE CONTENTS                     *
     F*---------------------------------------------------------------*
     F*2021.01.21|DCS   |T.MITSUI  |INITIAL VERSION                   *
     F*2021.03.12|DCS   |T.MITSUI  |ADD PARM                          *
     F*****************************************************************
     F*        INPUT/OUTPUT DEFINED                       *
     F*****************************************************
     F*==< CONVEYANCE PULL SCAN RESULT >==*
     FALCPL08 IF  E           K        DISK
     F*
     F*==< 3 POINT P/T RETRIEVAL SCAN RESULTS FILE >==*
     FALRPL0B IF  E           K        DISK
     F*
     F*==< IAF <-> ATC OR ASJ KANBAN CONNECT M/F >==*
     FALRPL35 IF  E           K        DISK
     F*
     F*==< CALCULATION BIN M/F BY TIME >==*
     FAAIPL11 IF  E           K        DISK
     F*
     E*****************************************************
     E*        ARRAY STRUCTURE DEFINED                    *
     E*****************************************************
     E                    @BIN       24  2 0
     E*
     I*****************************************************
     I*        DATA STRUCTURE DEFINED                     *
     I*****************************************************
     I*==< ALRPL35 >==*
     I*         ( A-PICS BARCODE )
     IR1SBAR      DS
     I                                        1   1 R1SBKK
     I                                        2   5 R1SBZN
     I                                        6   8 R1SBTN
     I                                        9  10 R1SBPN
     I*==< AAIPL11 >==*
     I            DS
     I                                        1  480@BIN
     I                                        1   20CDBI01
     I                                        3   40CDBI02
     I                                        5   60CDBI03
     I                                        7   80CDBI04
     I                                        9  100CDBI05
     I                                       11  120CDBI06
     I                                       13  140CDBI07
     I                                       15  160CDBI08
     I                                       17  180CDBI09
     I                                       19  200CDBI10
     I                                       21  220CDBI11
     I                                       23  240CDBI12
     I                                       25  260CDBI13
     I                                       27  280CDBI14
     I                                       29  300CDBI15
     I                                       31  320CDBI16
     I                                       33  340CDBI17
     I                                       35  360CDBI18
     I                                       37  380CDBI19
     I                                       39  400CDBI20
     I                                       41  420CDBI21
     I                                       43  440CDBI22
     I                                       45  460CDBI23
     I                                       47  480CDBI24
     I*
     C*****************************************************
     C*          PARAMETER DEFINED                        *
     C*****************************************************
     C           *ENTRY    PLIST
     C*                   ( IN )
     C                     PARM           P#CHYU  1
     C                     PARM           P#ZETI  4
     C                     PARM           P#TEHI  3
     C                     PARM           P#PAGE  2
     C                     PARM           P#HTHZ  80       DATE OF KANBAN PUB.
     C                     PARM           P#HTBB  20       BIN  OF KANBAN PUB.
     C                     PARM           P#HTTM  60       TIME OF KANBAN PUB.
     C*                   ( OUT )
     C                     PARM           P#DATE  80       PICKING DATE
     C                     PARM           P#TIME  60       PICKING TIME
     C*
     C*****************************************************
     C*          KEY ITEM DEFINED                         *
     C*****************************************************
     C*==< ALCPL08 : CONVEYANCE PULL SCAN RESULT >==*
     C           K@C08S    KLIST
     C                     KFLD           K@CHYU  1
     C                     KFLD           K@ZETI  4
     C                     KFLD           K@TEHI  3
     C                     KFLD           K@PAGE  2
     C                     KFLD           K@DATE  80
     C                     KFLD           K@TIME  60
     C           K@C08R    KLIST
     C                     KFLD           K@CHYU
     C                     KFLD           K@ZETI
     C                     KFLD           K@TEHI
     C                     KFLD           K@PAGE
     C*
     C*==< ALRPL0B : 3 POINT P/T RETRIEVAL SCAN RESULTS FILE >==*
     C           K@R0BS    KLIST
     C                     KFLD           K@ZETI
     C                     KFLD           K@TEHI
     C                     KFLD           K@PAGE
     C                     KFLD           K@DATE
     C                     KFLD           K@TIME
     C           K@R0BR    KLIST
     C                     KFLD           K@ZETI
     C                     KFLD           K@TEHI
     C                     KFLD           K@PAGE
     C*
     C*==< ALRPL35 : IAF <-> ATC OR ASJ KANBAN CONNECT M/F >==*
     C           K@R35S    KLIST
     C                     KFLD           K@ZETI
     C                     KFLD           K@DATE
     C                     KFLD           K@TIME
     C           K@R35R    KLIST
     C                     KFLD           K@ZETI
     C*
     C*****************************************************
     C*          MAIN ROUTINE                             *
     C*****************************************************
     C*==< INIT CLEAR >==*
     C                     Z-ADD*ZERO     P#DATE
     C                     Z-ADD*ZERO     P#TIME
     C*
     C*==< KEY SET >==*
     C                     MOVELP#CHYU    K@CHYU
     C                     MOVELP#ZETI    K@ZETI
     C                     MOVELP#TEHI    K@TEHI
     C                     MOVELP#PAGE    K@PAGE
     C                     Z-ADDP#HTHZ    K@DATE
     C*
     C                     Z-ADD*ZERO     K@TIME
I----C           P#HTTM    IFNE *ZERO
|    C                     Z-ADDP#HTTM    K@TIME
|    C*
+----C                     ELSE
|I---C           P#HTBB    IFNE *ZERO
||   C*                    ____________
||   C           *LOVAL    SETLLAAIPL11
||   C                     READ AAIPL11                  90
||   C*                    ~~~~~~~~~~~~
||I--C           *IN90     IFEQ '0'
|||  C                     Z-ADD1         J       30
|||  C           P#HTBB    LOKUP@BIN,J                   88
|||I-C           *IN88     IFEQ '1'
|||| C           J         ANDNE24
|||| C           J         MULT 10000     K@TIME
|||E-C                     ENDIF
||E--C                     ENDIF
|E---C                     ENDIF
E----C                     ENDIF
     C*
     C*==< GET FROM ALCPP01 >==*
     C*                    ____________
     C           K@C08S    SETGTALCPL08
     C           K@C08R    READEALCPL08                  91
     C*                    ~~~~~~~~~~~~
D----C           *IN91     DOWEQ'0'
|    C           P#DATE    ANDEQ*ZERO
|I---C           A8B2LZ    IFNE *BLANK
||   C           A8ERR     ANDNE'E'
||   C                     Z-ADDA8DATE    P#DATE
||   C                     Z-ADDA8TIME    P#TIME
||   C*
|+---C                     ELSE
||   C*                    ____________
||   C           K@C08R    READEALCPL08                  91
||   C*                    ~~~~~~~~~~~~
|E---C                     ENDIF
E----C                     ENDDO
     C*
     C*==< GET FROM ALRPP05 >==*
I----C           P#DATE    IFEQ *ZERO
|    C*                    ____________
|    C           K@R0BS    SETGTALRPL0B
|    C           K@R0BR    READEALRPL0B                  92
|    C*                    ~~~~~~~~~~~~
|D---C           *IN92     DOWEQ'0'
||   C           P#DATE    ANDEQ*ZERO
||I--C           PTOKNG    IFNE 'NG'
|||  C                     Z-ADDPTCODT    P#DATE
|||  C                     Z-ADDPTCOTM    P#TIME
|||  C*
||+--C                     ELSE
|||  C*                    ____________
|||  C           K@R0BR    READEALRPL0B                  92
|||  C*                    ~~~~~~~~~~~~
||E--C                     ENDIF
|E---C                     ENDDO
E----C                     ENDIF
     C*
     C*==< GET FROM ALRPP35 >==*
I----C           P#DATE    IFEQ *ZERO
|    C*                    ____________
|    C           K@R35S    SETGTALRPL35
|    C           K@R35R    READEALRPL35                  93
|    C*                    ~~~~~~~~~~~~
|D---C           *IN93     DOWEQ'0'
||   C           P#DATE    ANDEQ*ZERO
||I--C           R1SKJY    IFEQ *BLANK
|||  C           R1SBTN    ANDEQP#TEHI
|||  C           R1HNTE    ANDEQ'OK'
|||  C                     Z-ADDR1COHZ    P#DATE
|||  C                     Z-ADDR1COTI    P#TIME
|||  C*
||+--C                     ELSE
|||  C*                    ____________
|||  C           K@R35R    READEALRPL35                  93
|||  C*                    ~~~~~~~~~~~~
||E--C                     ENDIF
|E---C                     ENDDO
E----C                     ENDIF
     C*
     C*==< FINL >==*
     C                     SETON                     LR
     C                     RETRN
     C*
