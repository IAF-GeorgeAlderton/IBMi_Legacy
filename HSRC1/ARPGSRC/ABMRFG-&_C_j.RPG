     H            Y.
     F** ABMRFG *********************************************
     F*副資材　箱色データ
     F*   HOTTA.          2018.10.04                        *
     F* 2021.01.20 DCS. T.MITSUI
     F*   CHANGE WITH THE NUMBER OF FIGURES EXPANSION OF THE "KANBAN"
     F*******************************************************
     FABMWPF1 IF  E           K        DISK
     FABMWPFE UF  E           K        DISK                      A
     FABHPP40 IF  E           K        DISK
      *
     I            DS
     I                                        1  12 WKSHN
     I                                        1   5 WKSHN1
     I                                        6  10 WKSHN2
     I                                       11  12 WKSHN3
      *
     I            DS
     I                                        1   6 WKTKR
     I                                        1   1 WKTKR1
     I                                        2   3 WKTKR2
     I                                        4   5 WKTKR3
     I                                        6   6 WKTKR4
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  14 SDATE
     I                                        1   6 STIME
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     I              'YELLOW (4INCH)  '    C         WYEL
     I              'PURPLE (FORD)   '    C         WPFO
     I              'PURPLE (5INCH)  '    C         WPUR
     I              'BLUE (4INCH)    '    C         WBLU
     I              'WASHER CAN      '    C         WASH
     I              'YELLOW (5INCH)  '    C         WYEL5
     I              'BLUE (5INCH)    '    C         WBLU5
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
      *
     C                     READ ABMWPF11                 80
     C           *IN80     DOWEQ'0'
     C                     EXSR #SB200
     C*****                MOVELP2BCCD    W1BCCD
     C*****                UPDATABMWPF11
     C                     READ ABMWPF11                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C* <<箱色・名称獲得サブルーチン(ABMRFD) >>
     C           P2MR37    PLIST
     C                     PARM           P2SKBN  1        *処理区分
     C                     PARM           P2BKNO  20       *前工程№
     C                     PARM           P2BKTI  3        *前工程
     C                     PARM           P2JKTI  3        *自工程
     C                     PARM           P2JBMN  4        *自工程部門
     C                     PARM           P2AKTI  3        *次工程
     C                     PARM           P2CKTI  3        *次々工程
     C                     PARM           P2AKKB  3        *後工程機番
     C                     PARM           P2BCCD  1        *箱色コード
     C                     PARM           P2BCNM  6        *箱色名称
     C                     PARM           P2RTCD  1        *リターンコード
     C**                   MOVEL*BLANK    P2SKBN
     C**                   MOVE W1KSE1    P2BKNO
     C**                   MOVELW1KOM1    P2BKTI
     C**                   MOVELW1ATOK    P2JKTI
     C**                   MOVELW1BM      P2JBMN
     C**                   MOVELW1KOA1    P2AKTI
     C**                   MOVELW1KOA2    P2CKTI
     C**                   MOVELW1AKKB    P2AKKB
     C**                   MOVEL*BLANK    P2BCCD
     C**                   MOVEL*BLANK    P2BCNM
     C**                   MOVEL*BLANK    P2RTCD
     C**                   CALL 'ABMRFD'  P2MR37
      *
     C                     MOVELW1BCCD    P2BCCD
     C           P2BCCD    CHAINABMWPFE1             37
     C           *IN37     IFEQ '0'
     C           W1LOT     MULT W1KMAX    @KMAX   50
     C           W2BCCD    IFEQ '%'
     C                     ADD  W1KMAX    W2KMA0
     C                     ELSE
     C                     ADD  @KMAX     W2KMA0
     C                     ENDIF
     C                     UPDATABMWPFE1
     C                     ELSE
     C                     CLEARABMWPFE1
     C                     MOVELP2BCCD    W2BCCD
     C**                   MOVELP2BCNM    W2BCNM
     C           W2BCCD    CHAINABHPP401             25
     C           *IN25     IFEQ '0'
     C                     MOVELA4NAME    W2BCNM
     C                     ENDIF
     C                     SELEC
      *YELLOW (4INCH)
     C           W2BCCD    WHEQ '#'
     C                     MOVEL*BLANK    W2BCNM
     C                     MOVELWYEL      W2BCNM
      *YELLOW (5INCH)
     C           W2BCCD    WHEQ 'Y'
     C                     MOVEL*BLANK    W2BCNM
     C                     MOVELWYEL5     W2BCNM
      *DS DSM
     C           W2BCCD    WHEQ '@'
     C                     MOVEL*BLANK    W2BCNM
     C                     MOVELWPUR      W2BCNM
      *FORD
     C           W2BCCD    WHEQ 'N'
     C                     MOVEL*BLANK    W2BCNM
     C                     MOVELWPFO      W2BCNM
      *BLUE 4ICH
     C           W2BCCD    WHEQ '&'
     C                     MOVEL*BLANK    W2BCNM
     C                     MOVELWBLU      W2BCNM
      *BLUE 5INCH
     C           W2BCCD    WHEQ 'B'
     C                     MOVEL*BLANK    W2BCNM
     C                     MOVELWBLU5     W2BCNM
      *WASHER CAN
     C           W2BCCD    WHEQ '%'
     C                     MOVEL*BLANK    W2BCNM
     C                     MOVELWASH      W2BCNM
     C                     ENDSL
     C           W1LOT     MULT W1KMAX    @KMAX   50
     C           W2BCCD    IFEQ '%'
     C                     Z-ADDW1KMAX    W2KMA0
     C                     ELSE
     C                     Z-ADD@KMAX     W2KMA0
     C                     ENDIF
     C                     WRITEABMWPFE1
     C                     ENDIF
      * DS,DSMは紫追加
     C*****      P2JKTI    IFEQ 'DS '
     C*****      P2JKTI    OREQ 'DSM'
     C*****      'N'       CHAINABMWPFE1             37
     C*****      *IN37     IFEQ '0'
     C*****      W1LOT     MULT W1KMAX    @KMAX   50
     C*****                ADD  @KMAX     W2KMA0
     C*****                UPDATABMWPFE1
     C*****                ELSE
     C*****                CLEARABMWPFE1
     C*****                MOVEL'N'       W2BCCD
     C*****                MOVEL'PURPLE'  W2BCNM
     C*****      W1LOT     MULT W1KMAX    @KMAX   50
     C*****                Z-ADD@KMAX     W2KMA0
     C*****                WRITEABMWPFE1
     C*****                ENDIF
     C*****                ENDIF
      *
     CSR         ESB200    ENDSR
