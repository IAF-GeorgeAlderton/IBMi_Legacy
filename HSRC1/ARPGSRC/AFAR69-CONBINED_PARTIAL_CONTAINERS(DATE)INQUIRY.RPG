     H            Y.
     F** AFAR69 *********************************************
     F*  CONBINED PARTIAL CONTAINERS(DATE)INQUIRY *
     F*      DEC/18/01                                      *
     F******************************************* AFAR69 ****
     FAFAPW69 CF  E                    WORKSTN
     F                                              KINFDS @INFDS
     F                                        RRN1  KSFILE SFL01
     FAFAPL65 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     ********************************************************
     E                    ERR     1   2 60
     I@INFDS      DS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I* SYSTEM DATE
     I            DS
     I                                        1  120WTIME
     I                                        1   60SYTM1
     I                                        7  120SYDT1
     I            DS
     I                                        1   80W@DATE
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80AADATE
     I                                        1   40AAYYYY
     I                                        5   60AAMMMM
     I                                        7   80AADDDD
     I            DS
     I                                        1   20AAKOHH
     I                                        3   40AAKOSS
     I                                        1   40ARKOTM
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *---------------------------------------------------------
      *   MAIN ROUTINE
      *---------------------------------------------------------
     C           @@ID      DOUEQ'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C           @@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *---------------------------------------------------------
      *   INITIAL ROUTINE
      *---------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           PUSER  10
      *
     C           K#AFA     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C                     MOVE '01'      @@ID    2
      *
     C                     ENDSR
      *---------------------------------------------------------
      *    1ST SCREEN
      *---------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     WRITEAFAPW691
     C                     EXFMTAFAPW692
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET
     C           RRN1      IFEQ *ZERO
     C                     SETON                     9933
     C                     MOVE ERR,2     @MSG
     C                     ELSE
     C                     MOVE '02'      @@ID
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *---------------------------------------------------------
      *    CHECK
      *---------------------------------------------------------
     C           #CHK1     BEGSR
     C*
     C                     SETOF                     3399
     C                     MOVE *BLANK    @MSG
     C           DSENDD    IFLT DSSTRD
     C                     SETON                     3399
     C                     MOVE ERR,1     @MSG
     C                     ENDIF
      *
     C                     ENDSR
      *---------------------------------------------------------
      *  SET DATA
      *---------------------------------------------------------
     C           #SET      BEGSR
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @@RRN   40
     C                     MOVE *OFF      *IN80
     C                     MOVE *ON       *IN71
     C                     WRITESFLCTL
     C                     MOVE *OFF      *IN71
      *
     C                     Z-ADDDSSTRD    W@DATE
     C           K#AFA     SETLLAFAPL65
     C                     EXSR #SET11
      *
     C                     ENDSR
      *---------------------------------------------------------
      *  SET DATA
      *---------------------------------------------------------
     C           #SET11    BEGSR
      *
     C                     Z-ADD@@RRN     RRN1
     C                     Z-ADD*ZERO     @CNT    20
     C                     CLEARSFL01
      *
     C           *IN80     DOWEQ*OFF
     C                     READ AFAPL65                  80
     C           *IN80     IFEQ *OFF
     C           DSENDD    IFNE *ZERO
     C           AADATE    ANDGTDSENDD
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVE AANLOT    @NLOT
     C                     MOVE AADATE    @UPDAY
     C                     MOVELAAKOME    @MEMB
     C                     MOVE AAKAN1    @KAN1
     C                     MOVE AAKAN2    @KAN2
     C                     MOVE AAKAN3    @KAN3
     C                     MOVE AALOT1    @LOT1
     C                     MOVE AALOT2    @LOT2
     C                     MOVE AALOT3    @LOT3
     C                     MOVE AAKAN4    @KAN4
     C                     MOVE AAKAN5    @KAN5
     C                     MOVE AAKAN6    @KAN6
     C                     MOVE AALOT4    @KAN4
     C                     MOVE AALOT5    @KAN5
     C                     MOVE AALOT6    @KAN6
     C                     Z-ADDAACOPY    @COPY
     C           AAUPFG    IFEQ '1'
     C                     MOVE 'S'       @SRPL
     C                     ELSE
     C                     MOVE *BLANK    @SRPL
     C                     ENDIF
     C                     MOVE AAPART    @PART
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ADD  1         @CNT
     C           @CNT      IFEQ 6
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADDRRN1      @@RRN
     C                     Z-ADDRRN1      RRN
      *
     C                     ENDSR
      *---------------------------------------------------------
      *    2ND SCREEN
      *---------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     WRITEAFAPW699
     C                     MOVE *ON       *IN70
     C                     EXFMTSFLCTL
     C                     MOVE *OFF      *IN70
      *
     C                     Z-ADD@@REC     RRN
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      @@ID
     C           *IN38     WHEQ *ON
     C           *IN80     ANDEQ*OFF
     C                     EXSR #SET11
     C           *INKE     WHEQ *ON
     C                     EXSR #PRT
     C                     MOVE '01'      @@ID
     C                     ENDSL
      *
     C                     ENDSR
      *---------------------------------------------------------
      *  PRINT
      *---------------------------------------------------------
     C           #PRT      BEGSR
      *
     C                     MOVE *OFF      *IN98
     C                     TIME           SYTM1   60
     C                     Z-ADDDSSTRD    DAT1    60
     C                     Z-ADDDSENDD    DAT2    60
     C                     MOVELPUSER     @USER   7
     C           K#AFA     SETLLAFAPL65
      *
     C           *IN90     DOUEQ*ON
     C                     READ AFAPL65                  90
     C           *IN90     IFEQ *OFF
     C           DSENDD    IFNE *ZERO
     C           AADATE    ANDGTDSENDD
     C                     LEAVE
     C                     ENDIF
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED1
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
      *
     C           AAUPFG    IFEQ '1'
     C                     MOVE 'S'       @@SPL   1
     C                     ELSE
     C                     MOVE *BLANK    @@SPL
     C                     ENDIF
     C                     EXCPT@OUT
      *
     C           AAKAN2    IFNE *BLANK
     C   OF                EXCPT@HED1
     C                     EXCPT@OUT2
     C                     ENDIF
      *
     C           AAKAN3    IFNE *BLANK
     C   OF                EXCPT@HED1
     C                     EXCPT@OUT3
     C                     ENDIF
      *
     C           AAKAN4    IFNE *BLANK
     C   OF                EXCPT@HED1
     C                     EXCPT@OUT4
     C                     ENDIF
      *
     C           AAKAN5    IFNE *BLANK
     C   OF                EXCPT@HED1
     C                     EXCPT@OUT5
     C                     ENDIF
      *
     C           AAKAN6    IFNE *BLANK
     C   OF                EXCPT@HED1
     C                     EXCPT@OUT6
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     OQPRINT  E    2           @HED1
     O                                  131 '.....................'
