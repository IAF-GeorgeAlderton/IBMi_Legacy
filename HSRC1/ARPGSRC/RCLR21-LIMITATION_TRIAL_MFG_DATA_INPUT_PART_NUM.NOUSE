     C           1         CHAINRAANPNO              10
     C           *IN10     IFEQ '1'
     C                     MOVE *BLANK    AAAAAA
     C                     Z-ADD0         BBBBBB
     C                     END
      *
     C           TNO       IFEQ AAAAAA
     C                     ADD  1         BBBBBB
     C                     Z-ADDBBBBBB    TNO13
     C                     ELSE
     C                     MOVE TNO       AAAAAA
     C                     Z-ADD1         BBBBBB
     C                     Z-ADD1         TNO13
     C                     END
      *
     C           *IN10     IFEQ '0'
     C                     EXCPTUPR
     C                     ELSE
     C                     EXCPTADR
     C                     END
     C                     END
      *
     C                     ADD  1         TNO2W
     C                     ADD  1         @THNO
      *
     C           @THNO     IFGE 100
      *
     C                     SETOF                     10
     C           1         CHAINRAANPNO              10
     C           *IN10     IFEQ '0'
     C                     ADD  1         BBBBBB
     C                     Z-ADDBBBBBB    TNO13
     C                     Z-ADD1         TNO2W
     C                     Z-ADD1         @THNO
     C                     EXCPTUPR
     C                     END
      *
     C                     END
