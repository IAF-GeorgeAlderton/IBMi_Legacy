     C           #INV      BEGSR
      *-----------------------------------------------
     C                     Z-ADD*DATE     @@DAT
     C                     MOVELWNONY     K@KWD2    P
     C           K#PCT     CHAINAB#PPCT              93
     C           *IN93     IFEQ *OFF
     C           CTNBR1    IFEQ @@YM
     C                     ADD  1         CTNBR2
     C                     ELSE
     C                     Z-ADD@@YM      CTNBR1
     C                     Z-ADD1         CTNBR2
     C                     ENDIF
     C                     UPDATAB#PPCT1
     C                     ELSE
     C                     CLEARAB#PPCT1
     C                     MOVELK@KWD1    CTKEY1
     C                     MOVELK@KWD2    CTKEY2
     C                     Z-ADD@@YM      CTNBR1
     C                     Z-ADD1         CTNBR2
     C                     WRITEAB#PPCT1
     C                     ENDIF
      *
     C                     MOVE @@YM4     @@INV1
     C                     MOVE CTNBR2    @@INV2
     C                     MOVE @@INVO    WINVO
      *
     C                     ENDSR
      *-----------------------------------------------
     C           #MH       BEGSR
      *-----------------------------------------------
     C           @@M       IFNE *BLANK
     C                     MOVE *BLANK    BA1
     C                     MOVE *BLANK    BA2
     C                     MOVE *BLANK    BA3
     C                     MOVELWMHIN     XMHIN
     C                     MOVE XMHN1     ZMHN1
     C                     MOVE XMHN2     ZMHN2
     C                     MOVE XMHN3     ZMHN3
     C                     MOVE XMHN4     ZMHN4
     C           XMHN4     IFNE *BLANK
     C                     MOVE '-'       BA3
     C                     ENDIF
     C           XMHN3     IFNE *BLANK
     C                     MOVE '-'       BA2
     C                     ENDIF
     C           XMHN2     IFNE *BLANK
     C                     MOVE '-'       BA1
     C                     ENDIF
     C                     MOVELZMHIN     WMHIN     P
     C                     ENDIF
      *
     C                     ENDSR
