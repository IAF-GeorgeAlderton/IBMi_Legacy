      *
     C                     MOVELB1NBAN    @@8     8
     C                     SELEC
     C           B1TOKU    WHEQ 0873
     C                     MOVELB1NBAN    #ODR1
     C                     OTHER
     C                     MOVE B1ODR1    #ODR1  10
     C                     ENDSL
      * FORD
