     C           #P10      BEGSR
      *-----------------------------------------------
     C           K#P10     SETLLAB#PL111
     C           *IN95     DOUEQ*ON
     C           K#P10     READEAB#PL111                 95
     C           *IN95     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BACARD    ANDEQ'MA02'
      *
     C           BANUKE    IFNE PUNUKE
     C                     ITER
     C                     ENDIF
      *
     C           BANOBN    IFNE PUBINN
     C                     ITER
     C                     ENDIF
      *
     C           BAODRN    IFNE PUODRN
     C                     ITER
     C                     ENDIF
      *
     C           BASRYO    IFEQ 0
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE BATOKU    PTOKU   4
     C                     MOVE BANONY    PNONY   4
     C                     MOVE BANKOJ    PNKOJ   1
     C                     MOVE BANUKE    PNUKE   4
     C                     MOVE BAMHIN    $MHIN
     C                     MOVE *BLANK    $SHIN  12
     C                     MOVE *BLANK    $FLG    1
      *
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           $MHIN
     C                     PARM           $SHIN  12
     C                     PARM           $FLG    1
      *
     C           $FLG      IFEQ '*'
     C                     MOVE *BLANK    $MHN3
     C                     MOVE *BLANK    $MHN4
     C                     END
      *
     C                     MOVE BATOKU    @TOKU
     C                     MOVE BANONY    @NONY
     C                     MOVE BANKOJ    @NKOJ
     C                     MOVE BANUKE    @NUKE
     C                     MOVE $MHIN     @MHIN
     C                     MOVE BANOHZ    @HIZK
     C                     Z-ADD0         @TANK
     C                     MOVE *BLANK    @CHEK
      *
     C                     CALL 'FBCR10'
     C                     PARM           @TOKU
     C                     PARM           @NONY
     C                     PARM           @NKOJ
     C                     PARM           @NUKE
     C                     PARM           @MHIN
     C                     PARM           @HIZK
     C                     PARM           @TANK
     C                     PARM           @CHEK
      * UNIT PRICE ERROR
  B6 C           @TANK     IFEQ 0
     C                     MOVE BANONY    D@NONY
     C                     MOVE BANKOJ    D@FACT
     C                     MOVE BANUKE    D@DOCK
     C                     MOVE BAMHN1    D@PRT1
     C                     MOVE BAMHN2    D@PRT2
     C                     MOVE BAMHN3    D@PRT3
     C                     EXFMTDSP03
      *
     C                     MOVE '1'       P@END
     C                     MOVE *ON       *INLR
     C                     RETRN
     C                     END
      *
     C                     MOVE BASBAN    #SBAN
     C                     MOVE BAODRN    #ODR1
      *
     C                     MOVE BASIRE    #SIRE
     C                     MOVE BASIRK    #SIRK
     C                     Z-ADDBANOHZ    WNOHZ
     C                     MOVELBANUKE    WNUKE
     C                     MOVELBANUKE    WNUKE4
     C                     Z-ADDBASRYO    WSRYO
     C                     MOVELBAMHIN    WMHIN
     C                     Z-ADD@TANK     WTANK
     C                     MOVE BACARD    WCARD
     C           BAINVN    CAT  'L':0     WINVO  16
     C                     MOVELBAINVN    WKRLNO 20
     C                     Z-ADDBASYOS    WSYOS
     C                     MOVE BATOKU    WTOKU
     C                     MOVE BANONY    WNONY   4
     C                     MOVE BANKOJ    WNKOJ   1
     C                     MOVE BANOBN    WNBIN   2
     C           BASYOS    IFEQ *ZERO
     C           BAUSYS    ANDNE*ZERO
     C                     Z-ADDBAUSYS    WSYOS
     C                     ENDIF
     C           WINVO     IFEQ *BLANK
     C           @@INVO    IFEQ *BLANK
     C                     EXSR #INV
     C                     ELSE
     C                     MOVE @@INVO    WINVO
     C                     ENDIF
     C                     ENDIF
      *
     C                     EXSR #MH
     C                     EXCPTDT1
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
