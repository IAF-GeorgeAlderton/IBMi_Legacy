     C           B1SRYO    IFEQ 0
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE *BLANK    @@F     1
     C                     MOVE B1NONY    @NON4   4
     C           @NON4     CHAINABF9L01              96
     C           *IN96     IFEQ *OFF
