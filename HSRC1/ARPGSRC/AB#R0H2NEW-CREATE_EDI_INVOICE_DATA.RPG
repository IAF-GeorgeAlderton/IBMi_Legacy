      ** ---------------------------------------------------- **
      *  APPEND A "P" TO THE END OF THE INVOICE#.......
      **
     C           B1NBAN    CAT  'L':0     WINVO  16
      *
      ** ---------------------------------------------------- **
     C*
     C           B1NONY    IFEQ 3511                       TTTX
     C           B1NONY    OREQ 3512                       TTCA
     C           B1NONY    OREQ 3513                       TTMX
     C           B1NONY    OREQ 4022                       YKTA
     C           B1NONY    OREQ 3550                       TTMA
     C           B1NONY    OREQ 3556                       TTAI
     C           B1NONY    OREQ 0250                       APMM
     C           B1NONY    OREQ 8296                       TESLA
     C           K#PK      KLIST
     C                     KFLD           B1NOYY
     C                     KFLD           B1NOMM
     C                     KFLD           B1NODD
     C                     KFLD           B1TOKU
     C                     KFLD           B1NONY
     C                     KFLD           B1NKOJ
     C                     KFLD           B1NUKE
     C                     KFLD           B1NOBI
     C           K#PK      SETLLAB#PL75
     C           *IN90     DOUEQ*ON
     C           K#PK      READEAB#PL75                  90
     C           *IN90     IFEQ *OFF
     C           PUSKJY    ANDEQ*BLANK
     C           B1ODR1    IFEQ PUODRN
     C                     MOVELPUSERL    WINVO     P
     C                     LEAVE
     C                     END
     C                     END
     C                     ENDDO
     C                     END
     C*
     C                     Z-ADDB1SYUY    WSYOS   60
     C                     MOVE B1TOKU    WTOKU   4
     C                     MOVE B1NONY    WNONY   4
     C                     MOVE B1NKOJ    WNKOJ   1
     C                     MOVE B1NOBI    WNBIN   2
     C           WINVO     IFEQ *BLANK
     C           @@INVO    IFEQ *BLANK
     C                     EXSR #INV
     C                     ELSE
     C                     MOVE @@INVO    WINVO
     C                     ENDIF
     C                     ENDIF
      *
     C           B1NONY    IFEQ 0250
     C                     EXSR #APMM
     C                     END
     C*
     C           B1NONY    IFEQ 8296
     C                     EXSR #TESLA
     C                     END
     C*
     C                     EXSR #MH
     C                     EXCPTDT1
      *
     C                     ENDIF
     C                     ENDDO
