     H*****************************************************************
     FAB#PWQ2 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN1  KSFILE SFREC1
     FFGBPL01 IF  E           K        DISK
     FGADPL11 IF  E           K        DISK
     FAB#PPQ1 IF  E           K        DISK
      *================================================================
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                     *PROGRAM W@PGM
     I                                      244 253 W@WSID
     I                                      254 263 W@USER
     I                                      264 269 W@JBNO
     C*===============================================================
     C           *ENTRY    PLIST
     C                     PARM           P@PLNT  8
     C                     PARM           P@SHCD 10
     C*===============================================================
     C*  START  PROGRAM
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
     C                     TIME           @SDATE
     C                     MOVEA*ALL'0'   *IN
      *
     C* SFLCLR
     C                     SETON                     72
     C                     WRITESFCTL1
     C                     SETOF                     72
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         ENDRRN  40
      *
     C           KEY01     KLIST
     C                     KFLD           K@PLNT 10
     C                     KFLD           K@SHCD 10
      *
     C           KEY02     KLIST
     C                     KFLD           Q1TOKU
     C                     KFLD           Q1NONY
      *
     C                     MOVELP@PLNT    K@PLNT 10
     C                     MOVELP@SHCD    K@SHCD 10
     C                     MOVEL*BLANK    P@PLNT
     C                     MOVEL*BLANK    P@SHCD
      *
     C           KEY01     SETLLAB#PPQ1
      *-----------------------------------
     C                     DO   *HIVAL
     C                     READ AB#PPQ1                  90
     C   90                LEAVE
     C*
     C           Q1SKJY    IFEQ 'D'                        DELETE CODE
     C                     ITER
     C                     ENDIF
     C*
     C                     MOVELQ1PLNT    S1PLNT
     C                     MOVELQ1SHCD    S1SHCD
     C                     MOVELQ1TOKU    S1TOKU
     C                     MOVELQ1NONY    S1NONY
     C                     MOVEL*BLANK    S1SMEI
     C                     MOVEL*BLANK    S1KMEI
     C*
     C           Q1TOKU    CHAINFGBPL01              91
     C  N91      B2SKJY    IFEQ 'D'
     C                     SETON                     91
     C                     ENDIF
     C                     MOVELB2SMEI    S1SMEI
     C*
     C           KEY02     SETLLGADPL11
     C                     DO   *HIVAL
     C           KEY02     READEGADPL11                  91
     C   91                LEAVE
     C           B5SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C                     MOVELB5KMEI    S1KMEI
     C                     LEAVE
     C                     ENDDO
     C*
     C                     ADD  1         RRN1
     C                     WRITESFREC1
     C*
     C                     ENDDO
      *-----------------------------------
     C                     Z-ADDRRN1      ENDRRN
     C                     Z-ADD1         RRN1             エラー
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
      *===============================================================
      *  DISPLAY SCREEN 1
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     SETON                     70
     C           ENDRRN    IFNE 0
     C                     SETON                     71
     C                     ENDIF
     C                     WRITEDSP01
     C                     EXFMTSFCTL1
     C                     SETOF                     707199
     C                     Z-ADD$$RRN     RRN1
     C*----------
     C                     SELEC
     C* < F3 >  EXIT
     C           *INKC     WHEQ *ON
     C   KC                MOVE '#END    '@STEP
     C* < PAGE UP/DOWN >
     C           *IN73     WHEQ *ON
     C           *IN73     OREQ *ON
     C                     MOVE '#DSP1   '@STEP
     C* < ENTR >
     C                     OTHER
     C           $RRN      IFNE 0
     C           $RRN      CHAINSFREC1               95
     C           *IN95     IFEQ *OFF
     C                     MOVELS1PLNT    P@PLNT
     C                     MOVELS1SHCD    P@SHCD
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *===============================================================
