     C                     ENDSR
      *************************************************************
      * INITIAL SETTING
      *************************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4
      *
     C           K#PL13    KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#NOYY
     C                     KFLD           K#NOMM
     C                     KFLD           K#NODD
      *
     C           K#W9M     KLIST
     C                     KFLD           K#NONY
     C                     KFLD           K#MHIN 20
     C**                   KFLD           K#NUKE  4
     C                     KFLD           K#NOHZ  80
      *
     C           K#W9MB    KLIST
     C                     KFLD           K#NONY
     C                     KFLD           K#MHIN
     C**                   KFLD           K#NUKE
      *
     C           K#W9MC    KLIST
