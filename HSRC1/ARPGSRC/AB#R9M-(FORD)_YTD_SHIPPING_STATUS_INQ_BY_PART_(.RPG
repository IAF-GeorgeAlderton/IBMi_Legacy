     C                     MOVEL'01'      W@ID    2
     C                     MOVELTODAY     XYEAR
     C                     Z-ADDTODAY     XSDAT
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         RRN2    40
     C                     Z-ADD0         RCNT    40
     C                     Z-ADD0         @NONY   40
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         SVQTY   80
     C                     MOVE *BLANK    SVNONY  4
     C                     Z-ADD0         SVBOX   60
     C                     Z-ADD0         SVQPC   60
     C                     MOVE *BLANK    SVNKOJ  1
     C                     MOVE *BLANK    SVNUKE  4
     C                     MOVE *BLANK    SVMHIN 20
     C                     Z-ADD0         FCONT   20
     C                     Z-ADD0         DCONT   20
      *
     C                     ENDSR
