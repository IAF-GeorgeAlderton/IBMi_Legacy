     H            Y.
      ** AB#R9M  *********************************************
      *  FORD YTD SHIPPING STATUS INQ BY PART W/O DOCK       *
      *  J.WATANABE 2022.02.02                               *
      ********************************************************
     FAB#PW9M CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                        RRN2  KSFILE SFL02
     FAB#PLA3 IF  E           K        DISK
     FABFPP30 IF  E           K        DISK
     FAB#WP9M UF  E           K        DISK                      A
      ********************************************************
     E                    MSG     1  12 60
      *
     I            DS
     I                                        1   80K#NOHZ
     I                                        1   40K#NOYY
     I                                        5   60K#NOMM
     I                                        7   80K#NODD
      *
     I            DS
     I                                        1  20 S1MHIN
     I                                        1   5 S1MHN1
     I                                        6  10 S1MHN2
     I                                       11  15 S1MHN3
     I                                       16  20 S1MHN4
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *-----------------------------------------------------------*
      *     M  A  I  N  L  I  N  E                                *
      *-----------------------------------------------------------*
      *
     C                     EXSR #INIT
      *
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP1
     C           W@ID      CASEQ'02'      #CTL1
     C                     ENDCS
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *************************************************************
      * DISPLAY 1ST SCREEN
      *************************************************************
     C           #DSP1     BEGSR
      *
     C                     EXFMTDSP01
     C                     MOVEL*BLANKS   XMSG
     C                     MOVE *OFF      *IN85
     C                     MOVE *OFF      *IN41
     C                     MOVE *OFF      *IN42
     C                     MOVE *OFF      *IN43
     C                     MOVE *OFF      *IN44
     C                     MOVE *OFF      *IN45
      * F1/F3: EXIT
     C           *INKA     IFEQ *ON
     C           *INKC     OREQ *ON
     C                     MOVEL'99'      W@ID
     C                     GOTO XDSP1
     C                     ENDIF
      * F9: SHORTAGE INQ
     C           *INKI     IFEQ *ON
     C                     CALL 'AB#R9N '
     C                     GOTO XDSP1
     C                     ENDIF
      * F10: PLANT INQ
     C           *INKJ     IFEQ *ON
     C                     MOVE *BLANK    $PLNT
     C                     CALL 'ABFR07 '
     C                     PARM           $PLNT   5
     C                     GOTO XDSP1
     C                     ENDIF
      *
     C                     EXSR #CHK1
      *
     C           *IN85     IFEQ *OFF
     C                     MOVEL'02'      W@ID
     C                     ENDIF
      *
     C           XDSP1     ENDSR
      *************************************************************
      *  CHECK ENTRY DATA
      *************************************************************
     C           #CHK1     BEGSR
     C                     MOVE *BLANK    XPLNT1
      * CHECK DATE FROM
     C           XYEAR     IFEQ 0
     C                     MOVELMSG,6     XMSG
     C                     SETON                     4185
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           XYEAR     IFLE 2021
     C                     MOVELMSG,2     XMSG
     C                     SETON                     4185
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     MOVELXYEAR     LTR8    8
     C                     MOVE '0101'    LTR8
     C                     MOVELLTR8      $SRC      P
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN1   1
     C           $RTN1     IFNE *BLANK
     C                     MOVELMSG,1     XMSG
     C                     SETON                     4185
     C                     GOTO XCHK1
     C                     ENDIF
      * DELIVERY#
     C           XNONY     IFEQ *BLANK
     C           XPLNT     ANDEQ*BLANK
     C                     MOVELMSG,8     XMSG
     C                     SETON                     4385
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           XNONY     IFNE *BLANK
     C           XPLNT     ANDNE*BLANK
     C                     MOVELMSG,10    XMSG
     C                     SETON                     434485
     C                     GOTO XCHK1
     C                     ENDIF
      * CHECK DELIVERY CODE
     C           XNONY     IFNE *BLANK
     C                     MOVELXNONY     $DLV
     C                     CALL 'UTLR62'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTN2   1
     C           $RTN2     IFEQ '*'
     C                     MOVELMSG,9     XMSG
     C                     MOVE '1'       XMSG
     C                     SETON                     4385
     C                     GOTO XCHK1
     C                     ENDIF
     C                     MOVELXNONY     XNONY1
     C                     MOVEL$NAME1    XNAME
     C                     ENDIF
      * CHECK PLANT CODE AGAIN
     C           XPLNT     IFNE *BLANK
     C                     MOVELXPLNT     $PLNT
     C                     CALL 'UTLR34E'
     C                     PARM           $PLNT   5
     C                     PARM           $NONY1  4
     C                     PARM           $NONY2  4
     C           $NONY1    IFEQ *ZERO
     C                     MOVELMSG,11    XMSG
     C                     SETON                     4485
     C                     GOTO XCHK1
     C                     ENDIF
     C           $NONY1    IFNE *ZERO
     C           $NONY2    ANDNE*ZERO
     C                     MOVELMSG,12    XMSG
     C                     MOVELXPLNT     XMSG
     C                     SETON                     4485
     C                     GOTO XCHK1
     C                     ENDIF
     C                     MOVEL$NONY1    XNONY1
     C                     ENDIF
     C                     MOVELXPLNT     XPLNT1
      * CHECK DELIVERY CODE
     C           XNONY1    IFNE *BLANK
     C                     MOVELXNONY1    $DLV
     C                     CALL 'UTLR62'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTN2   1
     C           $RTN2     IFEQ '*'
     C                     MOVELMSG,9     XMSG
     C                     MOVE '2'       XMSG
     C                     SETON                     4385
     C                     GOTO XCHK1
     C                     ENDIF
     C                     MOVEL$NAME1    XNAME
     C                     ENDIF
      * DEMAND DATE
     C           XSDAT     IFEQ 0
     C                     MOVELMSG,3     XMSG
     C                     SETON                     4585
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     MOVELXSDAT     NUM4    40
     C           XYEAR     IFNE NUM4
     C                     MOVELMSG,7     XMSG
     C                     SETON                     4585
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     MOVELXSDAT     $SRC      P
     C                     CALL 'UTLR01'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE   8
     C                     PARM           $RTN3   1
     C           $RTN3     IFNE *BLANK
     C                     MOVELMSG,7     XMSG
     C                     SETON                     4585
     C                     GOTO XCHK1
     C                     ENDIF
      * IF NO ERROR...
      *   GET PLANT CODE
     C                     MOVELXNONY1    $NONY   4
     C                     MOVE *BLANK    $NUKE
     C                     CALL 'UTLR34D'
     C                     PARM           $NONY   4
     C                     PARM           $NUKE   4
     C                     PARM           $PLNT   5
     C                     PARM           $RTN4   1
     C           XPLNT1    IFEQ *BLANK
     C                     MOVEL$PLNT     XPLNT1
     C                     ENDIF
      *
     C                     MOVELXYEAR     @FROM   80
     C                     MOVE '0101'    @FROM
     C                     MOVELXYEAR     @TO     80
     C                     MOVE '1231'    @TO
     C                     MOVELXNONY1    @NONY
     C                     MOVELXMHIN     $FLD1     P
     C                     CALL 'UUUR05'
     C                     PARM           $FLD1  25
     C                     PARM           $FLD2  25
     C                     MOVEL$FLD2     @MHIN  20
      *
     C           *IN85     IFEQ *OFF
     C                     EXSR #CRTW1
     C                     EXSR #CRTW2
      *
     C           RCNT      IFGT 0
     C                     MOVEL'02'      W@ID
     C                     ELSE
     C                     MOVELMSG,4     XMSG
     C                     SETON                     414285
     C                     ENDIF
     C                     ENDIF
      *
     C           XCHK1     ENDSR
      *************************************************************
      * CREATE WF (AB#WP9M) FROM AB#PLA3 (PP10)
      *************************************************************
     C           #CRTW1    BEGSR
      * CLEAR WORK FILE
     C           *LOVAL    SETLLAB#WP9M
     C                     DO   *HIVAL
     C                     READ AB#WP9M                  99
     C   99                LEAVE
     C                     DELETAB#WP9M1
     C                     ENDDO
      *
     C                     MOVELXNONY1    K#NONY
     C                     Z-ADD@FROM     K#NOHZ
     C           K#PL13    SETLLAB#PLA3
      *
     C                     DO   *HIVAL
     C           @NONY     READEAB#PLA3                  98
     C   98                LEAVE
      * END
     C           BANOHZ    IFGT @TO
     C                     LEAVE
     C                     ENDIF
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           XMHIN     IFNE *BLANK
     C           BAMHIN    ANDNE@MHIN
     C                     ITER
     C                     ENDIF
      *
     C                     CLEARAB#WP9M1
     C                     Z-ADDBATOKU    W8TOKU
     C                     Z-ADDBANONY    W8NONY
     C                     MOVELBANKOJ    W8NKOJ
     C                     MOVELBANUKE    W8NUKE
     C                     Z-ADDBANOHZ    W8NOHZ
     C                     Z-ADDBANOBN    W8NOBN
     C                     MOVELBAMHIN    W8MHIN
     C                     MOVELBAODRN    W8ODRN
     C                     Z-ADDBASRYO    W8QTY
     C                     Z-ADDBASYOS    W8QPC
     C                     Z-ADDBAURHZ    W8URHZ
     C                     MOVELBAEDIK    W8EDIK
     C                     Z-ADDBACRHZ    W8CRHZ
     C           BASYOS    IFEQ 0
     C                     Z-ADD1         W8BOX
     C                     ELSE
     C           BASRYO    DIV  BASYOS    SHO     80
     C                     MVR            REM     80
     C           REM       IFGT 0
     C                     ADD  1         SHO
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADDSHO       W8BOX
      *
     C                     ADD  1         RCNT
     C                     WRITEAB#WP9M1
      *
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************
      * CREATE WF (AB#WP9M) FROM ABFPP30
      *************************************************************
     C           #CRTW2    BEGSR
      *
     C           XPLNT1    SETLLABFPP30
      *
     C                     DO   *HIVAL
     C           XPLNT1    READEABFPP30                  96
     C   96                LEAVE
      * END
     C           CGSIDT    IFLT @FROM
     C           CGSIDT    ORGT @TO
     C                     ITER
     C                     ENDIF
      *
     C           CGDLCD    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           XMHIN     IFNE *BLANK
     C           CGPART    ANDNE@MHIN
     C                     ITER
     C                     ENDIF
      *
     C                     MOVEL@NONY     K#NONY
     C                     MOVELCGPART    K#MHIN    P
     C           K#W9MC    CHAINAB#WP9M              99
     C           *IN99     IFEQ *ON
     C                     EXSR #GETD
     C           $YTDQ     IFNE *ZEROS
     C                     CLEARAB#WP9M1
     C                     Z-ADD5149      W8TOKU
     C                     Z-ADD@NONY     W8NONY
     C                     MOVE '0'       W8NKOJ
     C                     MOVE '00  '    W8NUKE
     C                     Z-ADD@FROM     W8NOHZ
     C                     Z-ADD01        W8NOBN
     C                     MOVELCGPART    W8MHIN
     C                     MOVEL'99999'   W8ODRN    P
     C                     Z-ADD0         W8QTY
     C                     Z-ADD0         W8QPC
     C                     Z-ADD0         W8URHZ
     C                     MOVE ' '       W8EDIK
     C                     Z-ADD0         W8CRHZ
     C                     Z-ADD0         W8BOX
     C                     ADD  1         RCNT
     C                     WRITEAB#WP9M1
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      ************************************************************
      *  GET FORD DEMAND
      ************************************************************
     C           #GETD     BEGSR
      *
     C                     MOVELXSDAT     $END
     C                     MOVELXPLNT1    $PLNT
     C                     MOVELCGPART    $MHIN
     C                     CALL 'UEXR41C'
     C                     PARM           $END    8
     C                     PARM           $PLNT   5
     C                     PARM           $MHIN  20
     C                     PARM           $NONY   4
     C                     PARM           $YTDQ   9
      * ADJUST 2022
     C           XSDAT     IFGE 20220000
     C           XSDAT     ANDLE20229999
     C                     EXSR #A2022
     C                     ENDIF
      *
     C                     ENDSR
      ************************************************************
      * ADJUST FORD SHIPPING QTY
      ************************************************************
     C           #A2022    BEGSR
      *
      *
     C                     ENDSR
      ************************************************************
      *  SET SFL01 BY AB#WP9M
      ************************************************************
     C           #SFL1     BEGSR
      *
     C                     EXSR #CLRS1
      *
     C                     Z-ADD0         RRN1
     C                     MOVE 'Y'       FIRST
     C           *LOVAL    SETLLAB#WP9M
     C                     DO   *HIVAL
     C                     READ AB#WP9M                  97
     C   97                LEAVE
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELW8MHIN    SVMHIN
     C                     MOVELW8NUKE    SVNUKE
     C                     ENDIF
      * BREAK?
     C           W8MHIN    IFNE SVMHIN
     C**         W8NUKE    ORNE SVNUKE
     C                     EXSR #BRK1
     C                     ENDIF
      * PROCESS
     C                     MOVELW8NONY    SVNONY
     C                     ADD  W8QTY     SVQTY
     C                     ADD  W8BOX     SVBOX
     C                     Z-ADDW8QPC     SVQPC
      *
     C                     ENDDO
      * LAST BREAK
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK1
     C                     ENDIF
      *
     C                     Z-ADDRRN1      COUNT   60
      *
     C                     ENDSR
      ************************************************************
      *  SFL BREAK
      ************************************************************
     C           #BRK1     BEGSR
      *
     C                     CLEARSFL01
     C                     MOVELSVNONY    S1NONY
     C                     MOVELSVMHIN    S1MHIN
     C                     MOVE '0'       S1NKOJ
     C                     MOVELSVNUKE    S1NUKE
     C                     Z-ADDSVQTY     S1QTY
     C                     Z-ADDSVBOX     S1BOX
     C                     Z-ADDSVQPC     S1QPC
      * FORD DEMAND
     C                     MOVELXSDAT     $END
     C                     MOVELXNONY1    $NONY
     C                     MOVELSVMHIN    $MHIN
     C                     CALL 'UEXR41D'
     C                     PARM           $END    8
     C                     PARM           $NONY   4
     C                     PARM           $MHIN  20
     C                     PARM           $PLNT   5
     C                     PARM           $YTDQ   9
     C                     MOVE $YTDQ     S1FRDQ
     C           S1QTY     SUB  S1FRDQ    S1DIF
     C           S1DIF     IFGE 0
     C                     MOVE *OFF      S1SHRT
     C                     MOVE *OFF      *IN81
     C                     ELSE
     C                     MOVE *ON       S1SHRT
     C                     MOVE *ON       *IN81
     C                     ENDIF
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
      * RESET
     C                     MOVELW8MHIN    SVMHIN
     C                     MOVELW8NKOJ    SVNKOJ
     C                     MOVELW8NUKE    SVNUKE
     C                     MOVE *BLANK    SVNONY
     C                     Z-ADD0         SVQTY
     C                     Z-ADD0         SVBOX
     C                     Z-ADD0         SVQPC
     C                     Z-ADD0         FCONT
     C                     Z-ADD0         DCONT
      *
     C                     ENDSR
      ************************************************************
      *  DSPLAY 2ND SCREEN
      ************************************************************
     C           #CTL1     BEGSR
      *
     C                     EXSR #SFL1
      *
     C                     WRITEDSP99
     C                     MOVEL'1'       *IN70
     C                     EXFMTCTL01
     C                     MOVEL*BLANKS   XMSG
     C                     MOVEL'0'       *IN85
     C                     MOVEL'0'       *IN70
      *
     C                     SELEC
      * F3: EXIT
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * F12: BACK
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
     C                     OTHER
     C                     EXSR #CHK2
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************
      * CLEAR SUB FILE 01
      *************************************************************
     C           #CLRS1    BEGSR
      *
     C                     SETON                     71
     C                     WRITECTL01
     C                     SETOF                     71
     C                     Z-ADD0         RRN1
     C                     SETOF                     81
      *
     C                     ENDSR
      *************************************************************
      * CLEAR SUB FILE 02
      *************************************************************
     C           #CLRS2    BEGSR
      *
     C                     SETON                     71
     C                     WRITECTL02
     C                     SETOF                     71
     C                     Z-ADD0         RRN2
     C                     Z-ADD0         H2FRDQ
     C                     Z-ADD0         H2DIF
     C                     Z-ADD0         H2QTY
     C                     Z-ADD0         H2BOX
      *
     C                     ENDSR
      *************************************************************
      *  CHECK SUB FILE
      *************************************************************
     C           #CHK2     BEGSR
      *
      *
     C           1         DO   COUNT     RRN1
      *
     C           RRN1      CHAINSFL01                50
     C           *IN50     IFEQ *OFF
     C           S1SEL     ANDNE' '
     C                     EXSR #SFL2
     C           *IN03     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVE *BLANK    S1SEL
     C                     UPDATSFL01
      *
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************
      * DISPLAY SFL02 SCREEN
      *************************************************************
     C           #SFL2     BEGSR
      *
     C                     EXSR #SET2
      *
     C                     DO   *HIVAL
     C                     WRITEDSP99
     C                     MOVEL'1'       *IN70
     C                     EXFMTCTL02
     C                     MOVEL*BLANKS   XMSG
     C                     MOVEL'0'       *IN85
     C                     MOVEL'0'       *IN70
      *
     C                     SELEC
      * F3: EXIT
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C                     LEAVE
      * F12: BACK
     C           *INKL     WHEQ *ON
     C                     MOVEL'02'      W@ID
     C                     LEAVE
     C                     OTHER
     C                     EXSR #CHK3
     C                     ENDSL
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************
      * SET DATA FOR SFL02
      *************************************************************
     C           #SET2     BEGSR
      *
     C                     EXSR #CLRS2
      *
     C                     MOVELS1MHIN    $MHIN     P
     C                     CALL 'UUUR03'
     C                     PARM           $MHIN  20
     C                     PARM           $MHIN2 23
     C                     MOVEL$MHIN2    XPART2
      *
     C                     Z-ADDS1FRDQ    H2FRDQ
     C                     Z-ADDS1DIF     H2DIF
     C           S1DIF     IFGT 0
     C                     MOVEL'OVER :'  XDIF
     C                     ELSE
     C                     MOVEL'SHORT:'  XDIF
     C                     ENDIF
     C           S1DIF     IFGE 0
     C                     MOVE *OFF      *IN81
     C                     ELSE
     C                     MOVE *ON       *IN81
     C                     ENDIF
      *
     C                     Z-ADD0         RRN2
     C                     Z-ADD0         S2CUM
     C                     MOVELS1MHIN    K#MHIN
     C                     Z-ADD0         K#NOHZ
     C**                   MOVE *BLANK    K#NUKE
     C           K#W9M     SETLLAB#WP9M
     C                     DO   *HIVAL
     C           K#W9MB    READEAB#WP9M                  97
     C   97                LEAVE
      *
     C**                   MOVELS1NONY    S2NONY
     C**                   MOVELS1MHN1    S2MHN1
     C**                   MOVELS1MHN2    S2MHN2
     C**                   MOVELS1MHN3    S2MHN3
     C                     MOVE '0'       S2NKOJ
     C                     MOVELW8NUKE    S2NUKE
     C                     Z-ADDW8NOHZ    S2NOHZ
     C                     Z-ADDW8NOBN    S2NOBN
     C                     Z-ADDW8QTY     S2QTY
     C                     ADD  W8QTY     H2QTY
     C                     Z-ADDW8BOX     S2BOX
     C                     ADD  W8BOX     H2BOX
     C                     ADD  W8QTY     S2CUM
     C                     Z-ADDW8QPC     S2QPC
     C                     Z-ADDW8URHZ    S2BILL
     C                     MOVELW8EDIK    S2EDIK
     C                     Z-ADDW8CRHZ    S2CRHZ
      *
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************
      * CHECK SCREEN 3
