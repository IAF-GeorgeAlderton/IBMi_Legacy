     H            Y.                                    1
     F** AAPR92 *************************************
     F* .. WASHER DATA FILE TRANSFER                *
     F* A.MAMIYA                   2000.10.27       *
     F************************************* AAPR92 **
     FAKEPP01 IP  E                    DISK
     FAKCPL01 IF  E           K        DISK
     FAAPWP94 O   F     128            DISK
      *削除コード
     I            DS
     I                                        1   80M1SKHZ
     I                                        1   40M1SKYY
     I                                        5   60M1SKMM
     I                                        7   80M1SKDD
     I            DS
     I                                        1   80M3SKHZ
     I                                        1   40M3SKYY
     I                                        5   60M3SKMM
     I                                        7   80M3SKDD
      *有効日
     I            DS
     I                                        1  100M3HZ01
     I                                        1   80M3HZHZ
     I            DS
     I                                        1   80M1SYHZ
     I                                        1   40M1SYYY
     I                                        5   60M1SYMM
     I                                        7   80M1SYDD
     I            DS
     I                                        1   6 WTKRO
     I                                        1   1 WSTRK
     I                                        2   3 WSTRT
     I                                        4   5 WSTRR
     I                                        6   6 WSTRD
      *
     C                     Z-ADD0         WSSYS   60
     C                     MOVEL*BLANK    WSTRK   1
     C                     MOVEL*BLANK    WSTRT   2
     C                     MOVEL*BLANK    WSTRR   2
     C                     MOVEL*BLANK    WSTRD   1
      *削除データの為、終了
     C           M3SKJY    IFEQ 'D'
     C           M3SKHZ    ANDLE*DATE
     C                     GOTO @END
     C                     END
      *有効日・失効日
     C           *DATE     IFGE M3HZHZ
     C                     MOVELM3NB01    WTKRO
     C                     ELSE
     C                     MOVELM3QT01    WTKRO
     C                     END
      *
     C           KEY1      KLIST
     C                     KFLD           M3HIN1
     C                     KFLD           M3HIN2
     C                     KFLD           M3HIN3
      *
     C                     SETOF                     20
     C           KEY1      CHAINAKCPL011             20
     C           *IN20     IFEQ '0'
     C           M1SKJY    IFEQ 'D'
     C           M1SKHZ    ANDLE*DATE
     C                     ELSE
     C           *DATE     IFGE M1SYHZ
     C                     Z-ADDM1SSYS    WSSYS
     C                     ELSE
     C                     Z-ADDM1KSYS    WSSYS
     C                     END
     C                     END
     C                     END
      *
     C           *IN10     IFEQ '0'
     C                     EXCPTHD1
     C                     SETON                     10
     C                     END
      *
     C                     EXCPTDT1
      *
     C           @END      TAG
     OAAPWP94 E                HD1
     O                                      'LOCATION'
     O                                      ','
     O                                      'PART NO'
     O                                      ','
     O                                      'CONTAINER'
     O        E                DT1
     O                         WSTRK
     O                                      '-'
     O                         WSTRT
     O                                      '-'
     O                         WSTRR
     O                                      '-'
     O                         WSTRD
     O                                      ','
     O                         M3HIN1
     O                         M3HIN2
     O                         M3HIN3
     O                                      ','
     O                         WSSYS Z
