     H            Y.                                                      DAD000
     F** AAMRS5 *******************************************************
     F*指定した部門・工程・機番の前の部門・工程・機番を取得
     F* KIRI  2019.11.06
     F******************************************************* AAMRS5 **
      *
     E                    OBM        15  4               部門
     E                    OKB        15  3               機番
     E                    OTK        15  6               所番地
     E                    OSH        15  1               かんばん種類
     E                    OKO        15  3               工程
     E                    OHB        15 12               品番
     I            DS
     I                                        1   6 W@BANA
     I                                        1   1 W@BAN1
     I                                        2   3 W@BAN2
     I                                        4   5 W@BAN3
     I                                        6   6 W@BAN4
      *
     C           *ENTRY    PLIST
     C                     PARM           PIHIN1  5
     C                     PARM           PIHIN2  5
     C                     PARM           PIHIN3  2
     C                     PARM           PIBMON  4
     C                     PARM           PIKOTE  3
     C                     PARM           PIKIBN  3
     C                     PARM           PIBAN1  1
     C                     PARM           PIBAN2  2
     C                     PARM           PIBAN3  2
     C                     PARM           PIBAN4  1
     C                     PARM           PIDATE  8
     C                     PARM           PIBIN   2
      *
     C                     PARM           POBMON  4
     C                     PARM           POKOTE  3
     C                     PARM           POKIBN  3
      *
     C                     MOVE PIHIN1    K@HIN1  5
     C                     MOVE PIHIN2    K@HIN2  5
     C                     MOVE PIHIN3    K@HIN3  2
     C                     MOVE PIBAN1    W@BAN1
     C                     MOVE PIBAN2    W@BAN2
     C                     MOVE PIBAN3    W@BAN3
     C                     MOVE PIBAN4    W@BAN4
     C                     MOVE PIDATE    W@DATE  8
     C                     MOVE PIBIN     W@BIN   2
      *
     C                     MOVE *BLANK    POBMON
     C                     MOVE *BLANK    POKOTE
     C                     MOVE *BLANK    POKIBN
      *工程切替マスター情報
     C           AAMRSC    PLIST
     C                     PARM           K@HIN1  5
     C                     PARM           K@HIN2  5
     C                     PARM           K@HIN3  2
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
      *
     C                     MOVE *BLANK    PBMN   60
     C                     MOVE *BLANK    PKBN   45
     C                     MOVE *BLANK    PTKR   90
     C                     MOVE *BLANK    PSHR   15
     C                     MOVE *BLANK    PKOT   45
     C                     MOVE *BLANK    PHBN  180
     C                     MOVE *BLANK    STATUS  1
      *
     C                     MOVEA*BLANK    OBM
     C                     MOVEA*BLANK    OKB
     C                     MOVEA*BLANK    OTK
     C                     MOVEA*BLANK    OSH
     C                     MOVEA*BLANK    OKO
     C                     MOVEA*BLANK    OHB
      *
      *
     C                     CALL 'AAMRSC'  AAMRSC
      *
     C           STATUS    IFNE '1'
     C                     GOTO @END
     C                     END
      *
     C                     MOVEAPBMN      OBM
     C                     MOVEAPKBN      OKB
     C                     MOVEAPTKR      OTK
     C                     MOVEAPSHR      OSH
     C                     MOVEAPKOT      OKO
     C                     MOVEAPHBN      OHB
      *
     C                     SETOF                     77
     C                     MOVE *BLANK    P$BMON  4
     C                     MOVE *BLANK    P$KOTE  3
     C                     MOVE *BLANK    P$KIBN  3
      *-----------------------------------
S1   C           1         DO   15        @X      20
     C*
 S2  C           OKO,@X    IFEQ *BLANK                     工程
     C                     LEAVE
 E2  C                     END
     C*
     C           @X        SUB  1         @1      20
     C           @1        IFNE 0
     C***        OTK,@1    ANDNE'------'
     C                     MOVE OBM,@1    P$BMON
     C                     MOVE OKO,@1    P$KOTE
     C                     MOVE OKB,@1    P$KIBN
     C                     ENDIF
      *
 S2  C           PIBMON    IFNE *BLANK
     C           PIBMON    ANDNEOBM,@X                     部門
     C                     ITER
 E2  C                     END
 S2  C           PIKOTE    IFNE *BLANK
     C           PIKOTE    ANDNEOKO,@X                     工程
     C                     ITER
 E2  C                     END
 S2  C           PIKIBN    IFNE *BLANK                     機番
     C           PIKIBN    ANDNEOKB,@X
     C                     ITER
 E2  C                     END                             所番地
     C           W@BANA    IFNE *BLANK
     C           W@BANA    ANDNEOTK,@X
     C                     ITER
     C                     END
     C*
     C                     MOVE P$BMON    POBMON
     C                     MOVE P$KOTE    POKOTE
     C                     MOVE P$KIBN    POKIBN
     C                     LEAVE
     C*
     C                     ENDDO
      *-----------------------------------
      *-----------------------------------
     C           @END      TAG
      *
      *
     C                     SETON                     LR
     C                     RETRN
