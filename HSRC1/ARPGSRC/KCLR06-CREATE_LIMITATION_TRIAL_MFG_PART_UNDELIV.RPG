     C           CNKI1     IFEQ 1
     C           CNKI1     OREQ 2
     C           CNKI1     OREQ 3
     C           P5NOYY    ADD  1         YNKI
     C                     ELSE
     C                     Z-ADDP5NOYY    YNKI
     C                     END
     C                     ELSE
     C                     Z-ADDP5NOYY    YNKI
     C                     END
     C                     END
     C*
     C                     MOVE NKI,B     CNKI2   60
     C                     MOVELYNKI      CNKI2
     C                     Z-ADD*ZERO     KNKI1
     C                     Z-ADD*ZERO     KNKI2
     C                     Z-ADD*ZERO     KNKI3
     C           KNM,B     IFNE '00'
     C                     MOVE KNM,B     KNKI1
     C                     MOVE KND,B     KNKI2
     C*
     C           P5NOMM    IFEQ 1
     C           P5NOMM    OREQ 2
     C           P5NOMM    OREQ 3
     C           KNKI1     IFEQ 10
     C           KNKI1     OREQ 11
     C           KNKI1     OREQ 12
     C           P5NOYY    SUB  1         YNKI2   40
     C                     ELSE
     C                     Z-ADDP5NOYY    YNKI2
     C                     END
     C                     ELSE
     C           P5NOMM    IFEQ 10
     C           P5NOMM    OREQ 11
     C           P5NOMM    OREQ 12
     C           KNKI1     IFEQ 1
     C           KNKI1     OREQ 2
     C           KNKI1     OREQ 3
     C           P5NOYY    ADD  1         YNKI2
     C                     ELSE
     C                     Z-ADDP5NOYY    YNKI2
     C                     END
     C                     ELSE
     C                     Z-ADDP5NOYY    YNKI2
     C                     END
     C                     END
     C*
     C                     END
     C           KNM,B     IFEQ '00'
     C           CNKI2     CABGTHIZK      NLOOP
     C                     ELSE
     C                     GOTO NLOOP
     C                     END
     C                     Z-ADD*ZERO     B2      20
     C                     Z-ADD*ZERO     B3      20
     C                     Z-ADDB         B2
     C                     ADD  1         B2
     C           B2        IFLE A
     C           B2        DO   A         B3
     C           KNM,B3    IFNE '00'
     C                     GOTO NLOOP
     C                     END
     C                     END
     C                     END
     C           *IN50     IFEQ '0'
     C                     EXSR MVE
     C                     SETON                     50
     C                     END
     C           KUBN      IFEQ '4'
     C           P5NONY    CHAINFGBPL011             21
     C                     ELSE
     C           BMN,B     CHAINFGBPL011             21
     C                     END
     C           *IN21     IFEQ '1'
     C                     GOTO END
     C                     END
     C           KUBN      IFEQ '4'
     C                     Z-ADDP5NONY    BMONKO  40
     C                     ELSE
     C                     Z-ADDBMN,B     BMONKO
     C                     END
     C                     MOVELB2SMEI    KOJYOU 16
     C                     MOVE DDD       KOJYOU
     C                     MOVE TEN       TEHINO  7
     C                     MOVE HNB       HINBAN 14
     C                     MOVE TOK       TOKORO  9
     C                     Z-ADDP5TOKU    TOKUIS  40
     C                     Z-ADDP5NONY    NOUNYU  40
     C                     MOVE P5NKOJ    KOJYNO  1
     C                     MOVE P5NUKE    UKEIRE  4
     C                     Z-ADDP5NHZK    UNOUKI  60
     C                     Z-ADDP5THZK    SYUKAT  60
     C                     Z-ADDP5SRYO    SURYOU  70
      *
     C           $TEHI     IFEQ 'Z'
     C                     EXCPTDT
     C                     SETON                     U1
     C                     ELSE
     C                     EXCPTDT2
     C                     SETON                     U2
     C                     END
     C           NLOOP     TAG
     C                     END
     C           END       TAG
     C                     GOTO START
     C*-----------------------------------------------*
     C*          工程数の検索　サブルーチン         *
     C*-----------------------------------------------*
     C           KOTEI     BEGSR
     C                     Z-ADD1         A       20
     C           1         DO   15        A
     C                     SETOF                     10
     C           KTE,A     IFEQ *BLANK
     C                     SUB  1         A
     C                     SETON                     10
     C                     END
     C  N10                END
     C                     ENDSR
     C*-----------------------------------------------*
     C*            ＭＯＶＥ　サブルーチン           *
     C*-----------------------------------------------*
     C           MVE       BEGSR
     C                     Z-ADD1         C       20
     C           1         DO   A         C
     C           BMN,C     CHAINFGBPL011             70
     C           *IN70     IFEQ '1'
     C                     GOTO OWARI
     C                     END
     C                     MOVE KTE,C     KTEI,C
     C                     MOVELB2SMEI    KAKO,C
     C                     MOVE DDD       KAKO,C
     C                     Z-ADDNKI,C     GNKI,C
     C           KNM,C     IFEQ '00'
     C                     MOVE *BLANK    MN
     C                     MOVE *BLANK    DA
     C                     MOVE *BLANK    BN
     C                     ELSE
     C                     MOVE KNM,C     MN
     C                     MOVE KND,C     DA
     C                     MOVE KNB,C     BN
     C                     END
     C                     MOVE KNHI      NBN,C
     C           OWARI     TAG
     C                     END
     C                     ENDSR
