     H            Y.
     F** ALDRA5 *********************************************
     F* THE NUMBER OF PROCESSED BOXES BY WORKER
     F*             ITS.           2015.06.29               *
     F*******************************************************
     FALDPWA5 CF  E                    WORKSTN
     E                    ER      1  20 60
      *
     I            DS
     I                                        1  120D1DE1
     I                                        1   80D1DED1
     I                                        9  120D1DET1
     I                                        1   40YEAR
     I                                        5   60MM
     I                                        7   80DD
     I                                        9  120HHMM
      *
     I            DS
     I                                        1  120D1DE2
     I                                        1   80D1DED2
     I                                        9  120D1DET2
     I                                        1   40YEAR2
     I                                        5   60MM2
     I                                        7   80DD2
     I                                        9  120HHMM2
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1YY1   40
     C                     PARM           P1MM1   20
     C                     PARM           P1DD1   20
     C                     PARM           P1DET1  40
     C                     PARM           P1YY2   40
     C                     PARM           P1MM2   20
     C                     PARM           P1DD2   20
     C                     PARM           P1DET2  40
     C                     PARM           P9CMD   2
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     TIME           SDATE
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVEL'01'      DSPSW   2
     C                     MOVEL*BLANK    P9CMD
     C                     Z-ADD0         P1YY1
     C                     Z-ADD0         P1MM1
     C                     Z-ADD0         P1DD1
     C                     Z-ADD0         P1DET1
     C                     Z-ADD0         P1YY2
     C                     Z-ADD0         P1MM2
     C                     Z-ADD0         P1DD2
     C                     Z-ADD0         P1DET2
     C                     Z-ADD0         D1DED1
     C                     Z-ADD0         D1DET1
     C                     Z-ADD0         D1DED2
     C                     Z-ADD0         D1DET2
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTALDPWA51
     C                     SETOF                     020304
     C                     SETOF                     313233
     C                     SETOF                     343599
     C                     MOVEL*BLANK    D1ERR
      *
     C           *IN01     IFEQ '1'
     C                     MOVEL'01'      P9CMD
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1DED1    IFEQ 0
     C                     MOVELER,2      D1ERR
     C                     SETON                     020304
     C                     SETON                     99
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           MM        IFGE 1
     C           MM        ANDLE12
     C                     ELSE
     C                     MOVELER,5      D1ERR
     C                     SETON                     0399
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1DET1    IFGE 2400
     C                     MOVELER,4      D1ERR
     C                     SETON                     3199
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1DET2    IFGE 2400
     C                     MOVELER,4      D1ERR
     C                     SETON                     3599
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1DE2     IFNE 0
     C           MM2       IFGE 1
     C           MM2       ANDLE12
     C                     ELSE
     C                     MOVELER,5      D1ERR
     C                     SETON                     3399
     C                     GOTO ESB210
     C                     ENDIF
     C           D1DE2     IFLT D1DE1
     C                     MOVELER,3      D1ERR
     C                     SETON                     323334
     C                     SETON                     3599
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADDYEAR      P1YY1
     C                     Z-ADDMM        P1MM1
     C                     Z-ADDDD        P1DD1
     C                     Z-ADDHHMM      P1DET1
     C                     Z-ADDYEAR2     P1YY2
     C                     Z-ADDMM2       P1MM2
     C                     Z-ADDDD2       P1DD2
     C                     Z-ADDHHMM2     P1DET2
      *
     C           *IN05     IFEQ '1'
     C                     MOVEL'05'      P9CMD
     C                     MOVEL'99'      DSPSW
     C                     ENDIF
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
** ER
E-01
E-02 INPUT SCANNING DATE.
E-03 RANGE ERROR.
E-04 INPUT 00:00 - 23:59.
E-05 MONTH ERROR.
E-06
