      *
     CLR                   EXSR SUBRTN
      *================================================================
     C           SUBRTN    BEGSR
      *
     C           *IN,90    IFEQ '0'
     C                     Z-ADD0         HMS
     C                     MOVELF04       HM
     C                     Z-ADD*DATE     YMD
     C                     MOVEA'1'       *IN,90
     C           KEY1      SETGTAGDPL111
     C                     READ AGDPL111                 10
     C           *IN,10    IFEQ '0'
     C****                 Z-ADDF8YMD     YMD
     C                     END
     C                     END
      *
     C                     SETOF                     10
     C                     DO   *HIVAL
     C           STEP01    TAG
     C                     READ AD#PP15                  10
     C           *IN10     CABEQ'1'       LEND
     C           CASKJY    CABEQ'D'       STEP01
     C           CAGYOM    IFEQ '04'
     C                     GOTO STEP01
     C                     ENDIF
      *
     C                     SETOF                     20
     C           KEY2      CHAINAGAPL411             20
     C           *IN20     IFEQ '0'
     C           CBSKJY    ANDEQ'D'
     C           CBSKHZ    ANDLE*DATE
     C                     SETON                     20
     C                     END
     C           *IN20     IFEQ '1'
     C                     GOTO STEP01
     C                     END
     C                     Z-ADDCBMBMN    CABMON
      *
     C           CATYMD    IFLT YMD
     C                     EXCPTDATA1
     C  NU7                SETON                     U7
     C                     MOVEL'AD#PP15' WKFILE 10 P
     C                     EXSR #SB555
     C                     ELSE
      *
     C           CATYMD    IFEQ YMD
