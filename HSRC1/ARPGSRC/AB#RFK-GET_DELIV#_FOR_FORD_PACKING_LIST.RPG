     H            Y.
     F** AB#RFK *************************************
     F*  PACKING SLIP(GET DELIVERY CODE FOR NIRVANA)*
     F*    N.HYOTO                2000.11.03        *
     F*                                             *
     F* TCHK1 12/31/09 ADD DELIVERY GROUP           *
     F* TCHK2 05/11/11 ADD CUATITLAUN(AP23A:5163) GROUP#2
     F* TCHK3 07/15/11 CHG DELEVERY GROUP
     F* TCHK4 05/01/12 CHG DELEVERY GROUP(5150,5173)
     F* TCHK5 07/03/12 CHG DELEVERY GROUP(5164,5173)
     F* TCHK6 03/15/13 CHG DELEVERY GROUP '3' FOR 'IE'
     F************************************* AB#RFK **
     FABFDL01 IF  E           K        DISK
TCHK1F*
TCHK2E*TCHK1              GRP2    1  16  4
TCHK3E*TCHK2              GRP2    1  17  4
TCHK4E*TCHK3              GRP2    1   5  4
TCHK4E                    GRP2    1   2  4
     I*****************************************************************
     I            DS
     I                                        1   4 WPLAN
     I                                        1   40WDELY
     I            DS
     I                                        1   80QASKHZ
     I                                        1   40QASKYY
     I                                        5   60QASKMM
     I                                        7   80QASKDD
     I            DS
     I                                        1   80QAEFHZ
     I                                        1   40QAEFYY
     I                                        5   60QAEFMM
     I                                        7   80QAEFDD
     C*
     C*****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PPLAN   4
     C                     PARM           PDOCK   4
     C                     PARM           PEND    1
TCHK1C                     PARM           PFLAG   1
      *
     C           KEY1      KLIST
     C                     KFLD           KDELY   40
     C                     KFLD           KDOCK   4
     C*****************************************************************
     C                     MOVE PPLAN     WPLAN
     C                     Z-ADDWDELY     KDELY
     C                     MOVELPDOCK     KDOCK
     C           KEY1      SETGTABFDL01
     C           @LOOP     TAG
     C                     READ ABFDL01                  90
     C           *IN90     IFEQ '0'
     C                     SELEC
     C           QASKJY    WHEQ 'D'
     C           QASKHZ    ANDLE*DATE
     C                     GOTO @LOOP
     C           QAEFHZ    WHGT *DATE
     C                     GOTO @LOOP
     C                     OTHER
TCHK1C           PFLAG     IFEQ '1'
     C                     MOVE QANONY    PPLAN
     C                     MOVELQADOCK    PDOCK
TCHK1C                     END
TCHK1C           PFLAG     IFEQ '2'
TCHK1C           PFLAG     OREQ '3'
TCHK1C                     MOVELQAPLAN    W@A002  2
TCHK1C           W@A002    IFEQ 'IE'
TCHK1C                     GOTO @LOOP
TCHK1C                     END
TCHK1C                     MOVELQANONY    W@A004  4
TCHK1C           W@A004    LOKUPGRP2                     91
TCHK1C           PFLAG     IFEQ '2'
TCHK1C           *IN91     IFEQ *ON
TCHK1C                     GOTO @LOOP
TCHK1C                     END
TCHK1C                     ELSE
TCHK1C           *IN91     IFEQ *OFF
TCHK1C                     GOTO @LOOP
TCHK1C                     END
TCHK1C                     END
TCHK1C                     MOVE QANONY    PPLAN
TCHK1C                     MOVELQADOCK    PDOCK
TCHK1C                     END
TCHK6C           PFLAG     IFEQ '4'
TCHK6C                     MOVELQAPLAN    W@A002  2
TCHK6C           W@A002    IFNE 'IE'
TCHK6C                     GOTO @LOOP
TCHK6C                     END
TCHK6C                     MOVE QANONY    PPLAN
TCHK6C                     MOVELQADOCK    PDOCK
TCHK6C                     END
     C                     ENDSL
     C*
     C                     ELSE
     C                     MOVE '1'       PEND
     C                     END
     C*
     C                     SETON                     LR
     C                     RETRN
** GRP2
5164
5173
