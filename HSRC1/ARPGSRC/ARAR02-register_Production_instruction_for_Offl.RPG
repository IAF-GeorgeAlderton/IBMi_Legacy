     C                     MOVE *BLANK    WB22   22
     C*
     C                     MOVE *BLANK    F30    30
     C                     MOVELDS30      F30
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVELF30       DS30
     C*
     C                     MOVE *BLANK    F30
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVELF30       @BLK18 18
     C*
     C                     MOVE *BLANK    F30
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVELF30       BLK30  30
     C*
     C                     MOVE *BLANK    F30
     C                     MOVEL'SC'      F30
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVELF30       SC      2
     C*
     C                     MOVE *BLANK    F30
     C                     MOVELX9431     F30
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVELF30       X9431
     C*
     C                     MOVE *BLANK    F30
     C                     MOVELWB29      F30
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVELF30       WB29
     C*
     C                     MOVE *BLANK    F30
     C                     MOVELWB22      F30
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVELF30       WB22
     C*
     C                     MOVE *BLANK    FSW1    1
     C                     Z-ADD0         SQ1     40
     C                     Z-ADD0         CNT1    40
     C                     MOVE *BLANK    BLK1    2
     C*
     C                     MOVE '0000'    WBMN1   4
     C*
     C                     DO   *HIVAL
     C                     SETOF                     10
     C                     READ ARAPL011                 10
     C           *IN10     IFEQ '0'
     C           FSW1      IFEQ *BLANK
     C                     OPEN ARAWP01
     C                     EXCPTA01
     C                     MOVE *BLANK    BLK1
     C                     MOVEL'*'       FSW1
     C                     END
     C*
     C           ARBMON    IFNE WBMN1
     C                     ADD  1         CNT1
     C                     Z-ADD0         SQ1
     C                     EXCPTA02
     C                     MOVE ARBMON    WBMN1
     C                     MOVELARBLOK    BLK1
     C                     MOVELARKDAI    KDA1    1
     C                     ELSE
     C           ARKDAI    IFNE KDA1
     C                     ADD  1         CNT1
     C                     Z-ADD0         SQ1
     C                     EXCPTA02
     C                     MOVELARBLOK    BLK1
     C                     MOVELARKDAI    KDA1
     C                     ELSE
     C           ARBLOK    IFNE BLK1
     C                     ADD  1         CNT1
     C                     Z-ADD0         SQ1
     C                     EXCPTA02
     C                     MOVELARBLOK    BLK1
     C                     END
     C                     END
     C                     END
     C*
     C                     ADD  1         CNT1
     C                     ADD  1         SQ1
     C                     MOVE *BLANK    F30
     C                     MOVELSQ1       F30
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVELF30       XSQ1    4
     C*
     C                     MOVEL@BLK18    BLK18  18
     C*
     C                     MOVELARTOKU    F30
     C                     CALL 'AZZR12'
     C                     PARM           F30
     C                     MOVELF30       WTOKU   40
     C*
     C           WTOKU     IFNE 0
     C                     SETOF                     11
     C           WTOKU     CHAINFGBPL011             11
     C           *IN11     IFEQ '0'
     C                     MOVELB2SMEI    @ME18
     C                     CALL 'AZZR11'
     C                     PARM           F30
     C                     MOVEL@ME18     BLK18
     C                     END
     C                     END
   #@C*
   #@C*                    EXSR S#@F06
     C*
     C                     EXCPTA03
     C*
     C                     END
     C  N10                END
