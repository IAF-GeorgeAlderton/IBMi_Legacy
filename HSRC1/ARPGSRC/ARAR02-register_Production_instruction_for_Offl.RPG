     C*
     C*  ﾃmb ﾃcyh EBCDIC --> ASCII
     C*
     C                     MOVE *BLANK    DS30
     C                     MOVEL'D'       D
     C                     MOVEL'0111'    X9431   4
     C                     MOVEL'HD'      HD
     C                     MOVEL'DT'      DT
     C                     MOVEL'BK'      BK
     C                     MOVEL'AA'      AA
     C                     MOVEL'EE'      EE
     C                     MOVEL'00'      X00
