     C                     MOVE CTBHKO    CFBHK1  30
     C                     MOVE CTBNYY    CFBYY1  40
     C                     MOVE CTBNMM    CFBMM1  20
     C                     MOVE CTBNDD    CFBDD1  20
     C                     MOVE CTBNBB    CFBBB1  20
     C                     ELSE
     C           WDATE1    IFEQ WDATE2
     C                     MOVE CTBHKO    CFBHK1  30
     C                     MOVE CTBNYY    CFBYY1  40
     C                     MOVE CTBNMM    CFBMM1  20
     C                     MOVE CTBNDD    CFBDD1  20
     C                     MOVE CTBNBB    CFBBB1  20
     C                     ELSE
     C                     MOVE CTBHKO    CFBHK2  30
     C                     MOVE CTBNYY    CFBYY2
     C                     MOVE CTBNMM    CFBMM2
     C                     MOVE CTBNDD    CFBDD2
     C                     MOVE CTBNBB    CFBBB2  20
     C                     END
     C                     END
     C                     EXCPTCHG
     C                     MOVE *ZERO     CFBHK1
     C                     MOVE *ZERO     CFBYY1
     C                     MOVE *ZERO     CFBMM1
     C                     MOVE *ZERO     CFBDD1
     C                     MOVE *ZERO     CFBBB1
     C                     MOVE *ZERO     CFBHK2
     C                     MOVE *ZERO     CFBYY2
     C                     MOVE *ZERO     CFBMM2
     C                     MOVE *ZERO     CFBDD2
     C                     MOVE *ZERO     CFBBB2
