     C                     MOVE *BLANK    WH2
     C                     ELSE
     C                     MOVE '-'       WH2
     C                     END
     C                     MOVE WSAGYO    @SAGYO
     C                     ADD  2         LCNT
     C                     WRITEATAPR823
     C           LCNT      IFGE 52
     C                     ADD  1         @PAGE
     C                     MOVE *ZERO     LCNT    40
     C                     WRITEATAPR821
     C                     END
     C                     MOVE *BLANK    @MINOJ
     C                     MOVE CTSYHZ    WMKSY1  60
     C                     MOVE CTSYBB    WMKSYB  20
     C                     MOVE CTBMON    WKBMON  40
     C                     SETOF                     10
