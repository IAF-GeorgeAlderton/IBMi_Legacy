     C           CTBMON    IFNE WKBMON
     C                     MOVE *YEAR     @NEN
     C                     MOVE UMONTH    @TUKI
     C                     MOVE UDAY      @HI
     C                     MOVE 1         @PAGE
     C                     Z-ADDCTBMON    #WKEY   40
     C           #WKEY     CHAINFGBPL011             21
     C           *IN21     IFEQ '0'
     C                     MOVELB2SMEI    @NAME
     C                     ELSE
     C                     MOVE *BLANK    @NAME
     C                     END
     C                     MOVEA'0'       *IN,21
     C                     WRITEATAPR821
     C                     Z-ADD0         LCNT
     C                     MOVE '*'       SW1     1
     C                     END
     C           CTSYHZ    IFNE WMKSY1
     C           CTSYBB    ORNE WMKSYB
     C                     MOVE CTSYHZ    @MKSY1
     C                     MOVE CTSYBB    @MKSYB
     C                     WRITEATAPR822
     C                     ADD  2         LCNT
     C           LCNT      IFGE 52
     C                     ADD  1         @PAGE
     C                     MOVE *ZERO     LCNT    40
     C                     WRITEATAPR821
     C                     END
     C                     END
     C                     MOVE CTKBAN    @KIBAN
     C                     MOVE CTHIN1    @HIN1
     C                     MOVE CTHIN2    @HIN2
