  K.YC                     KFLD           #TEHAI  3
      *=940304
     C           #KEYCH    KLIST
     C                     KFLD           #KBMN   40
     C                     KFLD           #K8990  40
     C           *ENTRY    PLIST
     C                     PARM           PARM1   8        * ﾉcpﾏcﾍﾞ
     C                     PARM           PARM2   2        * ﾍﾞ]
     C                     PARM           PARM3   5        * ﾎﾞy]
     C                     PARM           PARM4   1        * bgﾅg
     C                     PARM           PARM6   3        * ﾒﾇn ﾇﾞv
     C                     PARM           PARM5   3        * ﾒﾇn BLK
