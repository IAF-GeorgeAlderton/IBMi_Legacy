     C                     MOVE PARM2     @NONUB  20
     C                     MOVE @NONYU    WKHMD   40
     C                     MOVEL@NONYU    WYEAR   40
     C                     MOVELWKHMD     WMONTH  20
     C                     MOVE WKHMD     WDAY    20
     C*************************************
     C*  明細処理  (ATAPR822 ATAPR823)  *
     C*************************************
     C*          *LOVAL    SETLLATANL051             8080
     C           *IN81     DOWEQ'0'
     C*
     C*=== IAF
     C           PARM3     IFEQ '0111 '
     C                     READ MINI04R                  81
     C                     END
     C*
     C                     SETOF                     3133
     C                     SETOF                     8586
     C           *IN81     CABEQ'1'       LISEND
     C           CTBNKI    IFEQ '*'
     C           CFBNHZ    IFNE *ZERO
     C                     MOVE CTZENO    #ZENO
     C                     MOVE CTTHNO    #TEHAI
     C           #KEY1     CHAINAH#PL111             31
     C           *IN31     IFEQ '0'
     C                     MOVELCFBLOK    CHKBLK  1
     C           PARM5     IFEQ *BLANK
     C                     ELSE
     C                     MOVEAPARM5     BL1
     C                     MOVEAPARM6     BL2
     C           CHKBLK    IFNE *BLANK
     C           CHKBLK    LOKUPBL2                      85
     C           *IN85     CABEQ'1'       LISEND
     C           CHKBLK    LOKUPBL1                      86
     C           *IN86     CABEQ'0'       LISEND
     C                     END
     C                     END
     C*=====(pｬcﾒｭh bgﾅg kｩｮh )==============================*
     C*
     C                     MOVE CFBYY1    WFBYY1
     C                     MOVE CFBMM1    WFBMM1
     C                     MOVE CFBDD1    WFBDD1
     C                     MOVE CFBBB1    WFBBB1
     C                     MOVE CTBNYY    WTBNYY
     C                     MOVE CTBNMM    WTBNMM
     C                     MOVE CTBNDD    WTBNDD
     C                     MOVE CTBNBB    WTBNBB
