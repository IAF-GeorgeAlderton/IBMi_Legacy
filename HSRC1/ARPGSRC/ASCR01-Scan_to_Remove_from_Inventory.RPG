     H            Y.
     F** ASCR01 *********************************************
     F*  SCAN TO REMOVE FROM INVENTORY (STORE IN/OUT)       *
     F*    LEC.  2024.10.14                                 *
     F*******************************************************
     FASCPW01 CF  E                    WORKSTN
     FFCEPL07 IF  E           K        DISK
     FALBPL30 IF  E           K        DISK
     FNZUPL01 UF  E           K        DISK
     FASCPP01 UF  E           K        DISK                      A
     E                    ER      1   5 25
      *
      *
      *  APICS BARCODE QR
     I            DS
     I                                        1 200 QRCODE
     I                                        1   3 D1TYPE
     I                                        7  10 ZETI
     I                                       53  55 TEHI
     I                                       59  60 PAGN
     I                                      140 1470D1ISDT
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  140SDATE
     I                                        1   60STIME
      *
     I            DS
     I                                        1  12 PART#
     I                                        1   5 SHN1
     I                                        6  10 SHN2
     I                                       11  12 SHN3
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           WKCD    6
      *
     C           #NZUKY    KLIST
     C                     KFLD           ZETI
     C                     KFLD           TEHI
     C                     KFLD           PAGN
      *
      *----------------------------------------------------*
      * MAINLINE LOGIC                                     *
      *----------------------------------------------------*
      *
      * dummy read                                         *
     C                     READ ASCPP01             N    50
     C                     MOVEL'01'      DSPSW   2
      *
      * get worker name...
     C                     MOVELWKCD      WKCD60  60
     C           WKCD60    CHAINALBPL30              51
      *
      *
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB100
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * GET APICS BARCODE AND REMOVE FROM INVENTORY        *
      *----------------------------------------------------*
     C           #SB100    BEGSR
      *
     C           DSPSW     DOWEQ'01'
      *
     C                     EXFMTDSP01
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     3199
      *
     C                     MOVELD1BARC    QRCODE
      *
     C                     DO
      * end pgm...
     C           *IN01     IFEQ *ON
     C                     CLEARD1BARC
     C                     MOVEL'99'      DSPSW
     C                     LEAVE
     C                     ENDIF
      * check barcode...
     C           D1BARC    IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVELER,2      MSG
     C                     LEAVE
     C                     ENDIF
      *
      * check for a valid qr code...
     C           D1TYPE    IFNE 'C01'
     C                     SETON                     3199
     C                     MOVELER,5      MSG
     C                     LEAVE
     C                     ENDIF
      *
      * check part master...
     C           ZETI      CHAINFCEPL07              51
     C           *IN51     IFEQ *OFF
     C                     MOVELA2BHB1    SHN1
     C                     MOVELA2BHB2    SHN2
     C                     MOVELA2BHB3    SHN3
     C                     ELSE
     C                     SETON                     3199
     C                     MOVELER,3      MSG
     C                     LEAVE
     C                     ENDIF
      *
      * check inventory file (store in/out)...
     C           #NZUKY    SETGTNZUPL01
     C           #NZUKY    REDPENZUPL01             N    51
     C           *IN51     DOWEQ*OFF
     C           N2SKJY    IFEQ ' '
     C           N2DEHZ    ANDEQ*ZERO
     C           N2HAHZ    ANDEQD1ISDT
     C                     LEAVE
     C                     ENDIF
     C           #NZUKY    REDPENZUPL01             N    51
     C                     ENDDO
      *
     C           *IN51     IFEQ *ON
     C                     SETON                     3199
     C                     MOVELER,4      MSG
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           *IN01     IFEQ *OFF
      *
     C           *IN99     IFEQ *ON
     C                     EXSR #SB999
      *
     C                     ELSE
     C                     TIME           WTIME
     C                     MOVEL*BLANK    MSG
     C                     EXSR #UPD
     C                     EXSR #SB500
     C                     ADD  1         D1TOTL
     C                     MOVELER,1      MSG
     C                     ENDIF
      *
     C                     CLEARD1BARC
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      * Write to Scan History file - ASCPP01               *
      *----------------------------------------------------*
     C           #SB500    BEGSR
      *
     C                     CLEARASCPP011
     C                     MOVELWKCD      SCWKCD
     C                     MOVELALWKNM    SCWKNM
     C                     MOVELW#PGM     SCCOPG
     C                     Z-ADDSDATE     SCCODT
     C                     Z-ADDSTIME     SCCOTM
     C                     MOVELZETI      SCZETI
     C                     MOVELSHN1      SCSHN1
     C                     MOVELSHN2      SCSHN2
     C                     MOVELSHN3      SCSHN3
     C                     MOVELTEHI      SCTEHI
     C                     MOVELPAGN      SCPAGE
     C                     Z-ADDD1ISDT    SCISDT
     C                     MOVELD1BARC    SCQRCD
     C                     WRITEASCPP011
      *
     C                     ENDSR
      *----------------------------------------------------*
      * Update Inventory file (store in/out)               *
      *----------------------------------------------------*
     C           #UPD      BEGSR
      *
     C           #NZUKY    SETGTNZUPL01
     C           #NZUKY    REDPENZUPL01                  51
     C           *IN51     DOWEQ*OFF
     C           N2SKJY    IFEQ ' '
     C           N2DEHZ    ANDEQ*ZERO
     C           N2HAHZ    ANDEQD1ISDT
     C                     MOVEL'D'       N2SKJY
     C                     Z-ADDSDATE     N2SKHZ
     C                     Z-ADDSDATE     N2KOHZ
     C                     Z-ADDSTIME     N2KOTI
     C                     MOVELWKCD      N2KOME    P
     C                     MOVELW#PGM     N2KOPG
     C                     Z-ADDSDATE     N2DEHZ
     C                     Z-ADDSTIME     N2DETI
     C                     UPDATNZUPL011
     C                     LEAVE
     C                     ENDIF
     C           #NZUKY    REDPENZUPL01                  51
     C                     ENDDO
      *
      *
     C                     ENDSR
      *----------------------------------------------------*
      * Display Error Message                              *
      *----------------------------------------------------*
     C           #SB999    BEGSR
      *
     C                     MOVELMSG       P1ERR
     C                     CALL 'AM#R08'
     C                     PARM           P1ERR  25
      *
     C                     ENDSR
      *----------------------------------------------------*
**                      >
REMOVED FROM INVENTORY
SCAN APICS KANBAN QR
PART NOT FOUND IN M/F
APICS NOT FOUND
INVALID APICS KANBAN QR
