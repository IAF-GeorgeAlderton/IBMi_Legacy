JW1   * GET DELIVERY DATE
 .   C           D2DLVR    IFEQ 0
 .   C                     MOVELTODAY     $BDATE
 .   C                     CALL 'UTLR24D'
 .   C                     PARM           $BDATE  8
 .   C                     PARM           $FRIDY  8
 .   C                     MOVEL$FRIDY    $YMD
 .   C                     CALL 'EDTR07 '                   YYMMDD --> MMDDYY
 .   C                     PARM           $YMD    8
 .   C                     PARM           $MDY1   8
 .   C                     PARM           $MDY2   6
 .   C                     MOVEL$MDY1     D2DLVR
JW1  C                     ENDIF
