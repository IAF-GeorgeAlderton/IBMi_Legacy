S1   C  N99      D2AIR     IFNE 0                          AIR/BOX
 S2  C           D2DLVR    IFEQ 0                          DELIVERY
     C                     MOVELMSG,5     D#MSG
     C                     SETON                     2399
 X2  C                     ELSE
  S3 C           D2DLMM    IFLT 1                          DELIVERY
     C           D2DLMM    ORGT 12                         DELIVERY
     C                     MOVELMSG,6     D#MSG
     C                     SETON                     2399
  E3 C                     ENDIF
  S3 C  N99      D2DLDD    IFLT 1                          DELIVERY
     C           D2DLDD    ORGT 31                         DELIVERY
     C                     MOVELMSG,6     D#MSG
     C                     SETON                     2399
  E3 C                     ENDIF
 E2  C                     ENDIF
X1   C                     ELSE
 S2  C           D2DLVR    IFNE 0                          DELIVERY
     C                     MOVELMSG,6     D#MSG
     C                     SETON                     2399
 E2  C                     ENDIF
E1   C                     ENDIF
