     C                     ELSE
     C                     MOVE A2SSYT    $$HAKO
     C                     ENDIF
     C           A2TRHZ    IFGT *DATE
     C                     MOVE A2KTRK    $$KTRK
     C                     MOVE A2KTRT    $$KTRT
     C                     MOVE A2KTRR    $$KTRR
     C                     MOVE A2KTRD    $$KTRD
     C                     ELSE
     C                     MOVE A2STRK    $$KTRK
     C                     MOVE A2STRT    $$KTRT
     C                     MOVE A2STRR    $$KTRR
     C                     MOVE A2STRD    $$KTRD
     C                     ENDIF
     C                     ENDIF
