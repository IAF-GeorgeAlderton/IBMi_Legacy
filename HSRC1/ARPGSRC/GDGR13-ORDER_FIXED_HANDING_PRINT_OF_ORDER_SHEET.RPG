     C                     MOVE *BLANK    $$SMEI 15
     C                     MOVE *BLANK    $$TMEI 15
     C                     MOVE *BLANK    $$DMEI 15
     C                     Z-ADD0         $$GEK2  90       月間必要数
     C* S1SEIH = '3' AKBPL04 AKCPL01
     C* S1SEIH <> '3' FCEPL01
     C*
     C           S1SEIH    IFEQ '3'
     C           KEY01     SETLLAKBPL041                 10
     C                     MOVEA'0'       *IN,90
     C                     DO   *HIVAL
     C           ##21      TAG
     C           KEY01     READEAKBPL041                 10
     C           *IN10     IFEQ '0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    IFLE *DATE
     C                     GOTO ##21
     C                     END
     C                     END
     C           L1UKHZ    IFGT *DATE
     C                     GOTO ##21
     C                     END
     C           L1STHZ    IFLE *DATE
     C                     GOTO ##21
     C                     END
     C                     Z-ADD0         $$GEKN
     C                     Z-ADD0         $$TUSZ
     C                     MOVE *BLANK    $$TMEI
     C                     MOVE *BLANK    $$DMEI
     C                     MOVE L1SYOT    $$HAKO
     C                     MOVE L1TKR1    $$KTRK
     C                     MOVE L1TKR2    $$KTRT
     C                     MOVE L1TKR3    $$KTRR
     C                     MOVE L1TKR4    $$KTRD
     C                     END
     C  N10                END
     C* $$SMEI $$GEKN INPUT FROM FCEPL01
     C                     MOVE *BLANK    $$SMEI
     C           KEY01     CHAINFCEPL01              95
     C  N95      A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     95
     C                     ENDIF
     C           *IN95     IFEQ *OFF
     C                     MOVE A2SMEI    $$SMEI
     C                     Z-ADDA2GEKN    $$GEKN
     C                     END
     C* IF $$GEKN=0 THEN INPUT AKCPL01
     C           $$GEKN    IFEQ 0
     C                     SETOF                     95
     C           KEY01     CHAINAKCPL011             95
     C           *IN95     IFEQ '0'
     C           M1SKJY    IFEQ 'D'
     C           M1SKHZ    ANDLE*DATE
     C                     SETON                     95
     C                     END
     C                     END
     C           *IN95     IFEQ '0'
     C                     MOVE M1GEKN    $$GEKN
     C                     END
     C                     END
     C*
     C                     ELSE
     C* S1SEIH <> '3' FCEPL01
     C           KEY01     CHAINFCEPL01              95
     C  N95      A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     95
     C                     ENDIF
