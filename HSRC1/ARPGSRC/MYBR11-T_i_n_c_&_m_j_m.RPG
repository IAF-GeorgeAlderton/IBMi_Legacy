      *
      *
      ****************************************
      * 前回入力したmﾞｰjそのまま残し表示 *
      ****************************************
     C           PFCMD     IFEQ 'F3'
      *
     C                     MOVE *BLANK    PFCMD
     C                     MOVELPKOJO     IKOJO
     C                     MOVEAPKOTI     IKO
     C                     MOVEAPCOST     ICO
     C                     MOVELPKUBN     IKUBN
     C                     MOVELPNATK     INATK
     C                     MOVELPNAKI     INAKI
     C                     MOVELPBRYM     IBRYM
      *
     C                     Z-ADD1         A
     C                     MOVE *BLANK    WKTCK
     C                     MOVE *BLANK    WCSCK
     C           1         DO   10        A
     C           IKO,A     IFNE *BLANK
     C                     MOVEL'*'       WKTCK
     C                     END
     C           ICO,A     IFNE *BLANK
     C                     MOVEL'*'       WCSCK
     C                     END
     C                     END
      *
      *==========
      * 工場名
     C                     MOVELIKOJO     WKOJO   40
      *
     C                     SETOF                     01
     C                     MOVE *BLANK    OKJNM
     C           WKOJO     CHAINFGBPL011             01
     C           *IN01     IFEQ '0'
     C                     MOVELB2KEMI    OKJNM
     C                     END
      *
      *===========
      *  ﾃﾇnﾈ]jｰ
     C                     CLEAROCO
     C                     Z-ADD1         A
     C           1         DO   10        A
     C           ICO,A     IFNE *BLANK
     C                     MOVELICO,A     WCOST
     C                     MOVE *BLANK    OCOST
     C                     MOVELWCOS1     OCOS1
     C                     MOVELWCOS2     OCOS2
     C                     MOVELWCOS3     OCOS3
     C                     MOVEL'-'       OCO1
     C                     MOVEL'-'       OCO2
     C                     MOVELOCOST     OCO,A
     C                     END
     C                     END
