      ***********************************************
      * MAIN ROUTINE                                *
      ***********************************************
      * GET TOTAL
     C                     Z-ADD*ZERO     WW#BOX  90
     C           *LOVAL    SETLLABWPP31
     C                     DO   *HIVAL
     C                     READ ABWPP31                  99
     C           *IN99     IFEQ *ON
     C                     LEAVE
     C                     END
     C                     ADD  FC#BOX    WW#BOX           TOTAL BOX#
     C                     ENDDO
      *
     C           WW#BOX    DIV  PMXPL     @TPAL   50
     C                     MVR            @@MVR   50
     C           @@MVR     IFNE *ZERO
     C                     ADD  1         @TPAL            TOTAL PALLET#
     C                     END
     C*
     C           *LIKE     DEFN ISBAN     W@SBAN
     C           *LIKE     DEFN IMHN      W@MHN
     C                     MOVEL*BLANK    W@SBAN
     C                     MOVEL*BLANK    W@MHN
     C                     MOVEL*BLANK    W@LOC1  1
     C                     MOVEL*BLANK    W@LOC2  2
     C                     MOVEL*BLANK    W@LOC3  2
     C                     MOVEL*BLANK    W@LOC4  1
     C                     Z-ADD*ZERO     WHAKO
     C                     Z-ADD*ZERO     WD#BOX  50
TCHK2C                     MOVEL*OFF      W@1ST   1
      * DETAIL PROCESS
     C           *LOVAL    SETLLABWPP31
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ABWPP31                  99
      * END PROCESS
     C           *IN99     IFEQ *ON
     C                     EXSR #DTL
     C                     EXSR #TTL
     C                     LEAVE
     C                     END
     C* FIRST?
     C           W@SBAN    IFEQ *BLANK
     C                     MOVELISBAN     W@SBAN
     C                     END
      *
     C           W@MHN     IFEQ *BLANK
     C                     MOVELIMHN      W@MHN
     C                     END
      *
TCHK2C           W@1ST     IFEQ *OFF
     C                     MOVELFCLOC1    W@LOC1
     C                     MOVELFCLOC2    W@LOC2
     C                     MOVELFCLOC3    W@LOC3
     C                     MOVELFCLOC4    W@LOC4
TCHK2C                     MOVEL*ON       W@1ST
JW2  C                     EXSR #SAVE
     C                     END
     C* BREAK?
     C           ISBAN     IFNE W@SBAN
     C           IMHN      ORNE W@MHN
     C                     EXSR #DTL
     C                     MOVELISBAN     W@SBAN
     C                     MOVELIMHN      W@MHN
     C                     MOVELFCLOC1    W@LOC1
     C                     MOVELFCLOC2    W@LOC2
     C                     MOVELFCLOC3    W@LOC3
     C                     MOVELFCLOC4    W@LOC4
JW2  C                     EXSR #SAVE
     C                     END
     C* DETAIL PROCESS
 GA  C                     MOVE '-'       FLD1
 GA  C                     MOVE '-'       FLD2
 GA  C                     MOVE '-'       FLD3
 GA  C                     MOVE '-'       FLD4
 GA  C                     MOVE *BLANK    FLD5
 GA  C                     SETOF                     11
 GA  C                     SETOF                     60
 GA  C                     SETOF                     12
     C                     SELEC
     C           ITOKU     WHEQ 5149
 GA  C                     SETON                     11
 GA  C                     MOVE IMHN1     WPART1
 GA  C                     MOVE IMHN2     WPART2
 GA  C                     MOVE IMHN3     WPART3
     C           ITOKU     WHEQ 0295
GA310C           ITOKU     OREQ 0296
     C                     SETON                     60
 GA  C                     MOVE IMHN1     NPART1
 GA  C                     MOVE IMHN2     NPART2
 GA  C                     MOVE IMHN3     NPART3
 GA  C                     MOVE NMHN1     PART1
 GA  C                     MOVE NMHN2     PART2
 GA  C                     MOVE NMHN3     PART3
 GA  C                     MOVE NMHN4     PART4
 GA  C                     MOVE PARTA     PART   17
     C           ITOKU     WHEQ 0390
     C                     SETON                     60
 GA  C                     MOVE IMHN1     NPART1
 GA  C                     MOVE IMHN2     NPART2
 GA  C                     MOVE IMHN3     NPART3
 GA  C                     MOVE NMHN1     PART5
 GA  C                     MOVE NMHN2     PART6
 GA  C                     MOVE NMHN3     PART7
 GA  C                     MOVE NMHN4     PART8
 GA  C                     MOVELPARTB     PART   17
 GA  C           ITOKU     WHEQ 0291
 GA  C                     SETON                     12
 GA  C                     MOVE IMHN1     WPART4
 GA  C                     MOVE IMHN2     WPART5
 GA  C                     MOVE IMHN3     WPART6
     C                     OTHER
     C                     MOVE IMHN1     WMHN1
     C                     MOVE '-'       WMH1
     C                     MOVE IMHN2     WMHN2
     C                     MOVE '-'       WMH2
     C                     MOVE IMHN3     WMHN3
GA   C                     MOVE IMHN5     WMHN4
GA   C                     MOVE '-'       WMH5
GA   C                     MOVE IMHN6     WMHN6
GA   C                     MOVE IMHN7     WMHN7
GA   C                     MOVE '-'       WMH8
GA   C                     MOVE IMHN8     WMHN9
GA   C                     MOVE '-'       WMH10
GA   C                     MOVELIMHN9     WMHN11
     C                     ENDSL
     C* GET SBAN
     C                     Z-ADDITOKU     KTOKU
     C                     Z-ADDINONY     KNONY            DELIVERY CODE
     C           KEY2      SETGTAB#PP85
     C           *IN90     DOUEQ*ON
     C           KEY2      REDPEAB#PP85                  90
     C           *IN90     IFEQ *OFF
     C           A5DATE    ANDLEINOHZ
     C                     MOVELA5SBAN    WSBAN     P
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C           *IN90     IFEQ *ON
     C                     MOVELISBAN     WSBAN     P
     C                     ENDIF
     C*---
     C                     ADD  FC#BOX    WHAKO
     C*---
      *
     C                     MOVE YYYY      WNOYY
     C                     MOVE MM        WNOMM
     C                     MOVE DD        WNODD
     C                     MOVE '/'       WNO1
     C                     MOVE '/'       WNO2
      *
     C                     ENDDO
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C******************************************************
     C** END OF MAIN ROUTIE                               **
     C******************************************************
     C*=====================================================
     C* WRITE TOTAL INFORMATION
     C*=====================================================
     C           #TTL      BEGSR
      *
TCH55C                     EXSR #LARG
     C                     WRITEAB#PR443
      *
     C                     ENDSR
     C*=====================================================
     C* WRITE DETAIL LINE
     C*=====================================================
     C           #DTL      BEGSR
      *
JW2  C           FIRST1    IFEQ 'Y'
     C                     MOVEL*BLANKS   SPART  17        PART#
     C                     MOVEL*BLANKS   SSBAN   4        KANBAN#
     C                     Z-ADD*DATE     PHZ8
     C                     TIME           WTIME
     C                     ADD  1         WD#BOX
     C                     EXSR #EDIT
     C                     WRITEAB#PR441
JW2  C                     ADD  1         @@SKD
JW2  C                     MOVE 'N'       FIRST1
     C                     ENDIF
     C*
     C                     ADD  WHAKO     THAKO
     C                     Z-ADD*ZERO     SHAKO   50
      *** LOOP *********************************************
     C                     DO   *HIVAL
      ******************************************************
      * NOT SPLIT
JW1  C           THAKO     IFLE PMXPL
     C           *IN70     IFEQ '1'
     C                     EXSR #EDIT
     C                     WRITEAB#PR441
JW2  C                     ADD  1         @@SKD
     C                     SETOF                     70
     C                     ENDIF
      *
     C                     WRITEAB#PR442
JW2   * OUT PP71
     C           WHAKO     IFNE 0
     C                     EXSR #PP71
     C                     ENDIF
      *
     C                     Z-ADD0         WHAKO
     C                     LEAVE
     C                     ENDIF
      * SPLIT
     C           THAKO     SUB  PMXPL     SHAKO
     C                     SUB  SHAKO     WHAKO
     C           *IN70     IFEQ '1'
     C                     EXSR #EDIT
     C                     WRITEAB#PR441
JW2  C                     ADD  1         @@SKD
     C                     SETOF                     70
     C                     ENDIF
      *
     C                     WRITEAB#PR442
JW2   * OUT PP71
     C           WHAKO     IFNE 0
     C                     EXSR #PP71
     C                     ENDIF
      *
     C                     Z-ADDPMXPL     THAKO
TCH55C                     EXSR #LARG
     C                     WRITEAB#PR443
      *
     C                     SETON                     70
     C                     ADD  1         WD#BOX
     C                     EXSR #EDIT
     C                     WRITEAB#PR441
JW2  C                     ADD  1         @@SKD
     C                     SETOF                     70
      *
     C                     Z-ADDSHAKO     THAKO
     C                     Z-ADDSHAKO     WHAKO
      *
     C           WHAKO     IFEQ *ZERO
     C                     LEAVE
     C                     END
      *
     C                     ENDDO
      *
JW2  C**N55                SETON                     55
      *
     C                     ENDSR
     C*=====================================================
     C* EDIT PALLET
     C*=====================================================
     C           #EDIT     BEGSR
      *
     C                     MOVELWD#BOX    W@A5    5
     C                     MOVEAW@A5      T1
     C                     Z-ADD*ZERO     X       20
     C                     Z-ADD*ZERO     Y       20
      *
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           X         IFGT 5
     C                     LEAVE
     C                     END
     C           T1,X      IFEQ *ZERO
     C                     ITER
     C                     END
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C                     MOVELT1,X      T2,Y
     C                     ADD  1         X
     C           X         IFGT 5
     C                     LEAVE
     C                     END
     C                     ENDDO
     C           X         IFGT 5
     C                     LEAVE
     C                     END
     C                     ENDDO
     C*
     C                     ADD  1         Y
     C                     MOVEL'/'       T2,Y
     C*
     C                     MOVEL@TPAL     W@A5
     C                     MOVEAW@A5      T1
     C                     Z-ADD*ZERO     X       20
      *
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           X         IFGT 5
     C                     LEAVE
     C                     ENDIF
     C           T1,X      IFEQ *ZERO
     C                     ITER
     C                     ENDIF
      *
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C                     MOVELT1,X      T2,Y
     C                     ADD  1         X
     C           X         IFGT 5
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           X         IFGT 5
     C                     LEAVE
     C                     END
     C                     ENDDO
     C*
     C                     MOVEAT2        @#PLT
     C*
     C                     ENDSR
      *========================================
      * SAVE WP31 DATA
      *========================================
JW2  C           #SAVE     BEGSR
      *
     C                     MOVELINOHZ     SNOHZ
     C                     MOVELINOTM     SNOTM
     C                     MOVELISIRE     SSIRE
     C                     MOVELISIRK     SSIRK
     C                     MOVELINUKE     SNUKE
     C                     MOVELIODRN     SODRN
     C**                   MOVELISBAN     SSBAN
     C                     MOVELIMHN      SMHN
     C                     MOVELISRYO     SSRYO
     C                     MOVELISYOS     SSYOS
     C                     MOVELISHN      SSHN
     C                     MOVELITOKU     STOKU
     C                     MOVELINONY     SNONY
     C                     MOVELINKOJ     SNKOJ
     C                     MOVELIINV#     SINV#
      *
JW2  C                     ENDSR
      *========================================
      * OUTPUT AB#PP71
      *========================================
JW2  C           #PP71     BEGSR
      * GET PACKING LIST#
     C                     MOVELSNOHZ     $NOHZ   8
     C                     MOVELSTOKU     $CUST
     C                     MOVELSNONY     $NONY
     C                     MOVELSNKOJ     $NKOJ
     C                     MOVELSNUKE     $NUKE
     C                     MOVELSNOTM     $BINN
     C                     MOVEL'00000000'$RLHZ
     C                     MOVE *BLANK    $ODRN
     C                     CALL 'UTLR51'
     C                     PARM           $NOHZ   8
     C                     PARM           $CUST   4
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $BINN   2
     C                     PARM           $RLHZ   8
     C                     PARM           $ODRN  10
     C                     PARM           $PICK#  9
     C                     PARM           $RTN    1
      * IF FIRST PACKING#, DELETE PAST RECORD
     C           FIRST2    IFEQ 'Y'
     C                     MOVE 'N'       FIRST2
     C                     EXSR #DLT71
     C                     ENDIF
      *
     C                     CLEARAB#PP711
     C                     Z-ADDTODAY     MPCRHZ           CRT DATE
     C                     Z-ADDNOW       MPCRTM           CRT TIME
     C                     MOVEL#USER     MPCRUS           CRT USER
     C                     MOVEL#PGM      MPCRPG           CRT PGM
     C                     MOVEL#WSID     MPCRWS           CRT WSID
     C                     MOVEL$PICK#    MPSERL           PACKING LIST#
      *
     C                     Z-ADD@@SKD     MPPAL#           PALLET#
     C                     Z-ADDSTOKU     MPTOKU           CUST CODE
     C                     Z-ADDSNONY     MPNONY           DELIV CODE
     C                     MOVELSNKOJ     MPNKOJ           FACTORY
     C                     MOVELSNUKE     MPNUKE           DOCK
     C                     MOVELSMHN      MPMHN            USER PART
     C                     Z-ADDSNOHZ     MPNOHZ           SHIP DATE
     C                     Z-ADDSNOTM     MPNOBN           BIN
     C                     MOVELSODRN     MPODRN           ORDER NO
      * VALUE
     C           WHAKO     MULT SSYOS     MPSRYO           ORDER QTY
     C                     Z-ADDSSYOS     MPSYOS           QTY/BOX
     C                     Z-ADDWHAKO     MPHAKO           BOX
     C                     MOVELSSHN      MPSHN            IAF PART1
     C                     MOVELFCLOC1    MPLOC1           LOC 1
     C                     MOVELFCLOC2    MPLOC2           LOC 2
     C                     MOVELFCLOC3    MPLOC3           LOC 3
     C                     MOVELFCLOC4    MPLOC4           LOC 4
     C                     Z-ADD@TPAL     MPTPAL           TTL PALLET#
      *
     C                     WRITEAB#PP711
      *
JW2  C                     ENDSR
      *========================================
      * DELETE PAST RECORD
      *========================================
JW2  C           #DLT71    BEGSR
      *
     C           $PICK#    SETLLAB#PP71
     C                     DO   *HIVAL
     C           $PICK#    READEAB#PP71                  98
     C   98                LEAVE
      *
     C           MPSKJY    IFEQ *BLANK
     C                     MOVE 'D'       MPSKJY
     C                     Z-ADDTODAY     MPSKHZ
     C                     UPDATAB#PP711
     C                     ENDIF
     C                     ENDDO
      *
JW2  C                     ENDSR
     C*=====================================================
     C* PRINT LARGE CHARACTER
     C*=====================================================
     C           #LARG     BEGSR
      *
     C                     MOVELWNOMM     WW,1
     C                     MOVE WNOMM     WW,2
     C                     MOVELWNODD     WW,3
     C                     MOVE WNODD     WW,4
     C*
     C           1         DO   4         CC      10
     C*
     C                     MOVE *BLANKS   #L1
     C                     MOVE *BLANKS   #L2
     C                     MOVE *BLANKS   #L3
     C                     MOVE *BLANKS   #L4
     C                     MOVE *BLANKS   #L5
     C                     MOVE *BLANKS   #L6
     C                     MOVE *BLANKS   #L7
     C                     MOVE *BLANKS   #L8
     C                     MOVE WW,CC     #CHR
     C                     CALL 'AB#R4P'  P#CMD
     C           CC        IFEQ 1
     C                     MOVE #L1       #11
     C                     MOVE #L2       #12
     C                     MOVE #L3       #13
     C                     MOVE #L4       #14
     C                     MOVE #L5       #15
     C                     MOVE #L6       #16
     C                     MOVE #L7       #17
     C                     MOVE #L8       #18
     C                     ENDIF
     C           CC        IFEQ 2
     C                     MOVE #L1       #21
     C                     MOVE #L2       #22
     C                     MOVE #L3       #23
     C                     MOVE #L4       #24
     C                     MOVE #L5       #25
     C                     MOVE #L6       #26
     C                     MOVE #L7       #27
     C                     MOVE #L8       #28
     C                     ENDIF
     C           CC        IFEQ 3
     C                     MOVE #L1       #31
     C                     MOVE #L2       #32
     C                     MOVE #L3       #33
     C                     MOVE #L4       #34
     C                     MOVE #L5       #35
     C                     MOVE #L6       #36
     C                     MOVE #L7       #37
     C                     MOVE #L8       #38
     C                     ENDIF
     C           CC        IFEQ 4
     C                     MOVE #L1       #41
     C                     MOVE #L2       #42
     C                     MOVE #L3       #43
     C                     MOVE #L4       #44
     C                     MOVE #L5       #45
     C                     MOVE #L6       #46
     C                     MOVE #L7       #47
     C                     MOVE #L8       #48
     C                     ENDIF
     C*
     C                     ENDDO
     C*
     C                     ENDSR
