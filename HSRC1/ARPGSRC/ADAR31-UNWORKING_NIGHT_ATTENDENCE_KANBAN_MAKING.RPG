     H            Y
     F**************************************************
     F* UNWORKING NIGHT ATTENDENCE KANBAN MAKING  SALES /PRODUCT DEMAND FORECAST
     F* HANDLING
     F**************************************************
     FAB#PP01 IP  E                    DISK                           U2
     FABBPP01 IS  E                    DISK                           U1
     FAB#PL03 IF  E           K        DISK                           U3
     FADAWL30 IF  E           K        DISK
     FADAWLB1 IS  E           K        DISK                           U3
     FAGDPL11 IF  E           K        DISK
     FADAWP31 O   F      32            DISK                      A
     I            DS
     I                                        1   4 W5NONY
     I                                        5   8 W5NUKE
     I                                        1   8 WAKEY
     I            DS
     I                                        1   4 W1NONY
     I                                        5   8 W1NUKE
     I                                        1   8 WBKEY
     I            DS
     I                                        1   40B1NOYY
     I                                        5   60B1NOMM
     I                                        7   80B1NODD
     I                                        1   80B1NOHZ
     I            DS
     I                                        1   5 Q5SHN1
     I                                        6  10 Q5SHN2
     I                                       11  12 Q5SHN3
     I                                        1  12 WHINA
     I            DS
     I                                        1   5 B1SHN1
     I                                        6  10 B1SHN2
     I                                       11  12 B1SHN3
     I                                        1  12 WHINB
     I            DS
     I                                        1   80B1SKHZ
     I                                        1   40B1SKYY
     I                                        5   60B1SKMM
     I                                        7   80B1SKDD
     **
     C**************************
     C*  初期値セット        *
     C**************************
     C           *ENTRY    PLIST
     C                     PARM           PARM1   1        *区分
     C                     PARM           PARM2   8        *日付１
     C                     PARM           PARM3   8        *日付２
     C                     PARM           PARM4   1        *保管
     C                     PARM           PARM5   1        *方式
     C                     PARM           PARM6   6        *番地
     C                     PARM           PARM7   8        *Ｓ日付
     C                     PARM           PARM8   8        *Ｅ日付
     C                     PARM           PARM9   1        *前夜勤区
     C                     PARM           PARM10  6        *年月
     C                     PARM           PARM11  1        *旬
     C                     MOVE PARM10    WYM     60
     C                     MOVE PARM11    WHI     10
     C                     MOVE PARM7     WSYMD   80
     C                     MOVE PARM8     WEYMD   80
     C**************************
     C* 合成キー             *
     C**************************
     C           #KEY1     KLIST
     C                     KFLD           #HIN1   5
     C                     KFLD           #HIN2   5
     C                     KFLD           #HIN3   2
     C           #KEY      KLIST
     C                     KFLD           #YY     40
     C                     KFLD           #MM     20
     C                     KFLD           #DD     20
     C           #KEY2     KLIST
     C                     KFLD           #NONU   40
     C                     KFLD           #KOJO   1
     C                     KFLD           #UKEI   4
     C   U1                SETON                     31
     C   U2                SETON                     32
     C   U3                SETON                     33
     C           FLDSW     IFEQ *BLANK
     C                     Z-ADD0         WKNONY
     C                     MOVE '1'       FLDSW   1
     C                     END
     C**********************************
     C*  内示累積処理   < ABBPP01 >  *
     C**********************************
     C           *IN31     IFEQ '1'
     C           *IN10     IFEQ '0'
     C                     EXSR $SB900
     C                     END
     C           Q5NNNK    IFNE *BLANK
     C                     Z-ADDQ5NNNM    WKKSU1  70
     C                     ELSE
     C           Q5CHS2    IFNE *ZERO
     C                     Z-ADDQ5CHS2    WKKSU1
     C                     ELSE
     C                     Z-ADDQ5CHS1    WKKSU1
     C                     END
     C                     END
     C           WKKSU1    IFNE *ZERO
     C           X         IFNE *ZERO
     C           WKKSU1    DIV  Y         CTRSU   70H
     C           CTRSU     MULT X         OSUU    70
     C                     END
     C                     MOVE Q5NONY    #NONU
     C                     MOVE Q5NUKE    #UKEI
     C                     MOVE Q5NKOJ    #KOJO
     C           WKNUKE    IFEQ Q5NUKE
     C           WKNONY    ANDEQQ5NONY
     C           WKNKOJ    ANDEQQ5NKOJ
     C                     ELSE
     C                     SETOF                       21
     C           #KEY2     CHAINADAWL301             21
     C                     END
     C           *IN21     IFEQ '0'
     C                     MOVE Q5NONY    ONONU   40
     C                     MOVE Q5NUKE    OUKEI   4
     C                     MOVE DABIN     OBIN    10
     C                     MOVE WHINA     OHIN   12
     C                     MOVE Q5NKOJ    OKOJO   1
     C                     MOVE Q5SHN1    #HIN1
     C                     MOVE Q5SHN2    #HIN2
     C                     MOVE Q5SHN3    #HIN3
     C           DANIS     IFNE *ZEROS
     C           OSUU      MULT DANIS     OSUU
     C                     END
     C                     EXCPTFILE
     C                     Z-ADD0         OSUU
     C                     END
     C                     MOVE Q5NUKE    WKNUKE  4
     C                     MOVE Q5NONY    WKNONY  40
     C                     MOVE Q5NKOJ    WKNKOJ  1
     C                     END
     C                     END
     C********************************
     C*  売上累積処理  <AB#PP01 >  *
     C********************************
     C           *IN32     IFEQ '1'
     C                     SETOF                       60
     C           B1SKJY    IFEQ 'D'
     C           B1SKHZ    ANDLT*DATE
     C                     SETON                     60
     C                     END
      *
     C           *IN60     IFEQ '0'
     C           B1NOHZ    IFGE WSYMD
     C           B1NOHZ    ANDLEWEYMD
     C                     MOVE B1NUKE    #UKEI
     C                     MOVE B1NONY    #NONU
     C                     MOVE B1NKOJ    #KOJO
     C           WKNUKE    IFEQ B1NUKE
     C           WKNONY    ANDEQB1NONY
     C           WKNKOJ    ANDEQB1NKOJ
     C                     ELSE
     C                     SETOF                       21
     C           #KEY2     CHAINADAWL301             21
     C                     END
     C           *IN21     IFEQ '0'
     C                     MOVE B1NONY    ONONU
     C                     MOVE B1NUKE    OUKEI
     C                     MOVE DABIN     OBIN
     C                     MOVE B1SRYO    OSUU
     C                     MOVE WHINB     OHIN
     C                     MOVE B1NKOJ    OKOJO
     C           DANIS     IFNE *ZEROS
     C           OSUU      MULT DANIS     OSUU
     C                     END
     C                     EXCPTFILE
     C                     Z-ADD0         OSUU
     C                     END
     C                     MOVE B1NUKE    WKNUKE  4
     C                     MOVE B1NONY    WKNONY  40
     C                     MOVE B1NKOJ    WKNKOJ  1
     C                     END
     C                     END
      *
     C                     END
     C**************************************
     C*  売上累積処理品番別  <AB#PL03 >  *
     C**************************************
     C           *IN33     IFEQ '1'
     C                     MOVE DAHIN1    #HIN1
     C                     MOVE DAHIN2    #HIN2
     C                     MOVE DAHIN3    #HIN3
     C                     MOVE *BLANK    FSW     1
     C                     SETOF                         61
     C           #KEY1     SETLLAB#PL031
     C                     DO   *HIVAL
     C           #KEY1     READEAB#PL031                 61
     C                     SETOF                         62
     C           *IN61     IFEQ '0'
     C           B1SKJY    ANDEQ'D'
     C           B1SKHZ    ANDLE*DATE
     C                     SETON                         62
     C                     END
     C           *IN62     IFEQ '0'
     C           *IN61     ANDEQ'0'
     C           B1NOHZ    ANDGEWSYMD
     C           B1NOHZ    ANDLEWEYMD
     C           FSW       IFEQ *BLANK
     C                     MOVE B1NONY    BKNONY  40
     C                     MOVE B1NUKE    BKNUKE  4
     C                     MOVE B1NKOJ    BKNKOJ  1
     C                     MOVE '*'       FSW
     C                     END
      * FILE CRT
     C                     MOVE BKNONY    ONONU
     C                     MOVE BKNUKE    OUKEI
     C                     MOVE BKNKOJ    OKOJO
     C                     MOVE DABIN     OBIN
     C                     MOVE B1SRYO    OSUU
     C                     MOVE DASHIN    OHIN
     C           DANIS     IFNE *ZEROS
     C           OSUU      MULT DANIS     OSUU
     C                     END
     C                     EXCPTFILE
     C                     Z-ADD0         OSUU
     C                     END
     C  N61                END
      *
     C                     END
     C*************************
     C*  カレンダー処理     *
     C*************************
     CSR         $SB900    BEGSR
     C*
     C** 旬の計算
     C*
     C                     Z-ADD0         X       20
     C                     MOVE PARM10    WYM     60
     C                     MOVE PARM11    WHI     10
     C                     MOVELWYM       WEYMD
     C                     MOVELWYM       WSYMD
     C           WHI       IFEQ 1
     C                     MOVE 01        WSYMD
     C                     MOVE 10        WEYMD
     C                     ELSE
     C           WHI       IFEQ 2
     C                     MOVE 11        WSYMD
     C                     MOVE 20        WEYMD
     C                     ELSE
     C                     MOVE 21        WSYMD
     C                     MOVE 31        WEYMD
     C                     END
     C                     END
     C                     MOVE WSYMD     WWMD    40
     C                     MOVELWSYMD     #YY
     C                     MOVELWWMD      #MM
     C                     MOVE WSYMD     #DD
     C           #KEY      SETLLAGDPL111
     C           *IN81     DOWEQ'0'
     C                     READ AGDPL111                 81
     C           *IN81     CABEQ'1'       NEXT
     C                     MOVELF8KAYY    F8HYM   60
     C                     MOVE F8KAMM    F8HYM
     C                     MOVE F8KADD    F8KAHZ  80
     C                     MOVELF8HYM     F8KAHZ
     C           F8KAHZ    IFGE WSYMD
     C           F8KAHZ    IFLE WEYMD
     C                     ADD  1         X
     C                     END
     C                     END
     C                     END
     C*
     C** 月の計算
     C*
     C           NEXT      TAG
     C                     Z-ADD0         Y       20
     C*  01
     C           #MM       IFEQ 01
     C                     MOVE 31        WEYMD
     C                     MOVE 01        WSYMD
     C                     END
     C*  02
     C           #MM       IFEQ 02
     C           #YY       DIV  4         AXX     30
     C                     MVR            AMX     30
     C           AMX       IFNE *ZERO
     C                     MOVE 28        WEYMD
     C                     ELSE
     C                     MOVE 29        WEYMD
     C                     END
     C                     MOVE 01        WSYMD
     C                     END
     C*  03
     C           #MM       IFEQ 03
     C                     MOVE 31        WEYMD
     C                     MOVE 01        WSYMD
     C                     END
     C*  04
     C           #MM       IFEQ 04
     C                     MOVE 30        WEYMD
     C                     MOVE 01        WSYMD
     C                     END
     C*  05
     C           #MM       IFEQ 05
     C                     MOVE 31        WEYMD
     C                     MOVE 01        WSYMD
     C                     END
     C*  06
     C           #MM       IFEQ 06
     C                     MOVE 30        WEYMD
     C                     MOVE 01        WSYMD
     C                     END
     C*  07
     C           #MM       IFEQ 07
     C                     MOVE 31        WEYMD
     C                     MOVE 01        WSYMD
     C                     END
     C*  08
     C           #MM       IFEQ 08
     C                     MOVE 31        WEYMD
     C                     MOVE 01        WSYMD
     C                     END
     C*  09
     C           #MM       IFEQ 09
     C                     MOVE 30        WEYMD
     C                     MOVE 01        WSYMD
     C                     END
     C*  10
     C           #MM       IFEQ 10
     C                     MOVE 31        WEYMD
     C                     MOVE 01        WSYMD
     C                     END
     C*  11
     C           #MM       IFEQ 11
     C                     MOVE 30        WEYMD
     C                     MOVE 01        WSYMD
     C                     END
     C*  12
     C           #MM       IFEQ 12
     C                     MOVE 31        WEYMD
     C                     MOVE 01        WSYMD
     C                     END
     C                     MOVE WSYMD     WWMD    40
     C                     MOVELWSYMD     #YY
     C                     MOVELWWMD      #MM
     C                     MOVE WSYMD     #DD
     C                     SETOF                         81
     C           #KEY      SETLLAGDPL111
     C           *IN81     DOWEQ'0'
     C                     READ AGDPL111                 81
     C           *IN81     CABEQ'1'       $S900E
     C                     MOVELF8KAYY    F8HYM   60
     C                     MOVE F8KAMM    F8HYM
     C                     MOVE F8KADD    F8KAHZ  80
     C                     MOVELF8HYM     F8KAHZ
     C           F8KAHZ    IFGE WSYMD
     C           F8KAHZ    IFLE WEYMD
     C                     ADD  1         Y                * iﾞlf]
     C                     END
     C                     END
     C                     END
     C           $S900E    TAG
     C                     SETON                       10
     CSR                   ENDSR
     **
     OADAWP31 EADD             FILE
     O                         ONONU      4
     O                         OUKEI      8
     O                         OSUU      15
     O                         OBIN      16
     O                         OHIN      28
     O                         OKOJO     29
