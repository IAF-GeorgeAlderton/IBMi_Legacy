     H            Y.
     F** VVVRA0 ****************************
     F* CREATE PGM-FILE TABLE              *
     F* %0001 REMOVE CHECK LIGIC FOR MANE  TUCKER *
     F**************************************
     FVVVWPA0 IF  E                    DISK
     FVVVPPA0 O   E                    DISK                      A
      *
     I            DS
     I                                        1  10 WHPNAM
     I                                        2   3 KBN2
     I                                        4   4 KBN
      *
     I            DS
     I                                        1  11 WHFNAM
     I                                        4   5 PP
      *
     C                     READ VVVWPA0                  81
     C           *IN81     DOWEQ'0'
     C           KBN       IFEQ 'R'
     C           KBN2      OREQ '#R'
     C           WHOBJT    IFEQ 'F'
     C                     EXSR #SB001
     C                     ENDIF
     C                     ENDIF
     C                     READ VVVWPA0                  81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *-----------------------------------------*
      *                                         *
      *-----------------------------------------*
     CSR         #SB001    BEGSR
      *
     C                     MOVELWHPNAM    VVPNAM
     C                     MOVELWHFNAM    VVFNAM
     C                     MOVEL*BLANK    VVRFI
     C* %0001 REMOVE CHECK LOGIC FOR NAME
     C***        PP        IFEQ 'PP'
     C***        PP        OREQ 'NP'
     C***        PP        OREQ 'TP'
     C***        PP        OREQ 'WP'
     C***        PP        OREQ 'PR'
     C***        PP        OREQ 'PW'
     C                     MOVELWHFNAM    VVRFI
     C***                  ENDIF
     C                     Z-ADDWHFUSG    VVFUSG
     C                     MOVEL*BLANK    VVFUS@
     C           VVFUSG    IFEQ 1
     C                     MOVEL'I'       VVFUS@
     C                     END
     C           VVFUSG    IFEQ 2
     C                     MOVEL'O'       VVFUS@
     C                     END
     C           VVFUSG    IFEQ 3
     C                     MOVEL'I/O'     VVFUS@
     C                     END
     C           VVFUSG    IFEQ 4
     C                     MOVEL'U'       VVFUS@
     C                     END
     C           VVFUSG    IFEQ 5
     C                     MOVEL'I/U'     VVFUS@
     C                     END
     C           VVFUSG    IFEQ 6
     C                     MOVEL'O/U'     VVFUS@
     C                     END
     C           VVFUSG    IFEQ 7
     C                     MOVEL'I/O/U'   VVFUS@
     C                     END
     C           VVFUSG    IFEQ 8
     C                     MOVEL'N/S'     VVFUS@
     C                     END
     C           VVFUSG    IFEQ 0
     C                     MOVEL'N/A'     VVFUS@
     C                     END
     C                     WRITEVVVPPA01
      *
     CSR         ESB001    ENDSR
