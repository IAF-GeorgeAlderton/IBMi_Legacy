     H            Y.
     F** MRHR12 **************************************
     F* INQ PILOT LOCATION                           *
     F*    ITS.             2014.05.08               *
     F************************************************
     FMRHPW12 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL
     FMRHPL11 IF  E           K        DISK
      *
     E                    ER      1  15 65
      *
     I            DS
     I                                        1  14 WWSHN
     I                                        1   5 WWSHN1
     I                                        6   6 WWSF1
     I                                        7  11 WWSHN2
     I                                       12  12 WWSF2
     I                                       13  14 WWSHN3
      *
     I            DS
     I                                        1  12 SBHIN
     I                                        1   5 SBHIN1
     I                                        6  10 SBHIN2
     I                                       11  12 SBHIN3
      *
     I            DS
     I                                        1   9 P2JBN
     I                                        1   1 P2JBN1
     I                                        2   2 JF1
     I                                        3   4 P2JBN2
     I                                        5   5 JF2
     I                                        6   7 P2JBN3
     I                                        8   8 JF3
     I                                        9   9 P2JBN4
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTITM
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1BAN1  1
     C                     PARM           P1BAN2  2
     C                     PARM           P1BAN3  2
     C                     PARM           P1BAN4  1
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      *  メインルーチン                                  *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      *   初期処理                                       *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      *   主処理                                         *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *データ検索                                        *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     C           KEY       KLIST
     C                     KFLD           K1BAN1  1
     C                     KFLD           K1BAN2  2
     C                     KFLD           K1BAN3  2
     C                     KFLD           K1BAN4  1
     C                     MOVELP1BAN1    K1BAN1
     C                     MOVELP1BAN2    K1BAN2
     C                     MOVELP1BAN3    K1BAN3
     C                     MOVELP1BAN4    K1BAN4
     C                     SETOF                     8166
     C           KEY       SETLLMRHPL111
     C                     READ MRHPL111                 81
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ MRHPL111                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     MOVE '02'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      *   第二画面処理                                   *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C           CTRX      IFEQ 0
     C                     SETON                     72
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     ELSE
     C                     SETON                     7273
     C                     ENDIF
      *
     C                     WRITEMRHPW129
     C                     EXFMTSFLCTL
     C                     SETOF                     7273
     C                     SETOF                     3199
     C                     MOVEL*BLANK    D9ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           CTRX      IFEQ 0
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
      * ROLLDOWN/PAGEUP *
      *-----------------*
     C           *IN52     IFEQ '1'
     C*                    ADD  1         CTRX
      * 1ST. PAGE
     C           WKPAGE    IFEQ 1
     C**                   GOTO ESB220
     C                     ENDIF
      *-----------------*
     C           *IN81     IFEQ '1'
     C                     SETOF                     81
     C           *HIVAL    SETGTMRHPL111
     C                     READPMRHPL111                 81
     C                     SUB  1         CTRX
     C                     ENDIF
      *
     C                     ADD  15        CTRX
      *                         L--表示行数
     C                     SETOF                     6627
      *
     C                     DO   *HIVAL
     C                     EXSR #READP
     C                     READPMRHPL111                 81
     C  N81N27             ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C                     EXSR #NEXTP
     C  N81N66             ENDDO
      *
     C                     Z-ADD0         CTRX    40
      *
     C           *IN81     IFEQ '1'
     C           *LOVAL    SETLLMRHPL111
     C                     READ MRHPL111                 81
     C                     ENDIF
      *
     C                     EXSR #CLR
     C                     SETOF                     8166
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ MRHPL111                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C                     EXSR #NEXT
     C  N81N66             ENDDO
      *
     C                     SUB  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      *--------------------*
      * ROLL-UP            *
      *--------------------*
     C           *IN51     IFEQ '1'
     C           *IN81     ANDEQ'0'
      *
     C                     EXSR #CLR
      *
     C                     SETOF                     6681
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ MRHPL111                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C                     EXSR #NEXT
     C  N81N66             ENDDO
      *
     C                     ADD  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      *   終了処理                                       *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      *   照会データ検索                                 *
      *----------------------------------------------------*
     CSR         #READ     BEGSR
      *
     C           SBGSJY    IFEQ 'D'
     C           SBGSHZ    ANDLE*DATE
     C                     GOTO EREAD
     C                     ENDIF
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREAD
     C                     ENDIF
      *
     C                     EXSR #EDIT
     C                     ADD  1         RRN
     C                     ADD  1         @RRN
     C                     ADD  1         CTRX
     C                     WRITESFL
      *
     C           CTRX      IFEQ 15
     C                     SETON                       66
     C                     ENDIF
      *
     CSR         EREAD     ENDSR
      *----------------------------------------------------*
      *   検索ファイル逆読み                             *
      *----------------------------------------------------*
     CSR         #READP    BEGSR
      *
     C           SBGSJY    IFEQ 'D'
     C           SBGSHZ    ANDLE*DATE
     C                     GOTO EREADP
     C                     ENDIF
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREADP
     C                     ENDIF
      *
     C                     SUB  1         CTRX           27
      *
     CSR         EREADP    ENDSR
      *----------------------------------------------------*
      *   検索条件判定                                   *
      *----------------------------------------------------*
     CSR         #SELEC    BEGSR
      *
     C                     MOVEL'1'       WKGET
      *
     CSR         ESELEC    ENDSR
      *----------------------------------------------------*
      *   表示項目＆サブファイルクリアー                 *
      *----------------------------------------------------*
     CSR         #CLR      BEGSR
      *
     C                     SETON                     71
     C                     WRITESFLCTL
     C                     SETOF                     7166
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN    40
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         @SFRC1
      *
     CSR         ECLR      ENDSR
      *----------------------------------------------------*
      *   編集処理                                       *
      *----------------------------------------------------*
     CSR         #EDIT     BEGSR
      *
     C                     MOVEL*BLANK    S1BAN
     C                     MOVEL*BLANK    P2JBN
     C                     MOVELSBBAN1    P2JBN1
     C                     MOVELSBBAN2    P2JBN2
     C                     MOVELSBBAN3    P2JBN3
     C                     MOVELSBBAN4    P2JBN4
     C                     MOVEL'-'       JF1
     C                     MOVEL'-'       JF2
     C                     MOVEL'-'       JF3
     C                     MOVELP2JBN     S1BAN
     C                     Z-ADDSBHAKO    S1HAKO
      *
     C                     MOVEL*BLANK    S1SHN
     C                     MOVEL*BLANK    WWSHN
     C           SBHIN     IFNE *BLANK
     C                     MOVELSBHIN1    WWSHN1
     C           SBHIN2    IFNE *BLANK
     C                     MOVEL'-'       WWSF1
     C                     MOVELSBHIN2    WWSHN2
     C           SBHIN3    IFNE *BLANK
     C                     MOVEL'-'       WWSF2
     C                     MOVELSBHIN3    WWSHN3
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     MOVELWWSHN     S1SHN
      *
     C                     MOVEL*BLANK    S1LNO
     C           SBLNO1    IFNE *BLANK
     C           SBLNO1    CAT  '-':0     S1LNO
     C           S1LNO     CAT  SBLNO2:0  S1LNO
     C                     ENDIF
      *
     CSR         EEDIT     ENDSR
      *----------------------------------------------------*
      *   次データ                                       *
      *----------------------------------------------------*
     CSR         #NEXT     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXT
     C                     ENDIF
      *
     C                     READ MRHPL111                 81
      *
     CSR         ENEXT     ENDSR
      *----------------------------------------------------*
      *   前データ                                       *
      *----------------------------------------------------*
     CSR         #NEXTP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXTP
     C                     ENDIF
      *
     C                     READPMRHPL111                 81
      *
     CSR         ENEXTP    ENDSR
     C*----------------------------------------------------------------
