      * CREATE FILE OF VALID LOT #S FOR APICS KANBANS
      * LEC    2024/12/12    CREATE
      *******************************************************
     FAFAPPLT O   E           K        DISK                      A
      *
     E                    CHR    18  18  1               ALPHA CHARS
      *
     I            DS
     I                                        1   3 LOT#
     I                                        1   1 FRST
     I                                        2   2 SCND
     I                                        3   3 THRD
      *
      *
     C                     DO   18        X       20
     C                     MOVE CHR,X     FRST
      *
     C                     DO   18        Y       20
     C                     MOVE CHR,Y     SCND
      *
     C                     DO   18        Z       20
     C                     MOVE CHR,Z     THRD
      *
     C                     MOVE LOT#      BELOT#
     C                     WRITEAFAPPLT1
     C                     ENDDO
      *
     C                     ENDDO
     C                     ENDDO
      *
      *
     C                     Z-ADD1         CNT     30
     C           CNT       DOWLT990
     C                     MOVELCNT       BELOT#
     C                     WRITEAFAPPLT1
     C                     ADD  1         CNT
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
