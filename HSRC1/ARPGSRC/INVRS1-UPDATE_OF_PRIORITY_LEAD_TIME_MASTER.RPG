     C                     ENDSR
      *===============================================================
      *  画面３　チェック
      *===============================================================
     C           #CHK3     BEGSR
     C*--------------------
     C           D3DAYS    IFEQ 0
     C           D3HOUR    ANDEQ0
     C           D3MINS    ANDEQ0
     C                     SETON                     313233
     C                     SETON                     99
     C                     MOVELMSG,10    D3ERR
     C                     GOTO @CHK3Z
     C                     ENDIF
     C*
     C           D3HOUR    IFGT 24
     C                     SETON                     3299
     C                     MOVELMSG,11    D3ERR
     C                     GOTO @CHK3Z
     C                     ENDIF
     C*
     C           D3MINS    IFGT 60
     C                     SETON                     3399
     C                     MOVELMSG,12    D3ERR
     C                     GOTO @CHK3Z
     C                     ENDIF
     C*-------------------------
     C           @CHK3Z    TAG
     C*-------------------------
     C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK3 F5'
     C                     MOVEL'#UPDAT  '@STEP
     C                     ELSE
     C                     MOVEL'#DSP3   '@STEP
     C                     ENDIF
     C                     ENDSR
      *===============================================================
      *  更新処理
      *===============================================================
     C           #UPDAT    BEGSR
     C*
     C           KEY01     CHAININVPPS1              90
     C   90                CLEARINVPPS11
     C*
     C           D2TYPE    IFEQ '0'                        0-CANCEL
     C                     MOVE 'D'       M@SKJY           DELETE CODE
     C                     Z-ADD@SYSHZ    M@SKDT           DELETE DATE
     C  N90                UPDATINVPPS11
     C                     ELSE
     C                     MOVE *BLANK    M@SKJY           DELETE CODE
     C                     Z-ADD0         M@SKDT           DELETE DATE
     C                     Z-ADD@SYSHZ    M@KODT           UPDATE DATE
     C                     Z-ADD@SYSTM    M@KOTM           UPDATE TIME
     C                     MOVELW@PGM     M@KOPG           UPDATE PGM
     C                     MOVELW@USER    M@KOUS           UPDATE USER
     C                     MOVELK@BMON    M@BMON
     C                     MOVELK@KOTE    M@KOTE
     C                     MOVELK@KIBN    M@KIBN
     C                     Z-ADDD3DAYS    M@DAYS
     C                     Z-ADDD3HOUR    M@HOUR
     C                     Z-ADDD3MINS    M@MINS
     C                     MOVE D3SHTG    M@SHTG
     C   90                WRITEINVPPS11
     C  N90                UPDATINVPPS11
     C                     ENDIF
      *
     C                     MOVE *BLANK    D2TYPE
     C                     MOVE *BLANK    D2BMON
     C                     MOVE *BLANK    D2KOTE
     C                     MOVE *BLANK    D2KIBN
     C                     MOVE *BLANK    D2ERR
