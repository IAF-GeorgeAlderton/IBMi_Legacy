     H            Y.
     F** GDGRY1 *********************************************
     F* NUMBER OF SHEETS RECORD FILE CREATE                 *
     F*       MSK..                2004.11.09               *
     F********************************************* GDGRY1 **
     FGDGWP9Y IP  F     128            DISK
     FGDGPPY1 O   E                    DISK                      A
      *
     IGDGWP9Y AA  01
     I                                        1  12 INHIN L1
     I                                        1   5 INHN1
     I                                        6  10 INHN2
     I                                       11  12 INHN3
     I                                       13  13 INKBN
     I                                       14  180INMAS
     I                                       19  19 INFLG
     I                                       20  240INSEQ
      *
     C                     SELEC
      * KANBAN
     C           INKBN     WHEQ '1'
     C                     ADD  INMAS     @1MAIS
      * HAND
     C           INKBN     WHEQ '2'
     C                     ADD  INMAS     @2MAIS
      * UPDAT
     C           INKBN     WHEQ '3'
     C*          INSEQ     IFGE WKSEQ
     C*                    Z-ADDINMAS     @3MAIS
     C*                    MOVE INSEQ     WKSEQ   50
     C*                    MOVE INFLG     WKFL3   1
     C*                    END
     C                     ADD  INMAS     @3MAIS
      * MACHING
     C           INKBN     WHEQ '4'
     C                     ADD  INMAS     @4MAIS
      * PT PLAN +
     C           INKBN     WHEQ '5'
     C                     ADD  INMAS     @5MAIS
      *
      * PT PLAN -
     C           INKBN     WHEQ '6'
     C                     ADD  INMAS     @6MAIS
      * ADJUST.
     C           INKBN     WHEQ '7'
     C                     ADD  INMAS     @7MAIS
      * UPDAT
     C           INKBN     WHEQ '8'
     C*          INSEQ     IFGE WKSE1
     C*                    Z-ADDINMAS     @9MAIS
     C*                    MOVE INSEQ     WKSE1   50
     C*                    MOVE INFLG     WKFL7   1
     C*                    END
     C                     ADD  INMAS     @9MAIS
      *
     C                     ENDSL
      * PARTS NUMBER BREAK
     CL1                   EXSR $SB600
      *----------------------------------------------------*
      * NUMBER OF SHEETS RECORD FILE CREATE                *
      *----------------------------------------------------*
     CSR         $SB600    BEGSR
     C                     CLEARGDGPPY11
     C                     MOVE INHN1     XAHIN1
     C                     MOVE INHN2     XAHIN2
     C                     MOVE INHN3     XAHIN3
     C                     Z-ADD@1MAIS    XZMAS1
     C                     Z-ADD@2MAIS    XZMAS2
     C                     Z-ADD@3MAIS    XZMAS3
     C                     Z-ADD@4MAIS    XZMAS4
     C                     Z-ADD@5MAIS    XZMAS5
     C                     Z-ADD@6MAIS    XZMAS6
     C                     Z-ADD@7MAIS    XZMAS7
     C                     Z-ADD@9MAIS    XZMAS9
      *
     C*          WKFL3     IFEQ 'D'
     C*                    MULT -1        XZMAS3
      *
     C*                    ELSE
     C*          XZMAS1    ADD  XZMAS2    WKMAIS  50
     C*          XZMAS3    IFNE 0
     C*          XZMAS3    SUB  WKMAIS    XZMAS3
     C*                    END
     C*                    END
      *
     C                     WRITEGDGPPY11
     C                     Z-ADD0         @1MAIS  30
     C                     Z-ADD0         @2MAIS  30
     C                     Z-ADD0         @3MAIS  30
     C                     Z-ADD0         @4MAIS  30
     C                     Z-ADD0         @5MAIS  30
     C                     Z-ADD0         @6MAIS  30
     C                     Z-ADD0         @7MAIS  30
     C                     Z-ADD0         @8MAIS  30
     C                     Z-ADD0         @9MAIS  30
     C                     Z-ADD0         @@MAIS  30
     C                     Z-ADD0         WKSE1   50
     C                     Z-ADD0         WKSEQ   50
     C                     MOVE *BLANK    WKFL7   1
     C                     MOVE *BLANK    WKFL3   1
     CSR         $S600E    ENDSR
