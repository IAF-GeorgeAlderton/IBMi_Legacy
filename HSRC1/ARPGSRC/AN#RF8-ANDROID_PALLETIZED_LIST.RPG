     H            Y.
     F** AN#RF8 ********************************************
     F*  ANDROID PALLETIZED LIST                           *
     F*                                                    *
     F* TCHK1 07/18/06 CREATE(COPY FROM AB#RF8)            *
     F******************************************************
     FABR6L05 IF  E           K        DISK
     FABR6PW1 UF  E           K        DISK
     FAN#PRF8 O   E             70     PRINTER
     E************************************************
     E                    AR1        20  1
     E                    AR2        20  1
     E                    PLT       100  2 0
     I************************************************
     I* DELIVERY DATE
     I            DS
     I                                        1   8 WSHDT
     I                                        1   80KSHDT
     I                                        1   40WSHYY
     I                                        5   60WSHMM
     I                                        7   80WSHDD
     I            DS
     I                                        1   8 WREDT
     I                                        1   80KREDT
     I                                        1   40KREYY
     I                                        5   60KREMM
     I                                        7   80KREDD
     I                                        1   40WDEYY
     I                                        5   60WDEMM
     I                                        7   80WDEDD
     I* DELIVERY CODE
     I            DS
     I                                        1  13 WNOHB
     I                                        1  10 WNOHZ
     I                                        1   4 WNOYY
     I                                        5   5 WNO1
     I                                        6   7 WNOMM
     I                                        8   8 WNO2
     I                                        9  10 WNODD
     I                                       11  11 WNO3
     I                                       12  13 WNOBN
     I            DS
     I                                        1  10 WREHZ
     I                                        1   4 WREYY
     I                                        5   5 WRE1
     I                                        6   7 WREMM
     I                                        8   8 WRE2
     I                                        9  10 WREDD
 GA  I            DS
 GA  I                                        1  20 PARTN
 GA  I                                        1   7 WPART1
 GA  I                                        8  20 WPART2
     I            DS
     I                                        1   6 WDELY
     I                                        1   1 WKK1
     I                                        2   5 @DELY
     I                                        6   6 WKK2
     I* PART EDIT(W,N   YL)
     I            DS
     I                                        1  20 WMHIN
     I                                        1   7 WMHN1
     I                                        8   8 WMH1
     I                                        9  20 WMHN2
     I                                        1   5 WMHN3
     I                                        6   6 WMH2
     I                                        7  10 WMHN4
     I                                       11  11 WMH3
     I                                       12  20 WMHN5
     I            DS
     I                                        1  20 PARTN1
     I                                        1   5 WPART4
     I                                        6   9 WPART5
     I                                       10  20 WPART6
     I* SYSTEM DATE & TIME
     I            DS
     I                                        1  120WDTTM
     I                                        1   2 PTHHH
     I                                        3   4 PTMMM
     I                                        5   6 PTDDD
     I                                        7   8 PYYYY
     I                                        9  10 PMMMM
     I                                       11  12 PDDDD
     C************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PSIRE   4
     C                     PARM           PDOCK   4
     C                     PARM           PSHDT   80
     C                     PARM           PSHTM   20
     C                     PARM           PREHZ   80
     C                     PARM           PPS#    60
     C                     PARM           PBIL#  11
      *
     C           KEY1      KLIST
     C                     KFLD           KSHDT
     C                     KFLD           KSHTM
     C                     KFLD           KREYY
     C                     KFLD           KREMM
     C                     KFLD           KREDD
     C                     KFLD           KDELY
     C                     KFLD           KDOCK
      *
     C           KEY2      KLIST
     C                     KFLD           KSHDT
     C                     KFLD           KSHTM
     C                     KFLD           KREYY
     C                     KFLD           KREMM
     C                     KFLD           KREDD
     C                     KFLD           KDELY
     C                     KFLD           KDOCK
     C                     KFLD           KPLAT
     C                     KFLD           KCPAR
     C           K#FW      KLIST
     C                     KFLD           FCDELY
     C                     KFLD           FCDOCK
     C                     KFLD           FCSHDT
     C                     KFLD           FCSHTM
     C                     KFLD           FCRYYY
     C                     KFLD           FCRMMM
     C                     KFLD           FCRDDD
     C                     KFLD           FC#PLT
      *
     C           *LIKE     DEFN FCCPAR    KCPAR
     C           *LIKE     DEFN FCCPAR    @CPAR
     C           *LIKE     DEFN FC#PLT    KPLAT
     C           *LIKE     DEFN FC#PLT    @PLAT
     C                     Z-ADD*ZERO     @CONT   30
     C*
     C                     SETON                     77
     C                     MOVE PSHDT     KSHDT   80
     C                     Z-ADDPSHTM     KSHTM   20
     C                     MOVE PREHZ     KREHZ   80
     C                     MOVE PSIRE     KDELY   40
     C                     MOVE PDOCK     KDOCK   4
     C                     MOVELPPS#      WPS#    60
     C                     MOVELPBIL#     WBIL#  11
     C*
     C                     TIME           WDTTM
 GA  C                     MOVE *BLANK    WPART  20
     C                     MOVE *BLANK    WPBCD   1
 GA  C                     MOVEA*BLANK    AR1
 GA  C                     MOVEA*BLANK    AR2
     C                     Z-ADD*ZERO     WPLAT   20
     C                     MOVE PSHDT     WSHDT
     C                     MOVE WSHYY     WNOYY
     C                     MOVE '/'       WNO1
     C                     MOVE WSHMM     WNOMM
     C                     MOVE '/'       WNO2
     C                     MOVE WSHDD     WNODD
     C                     MOVE '-'       WNO3
     C                     MOVE PSHTM     WNOBN
     C                     MOVE PREHZ     WREDT
     C                     MOVE WDEYY     WREYY
     C                     MOVE '/'       WRE1
     C                     MOVE WDEMM     WREMM
     C                     MOVE '/'       WRE2
     C                     MOVE WDEDD     WREDD
      *
     C                     SELEC
     C           PSIRE     WHEQ '2855'
     C                     MOVEL'AIW01'   WPLAN
     C           PSIRE     WHEQ '2856'
     C                     MOVEL'AIL01'   WPLAN
     C                     ENDSL
      *
     C                     Z-ADD*ZERO     PLT
     C                     Z-ADD*ZERO     X       30
     C           KEY1      SETLLABR6P011
     C           *IN81     DOUEQ*ON
     C           KEY1      READEABR6P011                 81
     C           *IN81     IFEQ *OFF
     C           FCSKJY    ANDNE'D'
      *
     C           FC#PLT    LOKUPPLT                      11
     C           *IN11     IFEQ *OFF
     C           K#FW      CHAINABR6PW1              96
     C           *IN96     IFEQ *ON
     C           *IN96     OREQ *OFF
     C           WCPRNT    ANDNE*BLANK
     C                     ITER
     C                     ENDIF
     C                     MOVE '1'       WCPRNT
     C                     UPDATABR6PW11
     C                     ADD  1         X
     C                     Z-ADDFC#PLT    PLT,X
     C                     ENDIF
      *
     C           FCCPAR    IFNE @CPAR
     C           @CONT     ANDGT*ZERO
     C           FC#PLT    ORNE @PLAT
     C           @CONT     ANDGT*ZERO
     C                     MOVE @CPAR     KCPAR
     C                     Z-ADD@PLAT     KPLAT
     C                     EXSR #OUT
     C                     Z-ADD*ZERO     @CONT
     C           KEY2      SETGTABR6P011
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE FCCPAR    @CPAR
     C                     Z-ADDFC#PLT    @PLAT
     C           FCPBCD    IFNE 'M'
     C           FCPRNT    ANDNE'C'
     C                     ADD  1         @CONT
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           @CONT     IFGT *ZERO
     C                     MOVE @CPAR     KCPAR
     C                     Z-ADD@PLAT     KPLAT
     C                     EXSR #OUT
     C                     ENDIF
     C*
     C                     SETON                     LR
     C                     RETRN
      *------------------------------------------------------
     C           #OUT      BEGSR
      *------------------------------------------------------
     C                     MOVE *OFF      *IN90
     C                     MOVE *BLANK    WPART
     C           KEY2      SETLLABR6P011
     C           KEY2      READEABR6P011                 90
     C*
     C           *IN90     DOWEQ'0'
     C           FCSKJY    IFNE 'D'
     C*
     C           WPLAT     IFNE FC#PLT
     C                     MOVE FC#PLT    WPLAT
     C                     MOVE '('       WKK1
     C                     MOVE FCDELY    @DELY
     C                     MOVE ')'       WKK2
     C                     MOVE FCDOCK    WDOCK
     C                     WRITEAN#PRF81
     C                     SETON                     50
     C                     END
      *
     C* EDIT PART NUMBER
 GA  C           WPART     IFNE FCCPAR
 GA  C           FC#PLT    ORNE WPLAT
     C           WPART     IFNE *BLANK
     C                     MOVE *OFF      *IN50
     C                     ENDIF
      *
TCHK C                     MOVELFCCPAR    WPART
TCHK C                     MOVELFCCPAR    WMHIN
 GA  C***                  Z-ADD1         I       20
 GA  C***                  Z-ADD1         N       20
     C***                  MOVE *BLANK    AR2
 GA  C***                  MOVEAFCCPAR    AR1
 GA  C***        1         DO   20        I       20
 GA  C***        AR1,I     IFNE *BLANK
 GA  C***                  MOVE AR1,I     AR2,N
 GA  C***                  ADD  1         N       20
 GA  C***                  END
 GA  C***                  ENDDO
 GA  C***        AR2,1     IFEQ 'W'
 GA  C***        AR2,1     OREQ 'N'
 GA  C***                  MOVEL*BLANK    PARTN
 GA  C***                  MOVEAAR2       PARTN
     C***                  MOVE *BLANK    WMHIN            EDIT PART
 GA  C***                  MOVELWPART1    WMHN1            | 7-13
 GA  C***                  MOVE '-'       WMH1             |
 GA  C***                  MOVELWPART2    WMHN2            |
 GA  C***                  ELSE
 GA  C***                  MOVEL*BLANK    PARTN1
 GA  C***                  MOVEAAR2       PARTN1
     C***                  MOVE *BLANK    WMHIN            EDIT PART
 GA  C***                  MOVELWPART4    WMHN3
 GA  C***                  MOVE '-'       WMH2
 GA  C***                  MOVELWPART5    WMHN4
 GA  C***                  MOVE '-'       WMH3
 GA  C***                  MOVELWPART6    WMHN5
 GA  C***                  END
     C           *IN50     IFEQ '0'
     C                     WRITEDUMMY
     C                     END
     C                     SETOF                     50
     C                     WRITEAN#PRF82
     C                     MOVE FCPBCD    WPBCD
     C                     MOVE FC#PLT    WPLAT
     C                     ELSE
     C                     MOVE *BLANK    WMHIN
     C                     END
     C*
     C* LABEL DATA
     C           FCPRNT    IFNE 'C'
     C                     MOVE FC#PLT    PPLAT
     C                     MOVE FCPBCD    PPBCD
     C                     Z-ADDFCSEQ#    PSEQ#
     C                     WRITEAN#PRF83
 GA  C                     END
     C                     END
      *
     C           *IN70     IFEQ '1'
     C                     WRITEAN#PRF81
     C                     SETON                     50
     C                     SETOF                     70
     C                     MOVE *BLANK    WPART
     C                     END
     C*
     C           KEY2      READEABR6P011                 90
     C                     END
      *
     C                     ENDSR
