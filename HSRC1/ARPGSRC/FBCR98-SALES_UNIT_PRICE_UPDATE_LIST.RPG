     C                     Z-ADD0         ITSHZ
      *
     C           STP1      TAG
     C                     EXFMTFBCPW261
     C                     SETOF                     010203
     C                     SETOF                     99
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           ITOKU     IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
      *
     C                     SETOF                     10
     C                     MOVE ITOKU     WTOKU   40
     C           WTOKU     CHAINFGBPL011             10
     C           *IN10     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '1'
     C                     SETON                     0199
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
      *
     C           ITKHZ     IFEQ 0
     C                     SETON                     0299
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     END
      *
     C           ITKYY     IFGE 2000
     C           ITKMM     ANDGE01
     C           ITKMM     ANDLE12
     C           ITKDD     ANDGE01
     C           ITKDD     ANDLE31
     C                     ELSE
     C                     SETON                     0299
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     END
      *
     C           ITSHZ     IFEQ 0
     C                     SETON                     0399
     C                     MOVE ER,5      MSG
     C                     GOTO STP1
     C                     END
      *
     C           ITSYY     IFGE 2000
     C           ITSMM     ANDGE01
     C           ITSMM     ANDLE12
     C           ITSDD     ANDGE01
     C           ITSDD     ANDLE31
     C                     ELSE
     C                     SETON                     0399
     C                     MOVE ER,6      MSG
     C                     GOTO STP1
     C                     END
      *
     C           ITKHZ     IFGE ITSHZ
     C                     SETON                     020399
     C                     MOVE ER,7      MSG
     C                     GOTO STP1
     C                     END
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP1
     C                     END
