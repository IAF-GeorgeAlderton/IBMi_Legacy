     H            Y.
     F** AM#R40 ****************************************************************
     F*  PROGRAM    : TOYOTA SHIPPING CONFIRMATION MISSING PACKING DATA        *
     F*  WRITTEN    : 2/5/2019                                                 *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F*  FUNCTION   : CHECK TRANZACTION                                        *
     F**************************************************************************
     FAB#PL65CIF  E           K        DISK
     FAM#PL09 IF  E           K        DISK
     FAL#PL10 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   80K6NOHZ
     I                                        1   40K6NOYY
     I                                        5   60K6NOMM
     I                                        7   80K6NODD
     I            DS
     I                                        1   80A6NOHZ
     I                                        1   40A6NOYY
     I                                        5   60A6NOMM
     I                                        7   80A6NODD
     I            DS
     I                                        1   80A6DEHZ
     I                                        1   40A6DEYY
     I                                        5   60A6DEMM
     I                                        7   80A6DEDD
     I            DS
     I                                        1  20 A6MHN
     I                                        1   5 A6MHN1
     I                                        6  10 A6MHN2
     I                                       11  15 A6MHN3
     I                                       16  20 A6MHN4
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           K#65      SETLLAB#PL65C
     C           *IN98     DOWEQ*OFF
     C                     READ AB#PL65C                 98
     C   98                LEAVE
      * END ?
     C           A6NOHZ    IFGT @TO
     C                     LEAVE
     C                     ENDIF
      * IGNORE
     C           A6SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * CHAIN
     C                     MOVELA6NONY    K1NONY
     C                     MOVELA6NOHZ    K1SHID
     C                     MOVELA6NUKE    K1DOCK
     C                     MOVELA6ORNO    K1ORD#
     C                     MOVELA6MHN     K12HN1
     C                     MOVE '0000'    K12OX#
     C                     MOVE A6BOXN    K12OX#
     C           K#AM      CHAINAM#PL09              99
     C           *IN99     IFEQ *ON
     C                     EXSR @AL
     C                     EXSR @PRINT
     C                     ENDIF
      *
     C                     ENDDO
      * SET RETURN CODE
     C           SEQ#      IFEQ 0
     C                     MOVE '*'       $RTN
     C                     ELSE
     C                     MOVE *BLANK    $RTN
     C                     ENDIF
      * SET COUNT
     C                     MOVELSEQ#      $CNT
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  FETCH AL#PP01                                     *
      *----------------------------------------------------*
     C           @AL       BEGSR
      *
     C                     MOVELA6NOHZ    KASHID
     C                     MOVELA6TOKU    KATOKU
     C                     MOVELA6NONY    KANONY
     C                     MOVELA6NKOJ    KANKOJ
     C                     MOVELA6NUKE    KANUKE
     C                     MOVELA6MHN     KAMHN
     C                     MOVELA6ORNO    KAORD#
     C                     MOVELA6BOXN    KABOX#
     C           K#AL      CHAINAL#PL10              99
     C           *IN99     IFEQ *OFF
     C                     MOVELCASURT    @SURT   7
     C                     ELSE
     C                     MOVE *BLANK    @SURT
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           @PRINT    BEGSR
      *
     C           LIN#      IFGT 65
     C                     EXCPT@HDR
     C                     Z-ADD4         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $FROM   8
     C                     PARM           $TO     8
     C                     PARM           $CNT    4
     C                     PARM           $RTN    1
      *
     C                     MOVEL$FROM     @FROM   80
     C                     Z-ADD@FROM     K6NOHZ
     C                     MOVEL$TO       @TO     80
      *
     C           K#65      KLIST
     C                     KFLD           K6NOYY
     C                     KFLD           K6NOMM
     C                     KFLD           K6NODD
      *
     C           K#AM      KLIST
     C                     KFLD           K1NONY  40
     C                     KFLD           K1SHID  8
     C                     KFLD           K1DOCK  2
     C                     KFLD           K1ORD# 12
     C                     KFLD           K12HN1 12
     C                     KFLD           K12OX#  4
      *
     C           K#AL      KLIST
     C                     KFLD           KASHID  8
     C                     KFLD           KATOKU  40
     C                     KFLD           KANONY  40
     C                     KFLD           KANKOJ  1
     C                     KFLD           KANUKE  4
     C                     KFLD           KAMHN  12
     C                     KFLD           KAORD# 12
     C                     KFLD           KABOX#  4
      *
     C                     TIME           @SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   42 '** TOYOTA SHIPPING C'
     O                                   62 'ONFIRMATION - MISSIN'
     O                                   82 'G PACKING DATA **   '
     O                                   99 'DATE'
     O                         TODAY    102 '    .  .  '
     O                         NOW      112 '  :  :  '
     O                                  115 'P.'
     O                         PAGE  Z  119
     O        E   02           @HDR
     O                                    5 'FROM:'
     O                         @FROM     16 '    /  /  '
     O                                   21 'TO:'
     O                         @TO       32 '    /  /  '
     O                                   55 '<KANBAN(AB#PP65) VS '
     O                                   75 'PACKING(AM#PP01)>   '
     O        E   04           @HDR
     O                                    5 'SEQ#'
     O                                   13 'S_ROUTE'
     O                                   25 'SHIP DATE'
     O                                   32 'DLV#'
     O                                   37 'DOCK'
     O                                   46 'ORDER#'
     O                                   67 'CUST PART....'
     O                                   77 'BOX#'
     O                                   83 'KAN#'
     O                                   98 'IAF PARTS....'
     O                                  118 'SCAN DATE / TIME...'
     O        E 1              @DTL
     O                         SEQ#  Z +001
     O                         @SURT   +002
     O                         A6NOHZ  +002 '    /  /  '
     O                         A6NONY  +002
     O                         A6NUKE  +002
     O                         A6ORNO  +002
     O                         A6MHN1  +002
     O                         A6MHN2  +001
     O                         A6MHN3  +001
     O                         A6BOXN  +002
     O                         A6KANO  +002
     O                         A6SHN1  +002
     O                         A6SHN2  +001
     O                         A6SHN3  +001
     O                         A6DEHZ  +000 '    /  /  '
     O                         A6DETM  +001 '0 :  :  '
     O**      E 1              @FOT
     O**                                 20 '** THERE IS NO TARGE'
     O**                                 40 'T DATA **           '
