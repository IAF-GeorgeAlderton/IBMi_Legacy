     C**********************************************************
     C* MAIN
     C**********************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ AAJPL11                  98
     C   98                LEAVE
      *
     C           CJCHYY    IFNE 9999
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #SET
      *
     C                     WRITEAAJWP171
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C**********************************************************
     C* SET DATA
     C**********************************************************
     C           #SET      BEGSR
      *
     C                     CLEARAAJWP171
     C                     MOVELCJBMON    AJBMON
     C                     MOVELCJBAN1    XJBAN1
     C                     MOVELCJBAN2    XJBAN2
     C                     MOVELCJBAN3    XJBAN3
