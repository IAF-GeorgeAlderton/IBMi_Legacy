     C                     ELSE
     C                     MOVE '-'       XHP1
     C                     ENDIF
     C           CJHIN3    IFEQ *BLANK
     C                     MOVE ' '       XHP2
     C                     ELSE
     C                     MOVE '-'       XHP2
     C                     ENDIF
     C                     MOVELXJHIN     AJHIN
      *
     C                     MOVELCJSYUY    AJSYUY
