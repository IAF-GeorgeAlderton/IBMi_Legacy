     H            Y/                                    1
     H** FBCR47 *******************************************************
     H*  TOYOTA NAME CODE INQUIRY                                     *
     H*  JW      2018.08.07                                           *
     H*****************************************************************
     FFBCPW47 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN1  KSFILE SFL01
     FGADTL17 IF  E           K        DISK
     FFBCPP36 IF  E           K        DISK
      *================================================================
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *     <<
      *
     I           SDS
     I                                     *PROGRAM W@PGM
     I                                      244 253 W@WSID
     I                                      254 263 W@USER
     I                                      264 269 W@JBNO
     C*===============================================================
     C*  MAIN ROUTINE
     C*===============================================================
     C                     EXSR #INIT
      *
     C           *IN98     DOUEQ*ON
      *
     C                     SETON                     70
     C           ENDRRN    IFNE 0
     C                     SETON                     71
     C                     ENDIF
     C                     WRITEDSP01
     C                     EXFMTCTL01
     C                     SETOF                     707199
     C                     Z-ADD$$RRN     RRN1
     C*----------
     C                     SELEC
     C* <F3> END
     C           *INKC     WHEQ *ON
     C                     MOVE *ON       *IN98
     C* <PAGE UP/DOWN>
     C           *IN73     WHEQ *ON
     C           *IN73     OREQ *ON
      * <ENTR>
     C                     OTHER
     C           $RRN      IFNE 0
     C           $RRN      CHAINSFL01                95
     C           *IN95     IFEQ *OFF
     C                     MOVELS1SHP1    P@SHP1
     C                     MOVELS1SHP2    P@SHP2
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
     C           *ENTRY    PLIST
     C                     PARM           P@SHP1  5
     C                     PARM           P@SHP2  1
      *
     C           KEY01     KLIST
     C                     KFLD           K@SHP1
     C                     KFLD           K@SHP2
      *
     C                     TIME           @TIME
     C                     MOVEA*ALL'0'   *IN
      * SFLCLR
     C                     SETON                     72
     C                     WRITECTL01
     C                     SETOF                     72
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         ENDRRN  40
     C                     MOVE *BLANK    SVSHP1  5
      *
     C                     MOVELP@SHP1    K@SHP1 10
     C                     MOVELP@SHP2    K@SHP2 10
     C                     MOVEL*BLANK    P@SHP1
     C                     MOVEL*BLANK    P@SHP2
      * SET INITIAL DATA
     C           KEY01     SETLLFBCPP36
      *-----------------------------------
     C                     DO   *HIVAL
     C                     READ FBCPP36                  90
     C   90                LEAVE
     C*
     C           F3SKJY    IFEQ 'D'                        DELETE CODE
     C                     ITER
     C                     ENDIF
      *
      * BREAK?
     C           SVSHP1    IFNE *BLANK
     C           SVSHP1    ANDNEF3SHP1
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     MOVELF3SHP1    S1SHP1
     C                     MOVELF3SHP2    S1SHP2
     C                     MOVELF3TOKU    S1TOKU
     C                     MOVELF3NONY    S1NONY
     C                     MOVEL*BLANK    S1KMEI
      * GET NAME
     C                     MOVELS1NONY    #NONY   40
     C           #NONY     SETLLGADTL17
     C                     DO   *HIVAL
     C           #NONY     READEGADTL17                  91
     C   91                MOVEL'???'     S1KMEI    P
     C   91                LEAVE
     C                     MOVELB5KMEI    S1KMEI
     C                     LEAVE
     C                     ENDDO
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     MOVELF3SHP1    SVSHP1
      *
     C                     ENDDO
      *-----------------------------------
     C                     Z-ADDRRN1      ENDRRN
     C                     Z-ADD1         RRN1             エラー
      *
     C                     ENDSR
