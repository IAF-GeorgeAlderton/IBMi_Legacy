     C                     Z-ADD20020319  K@YMD   80
     C           K@YMD     SETLLABBPL71
     C           *IN80     DOUEQ*ON
     C           K@YMD     READEABBPL71                  80
     C           *IN80     IFEQ *OFF
     C           A7KNID    ANDEQ'A'
      *
     C           K#KEY     CHAINAGAPL31              90
     C           K#KEY     CHAINAAMPL11              90
     C                     Z-ADD1         X       20
     C           CBKDAI    LOKUPKK,X                     10
     C                     DO   *HIVAL
     C                     SUB  1         X
     C           X         IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
      *
     C           LOC,X     IFEQ '------'
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #CMT
      *
     C                     LEAVE
     C                     ENDDO
      *
     C                     MOVELW@LOCT    A7LOCT
     C                     MOVELW@CMNT    A7CMNT
     C                     MOVELW@MCHN    A7MCHN
     C                     UPDATABBPP701
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C*
     C**************************************************************************
     C*         INITIALIZE
     C**************************************************************************
     C           *INZSR    BEGSR
      *
     C           K#AP11    KLIST
     C                     KFLD           WWZETI
     C                     KFLD           WWORDR
      *
     C           K#ABB     KLIST
     C                     KFLD           K@DATE  80
     C                     KFLD           WBAR
     C           K#AGD     KLIST
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C                     KFLD           K@DD    20
     C           K#KEY     KLIST
     C                     KFLD           A7PRT1
     C                     KFLD           A7PRT2
     C                     KFLD           A7PRT3
      *
     C                     Z-ADD*DATE     K@DATE
      *
     C                     ENDSR
      *----------------------------------------------
     C           #CMT      BEGSR
      *----------------------------------------------
     C                     MOVEL*BLANK    W@MCHN  3
     C                     MOVELLOC,X     W@LOCT
     C           W@LL      IFEQ 'H'
     C                     MOVELMCN,1     W@MCHN  3
     C                     MOVE *BLANK    W@CMNT 20
     C                     ELSE
     C                     EXSR #MCN
      *
     C                     MOVEA@LC       W@CMNT
     C                     Z-ADD1         W       20
     C           'RL '     LOKUPPRC,W                    10
     C   10                MOVE MCN,W     W@MCHN
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*       LOCATION, MACHINE
     C**************************************************************************
     C           #MCN      BEGSR
     C*
     C                     MOVE *BLANK    @LC
     C                     Z-ADD*ZERO     Y       20
     C           1         DO   15        X
     C           1         SUBSTLOC,X:2   @@LL    1
     C           LOC,X     IFNE *BLANK
     C           LOC,X     ANDNEW@LOCT
     C           @@LL      ANDGE'A'
     C           @@LL      ANDLE'Z'
     C           @@LL      ANDNE'P'
     C                     ADD  1         Y
     C           4         SUBSTLOC,X:2   @LC,Y
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
