      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C           W@ID      CASEQ'03'      #SCRN3
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#KEY     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C           K#AP      KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     RRN2    40
     C                     Z-ADD*ZERO     @@RRN   40
     C                     MOVEL'01'      W@ID    2
     C           *HIVAL    SETGTFCEPL04
     C                     READPFCEPL04                  90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDA2TAYY    E@YY
     C                     Z-ADDA2TAMM    E@MM
     C                     ELSE
     C                     Z-ADD*YEAR     E@YY
     C                     Z-ADD*MONTH    E@MM
     C                     ENDIF
     C                     Z-ADD200001    D@YYMM
      *
     C                     ENDSR
      *------------------------------------------------------
      *  1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C           RRN1      IFNE *ZERO
     C                     MOVE '02'      W@ID
     C                     ELSE
     C                     MOVE MSG,1     D@MSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
      *
     C           D@YYMM    IFEQ *ZERO
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
      *
     C                     ENDSR
      *
      *------------------------------------------------------
      *  SET DATA FOR SUBFILE
      *------------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1
      *
     C                     Z-ADDD@YYMM    K@YYMM
     C                     DO   *HIVAL
      * START
     C                     CLEARSFL01
     C                     Z-ADDK@YYMM    S@YYMM
     C                     MOVE 'IAF'     S@IAF
     C                     MOVE 'PT '     S@ASJ
      *
     C           K#KEY     SETLLFCEPL04
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEFCEPL04                  90
     C           *IN90     IFEQ *OFF
     C           WEND      IFNE *ZERO
     C           WSTART    ANDGEWEND
     C                     ITER
     C                     ENDIF
      *
      * PASS THROUGH
     C           K#AP      SETLLAAPTL01
     C           *IN95     DOUEQ*ON
     C           K#AP      READEAAPTL01                  95
     C           *IN95     IFEQ *OFF
     C           L5STYY    ANDEQ9999
     C           L5SKJY    ANDEQ*BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN95     IFEQ *ON
     C           K#AP      SETLLFCEPL40
     C           *IN95     DOUEQ*ON
     C           K#AP      READEFCEPL40                  95
     C           *IN95     IFEQ *OFF
     C           F4GSKD    ANDEQ*BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C           A2GEKN    DIV  20        @@QTY  101H
     C           @@QTY     DIV  A2SSYS    @@BOX   91H
     C           *IN95     IFEQ *ON
     C                     ADD  1         S@PRI1
     C                     ADD  @@BOX     S@BXI1
     C                     ELSE
     C                     ADD  1         S@PRA1
     C                     ADD  @@BOX     S@BXA1
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      * END
     C           K#KEY     SETLLFCEPL05
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEFCEPL05                  90
     C           *IN90     IFEQ *OFF
     C           WEND      IFNE *ZERO
     C           WSTART    ANDGEWEND
     C                     ITER
     C                     ENDIF
      * PASS THROUGH
     C           K#AP      SETLLAAPTL01
     C           *IN95     DOUEQ*ON
     C           K#AP      READEAAPTL01                  95
     C           *IN95     IFEQ *OFF
     C           L5STYY    ANDEQ9999
     C           L5SKJY    ANDEQ*BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN95     IFEQ *ON
     C           K#AP      SETLLFCEPL40
     C           *IN95     DOUEQ*ON
     C           K#AP      READEFCEPL40                  95
     C           *IN95     IFEQ *OFF
     C           F4GSKD    ANDEQ*BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C           A2GEKN    DIV  20        @@QTY  101H
     C           @@QTY     DIV  A2SSYS    @@BOX   91H
     C           *IN95     IFEQ *ON
     C                     ADD  1         S@PRI2
     C                     ADD  @@BOX     S@BXI2
     C                     ELSE
     C                     ADD  1         S@PRA2
     C                     ADD  @@BOX     S@BXA2
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           S@PRI1    IFNE *ZERO
     C           S@PRA1    ORNE *ZERO
     C           S@PRI2    ORNE *ZERO
     C           S@PRA2    ORNE *ZERO
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     ADD  1         K@MM
     C           K@MM      IFGT 12
     C                     SUB  12        K@MM
     C                     ADD  1         K@YY
     C                     ENDIF
     C           K@YYMM    IFGT E@YYMM
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     Z-ADD1         #RCNO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCNO
      *
     C                     SELEC
      *
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
     C                     OTHER
     C                     EXSR #CHK2
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     Z-ADD*ZERO     @@RRN
     C           *IN90     DOUEQ*ON
     C                     ADD  1         @@RRN
     C           @@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           S@SLCT    ANDNE*BLANK
      *
     C                     Z-ADDS@YYMM    D@DATE
     C                     MOVE *BLANK    S@SLCT
     C                     UPDATSFL01
     C                     EXSR #SET2
     C                     MOVE '03'      W@ID
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SET DATA FOR SUBFILE
      *------------------------------------------------------
     C           #SET2     BEGSR
      *
     C                     MOVE *ON       *IN54
     C                     WRITECTL02
     C                     MOVE *OFF      *IN54
     C                     Z-ADD*ZERO     RRN2
      *
     C                     Z-ADDD@DATE    K@YYMM
     C                     MOVE *BLANK    PRT
     C                     Z-ADD*ZERO     X       50
     C           K#KEY     SETLLFCEPL04
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEFCEPL04                  90
     C           *IN90     IFEQ *OFF
     C           WEND      IFNE *ZERO
     C           WSTART    ANDGEWEND
     C                     ITER
     C                     ENDIF
     C                     MOVE A2BHB1    S@PRT1
     C                     MOVE A2BHB2    S@PRT2
     C                     MOVE A2BHB3    S@PRT3
     C                     Z-ADDWSTART    S@YMD1
     C                     Z-ADDWEND      S@YMD2
     C                     MOVE W@LOC     S@LOC
     C           A2GEKN    DIV  20        S@QTY     H
     C           S@QTY     DIV  A2SSYS    S@BOX     H
     C                     ADD  1         X
     C                     MOVE A2PART    PRT,X
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C                     ENDIF
     C                     ENDDO
      * END
     C           K#KEY     SETLLFCEPL05
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEFCEPL05                  90
     C           *IN90     IFEQ *OFF
     C           A2PART    LOKUPPRT                      10
     C           *IN10     IFEQ *ON
     C                     ITER
     C                     ENDIF
     C           WEND      IFNE *ZERO
     C           WSTART    ANDGEWEND
     C                     ITER
     C                     ENDIF
     C                     MOVE A2BHB1    S@PRT1
     C                     MOVE A2BHB2    S@PRT2
     C                     MOVE A2BHB3    S@PRT3
     C                     Z-ADDWSTART    S@YMD1
     C                     Z-ADDWEND      S@YMD2
     C                     MOVE W@LOC     S@LOC
     C           A2GEKN    DIV  20        S@QTY     H
     C           S@QTY     DIV  A2SSYS    S@BOX     H
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   3RD SCREEN
      *------------------------------------------------------
     C           #SCRN3    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
