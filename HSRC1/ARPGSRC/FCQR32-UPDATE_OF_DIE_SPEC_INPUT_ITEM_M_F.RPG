     FFCQPW32 CF  E                    WORKSTN
     FFCQPL11 IF  E           K        DISK
     FFCQPL21 UF  E           K        DISK                      A
     FRGAPL11 IF  E           K        DISK
     E                    ER      1  11 60
     E                    SU     10  10  1
     E                    CD         12  2
     E                    NM         12 20
     I            DS
     I                                        1  24 CD
     I                                        1   2 O9CO01
     I                                        3   4 O9CO02
     I                                        5   6 O9CO03
     I                                        7   8 O9CO04
     I                                        9  10 O9CO05
     I                                       11  12 O9CO06
     I                                       13  14 O9CO07
     I                                       15  16 O9CO08
     I                                       17  18 O9CO09
     I                                       19  20 O9CO10
     I                                       21  22 O9CO11
     I                                       23  24 O9CO12
     I            DS
     I                                        1 240 NM
     I                                        1  20 NAME01
     I                                       21  40 NAME02
     I                                       41  60 NAME03
     I                                       61  80 NAME04
     I                                       81 100 NAME05
     I                                      101 120 NAME06
     I                                      121 140 NAME07
     I                                      141 160 NAME08
     I                                      161 180 NAME09
     I                                      181 200 NAME10
     I                                      201 220 NAME11
     I                                      221 240 NAME12
     I            DS
     I                                        1   6 KSN
     I                                        1   1 KBN
     I                                        2   2 KSN02
     I                                        3   6 KSN03
     I            DS
     I                                        1   60TIME
     I                                        1   20TIMEA
     I                                        3   40TIMEB
     I            DS
     I                                        1   80TODAY
     I                                        1   40TOYY
