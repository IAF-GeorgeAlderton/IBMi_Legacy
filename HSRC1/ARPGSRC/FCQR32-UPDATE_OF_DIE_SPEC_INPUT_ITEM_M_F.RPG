     I                                        2   2 CODEB
     C*****************************************************************
     C*  DECLARE PARM                                                 *
     C*****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           US     10
     C                     Z-ADD*YEAR     TOYY
     C                     Z-ADDUMONTH    TOMM
     C                     Z-ADDUDAY      TODD
     C*****************************************************************
     C*  START  PGM(FCQR31)                                           *
     C*****************************************************************
     C           @SCR0     TAG
     C                     MOVE *BLANK    KBN
     C                     MOVE *BLANK    O9KACD
     C                     Z-ADD*ZERO     TIME
     C                     SETOF                     010203
     C                     SETOF                     049099
     C*****************************************************************
     C*  SCREEN-1 DISPLAY                                             *
     C*****************************************************************
     C           @SCR1     TAG
     C                     EXFMTFCQPW321
     C                     MOVE *BLANK    MSG    60
     C   KA                SETON                     LR
     C   KA                RETRN
     C*
     C                     SETOF                     010290
     C                     SETOF                     0304
     C                     SETOF                     99
     C                     MOVE *BLANK    ERSW    1
     C                     EXSR #CHK1
     C           ERSW      COMP *BLANK               2020
     C   20                GOTO @SCR1
     C*
     C                     EXSR #SET
     C*****************************************************************
     C*  SCREEN-2 DIAPLAY                                             *
     C*****************************************************************
     C           @SCR2     TAG
     C                     EXFMTFCQPW322
     C                     MOVE *BLANK    MSG
     C   KC                GOTO @SCR0
     C*
     C                     SETOF                     010299
     C                     MOVE *BLANK    ERSW
     C                     EXSR #CHK2
     C           ERSW      COMP *BLANK               2020
     C   20                GOTO @SCR2
     C  NKE                GOTO @SCR2
     C*
     C                     EXSR #UPD
     C                     GOTO @SCR0
     C*
     C           @END      TAG
     C*****************************************************************
     C*  SCREEN-1 CHECK                                               *
     C*****************************************************************
     C           #CHK1     BEGSR
     C           KBN       COMP '0'                  0101
     C   01      KBN       COMP '1'                  0101
     C   01      KBN       COMP '2'                  0101
     C           *IN,1     IFEQ '1'
     C                     SETON                     99
     C                     MOVELER,1      MSG
     C                     MOVEL'*'       ERSW
     C                     GOTO @CHK1E
     C                     END
     C*
     C           O9KACD    IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVELER,2      MSG
     C                     MOVEL'*'       ERSW
     C                     GOTO @CHK1E
     C                     END
     C*
     C                     MOVE *BLANK    CHNSW   1
     C           O9KACD    CHAINFCQPL211             03
     C           *IN,3     IFEQ '1'
     C                     MOVE '*'       CHNSW
     C                     MOVE *BLANK    J8NAME
     C                     Z-ADD*ZERO     O9KOHZ
     C                     Z-ADD*ZERO     TIME
     C                     ELSE
     C                     MOVELO9TIME    TIME
     C           O9KSNM    CHAINRGAPL111             04
     C           *IN04     IFEQ '1'
     C                     MOVE *BLANK    J8NAME
     C                     END
     C                     END
     C*-- CANCELLATION --*
     C*-- CANCELLATION --*
     C           KBN       IFEQ '0'
     C           *IN,3     IFEQ '1'
     C                     SETON                     010299
     C                     MOVELER,3      MSG
     C                     MOVEL'*'       ERSW
     C                     GOTO @CHK1E
     C                     ELSE
     C           O9SKJY    IFEQ 'D'
     C           O9SKHZ    IFLE TODAY
     C                     SETON                     010290
     C                     SETON                     99
     C                     MOVELER,5      MSG
     C                     MOVEL'*'       ERSW
     C                     GOTO @CHK1E
     C                     END
     C                     END
     C                     END
     C                     END
     C*-- CHANGE --*
     C*-- CHANGE --*
     C           KBN       IFEQ '1'
     C           *IN,3     IFEQ '1'
     C                     SETON                     010299
     C                     MOVELER,4      MSG
     C                     MOVEL'*'       ERSW
     C                     GOTO @CHK1E
     C                     ELSE
     C           O9SKJY    IFEQ 'D'
     C           O9SKHZ    IFLE TODAY
     C                     SETON                     010290
     C                     SETON                     99
     C                     MOVELER,6      MSG
     C                     MOVEL'*'       ERSW
     C                     GOTO @CHK1E
     C                     END
     C                     END
     C                     END
     C                     END
     C*-- ADD  --*
     C*-- ADD  --*
     C           KBN       IFEQ '2'
     C           O9SKJY    IFEQ 'D'
     C           O9SKHZ    IFLE TODAY
     C                     SETON                     03
     C                     END
     C                     END
     C           *IN,3     IFEQ '0'
     C                     SETON                     010299
     C                     MOVELER,7      MSG
     C                     MOVEL'*'       ERSW
     C                     GOTO @CHK1E
     C                     END
     C                     END
     C*
     C           @CHK1E    TAG
     C                     ENDSR
     C*****************************************************************
     C*  SCREEN-2 CHECK                                               *
     C*****************************************************************
     C           #CHK2     BEGSR
     C                     SETOF                     99
     C                     MOVEA'00000000'*IN,01
     C                     MOVEA'00000'   *IN,09
     C                     MOVE *BLANK    ERSW
     C                     MOVE *BLANK    NM
     C*
     C           O9KANM    IFEQ *BLANK
     C                     SETON                     1399
     C                     MOVELER,8      MSG
     C                     MOVEL'*'       ERSW
     C                     GOTO @CHK2E
     C                     END
     C*
     C                     Z-ADD1         I       20
     C           1         DO   12        I
     C                     MOVE *BLANK    NM,I
     C                     MOVEA'0'       *IN,I
     C           CD,I      IFNE *BLANK
     C*
     C           CD,I      CHAINFCQPL111             20
     C  N20      O8SKJY    IFEQ 'D'
     C           O8SKHZ    IFLE TODAY
     C                     SETON                     20
     C                     END
     C                     END
     C   20                MOVEA'1'       *IN,I
     C   20                SETON                     99
     C   20                MOVELER,9      MSG
     C  N20                MOVELO8CONM    NM,I
     C*
     C                     MOVE CD,I      CODE
     C                     Z-ADD1         G       20
     C           CODEA     LOKUPSU,G                     50
     C  N50                MOVE ER,11     MSG
     C  N50                MOVEA'1'       *IN,I
     C  N50                SETON                     99
     C*
     C                     Z-ADD1         G       20
     C           CODEB     LOKUPSU,G                     50
     C  N50                MOVE ER,11     MSG
     C  N50                MOVEA'1'       *IN,I
     C  N50                SETON                     99
     C*
     C                     END
     C                     END
     C*
     C                     Z-ADD1         I
     C           1         DO   12        I
     C           CD,I      IFNE *BLANK
     C                     MOVE CD,I      CODE
     C                     Z-ADD1         X       20
     C           CH1       TAG
     C           CODE      LOKUPCD,X                     20
     C   20      I         IFNE X
     C                     SETON                     99
     C                     MOVELER,10     MSG
     C                     MOVEA'1'       *IN,I
     C                     ELSE
     C                     ADD  1         X
     C                     GOTO CH1
     C                     END
     C                     END
     C                     END
     C   99                MOVEL'*'       ERSW
     C           @CHK2E    TAG
     C                     ENDSR
     C*****************************************************************
     C*  FIELD  SET                                            *
     C*****************************************************************
     C           #SET      BEGSR
     C                     SETOF                     9098
     C                     MOVEL'-'       KSN02
     C*-- CANCELLATION --*
     C           KBN       IFEQ '0'
     C                     MOVEL'CAN '    KSN03
     C                     SETON                     9098
     C                     EXSR #NMST
     C                     END
     C*-- CHANGE --*
     C           KBN       IFEQ '1'
     C                     MOVEL'CHG '    KSN03
     C                     SETON                     90
     C                     EXSR #NMST
     C                     END
     C*-- ADD  --*
     C           KBN       IFEQ '2'
     C                     MOVE *BLANK    O9KANM
     C                     MOVE *BLANK    CD
     C                     MOVE *BLANK    NM
     C                     MOVEA'00000000'*IN,01
     C                     MOVEA'0000'    *IN,09
     C                     MOVEL'ADD '    KSN03
     C                     END
     C*
     C                     ENDSR
     C*****************************************************************
     C*  NAME  SET                                                    *
     C*****************************************************************
     C           #NMST     BEGSR
     C                     MOVE *BLANK    NM
     C                     MOVEA'00000000'*IN,01
     C                     MOVEA'00000'   *IN,09
     C                     Z-ADD1         I
     C           1         DO   12        I
     C           CD,I      IFNE *BLANK
     C           CD,I      CHAINFCQPL111             20
     C           *IN,20    IFEQ '0'
     C           O8SKJY    COMP *BLANK               2020
     C   20      O8SKHZ    COMP TODAY                  2020
     C                     END
     C  N20                MOVELO8CONM    NM,I
     C                     END
     C                     END
     C                     ENDSR
     C*****************************************************************
     C*  UPDATE OF FILE                                               *
     C*****************************************************************
     C           #UPD      BEGSR
     C                     TIME           TIME1   60
     C                     Z-ADDTIME1     TIME
     C                     Z-ADDTIMEA     O9KOJI
     C                     Z-ADDTIMEB     O9KOPN
     C                     Z-ADD*YEAR     O9KOYY
     C                     Z-ADDUMONTH    O9KOMM
     C                     Z-ADDUDAY      O9KODD
     C                     MOVELUS        O9KSNM
     C*
     C*-- CANCELLATION --*
     C           KBN       IFEQ '0'
     C                     MOVEL'D'       O9SKJY
     C                     Z-ADD*YEAR     O9SKYY
     C                     Z-ADDUMONTH    O9SKMM
     C                     Z-ADDUDAY      O9SKDD
     C                     END
     C*-- CHANGE --*
     C           KBN       IFEQ '1'
     C                     MOVE *BLANK    O9SKJY
     C                     Z-ADD*ZERO     O9SKYY
     C                     Z-ADD*ZERO     O9SKMM
     C                     Z-ADD*ZERO     O9SKDD
     C                     END
     C*-- ADD  --*
     C           KBN       IFEQ '2'
     C                     MOVE *BLANK    O9SKJY
     C                     Z-ADD*ZERO     O9SKYY
     C                     Z-ADD*ZERO     O9SKMM
     C                     Z-ADD*ZERO     O9SKDD
     C                     END
     C*****************************************************************
     C*  FCQPL21 (UPDATE & WROTE)                                     *
     C*****************************************************************
     C           CHNSW     COMP '*'                      20
     C   20                WRITEFCQPL211
     C  N20                UPDATFCQPL211
     C                     ENDSR
