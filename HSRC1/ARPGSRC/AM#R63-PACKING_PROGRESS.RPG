     H            Y.
     F** AM#R63  *******************************************
     F* PACKING PROGRESS                                   *
     F*      ITS.        2015.06.23                        *
     F******************************************************
     FAL#PL01 IF  E           K        DISK
     FAM#WP63 UF  E           K        DISK                      A
     FAL#PP31 IF  E           K        DISK
     FAB#PP65 IF  E           K        DISK
     FAB#PL15 IF  E           K        DISK
     FAB#PL13 IF  E           K        DISK
     FAL#PPB1 IF  E           K        DISK
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I            DS
     I                                        1  12 CAMHN
     I                                        1   5 CAMHN1
     I                                        6  10 CAMHN2
     I                                       11  12 CAMHN3
      *
     I            DS
     I                                        1  140CAPL
     I                                        1   80CAPLDT
     I                                        9  140CAPLTI
      *
     I            DS
     I                                        1  140W3AST
     I                                        1   80W3ASTD
     I                                        9  140W3ASTT
      *
     I            DS
     I                                        1  140W3AED
     I                                        1   80W3AEDD
     I                                        9  140W3AEDT
      *
     I            DS
     I                                        1   80K@NYMD
     I                                        1   40K@NOYY
     I                                        5   60K@NOMM
     I                                        7   80K@NODD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1DATE  8
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      *
     C                     EXSR #SB390
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AL#PP01
      *-----------------------------------------------------
     CSR         #SB390    BEGSR
      *
     C           KEYC1     KLIST
     C                     KFLD           KKKADT  8
      *
     C                     MOVE P1DATE    KKKADT
     C           KEYC1     SETLLAL#PL011
     C                     READ AL#PL011                 81
     C           *IN81     DOWEQ'0'
     C           CASKJY    IFEQ 'D'
     C           CASKHZ    ANDLESDATE
     C                     ELSE
     C           CAFIXD    IFNE 0
     C                     EXSR #SB710
     C           GETAB#    IFEQ '1'
     C                     EXSR #SB720
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     READ AL#PL011                 81
     C                     ENDDO
      *
     CSR         ESB390    ENDSR
      *-----------------------------------------------------
      *  AM#WP63
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C           KEY330    KLIST
     C                     KFLD           KKFIXD  80
     C                     KFLD           KKFIXT  60
     C                     KFLD           CATRKB
     C                     KFLD           KKIAFB  3
     C                     KFLD           KKEXTR  30
     C                     KFLD           KKIAFP  3
      *
     C           KEY33     KLIST
     C                     KFLD           KKFIXD  80
     C                     KFLD           KKFIXT  60
     C                     KFLD           CATRKB
     C                     KFLD           CAIAFB
     C                     KFLD           CAEXTR
     C                     KFLD           CAIAFP
      *シップデートの初回確定日
     C           CASHID    SETLLAL#PP311
     C           CASHID    READEAL#PP311                 81
     C           *IN81     DOWEQ'0'
     C           C3SKJY    IFEQ 'D'
     C           C3SKHZ    ANDLESDATE
     C                     ELSE
     C           C3EXTR    IFEQ 0
     C                     Z-ADDC3FIXD    KKFIXD
     C                     Z-ADDC3FIXT    KKFIXT
     C                     ENDIF
     C                     ENDIF
     C           CASHID    READEAL#PP311                 81
     C                     ENDDO
      *
     C                     MOVEL*BLANK    KKIAFB
     C                     Z-ADD0         KKEXTR
     C                     MOVEL*BLANK    KKIAFP
     C           KEY330    CHAINAM#WP631             24
     C           *IN24     IFEQ '1'
     C                     CLEARAM#WP631
     C                     Z-ADDKKFIXD    W3FIXD
     C                     Z-ADDKKFIXT    W3FIXT
     C                     MOVELCASHID    W3SHD1
     C                     MOVELCASHIT    W3SHT1
     C                     MOVELCATRKB    W3TRKB
     C                     WRITEAM#WP631
     C                     ENDIF
      *
     C           KEY33     CHAINAM#WP631             24
     C           *IN24     IFEQ '0'
     C                     ADD  1         W3BOX
     C           CAPLDT    IFEQ 0
     C           GET65     IFEQ '0'
     C                     ADD  1         W3NOPC
     C                     ENDIF
     C                     ELSE
     C                     ADD  1         W3SUMI
     C                     ENDIF
     C           W3AST     IFEQ 0
     C                     Z-ADDCAPL      W3AST
     C                     ELSE
     C           CAPL      IFNE 0
     C           CAPL      ANDLTW3AST
     C                     Z-ADDCAPL      W3AST
     C                     ENDIF
     C                     ENDIF
     C           CAPL      IFGT W3AED
     C                     Z-ADDCAPL      W3AED
     C                     ENDIF
     C           CASHID    IFEQ W3SHD1
     C           CASHID    OREQ W3SHD2
     C           CASHID    OREQ W3SHD3
     C                     ELSE
     C                     EXSR #SB511
     C                     ENDIF
     C                     UPDATAM#WP631
     C                     ELSE
     C                     CLEARAM#WP631
     C                     Z-ADDKKFIXD    W3FIXD
     C                     Z-ADDKKFIXT    W3FIXT
     C                     MOVELCASHID    W3SHD1
     C                     MOVELCASHIT    W3SHT1
     C                     MOVELCATRKB    W3TRKB
     C                     MOVELCAIAFB    W3IAFB
     C                     Z-ADDCAEXTR    W3EXTR
     C                     MOVELCAIAFP    W3IAFP
     C                     MOVELCASURT    W3SURT
     C                     Z-ADD1         W3BOX
     C           CAPLDT    IFEQ 0
     C                     Z-ADD0         W3SUMI
     C           GET65     IFEQ '0'
     C                     Z-ADD1         W3NOPC
     C                     ENDIF
     C                     ELSE
     C                     Z-ADD1         W3SUMI
     C                     ENDIF
     C                     Z-ADD0         W3PSTD
     C                     Z-ADD0         W3PSTT
     C                     Z-ADD0         W3PEDD
     C                     Z-ADD0         W3PEDT
     C                     Z-ADDCAPL      W3AST
     C                     Z-ADDCAPL      W3AED
     C                     MOVELCASHME    W3SHME
     C                     EXSR #SB501
     C                     WRITEAM#WP631
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
      *-----------------------------------------------------
      *  SHORTAGE LIST
      *-----------------------------------------------------
     CSR         #SB501    BEGSR
      *
     C                     MOVEL'0'       GETBB   1
     C           CASHME    SETLLAL#PPB11
     C           CASHME    READEAL#PPB11                 43
     C           *IN43     DOWEQ'0'
     C           GETBB     ANDEQ'0'
     C           CBSKJY    IFEQ 'D'
     C           CBSKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'1'       GETBB   1
     C                     Z-ADDCBHKHZ    W3HKHZ
     C                     Z-ADDCBHKTI    W3HKTI
     C                     ENDIF
     C           CASHME    READEAL#PPB11                 43
     C                     ENDDO
      *
     CSR         ESB501    ENDSR
      *-----------------------------------------------------
      *
      *-----------------------------------------------------
     CSR         #SB511    BEGSR
      *
     C                     SELEC
     C           W3SHD1    WHEQ *BLANK
     C                     MOVELCASHID    W3SHD1
     C                     MOVELCASHIT    W3SHT1
     C           W3SHD2    WHEQ *BLANK
     C                     MOVELCASHID    W3SHD2
     C                     MOVELCASHIT    W3SHT3
     C           W3SHD3    WHEQ *BLANK
     C                     MOVELCASHID    W3SHD3
     C                     MOVELCASHIT    W3SHT3
     C                     ENDSL
      *
     CSR         ESB511    ENDSR
      *----------------------------------------------------*
      *受注データ                                        *
      *----------------------------------------------------*
     CSR         #SB710    BEGSR
      *
     C                     MOVE CATOKU    KKTOKU  40
     C                     MOVE CANONY    KKNONY  40
     C                     MOVE CANKOJ    KKNKOJ  1
     C                     MOVELCANUKE    KKNUKE  4
     C                     MOVELCAORD#    K@ODRN 10
     C                     MOVELCAORD#    @@INVN 16
     C                     MOVE CASHID    K@NYMD
     C                     MOVELCASHIT    @SHTM   40
     C                     MOVELCAMHN1    KKMHN1
     C                     MOVELCAMHN2    KKMHN2
     C                     MOVELCAMHN3    KKMHN3
     C                     MOVEL*BLANK    KKMHN4
     C           K#15      KLIST
     C                     KFLD           KKTOKU  40
     C                     KFLD           KKNONY  40
     C                     KFLD           KKNKOJ  1
     C                     KFLD           KKNUKE  4
     C                     KFLD           KKMHN1  5
     C                     KFLD           KKMHN2  5
     C                     KFLD           KKMHN3  5
     C                     KFLD           K@MHN4  5
     C                     KFLD           K@ODRN
     C                     KFLD           K@NOYY
     C                     KFLD           K@NOMM
     C                     KFLD           K@NODD
     C           K#13      KLIST
     C                     KFLD           KKNONY  40
     C                     KFLD           K@NOYY
     C                     KFLD           K@NOMM
     C                     KFLD           K@NODD
     C                     KFLD           KKNUKE  4
     C                     KFLD           KKMHN1  5
     C                     KFLD           KKMHN2  5
     C                     KFLD           KKMHN3  5
     C                     KFLD           KKMHN4  5
      *
     C                     MOVEL'0'       GETAB#  1
     C           K#15      SETLLAB#PL15
     C           K#15      READEAB#PL15                  92
     C           *IN92     DOWEQ'0'
     C           GETAB#    ANDEQ'0'
     C           BASKJY    IFEQ 'D'
     C**JW       BASKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'1'       GETAB#  1
     C                     ENDIF
     C           K#15      READEAB#PL15                  92
     C                     ENDDO
      *
     C           GETAB#    IFEQ '0'
     C           K#13      SETLLAB#PL13
     C           K#13      READEAB#PL13                  92
     C           *IN92     DOWEQ'0'
     C           BASKJY    IFEQ 'D'
     C**JW       BASKHZ    ANDLE*DATE
     C                     ELSE
     C           BAINVN    IFEQ @@INVN
     C                     MOVEL'1'       GETAB#  1
     C                     ENDIF
     C                     ENDIF
     C           K#13      READEAB#PL13                  92
     C                     ENDDO
     C                     ENDIF
      *
     CSR         ESB710    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB720    BEGSR
      *
     C                     Z-ADD0         WKSUM3  10
     C           K#65      KLIST
     C                     KFLD           K@DEST  5
     C                     KFLD           K@NUKE  4
     C                     KFLD           K@ORNO 12
     C                     KFLD           K@KANO  4
     C                     KFLD           K@BOXN  4
     C                     MOVELCANAMC    K@DEST  5
     C                     MOVELCADOCK    K@NUKE  4
     C                     MOVELCAORD#    K@ORNO 12
     C                     MOVELCAKNB#    K@KANO  4
     C                     MOVELCABOX#    K@BOXN  4
     C                     MOVEL'0'       GET65   1
     C           K#65      SETLLAB#PP65
     C           K#65      READEAB#PP65             N    90
     C           *IN90     DOWEQ'0'
     C           GET65     ANDEQ'0'
     C           A6SKJY    IFEQ *BLANK
     C                     MOVEL'1'       GET65
     C                     ENDIF
     C           K#65      READEAB#PP65             N    90
     C                     ENDDO
      *
     CSR         ESB720    ENDSR
