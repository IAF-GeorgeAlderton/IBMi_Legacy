     C                     Z-ADD1         A
     C                     Z-ADD4         B
     C                     Z-ADD0         C       20
     C                     Z-ADD0         D       20
     C           1         DO   3         A
     C                     SUB  1         B
     C           HNKA,B    IFNE *BLANK
     C                     ADD  1         C
     C                     MOVE HNKA,B    KNKA,C
     C                     END
     C           HNKB,B    IFNE *BLANK
     C                     ADD  1         D
     C                     MOVE HNKB,B    KNKB,D
     C                     END
     C                     END
