     C*  ..構成品かんばん切替マスター..  *
     C*------------------------------------*
     C                     SETOF                     10
     C                     Z-ADD0         A       20
     C                     Z-ADD1         B       20
     C                     MOVE PRECD     I       20
     C           KEY4      CHAINAKEPL011             10
     C           *IN10     IFEQ '0'
     C           M3SKJY    ANDEQ'D'
     C           M3SKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '0'
     C                     MOVE HKO,I     E2KTEI
     C                     Z-ADDHBM,I     E2BMON
     C                     MOVE HHN,I     E2SHIN
     C                     MOVE HKO,I     HNKB,1
      *
     C                     SETOF                     11
     C                     DO   *HIVAL
     C           I         SUB  1         I
     C           I         IFEQ 0
     C                     SETON                     11
     C                     ELSE
      *
     C           HBN,I     IFNE '------'
     C           HBN,I     ANDNE'++++++'
     C                     MOVE HKO,I     E2MAEK
     C                     Z-ADDHBM,I     E2MAKB
     C                     MOVE HBN,I     E2MTKR
     C                     SETON                     11
     C                     ELSE
      *
     C           E2BMON    IFEQ HBM,I
     C                     ADD  1         B
     C           B         IFLE 3
     C                     MOVE HKO,I     HNKB,B
     C                     END
     C                     ELSE
      *
     C                     ADD  1         A
     C           A         IFLE 3
     C                     Z-ADDHBM,I     E2KOCD
     C                     MOVE HKO,I     HNKA,A
     C                     END
      *
     C                     END
     C                     END
     C                     END
     C  N11                END
     C                     END
