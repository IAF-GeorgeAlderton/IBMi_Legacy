      *
     CL1                   EXSR #AFA
      **************************************************************************
     C           #TANJ     BEGSR
      *
     C                     MOVELJ1HIN1    K@HIN1  5
     C                     MOVELJ1HIN2    K@HIN2  5
     C                     MOVELJ1HIN3    K@HIN3  2
      *
     C           AJZKEY    KLIST
     C                     KFLD           K@HIN1
     C                     KFLD           K@HIN2
     C                     KFLD           K@HIN3
      *
     C                     SETOF                     90
     C           AJZKEY    SETGTAJZPP50
     C                     DO   *HIVAL
     C           AJZKEY    REDPEAJZPP501                 90
     C   90                LEAVE
      *
     C           M@SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
      * SAME WEIGHT DATE & TIME
     C           J1KEHZ    IFEQ M@KEHZ
     C           J1KETM    ANDEQM@KETM
     C                     GOTO ETANJ
     C                     ENDIF
      *
     C                     LEAVE
     C                     ENDDO
      *
     C           *IN90     IFEQ '0'
     C                     EXSR #TANU                      UPDATE
     C                     ELSE
     C                     EXSR #TANW                      WRITE
     C                     ENDIF
      *
     C           ETANJ     ENDSR
      **************************************************************************
     C           #TANU     BEGSR
      *
     C                     Z-ADDW@DYMD    M@KODT
     C                     Z-ADDW@THMS    M@KOTM
     C                     MOVEL#USER     M@KOUS
     C                     MOVEL#PGM      M@KOPG
     C                     Z-ADDJ1KEHZ    M@KEHZ
     C                     Z-ADDJ1KETM    M@KETM
      * DATA RESET
      * COMPLETION WEIGHT  *BLANK
      * WEIGHT DATE 1  OLDER THAN 1 YEAR AGO TODAY
     C           M@TANJ    IFEQ 0
     C           M@KEH1    ANDLTL@DAT
     C                     Z-ADDJ1KEHZ    M@KEH1
     C                     Z-ADDJ1TANJ    M@TAN1
     C                     Z-ADD0         M@KEH2
     C                     Z-ADD0         M@TAN2
     C                     Z-ADD0         M@KEH3
     C                     Z-ADD0         M@TAN3
     C                     Z-ADD0         M@TANJ
     C                     UPDATAJZPP501
     C                     GOTO ETANU
     C                     ENDIF
      *
     C                     SELEC
      *  1 - 0 - 0 : 0
     C           M@TAN1    WHNE 0
     C           M@TAN2    ANDEQ0
     C                     Z-ADDJ1KEHZ    M@KEH2
     C                     Z-ADDJ1TANJ    M@TAN2
      *
      *  1 - 1 - 0 : 0
%001 C           M@TAN1    WHNE 0
   | C           M@TAN2    ANDNE0
   | C           M@TAN3    ANDEQ0
   | C                     Z-ADDJ1KEHZ    M@KEH3
   | C                     Z-ADDJ1TANJ    M@TAN3
   | C                     EXSR #HANT
   | C           @HANT     IFEQ '*'
   | C                     Z-ADDM@TAN3    M@TANJ
   | C                     ELSE
   | C                     Z-ADD0         M@TANJ
   | C                     ENDIF
   |  * 1 - 1 - 1 : 0
   | C           M@TAN1    WHNE 0
   | C           M@TAN2    ANDNE0
   | C           M@TAN3    ANDNE0
   | C           M@TANJ    ANDEQ0
   | C                     Z-ADDM@KEH2    M@KEH1
   | C                     Z-ADDM@TAN2    M@TAN1
   | C                     Z-ADDM@KEH3    M@KEH2
   | C                     Z-ADDM@TAN3    M@TAN2
   | C                     Z-ADDJ1KEHZ    M@KEH3
   | C                     Z-ADDJ1TANJ    M@TAN3
   | C                     EXSR #HANT
   | C           @HANT     IFEQ '*'
   | C                     Z-ADDM@TAN3    M@TANJ
   | C                     ELSE
   | C                     Z-ADD0         M@TANJ
%001 C                     ENDIF
      *
     C                     ENDSL
      *
     C                     UPDATAJZPP501
      *
     C           ETANU     ENDSR
      **************************************************************************
     C           #TANW     BEGSR
      *
     C                     CLEARAJZPP501
      *
     C                     MOVE *BLANK    M@SKJY
     C                     Z-ADD0         M@SKDT
     C                     Z-ADDW@DYMD    M@KODT
     C                     Z-ADDW@THMS    M@KOTM
     C                     MOVEL#USER     M@KOUS
     C                     MOVEL#PGM      M@KOPG
      *
     C                     MOVELJ1HIN1    M@HIN1
     C                     MOVELJ1HIN2    M@HIN2
     C                     MOVELJ1HIN3    M@HIN3
     C                     Z-ADDJ1KEHZ    M@KEHZ
     C                     Z-ADDJ1KETM    M@KETM
     C                     Z-ADDJ1KEHZ    M@KEH1
     C                     Z-ADDJ1TANJ    M@TAN1
      *
     C                     WRITEAJZPP501
      *
     C           ETANW     ENDSR
      **************************************************************************
     C           #HANT     BEGSR
      *
     C                     MOVEL*BLANK    @HANT   1
     C                     Z-ADD0         DIV1    74
     C                     Z-ADD0         PER1    72
     C                     Z-ADD0         DIV2    74
     C                     Z-ADD0         PER2    72
      *  COMPARE  3RD WITH 1ST
     C           M@TAN3    DIV  M@TAN1    DIV1
     C           DIV1      MULT 100       PER1
     C           PER1      IFGT 99
     C           PER1      ANDLT101
     C                     MOVEL'*'       @HANT
     C                     ENDIF
      *  COMPARE  3RD WITH 2ND
     C           @HANT     IFEQ '*'
     C           M@TAN3    DIV  M@TAN2    DIV2
     C           DIV2      MULT 100       PER2
     C           PER2      IFGT 99
     C           PER2      ANDLT101
     C                     ELSE
     C                     MOVEL' '       @HANT
     C                     ENDIF
     C                     ENDIF
      *
     C           EHANT     ENDSR
      **************************************************************************
     C           #DATR     BEGSR
      *
     C                     MOVE W@DYMD    PDATE
     C                     MOVE '-'       PPORM
     C                     MOVE '365'     PDAYS
     C                     MOVEL*BLANK    PRDAT
     C                     MOVEL*BLANK    PRTN
     C                     CALL 'DATR12'
     C                     PARM           PDATE   8
     C                     PARM           PPORM   1        + OR -
     C                     PARM           PDAYS   4
     C                     PARM           PRDAT   8
     C                     PARM           PRTN    1
      *
     C                     Z-ADD0         L@DAT   80
     C                     MOVELPRDAT     L@DAT
      *
     C           EDATR     ENDSR
      *-----------------------------------------------------
     C           #SETAD    BEGSR
     C*
     C                     ADD  1         @X
     C*
     C                     MOVE J1KANK    B@KANK
     C                     MOVE J1ZETI    B@ZETI
     C                     MOVE J1THAI    B@TEHI
     C                     MOVE J1PAG1    B@PAGE
     C                     MOVE J12JKA    B@2JKA
     C                     MOVE J1TASY    B@TASY
     C                     MOVE J1SYKO    B@SYKO
     C                     MOVE J1HKBR    B@HKBR
     C*
     C           @X        IFLE 6
     C                     MOVELB@ALL     AK,@X
     C                     END
     C*
     C           J1ZBR1    IFNE *BLANK
     C                     ADD  1         @Y
     C           @Y        IFLE 6
     C                     MOVELJ1ZBR1    LT,@Y
     C                     END
     C                     END
     C*
     C           J1ZBR2    IFNE *BLANK
     C                     ADD  1         @Y
     C           @Y        IFLE 6
     C                     MOVELJ1ZBR2    LT,@Y
     C                     END
     C                     END
     C*
     C           ESETAD    ENDSR
     C*-----------------------------------------------------
     C           #AFA      BEGSR
      *
     C           B#2       IFNE J1ZETI
     C                     GOTO EAFA
     C                     END
      *
     C           J1KBAR    IFEQ *BLANK
     C                     GOTO EAFA
     C                     END
      *
     C           @X        IFEQ 0
     C                     GOTO EAFA
     C                     END
      *
     C                     MOVE *BLANK    AASKJY
     C                     Z-ADD0         AASKHZ
     C                     Z-ADDW@DYMD    AAKOHZ
     C                     Z-ADDW@TH      AAKOHH
     C                     Z-ADDW@TM      AAKOSS
     C                     MOVELJ1KECD    AAKOME
     C                     Z-ADDW@DYMD    AAYMD
     C                     MOVE *BLANK    AAKCD
     C                     MOVE J1HIN1    AAPRT1
     C                     MOVE J1HIN2    AAPRT2
     C                     MOVE J1HIN3    AAPRT3
     C                     MOVE B#2       AAZETI
     C                     MOVE B#3       AANLOT
     C                     MOVE '1'       AAFLAG
     C                     MOVE *BLANK    AAAPFG
     C           J1APPL    IFEQ 'A'
     C                     MOVE '0'       AAAPFG           APICS
     C                     END
     C           J1APPL    IFEQ 'P'
     C                     MOVE '1'       AAAPFG           PLASTIC
     C                     END
     C                     Z-ADD1         AACOPY
     C                     MOVE *BLANK    AAUPFG
     C                     MOVE *BLANK    AAFILR
      *
      *  CHECK COMBINED PARTIAL CONTAINER
     C                     CALL 'AFAR6S'
     C                     PARM           AAZETI
     C                     PARM           AANLOT
     C                     PARM           P@FLG   1
      *
     C           P@FLG     IFEQ *BLANK
     C                     WRITEAFAPP601
     C                     ELSE
     C                     WRITEAFAPP6S1
     C                     END
      *
     C           EAFA      ENDSR
