     C           *IN10     IFEQ '0'
     C                     SETON                     10
     C                     TIME           WTIME   60
     C                     TIME           W@TIME
     C                     EXSR #DATR
     C                     Z-ADD0         J1SKYY
     C                     Z-ADD0         J1SKMM
     C                     Z-ADD0         J1SKDD
     C                     Z-ADD*YEAR     J1KOYY
     C                     Z-ADDUMONTH    J1KOMM
     C                     Z-ADDUDAY      J1KODD
     C                     Z-ADDWJJ       J1KOHH
     C                     Z-ADDWFF       J1KOSS
     C                     MOVE #USER     J1KOME
     C                     END
     C*
     C           *INL1     IFEQ '1'
     C                     Z-ADD0         @X      20
     C                     Z-ADD0         @Y      20
     C                     MOVE *BLANK    AK
     C                     MOVE *BLANK    LT
     C                     END
     C*-----------------------------------------------------
     C*
     C                     Z-ADDSYUY      J1SYUY
     C                     Z-ADDTANJ      J1TANJ
     C*
