     C                     RETRN
     C                     END
     C*/ SCR.CHK /
     C                     MOVE *BLANK    ERRMSG
     C                     MOVEA'00000'   *IN,01
     C                     MOVEA'0'       *IN,99
     C*
     C                     MOVEA'000'     *IN,11
     C           KTEI      COMP 0                        11
     C           MEKI      COMP 0                        12
     C           NIJI      COMP 0                        13
     C   11 12 13          MOVEA'1'       *IN,99
     C           *IN,99    IFEQ '1'
     C                     MOVEA'111'     *IN,01
     C                     MOVE MSG,1     ERRMSG
     C                     GOTO STP10
     C                     END
     C*
     C   11N12             MOVEA'1'       *IN,99
     C           *IN,99    IFEQ '1'
     C                     MOVEA'1'       *IN,02
     C                     MOVE MSG,2     ERRMSG
     C                     GOTO STP10
     C                     END
     C   11N13             MOVEA'1'       *IN,99
     C           *IN,99    IFEQ '1'
     C                     MOVEA'1'       *IN,03
     C                     MOVE MSG,2     ERRMSG
     C                     GOTO STP10
     C                     END
     C   12N13             MOVEA'1'       *IN,99
     C           *IN,99    IFEQ '1'
     C                     MOVEA'1'       *IN,03
     C   99                MOVE MSG,2     ERRMSG
     C   99                GOTO STP10
     C                     END
     C*
     C           NONUBI    IFEQ 0
     C                     MOVEA'1'       *IN,04
     C                     MOVEA'1'       *IN,99
     C                     MOVE MSG,3     ERRMSG
     C                     GOTO STP10
     C                     ELSE
     C           NOYY      IFLT 86
     C           NOMM      ORLT 01
     C           NOMM      ORGT 12
     C           NODD      ORLT 01
     C           NODD      ORGT 31
     C           NOBB      ORLT 01
     C                     MOVEA'1'       *IN,04
     C                     MOVEA'1'       *IN,99
     C                     MOVE MSG,4     ERRMSG
     C                     GOTO STP10
     C                     END
     C                     END
