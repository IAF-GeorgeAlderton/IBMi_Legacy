     C                     KFLD           F06C
     C                     KFLD           F06D
     C*
     C                     MOVE *BLANK    SW
     C           STP00     TAG
     C                     Z-ADD0         KTEI
     C                     Z-ADD0         MEKI
     C                     Z-ADD0         NIJI
     C                     Z-ADD0         NONUBI
     C                     MOVE *BLANK    ERRMSG
     C                     MOVEA'00000'   *IN,01
     C                     MOVEA'0'       *IN,99
     C*
     C*/ SCR.DSP /
     C*
     C           STP10     TAG
     C                     EXFMTAAFPW211
     C                     MOVE *BLANK    ERRMSG
     C           *INKA     IFEQ '1'
