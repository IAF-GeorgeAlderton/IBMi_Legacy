     H            Y.
     F** MCER59 *******************************************
     F* CHECK OF MCEPP52                                  *
     F*   ITS.                     2014.02.14             *
     F*****************************************************
     FMCETL52 IF  E           K        DISK
      *
     I            DS
     I                                        1   80MXSKHZ
     I                                        1   40MXSKYY
     I                                        5   60MXSKMM
     I                                        7   80MXSKDD
     I            DS
     I                                        1   80MXTRHZ
     I                                        1   40MXTRYY
     I                                        5   60MXTRMM
     I                                        7   80MXTRDD
      *
     C           *ENTRY    PLIST
     C                     PARM           PHIN1   5
     C                     PARM           PHIN2   5
     C                     PARM           PHIN3   2
     C                     PARM           PTOKU   4
     C                     PARM           PKOJO   1
     C                     PARM           PUKER   4
     C                     PARM           PTRHZ   8
     C                     PARM           PGET    1
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
     C           KEYHIN    KLIST
     C                     KFLD           #KHIN1  5
     C                     KFLD           #KHIN2  5
     C                     KFLD           #KHIN3  2
     C                     MOVE PHIN1     #KHIN1
     C                     MOVE PHIN2     #KHIN2
     C                     MOVE PHIN3     #KHIN3
     C                     MOVE PTOKU     ##TOKU  40
     C                     MOVE PKOJO     ##KOJO  1
     C                     MOVE PUKER     ##UKER  4
     C                     MOVE PTRHZ     ##TRHZ  80
     C                     MOVEL'0'       PGET    1
     C           KEYHIN    SETLLMCETL521
     C           KEYHIN    READEMCETL521                 21
     C           *IN21     DOWEQ'0'
     C           PGET      ANDEQ'0'
     C           MXSKJY    IFEQ 'D'
     C           MXSKHZ    ANDLE*DATE
     C                     ELSE
     C           MXTRHZ    IFEQ ##TRHZ
     C           MXTOKU    ANDEQ##TOKU
     C           MXKOJO    ANDEQ##KOJO
     C           MXUKER    ANDEQ##UKER
     C                     MOVEL'1'       PGET
     C                     ENDIF
     C                     ENDIF
     C           KEYHIN    READEMCETL521                 21
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
