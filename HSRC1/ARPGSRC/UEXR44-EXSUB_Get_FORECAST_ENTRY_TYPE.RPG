     H            Y.
      ** UEXR44 ****************************************************
      *  GET FORECAST ENTRY TYPE                                   *
      *  JW     2021.07.22                                         *
      *-------------------------------------------------           *
      *  JW     2024.01.15 ADD S FOR ENTRY TYPE                    *
      **************************************************************
      *  CALLING SEQ.                                              *
     C*                    CALL 'UEXR44 '
     C*                    PARM           $NONY   4
     C*                    PARM           $NKOJ   1
     C*                    PARM           $NUKE   4
     C*                    PARM           $MHIN  20
     C*                    PARM           $OTYP   1
     F*   IN  $NONY   4A  DELIVERY CODE                            *
     F*   "   $NKOJ   1A  FACTORY                                  *
     F*   "   $NUKE   4A  DOCK                                     *
     F*   "   $MHIN  20A  CUSTOMER PART                            *
     F*   OUT $OTYP   1A  ORDER ENTRY TYPE                         *
      **************************************************************
     FABBPL51 IF  E           K        DISK
     FABBPL63 IF  E           K        DISK
     FABFPL1C IF  E           K        DISK
     FEDIPL47 IF  E           K        DISK
      ***********************************************************
     I            DS
     I                                        1  20 K#MHIN
     I                                        1   5 K#MHN1
     I                                        6  10 K#MHN2
     I                                       11  15 K#MHN3
     I                                       16  20 K#MHN4
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        7  120TODAY6
      ****************************************************
      * MAIN ROUTINE
      ****************************************************
     C                     EXSR #INIT
      * CHECK ABBPL51 (PP50) ==============================
     C           K#PL51    SETLLABBPL51
     C                     DO   *HIVAL
     C           K#PL51    READEABBPL51                  98
     C   98                LEAVE
      *
 JW1 C           BBSDAT    IFLT TODAY
  .  C                     ITER
 JW1 C                     ENDIF
      *
 JW1 C                     MOVELBBFLG2    $OTYP
     C                     ENDDO
      *
      * CHECK ABFPL1C (FORD) ==============================
      * GET USER PART
     C                     MOVE *BLANK    XUPART 40
     C           K#PL47    SETLLEDIPL47
     C                     DO   *HIVAL
     C           K#PL47    READEEDIPL47                  97
     C   97                LEAVE
     C                     MOVELE5UPRT    XUPART
     C           E5NONY    IFEQ K#NONY
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           XUPART    IFNE *BLANK
     C           K#PL1C    SETLLABFPL1C
     C                     DO   *HIVAL
     C           K#PL1C    READEABFPL1C                  96
     C   96                LEAVE
     C                     MOVE 'E'       $OTYP
     C                     ENDDO
     C                     ENDIF
      *
      * CHECK ABBPL63 (PP60) ==============================
     C           K#PL51    SETLLABBPL63
     C                     DO   *HIVAL
     C           K#PL51    READEABBPL63                  95
     C   95                LEAVE
      *
JW1  C           ABDATE    IFLT TODAY6
JW1  C           ABSKJY    OREQ 'D'
 .   C                     ITER
JW1  C                     ENDIF
      *
     C                     MOVE 'M'       $OTYP
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ****************************************************
      * INITIALIZE
      ****************************************************
     C           #INIT     BEGSR
     C*
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4        IN
     C                     PARM           $NKOJ   1        IN
     C                     PARM           $NUKE   4        IN
     C                     PARM           $MHIN  20        IN
     C                     PARM           $OTYP   1        OUT
     C*
     C           K#PL51    KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#NKOJ  1
     C                     KFLD           K#NUKE  4
     C                     KFLD           K#MHN1  5
     C                     KFLD           K#MHN2  5
     C                     KFLD           K#MHN3  5
     C                     KFLD           K#MHN4  5
     C*
     C           K#PL1C    KLIST
     C                     KFLD           XUPART
     C                     KFLD           K#NONY
     C*
     C           K#PL47    KLIST
     C                     KFLD           K#MHN1
     C                     KFLD           K#MHN2
     C                     KFLD           K#MHN3
     C                     KFLD           K#MHN4
      *
JW1  C                     TIME           SDATE
     C                     MOVEL$NONY     K#NONY
     C                     MOVEL$NKOJ     K#NKOJ
     C                     MOVEL$NUKE     K#NUKE
     C                     MOVEL$MHIN     K#MHIN
      *
     C                     MOVE *BLANK    $OTYP
      *
     C                     ENDSR
