     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,3     F99ER2
     C                     LEAVE
     C                     END
     C*
     C           WWKANS    IFEQ 'A'
     C           WWKANS    OREQ 'R'
     C                     ELSE
     C                     SETON                     9961
     C                     MOVELERR,1     F3ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,8     F99ER2
     C                     END
     C*
     C           WWZETI    CHAINFCETL11              90
     C           *IN90     IFEQ *ON
     C           A2GSKD    ORNE *BLANK
     C                     SETON                     9961
     C           F3ERR     IFEQ *BLANK
     C                     MOVELERR,1     F3ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,4     F99ER2
     C                     END
     C                     ELSE
     C                     MOVELA2BHB1    W3SHN1
     C                     MOVELA2BHB2    W3SHN2
     C                     MOVELA2BHB3    W3SHN3
     C                     END
     C* CHECK DIGIT
TEST C           #USER     IFEQ 'TEST'
TEST C           #USER     OREQ 'I0777'
TEST C                     ELSE
     C                     MOVELWWKNBN    PMAREA    P
     C                     MOVE '014'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C           F3ERR     IFEQ *BLANK
     C                     MOVELERR,1     F3ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,15    F99ER2
     C                     END
     C                     END
     C           PMCHK     IFNE WWCHK
     C                     SETON                     9961
     C           F3ERR     IFEQ *BLANK
     C                     MOVELERR,1     F3ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,15    F99ER2
     C                     END
     C                     END
TEST C                     END
     C   99                LEAVE
     C*
     C           K#KEY     CHAINAAMPL11              90
     C           *IN90     IFEQ *ON
     C           CKSKJY    ORNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     F3ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,4     F99ER2
     C                     LEAVE
     C                     END
      *
     C           W2LOC#    LOKUPLOC                      10
     C  N10      W2LOC#    LOKUPLOX                      10
     C           *IN10     IFEQ *OFF
     C                     SETON                     9961
     C           F3ERR     IFEQ *BLANK
     C                     MOVELERR,10    F3ERR
     C                     MOVELERR,10    F99ER1
     C                     MOVELERR,02    F99ER2
     C                     END
     C                     END
     C   99                LEAVE
     C*
     C                     ENDDO
     C*
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     END
     C*
     C                     ENDSR
