     C           KEY1      KLIST
     C                     KFLD           @SHN1
     C                     KFLD           @SHN2
     C                     KFLD           @SHN3
      *
     C           *ENTRY    PLIST
     C                     PARM           PUSR   10
     C                     PARM           PKBN    1
     C                     PARM           PSHN   12
     C                     MOVE PSHN      @SHN
      *
     C                     SETOF                     01
     C           KEY1      CHAINAKFPL011             01
      *
     C                     SETOF                     10
     C           KEY1      CHAINAKCPL011             10
      *
     C*------------------*
     C*  ..追加処理..  *
     C*------------------*
     C           PKBN      IFEQ '2'
     C                     MOVE *BLANK    M4SKJY
     C                     Z-ADD0         M4SKHZ
     C                     Z-ADD*DATE     M4KOHZ
     C                     TIME           M4TIME
     C                     MOVELPUSR      M4KOME
     C                     MOVE @SHN1     M4KHN1
     C                     MOVE @SHN2     M4KHN2
     C                     MOVE @SHN3     M4KHN3
     C                     Z-ADD0         M4TAOH
     C                     Z-ADDM1TAHZ    M4TAHZ
     C                     MOVE *BLANK    M4TAHH
     C                     Z-ADD0         M4KATB
     C                     Z-ADDM1KASI    M4KATA
     C                     MOVE *BLANK    M4KATH
     C                     Z-ADD0         M4OSYS
     C                     MOVE *BLANK    M4OSYT
     C                     Z-ADDM1SSYS    M4NSYS
     C                     MOVE M1SSYT    M4NSYT
     C                     MOVE *BLANK    M4SYSH
     C                     Z-ADD0         M4SYOH
     C                     Z-ADDM1SYHZ    M4SYHZ
     C                     MOVE *BLANK    M4SYHH
     C                     Z-ADD0         M4OGEK
     C                     Z-ADDM1GEKN    M4NGEK
     C                     MOVE *BLANK    M4GEKH
     C                     MOVE *BLANK    M4KOTH
     C                     Z-ADD0         M4SAHZ
     C                     MOVE *BLANK    M4LIST
     C                     MOVE *BLANK    M4IKOU
     C                     Z-ADD2         M4KOSN
     C                     MOVE M1ZENO    M4ZETI
     C                     END
      *
     C*------------------*
     C*  ..変更処理..  *
     C*------------------*
     C           PKBN      IFEQ '1'
     C                     MOVE *BLANK    M4SKJY
     C                     Z-ADD0         M4SKHZ
     C                     Z-ADD*DATE     M4KOHZ
     C                     TIME           M4TIME
     C                     MOVELPUSR      M4KOME
      *
     C                     SETOF                     20
     C           M4IKOU    IFEQ '#'
     C                     SETON                     20
     C                     MOVE *BLANK    M4TAHH
     C                     MOVE *BLANK    M4KATH
     C                     MOVE *BLANK    M4SYSH
     C                     MOVE *BLANK    M4SYHH
     C                     MOVE *BLANK    M4GEKH
     C                     MOVE *BLANK    M4KOTH
     C                     MOVE *BLANK    M4IKOU
     C                     Z-ADD1         M4KOSN
     C                     END
      *
     C           M4KOSN    IFNE 2
      *
     C           M1TAHZ    IFNE M4TAHZ
     C                     MOVE '*'       M4TAHH
     C                     Z-ADDM4TAHZ    M4TAOH
     C                     END
      *
     C           M1KASI    IFNE M4KATA
     C                     MOVE '*'       M4KATH
     C                     Z-ADDM4KATA    M4KATB
     C                     END
      *
     C           M1SSYS    IFNE M4NSYS
     C                     MOVE '*'       M4SYSH
     C                     Z-ADDM4NSYS    M4OSYS
     C                     MOVE M4NSYT    M4OSYT
     C                     END
      *
     C           M1SYHZ    IFNE M4SYHZ
     C                     MOVE '*'       M4SYHH
     C                     Z-ADDM4SYHZ    M4SYOH
     C                     END
      *
     C           M1GEKN    IFNE M4NGEK
     C                     MOVE '*'       M4GEKH
     C                     Z-ADDM4NGEK    M4OGEK
     C                     END
      *
     C                     MOVE '#'       M4LIST
     C           M4TAHH    IFEQ *BLANK
     C           M4KATH    ANDEQ*BLANK
     C           M4SYSH    ANDEQ*BLANK
     C           M4SYHH    ANDEQ*BLANK
     C           M4GEKH    ANDEQ*BLANK
     C           M4KOTH    ANDEQ*BLANK
     C                     ELSE
     C                     MOVE *BLANK    M4LIST
     C                     END
     C                     END
      *
     C                     Z-ADDM1TAHZ    M4TAHZ
     C                     Z-ADDM1KASI    M4KATA
     C                     Z-ADDM1SSYS    M4NSYS
     C                     MOVE M1SSYT    M4NSYT
     C                     Z-ADDM1SYHZ    M4SYHZ
     C                     Z-ADDM1GEKN    M4NGEK
      *
     C                     MOVE M1ZENO    M4ZETI
      *
     C*------------------------------------------*
     C*  ..構成品工程別　月間必要数ファイル..  *
     C*------------------------------------------*
     C           *IN20     IFEQ '1'
     C           KEY1      SETLLAEBPL111
     C                     DO   *HIVAL
     C                     SETOF                     30
     C           KEY1      READEAEBPL111                 30
     C           *IN30     IFEQ '0'
      *
     C           AGIKOU    IFEQ '#'
     C                     Z-ADDAGNGEK    AGOGEK
     C                     MOVE *BLANK    AGGEKH
     C                     MOVE *BLANK    AGIKOU
     C                     END
      *
     C                     UPDATAEBPL111
      *
     C                     END
     C  N30                END
     C                     END
      *
     C                     END
      *
     C*------------------*
     C*  ..取消処理..  *
     C*------------------*
     C           PKBN      IFEQ '0'
     C                     MOVE 'D'       M4SKJY
     C                     Z-ADD*DATE     M4SKHZ
     C                     Z-ADD*DATE     M4KOHZ
     C                     TIME           M4TIME
     C                     MOVELPUSR      M4KOME
     C                     Z-ADD0         M4KOSN
     C                     MOVE *BLANK    M4LIST
     C                     END
      *
     C           *IN01     IFEQ '1'
     C                     WRITEAKFPL011
     C                     ELSE
     C                     UPDATAKFPL011
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
