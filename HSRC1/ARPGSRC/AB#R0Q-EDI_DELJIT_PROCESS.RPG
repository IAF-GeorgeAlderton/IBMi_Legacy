     H            Y.
     ** AB#R0Q **********************************
     *  ..EDI(862/830)  GENTRAN AS/400          *
     *
     *   TCH    10/28/03
     *   TCHK1  02/15/06 ADD NONY:0520
     *   TCHK2  09/01/06 CHG NEXT-MONDAY
     ********************************** AB#R0Q **
     FAB#EP20 UF  E                    DISK
     FAGDPL12 IF  E           K        DISK
     FAB#PP2H UF  E           K        DISK                      A
      *---------------------------------------------------------
TCHK1E*                   DT         30 28
TCHK1E                    DT         60 32
     E                    QY         30  9 0
     E                    UP         30  1
      *---------------------------------------------------------
     I* CALENDER FILE(FOR AGDPL12)
     I            DS
     I                                        1   80WKKADT
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
TCHK1I*           DS
TCHK1I*                                       1  28 @DTA
TCHK1I*                                       1  20 @MHN
TCHK1I*                                      21  28 @SHDT
TCHK1I            DS
TCHK1I                                        1  32 @DTA
TCHK1I                                        1   4 @NONY
TCHK1I                                        5  24 @MHN
TCHK1I                                       25  32 @SHDT
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *---------------------------------------------------------
     C           K#2H      KLIST
     C                     KFLD           AENONY
     C                     KFLD           K@RENO 15
      *
     C                     MOVE *BLANK    DT
     C                     Z-ADD*ZERO     QY
     C                     MOVE *BLANK    UP
     C                     Z-ADD*ZERO     Y       20
      *
     C           *IN80     DOUEQ*ON
     C                     READ AB#EP20                  80
     C           *IN80     IFEQ *OFF
     C           AEQNTY    ANDGT*ZERO
      *
     C           AESNDR    IFEQ 'QE4'
     C           AESNDR    OREQ 'PAF'
     C                     ITER
     C                     ENDIF
      *
     C           AEREF1    IFNE *BLANK
     C           AEORNO    ANDNE*BLANK
     C                     MOVELAEREF1    K@RENO
     C           K#2H      CHAINAB#PP2H              90
     C                     Z-ADD*DATE     AHKYMD
     C                     TIME           AHKTIM
     C                     MOVEL#PGM      AHKPGM
     C                     MOVELAEORNO    AHORNO
     C                     MOVELAEREF1    AHRENO
     C                     MOVELAENONY    AHNONY
     C  N90                UPDATAB#PP2H1
     C   90                WRITEAB#PP2H1
     C                     ENDIF
      *
     C           AESNDR    IFEQ 'BFT'
     C           AEORID    ANDNE*BLANK
     C                     ITER
     C                     ENDIF
      *
     C           AENUKE    IFEQ *BLANK
     C                     MOVEL'00  '    AENUKE
     C                     ENDIF
      *
     C                     Z-ADDAESHDT    K@YMD
     C           K#AGD     CHAINAGDPL12              95
     C           *IN95     IFEQ *OFF
     C           F8HIRU    IFNE *BLANK
     C           *IN95     DOUEQ*ON
     C                     READPAGDPL12                  95
     C           *IN95     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     Z-ADDWKKADT    AESHDT
     C                     UPDATAB#EP201
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDIF
      *
     C           @DATE     IFEQ *ZERO
     C           AEDATE    ORGT @DATE
     C                     Z-ADDAEDATE    @DATE
     C                     ENDIF
      *
     C                     Z-ADD1         X       20
TCHK1C                     MOVELAENONY    @NONY
     C                     MOVE AESHDT    @SHDT
     C                     MOVELAEMHIN    @MHN
     C           @DTA      LOKUPDT,X                     10
     C           *IN10     IFEQ *ON
     C                     ADD  AEQNTY    QY,X
     C                     ELSE
     C                     ADD  1         Y
     C                     MOVE @DTA      DT,Y
     C                     Z-ADDAEQNTY    QY,Y
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     CLOSEAB#EP20
     C                     OPEN AB#EP20
      *
     C           *IN80     DOUEQ*ON
     C                     READ AB#EP20                  80
     C           *IN80     IFEQ *OFF
     C           AEQNTY    ANDGT*ZERO
      *
     C           AESNDR    IFEQ 'QE4'
     C           AESNDR    OREQ 'PAF'
     C                     ITER
     C                     ENDIF
      *
     C           AEDATE    IFNE @DATE
     C                     DELETAB#EP201
     C                     ITER
     C                     ENDIF
      *
     C           AESHDT    IFGT W@END
     C                     DELETAB#EP201
     C                     ITER
     C                     ENDIF
      *
TCHK1C                     MOVELAENONY    @NONY
     C                     MOVE AESHDT    @SHDT
     C                     MOVELAEMHIN    @MHN
     C                     Z-ADD1         X       20
     C           @DTA      LOKUPDT,X                     10
     C           *IN10     IFEQ *ON
     C           UP,X      IFNE *BLANK
     C                     DELETAB#EP201
     C                     ITER
     C                     ENDIF
     C                     MOVE '1'       UP,X
     C                     Z-ADDQY,X      AEQNTY
     C                     UPDATAB#EP201
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-------------------------------------------------------
     C           *INZSR    BEGSR
      *
      * AGDPL12
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
      *
     C           *ENTRY    PLIST
     C                     PARM           P@DATE  8
      * NEXT MONDAY
     C                     Z-ADD*ZERO     @DATE   80
     C                     Z-ADD*DATE     K@YMD
     C                     MOVE *OFF      *IN88
     C           K#AGD     SETGTAGDPL12
     C           *IN80     DOUEQ*ON
     C                     READ AGDPL12                  80
     C           *IN80     IFEQ *OFF
     C           F8YOBI    IFEQ 1
     C                     MOVE *ON       *IN88
TCHK2C                     ELSE
TCHK2C                     MOVE *OFF      *IN88
     C                     ENDIF
     C           *IN88     IFEQ *ON
     C           F8HIRU    ANDEQ*BLANK
     C                     Z-ADDWKKADT    W@END   80
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
