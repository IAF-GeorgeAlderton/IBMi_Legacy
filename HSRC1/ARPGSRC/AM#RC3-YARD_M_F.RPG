      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     TIME           SDATE
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVEL'01'      DSPSW   2
     C                     EXSR #SB110
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB110    BEGSR
      *
     C                     Z-ADD0         X       30
     C                     CLEARYD
     C           1         SETLLAM#PPC11
     C                     READ AM#PPC11                 80
     C           *IN80     DOWEQ'0'
     C           RCSKJY    IFEQ 'D'
     C           RCSKHZ    ANDLE*DATE
     C                     ELSE
     C                     ADD  1         X
     C                     MOVELRCYARD    YD,X
     C                     ENDIF
     C                     READ AM#PPC11                 80
     C                     ENDDO
      *
     CSR         ESB110    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTAM#PWC31
     C                     MOVEL*BLANK    D1ERR
      *
     C           *IN03     IFEQ '1'
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     Z-ADD0         CNT     30
     C                     Z-ADD1         X       30
     C           X         DOWLE96
     C           YD,X      IFNE *BLANK
     C                     ADD  1         CNT
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
     C           CNT       IFEQ 0
     C                     MOVELER,1      D1ERR
     C                     SETON                     99
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           *IN05     IFEQ '1'
     C                     EXSR #SB500
     C                     MOVEL'99'      DSPSW
     C                     ENDIF
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * UPDATE                                             *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     EXSR #DLT
     C                     EXSR #WRT
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      * DELETE                                             *
      *----------------------------------------------------*
     CSR         #DLT      BEGSR
      *
     C           1         SETLLAM#PPC11
     C                     READ AM#PPC11                 80
     C           *IN80     DOWEQ'0'
     C           RCSKJY    IFEQ 'D'
     C           RCSKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'D'       RCSKJY
     C                     Z-ADD*DATE     RCSKHZ
     C                     UPDATAM#PPC11
     C                     ENDIF
     C                     READ AM#PPC11                 80
     C                     ENDDO
      *
     CSR         EDLT      ENDSR
      *----------------------------------------------------*
      * ADD                                                *
      *----------------------------------------------------*
     CSR         #WRT      BEGSR
      *
     C                     Z-ADD1         X       30
     C           X         DOWLE96
     C           YD,X      IFNE *BLANK
     C                     CLEARAM#PPC11
     C                     Z-ADD*DATE     RCKOHZ
     C                     TIME           RCKOTI
     C                     MOVELW#USER    RCKOME
     C                     MOVELYD,X      RCYARD
     C                     WRITEAM#PPC11
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         EWRT      ENDSR
