     H            Y.
      ** UTLR692 *********************************************
      *  UTILITY- GET PRINTER NAME BY ID                     *
      *  LEC      2020.01.30                                 *
      *---------------------------------
      *  CALLING SEQ.
      *                    CALL 'UTLR692'
      *                    PARM           $DPT    3
      *                    PARM           $PID    3
      *                    PARM           $PNM   10
      *                    PARM           $RTN    1
      *  OUT $PRT  : 10A PRINTER NAME
      *      $RTN  :  1A RETURN CODE (BLANK/*)
      ********************************************************
     FUTLPW692CF  E                    WORKSTN
     F**UTLWP10 IF  E           K        DISK
CHG  FUTLPP10 IF  E           K        DISK
      *
     E                    ERR     1   4 60
      *
      *-----------------------------------------------------------*
      *     M  A  I  N   R O U T I N E                            *
      *-----------------------------------------------------------*
     C                     EXSR #INIT
      *
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      @DSP1
     C                     ENDCS
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *************************************************************
      *  DISPLAY 1
      *************************************************************
     C           @DSP1     BEGSR
      *
     C                     EXFMTDSP01
     C                     MOVEL*BLANKS   XMSG
     C                     MOVE *OFF      *IN85
     C                     MOVE *OFF      *IN41
      * F1: END JOB
     C           *INKA     IFEQ *ON
     C                     MOVEL'99'      W@ID
     C                     MOVE '*'       $RTN
     C                     GOTO @END1
     C                     ENDIF
      *
     C                     EXSR #CHK1
      *
     C           *IN85     IFEQ *OFF
     C                     MOVELUTPRNM    $PNM
     C                     MOVEL'99'      W@ID
     C                     ENDIF
      *
     C           @END1     ENDSR
      *************************************************************
      *  CHECK OPTION
      *************************************************************
     C           #CHK1     BEGSR
      *
     C           XPID      CHAINUTLPP10              50
     C           *IN50     IFEQ *ON
     C                     MOVELERR,1     XMSG
     C                     SETON                     4185
     C                     ENDIF
      *
     C           *IN50     IFEQ *OFF
     C           UTDEPT    ANDNE$DPT
     C                     MOVELERR,2     XMSG
     C                     SETON                     4185
     C                     ENDIF
      *
     C                     ENDSR
      *************************************************************
      * INITIAL SET
      *************************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $DPT    3
     C                     PARM           $PID    3
     C                     PARM           $PNM   10
     C                     PARM           $RTN    1
      *
     C                     MOVE *BLANK    $RTN
     C                     MOVEL'01'      W@ID    2
     C                     MOVE *BLANKS   $PID
      *
     C                     ENDSR
** (ERR) --------------------------------------------------> (60)
PRINTER ID NOT FOUND
WRONG DEPARTMENT


