     H            Y.
     F** AM#RB3  *******************************************
     F* SHIPPING PROGRESS                                  *
     F*      ITS.        2015.06.23                        *
     F******************************************************
     FAL#PL01 IF  E           K        DISK
     FAM#WPB3 UF  E           K        DISK                      A
     FAB#PP65 IF  E           K        DISK
     FAB#PL15 IF  E           K        DISK
     FAB#PL13 IF  E           K        DISK
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I            DS
     I                                        1  12 CAMHN
     I                                        1   5 CAMHN1
     I                                        6  10 CAMHN2
     I                                       11  12 CAMHN3
      *
     I            DS
     I                                        1  140CAPL
     I                                        1   80CAPLDT
     I                                        9  140CAPLTI
      *
     I            DS
     I                                        1  140W3AST
     I                                        1   80W3ASTD
     I                                        9  140W3ASTT
      *
     I            DS
     I                                        1  140W3AED
     I                                        1   80W3AEDD
     I                                        9  140W3AEDT
      *
     I            DS
     I                                        1   80K@NYMD
     I                                        1   40K@NOYY
     I                                        5   60K@NOMM
     I                                        7   80K@NODD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1DATE  8
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      *
     C                     EXSR #SB390
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AL#PP01
      *-----------------------------------------------------
     CSR         #SB390    BEGSR
      *
     C           KEYC1     KLIST
     C                     KFLD           KKKADT  8
      *
     C                     MOVE P1DATE    KKKADT
     C           KEYC1     SETLLAL#PL011
     C                     READ AL#PL011                 81
     C           *IN81     DOWEQ'0'
     C           CASKJY    IFEQ 'D'
     C           CASKHZ    ANDLESDATE
     C                     ELSE
     C           CAFIXD    IFNE 0
     C                     EXSR #SB710
     C           GETAB#    IFEQ '1'
     C                     EXSR #SB720
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     READ AL#PL011                 81
     C                     ENDDO
      *
     CSR         ESB390    ENDSR
      *-----------------------------------------------------
      *  AM#WPB3
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C           KEY33     KLIST
     C                     KFLD           CASHID
     C                     KFLD           CASHIT
     C                     KFLD           CASURT
     C                     KFLD           CATRKB
     C                     KFLD           CAIAFB
     C                     KFLD           CAIAFP
      *
     C           KEY33     CHAINAM#WPB31             24
     C           *IN24     IFEQ '0'
     C                     ADD  1         W3BOX
     C           CAPLDT    IFEQ 0
     C                     ELSE
     C                     ADD  1         W3SUMI
     C                     ENDIF
     C                     UPDATAM#WPB31
     C                     ELSE
     C                     CLEARAM#WPB31
     C                     MOVELCASHID    W3SHID
     C                     MOVELCASHIT    W3SHIT
     C                     MOVELCASURT    W3SURT
     C                     MOVELCATRKB    W3TRKB
     C                     MOVELCAIAFB    W3IAFB
     C                     MOVELCAIAFP    W3IAFP
     C                     Z-ADD1         W3BOX
     C           CAPLDT    IFEQ 0
     C                     Z-ADD0         W3SUMI
     C                     ELSE
     C                     Z-ADD1         W3SUMI
     C                     ENDIF
     C                     WRITEAM#WPB31
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      *受注データ                                        *
      *----------------------------------------------------*
     CSR         #SB710    BEGSR
      *
     C                     MOVE CATOKU    KKTOKU  40
     C                     MOVE CANONY    KKNONY  40
     C                     MOVE CANKOJ    KKNKOJ  1
     C                     MOVELCANUKE    KKNUKE  4
     C                     MOVELCAORD#    K@ODRN 10
     C                     MOVELCAORD#    @@INVN 16
     C                     MOVE CASHID    K@NYMD
     C                     MOVELCASHIT    @SHTM   40
     C                     MOVELCAMHN1    KKMHN1
     C                     MOVELCAMHN2    KKMHN2
     C                     MOVELCAMHN3    KKMHN3
     C                     MOVEL*BLANK    KKMHN4
     C           K#15      KLIST
     C                     KFLD           KKTOKU  40
     C                     KFLD           KKNONY  40
     C                     KFLD           KKNKOJ  1
     C                     KFLD           KKNUKE  4
     C                     KFLD           KKMHN1  5
     C                     KFLD           KKMHN2  5
     C                     KFLD           KKMHN3  5
     C                     KFLD           K@MHN4  5
     C                     KFLD           K@ODRN
     C                     KFLD           K@NOYY
     C                     KFLD           K@NOMM
     C                     KFLD           K@NODD
     C           K#13      KLIST
     C                     KFLD           KKNONY  40
     C                     KFLD           K@NOYY
     C                     KFLD           K@NOMM
     C                     KFLD           K@NODD
     C                     KFLD           KKNUKE  4
     C                     KFLD           KKMHN1  5
     C                     KFLD           KKMHN2  5
     C                     KFLD           KKMHN3  5
     C                     KFLD           KKMHN4  5
      *
     C                     MOVEL'0'       GETAB#  1
     C           K#15      SETLLAB#PL15
     C           K#15      READEAB#PL15                  92
     C           *IN92     DOWEQ'0'
     C           GETAB#    ANDEQ'0'
     C           BASKJY    IFEQ 'D'
     C**JW       BASKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'1'       GETAB#  1
     C                     ENDIF
     C           K#15      READEAB#PL15                  92
     C                     ENDDO
      *
     C           GETAB#    IFEQ '0'
     C           K#13      SETLLAB#PL13
     C           K#13      READEAB#PL13                  92
     C           *IN92     DOWEQ'0'
     C           BASKJY    IFEQ 'D'
     C**JW       BASKHZ    ANDLE*DATE
     C                     ELSE
     C           BAINVN    IFEQ @@INVN
     C                     MOVEL'1'       GETAB#  1
     C                     ENDIF
     C                     ENDIF
     C           K#13      READEAB#PL13                  92
     C                     ENDDO
     C                     ENDIF
      *
     CSR         ESB710    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB720    BEGSR
      *
     C                     Z-ADD0         WKSUM3  10
     C           K#65      KLIST
     C                     KFLD           K@DEST  5
     C                     KFLD           K@NUKE  4
     C                     KFLD           K@ORNO 12
     C                     KFLD           K@KANO  4
     C                     KFLD           K@BOXN  4
     C                     MOVELCANAMC    K@DEST  5
     C                     MOVELCADOCK    K@NUKE  4
     C                     MOVELCAORD#    K@ORNO 12
     C                     MOVELCAKNB#    K@KANO  4
     C                     MOVELCABOX#    K@BOXN  4
     C                     MOVEL'0'       GET65   1
     C           K#65      SETLLAB#PP65
     C           K#65      READEAB#PP65             N    90
     C           *IN90     DOWEQ'0'
     C           GET65     ANDEQ'0'
     C           A6SKJY    IFEQ *BLANK
     C                     MOVEL'1'       GET65
     C                     ENDIF
     C           K#65      READEAB#PP65             N    90
     C                     ENDDO
      *
     CSR         ESB720    ENDSR
