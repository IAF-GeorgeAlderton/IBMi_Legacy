     H            Y.
     F***CHKR39*****************************************************************
     F*  PROGRAM    : CHECK DUPLICATE ORDERS (ABBPP01) FC SEBAN                *
     F*             : READ ABBPL04                                             *
     F*  WRITTEN    : 2019.04.29                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FABBPL04 IF  E           K        DISK
     FCHKWP39 O   E                    DISK
     FQPRINT  O   F     198     OF     PRINTER
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1  23 Q5MHIN
     I                                        1   5 Q5MHN1
     I                                        6   6 HP1
     I                                        7  11 Q5MHN2
     I                                       12  12 HP2
     I                                       13  17 Q5MHN3
     I                                       18  18 HP3
     I                                       19  23 Q5MHN4
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           *IN98     DOWEQ*OFF
     C                     READ ABBPL04                  98
     C           *IN98     IFEQ *OFF
      * ADJ PART
     C                     MOVE *BLANK    HP1
     C                     MOVE *BLANK    HP2
     C                     MOVE *BLANK    HP3
      * CHECK KEY
     C           Q5TOKU    IFEQ SVTOKU
     C           Q5NONY    ANDEQSVNONY
     C           Q5NKOJ    ANDEQSVNKOJ
     C           Q5NUKE    ANDEQSVNUKE
     C           Q5MHIN    ANDEQSVMHIN
      *
     C           Q5SEBN    IFEQ SVSEBN
     C           Q5SEBN    OREQ *BLANK
     C           SVSEBN    OREQ *BLANK
     C                     EXSR #PRINT                     PRINT
     C                     WRITECHKWP391
     C                     ENDIF
      *
     C                     ELSE
     C                     Z-ADDQ5TOKU    SVTOKU
     C                     Z-ADDQ5NONY    SVNONY
     C                     MOVELQ5NKOJ    SVNKOJ
     C                     MOVELQ5NUKE    SVNUKE
     C                     MOVELQ5MHIN    SVMHIN
     C                     MOVELQ5SEBN    SVSEBN
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C                     MOVE *BLANK    $RTN
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     Z-ADD0         SVTOKU  40
     C                     Z-ADD0         SVNONY  40
     C                     MOVE *BLANK    SVNKOJ  1
     C                     MOVE *BLANK    SVNUKE  4
     C                     MOVE *BLANK    SVMHIN 23
     C                     MOVE *BLANK    SVSEBN  4
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** DUPLICATE ORDER R'
     O                                   60 'EPORT (ABBPP01) **  '
     O                                   99 'DATE'
     O                         TODAY     82 '    .  .  '
     O                         NOW       92 '  :  :  '
     O                                   95 'P.'
     O                         PAGE  Z   99
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   10 'CUST'
     O                                   15 'DELV'
     O                                   17 'F'
     O                                   22 'DOCK'
     O                                   32 'USER_PART'
     O                                   51 'SV_SEBAN'
     O                                   61 'NW_SEBAN'
     O        E 1              @DTL
     O                         SEQ#    +001
     O                         SVTOKU  +001
     O                         SVNONY  +001
     O                         SVNKOJ  +001
     O                         SVNUKE  +001
     O                         SVMHIN  +001
     O                         SVSEBN  +001
     O                         Q5SEBN  +006
