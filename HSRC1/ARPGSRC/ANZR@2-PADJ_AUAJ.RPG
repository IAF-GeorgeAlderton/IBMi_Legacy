     F********************************************* ANZR09 **
     FFCEPP9X IP  E                    DISK
     FAAFPL03 UF  E           K        DISK
     FAAHPL03 UF  E           K        DISK
     I           SDS
     I                                        1  10 PGMNM
     I                                       91 170 MSGTXT
     I                                      244 253 WSID
     I                                      254 263 USID
     I                                      264 269 JBNO
     I            DS
     I                                        1   80A3STYD
     I                                        1   40A3STYY
     I                                        5   60A3STMM
     I                                        7   80A3STDD
     I            DS
     I                                        1   80L6STYD
     I                                        1   40L6STYY
     I                                        5   60L6STMM
     I                                        7   80L6STDD
     I            DS
     I                                        1   5 FX0001
     I                                        1   2 FX001X
     I                                        3   3 FX001Y
     I                                        4   5 FX001Z
     C*
     C                     MOVEL'0'       W1BAN1  1
     C                     MOVELFX001X    W1BAN2  2
     C                     MOVELFX001Z    W1BAN3  2
     C                     MOVEL'0'       W1BAN4  1
     C*
     C           KEYF40    KLIST
     C                     KFLD           W1BAN1
     C                     KFLD           W1BAN2
     C                     KFLD           W1BAN3
     C                     KFLD           W1BAN4
      *
     C                     MOVE FX0004    WX0004  50
     C           FX0005    IFEQ 'C    '
      *めっき
     C           KEYF40    SETLLAAFPL031
     C           KEYF40    READEAAFPL031                 80
     C           *IN80     DOWEQ'0'
     C           A3SKJY    IFEQ *BLANK
     C           A3STYD    ANDGE*DATE
     C           A3STHZ    ANDEQ99999999
     C                     ADD  WX0004    A3MAXH
     C                     ADD  WX0004    A3AMXH
     C                     ADD  WX0004    A3HLTS
     C                     ADD  WX0004    A3KMAX
     C           A3KMAX    IFGT A3KALL
     C                     Z-ADDA3KMAX    A3KALL
     C                     ENDIF
     C                     UPDATAAFPL031
     C                     LEAVE
     C                     ENDIF
     C                     READ AAFPL031                 80
     C                     ENDDO
     C                     ENDIF
      *引取
     C           FX0005    IFEQ 'E    '
     C           KEYF40    SETLLAAHPL031
     C           KEYF40    READEAAHPL031                 80
     C           *IN80     DOWEQ'0'
     C           L6SKJY    IFEQ *BLANK
     C           L6STYD    ANDGE*DATE
     C           L6STHZ    ANDEQ99999999
     C                     ADD  WX0004    L6MAXH
     C                     ADD  WX0004    L6AMXH
     C                     ADD  WX0004    L6HLTS
     C                     ADD  WX0004    L6KMAX
     C           L6KMAX    IFGT L6KALL
     C                     Z-ADDL6KMAX    L6KALL
     C                     ENDIF
     C                     UPDATAAHPL031
     C                     LEAVE
     C                     ENDIF
     C                     READ AAHPL031                 80
     C                     ENDDO
     C                     ENDIF
      *
