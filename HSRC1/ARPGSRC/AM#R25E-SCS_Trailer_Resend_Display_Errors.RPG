     C                     MOVE *ON       *INLR
     C                     RETRN
      **************************************************************************
      *         INITIALIZE
      **************************************************************************
     C           *INZSR    BEGSR
      *
     C                     TIME           WSDT
     C                     Z-ADD*ZERO     RRN1    40
     C                     MOVEL*BLANK    MSG
     C                     MOVEL'30'      @@ID    2
     C                     MOVEL*OFF      *IN49
     C                     MOVELTT        TRTICK
