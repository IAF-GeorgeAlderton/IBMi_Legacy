      *
     C           K#L402    KLIST
     C                     KFLD           KYCTID 110
     C                     KFLD           KYAPID 20
      *
     C                     Z-ADDL1CTID    KYCTID
     C                     MOVEL'TRAILER' KYAPID
      *
     C                     MOVELL1APID    S2APID
     C                     Z-ADDL1CTID    S2CTID
     C                     MOVELL1SURT    S2SURT
     C                     Z-ADDL1SHID    S2SHID
     C                     Z-ADDL1SHIT    S2SHIT
     C                     MOVELL1TRLR    S2TRLR
     C                     MOVELL1ORD#    S2ODRN
     C                     MOVELL1DOCK    S2NUKE
     C                     MOVELL1NAMC    S2NAMC
     C                     MOVELL1PALT    S2PALT
      *
     C           K#L402    SETLLAM#PL402
     C                     DO   *HIVAL
      *
     C           K#L402    READEAM#PL402                 65
      *
     C           *IN65     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVELM1KOBJ    S2KOBJ
     C                     MOVELM1MESG    S2MESG
      *
     C                     ADD  1         RRN2
     C                     WRITESFL020
     C                     ENDDO
      *
     C           RRN2      IFEQ *ZERO
