     C                     ENDSR
      **************************************************************************
      *     DISPLAY ERROR MESSAGE SUBFILE.
      **************************************************************************
     C           #DSP30    BEGSR
      *
     C           K#L403    KLIST
     C                     KFLD           SURT    9
     C                     KFLD           SHID    80
      *
     C                     MOVELTTSURT    SURT
     C                     MOVELTTSHID    SHID
      *
     C           K#L403    SETGTAM#PL403
     C                     DO   *HIVAL
      *
     C           K#L403    REDPEAM#PL403                 65
      *
     C           *IN65     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C           L1APID    IFEQ 'TRAILER'
