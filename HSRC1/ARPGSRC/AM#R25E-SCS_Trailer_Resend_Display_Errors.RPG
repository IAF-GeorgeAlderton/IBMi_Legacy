     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVEL*ON       *IN61
     C                     WRITECTL020
     C                     MOVEL*OFF      *IN61
     C                     MOVEL*OFF      *IN62
