     C                     SETOF                     25
     C           X         CHAINSFL                  25
     C           *IN25     IFEQ '0'
      *
     C           @SEL      IFNE *BLANK
     C           @SEL      ANDNE'1'
     C           @SEL      ANDNE'0'
     C                     SETON                     3699
     C                     SETOF                     0305
     C                     MOVELER,1      @ERR
     C                     END
      *
     C  N99      @LKBN     IFNE 'N'
     C           @LKBN     ANDNE'Y'
