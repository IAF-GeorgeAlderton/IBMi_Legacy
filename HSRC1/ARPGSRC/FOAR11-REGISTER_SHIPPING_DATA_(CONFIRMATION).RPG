     C                     GOTO $S220E
     C                     END
      *-------------------*
      * CMD-5 OR CMD-3    *
      *-------------------*
     C           *IN05     IFEQ '1'
     C           *IN03     OREQ '1'
     C                     Z-ADD1         X
     C           1         DO   9999      X
     C           TKT1,X    IFNE *BLANK
      *
     C                     MOVE @KOJO     #KKOJO
     C                     MOVE TKT1,X    #KKAT1
     C                     MOVE TKT2,X    #KKAT2
     C                     MOVE TKT3,X    #KKAT3
     C                     MOVE TDTN,X    #KDTNO
     C                     MOVE TISK,X    #KIKSK
     C                     Z-ADDTSRY,X    @@SRY   50       出庫数
     C                     MOVE TKAI,X    @@KAI   1        回数
     C                     MOVE TISK,X    @@ISK   1        行先
     C                     MOVE TLTB,X    @@LTB   1        発行有無
     C                     MOVE TMNT,X    @@MNT   1
     C           @@ISK     IFEQ '2'
     C           @@ISK     OREQ '1'
     C                     EXSR $SB500
     C                     END
      *
     C                     END
     C                     ENDDO
      *
