     H            Y.
     F** ACHR08 *********************************************
     F*調整理由ファイルの更新                             *
     F*       ITS.                 2012.05.15               *
     F*-----------------------------------------------------*
     F*かんばんマスターの更新プログラムからACHR01をCALL *
     F*して作成した安全在庫ワークファイルの情報を         *
     F*かんばんマスターに反映する。                       *
     F*******************************************************
     FACHWL01 UF  E           K        DISK
     FABHPL03 UF  E           K        DISK
     FADHPL03 UF  E           K        DISK
     FAKBPL03 UF  E           K        DISK
      *
     I           SDS
     I                                        1  10 PGMNM
     I                                       91 170 MSGTXT
     I                                      244 253 WSID
     I                                      254 263 USID
     I                                      264 269 JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           PIJBN1  1
     C                     PARM           PIJBN2  2
     C                     PARM           PIJBN3  2
     C                     PARM           PIJBN4  1
     C                     PARM           PIUKYY  40
     C                     PARM           PIUKMM  20
     C                     PARM           PIUKDD  20
     C                     PARM           PIUBIN  20
      *
     C                     MOVE WSID      E@JOBM 10
     C                     MOVE USID      E@USER 10
     C                     MOVE JBNO      E@WNBR  6
     C                     Z-ADD*DATE     E@DATE  80
      *
     C           KEYZ11    KLIST
     C                     KFLD           E@JOBM 10
     C                     KFLD           E@USER 10
     C                     KFLD           E@WNBR  6
     C                     KFLD           E@DATE  80
      *
     C           Z1KKEY    KLIST
     C                     KFLD           Z1JBN1
     C                     KFLD           Z1JBN2
     C                     KFLD           Z1JBN3
     C                     KFLD           Z1JBN4
     C                     KFLD           Z1UKYY
     C                     KFLD           Z1UKMM
     C                     KFLD           Z1UKDD
     C                     KFLD           Z1UBIN
      *
     C           KEYZ11    SETLLACHWL01
     C           KEYZ11    READEACHWL01                  55
     C           *IN55     DOWEQ'0'
      *
     C           Z1JBN1    IFEQ PIJBN1
     C           Z1JBN2    ANDEQPIJBN2
     C           Z1JBN3    ANDEQPIJBN3
     C           Z1JBN4    ANDEQPIJBN4
     C           Z1UKYY    ANDEQPIUKYY
     C           Z1UKMM    ANDEQPIUKMM
     C           Z1UKDD    ANDEQPIUKDD
     C           Z1UBIN    ANDEQPIUBIN
     C           Z1KKEY    CHAINABHPL031             88
     C           *IN88     IFEQ '0'
     C                     EXSR #ABH
     C                     GOTO @DEL
     C                     ENDIF
      *
     C           Z1KKEY    CHAINADHPL031             88
     C           *IN88     IFEQ '0'
     C                     EXSR #ADH
     C                     GOTO @DEL
     C                     ENDIF
      *
     C           Z1KKEY    CHAINAKBPL031             88
     C           *IN88     IFEQ '0'
     C                     EXSR #AKB
     C                     GOTO @DEL
     C                     ENDIF
      *
     C           @DEL      TAG
     C                     DELETACHWL011
     C                     ENDIF
      *
     C           KEYZ11    READEACHWL01                  55
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
     CSR         #ABH      BEGSR
      *
     C                     Z-ADDZ1CMAI    M6CMAI
     C                     Z-ADDZ1DAND    M6DAND
     C                     Z-ADDZ1KYOT    M6KYOT
     C                     Z-ADDZ1FRYO    M6FRYO
     C                     Z-ADDZ1SENY    M6SENY
     C                     Z-ADDZ1OTHH    M6OTHH
     C                     MOVELZ1CMT1    M6CMT1
     C                     MOVELZ1CMT2    M6CMT2
     C                     Z-ADDZ11NAI    M61NAI
     C                     Z-ADDZ12NAI    M62NAI
     C                     Z-ADDZ1JISK    M6JISK
     C                     Z-ADDZ1AUAJ    M6AUAJ
     C                     UPDATABHPL031
      *
     CSR         EABH      ENDSR
      *-----------------------------------------------------
     CSR         #ADH      BEGSR
      *
     C                     Z-ADDZ1CMAI    J6CMAI
     C                     Z-ADDZ1DAND    J6DAND
     C                     Z-ADDZ1KYOT    J6KYOT
     C                     Z-ADDZ1FRYO    J6FRYO
     C                     Z-ADDZ1SENY    J6SENY
     C                     Z-ADDZ1OTHH    J6OTHH
     C                     MOVELZ1CMT1    J6CMT1
     C                     MOVELZ1CMT2    J6CMT2
     C                     Z-ADDZ11NAI    J61NAI
     C                     Z-ADDZ12NAI    J62NAI
     C                     Z-ADDZ1JISK    J6JISK
     C                     Z-ADDZ1AUAJ    J6AUAJ
     C                     UPDATADHPL031
      *
     CSR         EADH      ENDSR
      *-----------------------------------------------------
     CSR         #AKB      BEGSR
      *
     C                     Z-ADDZ1CMAI    L1CMAI
     C                     Z-ADDZ1DAND    L1DAND
     C                     Z-ADDZ1KYOT    L1KYOT
     C                     Z-ADDZ1FRYO    L1FRYO
     C                     Z-ADDZ1SENY    L1SENY
     C                     Z-ADDZ1OTHH    L1OTHH
     C                     MOVELZ1CMT1    L1CMT1
     C                     MOVELZ1CMT2    L1CMT2
     C                     Z-ADDZ11NAI    L11NAI
     C                     Z-ADDZ12NAI    L12NAI
     C                     Z-ADDZ1JISK    L1JISK
     C                     Z-ADDZ1AUAJ    L1AUAJ
     C                     UPDATAKBPL031
      *
     CSR         EAKB      ENDSR
