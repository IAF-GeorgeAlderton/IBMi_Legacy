      * SAVE AETOKU/NONY
     C                     MOVELAETOKU    XXTOKU  4        PLANT
     C                     MOVELAENONY    XXNONY  4
      * CHANGE QTY
     C           AEEQTY    IFEQ 0
     C                     Z-ADD0.1       AEEQTY
     C                     ENDIF
JW3   * STOP EDI
     C           AENONY    IFEQ '5253'                     LITENS
     C                     GOTO @@JUMP
     C                     ENDIF
      *
      * IGNORE IF RCV_DATE >= SHP_DATE
     C           AERCVT    IFGE AEDAT1
     C           AEEQTY    ANDEQ0
     C                     GOTO @@JUMP
     C                     ENDIF
      * IGNORE QTY=0 FOR DENSO
     C                     MOVELAEPRTR    LTR5    5
     C           LTR5      IFEQ 'DENSO'
     C           AEEQTY    ANDLE0
     C                     GOTO @@JUMP
     C                     ENDIF
JW    * IGNORE DENSO,TN
     C           AENONY    IFEQ '3092'
     C                     GOTO @@JUMP
     C                     ENDIF
      * IGNORE WKW
     C           AENONY    IFEQ '8005'
     C                     GOTO @@JUMP
     C                     ENDIF
      * IGNORE ADVICS
     C           AENONY    IFEQ '0465'
     C                     GOTO @@JUMP
     C                     ENDIF
JW1   * IGNORE THAI SUMMIT
     C           AENONY    IFEQ '6022'
     C                     GOTO @@JUMP
     C                     ENDIF
      * IGNORE AAGT
     C           AENONY    IFEQ '0794'
     C                     GOTO @@JUMP
     C                     ENDIF
      * IGNORE TOYOTETSU
     C           AENONY    IFEQ '3511'                     TTTX
     C           AENONY    OREQ '3512'                     TTCA
     C           AENONY    OREQ '3550'                     TTMA
     C           AENONY    OREQ '3556'                     TTAI
     C           AENONY    OREQ '4022'                     YKTA
     C           AEESID    IFEQ 'C'
     C                     GOTO @@JUMP
     C                     ENDIF
     C                     MOVELAETOKU    WTOKU
     C                     MOVELAENONY    WNONY
     C                     MOVEL'0'       AENKOJ
     C                     MOVEL'00  '    AENUKE
     C                     MOVEL'0'       WNKOJ
     C                     MOVEL'00  '    WNUKE
     C                     ENDIF
