     C                     PARM           $NONY   4
     C                     PARM           $MHIN  20
     C                     PARM           $NUKE   4
     C                     PARM           $RTN    1
     C                     MOVEL$NUKE     AENUKE
     C                     ENDIF
     C                     ENDIF
