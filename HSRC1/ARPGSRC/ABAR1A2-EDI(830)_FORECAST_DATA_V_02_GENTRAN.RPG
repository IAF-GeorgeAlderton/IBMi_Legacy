     C           @@PRT3    IFEQ 'SRG'
     C           AEEQTY    IFLE 0
     C           AEORID    ORNE 'D'
     C                     GOTO @@JUMP
     C                     ENDIF
      *
     C           AENONY    IFEQ *BLANK
     C           AENONY    OREQ '0000'
     C                     MOVEL'SRG     'K@PL10    P
     C                     MOVELAESPID    K@SHCD    P
     C           K#PPQ1    CHAINAB#PPQ1              94
     C           *IN94     IFEQ *OFF
     C                     MOVELQ1TOKU    AETOKU
     C                     MOVELQ1NONY    AENONY
     C                     ELSE
     C                     MOVEL'0000'    AETOKU
     C                     MOVEL'0000'    AENONY
