      * *INL3 = *ON
     C           *INL3     IFEQ *ON
     C           AEPRTR    OREQ 'TMS'
     C           AEPRTR    OREQ 'TMMNA'
     C           AETOKU    OREQ 'HSP '
     C           LTR5      OREQ 'DENSO'
      * SHIP TO
     C                     MOVELAEPRTR    K@KWD1    P
     C                     MOVEL'ENONY'   K@KWD2    P
     C           K#KEY     CHAINAB#EP00              90
     C           *IN90     IFEQ *ON
     C                     MOVELAEPRTR    @@5     5 P
     C                     MOVEL@@5       K@KWD1    P
     C           K#KEY     CHAINAB#EP00              90
     C                     ENDIF
      *
     C           *IN90     IFEQ *OFF
     C                     MOVELEPVAL1    @VAL1   1
     C                     MOVE @VAL1     @N      1
     C                     SELEC
     C           @VAL1     WHEQ 'A'
     C**                   EXSR #NONY
     C           @VAL1     WHEQ 'B'
     C                     EXSR #HONDA
     C           @VAL1     WHEQ 'C'
     C                     EXSR #NONYC
     C                     ENDSL
      *
     C           XXTOKU    IFNE ZZTOKU
     C           *INL3     OREQ *ON
     C                     MOVEA'00'      *IN,97
     C                     MOVE *BLANK    @N      1
     C                     ENDIF
      *
     C                     ENDIF
      * ---------------------------------------------------
      * ADJUST HONDA CUST/DELIVERY
     C           XXTOKU    IFEQ 'HSP '
      * ---------------------------------------------------
     C           K#SHC     KLIST
     C                     KFLD           K@PLNT  3
     C                     KFLD           K@SHCD 10
     C                     MOVELAETOKU    K@PLNT
     C                     MOVELAEFLR1    K@SHCD
     C                     MOVE *OFF      *IN95
     C           K#SHC     SETGTAB#PPHN
     C                     DO   *HIVAL
     C           K#SHC     REDPEAB#PPHN                  95
     C   95                LEAVE
     C           AHSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C                     MOVELAHTOKU    AETOKU
     C                     MOVELAHNONY    AENONY
     C                     MOVELAHNONY    SVNONY
     C                     MOVELAHNONY    WNONY
     C                     LEAVE
     C                     ENDDO
     C                     ENDIF
      *
      * ---------------------------------------------------
      * GET HONDA NONY FROM WILD CHARACTER(*)
      * ---------------------------------------------------
     C           AENONY    IFEQ '0000'
     C                     MOVEL'*'       K@SHCD    P
     C           K#SHC     CHAINAB#PPHN              95
     C           *IN95     IFEQ *OFF
     C           AHSKJY    ANDNE'D'
     C                     MOVELAHTOKU    AETOKU
     C                     MOVELAHNONY    AENONY
     C                     MOVELAHNONY    SVNONY
     C                     MOVELAHNONY    WNONY
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVELAETOKU    XTOKU   4
      *
     C           AETOKU    IFGE '0001'
     C           AETOKU    ANDLE'9999'
     C                     MOVELAETOKU    WTOKU   40
     C                     ELSE
     C                     Z-ADD0         WTOKU
     C                     ENDIF
      * ---------------------------------------------------
JW2   * HONDA NONY CHECK
      * ---------------------------------------------------
     C           @@PRT5    IFEQ 'HONDA'
     C                     MOVELXXTOKU    $PLANT
     C                     MOVELAEFLR1    $SHCD
     C                     CALL 'UTLR74'
     C                     PARM           $PLANT  3
     C                     PARM           $SHCD  10
     C                     PARM           $TOKU   4
     C                     PARM           $NONY   4
     C                     PARM           $RTN1   1
     C           $RTN1     IFEQ '*'
     C                     MOVEL$TOKU     WTOKU
     C                     MOVEL$NONY     WNONY
     C                     ENDIF
JW2  C                     ENDIF
      * ---------------------------------------------------
      * TIMING OF OUTPUT
     C                     MOVE *BLANK    @@L     1
     C                     MOVELAEPRTR    K@KWD1    P
     C                     MOVEL'AB#WP10' K@KWD2    P
     C           K#KEY     CHAINAB#EP00              90
     C           *IN90     IFEQ *OFF
     C                     MOVELEPVAL1    @@L     1
     C                     ENDIF
      *
     C                     MOVELAENONY    WNONY   40
     C                     MOVELAENKOJ    WNKOJ   1
      *
     C                     ELSE
     C           @N        IFEQ 'A'
     C           AEFLR1    ANDNE@@FLR1
     C**                   EXSR #NONY
     C                     MOVELAENONY    WNONY   40
     C                     SETON                     30
     C                     ENDIF
     C                     ENDIF
      *
     C           @@L       IFEQ 'A'
     C           *INL1     ANDEQ*ON
     C                     Z-ADD*ZERO     WYM
     C                     Z-ADD*ZERO     @A      30
     C                     Z-ADD*ZERO     @@QTY   81
     C                     ENDIF
      *
     C           AEUPID    CABNE*BLANK    @@JUMP
      * 0946 TOWER AUTOMOTIVE
     C           AETOKU    IFEQ '0946'
     C           AERCVT    IFNE W@RCVT
     C           AENONY    ORNE W@NONY
     C           AENKOJ    ORNE W@NKOJ
     C           AENUKE    ORNE W@NUKE
     C           AEMHIN    ORNE W@MHIN
     C                     Z-ADD*ZERO     W@QTY2
     C                     Z-ADDAERCVT    W@RCVT
     C                     MOVELAENONY    W@NONY
     C                     MOVELAENKOJ    W@NKOJ
     C                     MOVELAENUKE    W@NUKE
     C                     MOVELAEMHIN    W@MHIN
     C                     END
     C           AEEQTY    SUB  AECQTY    W@QTY1  90
     C           W@QTY1    SUB  W@QTY2    AEEQTY
     C                     Z-ADDW@QTY1    W@QTY2
     C                     END
     C*
     C           WNONY     IFNE 0332
     C           AEEQTY    CABLT*ZERO     @@JUMP
     C                     ENDIF
      *
     C                     MOVELXXTOKU    AETOKU
     C                     MOVELXXNONY    AENONY
     C                     MOVE '1'       AEUPID
TEMP  *
     C***        TEMP      IFEQ 'N'
     C                     UPDATABAEP201
TEMP C***                  ENDIF
      * ---------------------------------------------------
      * PROCESS OR NOT
     C                     MOVEL'AEORID'  K@KWD2    P
     C           K#KEY     CHAINAB#EP00              90
     C           *IN90     IFEQ *OFF
     C                     MOVELEPVAL1    @@1     1
     C                     MOVELEPVAL2    @@X     1
     C           @@X       IFEQ 'N'
     C           @@1       CABEQAEORID    @@JUMP
     C                     ELSE
     C           AEPRTR    IFEQ 'AMBRAKE'
     C                     MOVELAEESID    @@@1    1
     C           @@@1      CABEQ'D'       @@JUMP
     C                     ELSE
     C           @@1       CABNEAEORID    @@JUMP
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C   L3                SETON                     30
      * ---------------------------------------------------
      * SET RECIEVED DATE
     C           AERCVT    IFEQ *ZERO
     C                     Z-ADD*DATE     WDAT8
     C                     ELSE
     C                     Z-ADDAERCVT    WDAT8   80
     C                     ENDIF
      * ---------------------------------------------------
      * REMOVE BLANK FROM USER PART# (--> WMHIN)
     C                     MOVEAAEMHIN    MH1       P
     C                     MOVE *BLANK    MH2
     C                     Z-ADD0         YY      20
     C           1         DO   30        XX      20
     C           MH1,XX    IFNE '-'
     C           MH1,XX    ANDNE'/'
     C           MH1,XX    ANDNE'.'
     C           MH1,XX    ANDNE*BLANK
     C                     ADD  1         YY
     C                     MOVE MH1,XX    MH2,YY
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAMH2       WMHIN     P
      * SRG
     C           @@PRT3    IFEQ 'SRG'
     C                     MOVELAEMHIN    WMHIN     P
     C                     ENDIF
      * ------------------------------------------------------------
     C                     MOVE 'C'       WNOKN   1        IN CHARGE
      * ------------------------------------------------------------
      * SET DOCK
     C                     MOVELAENUKE    WNUKE   4
     C           AENUKE    IFEQ *BLANK
     C           AENUKE    OREQ '0   '
     C           WNONY     IFEQ 0701
     C                     MOVEL'T00 '    WNUKE
     C                     ELSE
     C                     MOVEL'00  '    WNUKE
     C                     END
     C                     ENDIF
      * ---------------------------------------------------
      * TEXTRON
     C           AEMHIN    IFNE XXMHIN
     C           WNONY     ANDEQ5535
     C                     EXSR #RSET
     C                     ENDIF
      * ---------------------------------------------------
      * USER PART
     C                     MOVELAEMHIN    XXMHIN 30
      * TBA (3322)
     C           AENONY    IFEQ '3322'
     C           WTOKU     IFEQ 0
     C                     Z-ADD3315      WTOKU
     C                     ENDIF
     C           WNONY     IFEQ 0
     C                     Z-ADD3322      WNONY
     C                     ENDIF
     C                     MOVEL'0'       WNKOJ
     C                     MOVEL'00  '    WNUKE
     C                     ENDIF
      * ---------------------------------------------------
      * QTY
     C                     Z-ADDAEEQTY    WSURY   80
     C                     ADD  AEEQTY    @@QTY
      *
     C                     MOVELAEPRTR    WPRTR  10
      * SCHEDULE/START DATE
     C                     MOVELAEDAT1    @DATC     P
     C           @DATS     IFEQ *BLANK
     C                     MOVE @DAT6     WDAT6   60
     C           WDAT6     ADD  20000000  WNYMD
     C                     ELSE
     C                     MOVE AEDAT1    WNYMD
     C                     ENDIF
      *
     C           AESBAN    IFEQ *BLANK
     C           K#FCC     CHAINFCCTL13              90
     C           *IN90     IFEQ *OFF
     C                     MOVELB4SBAN    AESBAN
     C                     ELSE
     C                     MOVE '0000'    AESBAN
     C                     ENDIF
     C                     ENDIF
      * ---------------------------------------------------
      * SET SBAN
     C           WNONY     IFEQ 0541
     C           AESBAN    ANDEQ'AAAA'
     C           K#01      SETGTAB#PL01
     C           *IN90     DOUEQ*ON
     C           K#01      REDPEAB#PL01                  90
     C           *IN90     IFEQ *OFF
     C           B1SKJY    ANDEQ*BLANK
     C           B1SBAN    IFNE AESBAN
     C                     MOVE B1SBAN    AESBAN
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      * ---------------------------------------------------
      * END DATE
     C           AEDAT2    IFNE *ZERO
     C           AEDAT2    ANDNE19910816
     C                     MOVE AEDAT2    @DATC     P
     C           @DATS     IFEQ *BLANK
     C                     MOVE @DAT6     WDAT6   60
     C           WDAT6     ADD  20000000  @@EDAT  80
     C                     ELSE
     C                     MOVE AEDAT2    @@EDAT
     C                     ENDIF
     C                     ELSE
     C                     Z-ADD*ZERO     @@EDAT
     C                     ENDIF
      * ---------------------------------------------------
      * TOYOTA BUILD OUT
     C                     MOVEL*BLANK    WBBFLG  1
     C           AEORID    IFEQ 'D'
     C           AEESID    ANDEQ'F'
     C           AEDAT2    ANDEQ19910816
     C                     MOVEL'1'       WBBFLG
     C                     ENDIF
      *
     C           WNYMD     CABEQ0         @@JUMP
      *
     C           @@L       IFEQ 'A'
     C           WNYMD     LOKUPWYM                      55
     C           *IN55     IFEQ *OFF
     C                     ADD  1         @A
     C                     Z-ADDWNYMD     WYM,@A
     C                     MOVE '1'       @UP     1
     C                     ELSE
     C                     MOVE *BLANK    @UP
     C                     ENDIF
     C                     ENDIF
      *
     C           P@REC     IFEQ *BLANK
     C                     MOVE '1'       P@REC
     C                     ENDIF
      *
     C  N31                SETON                     3031
     C                     SETON                     20
      * ----------------------------------------------------
      * LEVELIZE WEEKLY FORECAST TO DAILY BASE
     C                     EXSR #LEVEL
      * ---------------------------------------------------
      * HISTORY FILE
     C           K#P5X     CHAINABBPL50              90
     C           *IN90     IFEQ *ON
     C                     CLEARABBPP501
     C                     ENDIF
     C                     Z-ADDWDAT8     BBRCDT
     C                     Z-ADDWTOKU     BBTOKU
     C                     Z-ADDWNONY     BBNONY
     C                     MOVE WNKOJ     BBNKOJ
     C                     MOVE WNUKE     BBNUKE
     C                     MOVELWMHN1     BBMHN1
     C                     MOVELWMHN2     BBMHN2
     C                     MOVELWMHN3     BBMHN3
     C                     MOVELWMHN4     BBMHN4
     C                     Z-ADDWNYMD     BBSDAT
     C           @@L       IFEQ 'A'
     C                     Z-ADD@@QTY     BBSQTY
     C                     ELSE
     C           WTOKU     IFEQ 0294
     C           *IN90     ANDEQ*OFF
     C                     ADD  WSURY     BBSQTY
     C                     ELSE
     C                     Z-ADDWSURY     BBSQTY
     C                     END
     C                     ENDIF
      *
     C                     MOVE AESBAN    BBSEBN
      * ---------------------------------------------------
      * IAF PART#
     C                     MOVE WTOKU     PTOKU
     C                     MOVE WNONY     PNONY
     C                     MOVE WNKOJ     PNKOJ
     C                     MOVE WNUKE     PNUKE
     C                     MOVE WMHIN     PMHIN
     C                     MOVE *BLANK    PSHIN
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           PMHIN  20
     C                     PARM           PSHIN  12
     C                     PARM           PFLAG   1
      *
     C                     MOVELPSHN1     BBSHN1
     C                     MOVELPSHN2     BBSHN2
     C                     MOVELPSHN3     BBSHN3
      *
     C                     MOVELWBBFLG    BBBFLG
      * ---------------------------------------------------
      * FORECAST TYPE
     C                     SELEC
     C           AEPRTR    WHEQ 'IFS'
     C                     MOVE 'I'       BBFLG2
     C                     OTHER
     C                     MOVE 'E'       BBFLG2
     C                     ENDSL
      *
TEMP C***        TEMP      IFEQ 'N'
     C   90                WRITEABBPP501
     C  N90                UPDATABBPP501
TEMP C***                  ENDIF
      *
     C           WTOKU     IFNE @@TOKU
     C           WNONY     ORNE @@NONY
     C           K#25      CHAINABAEP25              90
     C           *IN90     IFEQ *ON
     C                     Z-ADDWTOKU     AACUST
     C                     Z-ADDWNONY     AASHTO
      *
TEMP C***        TEMP      IFEQ 'N'
     C                     WRITEABAEP251
     C***                  ENDIF
      *
     C                     ENDIF
     C                     ENDIF
      *
     C           AETOKU    IFNE '0946'
     C           *INL2     IFEQ *ON
     C           K#FCE     CHAINFCEPL01              90
     C           *IN90     IFEQ *OFF
     C           AECQTY    ANDNEA2SSYS
     C           AECQTY    ANDNE*ZERO
      *
     C                     MOVE '3'       P@ERR1
     C           *IN96     IFEQ *OFF
     C           *INOC     OREQ *ON
     C                     EXCPT@HED3
     C                     ENDIF
     C  N96                MOVE *ON       *IN96
      * ---------------------------------------------------
      * GET CUST NAME
     C                     MOVELWNONY     $DLV
     C                     CALL 'UTLR62B'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTN    1
     C                     MOVEL$NAME1    XNAM15 15
      *
     C                     EXCPT@DTL3
     C                     ENDIF
     C                     ENDIF
     C                     END
      *
     C           AEDAT2    IFNE 19910816
     C                     MOVE AEDAT2    @@PDAT  8
     C                     ENDIF
     C                     MOVE AEFLR1    @@FLR1 10
     C                     Z-ADDWNONY     @@NONY  40
     C                     Z-ADDWTOKU     @@TOKU  40
     C           @@JUMP    TAG
      * RESTORE TOKU/NONY
     C                     MOVELXXTOKU    AETOKU
     C                     MOVELXXNONY    AENONY
      * SAVE    TOKU/NONY
     C                     MOVELXXTOKU    ZZTOKU  4
     C                     MOVELXXNONY    ZZNONY  4
      *////////////////////////////////////////////////////////
      *  END OF MAIN ROUTINE  /////////////////////////////////
      *////////////////////////////////////////////////////////
      *
      *********************************************************
