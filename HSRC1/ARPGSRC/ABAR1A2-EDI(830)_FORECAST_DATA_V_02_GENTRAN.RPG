     C                     MOVELAENONY    WNONY
     C                     MOVEL'0'       AENKOJ
     C                     MOVEL'00  '    AENUKE
     C                     MOVEL'0'       WNKOJ
     C                     MOVEL'00  '    WNUKE
      *
     C                     ENDIF
      * ---------------------------------------------------
      * ADJ AUTOKINITON
     C           AENONY    IFEQ '5444'
     C           AENONY    OREQ '5445'
     C           AENONY    OREQ '5446'
      * CHECK FIRST PART#
     C           AENONY    IFNE FFNONY
     C           AEMHIN    ORNE FFMHIN
     C                     Z-ADDAECQTY    QT5444
     C                     MOVELAENONY    FFNONY
     C                     MOVELAEMHIN    FFMHIN
     C                     ENDIF
      *
     C           AEEQTY    SUB  QT5444    @XQTY   80
     C                     Z-ADD@XQTY     AEEQTY
     C                     ADD  @XQTY     QT5444
     C           AEEQTY    IFLT 0
     C                     Z-ADD0         AEEQTY
     C                     ENDIF
     C                     ENDIF
      * ---------------------------------------------------
      * PISTON
     C           AEPRTR    IFEQ 'PISTON '
     C           AEPRTR    OREQ 'PISTON2'
     C           AEPRTR    OREQ 'PISTON4'
     C           AEPRTR    OREQ 'PISTON6'
     C           AEPRTR    OREQ 'PISTON7'
     C                     EXSR #PIST
     C                     ENDIF
      * ---------------------------------------------------
      * ADVICS (0465)
     C           AEPRTR    IFEQ 'ADVICS '
     C           AENUKE    IFEQ *BLANK
     C           AENUKE    OREQ '00  '
