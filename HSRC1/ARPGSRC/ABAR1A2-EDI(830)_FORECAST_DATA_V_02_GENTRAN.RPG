      *********************************************************
      *  LEVELIZE WEEKLY FORECAST TO DAILY BASE
      *********************************************************
     C           #LEVEL    BEGSR
      *
      * CHECK SHIPPING MASTER
     C           @@PRT5    IFNE 'HONDA'
JW   C           WNONY     IFEQ *ZERO
 .   C           AENONY    ANDNE*ZERO
 .   C                     MOVELAENONY    WNONY
 .   C                     ENDIF
 .    *
 .   C           WTOKU     IFEQ *ZERO
 .   C           AETOKU    ANDNE*ZERO
 .   C                     MOVELAETOKU    WTOKU
JW   C                     ENDIF
JW   C                     ENDIF
 .    *
 .   C           WNKOJ     IFEQ ' '
 .   C                     MOVE '0'       WNKOJ
JW   C                     ENDIF
 .    *
 .   C           WNUKE     IFEQ ' '
 .   C                     MOVEL'00  '    WNUKE
JW   C                     ENDIF
      *
     C           KEY5      CHAINGADPL111             10
     C           *IN10     IFEQ '0'
     C           B5SKJY    ANDEQ'D'
     C           B5SKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
      * CASE1:
     C           *IN10     IFEQ '1'
     C  N32                SETON                     4032
     C                     SETON                     05
      *
     C           *IN97     IFEQ *OFF
     C           *INOA     OREQ *ON
     C                     EXCPT@HED1
     C                     ENDIF
     C  N97                MOVE *ON       *IN97
      *
JWI  C           WTOKU     IFEQ 0
 |   C           AETOKU    ANDEQ'HSP'
 |   C                     Z-ADD0         WNONY
JWI  C                     ENDIF
      *
JWK  C           WSURY     IFGT 99
     C                     EXCPT@DTL1
JW9  C                     MOVE '1'       P@ERR2
JWI  C                     ENDIF
      *
     C                     GOTO XLEVEL
     C                     ENDIF
      * ====================================================
      * TOYOTA LEVELIZE
     C           AETOKU    IFEQ '3411'
     C                     EXSR #LVLT
     C                     ELSE
      * OTHER  CUSTOMER LEVELIZE
     C                     EXSR #LVLO
     C                     ENDIF
      *
     C           XLEVEL    ENDSR
      *********************************************************
      * LIVELIZE FOR TOYOTA
      *********************************************************
     C           #LVLT     BEGSR
      * ADJ END DATE
     C           AEDAT1    IFGE AEDAT2
      *  * GET WORKING DAYS
     C                     MOVELAEDAT1    $DT8
     C                     MOVEL'0007'    $DAY1
     C                     CALL 'UTLR02B'
     C                     PARM           $DT8    8
     C                     PARM           $DAY1   4
     C                     PARM           $DAY2   4
     C                     MOVEL$DAY2     @DAY2   40
     C           @DAY2     IFGE 1
     C                     SUB  1         @DAY2
     C                     ELSE
     C                     Z-ADD0         @DAY2
     C                     ENDIF
      *
     C                     MOVELAEDAT1    $DT8
     C                     MOVE '+'       $SIGN
     C                     MOVEL@DAY2     $DAYS
     C                     MOVE 'N'       $IAF
     C                     CALL 'UTLR10A'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN    1
     C                     MOVEL$TGT8     AEDAT2
     C                     ENDIF
      *
     C           *IN98     IFEQ *OFF
     C           *INOB     OREQ *ON
     C                     EXCPT@HED2
     C                     ENDIF
     C  N98                MOVE *ON       *IN98
JWK  C           WSURY     IFGT 99
     C                     EXCPT@DTL2
JW1  C                     ENDIF
      *
     C                     Z-ADD0         BB      20
     C                     Z-ADD0         HYM
     C                     Z-ADD0         WKAD    20
      * ----------------------------------------------------
      * FOR HONDA DAILY FORECAST
     C           AEESID    IFEQ 'C'
     C                     Z-ADD1         WKAD
     C                     Z-ADDWNYMD     HYM,1
     C                     ELSE
      * ----------------------------------------------------
      * NAL DAILY FORECAST
     C           AEESID    IFEQ 'D'
     C           AEPRTR    ANDEQ'NAL'
     C                     Z-ADD1         WKAD
     C                     Z-ADDWNYMD     HYM,1
      * ----------------------------------------------------
      * WEEKLY FORECAST
     C                     ELSE
      *
      *%%%%% GET WORKING DAYS  (WKAD=WORK DAYS, HYM=DATE) %%%%%
     C                     Z-ADDAEDAT1    WNYMD
     C           KEY4      SETLLAGDPL121                   START DATE
     C                     DO   *HIVAL
     C                     READ AGDPL121                 10
     C   10                LEAVE
      *
     C           F8KAHZ    IFGT AEDAT2                     END DATE
     C                     LEAVE
     C                     ENDIF
      * ---------------------------------------------------
      * IGNORE SAT AND SUN
     C           F8YOBI    IFEQ 6
     C           F8YOBI    OREQ 7
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         BB
     C                     ADD  1         WKAD
     C                     Z-ADDF8KAHZ    HYM,BB
      *
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDIF
      *%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
      *
%0004C                     Z-ADD0         WKSUR   70
%0004C                     Z-ADD0         WKSURD  70
%0004C                     Z-ADD0         WKSURX  73
      *
     C           WKAD      IFEQ 0
     C                     GOTO XLVLT                      STOP IF WRK_DAY=0
     C                     ENDIF
      *====================================================
      *
     C           WSURY     DIV  WKAD      WKSURD  70
%0004C                     MVR            WKSURX
      *
     C                     Z-ADD0         AA      20
     C           1         DO   *HIVAL
     C                     ADD  1         AA
      *
     C           HYM,AA    IFEQ 0
     C                     LEAVE
     C                     ENDIF
      * ---------------------------------------------------
      * ADD REMAINDER TO FIRST QTY
     C           AA        IFEQ 1
     C           WKSURD    ADD  WKSURX    WKSUR
     C                     ELSE
     C                     Z-ADDWKSURD    WKSUR
     C                     ENDIF
      *
     C                     Z-ADDHYM,AA    @NYMD
      *
     C           KEY2      CHAINABAWP101             11
      * WRITE
     C           *IN11     IFEQ '1'
     C                     CLEARABAWP101
     C                     Z-ADDWTOKU     ABTOKU
     C                     Z-ADDWNONY     ABNONY
     C                     MOVE WNKOJ     ABNKOJ
     C                     MOVE WNUKE     ABNUKE
     C                     MOVE AESBAN    ABSBAN
     C                     MOVELWMHIN     ABMHIN
     C                     Z-ADD@NYM      ABDATE
     C                     Z-ADD0         HSU
      * %0003
     C           WBBFLG    IFNE '1'
     C                     Z-ADDWKSUR     HSU,DX
     C                     ENDIF
      * ---------------------------------------------------
      * WRITE ABAWP10
     C                     XFOOTHSU       ABNNSU
     C                     MOVE WNOKN     ABNOKN
     C                     MOVELWBBFLG    ABBFLG
     C                     WRITEABAWP101
     C                     ITER
     C                     ENDIF
      * ---------------------------------------------------
      * UPDATE
     C           WBBFLG    IFEQ '1'
     C                     MOVELWBBFLG    ABBFLG
     C                     ELSE
     C           @@L       IFEQ *BLANK
     C           @@L       OREQ 'A'
     C           *INL1     ANDEQ*ON
      *
TCHK3C           WTOKU     IFEQ 0294
TCHK3C           K#P5X     CHAINABBPL50              90
TCHK3C   90                Z-ADDWKSUR     HSU,DX
TCHK3C  N90                ADD  WKSUR     HSU,DX
TCHK3C                     ELSE
     C                     Z-ADDWKSUR     HSU,DX
TCHK3C                     END
      *
     C                     ELSE
     C                     ADD  WKSUR     HSU,DX
     C                     ENDIF
      *
     C                     XFOOTHSU       ABNNSU
     C                     MOVE WNOKN     ABNOKN
      *
%0003C                     ENDIF
      * ---------------------------------------------------
      * UPDATE ABAWP10
     C                     UPDATABAWP101
      *
     C                     ENDDO
      *
     C           XLVLT     ENDSR
      *********************************************************
      * LIVELIZE FOR OTHER CUSTOMER
      *********************************************************
     C           #LVLO     BEGSR
      *
     C           *IN98     IFEQ *OFF
     C           *INOB     OREQ *ON
     C                     EXCPT@HED2
     C                     ENDIF
     C  N98                MOVE *ON       *IN98
JWK  C           WSURY     IFGT 99
     C                     EXCPT@DTL2
JW1  C                     ENDIF
      *
     C                     Z-ADD0         BB      20
     C                     Z-ADD0         HYM
     C                     Z-ADD0         WKAD    20
      * ----------------------------------------------------
      * FOR HONDA DAILY FORECAST
     C           AEESID    IFEQ 'C'
     C                     Z-ADD1         WKAD
     C                     Z-ADDWNYMD     HYM,1
     C                     ELSE
      * ----------------------------------------------------
      * OTHER DAILY FORECAST
     C           AEESID    IFEQ 'D'
     C           AEPRTR    ANDEQ'NAL'
     C                     Z-ADD1         WKAD
     C                     Z-ADDWNYMD     HYM,1
      * ----------------------------------------------------
      * WEEKLY FORECAST
     C                     ELSE
      *
     C           KEY4      SETLLAGDPL121
     C                     Z-ADD0         AA      20
     C           *IN10     DOUEQ*ON
     C                     READ AGDPL121                 10
     C           *IN10     IFEQ '0'
      *
     C                     ADD  1         AA
      *
     C           AA        IFGT 7
     C                     LEAVE
     C                     ENDIF
      * ---------------------------------------------------
      * IGNORE SAT AND SUN
     C           F8YOBI    IFEQ 6
     C           F8YOBI    OREQ 7
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         BB
     C                     ADD  1         WKAD
     C                     Z-ADDF8KAHZ    HYM,BB
      *
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDIF
      *
%0004C                     Z-ADD0         WKSUR   70
%0004C                     Z-ADD0         WKSURD  70
%0004C                     Z-ADD0         WKSURX  73
      *
     C           WKAD      IFEQ 0
     C                     GOTO XLVLO                      STOP IF WRK_DAY=0
     C                     ENDIF
      *====================================================
      *
     C           WSURY     DIV  WKAD      WKSURD  70
%0004C                     MVR            WKSURX
      *
     C                     Z-ADD0         AA
     C           1         DO   *HIVAL
     C                     ADD  1         AA
      *
     C           HYM,AA    IFEQ 0
     C                     LEAVE
     C                     ENDIF
      * ---------------------------------------------------
      * ADD REMAINDER TO FIRST QTY
     C           AA        IFEQ 1
     C           WKSURD    ADD  WKSURX    WKSUR
     C                     ELSE
     C                     Z-ADDWKSURD    WKSUR
     C                     ENDIF
      *
     C                     Z-ADDHYM,AA    @NYMD
      *
     C           KEY2      CHAINABAWP101             11
      * WRITE
     C           *IN11     IFEQ '1'
     C                     CLEARABAWP101
     C                     Z-ADDWTOKU     ABTOKU
     C                     Z-ADDWNONY     ABNONY
     C                     MOVE WNKOJ     ABNKOJ
     C                     MOVE WNUKE     ABNUKE
     C                     MOVE AESBAN    ABSBAN
     C                     MOVELWMHIN     ABMHIN
     C                     Z-ADD@NYM      ABDATE
     C                     Z-ADD0         HSU
      * %0003
     C           WBBFLG    IFNE '1'
     C                     Z-ADDWKSUR     HSU,DX
     C                     ENDIF
      * ---------------------------------------------------
      * WRITE ABAWP10
     C                     XFOOTHSU       ABNNSU
     C                     MOVE WNOKN     ABNOKN
     C                     MOVELWBBFLG    ABBFLG
     C                     WRITEABAWP101
     C                     ITER
     C                     ENDIF
      * ---------------------------------------------------
      * UPDATE
     C           WBBFLG    IFEQ '1'
     C                     MOVELWBBFLG    ABBFLG
     C                     ELSE
     C           @@L       IFEQ *BLANK
     C           @@L       OREQ 'A'
     C           *INL1     ANDEQ*ON
      *
TCHK3C           WTOKU     IFEQ 0294
TCHK3C           K#P5X     CHAINABBPL50              90
TCHK3C   90                Z-ADDWKSUR     HSU,DX
TCHK3C  N90                ADD  WKSUR     HSU,DX
TCHK3C                     ELSE
     C                     Z-ADDWKSUR     HSU,DX
TCHK3C                     END
      *
     C                     ELSE
     C                     ADD  WKSUR     HSU,DX
     C                     ENDIF
      *
     C                     XFOOTHSU       ABNNSU
     C                     MOVE WNOKN     ABNOKN
      *
%0003C                     ENDIF
      * ---------------------------------------------------
      * UPDATE ABAWP10
     C                     UPDATABAWP101
      *
     C                     ENDDO
      *
     C           XLVLO     ENDSR
      *********************************************************
      *  SET DELIVERY CODE FOR HONDA
      *********************************************************
     C           #HONDA    BEGSR
      *
      * SAVE ORIGINAL CONTENTS OF TOKU AND NONY FOR OUTPUT TO WF
     C                     MOVELAETOKU    SVTOKU  4
     C                     MOVEL'0000'    SVNONY  4
     C                     MOVEL'0000'    AENONY
      *
     C           AENKOJ    IFEQ *BLANK
     C                     MOVE '0'       AENKOJ
     C                     END
      * GET DELV#
     C                     MOVELAETOKU    $PLNT
     C                     MOVELAEFLR1    $SHCD
     C                     CALL 'UEXR09A'
     C                     PARM           $PLNT   3
     C                     PARM           $SHCD  10
     C                     PARM           $TOKU   4
     C                     PARM           $NONY   4
     C                     MOVEL$TOKU     AETOKU           NOW TOKU=CUST#
     C                     MOVEL$NONY     AENONY
     C                     MOVEL$NONY     SVNONY
     C                     MOVEL$NONY     WNONY
      *
      * IF DELIVERY CODE WAS NOT DETERMINED, WRITE TO WORKFILE FOR PRINTING
     C                     TESTN          SVNONY     41
     C           AENONY    IFEQ '0000'
     C           *IN41     ANDEQ*OFF
     C           AEFLR1    CHAINABAWP2H              61
     C           *IN61     IFEQ *ON
     C                     MOVELAEPRTR    W2PRTR
     C                     MOVELSVTOKU    W2TOKU
     C                     MOVELSVNONY    W2NONY
     C                     MOVELAEMHIN    W2MHIN
     C                     Z-ADDAEEQTY    W2EQTY
     C                     MOVELAEFLR1    W2SHCD
     C                     MOVELAESAD1    W2SAD1
     C                     MOVELAESAD2    W2SAD2
     C                     MOVELAECITY    W2CITY
     C                     MOVELAESTAT    W2STAT
     C                     MOVELAEZIPC    W2ZIPC
     C                     MOVELAECNTY    W2CNTY
     C                     MOVELAESNAM    W2SNAM
      *
TEMP C***        TEMP      IFEQ 'N'
     C                     WRITEABAWP2H1
TEMP C***                  ENDIF
      *
     C                     ENDIF
     C                     ENDIF
      *
     C           AEFLR2    IFNE *BLANK
     C                     MOVE AENONY    K@NONY
     C                     MOVE AETOKU    K@TOKU
     C           K#10      CHAINABAPP10              90
     C                     MOVELAEFLR2    A1RLNO
     C                     MOVE AENONY    A1NONY
     C                     MOVE AETOKU    A1CUST
     C                     Z-ADD*DATE     A1DATE
      *
TEMP C***        TEMP      IFEQ 'N'
     C   90                WRITEABAPP101
     C  N90                UPDATABAPP101
TEMP C***                  ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *********************************************************
      *  SET CUST / DELIV CODE
      *********************************************************
     C           #NONYC    BEGSR
      *
     C           AEPRTR    IFEQ 'TABC'
     C                     MOVE 3423      AETOKU
     C                     ELSE
     C                     MOVE 0323      AENONY
     C                     SELEC
     C           AENKOJ    WHEQ 'A'
     C                     MOVE 0541      AETOKU
     C           AENKOJ    WHEQ 'C'
     C                     MOVE 3411      AETOKU
     C                     ENDSL
     C                     ENDIF
      *
     C                     ENDSR
      *********************************************************
      *  RESET DAILY QTY FIELDS
      *********************************************************
     C           #RSET     BEGSR
      *
     C                     Z-ADDK@YM      @NYM
     C           KEY2      SETLLABAWP101
     C           *IN90     DOUEQ*ON
     C           KEY2X     READEABAWP101                 90
     C           *IN90     IFEQ *OFF
     C           ABDATE    IFGT K@YM
     C                     Z-ADD1         DX
     C                     ELSE
     C                     Z-ADDK@DD      DX
     C                     ENDIF
     C           DX        DO   31        XX      20
     C                     Z-ADD0         HSU,XX
     C                     ENDDO
      *
     C                     XFOOTHSU       ABNNSU
      *
     C                     UPDATABAWP101
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
