     C**                   MOVELD#4TR5    E8TKR5            LOCATION (STAIR)
     C**                   MOVELS@KAT3    E8KAT3            DIE NO.3
     C**                   MOVELS@KAT4    E8KAT4            DIE NO.4
     C                     MOVELS@LOC1    E8TKR1            LOCATION (FACTORY)
     C                     MOVELS@LOC2    E8TKR2            LOCATION (PASSAGE)
     C                     MOVELS@LOC3    E8TKR3            LOCATION (LINE)
     C                     MOVELS@LOC4    E8TKR4            LOCATION (STAIR)
     C                     MOVELS@LOC5    E8TKR5            LOCATION (STAIR)
     C                     Z-ADD1         E8KOSU            IN/OUT QUANTITY
     C                     MOVEL'O'       E8IOKB            IN/OUT FLG
     C                     MOVEL'H'       E8GSKB            GENERATION SOURCE
     C                     Z-ADDS@YMD     E8IOHZ            IN/OUT DATE
     C                     Z-ADDS@HMS     E8IOJK            IN/OUT TIME
     C                     MOVELP@TAC5    E8IOME            IN/OUT WORKER
     C                     MOVELD#1BAR    E8OREQ            OUT REQUESTER
     C                     MOVEL'OK'      E8HNTE            JUDGMENT
     C                     MOVEL*BLANK    E8EMSG            ERR MSG
I----C           S@MSG4    IFNE *BLANK
|    C                     MOVELS@MSG4    E8EMSG            ERR MSG
E----C                     ENDIF
     C           E8EMSG    IFEQ @ER,17
     C                     MOVEL'NG'      E8HNTE            JUDGMENT
     C                     END
     C                     MOVEL*BLANK    E8PBAR            PT BARCODE
     C                     MOVELD#5BAR    E8SBAR            S/OUT LABEL BARCODE
     C                     MOVELD#4BAR    E8LBAR            LOCATION BARCODE
     C                     MOVEL*BLANK    E8DBAR            DIE KANBAN BARCODE
     C*                    _____________
