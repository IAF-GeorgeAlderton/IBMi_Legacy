     C*                    ~~~~~~~~~~~~~
     C*==< ECSPP10 >==*
     C                     MOVELD#5KT1    K@KAT1            DIE#1
     C                     MOVELD#5KT2    K@KAT2                2
     C***                  MOVELD#5KT3    K@KAT3                3
     C***                  MOVELD#5KT4    K@KAT4                4
     C                     MOVELD#5KT4    K@KAT3                3
     C*                    MOVELS@KAT4    K@KAT4                4
     C*                    ____________
     C           K@CS10    CHAINECSPL10              96
     C*                    ~~~~~~~~~~~~
I----C           *IN96     IFEQ '1'
|    C           *IN96     OREQ '0'
|    C           E1SKJY    ANDEQ'D'
|    C                     CLEARECSPP101
|    C                     MOVELD#5KT1    E1KAT1            DIE#1
|    C                     MOVELD#5KT2    E1KAT2                2
|    C**                   MOVELD#5KT3    E1KAT3                3
|    C**                   MOVELD#5KT4    E1KAT4                4
|    C**                   MOVELD#4TR1    E1LOC1            LOCATION 1
|    C**                   MOVELD#4TR2    E1LOC2                     2
|    C**                   MOVELD#4TR3    E1LOC3                     3
|    C**                   MOVELD#4TR4    E1LOC4                     4
|    C                     MOVELS@KAT3    E1KAT3                3
|    C                     MOVELS@KAT4    E1KAT4                4
|    C                     MOVELS@LOC1    E1LOC1            LOCATION 1
|    C                     MOVELS@LOC2    E1LOC2                     2
|    C                     MOVELS@LOC3    E1LOC3                     3
|    C                     MOVELS@LOC4    E1LOC4                     4
E----C                     ENDIF
     C*
     C                     Z-ADDS@YMD     E1KDAT            UPDATE DATE
