|S---C                     SELEC
|+---C           *IN01     WHEQ '1'
||   C                     MOVEL'EXIT'    W@DSP9
|+---C           *IN07     WHEQ '1'
||I--C           *IN81     IFEQ '1'
|||  C                     MOVEL'EXIT'    W@DSP9
||E--C                     ENDIF
|E---C                     ENDSL
E----C                     ENDDO
