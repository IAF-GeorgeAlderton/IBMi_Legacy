     C                     Z-ADD0111      E8BMON            FACTORY CODE
     C                     MOVELD#2KIB    E8KIBN            MACHINE NO
     C                     MOVELD#3RSC    E8RIYU            IN/OUT REASON
     C                     MOVELD#5KT1    E8KAT1            DIE NO.1
     C                     MOVELD#5KT2    E8KAT2            DIE NO.2
     C                     MOVELD#5KT3    E8KAT3            DIE NO.3
     C                     MOVELD#5KT4    E8KAT4            DIE NO.4
