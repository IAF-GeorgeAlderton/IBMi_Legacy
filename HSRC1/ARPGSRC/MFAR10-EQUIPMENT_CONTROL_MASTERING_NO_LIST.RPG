     H            Y.
     F** MFAR10 ******************************
     F* EQUIPMENT CONTROL MASTERING NO. LIST *
     F*      A-IDOTA       1989.11.13        *
     F**************************** MFAR10 ****
     FMFAPL23 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER                        UC
     E                    KBN         5  6               NO.
     E                    KOT         5  3               PROCESS
     E                    KIK         5 10               MACHINE FORM
      * NO. *
     I            DS
     I                                        1   6 KIBN
     I                                        1   1 KIB1
     I                                        2   2 HI1
     I                                        3   4 KIB2
     I                                        5   5 HI2
     I                                        6   6 KIB3
      * DELETION DATE *
     I            DS
     I                                        1   80M@SKHZ
     I                                        1   40M@SKYY
     I                                        5   60M@SKMM
     I                                        7   80M@SKDD
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
      * TIME *
     I            DS
     I                                        1   60WTIME
     I                                        1   20HH
     I                                        3   40SS
      * COST CENTER *
     I            DS
     I                                        1   6 COST
     I                                        1   2 M@COS1
     I                                        3   4 M@COS2
     I                                        5   6 M@COS3
     I            DS
     I                                        1   6 K1
     I                                        1   2 KY1
     I                                        3   4 KY2
     I                                        5   6 KY3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     C           *ENTRY    PLIST
     C                     PARM           PKJ     4
     C                     MOVE PKJ       KJY     40
     C                     MOVE PKJ       KKOJ    40
      * KEY *
     C           KEY       KLIST
     C                     KFLD           KJY
      *****************
      *  LIST MAKING  *
      *****************
     C                     Z-ADD0         KT      20
     C                     MOVE *BLANK    KBN
     C                     MOVE *BLANK    KOT
     C                     MOVE *BLANK    KIK
     C                     SETOF                     1050
     C           KJY       IFNE 9999
     C           KEY       SETLLMFAPL231
     C                     END
     C                     DO   *HIVAL
     C           LOP10     TAG
     C           KJY       IFEQ 9999
     C                     READ MFAPL231                 10
     C                     ELSE
     C           KEY       READEMFAPL231                 10
     C                     END
     C           *IN10     IFEQ '0'
     C           M@SKJY    IFEQ 'D'
     C           M@SKHZ    ANDLE*DATE
     C                     GOTO LOP10
     C                     END
     C           M@JTKB    IFNE '1'
     C                     GOTO LOP10
     C                     END
     C*** WHEN THERE IS A SPECIFIED KEY  PRINT FILE OPEN ***
     C           *IN11     IFEQ '0'
     C                     OPEN QPRINT
     C                     TIME           WTIME   60
     C                     EXCPTMI
     C                     SETON                     11
     C                     END
     C           KKOJ      IFNE M@KOJY
     C                     MOVE M@KOJY    KKOJ    40
      * WHEN THE COST CENTER CHANGES
     C           KT        IFNE 0
     C                     EXCPTME
     C                     END
     C                     EXCPTSP
     C                     SETOF                     50
     C                     Z-ADD0         KT
     C                     MOVE *BLANK    KBN
     C                     MOVE *BLANK    KOT
     C                     MOVE *BLANK    KIK
     C                     MOVE COST      K1      6
     C* FACTORY NAME INPUT
     C           KKOJ      CHAINFGBPL011             70
     C           *IN,70    IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,70
     C                     END
     C*
     C  N70                MOVELB2SMEI    KJYUM  12
     C                     EXCPTMI
     C                     ELSE
      * WHEN THE COST CENTER CHANGES AS THE FACTORY'S WITHOUT CHANGING
     C           K1        IFNE COST
     C           KT        IFNE 0
     C                     EXCPTME
     C                     END
     C                     EXCPTSP
     C                     SETOF                     50
     C                     Z-ADD0         KT
     C                     MOVE *BLANK    KBN
     C                     MOVE *BLANK    KOT
     C                     MOVE *BLANK    KIK
     C                     MOVE COST      K1      6
     C                     END
     C                     END
      * NO. *
     C                     ADD  1         KT
     C                     MOVE *BLANK    KIBN
     C                     MOVELM@KBN1    KIB1
     C                     MOVE M@KBN1    KIB2
     C                     MOVE M@KBN2    KIB3
     C                     MOVE '-'       HI1
     C           KIB3      IFNE *BLANK
     C                     MOVE '-'       HI2
     C                     END
     C                     MOVE KIBN      KBN,KT
     C                     MOVE M@KOTE    KOT,KT
      * NO. *
     C                     MOVE M@KEIS    KIK,KT
      * CHECK *
     C           KBN,5     IFNE *BLANK
     C                     EXCPTME
     C                     SETON                     50
     C                     MOVE *BLANK    KBN
     C                     MOVE *BLANK    KOT
     C                     MOVE *BLANK    KIK
     C                     Z-ADD0         KT
     C                     END
      * OF *
     C           *INOF     IFEQ '1'
     C                     EXCPTMI
     C                     SETOF                     OF50
     C                     END
      *
     C                     END
     C  N10                END
      * END PROCESSING *
     C           *IN11     IFEQ '1'
     C           KBN,1     IFNE *BLANK
     C                     EXCPTME
     C                     END
     C                     CLOSEQPRINT
     C                     END
     C                     SETON                     LR
     C                     RETRN
     O* OUTPUT FORMAT
     OQPRINT  E  102           MI
     O                         #PGM       8
     O                                   16 '(MFAC04)'
     O                                  130 '...........'
     O        E  1             MI
     O                                   14 'FACTORY NAME'
     O                         KKOJ      20
     O                         KJYUM     33
     O                                   98 'TIME'
     O                         WTIME    107 '  :  :  '
     O                                  130 '.         .'
     O        E  1             MI
     O                                   98 'DATE'
     O                         UDATE Y  107
     O                                  130 '.         .'
     O        E  2             MI
     O                                  130 '.         .'
     O*
     O                                   19 'THE CENTRAL ORDER'
     O                                   27 'OF COST'
     O*
     O                                   40 '***'
     O                                   59 'EQUIPMENT CONTROL'
     O                                   69 'MASTERING'
     O                                   80 'NO. LIST'
     O                                   85 '***'
     O                                  103 'PAGE'
     O                         PAGE  Z  107
     O                                  130 '...........'
     O        E  2             MI
     O                                   12 'COST CENTER'
     O                                   26 'NO.  COURSE'
     O                                   32 'FORM'
     O                                   50 'NO.  COURSE'
     O                                   56 'FORM'
     O                                   74 'NO.  COURSE'
     O                                   80 'FORM'
     O                                   98 'NO.  COURSE'
     O                                  104 'FORM'
     O                                  122 'NO.  COURSE'
     O                                  128 'FORM'
     O        E  1             ME
     O                N50      KY1        5
     O                N50                 6 '-'
     O                N50      KY2        8
     O                N50                 9 '-'
     O                N50      KY3       11
     O                         KBN,1     19
     O                         KOT,1     24
     O                         KIK,1     36
     O                         KBN,2     43
     O                         KOT,2     48
     O                         KIK,2     60
     O                         KBN,3     67
     O                         KOT,3     72
     O                         KIK,3     84
     O                         KBN,4     91
     O                         KOT,4     96
     O                         KIK,4    108
     O                         KBN,5    115
     O                         KOT,5    120
     O                         KIK,5    132
      * SPACE *
     O        E  1             SP
     O                                    1 ' '
