     C                     SETON                     6199
     C                     MOVE MSG,2     D@MSG
     C                     ENDIF
     C                     ENDIF
     C           D@YYMM    IFEQ *ZERO
     C  N99                MOVE MSG,1     D@MSG
     C                     SETON                     6299
     C                     ENDIF
      *
     C                     Z-ADDD@YYMM    W@YM
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C  N99                MOVE MSG,1     D@MSG
     C                     SETON                     6299
     C                     ENDIF
      *
     C                     ENDSR
