     C           F2SLSP    IFNE @@SLPS
     C           @@SLPS    IFNE *BLANK
     C   OF                EXCPT@HED
     C                     EXCPT@CTOT
     C   OF                EXCPT@HED
     C                     EXCPT@STOT
     C                     Z-ADD*ZERO     @@CAMT 112
     C                     Z-ADD*ZERO     @@CTOT  90
     C                     Z-ADD*ZERO     @@SAMT 112
     C                     Z-ADD*ZERO     @@STOT  90
     C                     ENDIF
      *
     C                     EXSR #HED
     C                     MOVE F2SLSP    @@SLPS
     C                     ELSE
     C           @@TOKU    IFNE *ZERO
     C           @@TOKU    ANDNEF2TOKU
     C   OF                EXCPT@HED
     C                     EXCPT@CTOT
     C                     Z-ADD*ZERO     @@CAMT 112
     C                     Z-ADD*ZERO     @@CTOT  90
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADDF2TOKU    @@TOKU
      *
     C                     MOVE *BLANK    @@DSC  15
     C           F2CLAS    CHAINFBCPP25              95
     C           *IN95     IFEQ *OFF
     C                     MOVELF5DESC    @@DSC
     C                     ENDIF
      *
     C                     EXSR #ACT
     C                     EXSR #DUP
     C                     EXCPT@DTL
     C                     ADD  1         @@CNT
     C                     ADD  @@ACT     @@GTOT
     C                     ADD  @@AMT     @@GAMT 132
     C                     ADD  @@AMT     @@CAMT 112
     C                     ADD  @@ACT     @@CTOT  90
     C                     ADD  @@AMT     @@SAMT 112
     C                     ADD  @@ACT     @@STOT  90
      *
     C           F2RMK1    IFNE *BLANK
     C           F2RMK2    ORNE *BLANK
     C   OF                EXCPT@HED
     C                     EXCPT@RMK
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           @@CNT     IFNE *ZERO
     C   OF                EXCPT@HED
     C                     EXCPT@CTOT
     C   OF                EXCPT@HED
     C                     EXCPT@STOT
     C                     EXCPT@GTOT
     C                     ENDIF
      *
     C                     ENDSR
