     C*------------------------------------*
     C*  ..構成品かんばん切替マスター..  *
     C*------------------------------------*
     C                     SETOF                     10
     C           KEY1      CHAINAKEPL011             10
     C           *IN10     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C                     Z-ADD1         A       20
     C           1         DO   15        A
     C           SKB,A     IFEQ '3'
     C           SKB,A     OREQ 'P'
     C           SKB,A     OREQ 'Q'
      *
     C                     MOVE SDH,A     WDHIN
     C                     MOVE SKO,A     WKOTI   3
     C                     Z-ADDSBM,A     WBMON   40
     C                     MOVE SBN,A     WTKRO
     C                     MOVE SKB,A     WKDAI   1
      *
     C*--------------------------------*
     C*  ..構成品番　工程マスター..  *
     C*--------------------------------*
     C                     SETOF                     10
     C           KEY2      SETLLAKDPL021
     C                     DO   *HIVAL
     C                     SETOF                     11
     C           KEY2      READEAKDPL021                 11
     C           *IN11     IFEQ '0'
     C           M2JHIN    IFNE WKHIN
     C                     SETON                     10
     C                     END
     C                     END
     C  N11                END
      *
     C           *IN10     IFEQ '0'
      *
     C*------------------------------------------*
     C*  ..構成品番工程　所番地登録マスター..  *
     C*------------------------------------------*
     C           KEY3      SETLLAKHPL061
     C                     DO   *HIVAL
     C                     SETOF                     11
     C           KEY3      READEAKHPL061                 11
     C           *IN11     IFEQ '0'
     C           M5SKJY    IFEQ 'D'
     C           M5SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     MOVE 'D'       M5SKJY
     C                     Z-ADD*DATE     M5SKHZ
     C                     Z-ADD*DATE     M5KOHZ
     C                     TIME           M5TIME
     C                     MOVELPUS       M5KOME
     C                     UPDATAKHPL061
      *
     C*------------------------------*
     C*  ..工程内所番地マスター..  *
     C*------------------------------*
     C           KEY4      SETGTAAJPL111
     C                     SETOF                     12
     C           KEY4      REDPEAAJPL111                 12
     C           *IN12     IFEQ '0'
     C                     MOVE *BLANK    CJHIN1
     C                     MOVE *BLANK    CJHIN2
     C                     MOVE *BLANK    CJHIN3
     C                     Z-ADD0         CJSYUY
     C                     MOVE *BLANK    CJMBN1
     C                     MOVE *BLANK    CJMBN2
     C                     MOVE *BLANK    CJMBN3
     C                     MOVE *BLANK    CJMBN4
     C                     Z-ADD0         CJSLOT
     C                     Z-ADD*DATE     CJAKHZ
     C                     UPDATAAJPL111
     C                     END
      *
     C           M5KDAI    IFEQ '3'
     C                     EXSR SUBR3
     C                     END
      *
     C           M5KDAI    IFEQ 'P'
     C                     EXSR SUBRP
     C                     END
      *
     C           M5KDAI    IFEQ 'Q'
     C                     EXSR SUBRQ
     C                     END
      *
     C                     END
     C                     END
     C  N11                END
      *
     C                     END
     C                     END
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
