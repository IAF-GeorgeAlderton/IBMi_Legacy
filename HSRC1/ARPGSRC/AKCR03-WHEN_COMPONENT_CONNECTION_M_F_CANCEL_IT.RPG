      *
     C           *IN12     IFEQ '0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     MOVE 'D'       L1SKJY
     C                     Z-ADD*DATE     L1SKHZ
     C                     Z-ADD*DATE     L1KOHZ
     C                     TIME           L1TIME
     C                     MOVE PUS       L1KOME
     C                     MOVE '0'       L1DTKO
     C                     UPDATAKBPL011
      *
     C                     END
     C                     END
     C  N12                END
