     C****************************************************************
     C*  START PROGRAM  <AJSRC1>                                     *
     C****************************************************************
     C                     MOVE *BLANK    CD
     C                     MOVE *BLANK    NM
      *
     C                     Z-ADD1         X       20
     C                     SETOF                     50
     C           *LOVAL    SETLLAJSPLCD1
B001 C                     DO   30        X
     C                     READ AJSPLCD1                 50
      *
     C           *IN50     IFEQ '1'
     C                     GOTO ESC
     C                     ENDIF
     C           JASKJY    IFEQ 'D'
     C           SKHZ      ANDLE*DATE
     C                     GOTO ESC
     C                     ENDIF
      *
     C                     MOVE JAWKCD    CD,X
     C                     MOVE JAWKNM    NM,X
     C                     MOVE JAWKCD    KCOD    6
     C           ESC       TAG
     C                     ENDDO
     C                     EXSR SAKRED
      *
      *--------------------*
      *  DISPLAY 1 SCREEN  *
      *--------------------*
     C           STP1      TAG
     C                     EXFMTAJSPWC11
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
      *
     C           *IN60     IFEQ '1'
     C           INV       IFEQ '*'
     C                     EXSR UPSUB
     C                     ENDIF
     C                     ENDIF
     C           *IN65     IFEQ '1'
     C                     EXSR DWNSUB
     C                     ENDIF
     C                     GOTO STP1
      ************
      *  SAKRED  *
      ************
     C           SAKRED    BEGSR
      *
     C                     MOVE *BLANK    INV     1
     C                     SETOF                     25
     C                     DO   *HIVAL
     C                     READ AJSPLCD1                 25
     C           *IN25     IFEQ '1'
     C                     ENDIF
     C           JASKJY    IFEQ 'D'
     C           SKHZ      ANDLE*DATE
     C                     GOTO EXT
     C                     ENDIF
      *
     C                     MOVE '*'       INV
     C                     SETON                     25
     C           EXT       TAG
     C  N25                ENDDO
      *
     C                     ENDSR
      ***********
      *  UPSUB  *
      ***********
     C           UPSUB     BEGSR
     C                     MOVE *BLANK    CD
     C                     MOVE *BLANK    NM
      *
     C                     Z-ADD1         X       20
     C                     SETOF                     50
     C           KCOD      SETLLAJSPLCD1
B001 C                     DO   30        X
     C                     READ AJSPLCD1                 50
      *
     C           *IN50     IFEQ '1'
     C                     GOTO ESC2
     C                     ENDIF
     C           JASKJY    IFEQ 'D'
     C           SKHZ      ANDLE*DATE
     C                     GOTO ESC2
     C                     ENDIF
      *
     C                     MOVE JAWKCD    CD,X
     C                     MOVE JAWKNM    NM,X
     C           X         IFEQ 1
     C                     MOVE JAWKCD    KCD1    6
     C                     ENDIF
     C           X         IFEQ 16
     C                     MOVE JAWKCD    KCD2    6
     C                     ENDIF
     C           ESC2      TAG
     C                     ENDDO
