     C           *ENTRY    PLIST
     C                     PARM           PBMN    4
     C                     PARM           PDAT    6
     C                     PARM           PBIN    2
     C                     PARM           PSBN    1
     C                     PARM           PTSR    1
     C                     PARM           PFIL    9
     C                     MOVE PBMN      WBMON
     C                     MOVE PBMN      @BMN
      *
     C*------------------------------*
     C*  ..時刻別計算便マスター..  *
     C*------------------------------*
     C                     SETOF                     10
     C           WBMON     CHAINAAIPL111             10
     C           *IN10     IFEQ '1'
     C                     SETON                     U2LR
     C                     RETRN
     C                     END
      *
     C                     MOVE PDAT      @YMD
     C                     MOVE PBIN      @BIN
     C                     MOVE PBIN      WBIN
      *
     C*--------------------------*
     C*  ..当日処理終了か？..  *
     C*--------------------------*
     C                     SETOF                     90
     C           PTSR      IFEQ '*'
     C                     SETON                     90
     C                     END
      *
     C*--------------------*
     C*  ..最終便か？..  *
     C*--------------------*
     C                     SETOF                     91
     C           PSBN      IFEQ '*'
     C                     SETON                     91
     C                     END
      *
     C           STP1      TAG
     C                     EXFMTAFAPW571
     C                     SETOF                     5099
     C                     MOVE *BLANK    MSG1
     C                     MOVE *BLANK    MSG2
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     U2LR
     C                     RETRN
     C                     END
      *
     C*----------------------*
     C*  ..便のチェック..  *
     C*----------------------*
     C           @BIN      IFGT CDCIBI
     C                     SETON                     99
     C                     MOVE ER1,5     MSG1
     C                     GOTO STP1
     C                     END
      *
     C                     SETOF                     10
     C                     Z-ADD1         A       20
     C           @BIN      LOKUPCDBI,A                   10
     C           *IN10     IFEQ '0'
     C                     SETON                     99
     C                     MOVE ER1,6     MSG1
     C                     GOTO STP1
     C                     END
      *
   #@C           CDTOHZ    IFLT *DATE
      *
     C*------------------------------------------*
     C*  ..準備されているか？　の　チェック..  *
     C*------------------------------------------*
     C           CDDT,A    IFEQ '*'
     C           CDOK,A    ANDEQ'*'
     C                     SETON                     99
     C                     MOVE ER1,3     MSG1
     C                     GOTO STP1
     C                     END
     C                     ELSE
      *
     C*--------------------------------------------------------*
     C*  ..前回の便がＦＤ処理されているか？　の　チェック..  *
     C*--------------------------------------------------------*
     C           @BIN      IFGT 01
     C           @BIN      SUB  1         WSBIN   20
      *
     C                     SETOF                     10
     C                     Z-ADD1         B       20
     C           WSBIN     LOKUPCDBI,B                   10
      *
     C           CDDT,B    IFEQ '*'
     C           CDOK,B    ANDEQ*BLANK
     C                     SETON                     99
     C                     MOVE ER1,2     WMSG
     C                     MOVE WSBIN     WER
     C                     MOVE WMSG      MSG1
     C                     MOVE ER2,2     MSG2
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C*------------------------------------------*
     C*  ..準備されているか？　の　チェック..  *
     C*------------------------------------------*
     C           CDDT,A    IFEQ *BLANK
     C           CDOK,A    ANDEQ*BLANK
     C                     SETON                     99
     C                     MOVE ER1,3     MSG1
     C                     GOTO STP1
     C                     END
      *
     C*----------------------------------*
     C*  ..準備中か？　の　チェック..  *
     C*----------------------------------*
     C           CDDT,A    IFEQ 'H'
     C           CDOK,A    ANDEQ*BLANK
     C                     SETON                     99
     C                     MOVE ER1,4     MSG1
     C                     GOTO STP1
     C                     END
      *
     C*--------------------------------------------------*
     C*  ..既にＦＤ処理が処理済みか？　の　チェック..  *
     C*--------------------------------------------------*
     C           CDDT,A    IFEQ '*'
     C           CDOK,A    ANDEQ'*'
     C                     SETON                     5099
     C                     MOVE ER1,1     MSG1
     C                     MOVE ER2,1     MSG2
     C                     END
     C                     END
      *
     C                     MOVE @BIN      PBIN
     C                     MOVE 'AAA'     WFKBN
     C                     MOVE WFILE     PFIL
      *
     C           *IN50     IFEQ '1'
     C           *INKL     IFEQ '0'
     C                     GOTO STP1
     C                     END
     C                     ELSE
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
