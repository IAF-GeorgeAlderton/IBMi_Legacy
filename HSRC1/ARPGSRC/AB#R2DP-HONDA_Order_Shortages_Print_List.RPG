     H            Y.
      ** AB#R2DP  ******************************************
      *  HONDA - ORDER SHORTAGES - PRINT LIST              *
      * LEC   2021/08/05 CREATE                            *
      *-------------------------------------------------   *
JW1   * JW    2024.11.20 ADD SQ#                           *
      ******************************************************
     FAB#WPHSSUF  E           K        DISK
     FALBPL30 IF  E           K        DISK
     FQPRINT  O   F     153     OF     PRINTER
      *
     E                    TBL     1   1 50
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
      *
      * PART NUMBER
     I            DS
     I                                        1  12 W1SHN
     I                                        1   5 W1SHN1
     I                                        6  10 W1SHN2
      * EDITED PART NUMBER
     I            DS
     I                                        1  12 PART#
     I                                        1   5 SHN1
     I                                        6   6 DASH
     I                                        7  11 SHN2
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  14 SDATE
     I                                        1   6 STIME
      *
     C           *ENTRY    PLIST
     C                     PARM           PRT     1
      *
     C                     MOVE *BLANK    PRT
      *
     C                     DO   *HIVAL
      *
     C                     READ AB#WPHSS                 99
     C   99                LEAVE
      *
     C           W1FLDA    IFEQ 'PRINTED'
     C                     ITER
     C                     ELSE
      *
     C           W@1STP    IFEQ *ON
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     MOVEL*OFF      W@1STP
     C                     ENDIF
      *
     C                     MOVELW1SHID    SHIPDT  80
      *
     C                     MOVELW1SHN1    SHN1
     C                     MOVELW1SHN2    SHN2
      *
     C                     MOVELW1WKCD    K@TMCD  60
     C           K@TMCD    CHAINALBPL30              97
     C  N97                MOVELALWKNM    P@WKNM 15
     C   97                MOVEL*BLANK    P@WKNM
      *
JW1  C                     ADD  1         SEQ#
      *
     C                     EXCPT@DTL
      *
     C                     MOVEL'PRINTED' W1FLDA
     C           SDATE     CAT  STIME:1   W1FLDB
     C                     UPDATAB#WPHS1
     C                     MOVE 'Y'       PRT
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
      * INITIAL SET
      *-----------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     MOVEL'-'       DASH
     C                     TIME           WSDT
     C                     Z-ADDWSDT      WTIME
     C                     MOVEL*ON       W@1STP  1
JW1  C                     Z-ADD0         SEQ#    40
      *
     C                     ENDSR
      *
      *-----------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM      10
     O                         TBL,1     72
     O                                   87 'DATE'
     O                         WSSDATY   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O        E   02           @HED
     O                                   87 'TIME'
     O                         WSSTM6    98 '  :  :  '
     O        E   03           @HED
JW1  O                                    4 'SEQ#'
     O                                   17 'SHIP_DATE'
     O                                   26 'CUST_CD'
     O                                   34 'DELV_CD'
     O                                   40 'DOCK'
     O                                   49 'ORDER#'
     O                                   61 'BIN#'
     O                                   75 'PART_NUMBER'
     O                                   85 'PART_ID'
     O                                   92 'QPC'
     O                                  110 'SERIAL_BARCODE'
     O                                  128 'TEAM_MEMBER'
     O                                  148 'PLANT_NAME'
     O        E 1              @DTL
JW1  O                         SEQ#  Z    4
     O                         SHIPDTY   17
     O                         W1TOKU    24
     O                         W1NONY    33
     O                         W1NUKE    39
     O                         W1ORD#    55
     O                         W1NOBN    60
     O                         PART#     76
     O                         W1ZETI    84
     O                         W1QPC Z   92
     O                         W1SERL   114
     O                         P@WKNM   132
     O                         W1SMEI   153
** TBL
