      *
     C           CQGYOM    IFEQ '23'
     C                     MOVE CQKOMM    WZAMM
     C                     MOVE CQKODD    WZADD
     C                     Z-ADDCQHAKO    WZMIS
     C                     MOVE CQKOME    #KCODE
     C                     SETON                     66
     C                     END
      *
     C                     END
     C                     END
     C  N59N66             END
+tchk *
+tchkC           KEY1      SETGTAU#PL141
+tchkC                     SETOF                     6659
+tchkC                     DO   *HIVAL
+tchkC           KEY1      REDPEAU#PL141                 59
+tchkC           *IN59     IFEQ '0'
+tchkC           CQSKJY    ANDNE'D'
+tchkC           CQSKHZ    IFGE UYMD1
+tchkC           CQSKHZ    ANDLEUYMD2
+tchk *
+tchkC           CQGYOM    IFEQ '23'
+tchkC                     MOVE CQKOMM    WZAMM
+tchkC                     MOVE CQKODD    WZADD
+tchkC                     Z-ADDCQHAKO    WZMIS
+tchkC                     MOVE CQKOME    #KCODE
+tchkC                     SETON                     66
+tchkC                     END
+tchk *
+tchkC                     END
+tchkC                     END
+tchkC  N59N66             END
