     C           #WP31     BEGSR                           *
     C******************************************************
     C*          K#31      CHAINBTAWP31              93
     C*          *IN93     IFEQ *OFF
     C*                    Z-ADD*DATE     UPDATE
     C*                    MOVE *BLANK    UPID
     C*                    Z-ADDAAA       AA
     C*                    Z-ADDFFF       FF
     C*                    Z-ADDJJJ       JJ
     C*                    Z-ADDBBB       BB
     C*                    Z-ADDEEE       EE
     C*                    Z-ADD*ZERO     DD
     C*                    UPDATBTAWP311
     C*                    ELSE
     C*                    CLEARBTAWP311
     C*                    Z-ADD*DATE     UPDATE
     C*                    MOVE *BLANK    UPID
     C*                    Z-ADDAAA       AA
     C*                    Z-ADDFFF       FF
     C*                    Z-ADDJJJ       JJ
     C*                    Z-ADDBBB       BB
     C*                    Z-ADDEEE       EE
