     C                     ITER
     C                     ELSE
     C                     ADD  1         L
     C                     MOVE EKSERL    LBL,L
     C                     ENDIF
      *
     C                     ADD  1         SCAN
     C                     ENDIF
     C                     ENDDO
      *
     C           SCAN      IFEQ *ZERO
     C           K#12      CHAINAB#PL12              71
     C           *IN71     IFEQ *OFF
     C                     MOVELBAINVN    K@ORDN    P
     C           K#70      SETLLAB#PL7A
     C           *IN70     DOUEQ*ON
     C           K#70      READEAB#PL7A                  70
