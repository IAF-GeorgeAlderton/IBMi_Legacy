     C*                    MOVELUS        UPPSN
     C*                    MOVELBNT1      LOC1
     C*                    MOVELBNT2      LOC2
     C*                    MOVELBNT3      LOC3
     C*                    MOVELBNT4      LOC4
     C*                    MOVELHIN1      PART1
     C*                    MOVELHIN2      PART2
     C*                    MOVELHIN3      PART3
     C*                    WRITEBTAWP311
     C*                    ENDIF
