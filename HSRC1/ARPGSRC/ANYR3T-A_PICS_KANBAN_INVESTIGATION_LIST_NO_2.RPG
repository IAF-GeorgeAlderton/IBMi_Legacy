     C                     Z-ADD*ZERO     SCAN
     C                     MOVE SKBIN     @@BIN   2
     C                     MOVE KANR      @B2     2
     C                     MOVELORDN      K@ORDN    P
     C           K#70      SETLLAB#PL7A
     C           *IN70     DOUEQ*ON
     C           K#70      READEAB#PL7A                  70
     C           *IN70     IFEQ *OFF
     C           EKSKJY    ANDEQ*BLANK
     C           EKDEYY    ANDNE*ZERO
     C           @B2       IFNE *BLANK
     C           EKNOBN    ANDNE@B2
