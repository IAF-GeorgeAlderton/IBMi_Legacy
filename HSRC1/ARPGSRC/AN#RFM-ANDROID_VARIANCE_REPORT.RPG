     H            Y.
     F** AN#RFM ********************************************
     F*  ANDROID VARIANCE REPORT(NIRVANA)                  *
     F*                                                    *
     F*  *IN89=1 NOT WORKING DAY                           *
     F*  *IN91=1 NOT EXIST ABRAP01(EDI KEY DATA)           *
     F*  *IN92=1 NOT EXIST ABR2L02(ANDROID DATA)           *
     F*  *IN96=1 NOT EXIST AB#PL15(OPRDER DATA)            *
     F*                                                    *
     F* TCHK1 07/13/06 CREATE(COPY FROM AB#RFM)            *
     F******************************************************
     FABRAP01 IF  E           K        DISK
     FABR2L02 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FAB#PL15 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     FQPRINT2 O   F     132     OV     PRINTER
     E****************************************************
     I* RELEASED DATE(PARAMETER)
     I            DS
     I                                        1   8 WRDATE
     I                                        1   80WRDAT
     I                                        1   40WRYYYY
     I                                        5   60WRMMMM
     I                                        7   80WRDDDD
     I* SHIPPING DATE(PARAMETER)
     I            DS
     I                                        1   8 WSDATE
     I                                        1   80WSDAT
     I                                        1   40WSYYYY
     I                                        5   60WSMMMM
     I                                        7   80WSDDDD
     I* TIME
     I            DS
     I                                        1  120WTMDT
     I                                        1   60WTIME
     I                                        7  120WDATE
     I* PART NUMBER(INTERNAL PART=NO BLANKS)
     I            DS
     I                                        1  12 @SHIN
     I                                        1   5 WHIN1
     I                                        6  10 WHIN2
     I                                       11  12 WHIN3
     I* PART NUMBER(USER PART)
     I            DS
     I                                        1  20 WMHIN
     I                                        1   5 WMHN1
     I                                        6  10 WMHN2
     I                                       11  15 WMHN3
     I                                       16  20 WMHN4
     I* INVOICE NUMBER(OUT FILE)
     I            DS
     I                                        1   6 WINV#
     I                                        1   3 WINV1
     I                                        4   60WINV2
     I            DS
     I                                        1   80XXYMD
     I                                        1   40XXYY
     I                                        5   60XXMM
     I                                        7   80XXDD
     I            DS
     I                                        1   80F8KYMD
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     C***********************************************************
     C           *ENTRY    PLIST
     C                     PARM           PRYYYY  40
     C                     PARM           PRMMMM  20
     C                     PARM           PRDDDD  20
     C                     PARM           PSYYYY  40
     C                     PARM           PSMMMM  20
     C                     PARM           PSDDDD  20
     C                     PARM           PSIRE   4
     C* ABR2L02
     C           KEY2      KLIST
     C                     KFLD           K#PLAN  5        PLANT + A
     C                     KFLD           K#DOCK  4        DOCK
     C                     KFLD           K21              INTERNAL PART
     C                     KFLD           CFSIDT           SCHEDULE ISSUE DATE
     C                     KFLD           CFPOR#           ORDER #
     C                     KFLD           CFREF#           REFERENCE #
     C                     KFLD           K22              SHIP DATE
     C* AB#PL15
     C           KEY6      KLIST
     C                     KFLD           WTOKU            BATOKU
     C                     KFLD           WNONY              NONY
     C                     KFLD           WNKOJ              NKOJ
     C                     KFLD           WNUKE            BANUKE
     C                     KFLD           WMHN1              MHN1
     C                     KFLD           WMHN2              MHN2
     C                     KFLD           WMHN3            BAMHN3
     C                     KFLD           WMHN4              MHN4
     C                     KFLD           WODRN              ODRN
     C                     KFLD           WSYYYY           BANOYY
     C                     KFLD           WSMMMM             NOMM
     C                     KFLD           WSDDDD             NODD
     C           K#AB      KLIST
     C                     KFLD           WTOKU            BATOKU
     C                     KFLD           WNONY              NONY
     C                     KFLD           WNKOJ              NKOJ
     C                     KFLD           WNUKE            BANUKE
     C                     KFLD           WMHN1              MHN1
     C                     KFLD           WMHN2              MHN2
     C                     KFLD           WMHN3            BAMHN3
     C                     KFLD           WMHN4              MHN4
     C                     KFLD           WODRN              ODRN
     C                     KFLD           @@YYYY  40       BANOYY
     C                     KFLD           @@MMMM  20         NOMM
     C                     KFLD           @@DDDD  20         NODD
     C           K#ABX     KLIST
     C                     KFLD           WTOKU            BATOKU
     C                     KFLD           WNONY              NONY
     C                     KFLD           WNKOJ              NKOJ
     C                     KFLD           WNUKE            BANUKE
     C                     KFLD           WMHN1              MHN1
     C                     KFLD           WMHN2              MHN2
     C                     KFLD           WMHN3            BAMHN3
     C                     KFLD           WMHN4              MHN4
     C                     KFLD           WODRN              ODRN
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C*
     C***********************************************************
     C* MAIN CONTROL
     C***********************************************************
     C                     EXSR @INZ
     C                     EXSR @MAIN
     C                     EXSR @END
     C***********************************************************
     C* INITIALIZE WORK AREA
     C***********************************************************
     C           @INZ      BEGSR
     C*
     C                     TIME           WTMDT
     C*
     C                     Z-ADD*ZERO     WQTY2  100
     C                     Z-ADD*ZERO     WQTY3  100
     C                     Z-ADD*ZERO     WSUMQ  100
     C                     SETON                     OF
     C*
     C                     Z-ADDPRYYYY    WRYYYY
     C                     Z-ADDPRMMMM    WRMMMM
     C                     Z-ADDPRDDDD    WRDDDD
     C                     Z-ADDPSYYYY    WSYYYY
     C                     Z-ADDPSMMMM    WSMMMM
     C                     Z-ADDPSDDDD    WSDDDD
     C*
     C* NOT WORKING DAY?
     C           WRDATE    IFNE WSDATE
     C                     SETON                     89
     C                     END
      *
     C                     Z-ADD*DATE     K@YMD
     C                     Z-ADD1         @@CNT   30
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     ADD  1         @@CNT
     C           @@CNT     IFEQ 5
     C                     Z-ADDF8KYMD    W@LMT   80
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C*
     C                     ENDSR
     C***********************************************************
     C* MAIN
     C***********************************************************
     C           @MAIN     BEGSR
     C*
     C* READ EDI KEY FILE
     C           *LOVAL    SETLLABRAP01R
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ABRAP01R                 91
     C   91                LEAVE
     C           CFDLCD    IFNE *BLANK
     C                     ITER
     C                     END
     C           CFSIDT    IFLT W@LMT
     C                     ITER
     C                     END
      *
     C                     MOVELCFPART    K21    20
     C                     Z-ADDWRDAT     K22     80
     C                     MOVEL'A'       K#PLAN
     C                     MOVE CFDOCK    K#PLAN
     C                     MOVELCFDOC2    K#DOCK
     C           KEY2      CHAINABR2P011             92
     C           *IN92     IFEQ *ON
     C                     ITER
     C                     END
     C*
     C*
     C                     SELEC
     C           K#PLAN    WHEQ 'AIW01'
      * WIXOM
     C                     Z-ADD2855      WTOKU   40       CUSTOMER CODE
     C                     Z-ADD2855      WNONY   40       DELIVERY CODE
     C           K#PLAN    WHEQ 'AIL01'
      * LOUISVILLE
     C                     Z-ADD2856      WTOKU            CUSTOMER CODE
     C                     Z-ADD2856      WNONY            DELIVERY CODE
     C                     OTHER
     C                     Z-ADD*ZERO     WTOKU            CUSTOMER CODE
     C                     Z-ADD*ZERO     WNONY            DELIVERY CODE
     C                     ENDSL
      *
     C                     MOVE '0'       WNKOJ   1        FACTORY  CODE
     C                     MOVELCFDOC2    WNUKE   4        RECEIVING   E
     C                     MOVE *BLANK    WMHIN
     C                     MOVELAFIPAR    WMHIN  20        PART NUMBER E
     C                     Z-ADDWSDAT     WNYMD   80       DELIVERY DATE
     C                     MOVEL'11111'   WODRN  10        ORDER #     E
     C                     MOVELAFALFL    WALFL   4        FEED LINE
     C                     MOVELAFRALF    WRLOC   4
      *
     C                     Z-ADD*ZERO     XXQTY   90
     C                     Z-ADD*ZERO     XXYMD
     C                     Z-ADD*ZERO     WQTY2
     C                     Z-ADD*ZERO     WSURY
     C           AFLSDT    IFNE *ZERO
     C           20000000  ADD  AFLSDT    XXYMD
     C                     Z-ADDXXYY      @@YYYY
     C                     Z-ADDXXMM      @@MMMM
     C                     Z-ADDXXDD      @@DDDD
     C           K#AB      SETGTAB#PL15
     C           *IN97     DOUEQ*ON
     C           K#ABX     READEAB#PL15                  97
     C           *IN97     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BANOHZ    IFGE WSDAT
     C                     LEAVE
     C                     ENDIF
     C                     ADD  BASRYO    XXQTY
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
     C*
     C* NOT WORKING DAY,RE-CULUCULATE
     C           *IN89     IFEQ '1'
     C           AFQTY2    SUB  AFYSQY    WQTY2            ORDERED QTY
     C                     SUB  XXQTY     WQTY2
     C                     Z-ADDWQTY2     WSURY   70
     C                     ELSE
     C* REQUESTED CUM - SHIPPED CUM
     C           AFQTY2    SUB  AFYSQY    WQTY2            ORDERED QTY
     C                     SUB  XXQTY     WQTY2
     C                     Z-ADDWQTY2     WSURY   70
     C                     END
      *
     C           WQTY2     IFGT *ZERO
     C*
     C                     EXSR #ER1
     C*
     C                     MOVE *OFF      *IN87
     C           KEY6      SETLLAB#PL151
     C           *IN96     DOUEQ*ON
     C           KEY6      READEAB#PL151                 96
     C           *IN96     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C                     MOVE *ON       *IN87
     C           *INOF     IFEQ *ON
     C                     EXCPT#HED1
     C                     EXCPT#HED2
     C                     SETOF                     OF
     C                     END
     C                     MOVEL'  '      W#MARK  2
     C           WSURY     IFGT BASRYO
     C                     MOVEL'++'      W#MARK
     C                     END
     C                     EXCPT#DTL1
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN87     IFEQ *OFF
     C           *INOF     IFEQ *ON
     C                     EXCPT#HED1
     C                     EXCPT#HED2
     C                     SETOF                     OF
     C                     END
     C                     MOVEL'  '      W#MARK
     C           *IN96     IFEQ *OFF
     C           WSURY     IFGT BASRYO
     C                     MOVEL'++'      W#MARK
     C                     END
     C                     END
     C                     EXCPT#DTL1
     C                     ENDIF
     C*
     C                     ENDIF
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C***********************************************************
     C* END
     C***********************************************************
     C           @END      BEGSR
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C                     ENDSR
     C***********************************************************
     C* CUM QTY ERROR
     C***********************************************************
     C           #ER1      BEGSR
     C*
     C                     Z-ADD*YEAR     @@YYYY
     C                     Z-ADD*MONTH    @@MMMM
     C                     Z-ADD*DAY      @@DDDD
     C                     Z-ADD*ZERO     @@QTY   90
     C           K#AB      SETLLAB#PL15
     C           *IN97     DOUEQ*ON
     C           K#ABX     READEAB#PL15                  97
     C           *IN97     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BANOHZ    IFGE WSDAT
     C                     LEAVE
     C                     ENDIF
     C                     ADD  BASRYO    @@QTY
     C                     ENDIF
     C                     ENDDO
      *
     C                     ADD  CFCAMT    @@QTY
     C           @@QTY     IFGT AFQTY2
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HEDE
     C                     ENDIF
     C  N98                MOVE *ON       *IN98
     C                     EXCPT@DETE
     C                     ENDIF
     C*
     C                     ENDSR
     C********************************************************
     OQPRINT  E    2           #HED1
     O       OR        OF
     O                                    8 'AN#RFM'
     O                                   32 'ANDROID NIRVANA  DATA'
     O                                   48 'VARIANCE REPORT'
     O                                  131 '.....................'
     O*
     O        E 1              #HED1
     O       OR        OF
     O                                  131 '.         .         .'
     O*
     O        E 1              #HED1
     O       OR        OF
     O                                   89 'TIME'
     O                         WTIME     98 '  :  :  '
     O                                  131 '.         .         .'
     O*
     O        E 1              #HED1
     O       OR        OF
     O                                   89 'DATE'
     O                         UDATE Y   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O                                  131 '.....................'
     O*
     O        E 1              #HED2
     O       OR        OF
     O                                   23 '<<<<<<<<<<<<<<<<<<<<<<'
     O                                   37 ' ENTERED DATA '
     O                                   59 '>>>>>>>>>>>>>>>>>>>>>>'
     O*
     O                                   91 '------------------'
     O                                  106 ' EDI NEW DATA '
     O                                  123 '------------------'
     O        E 1              #HED2
     O       OR        OF
     O                                    6 'PLANT'
     O                                   11 'DOCK'
     O                                   16 'PART'
     O                                   49 'REQ. QTY.'
     O                                   60 'QTY./CONT.'
     O                                   65 'SHIP'
     O                                   76 'RELEASED'
     O                                   86 'NEW QTY.'
     O                                   92 'PLANT'
     O                                   97 'DOCK'
     O                                  102 'PART'
     O                                  123 'LINE'
     O                                  129 'R-LOC'
     O*
     O        E 1              #DTL1
     O                N96      BANONY     5
     O                N96      BANUKE    11
     O                N96      BAMHN1    17
     O                N96      BAMHN2    23
     O                N96      BAMHN3    29
     O                N96      BAMHN4    35
     O                N96      BASRYO1   48
     O                N96      BASYOS1   59
     O                         PSMMMM    62
     O                                   63 '/'
     O                         PSDDDD    65
     O                N96      BADEYY    70
     O                 96      PRYYYY    70
     O                                   71 '/'
     O                N96      BADEMM    73
     O                 96      PRMMMM    73
     O                                   74 '/'
     O                N96      BADEDD    76
     O                 96      PRDDDD    76
     O                         WSURY 1   85
     O                         W#MARK    87
     O                 96      WNONY     91
     O                 96      WNUKE     97
     O                 96      WMHIN    118
     O                 96      WALFL    123
     O                 96      WRLOC    128
     OQPRINT2 E    1           @HEDE
     O                         #PGM       8
     O                         UDATE Y  108
     O                         WTIME    118 '  :  :  '
     O                                  120 'P.'
     O                         PAGE1 Z  125
     O        E    2           @HEDE
     O                                   32 'ANDROID CUM QTY'
     O                                   48 'VARIANCE REPORT'
     O        E    4           @HEDE
     O                                    5 'PLANT'
     O                                   11 'DOCK'
     O                                   17 'PART'
     O                                   49 'ANDR CUM'
     O                                   62 'IAF CUM'
     O        E    5           @HEDE
     O                                   64 '+TODAY''S SHP'
     O        E 1              @DETE
     O                         AFSTID     5
     O                         AFDOCK    11
     O                         AFIPAR    33
     O                         AFQTY21   49
     O                         @@QTY 1   62
