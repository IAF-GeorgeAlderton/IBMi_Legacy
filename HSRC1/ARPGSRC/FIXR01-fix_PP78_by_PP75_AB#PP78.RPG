     H            Y.
     F***FIXR01  ***************************************************************
     F*  FIX PP78 BY PP75                                                      *
     F*  JW       2022.10.20                                                   *
     F**************************************************************************
     FAB#PL79 UF  E           K        DISK
     FAB#PL76 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     I            DS
     I                                        1   80P8NOHZ
     I                                        1   40P8NOYY
     I                                        5   60P8NOMM
     I                                        7   80P8NODD
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C**                   MOVE 'Y'       UPDFLG  1
      *
     C                     DO   *HIVAL
     C                     READ AB#PL79                  98
     C   98                LEAVE
      *
     C           P8SKJY    IFEQ 'D'
     C           P8ASDT    ORNE 0
     C                     ITER
     C                     ENDIF
      * PP75
     C           P8SERL    CHAINAB#PL76              99
     C           *IN99     IFEQ *OFF
     C           PUASDT    ANDNE0
     C                     EXSR #PRINT
      * UPDATE
     C           UPDFLG    IFEQ 'Y'
     C                     Z-ADDPUASDT    P8ASDT
     C                     Z-ADDPUKOTN    P8ASTM
     C                     MOVELPUKOME    P8ASNM
     C                     MOVEL#PGM      P8FLD1
     C                     UPDATAB#PP781
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           UPDFLG  1
      *
     C           UPDFLG    IFEQ ' '
     C                     MOVEL'N'       UPDFLG
     C                     ENDIF
      *
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   19 'UPDATE='
     O                         UPDFLG    20
     O                                   45 '** MISSING ASN DATE '
     O                                   65 'IN AB#PP78 **       '
     O                                   89 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                                  106 'P.'
     O                         PAGE  Z  110
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   10 'CUST'
     O                                   15 'DELV'
     O                                   31 'SHP_DATE'
     O                                   36 'BN'
     O                                   43 'ORDER#'
     O                                   55 'SERIAL#'
     O                                   67 'ASN DATE'
     O                                   79 'TO_BE_DATE'
     O                                   88 'UPD_DATE'
     O                                   99 'UPD_TIME'
     O                                  108 'UPD_USER'
     O        E 1              @DTL
     O                         SEQ#  1 +000
     O                         P8CUST  +001
     O                         P8NONY  +001
     O                         P8NKOJ  +001
     O                         P8NUKE  +001
     O                         P8NOHZ  +001 '    /  /  '
     O                         P8BINN  +001
     O                         P8ODRN  +001
     O                         P8SERL  +001
     O                         P8ASDT  +001 '    /  /  '
     O                         PUASDT  +001 '    /  /  '
     O                         PUKODT  +001 '    /  /  '
     O                         PUKOTN  +001 '0 :  :  '
     O                         PUKOME  +001
