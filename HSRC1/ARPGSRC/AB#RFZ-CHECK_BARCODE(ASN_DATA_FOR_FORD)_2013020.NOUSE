     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *---------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           PSIRE   4
     C                     PARM           PSIRK   1
     C                     PARM           PDOCK   4
     C                     PARM           PNOHZ   80
     C                     PARM           PNOBN   20
     C                     PARM           PREHZ   80
     C                     PARM           PPSCAC
     C                     PARM           PTRIL
     C                     PARM           PCSCAC
     C                     PARM           PCMOD
     C                     PARM           PPPCD
     C                     PARM           PSPCD   5
     C                     PARM           PFLG    1
      *
     C                     MOVE '01'      W@ID    2
      *
     C                     ENDSR
      *---------------------------------------------------
     C           #SCRN1    BEGSR
      *---------------------------------------------------
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     MOVE '9'       PFLG
     C           *INKI     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     MOVE *BLANK    PFLG
     C                     MOVE *BLANK    PSIRE
     C                     MOVE *BLANK    PSIRK
     C                     MOVE *BLANK    PDOCK
     C                     Z-ADD*ZERO     PNOHZ
     C                     Z-ADD*ZERO     PNOBN
     C                     MOVE *BLANK    PPSCAC
     C                     MOVE *BLANK    PTRIL
     C                     MOVE *BLANK    PCSCAC
     C                     MOVE *BLANK    PCMOD
     C                     MOVE *BLANK    PPPCD
     C                     MOVE *BLANK    PSPCD   5
     C                     OTHER
     C                     EXSR #CHK
     C           *IN99     IFEQ *OFF
     C                     MOVE '1'       PFLG
     C                     MOVE '99'      W@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *---------------------------------------------------
     C           #CHK      BEGSR
      *---------------------------------------------------
     C                     MOVEA'00000000'*IN,7
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    MSG
     C           PPSCAC    IFEQ *BLANK
     C                     SETON                     0799
     C                     MOVE ERR,2     MSG
     C                     ENDIF
      *
     C           PTRIL     IFEQ *BLANK
     C                     SETON                     0899
     C                     MOVE ERR,3     MSG
     C                     ENDIF
      *
     C           PCSCAC    IFEQ *BLANK
     C                     SETON                     0999
     C                     MOVE ERR,4     MSG
     C                     ENDIF
      *
     C           PCMOD     IFEQ *BLANK
     C                     SETON                     1099
     C                     MOVE ERR,5     MSG
     C                     ENDIF
      *
     C***        PPPCD     IFEQ *BLANK
     C*                    SETON                     1199
     C*                    MOVE ERR,6     MSG
     C*****                ENDIF
      *
     C           D@BARC    CHAINAB#PL76             N90
     C           *IN90     IFEQ *ON
     C                     MOVE *ON       *IN13
     C                     MOVE *ON       *IN99
     C                     MOVE ERR,1     MSG
     C                     ELSE
      *
     C                     MOVE PUNONY    PSIRE
     C                     CALL 'AB#RF0'
     C                     PARM           PSIRE
     C                     PARM           PFDID   1
