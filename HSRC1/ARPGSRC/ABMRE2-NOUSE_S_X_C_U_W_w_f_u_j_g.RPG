     I              '0123456789'          C         WKCKSU
      *
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C           1         SETLLABMWP311
     C                     READ ABMWP311                 21
     C           *IN21     DOWEQ'0'
     C           @AKERR    IFEQ '*'
     C           @BKCD1    ANDEQ'E'
     C                     EXSR #SB200
     C                     ENDIF
     C                     READ ABMWP311                 21
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------*
      *引取かんばん検索         *
      *---------------------------*
     CSR         #SB200    BEGSR
      *
     C           KEYL61    KLIST
     C                     KFLD           #K1HB5  5
     C                     KFLD           #K2HB5  5
     C                     KFLD           #K3HB2  2
      *
     C                     MOVEL@BJHN1    #K1HB5
     C                     MOVEL@BJHN2    #K2HB5
     C                     MOVEL@BJHN3    #K3HB2
     C           KEYL61    SETGTAAHTL061
     C           KEYL61    REDPEAAHTL061                 82
     C           *IN82     DOWEQ'0'
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    ANDLE*DATE
     C                     ELSE
     C           L6STHZ    IFEQ 99999999
     C                     Z-ADDWTIYY     L6KOYY
     C                     Z-ADDWTIMM     L6KOMM
     C                     Z-ADDWTIDD     L6KODD
     C                     Z-ADDWTITH     L6KOHH
     C                     Z-ADDWTITM     L6KOSS
     C                     MOVEL'ZIDOU'   L6KOME    P
     C                     EXSR #SB400
     C           WKSRYO    DIV  20        L6KSSU
     C                     UPDATAAHTL061
     C                     ENDIF
     C                     ENDIF
     C           KEYL61    REDPEAAHTL061                 82
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *---------------------------*
      * GHCPP21より設定数       *
      *---------------------------*
     CSR         #SB400    BEGSR
      *
     C                     SETOF                     99
     C           KEYMD1    KLIST
     C                     KFLD           #KMBN1  1
     C                     KFLD           #KMBN2  2
     C                     KFLD           #KMBN3  2
     C                     KFLD           #KMBN4  1
     C                     KFLD           #KMHN1  5
     C                     KFLD           #KMHN2  5
     C                     KFLD           #KMHN3  2
      *
     C                     MOVELL6ATK1    #KMBN1
     C                     MOVELL6ATK2    #KMBN2
     C                     MOVELL6ATK3    #KMBN3
     C                     MOVELL6ATK4    #KMBN4
     C                     MOVELL6SHN1    #KMHN1
     C                     MOVELL6SHN2    #KMHN2
     C                     MOVELL6SHN3    #KMHN3
     C                     MOVEL'0'       FGET2   1
     C                     Z-ADD0         WKSRYO  90
     C           KEYMD1    SETLLGHCTL211
     C           KEYMD1    READEGHCTL211                 83
     C           *IN83     DOWEQ'0'
     C           FGET2     ANDEQ'0'
     C                     Z-ADDMDSRYO    WKSRYO
     C                     MOVEL'1'       FGET2
     C           KEYMD1    READEGHCTL211                 83
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
