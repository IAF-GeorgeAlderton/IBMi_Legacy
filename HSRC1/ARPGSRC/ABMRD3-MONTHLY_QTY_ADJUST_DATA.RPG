     C                     Z-ADD1         W@P5MM
     C                     ELSE
     C                     ADD  1         W@P5MM
     C                     ENDIF
     C                     Z-ADDW@P5YM    D1YMN5
      * N+6
     C                     Z-ADDW@P5YM    W@P6YM
     C           W@P5MM    IFEQ 12
     C                     ADD  1         W@P6YY
     C                     Z-ADD1         W@P6MM
     C                     ELSE
     C                     ADD  1         W@P6MM
     C                     ENDIF
     C                     Z-ADDW@P6YM    D1YMN6  60
      *稼働日数
     C                     Z-ADD0         D1KDN
