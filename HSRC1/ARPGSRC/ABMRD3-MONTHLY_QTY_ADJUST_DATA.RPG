      *
     C                     MOVELP1SHN1    WKSHN1
     C                     MOVELP1SHN2    WKSHN2
     C                     MOVELP1SHN3    WKSHN3
     C                     EXSR #SB211
     C                     MOVELP@SHNA    D1SHN
     C                     MOVELP1ZANM    D1ZANM
     C                     Z-ADDP1KAZI    D1KAZI
      *
     C                     MOVEL*BLANK    D1KH1
     C                     MOVEL*BLANK    D1KH2
     C                     MOVEL*BLANK    D1KH3
     C                     MOVEL*BLANK    D1KH4
      *
     C           P1KH1     IFNE *BLANK
     C                     MOVELP1KH1     WKSHN
     C                     EXSR #SB211
     C                     MOVELP@SHNA    D1KH1
     C                     ENDIF
      *
     C           P1KH2     IFNE *BLANK
