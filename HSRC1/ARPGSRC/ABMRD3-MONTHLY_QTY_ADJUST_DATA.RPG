     C                     Z-ADD1         W@P2MM
     C                     ELSE
     C                     ADD  1         W@P2MM
     C                     ENDIF
     C                     Z-ADDW@P2YM    D1YMN2
      * N+3
     C                     Z-ADDW@P2YM    W@P3YM
     C           W@P2MM    IFEQ 12
     C                     ADD  1         W@P3YY
     C                     Z-ADD1         W@P3MM
     C                     ELSE
     C                     ADD  1         W@P3MM
     C                     ENDIF
     C                     Z-ADDW@P3YM    D1YMN3
      * N+4
     C                     Z-ADDW@P3YM    W@P4YM
