      *----------------------------------------------------*
     CSR         #SBAGD    BEGSR
      *
     C           KEYF8     KLIST
     C                     KFLD           #KKAYY  40
     C                     KFLD           #KKAMM  20
     C                     Z-ADD#KYY      #KKAYY
     C                     Z-ADD#KMM      #KKAMM
     C                     Z-ADD0         WKADO   31
     C           KEYF8     SETLLAGDPL121
     C           KEYF8     READEAGDPL121                 77
     C           *IN77     DOWEQ'0'
     C           F8HIRU    IFEQ *BLANK
     C                     ADD  0.5       WKADO
     C                     ENDIF
     C           F8YORU    IFEQ *BLANK
     C                     ADD  0.5       WKADO
     C                     ENDIF
     C           KEYF8     READEAGDPL121                 77
     C                     ENDDO
      *
