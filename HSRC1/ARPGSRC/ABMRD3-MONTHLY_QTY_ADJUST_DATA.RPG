     C                     EXSR #SB211
     C                     MOVELP@SHNA    D1KH4
     C                     ENDIF
      * N
     C                     Z-ADD*DATE     W@DATE
     C                     Z-ADDW@DTYM    D1YMN
      * N+1
     C                     Z-ADDW@DTYM    W@P1YM
     C           W@DTMM    IFEQ 12
     C                     ADD  1         W@P1YY
     C                     Z-ADD1         W@P1MM
     C                     ELSE
     C                     ADD  1         W@P1MM
     C                     ENDIF
     C                     Z-ADDW@P1YM    D1YMN1
      * N+2
     C                     Z-ADDW@P1YM    W@P2YM
     C           W@P1MM    IFEQ 12
