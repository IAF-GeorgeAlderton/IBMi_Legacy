     H            Y.
      ** AB#R3T **********************************************
      *  MIXED PALLET SHEETS FOR ALL                         *
      *                                                      *
      *                                                      *
      *                                                      *
      *                                                      *
      *                                                      *
      *
      ********************************* AB#R3T ***************
     FAB#PW3T CF  E                    WORKSTN
     FAB#PL1A IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FAB#PL90 IF  E           K        DISK
     FABWPP31 O   E           K        DISK                      A    UC
      *--------------------------------------------------
     E                    CMD     1   1 70
      *--------------------------------------------------
     I            DS
     I                                        1   80BANYMD
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I            DS
     I                                        1   80DATE
     I                                        1   20W@CT
     I                                        3   40W@YY
     I                                        5   60W@MM
     I                                        7   80W@DD
     I            DS
     I                                        1   80KDATE
     I                                        1   40KYYYY
     I                                        5   60KMM
     I                                        7   80KDD
     I            DS
     I                                        1  120#TIME
     I                                        1   20W@HH
     I                                        3   40W@MIN
     I                                        5   60W@SS
     I            DS
     I                                        1   80WNOHZ
     I                                        1   40WNOYY
     I                                        5   60WNOMM
     I                                        7   80WNODD
     I* CHANGE DATE(FCEPL01)
     I            DS
     I                                        1   80A2DATE
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
     I* LOCATION(FCEPL01)
     I            DS
     I                                        1   6 A2STKR
     I                                        1   1 A2STRK
     I                                        2   3 A2STRT
     I                                        4   5 A2STRR
     I                                        6   6 A2STRD
     I* LOCATION(FCEPL01)
     I            DS
     I                                        1   6 A2KTKR
     I                                        1   1 A2KTRK
     I                                        2   3 A2KTRT
     I                                        4   5 A2KTRR
     I                                        6   6 A2KTRD
     I            DS
     I                                        1   80YASKHZ
     I                                        1   40YASKYY
     I                                        5   60YASKMM
     I                                        7   80YASKDD
     I            DS
     I                                        1  12 ISHN
     I                                        1   5 ISHN1
     I                                        6  10 ISHN2
     I                                       11  12 ISHN3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *---------------------------------------------------
      * MAIN ROUTINE *
      *---------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      @DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *---------------------------------------------------
      *  DEFINITION
      *---------------------------------------------------
      * INITIALIZATION*
      *---------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     MOVEL'01'      W@ID    2
      *
     C           P#CALL    PLIST
     C                     PARM           P@CNT   30
JW   C                     PARM           P@NONY  4
      *
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      *
     C           KEY2      KLIST
     C                     KFLD           BASHN1
     C                     KFLD           BASHN2
     C                     KFLD           BASHN3
      *
     C                     Z-ADD70        P@LEN
     C                     MOVELCMD,1     P@CMD
     C                     Z-ADD1.07      PWEIG   52
      *
     C                     ENDSR
      *---------------------------------------------------
      * FIRST SCREEN  *
      *---------------------------------------------------
     C           @DSP1     BEGSR
     C                     EXFMTDSP01
     C*
     C                     SELEC
     C           *INKA     WHEQ '1'
     C                     MOVEL'99'      W@ID
     C           *INKE     WHEQ '1'
     C                     EXSR #CHK1
     C           *IN99     IFEQ '0'
     C                     EXSR #OUT
     C                     MOVEL'99'      W@ID
     C                     ENDIF
     C                     ENDSL
     C*
     C                     ENDSR
      *---------------------------------------------
      * CHECK
      *---------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     SETOF                     616299
     C           D@DATE    CHAINAB#PL1A              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------
      * OUTPUT
      *--------------------------------------------
     C           #OUT      BEGSR
      *
     C                     Z-ADD*ZERO     @@NONY  40
     C                     Z-ADD*ZERO     @@TOKU  40
     C                     MOVE *BLANK    @@NUKE  4
     C                     Z-ADD*ZERO     @@BIN   20
     C                     OPEN ABWPP31
      *
     C           D@DATE    SETLLAB#PL1A
     C           *IN90     DOUEQ*ON
     C           D@DATE    READEAB#PL1A                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
      *
     C           D@BIN     IFNE *ZERO
     C           D@BIN     ANDNEBANOBN
     C                     ITER
     C                     ENDIF
      *
     C           @@NONY    IFNE *ZERO
     C           BANONY    IFNE @@NONY
     C           BANOBN    ORNE @@BIN
     C           BANUKE    ORNE @@NUKE
     C                     EXSR #WRT
     C                     ENDIF
     C                     ENDIF
     C*
     C* SET VALUES NOT REQUIRED CALCULATIONS
     C                     Z-ADDBANOHZ    INOHZ
     C                     Z-ADDBANOBN    INOTM
     C                     MOVELBANUKE    INUKE
     C                     MOVELBAODRN    IODRN
     C                     MOVELBASBAN    ISBAN
     C                     MOVELBAMHIN    IMHN
     C                     Z-ADDBASRYO    ISRYO
     C                     MOVELBASHN1    ISHN1
     C                     MOVELBASHN2    ISHN2
     C                     MOVELBASHN3    ISHN3
     C                     Z-ADDBATOKU    ITOKU
     C                     MOVE BANONY    INONY
     C                     MOVELBANKOJ    INKOJ
     C                     MOVELBAINVN    IINV#
     C           BANONY    IFEQ 3503
     C           BANONY    OREQ 3504
     C                     MOVELBAODRN    IINV#     P
     C                     ENDIF
     C*
     C* SET QUANTITY / CONTAINERS
     C           BAUSYS    IFEQ *ZERO
     C           BASYOS    IFEQ *ZERO
     C                     Z-ADD1         ISYOS
     C*
     C                     ELSE
     C                     Z-ADDBASYOS    ISYOS
     C                     END
     C*
     C                     ELSE
     C                     Z-ADDBAUSYS    ISYOS
     C                     END
      *
     C           ISYOS     IFNE *ZERO
     C           BASRYO    DIV  ISYOS     @@ANS   50
     C                     MVR            @@MVR   50
     C           @@MVR     IFNE *ZERO
     C                     ADD  1         @@ANS
     C                     ENDIF
     C                     ENDIF
     C*
     C* SET LOCATION
     C           KEY2      SETLLFCEPL011
     C           #PART     TAG
     C           KEY2      READEFCEPL011                 91
B02  C           *IN91     IFEQ '0'
     C*
     C           A2GSKD    IFEQ 'D'
     C                     GOTO #PART
     C                     END
     C*
     C           D@DATE    IFGE A2DATE                     LOCATION
     C                     MOVE A2STRK    FCLOC1           NEW
     C                     MOVE A2STRT    FCLOC2
     C                     MOVE A2STRR    FCLOC3
     C                     MOVE A2STRD    FCLOC4
     C*
     C                     ELSE
     C                     MOVE A2KTRK    FCLOC1           OLD
     C                     MOVE A2KTRT    FCLOC2
     C                     MOVE A2KTRR    FCLOC3
     C                     MOVE A2KTRD    FCLOC4
     C                     END
     C                     Z-ADDA2KASI    W2KASI  72
     C*
     C* NOT READ FCEPL01
     C                     ELSE
     C                     MOVE *BLANK    FCLOC1
     C                     MOVE *BLANK    FCLOC2
     C                     MOVE *BLANK    FCLOC3
     C                     MOVE *BLANK    FCLOC4
     C                     Z-ADD*ZERO     W2KASI
B02  C                     END
     C*
     C* CALUCULATE THE NUMBER OF BOXES
     C           BASRYO    DIV  ISYOS     FC#BOX
     C                     MVR            WHAK1   40
     C           WHAK1     IFNE 0
     C                     ADD  1         FC#BOX
     C                     END
     C*
     C* CALUCULATE THE TOTAL WEIGHT PAR PART
     C* (QTY/CONTAINER) * (FINISHED WEIGHT) = NET WEIGHT PER BOX(G)
     C* NET WEIGHT + BOX WEIGHT             = GROSS WEIGHT PER BOX(G)
     C* (GROSS WEIGHT PER BOX) * # OF BOX   = TOTAL WEIGHT / PART(G)
     C* (TOTAL WEIGHT PER PART) / 1000      = TOTAL WEIGHT / PART(KG)
     C           ISYOS     MULT W2KASI    WKOT1   92
     C           WKOT1     ADD  PWEIG     WKOT1
     C           WKOT1     MULT FC#BOX    WKOT1
     C           WKOT1     DIV  1000      FCWEGH  62
     C*
     C                     WRITEAB#PP311
      *
     C                     Z-ADDBANONY    @@NONY
     C                     Z-ADDBANOBN    @@BIN
     C                     MOVELBANUKE    @@NUKE
     C                     MOVELBATOKU    @@TOKU
     C*
     C                     ENDIF
     C                     ENDDO
E1    *
     C           @@NONY    IFNE *ZERO
     C                     EXSR #WRT
     C                     ENDIF
E1    *
     C                     ENDSR
      *--------------------------------------------
      * OUTPUT
      *--------------------------------------------
     C           #WRT      BEGSR
      *
     C                     CLOSEABWPP31
      *
     C                     MOVEL@@NONY    C@NONY  4
     C           C@NONY    SETLLAB#PL90
     C           *IN95     DOUEQ*ON
     C           C@NONY    READEAB#PL90                  95
     C           *IN95     IFEQ *OFF
     C           YASKJY    ANDEQ*BLANK
     C                     Z-ADDYAMXPL    P@CNT
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     SELEC
     C           @@NONY    WHEQ 3804
     C           @@NONY    OREQ 3805
     C           @@NONY    OREQ 3347
     C           @@NONY    OREQ 3348
     C           @@NONY    OREQ 3503
     C           @@NONY    OREQ 3504
     C                     CALL 'AB#R49'  P#CALL
      *
     C                     OTHER
     C                     CALL 'AB#R48'  P#CALL
     C                     ENDSL
      *
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN ABWPP31
      *
     C                     ENDSR
** CMD
CLRPFM QTEMP/ABWPP31
