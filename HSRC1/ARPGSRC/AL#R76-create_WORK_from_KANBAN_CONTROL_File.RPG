     FAL#PL71 UF  E           K        DISK
     FAL#PL42 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FAO#PL42 IF  E           K        DISK
     FAL#WP46 O   E                    DISK                      A
      *
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WKST
     I                                        1   80WKSTHZ
     I                                        9  140WKSTTI
      *
     I            DS
     I                                        1  140C7ST
     I                                        1   80C7STHZ
     I                                        9  140C7STTI
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P7FIXD  80
     C                     PARM           P7FIXT  60
     C                     PARM           P7TIMS  20
     C                     PARM           P7TRKB  2
     C                     PARM           P7IAFB  3
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     Z-ADD0         WKST
     C                     Z-ADDSDATE     WKSTHZ
     C                     Z-ADDSTIME     WKSTTI
     C           KEYC7     KLIST
     C                     KFLD           KKNKHZ  80
     C                     KFLD           KKNKTI  60
      *抜き出し前
     C                     Z-ADD0         KKNKHZ
     C                     Z-ADD0         KKNKTI
     C                     Z-ADD0         P7FIXD
     C                     Z-ADD0         P7FIXT
     C                     Z-ADD0         P7TIMS
     C                     MOVEL*BLANK    P7TRKB
     C                     MOVEL*BLANK    P7IAFB
     C                     MOVEL'0'       GET     1
     C           KEYC7     SETLLAL#PL711
     C           KEYC7     READEAL#PL711                 81
     C           *IN81     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           C7SKJY    IFEQ 'D'
     C           C7SKHZ    ANDLESDATE
     C                     ELSE
     C           C7ST      IFLE WKST
     C                     MOVEL'1'       GET     1
     C                     Z-ADDC7FIXD    P7FIXD
     C                     Z-ADDC7FIXT    P7FIXT
     C                     Z-ADDC7TIMS    P7TIMS
     C                     MOVELC7TRKB    P7TRKB
     C                     MOVELC7IAFB    P7IAFB
     C                     EXSR #SB400
     C                     Z-ADDSDATE     C7KOHZ
     C                     Z-ADDSTIME     C7KOTI
     C                     MOVELW#USER    C7KOME
     C                     Z-ADDSDATE     C7NKHZ
     C                     Z-ADDSTIME     C7NKTI
     C                     UPDATAL#PL711
     C                     ENDIF
     C                     ENDIF
     C           KEYC7     READEAL#PL711                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AL#PP41
      *-----------------------------------------------------
     CSR         #SB400    BEGSR
      *
     C           KEYC1     KLIST
     C                     KFLD           C7FIXD
     C                     KFLD           C7FIXT
     C                     KFLD           C7TRKB
     C                     KFLD           C7IAFB
      *
     C           KEYC1     SETLLAL#PL421
     C           KEYC1     READEAL#PL421                 81
     C           *IN81     DOWEQ'0'
     C           C4SKJY    IFEQ 'D'
     C           C4SKHZ    ANDLESDATE
     C                     ELSE
     C                     EXSR #SB500
     C                     ENDIF
     C           KEYC1     READEAL#PL421                 81
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *-----------------------------------------------------
      *  AL#WP46
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C                     CLEARAL#WP461
     C                     MOVELC4SURT    W6SURT
     C                     MOVELC4SHID    W6SHID
     C                     MOVELC4SHIT    W6SHIT
     C                     MOVEL*BLANK    W6SMEI
     C           C4NONY    CHAINFGBPL011             24
     C           *IN24     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLESDATE
     C                     SETON                     24
     C                     ENDIF
     C           *IN24     IFEQ '0'
     C                     MOVELB2SMEI    W6SMEI
     C                     ENDIF
     C                     MOVELC4NUKE    W6DOCK
     C                     MOVELC4ORD#    W6ORD#
     C                     MOVELC4PALT    W6PALT
     C                     MOVELC4NONY    W6NONY
     C                     MOVELC4NKOJ    W6NKOJ
     C                     MOVELC4NUKE    W6NUKE
     C                     MOVELC4IAFB    W6IAFB
     C                     MOVELC4IAFP    W6IAFP
     C                     MOVELC4PPUL    W6PPUL
     C           C4EXTR    IFEQ 0
     C                     MOVEL*BLANK    W6EXT
     C                     ELSE
     C                     MOVEL'1'       W6EXT
     C                     ENDIF
     C                     MOVELC4SAT     W6SAT
     C                     Z-ADDC4BOX     W6BOX
     C                     Z-ADD0         W6EMPT
     C                     Z-ADD0         SYO     30
     C                     Z-ADD0         AMR     30
     C           W6BOX     DIV  12        SYO
     C                     MVR            AMR
     C           AMR       IFNE 0
     C           12        SUB  AMR       W6EMPT
     C                     ENDIF
     C                     Z-ADD0         P9PFTR
     C                     Z-ADD0         P9PFBI
     C                     CALL 'AL#R45'
     C                     PARM           C4FIXD
     C                     PARM           C4FIXT
     C                     PARM           C4TRKB
     C                     PARM           C4IAFB
     C                     PARM           P9PFTR  30
     C                     PARM           P9PFBI  30
     C                     Z-ADDP9PFTR    W6PFTR
     C                     Z-ADDP9PFBI    W6PFBI
     C                     Z-ADDC7FIXD    W6FIXD
     C                     Z-ADDC7FIXT    W6FIXT
     C                     Z-ADDC7TIMS    W6TIMS
     C                     Z-ADDC7EXTR    W6EXTR
     C           KEYO4     KLIST
     C                     KFLD           C4FIXD
     C                     KFLD           C4FIXT
     C                     KFLD           C4TRKB
     C                     KFLD           C4IAFB
     C                     KFLD           C4IAFP
     C           KEYO4     CHAINAO#PL42              19
     C           *IN19     IFEQ '0'
     C           O4SKJY    ANDEQ'D'
     C           O4SKHZ    ANDLESDATE
     C                     SETON                     19
     C                     ENDIF
     C           *IN19     IFEQ '0'
     C                     MOVELO4ZONE    W6ZONE
     C                     ELSE
     C                     MOVEL'A'       W6ZONE
     C                     ENDIF
     C                     WRITEAL#WP461
      *
     CSR         ESB500    ENDSR
