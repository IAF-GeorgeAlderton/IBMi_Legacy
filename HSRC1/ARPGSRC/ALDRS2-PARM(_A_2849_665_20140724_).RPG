     H            Y/
     F* PARM('A' '2849' '665' '20140724' '    ')
     FALDPL30 IF  E           K        DISK
     FADAPL01 IF  E           K        DISK
     FALSPL01 IF  E           K        DISK
     FALJPL10 IF  E           K        DISK
     FALCPL07 IF  E           K        DISK
      *
     I            DS
     I                                        1   80A3SYDT
     I                                        1   40A3SYYY
     I                                        5   60A3SYMM
     I                                        7   80A3SYDD
     I            DS
     I                                        1   80ADKODT
     I                                        1   40ADKOYY
     I                                        5   60ADKOMM
     I                                        7   80ADKODD
      *
     C           *ENTRY    PLIST
     C                     PARM           P@CHYU  1
     C                     PARM           P@ZENO  4
     C                     PARM           P@SHN1  5
     C                     PARM           P@SHN2  5
     C                     PARM           P@SHN3  2
     C                     PARM           P@THNO  3
     C                     PARM           P@PAGE  2
     C                     PARM           P@HTHZ  8
     C                     PARM           P@MAIS  4
     C                     PARM           P@SRT   30
      *
     C                     MOVE P@CHYU    K@CHYU  1
     C                     MOVE P@ZENO    K@ZENO  4
     C                     MOVE P@THNO    K@THNO  3
     C                     MOVE P@HTHZ    K@HTHZ  80
     C                     MOVE P@PAGE    K@PAGE  2
     C                     MOVE P@SHN1    K@SHN1  5
     C                     MOVE P@SHN2    K@SHN2  5
     C                     MOVE P@SHN3    K@SHN3  2
      *
     C           ALDKEY    KLIST
     C                     KFLD           K@ZENO  4
     C                     KFLD           K@THNO  3
     C                     KFLD           K@PAGE  2
      *
     C           ALJKEY    KLIST
     C                     KFLD           K@ZENO  4
     C                     KFLD           K@THNO  3
      *
     C                     Z-ADD0         @CNT
      *
     C           ALDKEY    SETLLALDPL30
     C                     DO   *HIVAL
     C           ALDKEY    READEALDPL30                  77
     C   77                LEAVE
     C           A3SYDT    IFLT K@HTHZ
     C                     ITER
     C                     END
     C                     ADD  1         @CNT    40
     C                     ENDDO
      * ALSPP01
     C                     EXSR #SBALS
      * ALJPP10  CREFORM
     C                     EXSR #SBALJ
      *
     C           ADAKEY    KLIST
     C                     KFLD           K@CHYU  1
     C                     KFLD           K@ZENO  4
     C                     KFLD           K@THNO  3
      *
     C           ADAKEY    SETLLADAPL01
     C                     DO   *HIVAL
     C           ADAKEY    READEADAPL01                  77
     C   77                LEAVE
     C           ADKODT    IFLT K@HTHZ
     C                     ITER
     C                     END
     C                     MOVELADPGNO    BDPGNO  2
     C           BDPGNO    IFNE P@PAGE
     C                     ITER
     C                     ENDIF
     C                     ADD  1         @CNT    40
     C                     ENDDO
      *
     C                     MOVE @CNT      P@MAIS
     C                     Z-ADD0         P@SRT
     C           @CNT      IFEQ 0
     C                     EXSR #SB411
     C                     ENDIF
      *
     C                     EXSR #END
      *
     C           #END      BEGSR
     C                     SETON                     LR
     C                     RETRN
     C           EEND      ENDSR
     C* ----------------------------------------------------
     CSR         #SBALS    BEGSR
     C* ----------------------------------------------------
     C           ALDKEY    SETLLALSPL011
     C           ALDKEY    READEALSPL011                 92
     C           *IN92     DOWEQ'0'
     C           ASSKJY    IFEQ 'D'
     C           ASSKDT    ANDLE*DATE
     C                     ELSE
     C           ASCODT    IFGE K@HTHZ
     C           ASOKNG    ANDEQ'OK'
     C                     ADD  1         @CNT    40
     C                     ENDIF
     C                     ENDIF
     C           ALDKEY    READEALSPL011                 92
     C                     ENDDO
      *
     CSR         ESBALS    ENDSR
     C* ----------------------------------------------------
     CSR         #SBALJ    BEGSR
     C* ----------------------------------------------------
     C           ALJKEY    SETLLALJPL101
     C           ALJKEY    READEALJPL101                 92
     C           *IN92     DOWEQ'0'
      *
     C           B0DATE    IFGE K@HTHZ
     C           B5PAG#    ANDEQK@PAGE
     C                     ADD  1         @CNT    40
     C                     ENDIF
      *
     C           ALJKEY    READEALJPL101                 92
     C                     ENDDO
      *
     CSR         ESBALJ    ENDSR
      *--------------------------------------------------*
      * SRT                                              *
      *--------------------------------------------------*
     CSR         #SB411    BEGSR
      *
     C           K@ALC     KLIST
     C                     KFLD           K@SHN1  5
     C                     KFLD           K@SHN2  5
     C                     KFLD           K@SHN3  2
     C                     KFLD           K@THNO  3
     C           K@ALC     SETLLALCPL07
      *
     C           *IN95     DOWEQ*OFF
     C           K@ALC     READEALCPL07                  95
1    C           *IN95     IFEQ *OFF
|     *
|2   C           A8DATE    IFGE K@HTHZ
||   C           A8ERR     ANDEQ*BLANK
||   C           A8PAG     ANDEQK@PAGE
||   C                     MOVELA8BRC2    LTR3    3
||3  C           LTR3      IFEQ 'SRT'
|||  C                     ADD  1         P@SRT
|||  C                     LEAVE
||3  C                     ENDIF
|2   C                     ENDIF
|     *
1    C                     ENDIF
      *
     C                     ENDDO
      *
     CSR         ESB411    ENDSR
