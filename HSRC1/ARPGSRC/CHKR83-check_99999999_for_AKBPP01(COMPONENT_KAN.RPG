     H            Y.
     F***CHKR83*****************************************************************
     F*  PROGRAM    : CHECK 99999999 FOR AKBPP01                               *
     F*             : RUN IN FCKC00 (10:10AM BY JOBSCDE)                       *
     F*  WRITTEN    : JW (SRA) 2021.11.09                                      *
     F**************************************************************************
     FAKBPL03 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     F**************************************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           *LOVAL    SETLLAKBPL03
     C                     DO   *HIVAL
     C                     READ AKBPL03                  98
     C   98                LEAVE
      * IGNORE
     C           L1SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * FIRST ?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELL1TKRO    SVTKRO  6
     C                     MOVELL1TKR1    SVTKR1  1
     C                     MOVELL1TKR2    SVTKR2  2
     C                     MOVELL1TKR3    SVTKR3  2
     C                     MOVELL1TKR4    SVTKR4  1
     C                     ENDIF
      * BREAK ?
     C           L1TKRO    IFNE SVTKRO
     C                     EXSR #BRK1
     C                     ENDIF
      * PROCESS
     C           L1STYY    IFEQ 9999
     C                     ADD  1         RCNT
     C                     ENDIF
      *
     C                     ENDDO
      * LAST BREAK ?
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK1
     C                     ENDIF
      * SET RETURN CODE
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  BREAK                                             *
      *----------------------------------------------------*
     C           #BRK1     BEGSR
      *
     C           RCNT      IFGT 1
     C                     EXSR #PRINT
     C                     ENDIF
      * RESET
     C                     Z-ADD0         RCNT
     C                     MOVELL1TKRO    SVTKRO
     C                     MOVELL1TKR1    SVTKR1
     C                     MOVELL1TKR2    SVTKR2
     C                     MOVELL1TKR3    SVTKR3
     C                     MOVELL1TKR4    SVTKR4
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C                     MOVE ' '       $RTN
     C                     TIME           SDATE
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     Z-ADD0         RCNT    30
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** COMPONENT KANBAN '
     O                                   60 'LOCATION CONTAINS MU'
     O                                   80 'LTIPLE 9999 DATE ** '
     O                                   89 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                                  106 'P.'
     O                         PAGE  Z  110
     O        E   02           @HDR
     O                                    9 '(AKBPP01)'
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   15 'LOCATION'
     O                                   23 'COUNT'
     O        E 1              @DTL
     O                         SEQ#  1 +000
     O                         SVTKR1  +002
     O                         SVTKR2  +001
     O                         SVTKR3  +001
     O                         SVTKR4  +001
     O                         RCNT  1 +002
