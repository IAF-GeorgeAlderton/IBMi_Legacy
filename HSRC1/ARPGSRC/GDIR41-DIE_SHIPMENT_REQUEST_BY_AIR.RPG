     H            Y/
     F***************************************************
     F*  DIE SHIPMENT REQUEST BY AIR                    *
     F*                                                 *
     F*                                                 *
     F*  INDICATOR 20=SORT BY ORDER DATE                *
     F*            02=FIELD PROTECT ON DSP01            *
     F***************************************************
     FGDIPW41 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FGDIPL40 UF  E           K        DISK                      A
     FGDIPL41 IF  E           K        DISK
     F            GDIPP401                          KRENAMEGDIPL41R
     FGCQPL12 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
      *------------------------------------------------------------
     E                    CMD     1   3 78
     E                    ERR     1   6 78
     E                    TAB1    1   3  1   TAB2    6
     E                    ARY       100 16
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1  16 WARY
     I                                        1   2 WD01
     I                                        3   6 WD02
     I                                        7   7 WD03
     I                                        8   8 WD04
     I                                        9  160WDAT
     I            DS
     I                                        1   80K@YMD
     I                                        1   60K@YM
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80F8YMD
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I            DS
     I                                        1   80W@YMD
     I                                        1   40W@YY
     I                                        5   60W@MM
     I                                        7   80W@DD
     I            DS
     I                                        1   60@@MDY
     I                                        1   20@@MM
     I                                        3   40@@DD
     I                                        5   60@@YY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#GCQ     KLIST
     C                     KFLD           D@D01
     C                     KFLD           D@D02
     C                     KFLD           D@D03
     C           K#AGD     KLIST
     C                     KFLD           W@YY
     C                     KFLD           W@MM
     C                     KFLD           W@DD
     C           K#GDI     KLIST
     C                     KFLD           S@D01
     C                     KFLD           S@D02
     C                     KFLD           S@D03
     C                     KFLD           S@D04
     C                     KFLD           H@DAT2
      *
     C                     Z-ADD*ZERO     @@RRN   40
     C                     Z-ADD*ZERO     WWRRN   40
     C                     MOVEL'01'      W@ID    2
      *
     C                     EXSR #SET
     C                     MOVE *OFF      *IN20
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA
      *------------------------------------------------------
     C           #SET      BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     X       30
     C                     MOVE *BLANK    ARY
      *
     C           *IN20     IFEQ *OFF
     C           *LOVAL    SETLLGDIPL40
     C                     ELSE
     C           *LOVAL    SETLLGDIPL41
     C                     ENDIF
      *
     C           *IN90     DOUEQ*ON
     C           *IN20     IFEQ *OFF
     C                     READ GDIPL40             N    90
     C                     ELSE
     C                     READ GDIPL41                  90
     C                     ENDIF
      *
     C           *IN90     IFEQ *OFF
     C                     CLEARSFL01
     C           DIORDT    IFLE *DATE
     C                     MOVE *ON       *IN11
     C                     ELSE
     C                     MOVE *OFF      *IN11
     C                     ENDIF
     C                     ADD  1         RRN1
     C                     Z-ADDRRN1      S@NBR
     C                     MOVELDIKAT1    S@D01
     C                     MOVELDIKAT2    S@D02
     C                     MOVELDIKAT3    S@D03
     C                     MOVELDIKAT4    S@D04
     C                     Z-ADDDIOQTY    S@QTY
     C                     Z-ADDDIORDT    H@DAT2
     C                     Z-ADDDIASDT    H@DAT1
     C                     Z-ADDH@DAT1    W@YMD
     C                     Z-ADDW@YY      @@YY
     C                     Z-ADDW@MM      @@MM
     C                     Z-ADDW@DD      @@DD
     C                     Z-ADD@@MDY     S@DAT1
     C                     Z-ADDH@DAT2    W@YMD
     C                     Z-ADDW@YY      @@YY
     C                     Z-ADDW@MM      @@MM
     C                     Z-ADDW@DD      @@DD
     C                     Z-ADD@@MDY     S@DAT2
     C                     WRITESFL01
      *
     C                     ADD  1         X
     C                     MOVE S@D01     WD01
     C                     MOVE S@D02     WD02
     C                     MOVE S@D03     WD03
     C                     MOVE S@D04     WD04
     C                     Z-ADDH@DAT2    WDAT
     C                     MOVE WARY      ARY,X
     C           WARY      IFLE @@ARY
     C                     Z-ADDRRN1      @@RRN
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           RRN1      IFEQ *ZERO
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDIF
      *
     C           @@RRN     IFEQ *ZERO
     C                     Z-ADD1         #RCNO
     C                     ELSE
     C                     Z-ADD@@RRN     #RCNO
     C                     ENDIF
      *
     C**                   Z-ADD#RCNO     WWRRN
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE *OFF      *IN02
     C           *IN20     IFEQ *OFF
     C                     MOVELCMD,1     D@CMD
     C                     ELSE
     C                     MOVELCMD,3     D@CMD
     C                     ENDIF
      *
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     WRITECTL01
     C                     MOVE *OFF      *IN51
      *
     C                     EXFMTDSP01
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     #RCNO
     C                     ENDIF
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKH     WHEQ *ON
     C           *IN20     IFEQ *OFF
     C                     MOVE *ON       *IN20
     C                     ELSE
     C                     MOVE *OFF      *IN20
     C                     ENDIF
     C                     Z-ADD*ZERO     @@RRN
     C                     EXSR #SET
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     MOVE '02'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
      *
     C           D@OPT     IFLT '0'
     C           D@OPT     ORGT '2'
     C                     SETON                     6199
     C                     MOVE ERR,1     D@MSG
     C                     ENDIF
      *
     C           D@NBR2    IFEQ *ZERO
     C           D@NBR     ANDNE*ZERO
     C                     Z-ADDD@NBR     D@NBR2
     C                     ENDIF
      *
     C                     SELEC
      * ADD
     C           D@OPT     WHEQ '2'
     C                     CLEARDSP02
      * CHANGE
     C           D@OPT     WHEQ '1'
     C           D@NBR     ANDNED@NBR2
     C                     SETON                     63
     C  N99                MOVE ERR,6     D@MSG
     C                     MOVE *ON       *IN99
      * DELETE
     C           D@OPT     WHEQ '0'
     C           D@NBR     IFGT D@NBR2
     C                     SETON                     6263
     C  N99                MOVE ERR,2     D@MSG
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     ENDSL
      *
     C           D@OPT     IFNE '2'
     C           D@NBR     IFEQ *ZERO
     C                     SETON                     6162
     C  N99                MOVE ERR,1     D@MSG
     C                     MOVE *ON       *IN99
     C                     ELSE
      *
     C           D@NBR2    CHAINSFL01                90
     C           *IN90     IFEQ *ON
     C           S@NBR     OREQ *ZERO
     C                     SETON                     63
     C  N99                MOVE ERR,2     D@MSG
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C           D@NBR     CHAINSFL01                90
     C           *IN90     IFEQ *ON
     C           S@NBR     OREQ *ZERO
     C                     SETON                     62
     C  N99                MOVE ERR,2     D@MSG
     C                     MOVE *ON       *IN99
     C                     ELSE
     C                     Z-ADDS@NBR     @@RRN
     C                     Z-ADDS@NBR     #RCNO
     C                     MOVE S@D01     D@D01
     C                     MOVE S@D02     D@D02
     C                     MOVE S@D03     D@D03
     C                     MOVE S@D04     D@D04
     C                     Z-ADDS@QTY     D@QTY
     C                     Z-ADDH@DAT1    D@DAT1
     C                     Z-ADDH@DAT2    D@DAT2
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C           D@OPT     LOKUPTAB1      TAB2           10
     C                     MOVELTAB2      D@MODE
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVE *ON       *IN02
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     WRITECTL01
     C                     MOVE *OFF      *IN51
      *
     C                     WRITEDSP01
     C                     EXFMTDSP02
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
     C                     EXSR #CLR
      *
     C                     OTHER
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C           D@OPT     IFGE '1'
     C                     EXSR #UPD
     C                     ELSE
     C                     EXSR #DLT
     C                     ENDIF
      *
     C                     EXSR #SET
     C                     CLEARDSP01
     C                     MOVE '01'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     EXSR #CLR
     C           K#GCQ     CHAINGCQPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6399
     C                     MOVE ERR,3     D@MSG
     C                     ENDIF
      *
     C           D@QTY     IFEQ *ZERO
     C                     SETON                     6699
     C                     ENDIF
      *
     C                     Z-ADDD@DAT1    W@YMD
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     64
     C  N99                MOVE ERR,4     D@MSG
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     Z-ADDD@DAT2    W@YMD
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     65
     C  N99                MOVE ERR,4     D@MSG
     C                     MOVE *ON       *IN99
     C                     ELSE
     C           D@OPT     IFNE '0'
     C           D@DAT2    ANDLT*DATE
     C                     SETON                     65
     C  N99                MOVE ERR,4     D@MSG
     C                     MOVE *ON       *IN99
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVE D@D01     WD01
     C                     MOVE D@D02     WD02
     C                     MOVE D@D03     WD03
     C                     MOVE D@D04     WD04
     C                     Z-ADDD@DAT2    WDAT
     C                     Z-ADD1         X
     C           WARY      LOKUPARY,X                    10
     C           *IN10     IFEQ *ON
     C           @@RRN     ANDNE*ZERO
     C           X         ANDNE@@RRN
     C  N99                MOVE ERR,5     D@MSG
     C                     MOVE *ON       *IN99
     C                     SETON                         6365
     C                     ELSE
     C                     MOVE WARY      @@ARY  16
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   UPDATE
      *------------------------------------------------------
     C           #UPD      BEGSR
      *
     C           D@OPT     IFNE '2'
     C           K#GDI     CHAINGDIPL40              90
      * CHANGE
     C           *IN90     IFEQ *OFF
     C                     MOVE D@D01     DIKAT1
     C                     MOVE D@D02     DIKAT2
     C                     MOVE D@D03     DIKAT3
     C                     MOVE D@D04     DIKAT4
     C                     Z-ADDD@QTY     DIOQTY
     C                     Z-ADDD@DAT1    DIASDT
     C                     Z-ADDD@DAT2    DIORDT
     C                     Z-ADD*DATE     DIKODT
     C                     TIME           DIKOTM
     C                     MOVEL#USER     DIKOME
     C                     UPDATGDIPP401
     C                     ENDIF
      *
     C                     ELSE
      * ADD
     C                     CLEARGDIPP401
     C                     MOVE D@D01     DIKAT1
     C                     MOVE D@D02     DIKAT2
     C                     MOVE D@D03     DIKAT3
     C                     MOVE D@D04     DIKAT4
     C                     Z-ADDD@QTY     DIOQTY
     C                     Z-ADDD@DAT1    DIASDT
     C                     Z-ADDD@DAT2    DIORDT
     C                     Z-ADD*DATE     DIKODT
     C                     TIME           DIKOTM
     C                     MOVEL#USER     DIKOME
     C                     WRITEGDIPP401
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   DELETE
      *------------------------------------------------------
     C           #DLT      BEGSR
      *
     C                     Z-ADDD@NBR     X       30
     C           *IN90     DOUEQ*ON
     C           X         CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           K#GDI     CHAINGDIPL40              95
     C           *IN95     IFEQ *OFF
     C                     MOVE 'D'       DISKJY
     C                     Z-ADD*DATE     DISKDT
     C                     Z-ADD*DATE     DIKODT
     C                     TIME           DIKOTM
     C                     MOVEL#USER     DIKOME
     C                     UPDATGDIPP401
     C                     ENDIF
     C                     ADD  1         X
     C           X         IFGT D@NBR2
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
**  CMD
F1: END     F8: SORT BY ORDER DATE
F1: END     F5: UPDATE      F12: GO BACK
F1: END     F8: SORT BY DIE CODE
**  ERR
OPTION ERROR
# ERROR
DIE# ERROR
DATE ERROR
DUPLICATE ERROR
OPTION 1 ALLOWS ONLY 1 LIN#.
**  TAB1 / TAB2
0DELETE
1CHANGE
2 ADD
