     H            Y.
     ** AB#RE0 ********************************************************
     *  CHECK AUDIT RECORD                                            *
     ******************************************************** AB#RAA **
     FAUDREC  IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *------------------------------------------------------------
     I            DS
     I                                        1   40W@TIME
     I                                        1   20W@HH
     I                                        3   40W@MN
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------------
      *   MAIN
      *------------------------------------------------------------
     C           *IN90     DOUEQ*ON
     C                     READ AUDREC                   90
     C           *IN90     IFEQ *OFF
     C           AFDSRS    IFNE 'S'
     C                     ITER
     C                     ENDIF
     C           AFDFID    IFEQ 'FA'
     C           AFDTID    OREQ '997'
     C                     ITER
     C                     ENDIF
     C           AFDTYP    IFNE 'T'
     C           AFDTYP    ANDNE'G'
     C                     ITER
     C                     ENDIF
      *
     C           AFDGCD    IFEQ 'R'
     C           AFDTAC    OREQ 'R'
     C                     EXSR #PRT
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           @ID     1
      *
     C                     Z-ADD*ZERO     @@DAT   70
     C                     Z-ADD*ZERO     @@TIM   40
     C                     MOVE *BLANK    @ID
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #PRT      BEGSR
      *-----------------------------------------------------
     C                     MOVE '1'       @ID
     C           *IN98     IFEQ *OFF
     C                     TIME           L@TIM   60
     C                     EXCPT@HED
     C                     MOVE *ON       *IN98
     C                     ENDIF
      * CONVERT
     C                     SELEC
     C           AFDTID    WHEQ '810'
     C                     MOVEL'-INVOICE'XFDTID  8
     C           AFDTID    WHEQ '856'
     C                     MOVEL'-ASN    'XFDTID
     C                     OTHER
     C                     MOVE *BLANK    XFDTID
     C                     ENDSL
      *
     C                     MOVELAFDGPT    @FDGPT 15
     C                     MOVELAFDTID    @FDTID  4
     C                     MOVELAFDIDF    @FDIDF 12
     C                     MOVELAFDTNB    @FDTNB  9
     C                     Z-ADDAFDCDT    L@DAT   60
JW1  C                     MOVELAFDCTM    L@TM2   40
      *
     C                     EXCPT@DTL
      *
     C                     ENDSR
      *-----------------------------------------------------
     OQPRINT  E   02           @HED
     O                         #PGM      10
     O                         UDATE Y   90
     O                         L@TIM    100 '  :  :  '
     O                                  104 'P.'
     O                         PAGE  Z  108
     O        E   03           @HED
     O                                   60 '< REJECTED EDI REPORT >'
     O        E   05           @HED
     O                                   12 'EDI PARTNER'
     O                                   25 'TRAN ID'
     O                                   46 'DOCUMENT_ID'
     O                                   59 'CREATE DATE'
     O                                   65 'TIME'
     O                                   75 'GRP ACK'
     O                                   87 'ACKNOWLEDGE'
     O                                   95 'NUMBER'
     O        E 2              @DTL
     O                         @FDGPT    16
     O                         @FDTID    22
     O                         XFDTID    30
     O                         @FDIDF    48
     O                         L@DAT     57 '  /  /  '
     O                         L@TM2     66 '  :  '
      *
     O                         AFDGCD    72
     O                         AFDTAC    82
     O                         @FDTNB    98
