     O                         W@LIN2    80
     O        E 1              @HDR
     O                         WADD3     35
     O                         W@LIN3    80
     O        E 1              @HDR
     O                         WADD4     35
     O        E 1              @HDR
     O                    31             22 '6.ULTIMATE COSIGNEE'
     O                                   56 '7.TRANSPORTATION'
     O        E 1              @HDR
     O                    31             27 '  COSWORTH LIMITED      '
     O                   N31             56 ' '
     O        E 1              @HDR
     O                    31             27 '  44ST. JAMES MILL RD   '
     O                         PTRAN     72
     O        E 1              @HDR
     O                    31             29 'NORTH HAMPTON NH NN5 5RA'
     O                   N31             56 ' '
     O        E 2              @HDR
     O                                   18 '8.CONDITIONS OF'
