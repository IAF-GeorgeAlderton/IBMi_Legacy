     O                                   45 '3.ASN'
     O                         BCINVN    66
     O        E 2              @HDR
     O                                   14 '4.CONSIGNEE'
     O                                   61 '5.PURCHASERS NAME AND'
     O                                   69 'ADDRESS'
     O        E 1              @HDR
     O                         WADD1     35
