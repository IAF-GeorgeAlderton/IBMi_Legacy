     C                     EXSR #INIT
     C*
     C                     DO   *HIVAL
     C                     EXFMTDSP01
     C                     SETOF                     414243
     C                     SETOF                     444546
     C                     SETOF                     474849
     C                     MOVE *OFF      *IN85
     C                     MOVE *BLANK    XMSG
     C* F3: END
     C           *INKC     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C                     EXSR #CHK1
     C           *IN85     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD1
     C                     ENDIF
     C*
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      * CHECK SCREEN5 DATA
      *===============================================================
     C           #CHK1     BEGSR
     C*--------------------
     C           XTOKU     IFEQ 0
     C                     SETON                     85  41
     C                     MOVELMSG,2     XMSG
     C                     GOTO @CHK1
     C                     ENDIF
     C*
     C           XNONY     IFEQ 0
     C                     SETON                     85  42
     C                     MOVELMSG,3     XMSG
     C                     GOTO @CHK1
     C                     ENDIF
     C*
     C           XSHDT     IFEQ 0
     C                     SETON                     85  43
     C                     MOVELMSG,4     XMSG
     C                     GOTO @CHK1
     C                     ENDIF
     C*
     C           XBNOLD    IFEQ 0
     C                     SETON                     85  44
     C                     MOVELMSG,7     XMSG
     C                     GOTO @CHK1
     C                     ENDIF
     C*
     C           XBNNEW    IFEQ 0
     C                     SETON                     85  45
     C                     MOVELMSG,8     XMSG
     C                     GOTO @CHK1
     C                     ENDIF
     C*
     C           XBNOLD    IFEQ XBNNEW
     C                     SETON                     85  45
     C                     MOVELMSG,11    XMSG
     C                     GOTO @CHK1
     C                     ENDIF
     C* CHECK ORDER
     C           K#PL10    KLIST
     C                     KFLD           XTOKU
     C                     KFLD           XNONY
     C                     KFLD           XNOYY
     C                     KFLD           XNOMM
     C                     KFLD           XNODD
      *
     C                     Z-ADD0         PP10R   40
     C                     MOVE *OFF      *IN95
     C           K#PL10    SETLLAB#PL10
     C           *IN95     DOWEQ*OFF
     C           K#PL10    READEAB#PL10                  95
     C           *IN95     IFEQ *OFF
     C           BASKJY    ANDNE'D'
      * BIN#
     C           XBNOLD    IFNE BANOBN
     C                     ITER
     C                     ENDIF
      * FACT
     C           XNKOJ     IFNE *BLANK
     C           XNKOJ     ANDNEBANKOJ
     C                     ITER
     C                     ENDIF
      * DOCK
     C           XNUKE     IFNE *BLANK
     C           XNUKE     ANDNEBANUKE
     C                     ITER
     C                     ENDIF
      * PO#
     C           XODRN     IFNE *BLANK
     C           XODRN     ANDNEBAODRN
     C                     ITER
     C                     ENDIF
      * INVOICE
     C           XINVN     IFNE *BLANK
     C           XINVN     ANDNEBAINVN
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         PP10R
     C                     ENDIF
     C                     ENDDO
     C*
     C           PP10R     IFEQ 0
     C                     SETON                     85
     C                     MOVELMSG,9     XMSG
     C                     GOTO @CHK1
     C                     ENDIF
      * IF NO ERROR...
     C                     MOVELMSG,10    XMSG
      *
     C           @CHK1     ENDSR
      *===============================================================
      *  UPDATE
      *===============================================================
     C           #UPD1     BEGSR
      *
     C                     Z-ADDXBNOLD    XBIN    20
