     H            Y.
     F** AB#R2K ***********************************************************
     F*  CONVERT NUMERIC -> CHARCTER(SHIT TO THE LEFT)                    *
     F*  TCH 2000.07.19                                                   *
     F*                                                                   *
     F******************************************************* AB#R2K ******
     E                    IN         30  1 0
     E                    OUT        30  1
     F******************************************************************
     I*
     I            DS
     I                                        1  300IN
     I                                        1  300WPIN
     C           *ENTRY    PLIST
     C                     PARM           PIN    300
     C                     PARM           POUT   30
      *
     C                     Z-ADDPIN       WPIN
     C                     MOVE *BLANK    OUT
     C                     SETOF                     90
     C                     Z-ADD*ZERO     I       20
     C                     Z-ADD*ZERO     M       20
     C* SERCH FIRST
     C           *IN90     DOUEQ'1'
     C                     ADD  1         I
     C           I         IFGT 30
     C                     MOVE *ZERO     OUT,1
     C                     GOTO #END
     C                     END
     C           IN,I      IFNE *ZERO
     C                     SETON                     90
     C                     END
     C                     END
      *
     C           I         DO   30        I
     C                     ADD  1         M
     C                     MOVE IN,I      OUT,M
     C                     END
      *
     C           #END      TAG
     C                     MOVEAOUT       POUT
      *
     C                     SETON                     LR
     C                     RETRN
