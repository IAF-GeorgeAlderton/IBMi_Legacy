     C*
     C                     EXSR @PRC01
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
     C******************************************************
     C           *INZSR    BEGSR
     C******************************************************
     C                     TIME           @TIME
     C                     TIME           @@DTTM
     C*
     C                     ENDSR
     C* -------------------------------------------------- *
     C*                                                    *
     C* -------------------------------------------------- *
     C           @PRC01    BEGSR
     C*
     C           *LOVAL    SETLLAAMPL11
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AAMPL11                  99
     C   99                LEAVE
     C           CKSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C*
     C                     MOVEL*BLANK    WKO
     C                     MOVEL*BLANK    WBM
     C                     MOVEL*BLANK    WBN
     C                     Z-ADD*ZERO     I       20
     C                     Z-ADD*ZERO     K       20
     C*
     C                     DO   *HIVAL
     C                     ADD  1         I
     C           I         IFGT 15
     C                     LEAVE
     C                     END
     C                     Z-ADDCGD,I     W@CGD
     C                     MOVELSKO,I     WKO,I
     C                     MOVELSBM,I     WBM,I
     C                     MOVELSBN,I     WBN,I
     C                     ENDDO
     C*
     C                     Z-ADD*ZERO     I
     C*
     C                     DO   *HIVAL
     C*
     C                     ADD  1         I
     C           I         IFGT 15
     C                     LEAVE
     C                     END
     C           WBM,I     IFEQ '0111'
     C           WBM,I     OREQ '0000'
     C           WBM,I     OREQ '8990'
     C           WBM,I     OREQ '2255'
     C           WBM,I     OREQ '    '
     C                     ITER
     C                     END
     C           WKO,I     IFEQ 'HN '
     C           WKO,I     OREQ 'KN '
     C                     ITER
     C                     END
     C*
     C                     MOVEL*BLANK    W@TKRO
     C                     MOVEL*BLANK    W@JBNT  6
     C                     EXSR SUBRTN
     C           W@JBNT    IFEQ '------'
     C           W@JBNT    OREQ '++++++'
     C           W@JBNT    OREQ '      '
     C                     ITER
     C                     END
     C           W@TKRO    IFEQ '------'
     C           W@TKRO    OREQ '++++++'
     C           W@TKRO    OREQ '      '
     C                     ITER
     C                     END
     C*
     C                     CLEARAFDWP911
     C                     MOVEL*BLANK    W@SHIN
     C                     MOVELCKHIN1    W@SHN1
     C           CKHIN2    IFNE *BLANK
     C                     MOVEL'-'       W@SHNA
     C                     END
     C                     MOVELCKHIN2    W@SHN2
     C           CKHIN3    IFNE *BLANK
     C                     MOVEL'-'       W@SHNB
     C                     END
     C                     MOVELCKHIN3    W@SHN3
     C                     MOVELW@SHIN    AWSHIN
     C                     MOVELWKO,I     AWPROC
     C                     MOVELWBM,I     AWBMON
     C                     MOVELW@TKR1    A@LOC1
     C                     MOVELW@TKR2    A@LOC2
     C                     MOVELW@TKR3    A@LOC3
     C                     MOVELW@TKR4    A@LOC4
     C                     MOVEL'-'       A@LOCA
     C                     MOVEL'-'       A@LOCB
     C                     MOVEL'-'       A@LOCC
     C                     MOVELA@LOC     AWLOC
     C*
     C                     WRITEAFDWP911
     C*
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*
     C* -------------------------------------------------- *
     C*                                                    *
     C* -------------------------------------------------- *
     C           SUBRTN    BEGSR
     C*
     C                     DO
     C*
     C           WKO,I     IFEQ 'SD '
     C           I         IFGT 1
     C           I         SUB  1         J       20
     C                     EXSR SUB#2
     C           W@TKRO    IFNE *BLANK
     C                     LEAVE
     C                     END
     C                     END
     C                     END
     C*
     C           WBM,I     IFEQ '6666'
     C                     MOVELWBN,I     W@JBNT
     C                     EXSR #IK
     C                     LEAVE
     C                     END
     C*
     C           WKO,I     IFEQ 'NP '
     C           I         IFGT 1
     C           I         SUB  1         J       20
     C                     EXSR SUB#1
     C           W@TKRO    IFNE *BLANK
     C                     LEAVE
     C                     END
     C                     END
     C                     END
     C*
     C                     MOVELWBN,I     W@JBNT
     C                     EXSR #IK
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C* -------------------------------------------------- *
     C*                                                    *
     C* -------------------------------------------------- *
     C           SUB#1     BEGSR
     C*
     C                     DO   *HIVAL
     C*
     C           WBN,J     IFEQ '------'
     C           WBN,J     OREQ '++++++'
     C                     SUB  1         J
     C           J         IFLT 1
     C                     MOVEL*BLANK    W@TKRO
     C                     LEAVE
     C                     ELSE
     C                     ITER
     C                     END
     C                     END
     C*
     C           WBM,J     IFEQ '0111'
     C           WKO,J     ANDEQ'DSM'
     C                     MOVELWBN,I     W@JBNT
     C                     EXSR #IK
     C                     ELSE
     C                     MOVELWBN,J     W@JBNT
     C                     EXSR #JK
     C                     END
     C* %0001 CHECK PREVIOUS DEPARTMENT OF NP
     C           WBM,J     IFEQ '0111'
     C                     MOVELWBN,I     W@JBNT
     C                     EXSR #IK
     C                     ENDIF
     C*
     C                     LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*
     C* -------------------------------------------------- *
     C*                                                    *
     C* -------------------------------------------------- *
     C           SUB#2     BEGSR
     C*
     C           WBM,J     IFEQ '0111'
     C           WKO,J     ANDEQ'DSM'
     C                     MOVELWBN,I     W@JBNT
     C                     EXSR #IK
     C                     ELSE
     C                     MOVELWBN,J     W@JBNT
     C                     EXSR #JK
     C                     END
     C*
     C* %0001 CHECK PREVIOUS DEPARTMENT OF SD
     C           WBM,J     IFEQ '0111'
     C                     MOVELWBN,I     W@JBNT
     C                     EXSR #IK
     C                     ENDIF
     C*
     C*
     C                     ENDSR
     C*******************************************************
     C           #IK       BEGSR
     C*******************************************************
     C                     Z-ADDI         K
     C*
     C                     DO   *HIVAL
     C*
     C                     SUB  1         K
     C           WBN,K     IFEQ '------'
     C           WBN,K     OREQ '++++++'
     C           K         IFLE 1
     C                     MOVEL*BLANK    W@TKRO
     C                     LEAVE
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C                     ENDIF
     C*
     C                     MOVELWBN,K     W@TKRO
     C                     LEAVE
     C                     ENDDO
     C*
     C                     ENDSR
     C*******************************************************
     C           #JK       BEGSR
     C*******************************************************
     C           J         IFEQ 1
     C                     MOVEL*BLANK    W@TKRO
     C                     GOTO JKEND
     C                     ENDIF
     C*
     C                     Z-ADDJ         K
     C                     DO   *HIVAL
     C*
     C                     SUB  1         K
     C           WBN,K     IFEQ '------'
     C           WBN,K     OREQ '++++++'
     C           K         IFLE 1
     C                     MOVEL*BLANK    W@TKRO
     C                     LEAVE
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C                     ENDIF
     C*
     C                     MOVELWBN,K     W@TKRO
     C                     LEAVE
     C                     ENDDO
     C*
     C           JKEND     ENDSR
