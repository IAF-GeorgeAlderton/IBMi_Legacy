     H            Y.
     F*** FCER93 *********************************
     F* INQUIRY OF COUNTING PART NO BY LOCATION  *
     F* H.ITO                1992.01.16          *
     F********************************* FCER93 ***
     FFCEPP01 IP  E                    DISK
     FALAPP06 IF  E           K        DISK
     FFCEPW93 CF  E                    WORKSTN
     FFCEWP93 O   F      64            DISK
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     I            DS
     I                                        1   80TQSKHZ
     I                                        1   40TQSKYY
     I                                        5   60TQSKMM
     I                                        7   80TQSKDD
     I            DS
     I                                        1   80A2TRHZ
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
     C*
     C  N10                Z-ADD0         HCNT    50
     C* N10                Z-ADD0         GCNT    50
     C  N10                SETON                       10
     C*
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    CABLE*DATE     END
     C                     END
     C*
     C           #KEY1     KLIST
     C                     KFLD           @TKR1
     C                     KFLD           @TKR2
     C                     MOVE *BLANK    @TKR1   1
     C                     MOVE *BLANK    @TKR2   2
     C*
     C           A2TRHZ    IFLT *DATE
     C                     MOVE A2STRK    @TKR1
     C                     MOVE A2STRT    @TKR2
     C                     ELSE
     C                     MOVE A2KTRK    @TKR1
     C                     MOVE A2KTRT    @TKR2
     C                     END
     C*
     C                     SETOF                     30
     C           #KEY1     CHAINALAPP061             30
     C           *IN30     IFEQ '0'
     C           TQSKJY    ANDEQ'D'
     C           TQSKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '0'
     C*          TQYSCD    IFEQ '1'
     C*          TQYSCD    OREQ '3'
     C                     ADD  1         HCNT
     C*                    ELSE
     C*          TQYSCD    IFEQ '2'
     C*                    ADD  1         GCNT
     C*                    END
     C*                    END
     C                     END
     C           END       TAG
     C*
     CLR                   EXFMTFCEPW931
     C*
     CLR                   EXCPTALAWTR
     C*
     OFCEWP93 E                ALAWTR
     O                                   15 'IAF  --------->'
     O                         HCNT  1   23
     O*                                  15 'HEADQUATERS -->'
     O*                        HCNT  1   23
     O*                                  37 'GOJYOGAWA -->'
     O*                        GCNT  1   45
