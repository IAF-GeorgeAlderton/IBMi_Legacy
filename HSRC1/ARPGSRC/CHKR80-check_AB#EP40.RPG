     H            Y.
     F** CHKR80 ****************************************************************
     F*  PROGRAM    : CHECK AB#EP40                                            *
     F*  WRITTEN    : 5/6/2020                                                *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#EP40 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      **************************************************************************
     E                    MSG     1   1 50
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           *LOVAL    SETLLAB#EP40
     C                     DO   *HIVAL
     C                     READ AB#EP40                  98
     C   98                LEAVE
      * TTAI PO#
     C                     MOVE *OFF      *IN85
     C                     SELEC
     C           ENONY     WHEQ '3511'
     C           EODRN     ANDNE'75237  '
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,1     XMSG
     C                     MOVE '75237  ' XMSG
     C           ENONY     WHEQ '3512'
     C           EODRN     ANDNE'1036   '
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,1     XMSG
     C                     MOVE '1036   ' XMSG
     C           ENONY     WHEQ '3550'
     C           EODRN     ANDNE'541    '
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,1     XMSG
     C                     MOVE '541    ' XMSG
     C           ENONY     WHEQ '3556'
     C           EODRN     ANDNE'7569   '
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,1     XMSG
     C                     MOVE '7569   ' XMSG
     C                     ENDSL
      *
     C           *IN85     IFEQ *ON
     C                     EXSR #PRINT
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      * PRINT HEADER
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD4         LIN#
     C                     ENDIF
      * PRINT DETAIL
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C                     TIME           @SDATE
     C                     Z-ADD0         SEQ#    40
     C                     MOVE *BLANK    XMSG   50
     C                     Z-ADD80        LIN#    50
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** CHECK ORDER REPOR'
     O                                   60 'T **                '
     O                                   99 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                         PAGE  Z  109
     O                                  106 'P.'
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   11 'CUST'
     O                                   17 'DELV'
     O                                   27 'SHP_DATE'
     O                                   34 'BN#'
     O                                   36 'F'
     O                                   41 'DOCK'
     O                                   49 'ORDER#'
     O                                   61 'SERIAL#'
     O                                   67 'MSG'
     O        E   04           @HDR
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O                                  120 '--------------------'
     O                                  130 '----------'
     O        E 1              @DTL
     O                         SEQ#  Z +001
     O                         ETOKU   +002
     O                         ENONY   +002
     O                         ENDATE  +002 '    /  /  '
     O**                       P8BINN  +002
     O                         ENKOJ   +002
     O                         ENUKE   +002
     O                         EODRN   +001
     O                         EMHIN   +001
     O                         ESRYO   +001
     O                         XMSG    +001
      *
** MSG ..1.........2.........3.........4.........5
TTAI ORDER# IS IRREGULAR !    S/B-->
