     H            Y.
     F** UEXR32 *********************************************
     F*  PROGRAM: CHECK APICS1/2/3 STATUS                   *
     F*  WRITTEN: T.SAKAKI      2020.09.09                  *
     F*-----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UEXR32'
     F*                    PARM           $SHN1   5
     F*                    PARM           $SHN2   5
     F*                    PARM           $SHN3   2
     F*                    PARM           $DATE   80
     F*                    PARM           $TYPE   2
     F*                    PARM           $RTN    1
     F*  IN  $SHN1 :  5A IAF PART1
     F*      $SHN2 :  5A IAF PART2
     F*      $SHN3 :  2A IAF PART3
     F*      $DATE :  8S STANDARD DATE
     F*  OUT $TYPE :  2A TYPE (A1:APICS1 A2:APICS2 A3:APICS3)
     F*      $RTN  :  1A RETURN CODE (Y:OK , N:NG)
     F******************************************************
     FAGAPL31 IF  E           K        DISK
     FCABPL01 IF  E           K        DISK
      *===================================================
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      *
     C                     MOVEL'A1'      $TYPE
     C                     MOVEL'N'       $RTN
     C                     MOVEL'  '      $HNTE   2
      *
      * A-PICS1
     C           K#SHN     CHAINAGAPL31              97
     C           *IN97     IFEQ *OFF
     C           CBSKJY    ANDEQ*BLANK
     C                     MOVEL'*'       $HNTE
     C                     ENDIF
      * A-PICS2
     C                     MOVEL*BLANK    W3TYPE  2
     C           K#SHN     CHAINCABPL01              98
     C           *IN98     IFEQ *OFF
     C           C3SKJY    ANDEQ*BLANK
     C                     MOVE '*'       $HNTE
     C                     MOVELC3TYPE    W3TYPE
     C                     ENDIF
      *
     C                     SELEC
     C*  A-PICS1
     C           $HNTE     WHEQ '* '
     C                     MOVEL'A1'      $TYPE
     C                     MOVEL'Y'       $RTN
     C*  A-PICS2
     C           $HNTE     WHEQ ' *'
     C                     MOVEL'A2'      $TYPE
     C                     MOVEL'Y'       $RTN
     C*  A-PICS2 OR 3
     C           $HNTE     WHEQ '**'
     C*
     C           W3TYPE    IFEQ 'A2'
     C                     MOVEL'A2'      $TYPE
     C                     MOVEL'Y'       $RTN
     C                     ENDIF
     C           W3TYPE    IFEQ 'A3'
     C                     MOVEL'A3'      $TYPE
     C                     MOVEL'Y'       $RTN
     C                     ENDIF
      * NG
     C                     OTHER
     C                     MOVEL'N'       $RTN
     C                     ENDSL
      *
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SHN1   5
     C                     PARM           $SHN2   5
     C                     PARM           $SHN3   2
     C                     PARM           $DATE   80
     C                     PARM           $TYPE   2
     C                     PARM           $RTN    1
      *
     C           K#SHN     KLIST
     C                     KFLD           $SHN1   5
     C                     KFLD           $SHN2   5
     C                     KFLD           $SHN3   2
      *
     C                     ENDSR
