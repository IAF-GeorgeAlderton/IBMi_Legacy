     C           1         DO   15        X
     C                     MOVELNUKH,X    WUKH    80
     C           WUKH      IFGT @UHZ
     C           OKOT,X    IFNE *BLANK
     C                     ADD  1         L
     C                     MOVE OKOT,X    AKT,L
     C                     END
     C                     ELSE
     C           NKOT,X    IFNE *BLANK
     C                     ADD  1         L
     C                     MOVE NKOT,X    AKT,L
     C                     END
     C                     END
     C                     END
      *
     C                     END
