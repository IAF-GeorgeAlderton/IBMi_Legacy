     C           *ENTRY    PLIST
     C                     PARM           PBMN    4        部門
     C                     PARM           PHN1    5        品番・１
     C                     PARM           PHN2    5        　　・２
     C                     PARM           PHN3    2        　　・３
     C                     PARM           PKS1    1        計算区分１
     C                     PARM           PKS2    1        　　　　２
     C                     PARM           PKTS    9        確定設定数
     C                     PARM           PSYU    7        自工程収容数
     C                     PARM           PGLT    4        合計Ｌ・Ｔ
     C                     PARM           PANZ    3        安全率
     C                     PARM           PBRA    3        バラツキ箱数
     C                     PARM           PSET    3        セット数
     C                     PARM           PALT    2        後工程ロット
     C                     PARM           PBN1    1        所番地・１
     C                     PARM           PBN2    2        　　　・２
     C                     PARM           PBN3    2        　　　・３
     C                     PARM           PBN4    1        　　　・４
     C                     PARM           PUYY    4        有効日　年
     C                     PARM           PUMM    2        有効日　月
     C                     PARM           PUDD    2        有効日　日
     C                     PARM           PUBN    2        有効日　便
     C                     PARM           PKJY    3        基準値
     C                     PARM           PLOT    3        生産ロット
     C                     PARM           PMIS    3        かんばん枚数
     C                     PARM           PERR    1        エラー
      *
     C                     MOVELPBMN      WBMN    40
     C                     MOVELPHN1      WHN1    5
     C                     MOVELPHN2      WHN2    5
     C                     MOVELPHN3      WHN3    2
     C                     MOVELPKS1      WKS1    1
     C                     MOVELPKS2      WKS2    1
     C                     MOVELPKTS      WKTS    90
     C                     MOVELPSYU      WSYU    70
     C                     MOVELPGLT      WGLT    42
     C                     MOVELPANZ      WANZ    32
     C                     MOVELPBRA      WBRA    30
     C                     MOVELPSET      WSET    30
     C                     MOVELPALT      WALT    20
     C                     MOVELPBN1      WBN1    1
     C                     MOVELPBN2      WBN2    2
     C                     MOVELPBN3      WBN3    2
     C                     MOVELPBN4      WBN4    1
     C                     MOVELPUYY      WUYY    40
     C                     MOVELPUMM      WUMM    20
     C                     MOVELPUDD      WUDD    20
     C                     MOVELPUBN      WUBN    20
     C                     MOVELPKJY      WKJY    30
     C                     MOVELPLOT      WLOT    30
     C                     MOVELPMIS      WMIS    30
     C                     MOVELPERR      WERR    1
      ****************************************************************
      *  KEY                                                 MAIN    *
      ****************************************************************
     C           KEY1      KLIST
     C                     KFLD           WBN1
     C                     KFLD           WBN2
     C                     KFLD           WBN3
     C                     KFLD           WBN4
      *
     C           KEY2      KLIST
     C                     KFLD           WBMN
     C                     KFLD           WKS2
      *
     C           KEY3      KLIST
     C                     KFLD           WHN1
     C                     KFLD           WHN2
     C                     KFLD           WHN3
      *
     C           KEY4      KLIST
     C                     KFLD           @BNT1
     C                     KFLD           @BNT2
     C                     KFLD           @BNT3
     C                     KFLD           @BNT4
      ****************************************************************
      * 計算式の振り分け      恵那工場  ---> ESUB        MAIN    *
      *                         岐阜工場  ---> GSUB                *
      *                         本社工場  ---> HSUB                *
      *                         五条川工場---> JSUB                *
      *                 ＩＡＦ・可児工場  ---> KSUB                *
      *                         熊本工場  ---> MSUB                *
      ****************************************************************
     C           WBMN      IFEQ 8974
     C                     EXSR ESUB
     C                     END
     C           WBMN      IFEQ 8982
     C                     EXSR GSUB
     C                     END
     C           WBMN      IFEQ 8990
     C                     EXSR HSUB
     C                     END
     C           WBMN      IFEQ 9024
     C*********            EXSR JSUB
     C                     END
     C           WBMN      IFEQ 9032
     C           WBMN      OREQ 9040
     C           WBMN      OREQ 9245
     C           WBMN      OREQ 9253
     C           WBMN      OREQ 0111
     C                     EXSR KSUB
     C                     END
     C           WBMN      IFEQ 9431
     C                     EXSR MSUB
     C                     END
      * MOVE *
     C                     MOVELWBMN      PBMN
     C                     MOVELWHN1      PHN1
     C                     MOVELWHN2      PHN2
     C                     MOVELWHN3      PHN3
     C                     MOVELWKS1      PKS1
     C                     MOVELWKS2      PKS2
     C                     MOVELWKTS      PKTS
     C                     MOVELWSYU      PSYU
     C                     MOVELWGLT      PGLT
     C                     MOVELWANZ      PANZ
     C                     MOVELWBRA      PBRA
     C                     MOVELWSET      PSET
     C                     MOVELWALT      PALT
     C                     MOVELWBN1      PBN1
     C                     MOVELWBN2      PBN2
     C                     MOVELWBN3      PBN3
     C                     MOVELWBN4      PBN4
     C                     MOVELWUYY      PUYY
     C                     MOVELWUMM      PUMM
     C                     MOVELWUDD      PUDD
     C                     MOVELWUBN      PUBN
     C                     MOVELWKJY      PKJY
     C                     MOVELWLOT      PLOT
     C                     MOVELWMIS      PMIS
     C                     MOVELWERR      PERR
      *
     C                     SETON                     LR
     C                     RETRN
      *==============================================================*
      *                                                              *
      * 恵那工場の計算                                    SUB-1    *
      *                                                              *
      *==============================================================*
     C           ESUB      BEGSR
      *
     C           WKS1      IFEQ 'E'
     C           WKS1      OREQ 'F'
     C           WKS1      OREQ 'Y'
     C                     GOTO SEND1
     C                     END
      *
     C           WKS1      IFNE 'S'
     C           WKS1      ANDNE'R'
     C                     MOVE '4'       WERR
     C                     GOTO SEND1
     C                     END
      *日当り箱数*
     C                     Z-ADD0         WRK1   103
     C                     Z-ADD0         @D      73
     C           WKTS      DIV  20        WRK1
     C           WSYU      IFNE 0
     C           WRK1      DIV  WSYU      @D        H
     C                     END
      *引取単位*
     C                     Z-ADDWALT      @H      50
      *仮ロット*
     C                     Z-ADD0         @KLOT   30
     C           WKS2      IFNE 'Z'
     C                     SETOF                     30
     C           KEY2      CHAINBAHPL011             30
     C           *IN30     IFEQ '0'
     C           BASKJY    ANDEQ'D'
     C**JW       BASKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
      *
     C           *IN30     IFEQ '1'
     C                     MOVE '5'       WERR
     C                     GOTO SEND1
     C                     ELSE
      *
     C                     Z-ADD1         A       20
     C           1         DO   8         A
     C           HIU,A     IFNE 0
     C           HIS,A     ANDEQ0
     C                     Z-ADD99.99     HIS,A
     C                     END
     C                     END
      *
     C                     SETOF                     30
     C                     Z-ADD1         A       20
     C           1         DO   8         A
     C           HIU,A     IFLE @D
     C           HIS,A     IFGT @D
     C           HIS,A     OREQ 99.99
     C                     Z-ADDLOT,A     @KLOT
     C                     SETON                     30
     C                     END
     C                     END
     C  N30                END
      *
     C                     END
     C                     END
      ****************************************************************
      * 計算区分（１）＝＂Ｓ＂又は＂Ｒ＂                           *
      ****************************************************************
     C           WKS1      IFEQ 'S'
     C           WKS1      OREQ 'R'
      ****************************************************************
      * 計算区分（２）＝ロット管理マスターの区分コードと同じコード *
      ****************************************************************
      **********
      *基準値*
      **********
     C           WKS2      IFNE 'Z'
     C                     Z-ADD0         WKJY
     C                     Z-ADD0         WRK3    93
     C                     Z-ADD0         WRK3A   70
      *
     C           @D        MULT WGLT      WRK3
     C                     MULT WANZ      WRK3
     C                     Z-ADDWRK3      WRK3B   93
      *
     C           @H        IFNE 0
     C                     DIV  @H        WRK3
     C                     END
     C           WRK3      ADD  .999      WRK3A
     C                     MULT @H        WRK3A
     C           WRK3A     ADD  WBRA      WKJY
      **************
      *生産ロット*
      **************
     C                     Z-ADD0         WLOT
     C                     Z-ADD0         WRK4    41
     C                     Z-ADD0         WRK5    30
      *
     C           @H        IFNE 0
     C           @KLOT     DIV  @H        WRK4
     C           WRK4      IFLT 1
     C                     Z-ADD1         WRK5
     C                     ELSE
     C                     Z-ADDWRK4      WRK5
     C                     END
     C           WRK5      MULT @H        WLOT
     C                     END
      *
     C           WLOT      IFLT 1
     C                     Z-ADD1         WLOT
     C                     END
     C                     Z-ADDWLOT      WWLOT   30
      *
     C           WLOT      IFLT WKJY
     C                     Z-ADDWKJY      WLOT
     C                     END
      ****************
      *かんばん枚数*
      ****************
     C                     Z-ADD0         WMIS
     C           WLOT      ADD  WKJY      WLOKJ   40
     C                     SUB  1         WLOKJ
      *
     C           WLOKJ     IFLE 21
     C                     Z-ADD1         WMIS
     C                     ELSE
      *
     C           WLOT      IFGE 21
     C                     Z-ADDWWLOT     WLOT
     C                     END
      *
     C                     Z-ADD0         WKJY
     C           WLOT      SUB  1         WLOTS1  30
     C           WRK3B     ADD  WLOTS1    WLOTS2  93
     C           WLOTS2    DIV  WLOT      WLOTS3  61H
      *
     C           WLOTS3    IFLT 2
     C                     Z-ADD2         WLOTS3
     C                     ELSE
     C                     ADD  0.6       WLOTS3
     C                     END
      *
     C           WLOTS3    ADD  WSET      WMIS
     C           WSET      IFNE 0
     C                     SUB  1         WMIS
     C                     END
     C                     END
      *
     C           WLOT      IFEQ 0
     C                     MOVE '6'       WERR
     C                     GOTO SEND1
     C                     END
      *
     C                     END
      ****************************************************************
      * 計算区分（２）＝＂Ｚ＂                                     *
      ****************************************************************
      **********
      *基準値*
      **********
     C           WKS2      IFEQ 'Z'
     C                     Z-ADD0         WKJY
     C                     Z-ADD0         WRK3    93
     C                     Z-ADD0         WRK3A   70
      *
     C           @D        MULT WGLT      WRK3
     C                     MULT WANZ      WRK3
     C                     Z-ADDWRK3      WRK3B
      *
     C           @H        IFNE 0
     C                     DIV  @H        WRK3
     C                     END
     C           WRK3      ADD  .999      WRK3A
     C                     MULT @H        WRK3A
     C           WRK3A     ADD  WBRA      WKJY
      ****************
      *かんばん枚数*
      ****************
     C                     Z-ADD0         WMIS
     C           WLOT      SUB  1         WLOTS1  30
     C           WRK3B     ADD  WLOTS1    WLOTS2  93
     C           WLOTS2    DIV  WLOT      WLOTS3  61H
      *
     C           WLOTS3    IFLT 2
     C                     Z-ADD2         WLOTS3
     C                     ELSE
     C                     ADD  0.6       WLOTS3
     C                     END
      *
     C           WLOTS3    ADD  WSET      WMIS
     C           WSET      IFNE 0
     C                     SUB  1         WMIS
     C                     END
      *
     C           WKJY      IFGT WLOT
     C                     Z-ADD0         WKJY
     C                     ELSE
      *
     C           WLOT      ADD  WKJY      WLOKJ   40
     C                     SUB  1         WLOKJ
      *
     C           WLOKJ     IFLE 21
     C                     Z-ADD1         WMIS
     C                     ELSE
     C                     Z-ADD0         WKJY
     C                     END
     C                     END
      *
     C           WLOT      IFEQ 0
     C                     MOVE '6'       WERR
     C                     END
      *
     C                     END
     C                     END
      *
     C           SEND1     ENDSR
      *==============================================================*
      *                                                              *
      * 岐阜工場の計算                                    SUB-2    *
      *                                                              *
      *==============================================================*
     C           GSUB      BEGSR
      *後工程ロット*
     C                     Z-ADD0         @ALOT
     C                     Z-ADD0         @WALOT
      *
     C           KEY1      SETLLAAJTL141
     C                     SETOF                     30
      *
     C                     DO   *HIVAL
     C           SSTP2     TAG
     C           KEY1      READEAAJTL141                 30
     C           *IN30     IFEQ '0'
     C           CJAKHZ    IFNE 0
     C           CJAKHZ    IFLE *DATE
     C                     GOTO SSTP2
     C                     END
     C                     END
     C           CJCHHZ    IFLT *DATE
     C                     GOTO SSTP2
     C                     END
      *
     C           CJSYUY    IFNE 0
     C           CJSLOT    DIV  CJSYUY    @WALOT
     C                     END
     C           @WALOT    IFGT @ALOT
     C                     Z-ADD@WALOT    @ALOT
     C                     END
     C                     END
     C  N30                END
      *
     C                     MULT 2         @ALOT
     C           @ALOT     IFLT 8
     C                     Z-ADD8         @ALOT
     C                     END
      *日当り箱数*
     C                     Z-ADD0         WRK1
     C                     Z-ADD0         @D
     C           WKTS      DIV  20        WRK1
     C           WSYU      IFNE 0
     C           WRK1      DIV  WSYU      @D        H
     C                     END
      ****************************************************************
      * 計算区分（１）＝＂Ｓ＂                                     *
      ****************************************************************
     C           WKS1      IFEQ 'S'
      **********
      *基準値*
      **********
     C           WKS2      IFNE 'Z'
     C                     Z-ADD0         WKJY
     C                     Z-ADD0         WRK11   62
      *
     C           @D        MULT 1.25      WRK11
     C                     MULT WGLT      WRK11
     C           WRK11     ADD  .99       WKJY
      **************
      *生産ロット*
      **************
     C                     Z-ADD@ALOT     WLOT
     C                     END
      ****************
      *かんばん枚数*
      ****************
     C                     Z-ADD1         WMIS
      *
     C                     END
      ****************************************************************
      * 計算区分（１）＝＂Ｒ＂                                     *
      ****************************************************************
     C           WKS1      IFEQ 'R'
      **********
      *基準値*
      **********
     C           WKS2      IFNE 'Z'
     C                     Z-ADD0         WKJY
      **************
      *生産ロット*
      **************
     C                     Z-ADD@ALOT     WLOT
     C                     END
      ****************
      *かんばん枚数*
      ****************
     C                     Z-ADD0         WMIS
     C                     Z-ADD0         WRK11   62
     C                     Z-ADD0         WRK12   30
      *
     C           @D        MULT 1.25      WRK11
     C                     MULT WGLT      WRK11
     C           WLOT      SUB  1         WRK12
     C                     ADD  WRK12     WRK11
     C           WLOT      IFNE 0
     C                     DIV  WLOT      WRK11
     C                     END
     C           WRK11     ADD  .99       WMIS
      *
     C                     END
      *
     C                     ENDSR
      *==============================================================*
      *                                                              *
      * 本社工場の計算                                    SUB-3    *
      *                                                              *
      *==============================================================*
     C           HSUB      BEGSR
      *日当り箱数*
     C                     Z-ADD0         WRK1
     C                     Z-ADD0         @D
     C           WKTS      DIV  20        WRK1
     C           WSYU      IFNE 0
     C           WRK1      DIV  WSYU      @D        H
     C                     END
      *
     C           WKS1      IFEQ 'R'
      **********
      *基準値*
      **********
     C                     Z-ADD0         WKJY
      **************
      *生産ロット*
      **************
     C                     Z-ADD0         WLOT
      ****************
      *かんばん枚数*
      ****************
     C                     Z-ADD0         WMIS
     C                     Z-ADD0         WRK13   72
      *
     C           @D        MULT 5         WRK13
     C           WRK13     DIV  5         WMIS
     C                     END
     C                     ENDSR
      *==============================================================*
      *                                                              *
      * 可児工場の計算                                    SUB-4    *
      *                                                              *
      *==============================================================*
     C           KSUB      BEGSR
      *後工程ロット*
     C                     MOVE *BLANK    @AHN1   5
     C                     MOVE *BLANK    @AHN2   5
     C                     MOVE *BLANK    @AHN3   2
     C                     Z-ADD0         @ALOT   30
     C                     Z-ADD0         @ASYO   50
     C                     Z-ADD0         @WALOT  30
      *
     C           KEY1      SETLLAAJTL141
     C                     SETOF                     30
      *
     C                     DO   *HIVAL
     C           SSTP3     TAG
     C           KEY1      READEAAJTL141                 30
     C           *IN30     IFEQ '0'
     C           CJAKHZ    IFNE 0
     C           CJAKHZ    IFLE *DATE
     C                     GOTO SSTP3
     C                     END
     C                     END
     C           CJCHHZ    IFLT *DATE
     C                     GOTO SSTP3
     C                     END
      *
     C           CJSYUY    IFNE 0
     C           CJSLOT    DIV  CJSYUY    @WALOT
     C                     END
     C           @WALOT    IFGT @ALOT
     C                     MOVELCJHIN1    @AHN1
     C                     MOVELCJHIN2    @AHN2
     C                     MOVELCJHIN3    @AHN3
     C                     Z-ADD@WALOT    @ALOT
     C                     Z-ADDCJSYUY    @ASYO
     C                     END
     C                     END
     C  N30                END
      *日当り箱数*
     C                     Z-ADD0         WRK1   103
     C                     Z-ADD0         @D      73
     C           WKTS      DIV  20        WRK1
     C           WSYU      IFNE 0
     C           WRK1      DIV  WSYU      @D        H
     C                     END
      *引取単位*
