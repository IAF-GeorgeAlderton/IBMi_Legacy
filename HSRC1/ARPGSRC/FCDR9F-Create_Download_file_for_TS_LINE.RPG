     C                     Z-ADD1         X
     C           *BLANK    LOKUPCP#,X                    77
     C           *IN77     IFEQ *ON
     C                     MOVELCKHBAN    CP#,X
     C                     ELSE
     C                     MOVEL*ALL'9'   CP#,1
     C                     END
