     C                     TIME           WSDT
     C           WSSMMM    SUB  1         W@DTMM  20
     C           W@DTMM    IFLE *ZERO
     C           WSSYYY    SUB  1         W@DTYY  40
     C                     ADD  12        W@DTMM
     C                     ELSE
     C                     Z-ADDWSSYYY    W@DTYY
     C                     END
     C*
     C           *LOVAL    SETLLAAMPL11
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AAMPL11                  99
     C   99                LEAVE
     C           CKSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C*
     C                     MOVEAN@MCN     MCN
     C                     MOVEAN@PRT     PRT
     C                     MOVEAN@LOC     LOC
     C                     MOVEAO@MCX     MCX
     C                     MOVEAO@PRX     PRX
     C                     MOVEAO@LOX     LOX
     C*
     C                     DO   15        J       20
     C****                 MOVELCHG,J     @CHG
     C****       @CHGDT    IFGT WSSDAT
     C****                 MOVELMCX,J     @MCN,J           MACHINE
     C****                 MOVELPRX,J     @PRT,J           PART NUMBER
     C****                 MOVELLOX,J     @LOC,J           LOCATION
     C****                 ELSE
     C                     MOVELMCN,J     @MCN,J           MACHINE
     C                     MOVELPRT,J     @PRT,J           PART NUMBER
     C                     MOVELLOC,J     @LOC,J           LOCATION
     C****                 END
     C                     ENDDO
     C*
     C                     DO   15        J       20
     C           @MCN,J    IFNE *BLANK
     C           @MCN,J    CHAINFCDPP9A              98
     C           *IN98     IFEQ *OFF
     C           F9SKBN    ANDEQ*BLANK
     C                     EXSR #SUB1
     C                     END
     C                     END
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C                     MOVEL*OFF      W@1ST   1
