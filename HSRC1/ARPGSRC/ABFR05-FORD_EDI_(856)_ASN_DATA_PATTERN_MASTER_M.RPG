     H            Y.
      ** AB#FRAS *******************************************
      *  FORD EDI (856) ASN DATA PATTERN MASTER MAINTE     *
      *                                                    *
      *  TCH  : 10/04/05 CREATE                            *
      **************************************** AB#FRAS *****
     FABFPW05 CF  E                    WORKSTN
     F                                        RRNP1 KSFILE SFLP01
     F                                              KINFDS @INFDS
     FAB#FPAS UF  E           K        DISK                      A
      *---------------------------------------------------
     E                    ERR     1  14 60
      *---------------------------------------------------
     I@INFDS      DS
     I                                     *STATUS  @STTS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME(6) + DATE(6)
     I            DS
     I                                        1  140WWTIME
     I                                        1   60WTIME
     I                                        1   40WTIM4
     I                                        7  120WSDATE
     I                                        9  120@@YM4
     I                                        7  120@@YM6
     I                                        7  140@@YMD
     I                                        7  100@@YY
     I                                       11  120@@MM
     I                                       13  140@@DD
     I            DS
     I                                        1   80W@DATE
     I                                        1   40W@YY
     I                                        5   60W@MM
     I                                        7   80W@DD
      *
     C                     TIME           WWTIME
      *
      ******************************************************
      *  MAIN
      ******************************************************
     C*
     C                     EXSR @P1INT
     C                     EXSR @P1SET
      *
     C                     DO   *HIVAL
      *
     C                     WRITECTLP99
     C                     Z-ADDW#RNP1    #RCN01
     C                     EXFMTCTLP01
     C   KA                LEAVE
      *
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP1
     C                     END
      *
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      W#P1ER  1
      * add new pattern
     C           *INKH     IFEQ *ON
     C                     EXSR @P2ADD
     C   KA                LEAVE
     C                     EXSR @P1INT
     C                     EXSR @P1SET
     C                     ITER
     C                     END
      * change pattern
     C                     EXSR @P2CHG
     C   KA                LEAVE
     C                     EXSR @P1INT
     C                     EXSR @P1SET
     C                     ITER
      *
     C                     ENDDO
      *
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C*----------------------------------------------------*
      *  INITTIAL ASN DATA PATTERN SCREEN
     C*----------------------------------------------------*
     C           @P1INT    BEGSR
      *
     C                     MOVEL*ON       *IN41
     C                     WRITECTLP01
     C                     MOVEL*OFF      *IN41
      *
     C                     Z-ADD1         W#RNP1  40
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  SET ASN DATA PATTERN SCREEN
     C*----------------------------------------------------*
     C           @P1SET    BEGSR
      *
     C                     Z-ADD*ZERO     RRNP1   40
     C           *LOVAL    SETLLAB#FPAS
      *
     C                     DO   *HIVAL
      *
     C                     READ AB#FPAS             N    91
     C   91                LEAVE
     C           AFSKJY    IFNE *BLANK
     C                     ITER
     C                     END
      *
     C                     CLEARSFLP01
     C                     MOVELAFPTNM    S1PTNM
     C                     MOVELAFT302    S1T302
     C           AFH302    IFNE *BLANK
     C                     MOVEL'Yes'     S1H302
     C                     END
     C                     MOVELAFT303    S1T303
     C           AFH303    IFNE *BLANK
     C                     MOVEL'Yes'     S1H303
     C                     END
     C                     MOVELAFT503    S1T503
     C           AFH503    IFNE *BLANK
     C                     MOVEL'Yes'     S1H503
     C                     END
     C                     MOVELAFT504    S1T504
     C           AFH504    IFNE *BLANK
     C                     MOVEL'Yes'     S1H504
     C                     END
     C                     MOVELAFT508    S1T508
     C           AFH508    IFNE *BLANK
     C                     MOVEL'Yes'     S1H508
     C                     END
      *
     C                     ADD  1         RRNP1
     C                     WRITESFLP01
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  CHECK ASN DATA PATTERN SCREEN FOR NEW PATTERN
     C*----------------------------------------------------*
     C           @P2ADD    BEGSR
      *
     C                     EXSR @P2INT
     C                     MOVEL'    ADD' F2ACTN    P
      *
     C                     DO   *HIVAL
      *
     C                     EXFMTFMTP02
     C   KA
     COR KL                LEAVE
      *
     C                     SETOF                     5169
     C                     MOVEL*BLANK    MSG
      *
     C           F2PTNM    IFEQ *BLANK
     C                     SETON                     5169
     C                     MOVELERR,1     MSG
     C                     ITER
     C                     END
      *
     C           F2PTNM    CHAINAB#FPAS              91
     C           *IN91     IFEQ *OFF
     C           AFSKJY    ANDEQ*BLANK
     C                     SETON                     5169
     C                     MOVELERR,2     MSG
     C                     ITER
     C                     END
      *
     C           *INKE     IFEQ *ON
     C                     EXSR @ADDF
     C                     LEAVE
     C                     END
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  INITIAL SET TO FMTP02
     C*----------------------------------------------------*
     C           @P2INT    BEGSR
      *
     C                     MOVEL*OFF      *IN51
     C                     SETOF                     616269
      *
     C                     MOVEL*BLANK    F2PTNM
     C                     MOVEL*BLANK    F2T302
     C                     MOVEL*BLANK    F2H302
     C                     MOVEL*BLANK    F2T303
     C                     MOVEL*BLANK    F2H303
     C                     MOVEL*BLANK    F2T503
     C                     MOVEL*BLANK    F2H503
     C                     MOVEL*BLANK    F2T504
     C                     MOVEL*BLANK    F2H504
     C                     MOVEL*BLANK    F2T508
     C                     MOVEL*BLANK    F2H508
      *
     C                     MOVEL*BLANK    MSG
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  WRITE ASN DATA PATTERN SCREEN FOR NEW PATTERN
     C*----------------------------------------------------*
     C           @ADDF     BEGSR
      *
     C                     CLEARAB#FPASR
      *
     C                     Z-ADD@@YY      AFKOYY
     C                     Z-ADD@@MM      AFKOMM
     C                     Z-ADD@@DD      AFKODD
     C                     MOVELWTIM4     AFKOHH
     C                     MOVE WTIM4     AFKOSS
     C                     MOVEL#PGM      AFKOPG
     C                     MOVEL#WSID     AFKOWS
     C                     MOVEL#USER     AFKOME
      *
     C                     MOVELF2PTNM    AFPTNM
     C                     MOVELF2T302    AFT302
     C           F2H302    IFNE *BLANK
     C                     MOVEL'Y'       AFH302
     C                     END
     C                     MOVELF2T303    AFT303
     C           F2H303    IFNE *BLANK
     C                     MOVEL'Y'       AFH303
     C                     END
     C                     MOVELF2T503    AFT503
     C           F2H503    IFNE *BLANK
     C                     MOVEL'Y'       AFH503
     C                     END
     C                     MOVELF2T504    AFT504
     C           F2H504    IFNE *BLANK
     C                     MOVEL'Y'       AFH504
     C                     END
     C                     MOVELF2T508    AFT508
     C           F2H508    IFNE *BLANK
     C                     MOVEL'Y'       AFH508
     C                     END
      *
     C           *IN91     IFEQ *OFF
     C                     UPDATAB#FPASR
     C                     ELSE
     C                     WRITEAB#FPASR
     C                     END
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  CHANGE ASN DATA PATTERN MASTER
     C*----------------------------------------------------*
     C           @P2CHG    BEGSR
      *
     C                     Z-ADD*ZERO     RRNP1
      *
     C                     DO   *HIVAL
      *
     C                     ADD  1         RRNP1
     C           RRNP1     CHAINSFLP01               91
     C   91                LEAVE
     C           S1SEL     IFEQ *BLANK
     C                     ITER
     C                     END
      *
     C                     EXSR @P2CDP
     C   KA                LEAVE
      *
     C                     MOVEL*BLANK    S1SEL
     C                     UPDATSFLP01
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  CHANGE ASN DATA PATTERN SCREEN
     C*----------------------------------------------------*
     C           @P2CDP    BEGSR
      *
     C                     EXSR @P2INT
     C           S1SEL     IFEQ 'C'
     C                     MOVEL'  CHANGE'F2ACTN    P
     C                     MOVEL*ON       *IN61
     C                     ELSE
     C                     MOVEL'  DELETE'F2ACTN    P
     C                     MOVEL*ON       *IN62
     C                     END
     C                     MOVELS1PTNM    F2PTNM
     C                     MOVELS1T302    F2T302
     C                     MOVELS1H302    F2H302
     C                     MOVELS1T303    F2T303
     C                     MOVELS1H303    F2H303
     C                     MOVELS1T503    F2T503
     C                     MOVELS1H503    F2H503
     C                     MOVELS1T504    F2T504
     C                     MOVELS1H504    F2H504
     C                     MOVELS1T508    F2T508
     C                     MOVELS1H508    F2H508
      *
     C                     DO   *HIVAL
      *
     C                     EXFMTFMTP02
     C   KA
     COR KL                LEAVE
      *
     C           *INKE     IFEQ *ON
     C                     EXSR @CHGF
     C                     LEAVE
     C                     END
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  UPDAT ASN DATA PATTERN SCREEN
     C*----------------------------------------------------*
     C           @CHGF     BEGSR
      *
     C                     DO
      *
     C           F2PTNM    CHAINAB#FPAS              91
     C           *IN91     IFEQ *ON
     C                     LEAVE
     C                     END
      *
     C           S1SEL     IFEQ 'D'
     C                     MOVEL'D'       AFSKJY
     C                     Z-ADD@@YY      AFSKYY
     C                     Z-ADD@@MM      AFSKMM
     C                     Z-ADD@@DD      AFSKDD
     C                     MOVEL#USER     AFSKME                        -
     C                     MOVEL#WSID     AFSKWS
     C                     MOVEL#PGM      AFSKPG
      *
     C                     ELSE
      *
     C                     Z-ADD@@YY      AFKOYY
     C                     Z-ADD@@MM      AFKOMM
     C                     Z-ADD@@DD      AFKODD
     C                     MOVELWTIM4     AFKOHH
     C                     MOVE WTIM4     AFKOSS
     C                     MOVEL#PGM      AFKOPG
     C                     MOVEL#WSID     AFKOWS
     C                     MOVEL#USER     AFKOME
     C                     MOVELF2T302    AFT302
     C           F2H302    IFNE *BLANK
     C                     MOVEL'Y'       AFH302
     C                     ELSE
     C                     MOVEL*BLANK    AFH302
     C                     END
     C                     MOVELF2T303    AFT303
     C           F2H303    IFNE *BLANK
     C                     MOVEL'Y'       AFH303
     C                     ELSE
     C                     MOVEL*BLANK    AFH303
     C                     END
     C                     MOVELF2T503    AFT503
     C           F2H503    IFNE *BLANK
     C                     MOVEL'Y'       AFH503
     C                     ELSE
     C                     MOVEL*BLANK    AFH503
     C                     END
     C                     MOVELF2T504    AFT504
     C           F2H504    IFNE *BLANK
     C                     MOVEL'Y'       AFH504
     C                     ELSE
     C                     MOVEL*BLANK    AFH504
     C                     END
     C                     MOVELF2T508    AFT508
     C           F2H508    IFNE *BLANK
     C                     MOVEL'Y'       AFH508
     C                     ELSE
     C                     MOVEL*BLANK    AFH508
     C                     END
      *
     C                     END
      *
     C                     UPDATAB#FPASR
      *
     C                     ENDDO
      *
     C                     ENDSR
** ERR
