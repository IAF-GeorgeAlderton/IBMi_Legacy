     C*
     C           @HIN1     IFEQ CFHIN1
     C           @HIN2     ANDEQCFHIN2
     C           @HIN3     ANDEQCFHIN3
     C           @YN       IFEQ 'Y'
     C           CFMNKB    IFEQ '1'
     C           CFMNKB    OREQ '2'
     C           CFMNKB    IFEQ '1'
     C           CFBHZ1    IFNE *ZERO
     C           CFBHK1    ADD  CFBHK2    WHAKO   20
     C           WHAKO     IFNE CFMAIS
     C           CFBHZ2    IFEQ *ZERO
     C                     EXSR $SB400
     C                     END
     C                     END
     C                     ELSE
     C                     EXSR $SB400
     C                     END
     C                     END
     C           CFMNKB    IFEQ '2'
     C           CFBHZ1    IFNE *ZERO
     C           CFBHK1    IFNE CFMHKO
     C                     EXSR $SB400
     C                     END
     C                     ELSE
     C                     EXSR $SB400
     C                     END
     C                     END
     C                     END
     C                     END
     C           @YN       IFEQ 'N'
     C                     EXSR $SB400
     C                     END
     C                     ELSE
     C                     SETON                     80
     C                     END
     C           TAG3      TAG
     C                     END
     C  N80                END
     C                     END
     C           *IN80     IFEQ '1'
     C           PSW1      IFEQ '*'
     C                     MOVE CTR       @KENSU
     C                     WRITEAUBPR513
     C                     CLOSEAUBPR51
     C                     END
     C                     END
     C                     SETOF                     80
     CSR                   ENDSR
     C*-----------------------------------------------------*
     C* PRINT LIST SUBRTN                                   *
     C*-----------------------------------------------------*
     CSR         $SB400    BEGSR
     C           PSW1      IFEQ ' '
     C                     OPEN AUBPR51
     C                     Z-ADD1         @PAGE
     C                     MOVE *DATE     @HADAY
     C                     MOVE CFHIN1    @NO1
     C                     MOVE CFHIN2    @NO2
     C                     MOVE CFHIN3    @NO3
     C           CFHIN3    IFNE *BLANK
     C                     SETON                     40
     C                     END
     C           PARM3     CHAINRGAPL111             21
     C           *IN21     IFEQ '0'
     C                     MOVELJ8NAME    @HASYA
     C                     END
     C                     WRITEAUBPR511
     C                     MOVE '*'       PSW1    1
     C                     END
     C** DETAILS * *
     C                     MOVE CFMNYY    WWHY
     C                     MOVE '.'       WWS1
     C                     MOVE CFMNMM    WWHM
     C                     MOVE '.'       WWS2
     C                     MOVE CFMNDD    WWHD
     C                     MOVE '-'       WWS3
     C                     MOVE CFMNBB    WWHB
     C           WWHB      IFEQ *ZERO
     C                     MOVE *BLANK    WWS3
     C                     END
     C                     MOVE WWK01     @SYORI
     C*
     C           CFBMON    CHAINFGBPL011             72
     C           *IN72     IFEQ '0'
     C                     MOVELB2SMEI    @BUMNA
     C                     END
     C*
     C                     MOVE CFZENO    SGY1
     C                     MOVE '-'       WBAR1
     C                     MOVE CFTHNO    SGY2
     C*
     C                     MOVE CFMAIS    @MAISU
     C                     MOVE CFMHKO    @MINOH
     C                     MOVE *ZERO     WKSU
     C           CFBHK1    ADD  CFBHK2    WKSU    30
     C           WKSU      IFNE *ZERO
     C           CFMAIS    SUB  WKSU      @MINOH
     C                     END
     C           CFMNKB    IFEQ '2'
     C           CFBHZ1    IFNE *ZERO
     C           CFMHKO    IFEQ CFBHK1
     C                     Z-ADD0         @MINOH
     C                     END
     C                     END
     C                     END
     C*
     C                     MOVE CFBYY1    WWHY
     C           WWHY      IFEQ '0000'
     C                     MOVE *BLANK    WWK01
     C                     ELSE
     C                     MOVE '.'       WWS1
     C                     MOVE CFBMM1    WWHM
     C                     MOVE '.'       WWS2
     C                     MOVE CFBDD1    WWHD
     C                     MOVE '-'       WWS3
     C                     MOVE CFBBB1    WWHB
     C                     END
     C                     MOVE WWK01     @BANK1
     C           CFMNKB    IFEQ '2'
     C           CFBHZ1    IFNE *ZERO
     C           CFMHKO    IFEQ CFBHK1
     C                     MOVE CFMNYY    WWHY
     C                     MOVE '.'       WWS1
     C                     MOVE CFMNMM    WWHM
     C                     MOVE '.'       WWS2
     C                     MOVE CFMNDD    WWHD
     C                     MOVE '-'       WWS3
     C                     MOVE CFMNBB    WWHB
     C           WWHB      IFEQ *ZERO
     C                     MOVE *BLANK    WWS3
     C                     END
     C                     MOVE WWK01     @BANK1
     C                     END
     C                     END
     C                     END
     C*
     C                     MOVE CFBHK1    @HAKO1
     C           CFMNKB    IFEQ '2'
     C           CFMAIS    SUB  CFMHKO    @HAKO1
     C                     END
     C*
     C                     MOVE CFBYY2    WWHY
     C           WWHY      IFEQ '0000'
     C                     MOVE *BLANK    WWK01
     C                     ELSE
     C                     MOVE '.'       WWS1
     C                     MOVE CFBMM2    WWHM
     C                     MOVE '.'       WWS2
     C                     MOVE CFBDD2    WWHD
     C                     MOVE '-'       WWS3
     C                     MOVE CFBBB2    WWHB
     C                     END
     C           CFMNKB    IFEQ '2'
     C           CFBHZ1    IFNE *ZERO
     C           CFMHKO    IFEQ CFBHK1
     C                     MOVE CFBYY1    WWHY
     C           WWHY      IFEQ '0000'
     C                     MOVE *BLANK    WWK01
     C                     ELSE
     C                     MOVE '.'       WWS1
     C                     MOVE CFBMM1    WWHM
     C                     MOVE '.'       WWS2
     C                     MOVE CFBDD1    WWHD
     C                     MOVE '-'       WWS3
     C                     MOVE CFBBB1    WWHB
     C                     END
     C                     END
     C                     END
     C                     END
     C                     MOVE WWK01     @BANK2
     C*
     C           CFBHZ2    IFNE *ZERO
     C           CFMAIS    SUB  CFBHK1    @HAKO2
     C                     ELSE
     C                     Z-ADD0         @HAKO2
     C                     END
     C           CFMNKB    IFEQ '2'
     C           CFBHZ1    IFNE *ZERO
     C           CFMHKO    IFEQ CFBHK1
     C                     MOVE CFBHK1    @HAKO2
     C                     END
     C                     END
     C                     END
     C                     MOVE CFKBAN    @KBAN
