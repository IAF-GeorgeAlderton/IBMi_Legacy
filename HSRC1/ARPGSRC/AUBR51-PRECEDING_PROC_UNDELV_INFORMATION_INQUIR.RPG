     C                     GOTO RETRY
     C                     ELSE
     C                     SETON                         99
     C                     MOVEL$MSG,6    @ERR
     C                     GOTO $200S
     C                     END
     C                     END
     C*
     C**ROLLDOWN
     C                     SETOF                     828399
     C                     MOVE *ZERO     Y       20
     C           *IN52     IFEQ '1'
     C           *IN81     IFEQ '0'
     C           @JOKEN    IFEQ 'A'
     C                     READPAH#TL201                 81
     C                     END
     C           @JOKEN    IFEQ 'B'
     C           #KEY1     READEAH#TL201                 81
     C                     END
     C           @JOKEN    IFEQ 'C'
     C                     READ AH#TL201                 81
     C                     END
     C                     END
     C           *IN81     IFEQ '1'
     C                     SETOF                         81
     C           @JOKEN    IFEQ 'A'
     C           #KEY      SETLLAH#TL201
     C                     END
     C           @JOKEN    IFEQ 'B'
