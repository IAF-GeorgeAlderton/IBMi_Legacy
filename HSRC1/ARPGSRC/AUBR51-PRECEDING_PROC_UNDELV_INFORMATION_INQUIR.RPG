     C                     SETOF                     159977
     C                     MOVE *BLANK    @ERR
     C*                    MOVE *ZERO     WKX
     C           *IN01     IFEQ '1'
     C                     SETON                       LR
     C                     RETRN
     C                     END
     C           *IN03     IFEQ '1'
