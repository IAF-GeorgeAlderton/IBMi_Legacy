     C           WKSU      IFNE *ZERO
     C           CFMAIS    SUB  WKSU      IR1,X
     C                     END
     C           CFMNKB    IFEQ '2'
     C           CFBHZ1    IFNE *ZERO
     C                     Z-ADD0         IR1,X
     C                     END
     C                     END
     C           SCW       IFEQ *BLANK
     C           X         ANDEQ1
  K.YC                     MOVE CFTHNO    WKTHNO  3
     C                     MOVE CFZENO    WKZENO  4
     C                     MOVE '*'       SCW     1
     C                     END
     C*
     C           X         CABEQ15        DSPLAY
