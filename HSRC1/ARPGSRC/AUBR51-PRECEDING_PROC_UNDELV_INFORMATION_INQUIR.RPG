     C                     MOVE CFMNMM    WWHM
     C                     MOVE '.'       WWS2
     C                     MOVE CFMNDD    WWHD
     C                     MOVE '-'       WWS3
     C                     MOVE CFMNBB    WWHB
     C                     MOVE WWK01     ER1,X
     C                     END
     C                     END
     C/SPACE 1
     C*************************
     C* NUMBER OF BOXES     *
     C*************************
     C                     MOVE CFBHK1    FR1,X
     C           CFMNKB    IFEQ '2'
     C           CFMAIS    SUB  CFMHKO    FR1,X
     C                     END
     C/SPACE 1
     C*************************
     C* RETRIEVAL HANDLING DAY 2*
     C*************************
     C                     MOVE CFBYY2    WWHY
     C           WWHY      IFEQ '0000'
     C                     MOVE *BLANK    GR1,X
     C                     ELSE
     C                     MOVE '.'       WWS1
     C                     MOVE CFBMM2    WWHM
     C                     MOVE '.'       WWS2
     C                     MOVE CFBDD2    WWHD
     C                     MOVE '-'       WWS3
     C                     MOVE CFBBB2    WWHB
     C                     MOVE WWK01     GR1,X
     C                     END
     C           CFMNKB    IFEQ '2'
