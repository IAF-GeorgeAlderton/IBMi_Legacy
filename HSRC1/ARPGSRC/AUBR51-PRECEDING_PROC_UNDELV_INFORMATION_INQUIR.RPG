     C                     SETON                     1099
     C                     GOTO $100S
     C                     ELSE
     C           CFSKJY    IFEQ 'D'
     C                     MOVEL$MSG,1    @ERR
     C                     SETON                     1099
     C                     GOTO $100S
     C                     END
     C                     END
     C*===== 条件のチエック=====*
     C           @JOKEN    IFNE 'A'
