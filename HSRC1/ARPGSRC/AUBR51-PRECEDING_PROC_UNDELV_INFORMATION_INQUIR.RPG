     C                     MOVE *ZERO     @HD
     C                     MOVE *ZERO     @BB
     C                     SETOF                       99
     C                     SETON                       LR
     C                     RETRN
     C                     END
     C*===== 日付のチエック =====*
     C                     MOVE @HY       WY
     C                     MOVE @HM       WM
     C                     MOVE @HD       WD
     C                     MOVE WYMD      WHYMD   80
     C           WYMD      IFNE *ZERO
     C                     EXSR $SB200
     C           *IN90     IFEQ '1'
     C           *IN98     OREQ '1'
     C                     MOVEL$MSG,3    @ERR
     C                     SETON                     1199
     C                     GOTO $100S
     C                     END
     C                     END
     C*===== 品番のチエック=====*
