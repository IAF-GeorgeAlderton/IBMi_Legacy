     C           CFMHKO    IFEQ CFBHK1
     C                     MOVE CFBYY1    WWHY
     C           WHY       IFEQ '0000'
     C                     MOVE *BLANK    GR1,X
     C                     ELSE
     C                     MOVE '.'       WWS1
     C                     MOVE CFBMM1    WWHM
     C                     MOVE '.'       WWS2
     C                     MOVE CFBDD1    WWHD
     C                     MOVE '-'       WWS3
     C                     MOVE CFBBB1    WWHB
     C                     MOVE WWK01     GR1,X
     C                     END
     C                     END
     C                     END
     C                     END
     C/SPACE 1
     C*************************
     C* NUMBER OF BOXES     *
     C*************************
     C           CFBHZ2    IFNE *ZERO
     C           CFMAIS    SUB  CFBHK1    HR1,X
     C                     ELSE
     C                     MOVE *ZERO     HR1,X
     C                     END
     C           CFMNKB    IFEQ '2'
     C           CFBHZ1    IFNE *ZERO
     C           CFMHKO    IFEQ CFBHK1
     C                     MOVE CFBHK1    HR1,X
     C                     END
     C                     END
     C                     END
     C/SPACE 1
     C*************************
