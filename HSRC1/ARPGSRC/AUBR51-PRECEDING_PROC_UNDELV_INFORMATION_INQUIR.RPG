     C*
     C           CFMNKB    IFEQ '1'
     C           CFBHZ1    IFNE *ZERO
     C           CFBHK1    ADD  CFBHK2    WHAKO   20
     C           WHAKO     IFEQ CFMAIS
     C                     GOTO #LOOP1
     C                     ELSE
