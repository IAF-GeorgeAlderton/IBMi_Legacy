      *
     C           *ENTRY    PLIST
     C                     PARM           P@SIRE  40
     C                     PARM           P@ZAIS 15
     C                     PARM           P@ZAIK  52
     C                     PARM           P@ORD   50
      *
     C           KEYGD1    KLIST
     C                     KFLD           K@ZAIS 15
     C                     KFLD           K@ZAIK  52
     C                     KFLD           K@ODRY  40
     C                     KFLD           K@ODRM  20
     C                     KFLD           K@ODRD  20
     C           KEYGD2    KLIST
     C                     KFLD           K@ZAIS 15
     C                     KFLD           K@ZAIK  52
     C                     Z-ADDP@SIRE    K@SIRE  40
     C                     MOVELP@ZAIS    K@ZAIS
     C                     Z-ADDP@ZAIK    K@ZAIK
     C                     Z-ADD0         P@ORD
      *
     C                     MOVE *DATE     PDATE
     C                     MOVEL'-'       PPORM
     C                     MOVEL'0019'    PDAYS
     C                     CALL 'DATR1A'
     C                     PARM           PDATE   8
     C                     PARM           PPORM   1        + OR -
     C                     PARM           PDAYS   4
     C                     PARM           PRDAT   8
     C                     PARM           PRTN    1
     C                     Z-ADD0         WKODR
     C                     MOVE PRDAT     WKODR
     C                     Z-ADDWKODRY    K@ODRY
     C                     Z-ADDWKODRM    K@ODRM
     C                     Z-ADDWKODRD    K@ODRD
     C           KEYGD1    SETLLGDLPL14
     C           KEYGD2    READEGDLPL14                  82
     C           *IN82     DOWEQ'0'
     C           LBSKJY    IFEQ 'D'
     C           LBSKHZ    ANDLE*DATE
     C                     ELSE
     C                     ADD  LBMAIS    P@ORD
     C                     ENDIF
     C           KEYGD2    READEGDLPL14                  82
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
