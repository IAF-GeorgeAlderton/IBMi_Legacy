     H            Y.
     F***************************************************
     F*   INPORT ORDER DATA ( DATA UPDATE)              *
     F*  CODING:K.OKACHI            2000.11.06          *
     F***************************************************
     FGDGPWA0 CF  E                    WORKSTN
     FGDGPP01 IF  E                    DISK
     FGDGWPA0 IF  F     256            DISK                      A
     E                    ER      1   6 60               d[ｰxｮﾈｰﾆﾞ
      *
     IGDGWPA0 AA  10
     I                                       17  21 WHIN1
     I                                       22  26 WHIN2
     I                                       27  28 WHIN3
      *
     I            DS
     I                                        1   80IASKHZ
     I                                        1   40IASKYY
     I                                        5   60IASKMM
     I                                        7   80IASKDD
     I            DS
     I                                        1  12 SHIN
     I                                        1   5 HIN1
     I                                        6  10 HIN2
     I                                       11  12 HIN3
      *
     C           STEP0     TAG
     C                     MOVE *BLANK    HIN1
     C                     MOVE *BLANK    HIN2
     C                     MOVE *BLANK    HIN3
      *
     C           STEP1     TAG
     C                     EXFMTGDGPWA01
     C                     SETOF                     0199
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           SHIN      IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVELER,1      MSG
     C                     GOTO STEP1
     C                     END
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STEP1
     C                     END
      *
     C           1         SETLLGDGWPA0
     C                     DO   *HIVAL
     C                     SETOF                     30
     C                     READ GDGWPA0                  30
     C           *IN30     IFEQ '0'
     C           WHIN1     IFEQ HIN1
     C           WHIN2     ANDEQHIN2
     C           WHIN3     ANDEQHIN3
     C                     SETON                     0199
     C                     MOVELER,2      MSG
     C                     GOTO STEP1
     C                     END
     C                     END
     C  N30                ENDDO
      *
     C                     MOVE *BLANK    CFLG    1
     C           1         SETLLGDGPP011
     C                     DO   *HIVAL
      *
     C                     SETOF                     70
     C                     READ GDGPP011                 70
     C           *IN70     IFEQ '0'
     C           IASKJY    IFEQ 'D'
     C           IASKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'AAPR02'  WKOME  10
     C           IAODER    IFEQ 0                          増減処理
     C           IAKOME    ANDEQWKOME
     C           IAHIN1    IFEQ HIN1
     C           IAHIN2    ANDEQHIN2
     C           IAHIN3    ANDEQHIN3
     C                     MOVE '*'       CFLG
     C                     EXCPTDAT
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C  N70                ENDDO
      *
     C           CFLG      IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVELER,3      MSG
     C                     GOTO STEP1
     C                     END
      *
     C                     GOTO STEP0
      *
     OGDGWPA0 EADD             DAT
     O                         IAODER     6
     O                         IAZETI    10
     O                         IASEIH    11
     O                         IARENB    15
     O                         IACD      16
     O                         IAHIN1    21
     O                         IAHIN2    26
     O                         IAHIN3    28
     O                         IASYOS    35
     O                         IAMAIS    38
     O                         IASYHZ    46
     O                         IAHAYY    50
     O                         IAHAMM    52
     O                         IAHADD    54
**  ERR
E-01 INPUT INTRAL COMPANY PART NO
E-02 THIS DATA HAS ALREADY BEEN INPUT
E-03 INPUT DATA IS NOT IN ORDER DATA FILE
