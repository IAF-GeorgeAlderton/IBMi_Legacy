      *--------------------------------------------------------
      *   MAIN ROUTINE
      *--------------------------------------------------------
     C                     EXSR #OUT
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *--------------------------------------------------------
      * INITIALIZE
      *--------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
      *
     C                     Z-ADD*DATE     K@DATE
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     Z-ADDF8KDAT    K@DATE
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     TIME           @@TIM   60
     C                     MOVE *ALL'-'   W@LINE132
     C                     MOVEL*BLANK    W@OPER  6
     C                     MOVEL*BLANK    W@SHFT  1
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  OUTPUT
      *--------------------------------------------------------
     C           #OUT      BEGSR
      *
     C                     MOVE *OFF      *IN98
TCHK2C********** K@DATE    SETLLAFAPL6Y1
      *
     C                     DO   *HIVAL
      *
     C                     READ AFAPL6Y1                 91
     C   91                LEAVE
      *
     C           AYERID    IFEQ '11'
     C                     ITER
     C                     END
      *
     C           AYOPER    IFNE W@OPER
     C                     MOVELAYOPER    K@OPER  60
     C           K@OPER    CHAINALBPL30              90
     C  N90                MOVELALWKNM    P@WKNM 20 P
     C   90                MOVELAYOPER    P@WKNM    P
     C                     MOVELAYOPER    W@OPER
     C                     MOVEL*BLANK    W@SHFT
     C                     ELSE
     C                     MOVEL*BLANK    P@WKNM
     C                     END
      *
     C           AYSHFT    IFNE W@SHFT
     C                     MOVELAYSHFT    W@SHFT  1
     C                     MOVELAYSHFT    P@SHFT  1
     C                     ELSE
     C                     MOVEL*BLANK    P@SHFT
     C                     END
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     END
     C  N98                MOVE *ON       *IN98
      *
     C                     SELEC
     C           AYERSC    WHEQ 'LOCATION'
     C                     MOVELAYERSC    W@@NM  16
     C           AYERSC    WHEQ 'LOT ID'
     C                     MOVELAYERSC    W@@NM
     C           AYERSC    WHEQ 'LOQ K#'
     C                     MOVEL'LOQ KANB'W@@NM
     C                     MOVE 'AN      'W@@NM
     C           AYERSC    WHEQ 'APICS K3'
     C           AYERSC    OREQ 'APICS K4'
     C                     MOVEL'APICS KA'W@@NM
     C                     MOVE 'NBAN    'W@@NM
     C                     ENDSL
TCHK2C                     MOVELW@@NM     P@SCNM 20 P
      *
TCHK2C                     MOVELAYKSTM    P@KSTM  40
TCHK2 *
TCHK2C                     MOVEL*BLANK    K@KOME
TCHK2C                     MOVELAYOPER    K@KOMC
TCHK2C                     MOVELAYSHFT    K@KOMS
TCHK2C           K@6X3     KLIST
TCHK2C                     KFLD           K@KOME
TCHK2C                     KFLD           K@KOYY
TCHK2C                     KFLD           K@KOMM
TCHK2C                     KFLD           K@KODD
TCHK2C                     KFLD           K@KOHH
TCHK2C                     KFLD           K@KOSS
TCHK2C           K@6X3     SETGTAFAPL6X3
TCHK2C           K@KOME    READEAFAPL6X3                 92
TCHK2C           *IN92     IFEQ *OFF
TCHK2C                     Z-ADDAXKODT    P@CODT  80
TCHK2C                     Z-ADDAXKOTM    P@COTM  40
TCHK2C                     ELSE
TCHK2C                     Z-ADD*ZERO     P@CODT
TCHK2C                     Z-ADD*ZERO     P@COTM
TCHK2C                     END
TCHK2 *
     C                     MOVE AYERID    @2      20
TCHK2C                     MOVELERR,@2    P@MSG  20
      *
     C                     EXCPT@DTL
      *
     C                     ENDDO
      *
     C                     ENDSR
      *-------------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                         UDATE Y  115
     O                         @@TIM    124 '  :  :  '
     O                                  127 'P.'
     O                         PAGE  Z  132
     O        E   02           @HED
     O                                   65 'EE(4-POINT)'
     O                                   80 'SCAN ERROR LOG'
     O        E   04           @HED
     O                                    8 'OPERATOR'
     O                                   26 'SHIFT'
     O                                   41 'SCAN DATE'
     O                                   46 'TIME'
     O                                   63 'SCREEN NAME'
     O                                   85 'SCANNED DATA'
     O                                  107 'ERROR MESSAGE'
     O                                  125 'CORRECTED'
     O        E   05           @HED
     O                         W@LINE   132
     O        E 1              @DTL
     O                         P@WKNM    20
     O                         P@SHFT    24
     O                         AYKSDTY   41
TCHK2O*                        AYKSTM    50 '  :  '
TCHK2O                         P@KSTM    50 '  :  '
TCHK2O                         P@SCNM    72
     O                         AYERDT    93
TCHK2O                         P@MSG    114
TCHK2O                         P@CODT   125 '    /  /  '
TCHK2O                         P@COTM   131 '  :  '
