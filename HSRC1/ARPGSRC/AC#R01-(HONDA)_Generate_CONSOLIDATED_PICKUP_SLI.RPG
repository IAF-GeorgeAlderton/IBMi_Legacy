     H            Y.
      ** AB#R1L **********************************************
      *  (HONDA) GENERATE CONSOLIDATED PICKUP SLIP           *
      *                                                      *
      *  J.W. 2017.01.31                                     *
      ********************************************************
     FAC#PW01 CF  E                    WORKSTN
     FAB#PL1J IF  E           K        DISK
     FAB#PL2J IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FAB#PL90 IF  E           K        DISK
     FAB#PL76 UF  E           K        DISK                      A
     FAB#PL80 UF  E           K        DISK                      A
     FAB#PL79 UF  E           K        DISK
     FAB#PPCT UF  E           K        DISK                      A
     FAC#PP10 UF  E           K        DISK                      A
      *--------------------------------------------------
     E                    MSG     1  12 70
     E                    PCK        15  9
     E                    BIN        15  2
     E                    ASN        15 16
      *--------------------------------------------------
     I            DS
     I                                        1 135 PCK
     I                                        1   9 D@PK01
     I                                       10  18 D@PK02
     I                                       19  27 D@PK03
     I                                       28  36 D@PK04
     I                                       37  45 D@PK05
     I                                       46  54 D@PK06
     I                                       55  63 D@PK07
     I                                       64  72 D@PK08
     I                                       73  81 D@PK09
     I                                       82  90 D@PK10
     I                                       91  99 D@PK11
     I                                      100 108 D@PK12
     I                                      109 117 D@PK13
     I                                      118 126 D@PK14
     I                                      127 135 D@PK15
     I            DS
     I                                        1  30 BIN
     I                                        1   2 D@BN01
     I                                        3   4 D@BN02
     I                                        5   6 D@BN03
     I                                        7   8 D@BN04
     I                                        9  10 D@BN05
     I                                       11  12 D@BN06
     I                                       13  14 D@BN07
     I                                       15  16 D@BN08
     I                                       17  18 D@BN09
     I                                       19  20 D@BN10
     I                                       21  22 D@BN11
     I                                       23  24 D@BN12
     I                                       25  26 D@BN13
     I                                       27  28 D@BN14
     I                                       29  30 D@BN15
     I            DS
     I                                        1   80W@NOHZ
     I                                        1   40W@NOYY
     I                                        5   60W@NOMM
     I                                        7   80W@NODD
     I            DS
     I                                        1  120#TIME
     I                                        1   20W@HH
     I                                        3   40W@MIN
     I                                        5   60W@SS
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80P8NOHZ
     I                                        1   40P8NOYY
     I                                        5   60P8NOMM
     I                                        7   80P8NODD
     I            DS
     I                                        1   80A2DATE
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
     I            DS
     I                                        1  20 BAMHN
     I                                        1   5 BAMHN1
     I                                        6  10 BAMHN2
     I                                       11  15 BAMHN3
     I                                       16  20 BAMHN4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ****************************************************
      *  MAIN ROUTINE
      ****************************************************
     C                     EXSR #INZ
      *
     C           W@ID      DOUEQ'99'
     C                     EXFMTDSP01
     C                     MOVE *OFF      *IN85
     C                     MOVE *OFF      *IN31
     C                     MOVE *OFF      *IN32
     C                     MOVE *OFF      *IN33
     C                     MOVE *OFF      *IN34
     C                     MOVE *OFF      *IN35
     C                     MOVE *BLANK    D@MSG
      *
     C                     SELEC
      * F1: END
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * F12: END
     C           *INKL     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           OKFLG1    IFEQ 'Y'
     C           *INKE     ANDEQ*ON
     C                     EXSR #WRT
     C                     MOVELW@PCK#    D@PACK
     C                     MOVELW@ASN#    D@ASN
     C                     MOVELMSG,11    D@MSG
     C                     ENDIF
     C                     Z-ADDPKCNT     D@CNT
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *==================================================
      * CHECK 1
      *==================================================
     C           #CHK1     BEGSR
      * CLEAR FIELD
     C                     MOVE *BLANK    D@PACK
     C                     MOVE *BLANK    D@ASN
      *
     C                     MOVE 'N'       OKFLG1
     C                     Z-ADD0         PKCNT   30
      *  CHECK DELIVERY
     C           D@NONY    IFEQ *BLANKS
     C                     MOVELMSG,1     D@MSG
     C                     SETON                     8531  ENTER DELIVERY
     C                     GOTO #CHK1E
     C                     ENDIF
      *
      *  CHECK FACTORY
     C           D@NKOJ    IFEQ *BLANKS
     C           *IN85     ANDEQ*OFF
     C                     MOVELMSG,2     D@MSG
     C                     SETON                     8532  ENTER FACTORY
     C                     GOTO #CHK1E
     C                     ENDIF
      *  CHECK DOCK
     C           D@NUKE    IFEQ *BLANKS
     C           *IN85     ANDEQ*OFF
     C                     MOVELMSG,10    D@MSG
     C                     SETON                     8535  ENTER DOCK
     C                     GOTO #CHK1E
     C                     ENDIF
      *
      *  CHECK SHIPPING DATE
     C                     MOVE D@NOHZ    K@YMD
     C           K@PP11    CHAINAGDPL12              99
     C           *IN99     IFEQ *ON
     C           *IN85     ANDEQ*OFF
     C                     MOVELMSG,3     D@MSG
     C                     SETON                     8533  SHIPDATE ERR
     C                     GOTO #CHK1E
     C                     ENDIF
      *  CHECK ORDER#
     C           D@ODRN    IFEQ *BLANK
     C           *IN85     ANDEQ*OFF
     C                     MOVELMSG,4     D@MSG
     C                     SETON                     8534  ORDER#   ERR
     C                     GOTO #CHK1E
     C                     ENDIF
      *
      * CHECK ORDER DATA (AB#PP10) ----------------------
     C                     MOVEA*ALL' '   PCK
     C                     MOVEA*ALL' '   BIN
     C                     MOVEA*ALL' '   ASN
     C                     Z-ADD0         BNCNT   30       BIN# COUNT
     C                     MOVE 'Y'       FIRST   1
     C                     MOVELD@NONY    K@NONY
     C                     MOVELD@NKOJ    K@NKOJ  1
     C                     MOVELD@NUKE    K@NUKE  4
     C                     MOVELD@NOHZ    K@NOHZ
     C                     MOVE *OFF      *IN90
     C           K@PL1J    SETLLAB#PL1J
     C           *IN90     DOWEQ*OFF
     C           K@PL1J    READEAB#PL1J                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDNE'D'
      *FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELBANONY    SVNONY
     C                     MOVELBANKOJ    SVNKOJ
     C                     MOVELBANUKE    SVNUKE
     C                     MOVELBANOHZ    SVNOHZ
     C                     MOVELBANOBN    SVNOBN
     C                     MOVELBAINVN    SVINVN
     C                     Z-ADD0         TRCNT            TRANSACTION COUNT
     C                     Z-ADD0         ODCNT            SAME ORDER# COUNT
     C                     Z-ADD0         URCNT            SHIPPED     COUNT
     C                     ENDIF
      *BREAK?  (ORDER# BY BIN#)
     C           BANONY    IFNE SVNONY
     C           BANKOJ    ORNE SVNKOJ
     C           BANUKE    ORNE SVNUKE
     C           BANOHZ    ORNE SVNOHZ
     C           BANOBN    ORNE SVNOBN
     C                     EXSR #BRK1
     C                     ENDIF
      *DETAIL PROCESS
     C                     ADD  1         TRCNT
     C           BAODRN    IFEQ D@ODRN
     C                     ADD  1         ODCNT
     C                     ENDIF
      * CHECK SHIPPED
     C           BAODRN    IFEQ D@ODRN
     C           BAURYY    ANDNE0
     C                     ADD  1         URCNT
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      * FINAL BREAK
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK1
     C                     ENDIF
      *
      * CHECK AND ERROR MSG -----------------
      *
     C           URCNT     IFNE 0
     C                     MOVELMSG,12    D@MSG
     C                     SETON                     853132 SHIPPED
     C                     GOTO #CHK1E
     C                     ENDIF
      *
     C           BNCNT     IFEQ 1
     C                     MOVELMSG,9     D@MSG
     C                     SETON                     853132 1 ORDER
     C                     GOTO #CHK1E
     C                     ENDIF
      *
     C           BNCNT     IFEQ 0
     C                     MOVELMSG,5     D@MSG
     C                     SETON                     853132 NO ORDER
     C                     GOTO #CHK1E
     C                     ENDIF
      *
     C           PKCNT     IFEQ 1
     C                     MOVELMSG,8     D@MSG
     C                     SETON                     853132 1 PACK LIST
     C                     GOTO #CHK1E
     C                     ENDIF
      *
     C           PKCNT     IFLE 0
     C                     MOVELMSG,7     D@MSG
     C                     SETON                     853132 NO PACK LIST
     C                     GOTO #CHK1E
     C                     ENDIF
      *
      * IF NO ERROR ============================
     C           *IN85     IFEQ *OFF
     C                     MOVE 'Y'       FLG10   1
     C                     MOVE 'Y'       OKFLG1
     C                     MOVELMSG,6     D@MSG
     C                     ENDIF
      *
     C           #CHK1E    ENDSR
      *==================================================
      * BREAK PROCESS 1
      *==================================================
     C           #BRK1     BEGSR
      *
     C           TRCNT     IFEQ ODCNT
     C                     EXSR #CHK2                      CHK PACK LIST
     C                     ELSE
     C                     GOTO #SKP1
     C                     ENDIF
      *
     C           OKFLG2    IFEQ 'Y'
     C                     ADD  1         BNCNT
     C                     ENDIF
      * RESET DATA
     C           #SKP1     TAG
     C                     MOVELBANONY    SVNONY
     C                     MOVELBANKOJ    SVNKOJ
     C                     MOVELBANUKE    SVNUKE
     C                     MOVELBANOHZ    SVNOHZ
     C                     MOVELBANOBN    SVNOBN
     C                     MOVELBAINVN    SVINVN
     C                     Z-ADD0         TRCNT            TRANSACTION COUNT
     C                     Z-ADD0         ODCNT            SAME ORDER# COUNT
      *
     C                     ENDSR
      *==================================================
      * CHECK PACKING LIST DATA
      *==================================================
     C           #CHK2     BEGSR
      *
     C                     MOVE 'N'       OKFLG2
     C                     MOVELSVNOBN    K@BIN
     C           K@PP78    SETLLAB#PL80
     C           K@PP78    CHAINAB#PL80             N91
     C           *IN91     IFEQ *OFF
     C           P8SKJY    ANDNE'D'
     C           P8ASDT    ANDEQ0
     C           P8BINN    ANDNE99
     C                     MOVE 'Y'       OKFLG2
     C                     ADD  1         PKCNT
     C                     Z-ADDPKCNT     IX      20
     C                     MOVELP8SERL    PCK,IX
     C                     MOVELP8BINN    BIN,IX
     C                     MOVELSVINVN    ASN,IX
     C                     ENDIF
      *
     C                     ENDSR
      *==================================================
      * WRITE  AB#PP78
      *==================================================
     C           #WRT      BEGSR
     C                     Z-ADD0         SVLPDT  80
     C                     Z-ADD0         SVLPTM  60
      * GET PACKING LIST# / ASN#
     C                     EXSR #GET
      * OUT/UPD AB#PP78
     C           1         DO   15        IX
     C           PCK,IX    IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
      *
     C           PCK,IX    CHAINAB#PL79              99
     C           *IN99     IFEQ *OFF
      * UPDATE PACKING LIST
     C                     MOVE 'C'       P8SKJY
     C                     MOVELD@ODRN    P8FLD1
     C                     MOVELASN,IX    P8FLD2
     C                     MOVELW@ASN#    P8FLD3
     C                     MOVELW@PCK#    P8FLD4
     C**                   MOVELD@ODRN    P8ODRN
      * SAVE LABEL DATE/TIME
     C                     Z-ADDP8LPDT    SVLPDT
     C                     Z-ADDP8LPTM    SVLPTM
      *
     C                     UPDATAB#PP781
     C                     EXSR #UP75
      * DELETE OLD AC#PP10
     C           FLG10     IFEQ 'Y'
     C                     MOVE 'N'       FLG10
     C                     EXSR #AD10D
     C                     ENDIF
      *
     C                     EXSR #AD10
      * IF FIRST, OUTPUT CONSOLIDATE PACKING LIST
     C           IX        IFEQ 1
     C                     EXSR #AD78
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *==================================================
      *  DELETE AC#PP10 (CONSOLIDATE ORDER DATA)
      *==================================================
     C           #AD10D    BEGSR
      *
     C           K@PL1J    SETLLAC#PP10
     C                     MOVE *OFF      *IN98
     C           *IN98     DOWEQ*OFF
     C           K@PL1J    READEAC#PP10                  98
     C           *IN98     IFEQ *OFF
     C           BCNOBN    ANDEQ99
     C           BCODRN    ANDEQD@ODRN
     C                     DELETAC#PP101
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *==================================================
      *  OUT AC#PP10 (CONSOLIDATE ORDER DATA)
      *==================================================
     C           #AD10     BEGSR
      *
     C           K@PL1J    SETLLAB#PL1J
     C                     MOVE *OFF      *IN98
     C           *IN98     DOWEQ*OFF
     C           K@PL1J    READEAB#PL1J                  98
     C           *IN98     IFEQ *OFF
     C           BANOBN    ANDEQP8BINN
     C           BAODRN    ANDEQD@ODRN
      * GET PP2A
     C                     MOVELBAODRN    K@ODRN
     C           K@PL2J    CHAINAB#PL2J              99
     C           *IN99     IFEQ *ON
     C                     MOVELBAMHN     ACMHIN
     C                     ENDIF
      * GET FCEPL01
     C                     EXSR #FCEP
      * CONSOLIDATE AB#PP10
     C                     Z-ADD99        K@BIN2
     C           K@PC10    CHAINAC#PP10              97
     C           *IN97     IFEQ *OFF
     C                     ADD  BASRYO    BCSRYO
     C                     ADD  BAODER    BCODER
      * RE-CALCULATE
     C                     EXSR #CALC
     C                     UPDATAC#PP101
     C                     ENDIF
      *
     C           *IN97     IFEQ *ON
      * MOVE
     C                     EXSR #MOVE
      * CALCULATE
     C                     EXSR #CALC
     C                     Z-ADD99        BCNOBN
     C                     MOVELW@ASN#    BCINVN
     C                     MOVELW@PCK#    BCPCK#
     C                     MOVELACMHIN    BCMHIN
     C                     Z-ADDP8NOHZ    BCNOHZ
      *
     C                     Z-ADD@DATE     BCCRHZ
     C                     Z-ADD@TIME     BCCRTM
     C                     MOVEL#USER     BCCRID
     C                     WRITEAC#PP101
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *==================================================
      *  CALCULATE
      *==================================================
     C           #CALC     BEGSR
      *
     C           BCSRYO    DIV  WSYOS     BCBOX#
     C                     MVR            WHAK1   40
     C           WHAK1     IFNE 0
     C                     ADD  1         BCBOX#
     C                     ENDIF
      *
     C           WSYOS     MULT BCUWGT    NWGT   103
     C                     DIV  1000      NWGT      H
     C                     ADD  BCBWGT    NWGT
     C           NWGT      MULT BCBOX#    NWGT
     C           NWGT      ADD  PWGT      BCTWGT
      *
     C                     ENDSR
      *==================================================
      *  RETRIEVE FCEPP01
      *==================================================
     C           #FCEP     BEGSR
     C* READ AB#PL90
     C                     MOVE *BLANK    @SUPP  10
     C                     Z-ADD0         PWGT    32
     C                     MOVELBANONY    LTR4    4
     C           LTR4      CHAINAB#PL90              99
     C           *IN99     IFEQ *OFF
     C                     MOVELYASUPP    @SUPP
     C           YAMXPL    IFGE 120
     C                     Z-ADD1.07      BWGT    32
     C                     ELSE
     C                     Z-ADD0.60      BWGT
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADDBWGT      BCBWGT
     C                     Z-ADDPWGT      BCPWGT
     C* READ FCEPP10
     C           K@FCEP    SETLLFCEPL01
     C           #PART     TAG
     C           K@FCEP    READEFCEPL01                  93
     C           *IN93     IFEQ *OFF
      *
     C           A2GSKD    IFEQ 'D'
     C                     GOTO #PART
     C                     END
      *
     C           P8NOHZ    IFGE A2DATE                     LOCATION
     C                     MOVE A2STRK    BCLOC1           NEW
     C                     MOVE A2STRT    BCLOC2
     C                     MOVE A2STRR    BCLOC3
     C                     MOVE A2STRD    BCLOC4
     C                     ELSE
     C                     MOVE A2KTRK    BCLOC1           OLD
     C                     MOVE A2KTRT    BCLOC2
     C                     MOVE A2KTRR    BCLOC3
     C                     MOVE A2KTRD    BCLOC4
     C                     ENDIF
     C                     Z-ADDA2KASI    W2KASI  72
     C* NOT READ FCEPL01
     C                     ELSE
     C                     MOVE *BLANK    BCLOC1
     C                     MOVE *BLANK    BCLOC2
     C                     MOVE *BLANK    BCLOC3
     C                     MOVE *BLANK    BCLOC4
     C                     Z-ADD0         W2KASI
     C                     ENDIF
     C                     Z-ADDW2KASI    BCUWGT
     C*
     C* CALUCULATE THE NUMBER OF BOXES
     C                     Z-ADDBASYOS    WSYOS   60
     C           WSYOS     IFEQ 0
     C                     Z-ADDBAUSYS    WSYOS
     C                     ENDIF
     C           WSYOS     IFEQ 0
     C                     Z-ADDBASRYO    WSYOS
     C                     ENDIF
      *
     C                     ENDSR
      *==================================================
      *  MOVE AB#PP10 TO AC#PP10
      *==================================================
     C           #MOVE     BEGSR
     C                     MOVELBASKJY    BCSKJY
     C                     MOVELBASKYY    BCSKYY
     C                     MOVELBASKMM    BCSKMM
     C                     MOVELBASKDD    BCSKDD
     C                     MOVELBAKOYY    BCKOYY
     C                     MOVELBAKOMM    BCKOMM
     C                     MOVELBAKODD    BCKODD
     C                     MOVELBAKOHH    BCKOHH
     C                     MOVELBAKOSS    BCKOSS
     C                     MOVELBAKOME    BCKOME
      *
     C           @SUPP     IFEQ *BLANK
     C                     MOVELBASIRE    BCSIRE
     C                     ELSE
     C                     MOVEL@SUPP     BCSIRE
     C                     ENDIF
      *
     C                     MOVELBASIRK    BCSIRK
     C                     Z-ADDBATOKU    BCTOKU
     C                     Z-ADDBANONY    BCNONY
     C                     MOVELBANKOJ    BCNKOJ
     C                     MOVELBANUKE    BCNUKE
     C                     MOVELBASBAN    BCSBAN
     C                     MOVELBAMHN1    BCMHN1
     C                     MOVELBAMHN2    BCMHN2
     C                     MOVELBAMHN3    BCMHN3
     C                     MOVELBAMHN4    BCMHN4
     C                     MOVELBASHN1    BCSHN1
     C                     MOVELBASHN2    BCSHN2
     C                     MOVELBASHN3    BCSHN3
     C                     Z-ADDBANOYY    BCNOYY
     C                     Z-ADDBANOMM    BCNOMM
     C                     Z-ADDBANODD    BCNODD
     C                     Z-ADDBANOTM    BCNOTM
     C                     MOVELBAINVN    BCINVN
     C                     MOVELBAODRN    BCODRN
     C                     Z-ADDBASRYO    BCSRYO
     C                     Z-ADDBASYOS    BCSYOS
     C                     Z-ADDBATANK    BCTANK
     C                     Z-ADDBAURYY    BCURYY
     C                     Z-ADDBAURMM    BCURMM
     C                     Z-ADDBAURDD    BCURDD
     C                     MOVELBACARD    BCCARD
     C                     MOVELBARCOD    BCRCOD
     C                     MOVELBAALFL    BCALFL
     C                     Z-ADDBANOBN    BCNOBN
     C                     Z-ADDBAUSYS    BCUSYS
     C                     MOVELBAODER    BCODER
     C                     MOVELBAHENK    BCHENK
     C                     MOVELBAJYKB    BCJYKB
     C                     MOVELBAEDIK    BCEDIK
     C                     MOVELBARESE    BCRESE
     C                     Z-ADDBADEYY    BCDEYY
     C                     Z-ADDBADEMM    BCDEMM
     C                     Z-ADDBADEDD    BCDEDD
     C                     MOVELBAPGID    BCPGID
     C                     ENDSR
      *=========================BCCRID  ==================
      *  GET PACKING LIST# --> W@PCK#  9A
      *      ASN#          --> W@ASN#  6A
      *==================================================
     C           #GET      BEGSR
      * GET PACKING LIST# -------------------------
     C                     MOVEL'PICKLIST'K@KWD1
     C                     MOVE *YEAR     @@YY    2
     C                     MOVE *MONTH    @@MM    2
     C           @@YY      CAT  @@MM:0    K@KWD2    P
     C           K@PPCT    CHAINAB#PPCT              99
     C           *IN99     IFEQ *OFF
     C                     ADD  1         CTNBR1
     C                     UPDATAB#PPCT1
     C                     ELSE
     C                     CLEARAB#PPCT1
     C                     MOVELK@KWD1    CTKEY1
     C                     MOVELK@KWD2    CTKEY2
     C                     ADD  1         CTNBR1
     C                     WRITEAB#PPCT1
     C                     ENDIF
      *
     C                     Z-ADDCTNBR1    @@5     50
     C                     MOVE @@5       @@5C    5
     C           K@KWD2    CAT  @@5C:0    BARC    9 P
     C                     MOVELBARC      W@PCK#  9
      *
      *  GET ASN#  ---------------------------------
     C                     MOVEL'HONDA'   K@KWD1    P
     C                     MOVEL'ASN# '   K@KWD2    P
     C           K@PPCT    CHAINAB#PPCT              99
     C           *IN99     IFEQ *OFF
     C                     ADD  1         CTNBR1
     C           CTNBR1    IFGT 99999999
     C                     Z-ADD1         CTNBR1
     C                     ENDIF
     C                     UPDATAB#PPCT1
     C                     ELSE
     C                     CLEARAB#PPCT1
     C                     MOVELK@KWD1    CTKEY1
     C                     MOVELK@KWD2    CTKEY2
     C                     ADD  1         CTNBR1
     C                     WRITEAB#PPCT1
     C                     ENDIF
      *
     C                     MOVE CTNBR1    @@8     8
     C           '0'       CHECK@@8       X       20     10
     C           *IN10     IFEQ *ON
     C           8         SUB  X         XX      20
     C                     ADD  1         XX
     C           XX        SUBST@@8:X     W@8     8
     C                     ELSE
     C                     MOVE @@8       W@8
     C                     ENDIF
      *
     C                     MOVELW@8       W@ASN#  6
      *
     C                     ENDSR
      *
      *==================================================
      *  OUTPUT AB#PP78
      *==================================================
     C           #AD78     BEGSR
      * OUTPUT AB#PP78
     C                     MOVE *BLANK    P8SKJY
     C                     Z-ADD99        P8BINN
     C                     MOVELW@PCK#    P8SERL
     C                     MOVELD@ODRN    P8ODRN
     C                     Z-ADDSVLPDT    P8LPDT
     C                     Z-ADDSVLPTM    P8LPTM
     C                     Z-ADD0         P8ASDT
     C                     Z-ADD0         P8ASTM
     C                     Z-ADD0         P8SPDT
     C                     Z-ADD0         P8SPTM
     C                     MOVELW@ASN#    P8FLD2
     C                     MOVELW@ASN#    P8FLD3
     C                     MOVELW@PCK#    P8FLD4
     C                     Z-ADD@DATE     P8KODT
     C                     Z-ADD@TIME     P8KOTM
     C                     MOVEL#USER     P8KONM
     C                     WRITEAB#PL801
     C                     EXSR #AD75
      *
      * DELETE BIN=99 RECORD IF CONSOLIDATE# IS OLD
     C                     Z-ADD99        K@BIN
     C                     MOVE *OFF      *IN92
     C           K@PP78    SETLLAB#PL80
     C           *IN92     DOWEQ*OFF
     C           K@PP78    READEAB#PL80                  92
     C           *IN92     IFEQ *OFF
     C                     MOVELP8FLD4    P8LT9   9
     C                     MOVELP8FLD1    P8LTA  10
     C           P8LT9     IFNE W@PCK#
*    C           P8LTA     ANDEQD@ODRN
     C                     MOVE 'D'       P8SKJY
     C                     Z-ADD@DATE     P8SKDT
     C                     Z-ADD@TIME     P8SKTM
     C                     MOVEL#USER     P8SKNM
     C                     UPDATAB#PL801
      * DELETE AB#PP75
     C           P8SERL    CHAINAB#PL76              99
     C           *IN99     IFEQ *OFF
     C                     MOVE 'D'       PUSKJY
     C                     Z-ADD@DATE     PUSKDT
     C                     UPDATAB#PP751
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *==================================================
      *  UPDATE AB#PP75
      *==================================================
     C           #UP75     BEGSR
      *
     C           P8SERL    CHAINAB#PL76              99
     C           *IN99     IFEQ *OFF
     C                     SELEC
     C           P8SKJY    WHEQ 'D'
     C                     MOVE 'D'       PUSKJY
     C                     Z-ADD@DATE     PUSKDT
     C           P8SKJY    WHEQ 'C'
     C                     MOVE 'C'       PUSKJY
     C**                   MOVELP8ODRN    PUODRN
     C                     ENDSL
     C                     UPDATAB#PP751
     C                     ENDIF
      *
     C                     ENDSR
      *==================================================
      *  OUPPUT AB#PP75 (BIN=99)
      *==================================================
     C           #AD75     BEGSR
      *
     C                     CLEARAB#PP751
     C                     Z-ADD@DATE     PUKODT
     C                     Z-ADD@TIME     PUKOTN
     C                     MOVEL#USER     PUKOME
     C                     Z-ADDP8CUST    PUCUST
     C                     Z-ADDP8NONY    PUNONY
     C                     MOVELP8NKOJ    PUNKOJ
     C                     MOVELP8NUKE    PUNUKE
     C                     Z-ADD99        PUBINN
     C                     MOVELP8SERL    PUSERL
     C                     MOVELD@ODRN    PUODRN
     C                     Z-ADDP8NOYY    PUNOYY
     C                     Z-ADDP8NOMM    PUNOMM
     C                     Z-ADDP8NODD    PUNODD
     C                     Z-ADDP8RLYY    PURLYY
     C                     Z-ADDP8RLMM    PURLMM
     C                     Z-ADDP8RLDD    PURLDD
     C                     Z-ADDP8LPDT    PULPDT
     C                     WRITEAB#PP751
      *
     C                     ENDSR
      *==================================================
