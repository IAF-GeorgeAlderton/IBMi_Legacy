     C           *ENTRY    PLIST
     C                     PARM           PKBN    1
     C                     PARM           PCD     3
     C                     MOVE PCD       WCD     31
      *
     C           *INMR     IFEQ '0'
      *
     C*-----------------------------------------*
     C*      ...売上データに無かった時...     *
     C*-----------------------------------------*
     C           *IN01     IFEQ '1'
     C                     Z-ADDNTOKU     WTOKU   40
     C                     Z-ADDNNONY     WNONY   40
     C                     MOVE NNKOJ     WNKOJ   1
     C                     MOVE NNUKE     WNUKE   4
     C                     MOVE NMHIN     WMHIN  20
     C                     MOVE NSHIN     WSHIN  12
     C                     MOVE NGKOJ     WGKOJ   1
     C                     MOVE NGUKE     WGUKE   4
     C                     MOVE NSEBN     WSEBN   4
     C                     MOVE NNOKU     WNOKU   1
     C           PKBN      IFEQ 'A'
     C                     Z-ADD0         NN1GM
     C                     Z-ADD0         NN1ND
     C                     END
     C                     EXCPTDT
     C                     ELSE
      *
     C*-----------------------------------------*
     C*      ...内示データに無かった時...     *
     C*-----------------------------------------*
     C                     Z-ADDJTOKU     WTOKU
     C                     Z-ADDJNONY     WNONY
     C                     MOVE JNKOJ     WNKOJ
     C                     MOVE JNUKE     WNUKE
     C                     MOVE JMHIN     WMHIN
     C                     MOVE JSHIN     WSHIN
     C                     MOVE JGKOJ     WGKOJ
     C                     MOVE JGUKE     WGUKE
     C                     MOVE JSEBN     WSEBN
     C                     MOVE 'C'       WNOKU
     C                     MOVE *BLANK    NCHNK
     C                     Z-ADD0         NCHNM
     C                     MOVE *BLANK    NNNNK
     C                     Z-ADD0         NNNNM
     C                     Z-ADD0         NS
     C                     MOVE *BLANK    N1NNK
     C                     Z-ADD0         N1NNM
     C                     MOVE *BLANK    N2NNK
     C                     Z-ADD0         N2NNM
     C                     Z-ADD0         NN3GM
     C                     Z-ADD0         NN3ND
     C                     Z-ADD0         NN2GM
     C                     Z-ADD0         NN2ND
     C                     Z-ADD0         NNAIG
     C                     Z-ADD0         NSYUY
     C                     MOVE *BLANK    NTANI
     C                     Z-ADD0         NUSER
     C                     Z-ADDJSURY     NN1GM
     C           NN1GM     DIV  WCD       NN1ND
     C                     EXCPTDT
     C                     END
     C                     ELSE
      *
     C*-------------------------------*
     C*      ...マッチした時...     *
     C*-------------------------------*
