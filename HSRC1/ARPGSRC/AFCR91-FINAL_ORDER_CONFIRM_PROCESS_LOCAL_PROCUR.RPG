      *
     C                     Z-ADD4511      ISIRE
     C                     MOVE *BLANK    WDATA   1
      *----------*
      * SCREEN 1 *
      *----------*
     C           @STP1     TAG
     C                     EXFMTAFCPW911
     C                     SETOF                     0102
     C                     SETOF                     99
      *-------*
      * CMD-1 *
      *-------*
     C           *INKA     IFEQ '1'
     C                     SETON                     LRU1
     C                     RETRN
     C                     END
      *
     C           ISIRE     IFEQ *ZERO
     C                     SETON                     0199
     C                     MOVELER,1      MSG
     C                     GOTO @STP1
     C                     END
      *
     C                     SETOF                     20
     C           ISIRE     CHAINFGBPL011             20
      *
     C           *IN20     IFEQ '0'
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     20
     C                     ELSE
     C                     MOVELB2SMEI    WVDNM  20
     C                     END
     C                     END
      *
     C           *IN20     IFEQ '1'
     C                     SETON                     0199
     C                     MOVELER,2      MSG
     C                     GOTO @STP1
     C                     END
      *
     C           WARN      IFEQ '*'
     C           *INKL     ANDEQ'1'
     C                     GOTO @JUMP
     C                     END
      *
     C           ILOTS     IFEQ 0
     C                     MOVEL'*'       WARN    1
     C           ILOTS     IFEQ 0
     C                     SETON                     0299
     C                     END
     C*
     C                     MOVELER,5      MSG
     C                     GOTO @STP1
     C                     ELSE
     C                     MOVEL*BLANK    WARN
     C                     END
      *
      *-------*
      * CMD-5 *
      *-------*
     C           *INKE     IFEQ '0'
     C                     GOTO @STP1
     C                     END
     C*-------------------*
     C* AFCPP9O ERR CHECK *
     C*-------------------*
     C           @JUMP     TAG
     C                     SETOF                     20
     C           ISIRE     SETLLAFCPL911
     C                     DO   *HIVAL
     C           ISIRE     READEAFCPL911                 20
     C           *IN20     IFEQ '0'
     C           C9SKJY    IFEQ 'D'
     C           C9SKHZ    ANDLE*DATE
     C                     ELSE
     C           C9ERR     IFNE *BLANK
     C                     SETON                     99
     C                     MOVELER,4      MSG
     C                     GOTO @STP1
     C                     END
     C                     END
     C                     END
     C  N20                ENDDO
      *
     C                     MOVEL*BLANK    #NOP
     C                     MOVEL*BLANK    #DSC
     C                     MOVEL*BLANK    #LOC
     C                     MOVEL*BLANK    #QTY
     C                     Z-ADD0         Y       30
     C                     Z-ADD0         Z       30
     C                     Z-ADD0         THAKO   50
     C                     MOVEL'/'       WDUMY1
     C                     MOVEL' KG'     WDUMY2
     C                     MOVEL'*'       WDUMY3
     C                     MOVEL'COIL'    WDUMY4
     C                     MOVEL'(KG)'    PFUNT1
     C*--------------*
     C* READ AFCPP90 *
     C*--------------*
     C                     SETOF                     20
     C           ISIRE     SETLLAFCPL911
