     C           *IN10     IFEQ *OFF
     C           'SCR15'   SCAN C9ZAIS                   10
     C   10                MOVE 'C'       AWCOID
     C                     ENDIF
     C           *IN10     IFEQ *OFF
     C           'SCR40'   SCAN C9ZAIS                   10
     C   10                MOVE 'D'       AWCOID
     C                     ENDIF
     C           *IN10     IFEQ *OFF
     C           'CH45K'   SCAN C9ZAIS                   10
     C   10                MOVE 'E'       AWCOID
     C                     ENDIF
     C           *IN10     IFEQ *OFF
     C           'SB25'    SCAN C9ZAIS                   10
     C   10                MOVE 'F'       AWCOID
     C                     ENDIF
     C           *IN10     IFEQ *OFF
     C           'NACH8'   SCAN C9ZAIS                   10
     C   10                MOVE 'G'       AWCOID
     C                     ENDIF
     C           *IN10     IFEQ *OFF
     C           'SAE15B24'SCAN C9ZAIS                   10
     C   10                MOVE 'H'       AWCOID
     C                     ENDIF
     C           *IN10     IFEQ *OFF
     C           'SAE1022' SCAN C9ZAIS                   10
     C   10                MOVE 'I'       AWCOID
     C                     ENDIF
     C           *IN10     IFEQ *OFF
     C           'CH12A'   SCAN C9ZAIS                   10
     C   10                MOVE 'J'       AWCOID
     C                     ENDIF
     C           *IN10     IFEQ *OFF
     C           'NHF55'   SCAN C9ZAIS                   10
     C   10                MOVE 'K'       AWCOID
     C                     ENDIF
     C           *IN10     IFEQ *OFF
     C           'CH18A'   SCAN C9ZAIS                   10
     C   10                MOVE 'L'       AWCOID
     C                     ENDIF
     C           *IN10     IFEQ *OFF
     C           'NHF55-8' SCAN C9ZAIS                   10
     C   10                MOVE 'M'       AWCOID
     C                     ENDIF
     C           *IN10     IFEQ *OFF
     C           'NHF55-S' SCAN C9ZAIS                   10
