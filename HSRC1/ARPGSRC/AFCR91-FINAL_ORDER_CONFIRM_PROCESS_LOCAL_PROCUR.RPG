     C**************************************************************************
     C* WRITE BILL OF LADING FILE
     C**************************************************************************
     C           #MOVE3    BEGSR
     C*
     C                     MOVELWTONM     BFTONM
     C                     MOVELWSH01     BFSH01
     C                     MOVELWSH02     BFSH02
     C                     MOVELWSH03     BFSH03
     C                     MOVELWFRNM     BFFRNM
1    C                     MOVELWFR01     BFFR01
     C                     MOVELWFR02     BFFR02
     C*NUMBER OF STANDS
     C                     Z-ADDILOTS     PIN
     C                     MOVEL*BLANK    POUT
     C                     Z-ADD0         PLEN
     C                     CALL 'AB#R2N'
     C                     PARM           PIN    305
     C                     PARM           POUT   30
     C                     PARM           PLEN    20
     C                     MOVE POUT      WLOTS   5
     C*
     C                     MOVELWLOTS     BFQTN1           SHIP UNIT
     C                     MOVE CMT,1     BFPTN1           PART# & UNIT
     C*
     C* WEIGHT
     C           ILOTS     MULT 60        WWEIGH  50
     C                     Z-ADDWWEIGH    PIN
     C                     MOVEL*BLANK    POUT
     C                     Z-ADD0         PLEN
     C                     CALL 'AB#R2N'
     C                     PARM           PIN    305
     C                     PARM           POUT   30
     C                     PARM           PLEN    20
     C                     MOVE POUT      WNET1  10
     C                     MOVE WNET1     BFWTN1
     C*
     C                     MOVEL'LB'      BFRTN1
     C*
     C                     MOVE CMT,2     BFPTNH           TOTAL GROSS
     C                     MOVELWNET1     BFWTNH           TOTAL WEIGHT
     C                     MOVE WWODNO    BFVHNO           VEHICLE NO.
     C                     MOVEL'LB'      BFRTNH
     C                     WRITEAFAPP70R
     C*
     C           EMOVE3    ENDSR
     C**************************************************************************
     C* WRITE PURCHASE REQUISITION FILE
     C**************************************************************************
     C           #MOVE4    BEGSR
     C*
