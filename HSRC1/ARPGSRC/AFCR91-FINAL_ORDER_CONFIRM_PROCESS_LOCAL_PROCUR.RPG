     C                     ENDIF
     C           *IN10     IFEQ *OFF
     C                     MOVE 'Z'       AWCOID
     C                     ENDIF
      *
     C           1         DO   C9COIL    X       30
     C                     MOVE X         AWPAGE
     C           AWWRID    CAT  AWPAGE:0  AWBARC
     C                     WRITEAFCWP901
     C                     ENDDO
      *
     C                     ENDSR
     C**************************************************************************
     C*          GET THE ODER NUMBER
     C**************************************************************************
     C           #ODNO     BEGSR
     C*
     C                     Z-ADD*YEAR     KYEAR
     C                     Z-ADDUMONTH    KMONTH
     C                     Z-ADD0         WWODNO  60       ORDER NO.
     C                     SETOF                     22
     C           KEY5      CHAINAFCNP911             22
     C           *IN22     IFEQ '1'
     C                     Z-ADD*YEAR     CAREYY
     C                     Z-ADDUMONTH    CAREMM
     C                     Z-ADD1         CARENO
     C                     Z-ADDCAODNO    WWODNO
     C                     WRITEAFCNP911
     C*
     C                     ELSE
     C                     ADD  1         CARENO
     C                     Z-ADDCAODNO    WWODNO
     C                     UPDATAFCNP911
     C                     END
     C           EODNO     ENDSR
     C**************************************************************************
     C* GET THE ESTIMATED DATE FOR RECEIVING
     C**************************************************************************
     C           #NOKI     BEGSR
     C*
     C                     MOVEL*DATE     KDATE   80
     C                     MOVELC9KAKE    KSUPP   40
     C                     MOVEL'A'       KTAIP   1
     C                     SETOF                     21
     C           KEY2      CHAINGCKPL211             21
     C           *IN21     IFEQ '0'
     C           T2SKJY    IFEQ 'D'
     C           T2SKHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADD0         WSKR    30
     C           T2SKR1    MULT T2SKR3    WSKR
     C           WSKR      IFNE *ZERO
     C                     SETOF                     21
     C           KEY3      SETLLAGDPL111
     C           1         DO   WSKR
     C                     READ AGDPL111                 21
     C           *IN21     IFEQ '0'
     C                     Z-ADDF8KAHZ    KDATE   80
     C                     END
     C  N21                ENDDO
     C                     ENDIF
      *
     C                     END
     C                     END
     C                     Z-ADDKDATE     WNOKI   80
     C*
     C           ENOKI     ENDSR
     C**************************************************************************
     C* SET ADDRESS (SUPPLIER AND IAF)
     C**************************************************************************
     C           #ADDR     BEGSR
     C*
     C                     SETOF                     21
     C                     MOVE C9KAKE    WKAKE   4
     C           WKAKE     CHAINEDIPL401             21
     C           *IN21     IFEQ '0'
     C           E4SKJY    IFEQ 'D'
     C           E4SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELE4ADD1    WTONM  40
     C                     MOVELE4ADD1    AWSUPL
     C                     MOVELE4ADD2    WSH01  40
     C                     MOVELE4ADD3    WSH02  40
     C                     MOVELE4ADD4    WSH03  40
     C                     END
     C                     END
     C*
     C                     MOVEL'0111'    WWSUPP  4
     C                     SETOF                     21
     C           WWSUPP    CHAINEDIPL401             21
     C           *IN21     IFEQ '0'
     C           E4SKJY    IFEQ 'D'
     C           E4SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELE4ADD1    WFRNM  40
     C                     MOVELE4ADD2    WFR01  40
     C                     MOVELE4ADD3    WFR02  40
     C                     END
     C                     END
     C*
     C           EADDR     ENDSR
     C**************************************************************************
     C* UPDATE AFCPP80:SCANED FILE
     C**************************************************************************
     C           #UPDT     BEGSR
     C*
     C                     SETOF                     21
     C           KEY1      SETLLAFCPL811
     C                     DO   *HIVAL
     C           KEY1      READEAFCPL811                 21
     C           *IN21     IFEQ '0'
     C           C8SKJY    IFEQ 'D'
     C           C8SKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #MOVE2
     C                     UPDATAFCPL811
     C                     END
     C                     END
     C  N21                ENDDO
     C*
     C           EUPDT     ENDSR
     C**************************************************************************
     C* SET PICK-UP LIST & BILL OF LADING & PURCHASE REQUISITION
     C**************************************************************************
     C           #DATA     BEGSR
     C*
     C                     ADD  C9COIL    THAKO
     C*//PURCHASE REQUISITION//
     C                     ADD  1         Z
     C                     MOVELC9ZAIS    #NOP,Z
     C                     MOVELC9ZAIS    AWMATR
     C*DIAMETER
     C                     Z-ADDC9ZAIK    PIN
     C                     MOVEL*BLANK    POUT
     C                     Z-ADD2         PLEN
     C                     CALL 'AB#R2N'
     C                     PARM           PIN    305
     C                     PARM           POUT   30
     C                     PARM           PLEN    20
     C                     MOVE POUT      WZAIK
     C                     MOVE POUT      AWDIAM
     C*BOX
     C                     Z-ADDC9COIL    PIN
     C                     MOVEL*BLANK    POUT
     C                     Z-ADD0         PLEN
     C                     CALL 'AB#R2N'
     C                     PARM           PIN    305
     C                     PARM           POUT   30
     C                     PARM           PLEN    20
     C                     MOVE POUT      WCOIL
     C                     MOVE POUT      AWTOTL
     C*WEIGHT / COIL
     C                     Z-ADDC9TKJR    PIN
     C                     MOVEL*BLANK    POUT
     C                     Z-ADD0         PLEN
     C                     CALL 'AB#R2N'
     C                     PARM           PIN    305
     C                     PARM           POUT   30
     C                     PARM           PLEN    20
     C                     MOVE POUT      WTKJR
     C                     MOVE POUT      AWGWGH
     C                     MOVE @DSC      #DSC,Z
     C*QTY.
     C           C9COIL    MULT C9TKJR    C9SRYO  80
     C                     Z-ADDC9SRYO    PIN
     C                     MOVEL*BLANK    POUT
     C                     Z-ADD0         PLEN
     C                     CALL 'AB#R2N'
     C                     PARM           PIN    305
     C                     PARM           POUT   30
     C                     PARM           PLEN    20
     C                     MOVE POUT      #QTY,Z
      *
     C                     MOVE *BLANK    @@LOC
     C           K#IZ      SETGTIZAPL01
     C           *IN96     DOUEQ*ON
     C           K#IZ      REDPEIZAPL01                  96
     C           *IN96     IFEQ *OFF
     C           ZCSKJY    ANDEQ*BLANK
     C           *DATE     ANDGEZCUKDT
     C           *DATE     ANDLEZCSTDT
     C                     MOVELZCADR1    @@L1
     C                     MOVELZCADR2    @@L2
     C                     MOVELZCADR3    @@L3
     C                     MOVELZCADR4    @@L4
     C                     MOVELZCADR1    AWLOC1
     C                     MOVELZCADR2    AWLOC2
     C                     MOVELZCADR3    AWLOC3
     C                     MOVELZCADR4    AWLOC4
     C                     MOVELZCZIRO    AWCOLR
     C                     Z-ADDZCSLTM    AWLTME
     C           ZCKNO2    CAT  ZCKNO3:0  AWWRID
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *BLANK    W@LOC
     C           @@LOC     IFNE *BLANK
     C                     MOVE '-'       W@L11
     C                     MOVE '-'       W@L22
     C                     MOVE '-'       W@L33
     C                     MOVE @@L1      W@L1
     C                     MOVE @@L2      W@L2
     C                     MOVE @@L3      W@L3
     C                     MOVE @@L4      W@L4
     C                     ENDIF
     C                     MOVE W@LOC     #LOC,Z
      *
     C           EDATA     ENDSR
     C**************************************************************************
     C* PRINT PICK-UP LIST
     C**************************************************************************
     C           #LIST     BEGSR
     C*
     C           C9COIL    MULT C9TKJR    C9SRYO  80
     C           *IN72     IFEQ '0'
     C           *IN71     IFEQ '1'
