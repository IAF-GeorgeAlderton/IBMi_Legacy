     C           ISIRE     READEAFCPL911                 20
     C           *IN20     IFEQ '0'
     C           C9SKJY    IFEQ 'D'
     C           C9SKHZ    ANDLE*DATE
     C                     ELSE
     C           *IN90     IFEQ '0'
      *
     C                     CLEARAFCWP901
      *
     C                     MOVEL'*'       WDATA
     C                     EXSR #ODNO
     C                     EXSR #NOKI
     C                     EXSR #ADDR
     C***                  EXCPT#HD1
     C                     SETON                     90
     C                     END
     C                     EXSR #DATA
     C                     EXSR #UPDT
     C                     EXSR #LIST
     C                     EXSR #MOVE1
     C                     UPDATAFCPL911
      *
     C                     EXSR #KAN
     C*//PURCHASE REQUISITION//
     C           Z         IFEQ 15
     C                     EXSR #MOVE4
     C                     END
     C                     END
     C                     END
     C  N20                ENDDO
     C*
     C           WDATA     IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,3      MSG
     C                     GOTO @STP1
     C                     END
