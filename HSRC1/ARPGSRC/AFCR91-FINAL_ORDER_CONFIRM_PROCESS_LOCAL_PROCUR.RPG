     C*//BILL OF LADING//
     C                     EXSR #MOVE3
     C*//PURCHASE REQUISITION//
     C                     EXSR #MOVE4
     C*// PICKUP LIST//
     C                     SETON                     72
     C                     EXSR #LIST
     C*
     C                     SETON                     LR
     C                     RETRN
     C**************************************************************************
     C*          KANBAN DATA
     C**************************************************************************
     C           #KAN      BEGSR
     C*
     C                     MOVE C9COIL    AWTOTL
     C           'SCM35'   SCAN C9ZAIS                   10
