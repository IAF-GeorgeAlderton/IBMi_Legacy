     C           #DSP03    BEGSR
     C                     Z-ADD1         W3SCNT  20
     C                     EXSR #SET3
      * SET INDICATOR
     C           D2DTW1    SUB  D2DTE1    D2DTD1
     C           D2DTW2    SUB  D2DTE2    D2DTD2
     C           D2DTW3    SUB  D2DTE3    D2DTD3
      *
     C           D2DTW1    IFEQ D2DTE1
