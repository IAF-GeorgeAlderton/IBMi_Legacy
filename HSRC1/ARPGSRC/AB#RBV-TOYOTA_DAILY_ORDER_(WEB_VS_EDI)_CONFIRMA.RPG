      *=====================================================
      *   MAIN ROUTINE
      *=====================================================
     C                     EXSR #INIT
      *
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #DSP01
     C           @@ID      CASEQ'02'      #DSP02
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *=====================================================
      * 1ST SCREEN
      *=====================================================
     C           #DSP01    BEGSR
     C                     MOVE CMD,1     D@CMD
      *
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
      * F1 END
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
      * ENTER
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN85     IFEQ *OFF
     C                     EXSR #SET1
     C           RRN1      IFGT *ZERO
     C                     MOVE '02'      @@ID
     C                     ELSE
     C                     MOVELMSG,3     D@MSG
     C                     END
     C                     END
     C                     ENDSL
      *
     C                     ENDSR
      *=====================================================
      * CHECK DATA ENTERED
      *=====================================================
     C           #CHK1     BEGSR
     C                     MOVEL*OFF      *IN61
     C                     MOVEL*OFF      *IN62
     C                     MOVE *OFF      *IN85
     C                     MOVE *BLANK    D@MSG
      *
     C           D@FRM     IFEQ *ZERO
     C                     MOVELMSG,1     D@MSG
     C                     SETON                     6185
     C                     GOTO XCHK1
     C                     END
      *
     C                     Z-ADDD@FRM     W@YMD
     C           K#AGDP    KLIST
     C                     KFLD           W@YY
     C                     KFLD           W@MM
     C                     KFLD           W@DD
     C           K#AGDP    CHAINAGDPL12              91
     C           *IN91     IFEQ *ON
     C                     MOVELMSG,2     D@MSG
     C                     SETON                     6185
     C                     GOTO XCHK1
     C                     END
      *
     C           XCHK1     ENDSR
      *=====================================================
      * SET SFL01
      *=====================================================
     C           #SET1     BEGSR
     C                     Z-ADD1         W@SCNT  20
     C*
     C                     CLEARSDT
     C                     CLEAR#DS
     C                     CLEAR@@A
     C                     CLEAR##DW
     C                     CLEAR##DE
     C                     Z-ADD*ZERO     J       20
     C*
     C                     MOVE *ON       *IN57
     C                     WRITECTL01
     C                     MOVE *OFF      *IN57
     C                     Z-ADD*ZERO     RRN1    40
     C* CREATE WF (AB#WPBV)
     C                     EXSR #SET11
     C                     EXSR #SET12
      * OUT SFL01
     C                     MOVE 'Y'       FIRST   1
     C           *LOVAL    SETLLAB#WPBV
     C*
     C                     DO   *HIVAL
     C                     READ AB#WPBV                  94
     C   94                LEAVE
     C* FIRST ?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELAWSEQ#    SVSEQ#
     C                     MOVELAWNOBN    SVNOBN
     C                     CLEAR##DW
     C                     CLEAR##DE
     C                     CLEAR##AW
     C                     CLEAR##AE
     C                     ENDIF
      * BREAK ?
     C           AWSEQ#    IFNE SVSEQ#
     C                     EXSR #BRK1
     C                     ENDIF
      * DETAIL PROCESS
     C           1         DO   3         J
     C                     SELEC
     C           AWWE      WHEQ 'W'
     C           AWNOBN    IFEQ 0
     C                     ADD  @@A,J     ##DW,J           WEB TOTAL
     C                     ELSE
     C                     ADD  @@A,J     ##AW,J           WEB DETAIL
     C                     ENDIF
      *
     C           AWWE      WHEQ 'E'
     C           AWNOBN    IFEQ 0
     C                     ADD  @@A,J     ##DE,J           EDI TOTAL
     C                     ELSE
     C                     ADD  @@A,J     ##AE,J           EDI DETAIL
     C                     END
     C                     ENDSL
     C                     ENDDO
      *
     C                     ENDDO
      * LAST BREAK
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK1
     C                     ENDIF
     C* WRITE HEADER
     C           RRN1      IFGT 0
     C           1         DO   3         JX      20
     C           SDT,JX    IFNE *BLANK
     C           SDT,JX    ANDNE'00000000'
     C                     MOVELSDT,JX    #DT,JX
      * DATE FORMAT
     C                     MOVELSDT,JX    $SRC      P
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTNX   1
     C           $RTNX     IFEQ *BLANK
     C                     MOVE *ALL'='   LTR12  12
     C                     MOVEL$TRUE2    LTR12
     C                     MOVE *ALL'='   #DS,JX
     C                     MOVE LTR12     #DS,JX
     C                     ELSE
     C                     MOVE *ALL'X'   LTR12  12
     C                     MOVEL$SRC      LTR12
     C                     MOVE *ALL'X'   #DS,JX
     C                     MOVE LTR12     #DS,JX
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
     C                     ENDIF
      *
     C                     Z-ADD1         #RCNO1
      *
     C                     ENDSR
      *=====================================================
      * BREAK 1
      *=====================================================
     C           #BRK1     BEGSR
      *
     C                     SELEC
     C           SVSEQ#    WHEQ 0001
     C                     MOVEL'NUMMI'   S1BNM     P
     C                     MOVE '0541'    S1BNM
     C           SVSEQ#    WHEQ 0002
     C                     MOVEL'TMMAL'   S1BNM     P
     C                     MOVE '3764'    S1BNM
     C           SVSEQ#    WHEQ 0003
     C                     MOVEL'TMMBC'   S1BNM     P
     C                     MOVE '3481'    S1BNM
     C           SVSEQ#    WHEQ 0004
     C                     MOVEL'TMMC'    S1BNM     P
     C                     MOVE '3503'    S1BNM
     C           SVSEQ#    WHEQ 0005
     C                     MOVEL'TMMI'    S1BNM     P
     C                     MOVE '3804'    S1BNM
     C           SVSEQ#    WHEQ 0006
     C                     MOVEL'TMMK'    S1BNM     P
     C                     MOVE '3347'    S1BNM
     C           SVSEQ#    WHEQ 0007
     C                     MOVEL'TMMNK'   S1BNM     P
     C                     MOVE '3220'    S1BNM
     C           SVSEQ#    WHEQ 0008
     C                     MOVEL'TMMTX'   S1BNM     P
     C                     MOVE '3851'    S1BNM
     C           SVSEQ#    WHEQ 0009
     C                     MOVEL'TMMWV'   S1BNM     P
     C                     MOVE '3931'    S1BNM
     C           SVSEQ#    WHEQ 0010
     C                     MOVEL'TMMMS'   S1BNM     P
     C                     MOVE '3428'    S1BNM
     C           SVSEQ#    WHEQ 0011
     C                     MOVEL'TMMGT'   S1BNM     P
     C                     MOVE '3226'    S1BNM
     C           SVSEQ#    WHEQ 0012
     C                     MOVEL'MTMUS'   S1BNM     P
     C                     MOVE '3770'    S1BNM
     C           SVSEQ#    WHEQ 0013
     C                     MOVEL'TBMNC'   S1BNM     P
     C                     MOVE '3941'    S1BNM
     C                     ENDSL
      *
     C                     MOVELSVSEQ#    S1BSQ#
      * SET INDICATOR
     C           S1B#W1    SUB  S1B#E1    S1B#D1
     C           S1B#W2    SUB  S1B#E2    S1B#D2
     C           S1B#W3    SUB  S1B#E3    S1B#D3
      *
     C           S1B#W1    IFEQ S1B#E1
     C                     MOVE *OFF      *IN41
     C                     ELSE
     C                     MOVE *ON       *IN41
     C                     ENDIF
     C           S1B#W2    IFEQ S1B#E2
     C                     MOVE *OFF      *IN42
     C                     ELSE
     C                     MOVE *ON       *IN42
     C                     ENDIF
     C           S1B#W3    IFEQ S1B#E3
     C                     MOVE *OFF      *IN43
     C                     ELSE
     C                     MOVE *ON       *IN43
     C                     ENDIF
     C                     MOVE *IN41     #41
     C                     MOVE *IN42     #42
     C                     MOVE *IN43     #43
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
      * RESET
     C                     MOVELAWSEQ#    SVSEQ#
     C                     MOVELAWNOBN    SVNOBN
     C**                   CLEAR##DW
     C**                   CLEAR##DE
     C                     CLEAR##AW
     C                     CLEAR##AE
      *
     C                     ENDSR
      *=====================================================
      * SET EDI DATA IN WORK FILE AB#WPBV
      *=====================================================
     C           #SET11    BEGSR
      * CLEAR AB#WPBV
     C                     CLOSEAB#WPBV
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN AB#WPBV
     C*
     C                     Z-ADDD@FRM     W@FRM
     C           K#PL19    KLIST
     C                     KFLD           W@FYY
     C                     KFLD           W@FMM
     C                     KFLD           W@FDD
     C           K#PL19    SETLLAB#PL19C
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AB#PL19C                 92
     C   92                LEAVE
     C           BASKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C*
     C                     SELEC
      **NUMMI
     C           BANONY    WHEQ 0541
     C                     Z-ADD0001      W@LIN#  40
      **TMMAL
     C           BANONY    WHEQ 3764
     C                     Z-ADD0002      W@LIN#  40
      **TMMBC
     C           BANONY    WHEQ 3481
     C                     Z-ADD0003      W@LIN#  40
      **TMMC
     C           BANONY    WHEQ 3503
     C                     Z-ADD0004      W@LIN#  40
      **TMMI
     C           BANONY    WHEQ 3804
     C                     Z-ADD0005      W@LIN#  40
      **TMMK
     C           BANONY    WHEQ 3347
     C                     Z-ADD0006      W@LIN#  40
      **TMMNK
     C           BANONY    WHEQ 3220
     C                     Z-ADD0007      W@LIN#  40
      **TMMTX
     C           BANONY    WHEQ 3851
     C                     Z-ADD0008      W@LIN#  40
      **TMMWV
     C           BANONY    WHEQ 3931
     C                     Z-ADD0009      W@LIN#  40
      **TMMMS
     C           BANONY    WHEQ 3428
     C                     Z-ADD0010      W@LIN#  40
      **TMMGT
     C           BANONY    WHEQ 3226
     C                     Z-ADD0011      W@LIN#  40
      **MTMUS
     C           BANONY    WHEQ 3770
     C                     Z-ADD0012      W@LIN#  40
      **TBMNC
     C           BANONY    WHEQ 3941
     C                     Z-ADD0013      W@LIN#  40
      *
     C                     OTHER
     C                     ITER
     C                     ENDSL
      *
     C                     Z-ADD1         IX      20
     C                     MOVELBANODT    LTR8    8
     C           LTR8      LOKUPSDT,IX                   89
     C           *IN89     IFEQ *OFF
     C                     Z-ADD1         IX
     C           *BLANK    LOKUPSDT,IX                   88
     C           *IN88     IFEQ *OFF
     C                     LEAVE
     C                     END
     C                     END
     C                     MOVELBANODT    SDT,IX
     C* BIN DETAIL
     C           K#WPAV    KLIST
     C                     KFLD           W@LIN#
     C                     KFLD           W@NOBN  20
     C                     KFLD           W@WE    1
      *
     C                     MOVELBANOBN    W@NOBN
     C                     MOVE 'E'       W@WE
     C           K#WPAV    CHAINAB#WPBV              93
     C           *IN93     IFEQ *ON
     C                     CLEARAB#WPBV1
     C                     Z-ADDW@LIN#    AWSEQ#
     C                     MOVELBANUKE    AWNUKE
     C                     Z-ADDBANONY    AWNONY
     C                     Z-ADDBANOBN    AWNOBN
     C                     MOVE 'E'       AWWE
     C                     END
     C*
     C**         BASYOS    IFNE 0
     C**         BASRYO    DIV  BASYOS    W@CONT  71
     C           BAUSYS    IFNE 0
     C           BASRYO    DIV  BAUSYS    W@CONT  71
     C                     MVR            REM     60
     C           REM       IFNE 0
     C                     ADD  1         W@CONT
     C                     ENDIF
     C                     ELSE
     C                     Z-ADD1         W@CONT
     C                     END
     C*
     C                     ADD  W@CONT    @@A,IX
     C*
     C  N93                UPDATAB#WPBV1
     C   93                WRITEAB#WPBV1
      * ADD TOTAL LINE
     C                     Z-ADD0         W@NOBN
     C           K#WPAV    CHAINAB#WPBV              97
     C           *IN97     IFEQ *OFF
     C                     ADD  W@CONT    @@A,IX
     C                     UPDATAB#WPBV1
     C                     ELSE
     C                     Z-ADD0         AWNOBN
     C                     Z-ADDW@CONT    @@A,IX
     C                     WRITEAB#WPBV1
     C                     ENDIF
     C*
     C                     ENDDO
     C*
      *
     C                     ENDSR
      *=====================================================
      * SET WEB DATA IN WORK FILE AB#WPBV
      *=====================================================
     C           #SET12    BEGSR
      *
     C                     MOVELD@FRM     LTR8    8
     C           LTR8      SETLLAL#PL01
      *
     C                     DO   *HIVAL
      *
     C                     READ AL#PL01                  96
     C   96                LEAVE
      * DELETED
     C           CASKJY    IFEQ 'D'
     C                     ITER
     C                     END
      * END
     C           CASHID    IFGT SDT,3
     C                     LEAVE
     C                     END
      * CHECK SHIP DATE
     C                     Z-ADD1         IX
     C           CASHID    LOKUPSDT,IX                   89
     C           *IN89     IFEQ *OFF
     C                     ITER
     C                     ENDIF
      *
     C                     SELEC
      **NUMMI
     C           CANONY    WHEQ 0541
     C                     Z-ADD0001      W@LIN#
      **TMMAL
     C           CANONY    WHEQ 3764
     C                     Z-ADD0002      W@LIN#
      **TMMBC
     C           CANONY    WHEQ 3481
     C                     Z-ADD0003      W@LIN#
      **TMMC
     C           CANONY    WHEQ 3503
     C                     Z-ADD0004      W@LIN#
      **TMMI
     C           CANONY    WHEQ 3804
     C                     Z-ADD0005      W@LIN#
      **TMMK
     C           CANONY    WHEQ 3347
     C                     Z-ADD0006      W@LIN#
      **TMMNK
     C           CANONY    WHEQ 3220
     C                     Z-ADD0007      W@LIN#
      **TMMTX
     C           CANONY    WHEQ 3851
     C                     Z-ADD0008      W@LIN#
      **TMMWV
     C           CANONY    WHEQ 3931
     C                     Z-ADD0009      W@LIN#
      **TMMMS
     C           CANONY    WHEQ 3428
     C                     Z-ADD0010      W@LIN#
      **TMMGT
     C           CANONY    WHEQ 3226
     C                     Z-ADD0011      W@LIN#
      **MTMUS
     C           CANONY    WHEQ 3770
