      *
     C                     OTHER
     C                     ITER
     C                     ENDSL
      * GET IAF BIN#
     C                     MOVELCASHID    $SDATE
     C                     MOVELCASURT    $ROUTE
     C                     CALL 'UTLR401'
     C                     PARM           $SDATE  8
     C                     PARM           $ROUTE 10
     C                     PARM           $BIN    2
     C                     PARM           $RTN    1
     C                     MOVEL$BIN      #BIN    20
     C           #BIN      IFEQ 0
     C                     Z-ADD99        #BIN
     C                     ENDIF
     C* BIN DETAIL
     C                     MOVEL#BIN      W@NOBN
     C                     MOVE 'W'       W@WE
     C           K#WPAV    CHAINAB#WPBV              93
     C           *IN93     IFEQ *ON
     C                     CLEARAB#WPBV1
     C                     Z-ADDW@LIN#    AWSEQ#
     C                     MOVELCADOCK    AWNUKE
     C                     Z-ADDCANONY    AWNONY
     C                     Z-ADD#BIN      AWNOBN
     C                     MOVE 'W'       AWWE
     C                     END
     C*
     C                     ADD  1         @@A,IX
     C*
     C  N93                UPDATAB#WPBV1
     C   93                WRITEAB#WPBV1
      * ADD TOTAL LINE
     C                     Z-ADD0         W@NOBN
     C           K#WPAV    CHAINAB#WPBV              97
     C           *IN97     IFEQ *OFF
     C                     ADD  1         @@A,IX
     C                     UPDATAB#WPBV1
     C                     ELSE
     C                     Z-ADD0         AWNOBN
     C                     Z-ADD1         @@A,IX
     C                     WRITEAB#WPBV1
     C                     ENDIF
     C*
     C                     ENDDO
     C*
     C                     ENDSR
      *=====================================================
      *
      *=====================================================
     C           #DSP02    BEGSR
      * SET INDICATOR
     C           D#DTW1    SUB  D#DTE1    D#DTD1
     C           D#DTW2    SUB  D#DTE2    D#DTD2
     C           D#DTW3    SUB  D#DTE3    D#DTD3
      *
     C           D#DTW1    IFEQ D#DTE1
     C                     MOVE *OFF      *IN44
     C                     ELSE
     C                     MOVE *ON       *IN44
     C                     ENDIF
     C           D#DTW2    IFEQ D#DTE2
     C                     MOVE *OFF      *IN45
     C                     ELSE
     C                     MOVE *ON       *IN45
     C                     ENDIF
     C           D#DTW3    IFEQ D#DTE3
     C                     MOVE *OFF      *IN46
     C                     ELSE
     C                     MOVE *ON       *IN46
     C                     ENDIF
     C                     MOVE *IN44     #44
     C                     MOVE *IN45     #45
     C                     MOVE *IN46     #46
      *
     C                     MOVE CMD,4     D@CMD
      * DISPLAY CTL01
     C                     MOVE *ON       *IN56
     C                     WRITEDSP99
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN56                       C
     C                     SETOF                     414243
     C                     SETOF                     444546
     C                     MOVE *BLANK    D@MSG
      *
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     #RCNO1
     C                     END
      *
     C                     SELEC
      * F1  END
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
      * F12 PREVIOUS
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      @@ID
     C* ENTER
     C                     OTHER
     C                     Z-ADD*ZERO     RRN1
     C                     DO   *HIVAL
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL01                95
     C   95                LEAVE
      * DETAIL SCREEN
     C           S1SEL     IFNE *BLANK
     C                     MOVEL*BLANK    S1SEL
     C                     UPDATSFL01
     C                     EXSR #DSP03
      * F1/F12 LEAVE
     C           *INKA     IFEQ *ON
     C           *INKL     OREQ *ON
     C                     LEAVE
     C                     END
     C                     END
     C                     ENDDO
     C                     ENDSL
