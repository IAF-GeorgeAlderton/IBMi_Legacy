     C****************************************************************
     C*  MAIN
     C****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C*
     C*<INIT>
     C                     Z-ADD*DATE     W1DATE
     C                     MOVE '8990'    WVEND   4
     C                     MOVE 'K'       WSEIH   1
     C*
     C                     DO   *HIVAL
     C                     Z-ADD0         WTANK   82
     C                     MOVEL*BLANK    WHANY   4
     C                     MOVEL*BLANK    #ER
     C                     READ INFILE                   10
     C   10                GOTO @END
     C*
     C                     EXSR #WRT01
     C           @ERDT     IFEQ *BLANK
     C                     EXSR #UPD01
     C                     END
     C*<>
     C           WER       IFNE *BLANK
     C                     EXSR #ERR
     C                     END
     C*
     C                     ENDDO
     C*
     C* <END>
     C           @END      TAG
     C           *IN50     IFEQ '1'
     C                     EXCPT#TO
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
     C****************************************************************
     C           #UPD01    BEGSR                                     *
     C****************************************************************
     C*CHECK
     C           KEY1      KLIST
     C                     KFLD           I@ODER
     C                     KFLD           I@ITEM
     C*
     C                     MOVE *BLANK    IIKAT1
     C                     MOVE *BLANK    IIKAT2
     C                     MOVE *BLANK    IIKAT3
     C                     MOVE *BLANK    IIKAT4
     C*
     C                     SETOF                     10
     C           KEY1      CHAINGDIPL161             10
     C           *IN10     IFEQ '0'
     C           IISKJY    IFEQ 'D'
     C           IISKHZ    ANDLE*DATE                                  )
     C                     SETON                     10
     C                     END
     C                     END
     C************************************************
     C*下記エラーの場合　発注データの更新は行わない*
     C************************************************
     C*発注データに存在しない
     C           *IN,10    IFEQ '1'
     C                     MOVE '3'       #ER,3
     C                     GOTO @ERR
     C                     END
     C*納入’＊’かキャンセル’Ｃ’されている
     C           *IN,10    IFEQ '0'
     C           IIIFMK    IFEQ '*'
     C                     MOVE '4'       #ER,4
     C                     GOTO @ERR
     C                     END
     C           IIIFMK    IFEQ 'C'
     C                     MOVE '5'       #ER,5
     C                     GOTO @ERR
     C                     END
     C                     END
     C*
     C                     MOVEL*BLANK    IISKJY
     C                     Z-ADD0         IISKHZ
     C                     Z-ADD*DATE     IIKOHZ
     C                     TIME           IIKOTM
     C                     MOVELPPUSER    IIKOME
     C                     MOVELI@INVO    IIINVO
     C                     ADD  I@SURY    IISURT
     C                     Z-ADD*DATE     IISIHZ
     C                     UPDATGDIPL161
     C           @ERR      TAG
     C*
     C           KEY3      KLIST
     C                     KFLD           WVEND
     C                     KFLD           WSEIH
     C                     KFLD           GDKKEY
      *
     C                     MOVE *BLANK    GDKKEY 20
     C                     MOVELI@KATA    GDKKEY
     C                     SETOF                     10
     C           KEY3      SETLLGDKPL011                 10
     C                     MOVEA'0'       *IN,90
     C                     DO   *HIVAL
     C           ##1       TAG
     C           KEY3      READEGDKPL011                 10
     C           *IN10     IFEQ '0'
     C           ISSKJY    IFEQ 'D'
     C           ISSKHZ    IFLE *DATE
     C                     GOTO ##1
     C                     END
     C                     END
     C           ISSTHZ    IFGT I@JYHZ
     C                     GOTO ##1
     C                     END
     C           ISENHZ    IFLT I@JYHZ
     C                     GOTO ##1
     C                     END
     C                     MOVEA'1'       *IN,90
     C*単価マスターとシッピング情報が異なる。
     C****       I@HANY    IFEQ 'S'
     C           ISTKP1    IFNE I@TANK
     C                     MOVE '2'       #ER,2
     C                     Z-ADDISTKP1    WTANK
     C                     END
     C*****                END
     C*****      I@HANY    IFEQ 'A'
     C*****      ISTKP2    IFNE I@TANK
     C*****                MOVE '2'       #ER,2
     C*****                Z-ADDISTKP2    WTANK
     C*****                END
     C*****                END
     C                     END
     C  N10                ENDDO
     C*単価マスターになし
     C           *IN90     IFEQ '0'
     C                     MOVE '1'       #ER,1
     C                     END
     C*
     C           EUPD01    ENDSR
     C****************************************************************
     C           #WRT01    BEGSR                                     *
     C****************************************************************
     C           KEY2      KLIST
     C                     KFLD           I@ODER
     C                     KFLD           I@ITEM
     C                     KFLD           I@IKBN
     C                     KFLD           I@PARE
     C                     KFLD           I@BXNO
     C*
     C                     MOVEL*BLANK    @ERDT   1
     C                     MOVEL*BLANK    @KOSN   1
     C                     SETOF                     10
     C           KEY2      CHAINGDIPL251             10
     C           *IN10     IFEQ '0'
     C           IKSKJY    IFEQ 'D'
     C           IKSKHZ    ANDLE*DATE                                  )
     C                     SETON                     10
     C                     MOVEL'*'       @KOSN
     C                     END
     C                     END
     C*重複更新チェック
     C           *IN10     IFEQ '0'
     C                     MOVE '6'       #ER,6
     C                     MOVEL'*'       @ERDT
     C                     GOTO EWRT01
     C                     END
     C*
     C                     MOVE ' '       IKSKJY           DELETE CODE
     C                     Z-ADD0         IKSKHZ
     C                     Z-ADD*DATE     IKKOHZ
     C                     TIME           IKKOTM
     C                     MOVELPPUSER    IKKOME
     C*
     C                     MOVELI@INVO    IKINVO
     C                     Z-ADDI@ODER    IKODER
     C                     Z-ADDI@ITEM    IKITEM
     C                     Z-ADDI@IKBN    IKIKBN
 %001C                     MOVE I@PARE    IKPARE
     C                     Z-ADDI@BXNO    IKBXNO
     C                     MOVELI@KAT1    IKKAT1
     C                     MOVELI@KAT2    IKKAT2
     C                     MOVELI@KAT3    IKKAT3
     C                     MOVELI@KAT4    IKKAT4
     C                     Z-ADDI@SYOS    IKSYOS
     C                     Z-ADDI@SBOX    IKSBOX
     C                     Z-ADDI@SURY    IKSURY
     C                     Z-ADDI@TANK    IKTANK
     C                     Z-ADDI@JYYY    IKJYYY
     C                     Z-ADDI@JYMM    IKJYMM
     C                     Z-ADDI@JYDD    IKJYDD
     C                     Z-ADDI@ASJY    IKASJY
     C                     Z-ADDI@ASJM    IKASJM
     C                     Z-ADDI@ASJD    IKASJD
     C                     Z-ADDI@SKOY    IKSKOY
     C                     Z-ADDI@SKOM    IKSKOM
     C                     Z-ADDI@SKOD    IKSKOD
     C                     Z-ADDI@TOYY    IKTOYY
     C                     Z-ADDI@TOYM    IKTOYM
     C                     Z-ADDI@TOYD    IKTOYD
     C                     MOVELI@HANY    IKHANY
     C                     Z-ADD*DATE     IKINHZ
     C                     Z-ADD0         IKNYUY
     C                     Z-ADD0         IKNYUM
     C                     Z-ADD0         IKNYUD
     C                     MOVE *BLANK    IKNYUK
     C*
     C           @KOSN     IFEQ '*'
     C                     UPDATGDIPL251
     C                     ELSE
     C                     WRITEGDIPL251
     C                     END
     C*
     C           EWRT01    ENDSR
     C****************************************************************
     C           #ERR      BEGSR                                     *
     C****************************************************************
     C*<ERR LISR>:
     C           *IN50     IFEQ '0'
     C                     EXCPT#HED
     C                     SETON                     50
     C                     END
     C           *INOF     IFEQ '1'
     C                     EXCPT#TO
     C                     EXCPT#HED
     C                     MOVEL'0'       *INOF
     C                     END
     C*
     C           I@HANY    IFEQ 'S'
     C                     MOVEL'SHIP'    WHANY
     C                     END
     C           I@HANY    IFEQ 'A'
     C                     MOVEL'AIR'     WHANY
     C                     END
     C                     EXCPT#DTL
     C*
     C                     ENDSR
     O*****************************************************************
     OQPRINT  E   02           #HED
