     H            Y.
      ** VVR50  **********************************************
      *  AS400 FILE INQUIRY                                  *
      *  J.WATANABE  2024.06.11                              *
      ********************************************************
     FAB#PW6Z CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL01
     FAB#PLAD IF  E           K        DISK
      ********************************************************
     E                    ERR     1   8 60
      *
     I            DS
     I                                        1   80PNOHZ
     I                                        1   40PNOYY
     I                                        5   60PNOMM
     I                                        7   80PNODD
      *
     I            DS
     I                                        1   80BANOHZ
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
      *
     I            DS
     I                                        1  12 BASHIN
     I                                        1   5 BASHN1
     I                                        6  10 BASHN2
     I                                       11  12 BASHN3
      *
     I            DS
     I                                        1  12 XSHIN
     I                                        1   5 XSHN1
     I                                        6  10 XSHN2
     I                                       11  12 XSHN3
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------------------*
      *     M  A  I  N    R O U T I N E                           *
      *-----------------------------------------------------------*
     C                     EXSR #INIT
      *
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP1
     C           W@ID      CASEQ'02'      #DSP2
     C                     ENDCS
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *************************************************************
      * SCREEN 1
      *************************************************************
     C           #DSP1     BEGSR
      *
     C           SFLG      IFEQ 'Y'
     C                     GOTO SKIP1
     C                     ENDIF
      *
     C                     EXFMTDSP01
     C                     MOVEL*BLANKS   XMSG
     C                     MOVE *OFF      *IN85
     C                     MOVE *OFF      *IN41
     C                     MOVE *OFF      *IN42
     C                     MOVE *OFF      *IN43
     C                     MOVE *OFF      *IN44
      *
     C           *INKA     IFEQ *ON
     C           *INKC     OREQ *ON
     C                     MOVEL'99'      W@ID
     C                     GOTO @END1
     C                     ENDIF
      *
     C           SKIP1     TAG
     C                     EXSR #CHK1
      *
     C           *IN85     IFEQ *OFF
     C           RRN       IFGT 0
     C                     MOVEL'02'      W@ID
     C                     ELSE
     C                     MOVELERR,2     XMSG
     C                     SETON                     313285
     C                     ENDIF
     C                     ENDIF
      *
     C           @END1     ENDSR
      *************************************************************
      * CHECK SCREEN 1
      *************************************************************
     C           #CHK1     BEGSR
      * SHIP (FROM)
     C           XNOHZF    IFEQ 0
     C                     MOVE *ON       *IN41
     C                     MOVE *ON       *IN85
     C                     MOVELERR,1     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      * VALIDATE SHIP (FROM)
     C                     MOVELXNOHZF    $SRC      P
     C                     CALL 'UTLR01'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE   8
     C                     PARM           $RTN1   1
     C           $RTN1     IFNE *BLANK
     C                     MOVE *ON       *IN41
     C                     MOVE *ON       *IN85
     C                     MOVELERR,2     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           XNOHZT    IFEQ 0
     C                     Z-ADDXNOHZF    XNOHZT
     C                     ENDIF
      * VALIDATE SHIP (TO)
     C                     MOVELXNOHZT    $SRC      P
     C                     CALL 'UTLR01'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE   8
     C                     PARM           $RTN1   1
     C           $RTN1     IFNE *BLANK
     C                     MOVE *ON       *IN42
     C                     MOVE *ON       *IN85
     C                     MOVELERR,6     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      * (FROM) < (TO)
     C           XNOHZF    IFGT XNOHZT
     C                     MOVE *ON       *IN41
     C                     MOVE *ON       *IN85
     C                     MOVELERR,7     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      * VALIDATE CUSTOMER
     C           XTOKU     IFNE 0
     C                     MOVELXTOKU     PMNONY
     C                     MOVE ' '       PMOPT
     C                     CALL 'UTLR16'
     C                     PARM           PMNONY  4
     C                     PARM           PMOPT   1
     C                     PARM           PMNAME 20
     C                     PARM           PTOKU   4
     C                     PARM           $RTN2   1
     C           $RTN2     IFNE *BLANK
     C                     MOVE *ON       *IN43
     C                     MOVE *ON       *IN85
     C                     MOVELERR,3     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
     C                     ENDIF
      * VALIDATE DELIVERY
     C           XNONY     IFNE 0
     C                     MOVELXNONY     PMNONY
     C                     MOVE ' '       PMOPT
     C                     CALL 'UTLR16'
     C                     PARM           PMNONY  4
     C                     PARM           PMOPT   1
     C                     PARM           PMNAME 20
     C                     PARM           PTOKU   4
     C                     PARM           $RTN2   1
     C           $RTN2     IFNE *BLANK
     C                     MOVE *ON       *IN44
     C                     MOVE *ON       *IN85
     C                     MOVELERR,4     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
     C                     ENDIF
      * IF NO ERRORS...
     C                     Z-ADDXNOHZF    PNOHZ
     C                     EXSR #SFL1
     C           COUNT     IFEQ 0
     C                     MOVE *ON       *IN41
     C                     MOVE *ON       *IN42
     C                     MOVE *ON       *IN85
     C                     MOVELERR,5     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           XCHK1     ENDSR
      *************************************************************
      * CHECK SCREEN 1
      *************************************************************
     C           #SFL1     BEGSR
     C                     EXSR @CLRSR
     C                     Z-ADD0         RRN
     C                     Z-ADD0         D1UNS
      * READ PP10
     C           K#NOHZ    SETLLAB#PLAD
     C                     DO   *HIVAL
     C                     READ AB#PLAD                  97
     C   97                LEAVE
      *
     C           BANOHZ    IFGT XNOHZT
     C                     LEAVE
     C                     ENDIF
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * SELECT CUSTOMER
     C           XTOKU     IFNE 0
     C           XTOKU     ANDNEBATOKU
     C                     ITER
     C                     ENDIF
      * SELECT DELIVERY
     C           XNONY     IFNE 0
     C           XNONY     ANDNEBANONY
     C                     ITER
     C                     ENDIF
      * SELECT BIN#
     C           XNOBN     IFNE 0
     C           XNOBN     ANDNEBANOBN
     C                     ITER
     C                     ENDIF
      * SELECT IAF PART
     C           XSHIN     IFNE *BLANK
     C           XSHIN     ANDNEBASHIN
     C                     ITER
     C                     ENDIF
      * GET UNSCAN QTY
     C                     MOVELBANONY    $NONY
     C                     MOVELBANKOJ    $NKOJ
     C                     MOVELBANUKE    $NUKE
     C                     MOVELBANOHZ    $NOHZ
     C                     MOVELBANOBN    $NOBN
     C                     MOVELBASHIN    $SHIN
     C                     MOVELBAODRN    $ODRN
     C                     CALL 'UEXR21B'
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $NOHZ   8
     C                     PARM           $NOBN   2
     C                     PARM           $SHIN  12
     C                     PARM           $ODRN  10
     C                     PARM           $UNS    5
     C                     PARM           $RTN    1
     C                     MOVEL$UNS      @UNS    50
      *
     C           @UNS      IFEQ 0
     C                     ITER
     C                     ENDIF
      * OUT SFL01
     C                     Z-ADDBANOHZ    S1NOHZ
     C                     Z-ADDBANOTM    S1NOTM
     C                     Z-ADDBATOKU    S1TOKU
     C                     Z-ADDBANONY    S1NONY
     C                     Z-ADDBANOBN    S1NOBN
     C                     MOVELBANKOJ    S1NKOJ
     C                     MOVELBANUKE    S1NUKE
     C                     MOVELBASHN1    S1SHN1
     C                     MOVELBASHN2    S1SHN2
     C                     MOVELBASHN3    S1SHN3
     C                     Z-ADD@UNS      S1UNS
     C                     ADD  @UNS      D1UNS
     C                     MOVELBAEDIK    S1TYP
     C                     MOVELBAMHN1    S1MHN1
     C                     MOVELBAMHN2    S1MHN2
     C                     MOVELBAMHN3    S1MHN3
     C                     Z-ADDBASRYO    S1SQTY
     C                     MOVELBAODRN    S1ODRN
      * GET BOX
     C                     Z-ADD0         @BOX    40
     C           BASYOS    IFNE 0
     C           BASRYO    DIV  BASYOS    @BOX
     C                     MVR            REM     40
     C           REM       IFGT 0
     C                     ADD  1         @BOX
     C                     ENDIF
     C                     ELSE
     C           BAUSYS    IFNE 0
     C           BASRYO    DIV  BAUSYS    @BOX
     C                     MVR            REM     40
     C           REM       IFGT 0
     C                     ADD  1         @BOX
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           @BOX      IFEQ 0
     C                     Z-ADD1         @BOX
     C                     ENDIF
     C                     Z-ADD@BOX      S1BOX
      * GET NAME
     C                     MOVELBANONY    PMNONY
     C                     MOVE 'D'       PMOPT
     C                     CALL 'UTLR16'
     C                     PARM           PMNONY  4
     C                     PARM           PMOPT   1
     C                     PARM           PMNAME 20
     C                     PARM           PTOKU   4
     C                     PARM           $RTN2   1
     C                     MOVELPMNAME    S1NAME
      *
     C                     ADD  1         RRN
     C           RRN       IFGE 9999
     C                     LEAVE
     C                     ENDIF
      *
     C                     WRITESFL01
     C                     ENDDO
      *
     C                     Z-ADDRRN       COUNT   60
      *
     C                     ENDSR
      ************************************************************
      * SCREEN 2
      ************************************************************
     C           #DSP2     BEGSR
      *
     C                     WRITEFMT90
     C                     MOVEL'1'       *IN70
     C                     EXFMTCTL01
     C                     MOVEL*BLANKS   XMSG
     C                     MOVEL'0'       *IN85
     C                     MOVEL'0'       *IN70
      *
     C                     SELEC
     C           SFLG      WHEQ 'Y'
     C                     MOVEL'99'      W@ID
     C           *INKA     WHEQ *ON
     C           *INKC     OREQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     EXSR @CLRSR
     C                     Z-ADD0         RRN
     C                     MOVEL'01'      W@ID
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************
      * CLEAR SCREEN
      *************************************************************
     C           @CLRSR    BEGSR
     C                     SETON                     71
     C                     WRITECTL01
     C                     SETOF                     71
     C                     Z-ADD0         RRN
      *
     C                     ENDSR
      *************************************************************
      * INITIALIZE
      *************************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           XNOHZF
     C                     PARM           XNOHZT
     C                     PARM           XTOKU
     C                     PARM           XNONY
     C                     PARM           XNOBN
     C                     PARM           PSHN1   5
     C                     PARM           PSHN2   5
     C                     PARM           PSHN3   2
      *
     C           K#NOHZ    KLIST
     C                     KFLD           PNOYY
     C                     KFLD           PNOMM
     C                     KFLD           PNODD
      * SET SKIP FLAG
     C           XNOHZF    IFEQ 0
     C           XNOHZT    ANDEQ0
     C           XTOKU     ANDEQ0
     C           XNONY     ANDEQ0
     C           XNOBN     ANDEQ0
     C           XSHN1     ANDEQ*BLANK
     C           XSHN2     ANDEQ*BLANK
     C           XSHN3     ANDEQ*BLANK
     C                     MOVE 'N'       SFLG    1
     C                     ELSE
     C                     MOVE 'Y'       SFLG
     C                     ENDIF
      *
     C                     MOVEL*BLANKS   XMSG
     C                     MOVEL'01'      W@ID    2
     C                     TIME           SDATE
     C                     Z-ADD0         RRN     50
      *
     C           XNOHZF    IFEQ 0
     C                     Z-ADDTODAY     XNOHZF
     C                     ENDIF
     C           XNOHZT    IFEQ 0
     C                     Z-ADDTODAY     XNOHZT
     C                     ENDIF
      *
     C                     MOVELPSHN1     XSHN1
     C                     MOVELPSHN2     XSHN2
     C                     MOVELPSHN3     XSHN3
      *
     C                     ENDSR
      *************************************************************
** ERR(60A)........2.........3.........4.........5.........6
ENTER SHIP DATE (FROM)!                                      01
SHIP DATE (FROM) IS INVALID!                                 02
CUSTOMER CODE IS INVALID!                                    03
DELIVERY CODE IS INVALID!                                    04
THERE IS NO DATA!                                            05
SHIP DATE (TO) IS INVALID!                                   06
SHIP DATE (FROM) SHOULD BE LESS THAN (TO)!                   07
                                                             08
