     C           *IN02     IFEQ '0'
     C                     SETON                     02
     C                     Z-ADD0         A       30
     C                     END
     C** コメント
     C           K#        IFEQ '*'
     C           C#        CABEQ'*'       END
     C                     ADD  1         A
     C                     MOVE CMT       FIL,A
     C                     MOVE '*'       CMM,A
     C                     GOTO STEP09
     C                     END
     C           R#        CABEQ'R'       STEP09
     C                     ADD  1         A
     C                     MOVE *BLANK    CMM,A
     C                     MOVE DATA      DAT,A
     C                     MOVE KETA      KET,A
     C                     MOVE ZOKU      ZOK,A
     C                     MOVE SYOSU     SYO,A
     C** フィールド名の変換
     C                     MOVEAFILNM     FL
     C                     Z-ADD1         N       20
     C                     Z-ADD1         M       20
     C                     MOVE '0'       SW      1
     C                     MOVE *BLANK    FO
     C           1         DO   35        N
     C           SW        IFEQ '1'
     C           FL,N      ANDEQCC,1
     C                     MOVE '0'       SW      1
     C                     GOTO STEP12
     C                     END
     C           SW        IFEQ '0'
     C           FL,N      ANDEQCC,1
     C                     MOVE '1'       SW      1
     C                     GOTO STEP11
     C                     END
     C           SW        IFEQ '1'
     C                     MOVE FL,N      FO,M
     C                     ADD  1         M
     C                     END
     C           STEP11    TAG
     C                     END
     C           STEP12    TAG
     C                     MOVEAFO        FIL,A
     C                     GOTO END
     C           STEP09    TAG
     C                     EXCPTPUT
     C           END       TAG
     CLR                   Z-ADD1         G       20
     CLR                   Z-ADD1         B       30
     CLR         1         DO   18        B
     CLR                   MOVE CMM,B     CM,B
