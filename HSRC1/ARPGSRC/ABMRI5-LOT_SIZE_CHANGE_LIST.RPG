     FABMPL31 IF  E           K        DISK
     FABMPRI5 O   E             55     PRINTER
      *
     I            DS
     I                                        1   80W@DATE
     I                                        1   40W@DAYY
     I                                        5   60W@DAMM
     I                                        7   80W@DADD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
      *
     I            DS
     I                                        1   8 CTIHZ
     I                                        1   2 CTIMM
     I                                        3   4 CTIDD
     I                                        5   8 CTIYY
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P@DTYM  60
      *
     C                     TIME           WTIME
      *
     C                     Z-ADDUDATE     @HYMD
     C                     SETON                     55
     C                     Z-ADDP@DTYM    K@DTYM  60
     C           K@DTYM    SETLLABMPL311
     C           K@DTYM    READEABMPL311                 87
     C           *IN87     DOWEQ'0'
     C           S5KLOT    IFNE S5KLOA
     C           S5PICS    ANDEQ'0'
     C           S5KCD1    IFEQ 'A'
     C           S5KCD1    OREQ 'B'
     C           *IN55     IFEQ '1'
     C                     WRITEABMPRI51
     C                     SETOF                     55
     C                     ENDIF
     C                     EXSR #SB001
     C                     ENDIF
     C                     ENDIF
     C           K@DTYM    READEABMPL311                 87
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------*
      * FCEPP01                                          *
      *--------------------------------------------------*
     CSR         #SB001    BEGSR
      *
     C                     MOVELS5ATOB    P2ATOB
     C                     MOVELS5ATOK    P2ATOK
     C                     MOVELS5ATK1    P2ATK1
     C                     MOVELS5ATK2    P2ATK2
     C                     MOVELS5ATK3    P2ATK3
     C                     MOVELS5ATK4    P2ATK4
