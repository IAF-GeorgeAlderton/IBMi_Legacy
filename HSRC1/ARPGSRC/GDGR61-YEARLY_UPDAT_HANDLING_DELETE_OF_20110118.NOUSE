      **** GDGR61 ****************************************************
      *       YEARLY UPDAT HANDLING / DELETE OF MONTHLY ORDER FILE
      *     G.B.C                              97/03/06
      ****************************************************************
     H            Y/                                    1
     FGDGPL20 UF  E           K        DISK
     I****************************************************************
     I*発注実績
     I            DS
     I                                        1   40WKYY
     I                                        1   4 WKDATE
     C****************************************************************
     C*           ＭＡＩＮ　ＲＯＵＴＩＮＥ                         *
     C****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C                     PARM           PPDATE  4
     C****************************************************************
     C                     MOVE PPDATE    WKDATE
     C           WKYY      SUB  5         WKYY2   40
     C                     SETON                     OF
     C*--------------------
B1   C                     DO   *HIVAL
     C                     READ GDGPL20                  90
     C   90                LEAVE
     C*
 B2  C           IDJSYY    IFGE WKYY2
     C                     LEAVE
 E2  C                     ENDIF
     C*
     C                     DELETGDGPL201
E1   C                     ENDDO
     C*--------------------
     C* <終　了>
     C           @END      TAG
     C                     SETON                     LR
     C                     RETRN
     C*****************************************************************
