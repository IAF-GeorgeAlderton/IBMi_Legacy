     H            Y.
     F** AB#R2C9 ************************************************************
     F*  REWRITE AB#WP2O(MASTER LABEL) FOR TTAI(3556)                       *
     F*  JW   2020.11.01                                                    *
     F*  JW   2021.10.06                                                    *
     F*  JW   2022.11.14 ADD TTMA(3550)                                     *
     F*  JW   2024.07.29 ADD AB#XP01A                                       *
     F****************************************** AB#R2C *********************
     FAB#WP2O UF  E                    DISK                      A    UC
JW   FAB#XP01AO   E                    DISK
     E*****************************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ***********************************************************************
      *                    MAIN ROUTINE                                     *
      ***********************************************************************
     C                     EXSR #INIT
      *
     C           SVDELY    IFEQ '3556'
     C           RCNT      ANDNE0
     C           MST#      ANDNE0
     C           SVDELY    OREQ '3550'
     C           RCNT      ANDNE0
     C           MST#      ANDNE0
     C                     EXSR #DLT
     C                     EXSR #WRT
     C                     ENDIF
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C***********************************************************
     C* FIRST PROCESS
     C***********************************************************
     C           #INIT     BEGSR
      *
     C                     TIME           SDATE
     C                     MOVE *BLANK    SVFILR  9
     C                     MOVE *BLANK    SVDELY  4
     C                     MOVE *BLANK    SVSHDT  8
     C                     MOVE *BLANK    SVORDR 10
     C                     MOVE *BLANK    SVFACT  1
     C                     MOVE *BLANK    SVDOCK  4
     C                     MOVE *BLANK    SVSIRE  4
     C                     MOVE *BLANK    SVPNAM 30
     C                     MOVE *BLANK    SVCNAM 10
     C                     MOVE *BLANK    SVSERL 18
     C                     MOVE *BLANK    SVSEQ#  4
     C                     MOVE *BLANK    SVSBAN  4
     C                     Z-ADD0         RCNT    40
     C                     Z-ADD0         MST#    30
      *
     C                     OPEN AB#WP2O
     C                     DO   *HIVAL
     C                     READ AB#WP2O             N    98
     C   98                LEAVE
      *
     C           O2DELY    IFEQ '3556'
     C           O2FLDB    ANDNE*BLANK
     C           O2DELY    OREQ '3550'
     C           O2FLDB    ANDNE*BLANK
     C                     ADD  1         RCNT
     C                     MOVELO2FILR    SVFILR           PL#
     C                     MOVELO2DELY    SVDELY
     C                     MOVELO2SHDT    SVSHDT
     C                     MOVELO2ORDR    SVORDR
     C                     MOVELO2FACT    SVFACT
     C                     MOVELO2DOCK    SVDOCK
     C                     MOVELO2SIRE    SVSIRE
     C                     MOVELO2PNAM    SVPNAM
     C                     MOVELO2CNAM    SVCNAM
     C                     MOVELO2SERL    SVSERL
     C                     MOVELO2SEQ#    SVSEQ#
     C                     MOVELO2SBAN    SVSBAN           BIN#
     C                     ENDIF
      *
     C                     ENDDO
     C                     CLOSEAB#WP2O
     C* GET PALLET#
     C           RCNT      IFNE 0
     C           SVFILR    IFEQ *BLANK
     C                     MOVELSVSHDT    $NOHZ
     C                     MOVELSVDELY    $CUST
     C                     MOVELSVDELY    $NONY
     C                     MOVELSVFACT    $NKOJ
     C                     MOVELSVDOCK    $NUKE
     C                     MOVELSVSBAN    $BINN            BIN#
     C                     MOVEL'00000000'$RLHZ
     C                     MOVELSVORDR    $ODRN
     C                     CALL 'UTLR51'
     C                     PARM           $NOHZ   8
     C                     PARM           $CUST   4
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $BINN   2
     C                     PARM           $RLHZ   8
     C                     PARM           $ODRN  10
     C                     PARM           $PICK#  9
     C                     PARM           $RTN    1
     C                     MOVEL$PICK#    SVFILR
     C                     ENDIF
      *
     C                     MOVELSVFILR    $PL#
     C                     CALL 'UEXR07D'
     C                     PARM           $PL#    9
     C                     PARM           $QTY    8
     C                     PARM           $BOX    4
     C                     PARM           $MST#   3
     C                     PARM           $MAX    3
     C                     PARM           $RTN    1
     C                     MOVEL$MST#     MST#
     C                     ENDIF
      *
     C                     ENDSR
     C***********************************************************
     C* DELETE AB#WP2O
     C***********************************************************
     C           #DLT      BEGSR
      *
     C                     OPEN AB#WP2O
     C                     DO   *HIVAL
     C                     READ AB#WP2O                  97
     C   97                LEAVE
      *
     C           O2DELY    IFEQ '3556'
     C           O2FLDB    ANDNE*BLANK
JW2  C           O2DELY    OREQ '3550'
     C           O2FLDB    ANDNE*BLANK
     C                     DELETAB#WP2O1
     C                     ENDIF
      *
     C                     ENDDO
     C                     CLOSEAB#WP2O
      *
     C                     ENDSR
     C***********************************************************
     C* WRITE AB#WP2O
     C***********************************************************
     C           #WRT      BEGSR
      *
     C                     OPEN AB#WP2O
     C           1         DO   MST#      IX      20
     C                     CLEARAB#WP2O1
     C                     MOVELSVDELY    O2DELY
     C                     MOVELSVSHDT    O2SHDT
     C                     MOVELSVFILR    O2FILR
     C                     MOVELSVORDR    O2ORDR
     C                     MOVELSVFACT    O2FACT
     C                     MOVELSVCNAM    O2CNAM
     C                     MOVELSVDOCK    O2DOCK
     C                     MOVELSVSIRE    O2SIRE
     C                     MOVELSVPNAM    O2PNAM
     C                     MOVELIX        O2SEQ#    P
     C                     MOVELSVSERL    LTR10  10
     C                     MOVE IX        LTR10
     C                     MOVELLTR10     O2SERL    P
     C                     MOVELSVSBAN    O2SBAN
     C                     WRITEAB#WP2O1
      *
 |   C                     CLEARAB#XP1A1
 |   C                     MOVEL'AB#WP2O 'IXWRKF    P
 |   C                     EXSR #XP01                      =>AB#XP01
      *
     C           IX        IFEQ 99
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     CLOSEAB#WP2O
      *
     C                     ENDSR
      *================================================================
      *  ..LABEL DATA ISSUE LOG                            *
      *================================================================
     C           #XP01     BEGSR
      **                   CLEARAB#XP1A1
     C                     Z-ADDTODAY     IXKOHZ           TODAY
     C                     Z-ADDNOW       IXKOTM           NOW
      **                   MOVEL          IXTOKU           CUSTOMER
     C                     MOVELO2DELY    IXNONY           DELIVERY
     C                     MOVELO2FACT    IXNKOJ           FACTORY
     C                     MOVELO2DOCK    IXNUKE           DOCK
     C                     MOVELO2ORDR    IXODRN           ORDER #
     C                     MOVELO2SERL    IXSERL           SERIAL NUMBER
     C                     MOVELO2SHDT    IXDEDT           INVOICE DATE
      **                   MOVE           IXNOBN           INVOICE BIN
      *
      **                   MOVEL          IXPL#
     C                     MOVEL#USER     IXKOUS
     C                     MOVEL#WSID     IXKOWS
     C                     MOVEL#PGM      IXKOPG
      *
      **                   MOVEL MHIN     IXMHIN
      **                   MOVEL ASHIN    IXSHIN
     C                     MOVELO2PNAM    IXINVN
      **                   MOVEL AHPOS    IXHPOS
      **                   MOVEL AROUT    IXROUT
      **                   Z-ADD ASRYO    IXSRYO
      **                   Z-ADD ASYOS    IXSYOS
      **                   Z-ADD AUSYS    IXUSYS
      **                   MOVEL KDSP     IXFIL1
      *
     C                     WRITEAB#XP1A1
      *
     C                     ENDSR
