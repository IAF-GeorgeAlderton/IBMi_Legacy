     H            Y.
     F** UTLR78D **********************************************
     F*  PROGRAM: UTILITY- GET DAILY SHIP VOLUME (BY ABHPP01) *
     F*  V03 : ADD $MSET2, $DSV2, $DSVQ2
     F*  ABHPP01: INTRA-PROCESS KANBAN M/F (KOTEINAI)         *
     F*  WRITTEN: JW (SRA) 2021.05.27                         *
     F*-------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR78D'
     F*                    PARM           $SHIN  12
     F*                    PARM           $ZETI   4
     F*                    PARM           $FPRC   3
JW   F*                    PARM           $FDPT   40
     F*                    PARM           $FMCN   3
     F*                    PARM           $FSIZE  3
     F*                    PARM           $LLOC   6
     F*                    PARM           $QPC    60
     F*                    PARM           $MSET   90
     F*                    PARM           $DSVB   61
     F*                    PARM           $DSVQ   80
V03  F*                    PARM           $MSET2  90
 .   F*                    PARM           $DSVB2  61
V03  F*                    PARM           $DSVQ2  80
     F*                    PARM           $RTN    1
     F*  IN  $SHIN : 12A  IAF PART
     F*  OUT $ZETI :  4A  PART ID
     F*      $FPRC :  3A  FIRST PROCESS
JW   F*      $FDPT :  4,0 FIRST DEPT
     F*      $FMCN :  3A  FIRSTLMACHINE
     F*      $FSIZE:  3A  FIRST MACHINE SIZE
     F*      $LLOC :  6A  LAST LOCATION
     F*      $QPC  :  6,0 Q/C
     F*      $MSET :  9,0 MONTHLY SET QTY
     F*      $DSVB :  6,1 DAILY SHIP VOLUME (BOX)
     F*      $DSVQ :  8,0 DAILY SHIP VOLUME (QTY)
V03  F*      $MSET2:  9,0 (FIRST SET) MONTHLY SET QTY
V03  F*      $DSVB2:  6,1 (FIRST SET) DAILY SHIP VOLUME (BOX)
V03  F*      $DSVQ2:  8,0 (FIRST SET) DAILY SHIP VOLUME (QTY)
     F*      $RTN  :  1A  RETURN CODE (BLANK/*)
     F******************************************************
     FAAMPL11 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FABBPP7G IF  E           K        DISK
V03  FGHCPL29 IF  E           K        DISK
      *===================================================
      * SYSTEM DATE
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      * KEY FIELDS
     I            DS
     I                                        1  12 K#SHN
     I                                        1   5 K#SHN1
     I                                        6  10 K#SHN2
     I                                       11  12 K#SHN3
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      * READ AAMPL11
     C           K#PL01    CHAINAAMPL11              99
     C           *IN99     IFEQ *ON
     C                     MOVE '*'       $RTN
     C                     GOTO ENDP
     C                     ENDIF
      * READ FCEPP01
     C           K#PL01    CHAINFCEPL01              99
     C           *IN99     IFEQ *ON
     C                     MOVE '*'       $RTN
     C                     GOTO ENDP
     C                     ENDIF
      *
     C                     MOVELCKKO01    $FPRC
JW   C                     Z-ADDCKBM01    $FDPT
     C                     MOVELCKKB01    $FMCN
     C                     Z-ADDA2GEKN    $MSET
     C                     MOVELA2ZETI    $ZETI
      * GET FINAL LOCATION
     C                     MOVEL$SHIN     P@SHIN
     C                     CALL 'UTLR21'
     C                     PARM           P@SHIN 12
     C                     PARM           $LLOC   6
     C                     PARM           $LQC    50
     C                     PARM           $LPRC   3
     C                     PARM           $LDPT   40
     C                     PARM           $ZETI   4
     C                     PARM           $RTNX   1
     C                     MOVEL$LLOC     $LLOC
     C                     Z-ADD$LQC      $QPC
      * CHECK QPC
     C           $LLOC     IFEQ *BLANK
     C           $QPC      OREQ 0
     C                     MOVE '*'       $RTN
     C                     GOTO ENDP
     C                     ENDIF
      * GET SIZE
     C           $FMCN     SETLLABBPP7G
     C                     DO   *HIVAL
     C           $FMCN     READEABBPP7G                  98
     C   98                LEAVE
      *
     C           A#SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELA#SIZE    $FSIZE
     C                     LEAVE
     C                     ENDDO
ADD   * CHECK LOCATION
     C***TEMP    $FMCN     IFEQ *BLANK
     C***        $FLOC     IFEQ '1N6610'
     C***                  MOVEL'NUT'     $FSIZE
     C***                  ELSE
     C***                  MOVE *BLANK    $FSIZE
     C***                  ENDIF
     C***                  ENDIF
      *
     C**         $FSIZE    IFEQ *BLANK
     C**                   MOVE '*'       $RTN
     C**                   GOTO ENDP
     C**                   ENDIF
      * GET DAILY SHIPPING VOLUME
     C           $MSET     DIV  20        $DSVQ     H
     C           $DSVQ     DIV  $QPC      $DSVB     H
V03   * READ GHCPL29
     C                     Z-ADD01        K#SEQ
     C           K#PL29    CHAINGHCPL29              99
     C           *IN99     IFEQ *ON
     C                     MOVE '*'       $RTN
     C                     GOTO ENDP
     C                     ENDIF
      *
     C                     Z-ADDM7SRYO    $MSET2
V03   * GET DAILY SHIPPING VOLUME
 .   C           $MSET2    DIV  20        $DSVQ2    H
V03  C           $DSVQ2    DIV  $QPC      $DSVB2    H
      *
     C           ENDP      TAG
     C                     SETON                     LR
     C                     RETRN
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SHIN  12
     C                     PARM           $ZETI   4
     C                     PARM           $FPRC   3
JW   C                     PARM           $FDPT   40
     C                     PARM           $FMCN   3
     C                     PARM           $FSIZE  3
     C                     PARM           $LLOC   6
     C                     PARM           $QPC    60
     C                     PARM           $MSET   90
     C                     PARM           $DSVB   61
     C                     PARM           $DSVQ   80
V03  C                     PARM           $MSET2  90
V03  C                     PARM           $DSVB2  61
V03  C                     PARM           $DSVQ2  80
     C                     PARM           $RTN    1
      *
      *
     C           K#PL01    KLIST
     C                     KFLD           K#SHN1  5
     C                     KFLD           K#SHN2  5
     C                     KFLD           K#SHN3  2
      *
     C           K#PL29    KLIST
     C                     KFLD           K#SHN1
     C                     KFLD           K#SHN2
     C                     KFLD           K#SHN3
     C                     KFLD           K#SEQ   20
      * SYSTEM DATE
     C                     TIME           SDATE
     C                     MOVEL$SHIN     K#SHN
     C                     MOVE *BLANK    $LLOC
     C                     MOVE *BLANK    $FSIZE
     C                     Z-ADD0         $QPC
     C                     Z-ADD0         $DSVB
     C                     Z-ADD0         $DSVQ
V03  C                     Z-ADD0         $DSVB2
V03  C                     Z-ADD0         $DSVQ2
     C                     MOVE *BLANK    $RTN
      *
JW1  C                     MOVE *BLANK    $ZETI
.    C                     MOVE *BLANK    $FPRC
.    C                     Z-ADD0         $FDPT
.    C                     MOVE *BLANK    $FMCN
.    C                     Z-ADD0         $MSET
.    C                     Z-ADD0         $MSET2
      *
     C                     ENDSR
