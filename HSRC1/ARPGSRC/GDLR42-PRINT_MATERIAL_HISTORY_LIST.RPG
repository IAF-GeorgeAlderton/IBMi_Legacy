      *********************** GDLR42 **
     FGDLWP4B IP  F     128            DISK
     FGDLPL32 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     IGDLWP4B AA  01
     I                                        1   40ISIRE L3
     I                                        5  19 IZAIS L2
     I                                       20  242IZAIK L2
     I                                       25  300IODER L1
     I                                       25  260IODR1
     I                                       27  280IODR2
     I                                       29  300IODR3
     I                                       31  350IITEM L1
     I                                       36  380IMAIS
     I                                       39  460IODHZ
     I*                                      47  490ISYMA
     I*                                      50  520IMIMA
      *
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
      *
     I            DS
     I                                        1   80LESKHZ
     I                                        1   40LESKYY
     I                                        5   60LESKMM
     I                                        7   80LESKDD
      *
     I            DS
     I                                        1   80LESPHZ
     I                                        1   40LESHPY
     I                                        5   60LESHPM
     I                                        7   80LESHPD
      *
     I            DS
     I                                        1   80LEINHZ
     I                                        1   40LEINSY
     I                                        5   60LEINSM
     I                                        7   80LEINSD
      *------*
      * PARM *
      *------*
     C           *ENTRY    PLIST
     C                     PARM           US     10
      *
     C                     MOVE *BLANK    WUSER   9
     C                     MOVE *BLANK    WUSME  15
     C                     CALL 'APLR00'
     C                     PARM           US
     C                     PARM           WUSME
     C                     MOVELWUSME     WUSER
      *------*
      * KEY1 *
      *------*
     C           KEY1      KLIST
     C                     KFLD           ISIRE
     C                     KFLD           IZAIS
     C                     KFLD           IZAIK
     C                     KFLD           IODR1
     C                     KFLD           IODR2
     C                     KFLD           IODR3
     C                     KFLD           IITEM
      *-----*
      * INZ *
      *-----*
     C           *IN05     IFEQ '0'
     C                     SETON                     05
     C                     TIME           WTIME   60
     C                     Z-ADD0         ISYJR   50
     C                     Z-ADD0         IREJR   50
     C                     Z-ADD0         IREMA   30
     C                     Z-ADD0         ISYMA   30
     C                     Z-ADD0         GMAIS   40
     C                     Z-ADD0         GSYMA   40
     C                     Z-ADD0         GREMA   40
     C                     Z-ADD0         GMIMA   40
     C                     END
      *
     C           *INL3     IFEQ '1'
     C                     MOVE *BLANK    WSIRE  16
     C                     SETOF                     10
     C           ISIRE     CHAINFGBPL011             10
      *
     C           *IN10     IFEQ '0'
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELB2SMEI    WSIRE
     C                     END
     C                     END
     C                     EXCPTHD
     C                     END
      *
     C           *INL2     IFEQ '1'
     C                     EXCPTSP
     C                     END
      *
     C                     SETOF                     30
     C           KEY1      SETLLGDLPL321
     C                     DO   *HIVAL
     C                     SETOF                     20
     C           KEY1      READEGDLPL32                  20
      *
     C           *IN20     IFEQ '0'
     C           LESKJY    IFEQ 'D'
     C           LESKHZ    ANDLE*DATE
     C                     ELSE
     C                     ADD  1         ISYMA
     C                     ADD  LEJURY    ISYJR
     C           LEINHZ    IFNE 0
     C                     ADD  1         IREMA
     C                     ADD  LEJURY    IREJR
     C                     END
     C                     END
     C                     END
     C  N20                ENDDO
      *
     C                     SETOF                     5051
     C           ISYMA     IFEQ 0
     C                     SETON                     50
     C                     END
     C           IREMA     IFEQ 0
     C                     SETON                     51
     C                     END
      *
     C                     ADD  IMAIS     GMAIS
     C                     ADD  ISYMA     GSYMA
     C                     ADD  IREMA     GREMA
     C                     Z-ADD0         IMIMA   30
     C           IMAIS     SUB  ISYMA     IMIMA
     C                     ADD  IMIMA     GMIMA
      *
     C                     MOVE *BLANK    IMINO   1
     C           IMIMA     IFNE 0
     C                     MOVE '*'       IMINO
     C                     END
      *
     C           *INOF     IFEQ '1'
     C                     SETOF                     OF
     C                     EXCPTHD
     C                     END
     C                     EXCPTDT
     C                     Z-ADD0         ISYMA
     C                     Z-ADD0         ISYJR
     C                     Z-ADD0         IREJR
     C                     Z-ADD0         IREMA
     CL2                   EXCPTTL
     CL2                   Z-ADD0         GMAIS
     CL2                   Z-ADD0         GSYMA
     CL2                   Z-ADD0         GREMA
     CL2                   Z-ADD0         GMIMA
      *
     OQPRINT  E  103           HD
