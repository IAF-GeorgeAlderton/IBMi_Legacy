     C           #CNT1     BEGSR
     C* SET ORDER INFORMATION
     C                     Z-ADD*ZERO     QMAIS   50
     C                     Z-ADD*ZERO     QSCAN   50
     C                     Z-ADD*ZERO     QTSURY  50
     C*SET KEY
     C                     Z-ADDAHYY      K81     40
     C           AHMM      SUB  3         K82     20
     C           K82       IFLE *ZERO
     C                     ADD  12        K82
     C                     SUB  1         K81
     C                     END
     C                     Z-ADDK@YM      W@YM    60
     C*SET MAX ORDER DATE
     C                     Z-ADDAHYY      W#ODRY
     C                     Z-ADDAHMM      W#ODRM
     C                     Z-ADD*HIVAL    W#ODRD
     C*
      * RETRIEVE THE SMALLEST ORDER NUMBER OF THE BACK ORDER
     C                     Z-ADD*ZERO     @@ORDR  60
     C           KEY       SETLLGDGPL27
B0   C           *IN91     DOUEQ*ON
     C           KEY       READEGDGPL27                  91
B1   C           *IN91     IFEQ *OFF
     C           IESKJY    ANDEQ*BLANK
B2   C           @@ORDR    IFEQ *ZERO
     C           @@ORDR    ORNE *ZERO
     C           IEODER    ANDLT@@ORDR
     C                     Z-ADDIEODER    @@ORDR
E2   C                     ENDIF
E1   C                     ENDIF
E0   C                     ENDDO
      *
     C           @@ORDR    IFNE *ZERO
     C           KEY9      CHAINGDGPL18              91
     C           *IN91     IFEQ *OFF
     C           ICYM      ANDLTK@YM
     C                     Z-ADDICODRY    K81
     C                     Z-ADDICODRM    K82
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     W@ODER  60
      *
     C           KEY8      SETLLGDGPL191
      *
     C                     DO   *HIVAL
      *
     C           KEY       READEGDGPL191                 91
     C   91                LEAVE
     C           ICSKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C           ICIFMK    IFEQ 'C'
     C                     ITER
     C                     END
     C*
     C           WODATE    IFGT W#ODAT
     C                     LEAVE
     C                     END
     C*
     C                     Z-ADD0         @@SURY  70
     C                     Z-ADD0         @@SBOX  50
     C                     Z-ADD0         @@RBOX  50
     C                     MOVE *BLANK    @RCV    1
     C                     MOVE *BLANK    @AIR    1
     C                     MOVEL*OFF      W@NRED  1
     C           KEY6      SETLLGDGPL251
     C*
     C                     DO   *HIVAL
     C*
     C           KEY6      READEGDGPL251                 94
     C   94                LEAVE
     C*
     C           @@ORDR    IFNE *ZERO
     C           IENYUK    ANDNE*BLANK
     C           ICYM      ANDLTW@YM
     C                     MOVEL*ON       W@NRED
     C                     LEAVE
     C                     ENDIF
      *
     C           @@ORDR    IFNE *ZERO
     C           IEHANY    ANDEQ'A'
     C           ICYM      ANDLTW@YM
     C                     MOVEL*ON       W@NRED
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  IESURY    @@SURY
      *
     C           IENYUM    IFNE *ZERO
     C                     ADD  IESBOX    @@SBOX
     C                     ELSE
     C                     ADD  IESBOX    @@RBOX
     C                     ENDIF
      *
 K1  C           IEHANY    IFEQ 'A'
     C                     MOVE 'A'       @AIR
 KK  C                     ELSE
     C                     MOVE *BLANK    @AIR
 K1  C                     ENDIF
     C*
     C                     ENDDO
      *
     C           W@NRED    IFEQ *ON
     C                     ITER
     C                     END
      *
     C           ICIFMK    IFEQ *BLANK
     C           @AIR      ANDEQ*BLANK
     C                     MOVE '*'       QFLAG   1        NOT RECEIVED
     C                     ELSE
     C                     MOVEL*BLANK    QFLAG
     C                     END
     C*
     C           ICMAIS    SUB  @@SBOX    @@BOX   50
      *
TCHK1C*          QFLAG     IFEQ '*'                        NOT RECEIVED
TCHK1C*                    ADD  @@BOX     QTSURY           ORDER TOTAL BOX
TCHK1C*                    ELSE
TCHK1C*                    ADD  ICMAIS    QMAIS            BOX
TCHK1C*                    END
      * SCANNED QTY
TCHK1C                     Z-ADD*ZERO     W@SCN1  50
     C           ICODER    IFNE W@ODER
     C                     MOVE ICZETI    K@ZETI
     C                     MOVE ICODER    K@ODER
     C           K#ALD     SETLLALDPL20
     C           *IN97     DOUEQ*ON
     C           K#ALD     READEALDPL20                  97
     C           *IN97     IFEQ *OFF
TCHK1C*                    ADD  1         QSCAN
TCHK1C                     ADD  1         W@SCN1
     C                     ENDIF
     C                     ENDDO
     C           K#80      SETLLGDGPL80
     C           *IN97     DOUEQ*ON
     C           K#80      READEGDGPL80                  97
     C           *IN97     IFEQ *OFF
TCHK1C*                    ADD  1         QSCAN
TCHK1C                     ADD  1         W@SCN1
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
TCHK1C*
TCHK1C           ICMAIS    IFNE W@SCN1
TCHK1C                     ADD  W@SCN1    QSCAN
TCHK1C           QFLAG     IFEQ '*'
TCHK1C                     ADD  @@BOX     QTSURY           ORDER TOTAL BOX
TCHK1C                     ELSE
TCHK1C                     ADD  ICMAIS    QMAIS            BOX
TCHK1C                     END
TCHK1C                     END
