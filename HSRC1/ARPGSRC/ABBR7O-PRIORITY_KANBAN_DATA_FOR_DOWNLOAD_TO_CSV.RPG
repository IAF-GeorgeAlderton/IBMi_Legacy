     H            Y.
     F** ABBR7O **********************************
     F*  DOWNLOAD PRIORITY KANBAN LIST DATA      *
     F*  JW       2022.06.14                     *
     F********************************************
     FABBPL70 IF  E           K        DISK
     FABBWP7B O   E           K        DISK
      *--------------------------------------------------
     E                    DPT        15  4
     E                    MCN        15  3
     E                    LOC        15  6
     E                    TYP        15  1
     E                    PRC        15  3
     E                    PRT        15 12
      *--------------------------------------------------
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   6 A7LOCT
     I                                        2   2 A702
     I                                        2   3 A7L1
     I                                        4   5 A7L2
     I            DS
     I                                        1   5 @LOC
     I                                        1   2 @LOC1
     I I            '-'                       3   3 @HFN
     I                                        4   5 @LOC2
     I                                        1   1 @@LL
     I            DS
     I                                        1  140A7DTTM
     I                                        1   80A7DATE
     I                                        9  140A7TIME
     I            DS
     I                                        1  140K#DTTM
     I                                        1   80K#DATE
     I                                        9  140K#TIME
     I            DS
     I                                        1  140@FDTTM
     I                                        1   80@FDATE
     I                                        9  140@FTIME
     I            DS
     I                                        1  140@TDTTM
     I                                        1   80@TDATE
     I                                        9  140@TTIME
     I            DS
     I                                        1  12 SHIN
     I                                        1   5 A7PRT1
     I                                        6  10 A7PRT2
     I                                       11  12 A7PRT3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------
     C                     EXSR #INIT
      *
     C                     EXSR #SET
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
      * SET DATA
      *-----------------------------------------------
     C           #SET      BEGSR
      *
     C                     Z-ADD@FDTTM    K#DTTM
     C           K#70      SETLLABBPL70
     C                     DO   *HIVAL
     C                     READ ABBPL70                  98
     C   98                LEAVE
      *
     C           A7DTTM    IFGT @TDTTM
     C                     LEAVE
     C                     ENDIF
      *
     C           A7KQTY    IFEQ 0
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADDA7DATE    W       20
      *
     C                     MOVE A7L1      @LOC1
     C                     MOVE A7L2      @LOC2
     C                     MOVEL@LOC      K#LOCT  6
      *
     C                     SELEC
     C           A702      WHEQ 'H'
     C           A702      OREQ 'N'
     C           A702      OREQ 'S'
     C                     MOVE '10'      K#LCID  2
      *
     C           A702      WHEQ 'T'
     C                     MOVE '20'      K#LCID
     C           A702      WHEQ 'L'
     C                     MOVE '21'      K#LCID
     C           A702      WHEQ 'J'
     C                     MOVE '22'      K#LCID
     C           A702      WHEQ 'F'
     C                     MOVE '23'      K#LCID
      *
     C           A702      WHEQ 'E'
     C                     MOVE '30'      K#LCID
     C           A702      WHEQ 'G'
     C                     MOVE '31'      K#LCID
     C                     ENDSL
      * GET PROC ----------
     C                     MOVELSHIN      P@SHN
     C                     CALL 'UEXR05'
     C                     PARM           P@SHN  12
     C                     PARM           XDPT   60
     C                     PARM           XMCN   45
     C                     PARM           XLOC   90
     C                     PARM           XTYP   15
     C                     PARM           XPRC   45
     C                     PARM           XPRT  180
     C                     PARM           XSTS    1
     C                     Z-ADD1         IX      20
     C                     MOVEAXMCN      MCN
     C                     MOVEAXPRC      PRC
     C           A7MCHN    LOKUPMCN,IX                   20
     C           *IN20     IFEQ *ON
     C                     MOVELPRC,IX    A7PRC1
     C                     ELSE
     C                     MOVE *BLANK    A7PRC1
     C                     ENDIF
      * GET SIZE ----------
     C                     MOVELA7PRC1    $PRC
     C                     CALL 'UTLR78B'
     C                     PARM           P@SHN
     C                     PARM           $PRC    3
     C                     PARM           $MCN    3
     C                     PARM           $SIZE   3
     C                     PARM           $RTN    1
     C                     MOVEL$SIZE     A7SIZ
      * GET MONTH SET -----
     C                     CALL 'UTLR78'
     C                     PARM           P@SHN
     C                     PARM           $ZETI   4
     C                     PARM           $FPRC   3
     C                     PARM           $FMCN   3
     C                     PARM           $FSIZE  3
     C                     PARM           $LLOC   6
     C                     PARM           $QPC    60
     C                     PARM           $MSET   90
     C                     PARM           $DSVB   61
     C                     PARM           $DSVQ   80
     C                     PARM           $RTN    1
     C                     Z-ADD$QPC      A7QPC
     C                     Z-ADD$MSET     A7MSTQ
     C           $MSET     DIV  20        A7DSTQ
     C           $QPC      IFEQ 0
     C                     Z-ADD0         A7MSTB
     C                     Z-ADD0         A7DSTB
     C                     ELSE
     C           A7MSTQ    DIV  $QPC      A7MSTB
     C           A7DSTQ    DIV  $QPC      A7DSTB
     C                     ENDIF
      *
     C                     MOVELK#LCID    A7LCID
     C                     MOVELK#LOCT    A7LOCT
     C                     WRITEABBWP7B1
      *
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------
      * INITIAL SET
      *-----------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@FDAT  8
     C                     PARM           P@FTIM  6
     C                     PARM           P@TDAT  8
     C                     PARM           P@TTIM  6
      *
     C           K#70      KLIST
     C                     KFLD           K#DATE
     C                     KFLD           K#TIME
      *
     C**         K#7B      KLIST
     C**                   KFLD           K#LCID  2
     C**                   KFLD           K#LOCT  6
     C**                   KFLD           A7PRT1
     C**                   KFLD           A7PRT2
     C**                   KFLD           A7PRT3
      *
     C                     TIME           SDATE
     C                     MOVELP@FDAT    @FDATE
     C                     MOVELP@FTIM    @FTIME
     C                     MOVELP@TDAT    @TDATE
     C                     MOVELP@TTIM    @TTIME
      *
     C                     ENDSR
