     H            Y.
      ** AB#RFT **********************************************
      *  FORD ADDRESS MASTER MAINTENANCE                     *
      *  K.KASHIWAGI 03.05.2001                              *
      ********************************* AB#RFT ***************
      * F3 - EXIT
      * F5 - ADD
      * F7 - CHANGE
      * F9 - DELETE
      * F12- PREVIOUS SCREEN
      * IN99 ERROR
      * IN97 CONFIRM ADDRESS 1 IS BLANK
      ********************************* AB#RFT ***************
     FAB#PWFT CF  E                    WORKSTN
     FABF9L01 UF  E           K        DISK                      A
     F***EDIPL31 UF  E           K        DISK                      A
     FGADPL15 IF  E           K        DISK
      *
     E                    MSGTBL  1  13 60
     I            DS
     I                                        1   80F9KYMD
     I                                        1   40F9KOYY
     I                                        5   60F9KOMM
     I                                        7   80F9KODD
     I            DS
     I                                        1   80F9SYMD
     I                                        1   40F9SKYY
     I                                        5   60F9SKMM
     I                                        7   80F9SKDD
     I            DS
     I                                        1   80DATE
     I                                        1   20W@CT
     I                                        3   40W@YY
     I                                        5   60W@MM
     I                                        7   80W@DD
     I            DS
     I                                        1   80DATE2
     I                                        1   40W@YY2
     I                                        5   60W@MM2
     I                                        7   80W@DD2
     I            DS
     I                                        1   80KDATE2
     I                                        1   40KW@YY
     I                                        5   60KW@MM
     I                                        7   80KW@DD
     I            DS
     I                                        1  120#TIME
     I                                        1   20W@HH
     I                                        3   40W@MIN
     I                                        5   60W@SS
     C*
     C           KEY1      KLIST
     C                     KFLD           KNONY   40       KEY FOR GADPL13
     C*
     C           KEY2      KLIST
     C                     KFLD           KDELY   4        KEY FOR ABF9L01
     C*
     C           *ENTRY    PLIST
     C                     PARM           US     10
     C*
      *--------------*
      * MAIN ROUTINE *
      *--------------*
     C                     EXSR @INTR
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      @DSP1            1ST SCREEN
     C           W@ID      CASEQ'02'      @DSP2            ADD SCREEN
     C           W@ID      CASEQ'03'      @DSP3            CHG SCREEN
     C           W@ID      CASEQ'04'      @DSP4            DELETE SCREEN
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
      *---------------*
      * INITIALIZATION
      *---------------*
     C           @INTR     BEGSR
     C*                    MOVEL*BLANKS   @MSG1
     C*                    MOVEL*BLANKS   @MSG2
     C*                    MOVEL*BLANKS   @MSG3
     C*                    MOVEL*BLANKS   @MSG4
     C                     MOVEL'01'      W@ID    2
     C                     TIME           #TIME
     C                     MOVE *DATE     DATE
     C                     Z-ADD2000      W@YY4   40
     C                     ADD  W@YY      W@YY4
     C                     SETOF                     9998
     C                     ENDSR
      *--------------*
      * FIRST SCREEN *
      *--------------*
     C           @DSP1     BEGSR
     C                     EXFMTAB#PWFT1
     C                     MOVEL*BLANKS   @MSG1
     C                     SETOF                     993098
     C*
     C                     SELEC
     C           *INKC     WHEQ '1'
     C                     MOVEL'99'      W@ID
     C*
     C           *INKE     WHEQ '1'
     C                     EXSR @CHK1
     C           *IN99     IFEQ '0'
     C                     CLEARAB#PWFT2
     C                     MOVE NONY1     NONY2
     C                     MOVEL'02'      W@ID
     C                     ENDIF
      *
     C           *INKG     WHEQ '1'
     C                     EXSR @CHK2
     C           *IN99     IFEQ '0'
     C                     CLEARAB#PWFT3
     C                     MOVE NONY1     NONY3
     C                     MOVELF9DOCK    DOCK3
     C                     MOVELF9SHIP    SHIP3
     C                     MOVELF9PLID    PLID3
     C                     MOVELF9ADD1    ADD13
     C                     MOVELF9ADD2    ADD23
     C                     MOVELF9FLAG    FLAG3
     C                     MOVEL'03'      W@ID
     C                     ENDIF
      *
     C           *INKI     WHEQ '1'
     C                     EXSR @CHK2
     C           *IN99     IFEQ '0'
     C                     CLEARAB#PWFT4
     C                     MOVE NONY1     NONY4
     C                     MOVELF9DOCK    DOCK4
     C                     MOVELF9SHIP    SHIP4
     C                     MOVELF9PLID    PLID4
     C                     MOVELF9ADD1    ADD14
     C                     MOVELF9ADD2    ADD24
     C                     MOVELF9FLAG    FLAG4
     C                     MOVEL'04'      W@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *--------------------*
     C* CHK1 FOR ADD RECORD
      *--------------------*
     C           @CHK1     BEGSR
     C           NONY1     IFEQ 0
     C                     SETON                     9930
     C                     MOVELMSGTBL,1  @MSG1
     C                     ELSE
     C                     MOVE NONY1     KNONY
     C                     SETOF                     70
     C           KEY1      CHAINGADPL15              70
     C           *IN70     IFEQ '1'
     C                     SETON                     9930
     C                     MOVELMSGTBL,1  @MSG1
     C                     ELSE
     C           B5TOKU    IFNE 5149
     C                     SETON                     9930
     C                     MOVELMSGTBL,1  @MSG1
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C*
     C           *IN99     IFEQ '0'
     C                     MOVE NONY1     KDELY
     C                     SETOF                     70
     C           KEY2      CHAINABF9L01              70
     C           *IN70     IFEQ '0'
     C           F9SKJY    IFEQ 'D'
     C           F9SYMD    ANDLE*DATE
     C                     ELSE
     C                     SETON                     9930
     C                     MOVELMSGTBL,2  @MSG1
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDSR
     C*
      *-------------------------------*
     C* CHK2 FOR CHAGE OR DELETE RECORD
      *-------------------------------*
     C           @CHK2     BEGSR
     C           NONY1     IFEQ 0
     C                     SETON                     9930
     C                     MOVELMSGTBL,1  @MSG1
     C                     ELSE
     C                     MOVE NONY1     KNONY
     C                     SETOF                     70
     C           KEY1      CHAINGADPL15              70
     C           *IN70     IFEQ '1'
    KC                     MOVELMSGTBL,1  @MSG1
     C                     SETON                     9930
     C                     ENDIF
     C                     ENDIF
     C*
     C           *IN99     IFEQ '0'
     C                     MOVE NONY1     KDELY
     C                     SETOF                     70
     C           KEY2      CHAINABF9L01              70
     C           *IN70     IFEQ '1'
     C                     SETON                     9930
     C                     MOVELMSGTBL,3  @MSG1
     C                     ELSE
     C           F9SKJY    IFEQ 'D'
     C           F9SYMD    ANDLE*DATE
     C                     SETON                     9930
     C                     MOVELMSGTBL,3  @MSG1
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDSR
      *---------------*
      * ADD SCREEN *
      *---------------*
     C           @DSP2     BEGSR
     C                     EXFMTAB#PWFT2
     C                     MOVEL*BLANKS   @MSG2
     C                     SETOF                     993132
     C                     SETOF                     333435
     C                     SETOF                     3670
     C*
     C                     SELEC
     C           *INKC     WHEQ '1'
     C                     MOVEL'99'      W@ID
     C*
     C           *INKL     WHEQ '1'
     C                     CLEARAB#PWFT1
     C                     MOVEL'01'      W@ID
     C*
     C           *INKE     WHEQ '1'
     C                     EXSR @ADCHK
     C           *IN99     IFEQ '0'
     C           *IN97     ANDEQ'0'
     C                     Z-ADD0         F9SYMD
     C                     MOVE NONY2     F9DELY
     C                     MOVELDOCK2     F9DOCK
     C                     MOVELSHIP2     F9SHIP
     C                     MOVELPLID2     F9PLID
     C                     MOVELADD12     F9ADD1
     C                     MOVELADD22     F9ADD2
     C                     MOVELFLAG2     F9FLAG
     C                     Z-ADDW@YY      W@YY2
     C                     Z-ADDW@MM      W@MM2
     C                     Z-ADDW@DD      W@DD2
     C                     ADD  20000000  DATE2
     C                     MOVE DATE2     F9KYMD
     C                     Z-ADDW@HH      F9KOHH
     C                     Z-ADDW@MIN     F9KOSS
     C                     MOVELUS        F9KOME
     C           F9SKJY    IFEQ 'D'
     C           F9SYMD    ANDLE*DATE
     C                     MOVEL*BLANKS   F9SKJY
     C                     Z-ADD0         F9SYMD
     C                     UPDATABF9P011
     C                     ELSE
     C                     WRITEABF9P011
     C                     ENDIF
     C                     CLEARAB#PWFT1
     C                     MOVELMSGTBL,10 @MSG1
     C                     SETON                     98
     C                     MOVEL'01'      W@ID
     C                     ENDIF
     C*
     C                     OTHER
     C                     EXSR @ADCHK
     C                     ENDSL
     C*
     C                     ENDSR
     C*-------
     C* CHANGE
     C*-------
     C           @DSP3     BEGSR
     C                     EXFMTAB#PWFT3
     C                     MOVEL*BLANKS   @MSG3
     C                     SETOF                     993132
     C                     SETOF                     333435
     C                     SETOF                     3670
     C*
     C                     SELEC
     C           *INKC     WHEQ '1'
     C                     MOVEL'99'      W@ID
     C*
     C           *INKL     WHEQ '1'
     C                     CLEARAB#PWFT1
     C                     MOVEL'01'      W@ID
     C*
     C           *INKG     WHEQ '1'
     C                     EXSR @CHCHK
     C           *IN99     IFEQ '0'
     C           *IN97     ANDEQ'0'
     C                     MOVE NONY3     F9DELY
     C                     MOVELDOCK3     F9DOCK
     C                     MOVELSHIP3     F9SHIP
     C                     MOVELPLID3     F9PLID
     C                     MOVELADD13     F9ADD1
     C                     MOVELADD23     F9ADD2
     C                     MOVELFLAG3     F9FLAG
     C                     Z-ADDW@YY      W@YY2
     C                     Z-ADDW@MM      W@MM2
     C                     Z-ADDW@DD      W@DD2
     C                     ADD  20000000  DATE2
     C                     MOVE DATE2     F9KYMD
     C                     Z-ADDW@HH      F9KOHH
     C                     Z-ADDW@MIN     F9KOSS
     C                     MOVELUS        F9KOME
     C                     UPDATABF9P011
     C                     CLEARAB#PWFT1
     C                     MOVELMSGTBL,11 @MSG1
     C                     SETON                     98
     C                     MOVEL'01'      W@ID
     C                     ENDIF
     C*
     C                     OTHER
     C                     EXSR @CHCHK
     C                     ENDSL
     C*
     C                     ENDSR
     C*--------
     C* DELETE
     C*--------
     C           @DSP4     BEGSR
     C                     EXFMTAB#PWFT4
     C                     MOVEL*BLANKS   @MSG4
     C*
     C                     SELEC
     C           *INKC     WHEQ '1'
     C                     MOVEL'99'      W@ID
     C*
     C           *INKL     WHEQ '1'
     C                     CLEARAB#PWFT1
     C                     MOVEL'01'      W@ID
     C*
     C           *INKI     WHEQ '1'
     C                     MOVEL'D'       F9SKJY
     C                     Z-ADDW@YY      W@YY2
     C                     Z-ADDW@MM      W@MM2
     C                     Z-ADDW@DD      W@DD2
     C                     ADD  20000000  DATE2
     C                     MOVE DATE2     F9SYMD
     C                     MOVE DATE2     F9KYMD
     C                     Z-ADDW@HH      F9KOHH
     C                     Z-ADDW@MIN     F9KOSS
     C                     MOVELUS        F9KOME
     C                     UPDATABF9P011
     C                     CLEARAB#PWFT1
     C                     MOVELMSGTBL,12 @MSG1
     C                     SETON                     98
     C                     MOVEL'01'      W@ID
     C*
     C                     ENDSL
     C*
     C                     ENDSR
     C*--------------
     C* ADD CHECK
     C*--------------
     C           @ADCHK    BEGSR
     C*
     C           DOCK2     IFEQ *BLANKS
     C                     SETON                     3199
     C                     MOVELMSGTBL,4  @MSG2
     C                     ENDIF
     C*
     C           SHIP2     IFEQ *BLANKS
     C                     SETON                     32
     C           *IN99     IFEQ '0'
     C                     SETON                     99
     C                     MOVELMSGTBL,5  @MSG2
     C                     ENDIF
     C                     ENDIF
     C*
     C           PLID2     IFEQ *BLANKS
     C                     SETON                     33
     C           *IN99     IFEQ '0'
     C                     SETON                     99
     C                     MOVELMSGTBL,6  @MSG2
     C                     ENDIF
     C                     ENDIF
     C*
     C           ADD22     IFEQ *BLANKS
     C                     SETON                     35
     C           *IN99     IFEQ '0'
     C                     SETON                     99
     C                     MOVELMSGTBL,8  @MSG2
     C                     ENDIF
     C                     ENDIF
     C*
     C           FLAG2     IFNE *BLANKS
     C           FLAG2     ANDNE'1'
     C                     SETON                     36
     C           *IN99     IFEQ '0'
     C                     SETON                     99
     C                     MOVELMSGTBL,9  @MSG2
     C                     ENDIF
     C                     ENDIF
     C*
     C           ADD12     IFEQ *BLANKS
     C                     SETON                     34
     C           *IN99     IFEQ '0'
     C           *IN97     IFEQ '0'
     C                     SETON                     97
     C                     MOVELMSGTBL,7  @MSG2
     C                     ELSE
     C                     SETOF                     97
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C*
     C                     ENDSR
     C*--------------
     C* CHG CHECK
     C*--------------
     C           @CHCHK    BEGSR
     C*
     C           DOCK3     IFEQ *BLANKS
     C                     SETON                     3199
     C                     MOVELMSGTBL,4  @MSG3
     C                     ENDIF
     C*
     C           SHIP3     IFEQ *BLANKS
     C                     SETON                     3299
     C           *IN99     IFEQ '0'
     C                     MOVELMSGTBL,5  @MSG3
     C                     ENDIF
     C                     ENDIF
     C*
     C           PLID3     IFEQ *BLANKS
     C                     SETON                     33
     C           *IN99     IFEQ '0'
     C                     SETON                     99
     C                     MOVELMSGTBL,6  @MSG3
     C                     ENDIF
     C                     ENDIF
     C*
     C           ADD23     IFEQ *BLANKS
     C                     SETON                     35
     C           *IN99     IFEQ '0'
     C                     SETON                     99
     C                     MOVELMSGTBL,8  @MSG3
     C                     ENDIF
     C                     ENDIF
     C*
     C           FLAG3     IFNE *BLANKS
     C           FLAG3     ANDNE'1'
     C                     SETON                     36
     C           *IN99     IFEQ '0'
     C                     SETON                     99
     C                     MOVELMSGTBL,9  @MSG3
     C                     ENDIF
     C                     ENDIF
     C*
     C           ADD13     IFEQ *BLANKS
     C                     SETON                     34
     C           *IN99     IFEQ '0'
     C           *IN97     IFEQ '0'
     C                     SETON                     97
     C                     MOVELMSGTBL,13 @MSG3
     C                     ELSE
     C                     SETOF                     97
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C*
     C                     ENDSR
** (MSGTBL)
E-01 INVALID DELIVERY CODE.
E-02 RECORD ALREADY EXISTS.
E-03 RECORD DOES NOT EXIST.
E-04 INVALID FORD PLANT CODE.
E-05 INVALID SHIP TO NAME.
E-06 INVALID PLANT ID.
E-07 CONFIRM ADDRESS 1 IS BLANK.  TO CONTINUE, PRESS F5.
E-08 INVALID ADDRESS 2.
E-09 INVALID CUM INCLUDE FLAG.
E-10 PROCESS FOR ADDING RECORD IS COMPLETED.
E-11 PROCESS FOR CHANGE RECORD IS COMPLETED.
E-12 PROCESS FOR DELETE RECORD IS COMPLETED.
E-13 CONFIRM ADDRESS 1 IS BLANK.  TO CONTINUE, PRESS F7.
