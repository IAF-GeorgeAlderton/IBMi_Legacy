     C                     ENDDO
     C                     Z-ADD2         Y
     C                     Z-ADD2         Z
     C                     DO   *HIVAL
     C           A2,Y      IFNE *BLANK
     C                     MOVELA2,Y      A2X,Z
     C                     SUB  1         Z
     C                     END
     C                     SUB  1         Y
     C           Y         IFLE *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     MOVEAA2X       W@A002  2
      *
     C                     MOVELW@A002    W@SHDD
     C*  YEAR
     C                     Z-ADD*ZERO     Y
     C                     Z-ADD*ZERO     Z
     C                     MOVEL*BLANK    A2
     C                     MOVEL'00'      A2X
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C           AY,X      OREQ '/'
     C                     LEAVE
     C                     END
     C           AY,X      IFGE '0'
     C           AY,X      ANDLE'9'
     C                     ADD  1         Y
     C                     MOVELAY,X      A2,Y
     C                     END
     C                     ENDDO
     C                     Z-ADD2         Y
     C                     Z-ADD2         Z
     C                     DO   *HIVAL
     C           A2,Y      IFNE *BLANK
     C                     MOVELA2,Y      A2X,Z
     C                     SUB  1         Z
     C                     END
     C                     SUB  1         Y
     C           Y         IFLE *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     MOVEAA2X       W@A002  2
      *
     C                     MOVELW@A002    W@SHYY
     C                     Z-ADD20        W@SHCC
     C*
     C* QTY
     C                     Z-ADD*ZERO     Y
     C                     Z-ADD*ZERO     Z
     C                     MOVE *BLANK    A9
     C                     MOVEL*ALL'0'   A9X
      *
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C           AY,X      OREQ ' '
     C                     LEAVE
     C                     END
     C           AY,X      IFGE '0'
     C           AY,X      ANDLE'9'
     C                     ADD  1         Y
     C                     MOVELAY,X      A9,Y
     C                     END
     C                     ENDDO
     C                     Z-ADD9         Y
     C                     Z-ADD9         Z
     C                     DO   9
     C           A9,Y      IFNE *BLANK
     C                     MOVE A9,Y      A9X,Z
     C                     SUB  1         Z
     C                     END
     C                     SUB  1         Y
     C           Y         IFLE *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVE @9C       @9      90
     C                     Z-ADD@9        AWSRYO
     C*
      *
     C                     MOVELW@TOKU    AWTOKU
     C                     MOVELW@NONY    AWNONY
     C                     MOVEL'0'       AWNKOJ
     C                     MOVELW@NUKE    AWNUKE
     C                     MOVEL*BLANK    AWSBAN
