     FOTHCUST IP  F     600            DISK
     FAB#WOTH O   E                    DISK
      *--------------------------------------------------------
     E                    AY        800  1
     E                    A2          2  1
     E                    A2X         2  1
     E                    A4          4  1
     E                    A4X         4  1
     E                    A9          9  1
     E                    A9X         9  1
     E                    A15        15  1
     E                    A10        10  1
      *--------------------------------------------------------
     IOTHCUST AA  01
     I                                        1   4 SEQN
     I                                        1  12 SEQ
     I                                       13 268 DAT1
     I                                      269 524 DAT2
     I                                      525 600 DAT3
     I            DS
     I                                        1   80W@SHDT
     I                                        1   40W@SHCY
     I                                        1   20W@SHCC
     I                                        3   40W@SHYY
     I                                        5   60W@SHMM
     I                                        7   80W@SHDD
     I            DS
     I                                        1  15 AWMHIN
     I                                        1   5 AWMHN1
     I                                        6  10 AWMHN2
     I                                       11  15 AWMHN3
      *
     C                     Z-ADD1         X
     C                     MOVEADAT1      AY,X
     C                     ADD  256       X       50
     C                     MOVEADAT2      AY,X
     C                     ADD  256       X       50
     C                     MOVEADAT3      AY,X
      *
     C                     Z-ADD*ZERO     X       50
      *
      * HEADER
     C           *IN99     IFEQ *OFF
      *
     C                     MOVEL*BLANK    A4
     C                     MOVEA'0000'    A4X
     C                     Z-ADD*ZERO     Y       50
     C                     Z-ADD*ZERO     Z       50
      * TOKU
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C                     LEAVE
     C                     END
     C           AY,X      IFGE '0'
     C           AY,X      ANDLE'9'
     C                     ADD  1         Y
     C                     MOVELAY,X      A4,Y
     C                     END
     C                     ENDDO
     C                     Z-ADD4         Y
     C                     Z-ADD4         Z
     C                     DO   *HIVAL
     C           A4,Y      IFNE *BLANK
     C                     MOVELA4,Y      A4X,Z
     C                     SUB  1         Z
     C                     END
     C                     SUB  1         Y
     C           Y         IFLE *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     MOVEAA4X       W@TOKU  4
      *
     C                     MOVEL*BLANK    A4
     C                     MOVEA'0000'    A4X
     C                     Z-ADD*ZERO     Y       50
     C                     Z-ADD*ZERO     Z       50
      * NONY
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C                     LEAVE
     C                     END
     C           AY,X      IFGE '0'
     C           AY,X      ANDLE'9'
     C                     ADD  1         Y
     C                     MOVELAY,X      A4,Y
     C                     END
     C                     ENDDO
     C                     Z-ADD4         Y
     C                     Z-ADD4         Z
     C                     DO   *HIVAL
     C           A4,Y      IFNE *BLANK
     C                     MOVELA4,Y      A4X,Z
     C                     SUB  1         Z
     C                     END
     C                     SUB  1         Y
     C           Y         IFLE *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     MOVEAA4X       W@NONY  4
      *
     C                     MOVEL*BLANK    A4
     C                     MOVEL*BLANK    A4X
     C                     Z-ADD*ZERO     Y       50
     C                     Z-ADD*ZERO     Z       50
      * NUKE
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C                     LEAVE
     C                     END
     C           AY,X      IFNE *BLANK
     C                     ADD  1         Y
     C                     MOVELAY,X      A4,Y
     C                     END
     C                     ENDDO
     C                     MOVEAA4        W@NUKE  4
      *
     C  N99                MOVE *ON       *IN99
     C                     GOTO @END
      *
     C                     END
      *
     C*
     C* DETAIL
     C                     Z-ADD*ZERO     Y       50
     C                     Z-ADD*ZERO     Z       50
     C*
     C* USER PART#
     C                     MOVEL*BLANK    A15
     C                     MOVEL*BLANK    AWMHIN
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C                     LEAVE
     C                     END
     C           AY,X      IFEQ '-'
     C                     ITER
     C                     END
     C                     ADD  1         Y
     C                     MOVELAY,X      A15,Y
     C                     ENDDO
     C                     MOVEAA15       AWMHIN
     C*
     C* SKIP WEEKLY SETTING#
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C                     LEAVE
     C                     END
     C                     END
     C*
     C* PO#
     C                     MOVEL*BLANK    A10
     C                     MOVEL*BLANK    AWORDN
     C                     Z-ADD*ZERO     Y
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C                     LEAVE
     C                     END
     C                     ADD  1         Y
     C                     MOVELAY,X      A10,Y
     C                     ENDDO
     C                     MOVEAA10       AWORDN
      *
     C* SHIP DATE
     C*  MONTH
     C                     Z-ADD*ZERO     Y
     C                     Z-ADD*ZERO     Z
     C                     MOVEL*BLANK    A2
     C                     MOVEL'00'      A2X
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C           AY,X      OREQ '/'
     C                     LEAVE
     C                     END
     C           AY,X      IFGE '0'
     C           AY,X      ANDLE'9'
     C                     ADD  1         Y
     C                     MOVELAY,X      A2,Y
     C                     END
     C                     ENDDO
     C                     Z-ADD2         Y
     C                     Z-ADD2         Z
     C                     DO   *HIVAL
     C           A2,Y      IFNE *BLANK
     C                     MOVELA2,Y      A2X,Z
     C                     SUB  1         Z
     C                     END
     C                     SUB  1         Y
     C           Y         IFLE *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     MOVEAA2X       W@A002  2
      *
     C                     MOVELW@A002    W@SHMM
     C*  DAY
     C                     Z-ADD*ZERO     Y
     C                     Z-ADD*ZERO     Z
     C                     MOVEL*BLANK    A2
     C                     MOVEL'00'      A2X
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C           AY,X      OREQ '/'
     C                     LEAVE
     C                     END
     C           AY,X      IFGE '0'
