     C*****************************************************
     C*  #CHK1  DSPLAY 1 CHECK                            *
     C*****************************************************
     C           #CHK1     BEGSR
     C*
     C*==<INI>==*
     C                     MOVEL*BLANK    D#EMSG           MSG
     C                     MOVEA'00000'   *IN,31           31-35
     C                     SETOF                     99
     C*
