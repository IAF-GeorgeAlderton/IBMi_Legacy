     F** ECSR75 *******************************************
     F* PRINT DIE LOCATION LABEL                          *
     F*          2017.08.25  ITS.  T.MITSUI               *
     F*****************************************************
     F* DEFILE FILE                                       *
     F*****************************************************
     F*==< DISPLAY FILE >==*
     FECSPW75 CF  E                    WORKSTN
     F                                        #RRN1 KSFILE ECSPW75S
     F                                              KINFDS INFDS
     F*
     F*==< DIE KANBAN M/F >==*
     FGCQPL11 IF  E           K        DISK
     F*
     F*==< DIE LOCATION LABEL ISSUE DATA (WORK) >==*
     FECSWP75 IF  E           K        DISK                      A
     F*
     E*****************************************************
     E* ARRAY                                             *
     E*****************************************************
     E                    @ER     1  10 60                MSG TABLE
     E*
     I*****************************************************
     I* DATA STRUCTUER                                    *
     I*****************************************************
     I           SDS
     I                                     *PROGRAM @@PGID
     I                                      244 253 @@WSID
     I                                      254 263 @@USID
     I                                      264 269 @@JBNO
     IINFDS       DS
     I                                      273 282 $$WSNM
     I                                    B 370 3710$$CUR
     I                                    B 378 3790$$RRN
     I            DS
     I                                        1  140S@TIME
     I                                        1   60S@HMS
     I                                        7  140S@YMD
     I                                        7  100S@YYYY
     I                                       11  120S@MM
     I                                       13  140S@DD
     I*==<SCREEN INF>==*
     I*         (LOCATION)
     I            DS
     I                                        1   7 D#TKR@
     I                                        1   1 D#TKR1
     I                                        2   3 D#TKR2
     I                                        4   5 D#TKR3
     I                                        6   6 D#TKR4
     I                                        7   7 D#TKR5
     I*         (LOCATION)
     I            DS
     I                                        1   7 D#BTK@
     I                                        1   1 D#BTK1
     I                                        2   3 D#BTK2
     I                                        4   5 D#BTK3
     I                                        6   6 D#BTK4
     I                                        7   7 D#BTK5
     I*         ( SFL )
     ID#HTR@      DS
     I                                        1   1 D#HTR1
     I                                        2   3 D#HTR2
     I                                        4   5 D#HTR3
     I                                        6   6 D#HTR4
     I                                        7   7 D#HTR5
     I*         ( SFL )
     ID#HKT@      DS
     I                                        1   2 D#HKT1
     I                                        3   6 D#HKT2
     I                                        7   7 D#HKT3
     I                                        8   8 D#HKT4
     I*==< GCQPL11 >==*
     I*         (DIE # )
     I            DS
     I                                        1   8 T6KAT0
     I                                        1   2 T6KAT1
     I                                        3   6 T6KAT2
     I                                        7   7 T6KAT3
     I                                        8   8 ##KAT4
     I*==< WORK >==*
     I*         (LOCATION    )
     I            DS
     I                                        1  11 W@TKR@
     I                                        1   1 W@TKR1
     I                                        2   2 W@TKH2
     I                                        3   4 W@TKR2
     I                                        5   5 W@TKH3
     I                                        6   7 W@TKR3
     I                                        8   8 W@TKH4
     I                                        9   9 W@TKR4
     I                                       10  10 W@TKH5
     I                                       11  11 W@TKR5
     I*         (DIE #    )
     I            DS
     I                                        1  11 W@KAT@
     I                                        1   2 W@KAT1
     I                                        3   3 W@KAH2
     I                                        4   7 W@KAT2
     I                                        8   8 W@KAH3
     I                                        9   9 W@KAT3
     I                                       10  10 W@KAH4
     I                                       11  11 W@KAT4
     I*         ( BARCODE      )
     I            DS
     I                                        1  16 W@BAR@
     I                                        1   8 W@BKT@
     I                                        9  15 W@BTR@
     I                                       16  16 W@BCDG
     I*         ( BARCODE      )
     I            DS
     I                                        1   8 W0KATA
     I                                        1   2 W0KAT1
     I                                        3   6 W0KAT2
     I                                        7   7 W0KAT3
     I                                        8   8 W0KAT4
     I*
     C*****************************************************
     C* PARAMETER                                         *
     C*****************************************************
     C           *ENTRY    PLIST
     C                     PARM           P@OUTR  50       OUTPUT CNT
     C*
     C*==< CHKR01 : GET CHECK DIGIT      >==*
     C           P@CHK1    PLIST
     C                     PARM           P@BRCD100         BARCODE
     C                     PARM           P@BYTE  3         CUL DIGIT
     C                     PARM           P@CKDG  1         CHECK DIGIT
     C                     PARM           P@RTN1  1         RTN CODE
     C*
     C*****************************************************
     C* KEY LIST                                          *
     C*****************************************************
     C*==< GCQPL11 : DIE KANBAN M/F >==*
     C           K@C11A    KLIST
     C                     KFLD           K@TKR1  1         FACTORY
     C           K@C11B    KLIST
     C                     KFLD           K@TKR1            FACTORY
     C                     KFLD           K@TKR2  2         PASSAGE
     C           K@C11C    KLIST
     C                     KFLD           K@TKR1            FACTORY
     C                     KFLD           K@TKR2            PASSAGE
     C                     KFLD           K@TKR3  2         LINE
     C           K@C11D    KLIST
     C                     KFLD           K@TKR1            FACTORY
     C                     KFLD           K@TKR2            PASSAGE
     C                     KFLD           K@TKR3            LINE
     C                     KFLD           K@TKR4  1         STAIR
     C           K@C11E    KLIST
     C                     KFLD           K@TKR1            FACTORY
     C                     KFLD           K@TKR2            PASSAGE
     C                     KFLD           K@TKR3            LINE
     C                     KFLD           K@TKR4            STAIR
     C                     KFLD           K@TKR5  1         STAIR
     C*
     C*==< ECSWP75 >
     C           K@WP75    KLIST
     C                     KFLD           K@KAT1  2        DIE # 1
     C                     KFLD           K@KAT2  4        DIE # 2
     C                     KFLD           K@KAT3  1        DIE # 3
     C                     KFLD           K@KAT4  1        DIE # 4
     C                     KFLD           K@TKR1           LOC CODE 1
     C                     KFLD           K@TKR2           LOC CODE 2
     C                     KFLD           K@TKR3           LOC CODE 3
     C                     KFLD           K@TKR4           LOC CODE 4
     C                     KFLD           K@TKR5           LOC CODE 5
     C                     KFLD           K@CHGD  80       CHG DATE
     C*
     C*****************************************************
     C* WORK                                              *
     C*****************************************************
     C                     MOVEL'EDT1'    S@PROC  4
     C                     Z-ADD*ZERO     S@RRN1  50
     C                     Z-ADD*ZERO     C@SLCT  50
     C*
     C*****************************************************
     C* MAIN                                              *
     C*****************************************************
     C*==<INITIALAIZE>==*
     C                     EXSR #INIT
     C*
     C*==<MAIN    >==*
D----C           S@PROC    DOWNE'EXIT'
|    C*
|S---C                     SELEC
|+---C           S@PROC    WHEQ 'EDT1'
||   C                     EXSR #EDT1
||   C*
|+---C           S@PROC    WHEQ 'DSP1'
||   C                     EXSR #DSP1
||   C*
|+---C           S@PROC    WHEQ 'CHK1'
||   C                     EXSR #CHK1
||   C*
|+---C           S@PROC    WHEQ 'EDT2'
