     C*
     C                     MOVEL*BLANK    D#TKR@
     C                     MOVEL*BLANK    D#EMSG
     C                     MOVEA'00000'   *IN,31
     C                     SETOF                     99
     C*
     C*==<NEXT>==*
     C                     MOVEL'DSP1'    S@PROC
     C*
     C           #EDT1E    ENDSR
     C*****************************************************
