     C*        (NOT INPUT)
I----C           D#TKR@    IFEQ *BLANK                     <NOT INPUT>
|    C                     MOVEL@ER,1     D#EMSG           MSG
|    C                     MOVEA'11111'   *IN,31           31-35
|    C                     SETON                     99
|    C                     MOVEL'DSP1'    S@PROC
|    C                     GOTO #CHK1E
E----C                     ENDIF
     C*
I----C           D#TKR1    IFEQ *BLANK
|I---C           D#TKR2    IFNE *BLANK
||   C           D#TKR3    ORNE *BLANK
