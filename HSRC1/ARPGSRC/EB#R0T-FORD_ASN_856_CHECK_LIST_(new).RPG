     H            Y/
      ******************************************************
      *  FORD ASN 856 CHECK LIST                           *
      *  J.WATANABE  08/02/2018                            *
      *  CHG DELIVERY CODE TABLE TO M/F                    *
      * -----------------------------------------          *
JW1   *  JW    2024.06.04 ADD E6RMD(METHOD)
      ******************************************************
     FEB#WP66 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *-------------------------------------------------------
     E                    TBL     1   2 30
      *-------------------------------------------------------
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------
     C                     DO   *HIVAL
     C                     READ EB#WP66                  98
     C   98                LEAVE
      * GET GROUP CODE
     C                     MOVELE6NONY    $DLV
     C                     CALL 'UTLR62'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTN    1
      *
     C           $GRP      IFEQ 'FRD'
     C                     MOVEL$NAME2    @NAME  30
     C                     ELSE
     C                     MOVELTBL,1     @NAME
     C                     ENDIF
      *
     C                     MOVELEPICK     ASN#    6
     C                     EXSR #PRINT
      *
     C                     ADD  1         TOTDTL  60
     C                     ENDDO
      * TOTAL
     C           TOTDTL    IFGT 0
     C                     EXCPT@TOT
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *--------------------------------------------------
      * PRINT
      *--------------------------------------------------
     C           #PRINT    BEGSR
      *
     C           LINE#     IFGE 62
     C                     EXCPT@HED
     C                     Z-ADD6         LINE#
     C                     ENDIF
      *
     C                     EXCPT@DTL
     C                     ADD  1         LINE#
      *
     C                     ENDSR
      *--------------------------------------------------
      * INITIAL SET
      *--------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     TIME           WSDT
     C                     MOVE *ALL'-'   @@LIN  81
     C                     Z-ADD90        LINE#   30
      *
     C                     ENDSR
      *---------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                         #USER     18
     O                         TODAY Y   80
     O                         NOW       90 '  :  :  '
     O                                   94 'P.'
     O                         PAGE  Z   98
     O        E   02           @HED
     O                                   40 '** FORD ASN CHECK LI'
     O                                   60 'ST **               '
     O        E   04           @HED
     O                                    7 'SHIP TO'
     O                                   36 'DELV'
     O                                   41 'DOCK'
     O                                   52 'SHIP DATE'
     O                                   58 'TIME'
     O                                   64 'BIN'
     O                                   74 'ASN#'
JW1  O                                   81 'ID'
      *
     O        E   05           @HED
JW1  O                         @@LIN     81
      *
     O        E 1              @DTL
     O                         @NAME     30
     O                         E6NONY    36
     O                         E6NUKE    41
     O                         E6NOHZ    53 '    /  /  '
     O                         E6NOTM    59 '  :  '
     O                         E6NBIN    63
     O                         ASN#      76
JW1  O                         E6RMD     81
      *
     O        E 2              @TOT
     O                                    9 '**TOTAL**'
     O                         TOTDTL1   16
** TBL
*PLANT NOT FOUND. CONTACT IT.*

