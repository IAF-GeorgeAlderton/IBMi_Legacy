     C                     SETOF                     10
     C           KEY2      REDPEIZBPL011                 10
      *
     C           *IN10     IFEQ '0'
     C           ZDSKJY    IFEQ 'D'
     C           ZDSKHZ    ANDLE*DATE
     C                     ELSE
     C           ZDUKHZ    IFLE *DATE
     C           ZDSTHZ    ANDGT*DATE
     C                     MOVELZDKNO3    PZETI
     C                     END
     C                     END
     C                     END
     C  N10                ENDDO
     C                     END
     C           EZETI     ENDSR
