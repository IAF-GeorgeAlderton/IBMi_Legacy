     C***************************************************************
     C           #ZETI     BEGSR
     C***************************************************************
     C           KEY2      KLIST
     C                     KFLD           WZAIS
     C                     KFLD           WZAIK
     C                     KFLD           WUKEI
     C                     KFLD           WSIRE
      *
     C                     MOVE *BLANK    PZETI   4
     C           WPTCD     IFEQ 'W'
     C                     SETOF                     20
     C           KEY2      SETGTIZAPL01
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY2      REDPEIZAPL011                 10
      *
     C           *IN10     IFEQ '0'
     C           ZCSKJY    IFEQ 'D'
     C           ZCSKHZ    ANDLE*DATE
     C                     ELSE
     C           ZCUKHZ    IFLE *DATE
     C           ZCSTHZ    ANDGT*DATE
     C                     MOVELZCKNO3    PZETI
     C                     END
     C                     END
     C                     END
     C  N10                ENDDO
     C                     END
