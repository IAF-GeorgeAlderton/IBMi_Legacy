     C           *ENTRY    PLIST
     C                     PARM           PUSER  10
     C                     PARM           PSIRE   4
     C                     MOVELPSIRE     W#SIRE  40
     C*
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    MSG
     C           @STP01    TAG
     C                     EXFMTGDLPW151
     C* < F1=ON >
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C* < F5=OFF >
     C           *INKE     IFEQ '0'
     C                     GOTO @STP01
     C                     END
      *
     C                     Z-ADD0         ZZ      40
     C****************
     C* READ BTBPL51 *
     C****************
     C                     SETOF                     10
     C           *LOVAL    SETLLBTBPL511
     C                     DO   *HIVAL
     C                     READ BTBPL511                 10
     C           *IN10     IFEQ '0'
     C           B5SKJY    IFEQ 'D'
     C           B5SKHZ    ANDLE*DATE
     C                     ELSE
      *
TCHK1C           B5SIRE    IFNE W#SIRE
TCHK1C                     ITER
TCHK1C                     END
TCHK1 *
     C           B5NUHZ    IFLE *DATE
     C                     SETOF                     11
     C                     Z-ADD1         A       40
     C           WKEY1     LOKUPHR1,A                    11
     C           *IN11     IFEQ '1'
     C                     ADD  B5MAIS    HR2,A
     C                     ELSE
     C                     ADD  1         ZZ      40
     C                     MOVELWKEY1     HR1,ZZ
     C                     Z-ADDB5MAIS    HR2,ZZ
     C                     END
      *
     C                     Z-ADD*DATE     B5KOHZ
     C                     TIME           B5KOTM
     C                     MOVELPUSER     B5KOME
     C                     MOVEL*BLANK    B5KOPG
     C                     MOVEL'GDLR15'  B5KOPG
     C                     Z-ADD*DATE     B5SYHZ
     C                     UPDATBTBPL511
     C                     END
     C                     END
     C                     END
     C  N10                ENDDO
      ****************
      * READ BTBPL41 *
      ****************
     C                     SETOF                     10
     C           *LOVAL    SETLLBTBPP411
     C                     DO   *HIVAL
     C                     READ BTBPP411                 10
     C           *IN10     IFEQ '0'
     C           B4SKJY    IFEQ 'D'
     C           B4SKHZ    ANDLE*DATE
     C                     ELSE
      *
TCHK1C           B4SIRE    IFNE W#SIRE
TCHK1C                     ITER
TCHK1C                     END
TCHK1 *
     C                     SETOF                     11
     C                     Z-ADD1         A       40
     C           WKEY2     LOKUPHR1,A                    11
     C           *IN11     IFEQ '1'
     C                     SUB  B4MAIS    HR2,A
     C                     ELSE
     C                     ADD  1         ZZ      40
     C                     MOVELWKEY2     HR1,ZZ
     C                     Z-SUBB4MAIS    HR2,ZZ
     C                     END
      *
     C                     DELETBTBPP411
     C                     END
     C                     END
     C  N10                ENDDO
      ****************
      * READ BTBPP05 *
      ****************
     C                     Z-ADD*DATE     $WYMD
     C                     Z-ADD*DATE     @WYMD
     C           @WMM      IFEQ 01
     C                     SUB  1         @WYY
     C                     Z-ADD12        @WMM
     C                     ELSE
     C                     SUB  1         @WMM
     C                     END
      *
     C                     SETOF                     20
     C           1         SETLLBTBPP051
     C                     DO   *HIVAL
     C           @RETY     TAG
     C                     READ BTBPP051               9920
     C           *IN99     IFEQ *ON
     C                     EXFMTDSPWN
     C                     GOTO @RETY
     C                     ENDIF
      *
     C           *IN20     IFEQ '0'
     C           BTSKJY    IFEQ 'D'
     C           BTSKHZ    ANDLE*DATE
     C                     ELSE
      *
TCHK1C           BTSIRE    IFNE W#SIRE
TCHK1C                     ITER
TCHK1C                     END
TCHK1 *
     C                     Z-ADD0         WMAIS   30
     C                     MOVEL*BLANK    WKOSN   1
     C           @WYM      IFEQ BTKEYM
     C                     Z-ADD1         U       30
     C           1         DO   31        U
     C           HTZ,U     IFEQ *BLANK
     C           HTP,U     IFNE 0
     C           HTM,U     ORNE 0
     C                     ADD  HTP,U     WMAIS
     C                     SUB  HTM,U     WMAIS
     C                     MOVEL'*'       HTZ,U
     C                     MOVEL'*'       WKOSN
     C                     END
     C                     END
     C                     ENDDO
     C                     END
      *
     C           $WYM      IFEQ BTKEYM
     C                     Z-ADD1         U
     C           1         DO   $WDD      U
     C           HTZ,U     IFEQ *BLANK
     C           HTP,U     IFNE 0
     C           HTM,U     ORNE 0
     C                     ADD  HTP,U     WMAIS
     C                     SUB  HTM,U     WMAIS
     C                     MOVEL'*'       HTZ,U
     C                     MOVEL'*'       WKOSN
     C                     END
     C                     END
     C                     ENDDO
     C                     END
      *
     C           WKOSN     IFEQ '*'
     C                     Z-ADD*DATE     BTKOHZ
     C                     TIME           BTKOTM
     C                     MOVELPUSER     BTKOME
     C                     UPDATBTBPP051
     C                     END
      *
     C           WMAIS     IFNE 0
     C                     SETOF                     11
     C                     Z-ADD1         A       40
     C           WKEY3     LOKUPHR1,A                    11
     C           *IN11     IFEQ '1'
     C                     ADD  WMAIS     HR2,A
     C                     ELSE
     C                     ADD  1         ZZ      40
     C                     MOVELWKEY3     HR1,ZZ
     C                     Z-ADDWMAIS     HR2,ZZ
     C                     END
     C                     END
      *
     C                     END
     C                     END
     C  N20                ENDDO
      ****************
      * READ GDLPL03 *
      ****************
     C           KEY1      KLIST
     C                     KFLD           WSIRE
     C                     KFLD           WUKEI
     C                     KFLD           WPTCD
     C                     KFLD           WZAIS
     C                     KFLD           WZAIK
      *
     C                     Z-ADD1         A
     C           1         DO   9999      A
     C                     MOVEL*BLANK    WKOSN
     C                     MOVELHR1,A     WHR1   29
     C                     Z-ADDHR2,A     WHR2    30
     C           WHR1      IFEQ *BLANK
     C                     SETON                     90
     C                     END
     C           *IN90     IFEQ '0'
     C           WHR2      IFNE 0
     C                     SETOF                     10
     C           KEY1      CHAINGDLPL031             10
     C           *IN10     IFEQ '0'
     C                     MOVEL'*'       WKOSN
     C           LASKJY    IFEQ 'D'
     C           LASKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C                     END
     C*GDGPL03 READ OK
     C           *IN10     IFEQ '0'
     C           WHR2      ADD  LAMAIS    #MAIS   30
      *
     C           #MAIS     IFLE 0
     C                     MOVEL'D'       LASKJY
     C                     Z-ADD*DATE     LASKHZ
     C                     Z-ADD*DATE     LAKOHZ
     C                     TIME           LAKOTM
     C                     MOVELPUSER     LAKOME
     C                     UPDATGDLPL031
     C           #MAIS     IFLT 0
     C                     MOVEL*BLANK    B4SKJY
     C                     Z-ADD0         B4SKHZ
     C                     Z-ADD*DATE     B4KOHZ
     C                     TIME           B4KOTM
     C                     MOVELPUSER     B4KOME
     C                     Z-ADDWSIRE     B4SIRE
     C                     Z-ADDWUKEI     B4UKEI
     C                     MOVELWPTCD     B4PTCD
     C                     MOVELWZAIS     B4ZAIS
     C                     Z-ADDWZAIK     B4ZAIK
     C                     Z-SUB#MAIS     B4MAIS
     C                     WRITEBTBPP411
     C                     END
     C                     END
      *
     C           #MAIS     IFGT 0
     C                     MOVEL*BLANK    LASKJY
     C                     Z-ADD0         LASKHZ
     C                     Z-ADD*DATE     LAKOHZ
     C                     TIME           LAKOTM
     C                     MOVELPUSER     LAKOME
     C                     Z-ADD#MAIS     LAMAIS
     C                     UPDATGDLPL031
     C                     END
      *
     C                     END
      *GDGPL03 READ NG
     C           *IN10     IFEQ '1'
     C                     Z-ADDWHR2      #MAIS   30
      *
     C           #MAIS     IFLT 0
     C                     MOVEL*BLANK    B4SKJY
     C                     Z-ADD0         B4SKHZ
     C                     Z-ADD*DATE     B4KOHZ
     C                     TIME           B4KOTM
     C                     MOVELPUSER     B4KOME
     C                     Z-ADDWSIRE     B4SIRE
     C                     Z-ADDWUKEI     B4UKEI
     C                     MOVELWPTCD     B4PTCD
     C                     MOVELWZAIS     B4ZAIS
     C                     Z-ADDWZAIK     B4ZAIK
     C                     Z-SUB#MAIS     B4MAIS
     C                     WRITEBTBPP411
     C                     END
      *
     C           #MAIS     IFGT 0
     C           WKOSN     IFEQ '*'
     C                     MOVEL*BLANK    LASKJY
     C                     Z-ADD0         LASKHZ
     C                     Z-ADD*DATE     LAKOHZ
     C                     TIME           LAKOTM
     C                     MOVELPUSER     LAKOME
     C                     Z-ADD#MAIS     LAMAIS
     C                     UPDATGDLPL031
     C                     ELSE
     C                     EXSR #ZETI
     C                     MOVEL*BLANK    LASKJY
     C                     Z-ADD0         LASKHZ
     C                     Z-ADD*DATE     LAKOHZ
     C                     TIME           LAKOTM
     C                     MOVELPUSER     LAKOME
     C                     Z-ADDWSIRE     LASIRE
     C                     Z-ADDWUKEI     LAUKEI
     C                     MOVEL*BLANK    LAUKOJ
     C                     MOVEL*BLANK    LAUUKE
     C                     MOVELWZAIS     LAZAIS
     C                     Z-ADDWZAIK     LAZAIK
     C                     MOVELPZETI     LAZETI
     C                     MOVELWPTCD     LAPTCD
     C                     Z-ADD#MAIS     LAMAIS
     C                     Z-ADD0         LAREDY
     C                     Z-ADD0         LAREDM
     C                     Z-ADD0         LAREDD
     C                     WRITEGDLPL031
     C                     END
     C                     END
      *
     C                     END
      *
     C                     END
     C                     END
     C  N90                ENDDO
      *
TCHK2C*                    SETON                     LR
TCHK2C                     SETON                     LRU1
     C                     RETRN
