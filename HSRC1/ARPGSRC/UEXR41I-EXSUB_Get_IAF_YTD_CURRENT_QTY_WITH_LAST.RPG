     H            Y.
     F** UEXR41I ******************************************************
     F*  EXSUB- GET IAF YTD-CURRENT QTY BY PP10 (V.3)                 *
     F*             WITH LAST SHIPPED DATE                            *
     F*  WRITTEN: JW (SRA) 2022.12.15                                 *
     F*---------------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UEXR41I'
     F*                    PARM           $YEAR   4
     F*                    PARM           $NONY   4
     F*                    PARM           $MHIN  20
     F*                    PARM           $YTDQ   9
     F*                    PARM           $LSDAT  8
     F*  IN: $YEAR   4A  TARGET YEAR
     F*      $NONY   4A  DELIVERY CODE
     F*      $MHIN  20A  USER PART
     F*  OUT:$YTDQ   9A  YTD SHIPPED QTY
     F*      $LSDAT  8A  LAST SHIPPED DATE (YYYYMMDD)
     F******************************************************
     FAB#PL10BIF  E           K        DISK
      *
     I            DS
     I                                        1  15 BAMHIN
     I                                        1   5 BAMHN1
     I                                        6  10 BAMHN2
     I                                       11  15 BAMHN3
     I            DS
     I                                        1  15 WMHIN
     I                                        1   5 WMHN1
     I                                        6  10 WMHN2
     I                                       11  15 WMHN3
      *
     I            DS
     I                                        1   80BAURHZ
     I                                        1   40BAURYY
     I                                        5   60BAURMM
     I                                        7   80BAURDD
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      *
     C           K#L10B    SETLLAB#PL10B
     C                     DO   *HIVAL
     C           K#L10B    READEAB#PL10B                 98
     C   98                LEAVE
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C           BAURYY    IFEQ 0
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  BASRYO    @YTDQ
      *
     C           BAURHZ    IFGT @LSHZ
     C                     Z-ADDBAURHZ    @LSHZ
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVEL@YTDQ     $YTDQ
     C                     MOVEL@LSHZ     $LSHZ
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *=====================================================
      * INITIAL SETTING
      *=====================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $YEAR   4
     C                     PARM           $NONY   4
     C                     PARM           $MHIN  20
     C                     PARM           $YTDQ   9        YTS SHP QTY
     C                     PARM           $LSHZ   8        LAST SHP DATE
      *
     C           K#L10B    KLIST
     C                     KFLD           KANOYY  40
     C                     KFLD           KANONY  40
     C                     KFLD           KAMHN1  5
     C                     KFLD           KAMHN2  5
     C                     KFLD           KAMHN3  5
      *
     C                     MOVE *ALL'0'   $YTDQ
     C                     MOVE *ALL'0'   $LSHZ
     C                     Z-ADD0         @YTDQ   90
     C                     MOVEL$NONY     @NONY   40
     C                     MOVEL$YEAR     @YEAR   40
     C                     Z-ADD0         @LSHZ   80
      *SET KEY
     C                     MOVEL$YEAR     KANOYY
     C                     MOVEL$NONY     KANONY
     C                     MOVEL$MHIN     WMHIN
     C                     MOVELWMHN1     KAMHN1
     C                     MOVELWMHN2     KAMHN2
     C                     MOVELWMHN3     KAMHN3
      *
     C                     ENDSR
