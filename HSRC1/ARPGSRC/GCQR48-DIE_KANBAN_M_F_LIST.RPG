     C           *ENTRY    PLIST
     C                     PARM           USER   10
      *
      *-------------------*
      *  HEADER           *
      *-------------------*
     C           OPNSW     IFEQ *BLANK
     C                     OPEN GCQPR48
     C                     TIME           @TIME
     C                     MOVE UDATE     @DATE
      *
     C                     SETOF                       21
     C                     MOVELUSER      @USER
     C           USER      CHAINRGAPL111             21
     C           *IN21     IFEQ '0'
     C                     MOVELJ8NAME    @USER
     C                     END
      *
     C                     WRITEGCQPR481
      *
     C                     MOVE '1'       OPNSW   1
     C                     END
      *-------------------*
      * DETAILS           *
      *-------------------*
     C                     MOVE '-'       @H1
     C                     MOVE '-'       @H2
     C                     MOVE '-'       @H3
     C                     MOVE '-'       @H4
     C                     MOVE '-'       @H5
     C                     MOVE '-'       @H6
     C                     MOVE T6KOCD    @KOCD
     C                     MOVE T6KOTP    @KOTP
     C                     MOVE T6KOBD    @KOBD
     C                     MOVE T6LTIM    @LTIM
     C                     MOVE T6SETI    @SETI
     C                     SETOF                     21
     C           T6SETI    CHAINAABPL01              21
     C           *IN21     IFEQ '0'
     C           A4SKJY    IFEQ 'D'
     C           A4SKHZ    ANDLEHYMD
     C                     SETON                       21
     C                     END
     C                     END
     C           *IN21     IFEQ '0'
     C                     MOVELA4SETN    @SETN
     C                     END
