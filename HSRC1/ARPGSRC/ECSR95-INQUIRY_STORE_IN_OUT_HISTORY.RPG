      ******************************************* AJHR17 **
     FECSPW95 CF  E                    WORKSTN
     FGCQPL14 IF  E           K        DISK
     FECSPL84 IF  E           K        DISK
     FECSPP78 IF  E           K        DISK
     FECSWP95 O   E                    DISK
      *****************************************************************
     E                    ER      1  99 60               ERR MSG
      *****************************************************************
     I            DS
     I                                        1  140WTIME
     I                                        1   40WJF
     I                                        7  140WYMD
     I            DS
     I                                        1  120WXDATE
     I                                        1   80WXYMD
     I                                        9  120WXJF
     I            DS
     I                                        1  120WWDAT1
     I                                        1   80D1YMD1
     I                                        9  120D1TIM1
     I                                       11  120D1FF
     I            DS
     I                                        1  120WWDAT2
     I                                        1   80D1YMD2
     I                                        9  120D1TIM2
     I                                       11  120D2FF
      * KEY
     C           KEY1      KLIST
     C                     KFLD           K@KAT1  2
     C                     KFLD           K@KAT2  4
     C                     KFLD           K@KAT3  1
     C           KEY2      KLIST
     C                     KFLD           K@DATE  80
     C                     KFLD           K@TIME  60
      * PARAMETER
     C           *ENTRY    PLIST
     C                     PARM           O@YMD1  80
     C                     PARM           O@TIM1  40
     C                     PARM           O@YMD2  80
     C                     PARM           O@TIM2  40
     C                     PARM           O@DIE1  2
     C                     PARM           O@DIE2  4
     C                     PARM           O@DIE3  1
     C                     PARM           O@DIE4  1
     C                     PARM           O@RIYU  1
     C                     PARM           O@MSNO  3
     C                     PARM           O@IOKB  1
     C                     PARM           O@GSKB  1
     C                     PARM           O@JUDG  1
     C                     PARM           O@FKEY  2
      *
     C                     TIME           WTIME
     C                     Z-ADD0         D1YMD1
     C                     Z-ADD0         D1TIM1
     C                     Z-ADDWYMD      D1YMD2
     C                     Z-ADDWJF       D1TIM2
     C                     MOVEL'1'       D1GSKB
     C                     MOVEL'1'       D1JUDG
     C           @DSP1     TAG
     C                     EXFMTECSPW951
     C           *INKA     IFEQ '1'
     C                     MOVEL'01'      O@FKEY
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C                     SETOF                     343536
     C                     SETOF                     374043
     C                     SETOF                     99
     C                     SETOF                     414243
      * CHECK
     C                     MOVELD1YMD1    P@DATE
     C                     CALL 'DATR10'
     C                     PARM           P@DATE  8
     C                     PARM           P@RTN   1
     C           P@RTN     IFEQ '1'
     C                     MOVELER,01     ERR
     C                     SETON                     3499
     C                     GOTO @DSP1
     C                     END
      *
     C           D1FF      IFLT 00
     C           D1FF      ORGT 59
     C                     MOVELER,02     ERR
     C                     SETON                     3599
     C                     GOTO @DSP1
     C                     END
      *
     C           D1TIM1    IFLT 0000
     C           D1TIM1    ORGT 2359
     C                     MOVELER,02     ERR
     C                     SETON                     3599
     C                     GOTO @DSP1
     C                     END
      *
     C                     MOVELD1YMD2    P@DATE
     C                     CALL 'DATR10'
     C                     PARM           P@DATE  8
     C                     PARM           P@RTN   1
     C           P@RTN     IFEQ '1'
     C                     MOVELER,01     ERR
     C                     SETON                     3699
     C                     GOTO @DSP1
     C                     END
      *
     C           D2FF      IFLT 00
     C           D2FF      ORGT 59
     C                     MOVELER,02     ERR
     C                     SETON                     3799
     C                     GOTO @DSP1
     C                     END
      *
     C           D1TIM2    IFLT 0000
     C           D1TIM2    ORGT 2359
     C                     MOVELER,02     ERR
     C                     SETON                     3799
     C                     GOTO @DSP1
     C                     END
      *
     C           WWDAT1    IFGT WWDAT2
     C                     MOVELER,03     ERR
     C                     SETON                     343536
     C                     SETON                     3799
     C                     GOTO @DSP1
     C                     END
      *
     C           D1DIE1    IFNE ' '
     C                     MOVELD1DIE1    K@KAT1
     C                     MOVELD1DIE2    K@KAT2
     C                     MOVELD1DIE3    K@KAT3
     C           D1DIE3    IFNE 'U'
     C                     MOVEL*BLANK    K@KAT3
     C                     END
     C                     SETOF                     71
     C           KEY1      CHAINGCQPL14              71
     C           *IN71     IFEQ '0'
     C           T6SKJY    ANDEQ'D'
     C                     SETON                     71
     C                     END
     C           *IN71     IFEQ '1'
     C                     MOVELER,04     ERR
     C                     SETON                     4099
     C                     GOTO @DSP1
     C                     END
     C                     END
      *
     C           D1IOKB    IFNE ' '
     C           D1IOKB    IFNE '1'
     C           D1IOKB    ANDNE'2'
     C                     MOVELER,05     ERR
     C                     SETON                     4499
     C                     GOTO @DSP1
     C                     END
     C                     END
      *
     C           D1GSKB    IFNE ' '
     C           D1GSKB    IFNE '1'
     C           D1GSKB    ANDNE'2'
     C                     MOVELER,05     ERR
     C                     SETON                     4599
     C                     GOTO @DSP1
     C                     END
     C                     END
      *
     C           D1JUDG    IFNE ' '
     C           D1JUDG    IFNE '1'
     C           D1JUDG    ANDNE'2'
     C                     MOVELER,05     ERR
     C                     SETON                     4399
     C                     GOTO @DSP1
     C                     END
     C                     END
      *
     C           *INKE     IFEQ '0'
     C           *INKL     ANDEQ'0'
     C                     GOTO @DSP1
     C                     END
      *
     C           *INKE     IFEQ '1'
     C                     MOVEL'05'      O@FKEY
     C                     END
      *
     C           *INKL     IFEQ '1'
     C                     MOVEL'12'      O@FKEY
     C                     END
      *
     C                     Z-ADDD1YMD1    O@YMD1
     C                     Z-ADDD1TIM1    O@TIM1
     C                     Z-ADDD1YMD2    O@YMD2
     C                     Z-ADDD1TIM2    O@TIM2
     C                     MOVELD1DIE1    O@DIE1
     C                     MOVELD1DIE2    O@DIE2
     C                     MOVELD1DIE3    O@DIE3
     C                     MOVELD1DIE4    O@DIE4
     C                     MOVELD1RIYU    O@RIYU
     C                     MOVELD1MSNO    O@MSNO
     C                     MOVELD1IOKB    O@IOKB
     C                     MOVELD1GSKB    O@GSKB
     C                     MOVELD1JUDG    O@JUDG
      *
      * MAIN
     C                     Z-ADD0         W@CNT   80
     C                     Z-ADDD1YMD1    K@DATE
     C                     MOVELD1TIM1    K@TIME
     C                     MOVE 00        K@TIME
     C                     SETOF                     72
     C           KEY2      SETLLECSPL84
     C                     DO   *HIVAL
     C                     READ ECSPL84                  72
     C   72                LEAVE
     C                     Z-ADDE8IOHZ    WXYMD
     C                     MOVELE8IOJK    WXJF
     C           WXDATE    IFGT WWDAT2
     C                     LEAVE
     C                     END
     C           E8SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C           D1DIE1    IFNE ' '
     C           D1DIE1    ANDNEE8KAT1
     C                     ITER
     C                     END
     C           D1DIE2    IFNE ' '
     C           D1DIE2    ANDNEE8KAT2
     C                     ITER
     C                     END
     C           D1DIE3    IFNE ' '
     C           D1DIE3    ANDNEE8KAT3
     C                     ITER
     C                     END
     C           D1DIE4    IFNE ' '
     C           D1DIE4    ANDNEE8KAT4
     C                     ITER
     C                     END
     C           D1RIYU    IFNE ' '
     C           D1RIYU    IFNE E8RIYU
     C                     ITER
     C                     END
     C                     END
     C           D1MSNO    IFNE ' '
     C           D1MSNO    IFNE E8KIBN
     C                     ITER
     C                     END
     C                     END
     C           D1IOKB    IFNE ' '
     C           D1IOKB    IFEQ '1'
     C           E8IOKB    ANDNE'I'
     C                     ITER
     C                     END
     C           D1IOKB    IFEQ '2'
     C           E8IOKB    ANDNE'O'
     C                     ITER
     C                     END
     C                     END
     C           D1GSKB    IFNE ' '
     C           D1GSKB    IFEQ '1'
     C           E8GSKB    ANDNE'H'
     C                     ITER
     C                     END
     C           D1GSKB    IFEQ '2'
     C           E8GSKB    ANDNE'A'
     C                     ITER
     C                     END
     C                     END
     C           D1JUDG    IFNE ' '
     C           D1JUDG    IFEQ '1'
     C           E8HNTE    IFNE 'OK'
     C                     ITER
     C                     END
     C                     END
     C           D1JUDG    IFEQ '2'
     C           E8HNTE    IFNE 'NG'
     C                     ITER
     C                     END
     C                     END
     C                     END
      *
     C                     MOVEL' '       W0INPK
     C                     MOVEL' '       KBAR   14
     C                     MOVELE8SBAR    KBAR
     C                     SETOF                     82
     C           KBAR      CHAINECSPP78              82
     C           *IN82     IFEQ '0'
     C                     MOVEL'2'       W0INPK
     C                     END
      *
     C                     Z-ADDE8BMON    W0BMON
     C                     MOVELE8KIBN    W0KIBN
     C                     MOVELE8RIYU    W0RIYU
     C                     MOVELE8KAT1    W0KAT1
     C                     MOVELE8KAT2    W0KAT2
     C                     MOVELE8KAT3    W0KAT3
     C                     MOVELE8KAT4    W0KAT4
     C                     MOVELE8TKR1    W0TKR1
     C                     MOVELE8TKR2    W0TKR2
     C                     MOVELE8TKR3    W0TKR3
     C                     MOVELE8TKR4    W0TKR4
     C                     MOVELE8TKR5    W0TKR5
     C                     Z-ADDE8KOSU    W0KOSU
     C                     MOVELE8IOKB    W0IOKB
     C                     MOVELE8GSKB    W0GSKB
     C                     Z-ADDE8IOHZ    W0IOHZ
     C                     Z-ADDE8IOJK    W0IOJK
     C                     MOVELE8IOME    W0IOME
     C                     MOVELE8OREQ    W0OREQ
     C                     MOVELE8HNTE    W0HNTE
     C                     MOVELE8EMSG    W0EMSG
     C                     MOVELE8PBAR    W0PBAR
     C                     MOVELE8SBAR    W0SBAR
     C                     MOVELE8LBAR    W0LBAR
     C                     MOVELE8DBAR    W0DBAR
     C                     WRITEECSWP951
     C                     ADD  1         W@CNT
     C                     ENDDO
      *
     C           W@CNT     IFEQ 0
     C                     MOVELER,06     ERR
     C                     SETON                     343536
     C                     SETON                     374041
     C                     SETON                     424399
     C                     GOTO @DSP1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *
**  ER  (ERROR MESSAGE )
E-01 READ DATE IS WRONG
E-02 READ TIME IS WRONG
E-03 START DATE&TIME > END DATE&TIME
E-04 THIS DIE NO IS NOT EXIST
E-05 INPUT "1" OR "2"
E-06 NO DATA.
