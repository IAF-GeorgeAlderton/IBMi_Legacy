     C                     OPEN ABBWP69
      *
     C           *LOVAL    SETLLABBWP68
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ABBWP68                  98
     C   98                LEAVE
     C*
     C           T6NNNM    DIV  W@1CNT    W@DIF2 123H
     C           W@DIF2    MULT 20        W@DIF3 112H
     C           W@DIF3    SUB  T6SETQ    W@DIF4 112
     C           W@DIF4    DIV  20        W@DIF5 112H
     C           W@DIF5    DIV  T6BOXQ    T6NDF1    H
      *
     C           T61NNM    DIV  W@2CNT    W@DIF2 123H
     C           W@DIF2    MULT 20        W@DIF3 112H
     C           W@DIF3    SUB  T6SETQ    W@DIF4 112
     C           W@DIF4    DIV  20        W@DIF5 112H
     C           W@DIF5    DIV  T6BOXQ    T61DF1    H
      *
     C           T62NNM    DIV  W@3CNT    W@DIF2 123H
     C           W@DIF2    MULT 20        W@DIF3 112H
     C           W@DIF3    SUB  T6SETQ    W@DIF4 112
     C           W@DIF4    DIV  20        W@DIF5 112H
     C           W@DIF5    DIV  T6BOXQ    T62DF1    H
     C*
     C                     MOVEL*BLANK    T6MRK2
     C           T6SHP1    IFGT *ZERO
     C           T6SHP2    ORGT *ZERO
     C           T6SHP3    ORGT *ZERO
     C           T6SHP4    ORGT *ZERO
     C           T6SHP5    ORGT *ZERO
     C           T6SHP6    ORGT *ZERO
     C           T6MRKA    IFNE *BLANK
     C                     MOVEL'*'       T6MRK2
     C                     END
     C           T6MRKA    IFEQ *BLANK
     C           T6MRKB    ANDNE*BLANK
     C           T6MRKC    ANDEQ*BLANK
     C                     MOVEL'*'       T6MRK2
     C                     END
     C                     END
     C*
     C                     Z-ADD*ZERO     TFFQ01
     C                     Z-ADD*ZERO     TFFQ02
     C                     Z-ADD*ZERO     TFFQ03
     C                     Z-ADD*ZERO     TFSQ0A
     C                     Z-ADD*ZERO     TFSQ01
     C                     Z-ADD*ZERO     TFSQ02
     C                     Z-ADD*ZERO     TFSQ03
     C                     Z-ADD*ZERO     TFFF01
     C                     Z-ADD*ZERO     TFDF01
     C                     Z-ADD*ZERO     TFFF02
     C                     Z-ADD*ZERO     TFDF02
     C                     Z-ADD*ZERO     TFFF03
     C                     Z-ADD*ZERO     TFDF03
     C*
     C           T6FQ01    DIV  W@1CNT    W@DIF2 123H
     C           W@DIF2    MULT 20        TFFQ01    H
     C                     ADD  TFFQ01    TFFF01
     C           T6FQ02    DIV  W@2CNT    W@DIF2 123H
     C           W@DIF2    MULT 20        TFFQ02    H
     C                     ADD  TFFQ02    TFFF02
     C           T6FQ03    DIV  W@3CNT    W@DIF2 123H
     C           W@DIF2    MULT 20        TFFQ03    H
     C                     ADD  TFFQ03    TFFF03
     C*
     C           T6SQ01    DIV  W@PMD1    W@DIF2 123H
     C           W@DIF2    MULT 20        TFSQ01    H
     C           T6SQ02    DIV  W@PMD2    W@DIF2 123H
     C           W@DIF2    MULT 20        TFSQ02    H
     C           T6SQ03    DIV  W@PMD3    W@DIF2 123H
     C           W@DIF2    MULT 20        TFSQ03    H
     C*
     C           TFSQ01    IFGT TFSQ0A
     C                     Z-ADDTFSQ01    TFSQ0A
     C                     END
     C           TFSQ02    IFGT TFSQ0A
     C                     Z-ADDTFSQ02    TFSQ0A
     C                     END
     C           TFSQ03    IFGT TFSQ0A
     C                     Z-ADDTFSQ03    TFSQ0A
     C                     END
     C*
     C                     ADD  TFSQ0A    TFFF01
     C                     ADD  TFSQ0A    TFFF02
     C                     ADD  TFSQ0A    TFFF03
     C*
     C           TFFF01    SUB  T6SETQ    W@DIF4 112
     C           W@DIF4    DIV  20        W@DIF5 112H
     C           W@DIF5    DIV  T6BOXQ    TFDF01    H
     C           TFFF02    SUB  T6SETQ    W@DIF4 112
     C           W@DIF4    DIV  20        W@DIF5 112H
     C           W@DIF5    DIV  T6BOXQ    TFDF02    H
     C           TFFF03    SUB  T6SETQ    W@DIF4 112
     C           W@DIF4    DIV  20        W@DIF5 112H
     C           W@DIF5    DIV  T6BOXQ    TFDF03    H
     C*
     C                     MOVEL*BLANK    T6PTYP
     C*
     C           K#FCEA    KLIST
     C                     KFLD           T6SHN1
     C                     KFLD           T6SHN2
     C                     KFLD           T6SHN3
     C* PASS THROUGH
     C           K#FCEA    SETLLAAPTL01
     C           *IN96     DOUEQ*ON
     C           K#FCEA    READEAAPTL01                  96
     C           *IN96     IFEQ *OFF
     C           L5SKJY    ANDEQ*BLANK
     C           L5STYY    ANDEQ9999
     C                     MOVEL'PT '     T6PTYP
     C                     LEAVE
     C                     END
     C                     ENDDO
     C* HALF FINISHED
     C           *IN96     IFEQ *ON
     C           K#FCEA    SETLLFCEPL40
     C           *IN96     DOUEQ*ON
     C           K#FCEA    READEFCEPL40                  96
     C           *IN96     IFEQ *OFF
     C           F4GSKD    ANDEQ*BLANK
     C           K#L40     KLIST
     C                     KFLD           F4HPR1
     C                     KFLD           F4HPR2
     C                     KFLD           F4HPR3
     C           K#L40     SETGTAANPL06
     C                     DO   *HIVAL
     C           K#L40     REDPEAANPL06                  94
     C   94                LEAVE
     C           L7SKJY    IFEQ *BLANK
     C           L7STYY    ANDEQ9999
     C                     MOVEL'BPT'     T6PTYP
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     END
     C*
     C                     MOVEL*BLANK    T6PRDT
     C           T6PTYP    IFNE *BLANK
     C           T6PTYP    IFEQ 'PT '
     C                     MOVELT6SHN1    W@SHN1
     C                     MOVELT6SHN2    W@SHN2
     C                     MOVELT6SHN3    W@SHN3
     C                     ELSE
     C                     MOVELF4HPR1    W@SHN1
     C                     MOVELF4HPR2    W@SHN2
     C                     MOVELF4HPR3    W@SHN3
     C                     END
     C                     MOVELW@SHIN    K@SHIN 20 P
     C           K@SHIN    SETGTGDKPL03
     C                     DO   *HIVAL
     C           K@SHIN    REDPEGDKPL03                  95
     C   95                LEAVE
     C           ISSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C                     MOVELISENHZ    T6PRDT
     C                     LEAVE
     C                     ENDDO
     C                     END
     C*
     C                     Z-ADD*ZERO     T6HIFQ
     C           T6NNNM    DIV  W@1CNT    W#FCST 123H
     C           W#FCST    MULT 20        W@FCST 112H
     C           W@FCST    IFGT T6HIFQ
     C                     Z-ADDW@FCST    T6HIFQ
     C                     Z-ADDT6NDF1    T6HIDF
     C                     END
     C           T61NNM    DIV  W@2CNT    W#FCST    H
     C           W#FCST    MULT 20        W@FCST    H
     C           W@FCST    IFGT T6HIFQ
     C                     Z-ADDW@FCST    T6HIFQ
     C                     Z-ADDT61DF1    T6HIDF
     C                     END
     C           T62NNM    DIV  W@3CNT    W#FCST    H
     C           W#FCST    MULT 20        W@FCST    H
     C           W@FCST    IFGT T6HIFQ
     C                     Z-ADDW@FCST    T6HIFQ
     C                     Z-ADDT62DF1    T6HIDF
     C                     END
     C**JW1      TFFF01    IFGT T6HIFQ
     C**                   Z-ADDTFFF01    T6HIFQ
     C**                   Z-ADDTFDF01    T6HIDF
     C**                   END
     C**         TFFF02    IFGT T6HIFQ
     C**                   Z-ADDTFFF02    T6HIFQ
     C**                   Z-ADDTFDF02    T6HIDF
     C**                   END
     C**         TFFF03    IFGT T6HIFQ
     C**                   Z-ADDTFFF03    T6HIFQ
     C**                   Z-ADDTFDF03    T6HIDF
     C**                   END
JW2  C* BOX/DAY (T6BOXD)
JW2  C           T6SETQ    DIV  20        T6BOXD    H
JW2  C           T6BOXQ    IFNE 0
JW2  C           T6BOXD    DIV  T6BOXQ    T6BOXD    H
JW2  C                     ENDIF
JW2  C           T6BOXD    IFEQ 0
JW2  C                     Z-ADD0.1       T6BOXD
JW2  C                     ENDIF
JW2  C* RATIO   (T6RATI)
JW2  C           T6HIFQ    MULT 100       NUM11  110H
JW2  C           T6SETQ    IFEQ 0
JW2  C                     Z-ADD0         T6RATI
JW2  C                     ELSE
JW2  C           NUM11     DIV  T6SETQ    T6RATI    H
JW2  C                     ENDIF
JW2  C*
     C                     WRITEABBWP69R
     C*
     C                     ENDDO
