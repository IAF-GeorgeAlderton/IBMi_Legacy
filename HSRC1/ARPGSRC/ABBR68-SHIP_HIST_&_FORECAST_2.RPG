     C           *INZSR    BEGSR
     C*
     C           *ENTRY    PLIST
     C                     PARM           PMYYMM  6
     C                     PARM           PMD1    6
     C                     MOVELPMD1      W@YMD
     C* DECIDE MONTH
     C           PMYYMM    IFEQ *BLANK
     C                     TIME           WSDT
     C                     Z-ADDWSSMMM    K@MMMM
     C                     Z-ADDWSSYYY    K@YYYY
     C           WSSDDD    IFGE 20
     C                     ADD  1         K@MMMM
     C                     END
     C           K@MMMM    IFGT 12
     C                     ADD  1         K@YYYY
     C                     SUB  12        K@MMMM
     C                     END
     C                     ELSE
     C                     MOVELPMYYMM    K@YYYY  40
     C                     MOVE PMYYMM    K@MMMM  20
     C                     END
     C* 1ST MONTH
     C           K#AGD     KLIST
     C                     KFLD           K@YYYY
     C                     KFLD           K@MMMM
     C           K#AGD     SETLLAGDPL12
     C                     Z-ADD*ZERO     W@1CNT  31
     C                     DO   *HIVAL
     C           K#AGD     READEAGDPL12                  97
     C   97                LEAVE
     C           F8HIRU    IFNE *BLANK
     C           F8YORU    ANDNE*BLANK
     C                     ITER
     C                     END
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         W@1CNT
     C                     ITER
     C                     END
     C                     ADD  0.5       W@1CNT
     C                     ENDDO
     C* 2ND MONTH
     C                     ADD  1         K@MMMM
     C           K@MMMM    IFGT 12
     C                     ADD  1         K@YYYY
     C                     SUB  12        K@MMMM
     C                     END
     C           K#AGD     SETLLAGDPL12
     C                     Z-ADD*ZERO     W@2CNT  31
     C                     DO   *HIVAL
     C           K#AGD     READEAGDPL12                  97
     C   97                LEAVE
     C           F8HIRU    IFNE *BLANK
     C           F8YORU    ANDNE*BLANK
     C                     ITER
     C                     END
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         W@2CNT
     C                     ITER
     C                     END
     C                     ADD  0.5       W@2CNT
     C                     ENDDO
     C* 3RD MONTH
     C                     ADD  1         K@MMMM
     C           K@MMMM    IFGT 12
     C                     ADD  1         K@YYYY
     C                     SUB  12        K@MMMM
     C                     END
     C           K#AGD     SETLLAGDPL12
     C                     Z-ADD*ZERO     W@3CNT  31
     C                     DO   *HIVAL
     C           K#AGD     READEAGDPL12                  97
     C   97                LEAVE
     C           F8HIRU    IFNE *BLANK
     C           F8YORU    ANDNE*BLANK
     C                     ITER
     C                     END
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
