     C                     ITER
     C                     END
     C                     ADD  0.5       W@3CNT
     C                     ENDDO
     C* SHIP CLOSE YYMM ------------------------------------
     C* 1ST MONTH
     C                     Z-ADDW@YY      K@YYYY
     C                     Z-ADDW@MM      K@MMMM
     C           K#AGD     SETLLAGDPL12
     C                     Z-ADD*ZERO     W@PMD1  31
     C                     DO   *HIVAL
     C           K#AGD     READEAGDPL12                  97
     C   97                LEAVE
     C           F8HIRU    IFNE *BLANK
     C           F8YORU    ANDNE*BLANK
     C                     ITER
     C                     END
