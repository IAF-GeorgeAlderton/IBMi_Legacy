     C                     ITER
     C                     END
     C                     ADD  0.5       W@PMD2
     C                     ENDDO
     C* 3RD MONTH
     C                     SUB  1         K@MMMM
     C           K@MMMM    IFLE *ZERO
     C                     SUB  1         K@YYYY
     C                     ADD  12        K@MMMM
     C                     END
     C           K#AGD     SETLLAGDPL12
