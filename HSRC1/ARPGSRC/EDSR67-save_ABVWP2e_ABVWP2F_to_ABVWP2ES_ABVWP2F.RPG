     H            Y.
     F** EDSR67 *****************************************************
     F*  PROGRAM: SAVE ABVWP2E/ABVWP2F TO ABVWP2ES/ABVWP2FS         *
     F*  WRITTEN: J.WATANABE   2020.11.11                           *
     F***************************************************************
     FABVWP2E IF  E                    DISK
     FABVWP2F IF  E                    DISK
     FABVWP2ESO   E                    DISK
     FABVWP2FSO   E                    DISK
      *--------------------------------------------------------
     I            DS
     I                                        1  140D#TIME
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
      * INITIAL SETTING
     C                     TIME           D#TIME
      *
      * SAVE ABVWP2E --------------------------------------
     C                     DO   *HIVAL
     C                     READ ABVWP2E                  99
     C   99                LEAVE
     C                     Z-ADDTODAY     E2CRHZ
     C                     Z-ADDNOW       E2CRTM
     C                     MOVEL#USER     E2CRUS
     C                     MOVEL#WSID     E2CRWS
     C                     WRITEABVW2ES1
     C                     ENDDO
      *
      * SAVE ABVWP2F --------------------------------------
     C                     DO   *HIVAL
     C                     READ ABVWP2F                  98
     C   98                LEAVE
     C                     Z-ADDTODAY     F2CRHZ
     C                     Z-ADDNOW       F2CRTM
     C                     MOVEL#USER     F2CRUS
     C                     MOVEL#WSID     F2CRWS
     C                     WRITEABVW2FS1
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
