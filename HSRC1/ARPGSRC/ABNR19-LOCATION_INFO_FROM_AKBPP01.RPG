      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     READ CADPL03                  21
     C           *IN21     DOWEQ'0'
     C           C2SKJY    IFEQ 'D'
     C           C2SKHZ    ANDLESDATE
     C                     ELSE
     C           C2STHZ    IFEQ 99999999
     C                     EXSR #SB200
     C                     ENDIF
     C                     ENDIF
     C                     READ CADPL03                  21
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------*
      *AAJPP11 検索       *
      *---------------------------*
     CSR         #SB200    BEGSR
      *
     C                     CLEARABNPP111
     C                     MOVELC2KCD1    S7KCD1
     C                     MOVELC2KCD2    S7KCD2
     C                     Z-ADDC2BMON    S7BMON
     C                     MOVELC2TKR1    S7TKR1
     C                     MOVELC2TKR2    S7TKR2
     C                     MOVELC2TKR3    S7TKR3
     C                     MOVELC2TKR4    S7TKR4
     C                     MOVELC2SHN1    S7SHN1
     C                     MOVELC2SHN2    S7SHN2
     C                     MOVELC2SHN3    S7SHN3
     C                     Z-ADDC2KMAX    S7KMAX
     C           KEYA31    KLIST
     C                     KFLD           C2TKR1
     C                     KFLD           C2TKR2
     C                     KFLD           C2TKR3
     C                     KFLD           C2TKR4
     C                     Z-ADD32        @@SHAK  30
     C           KEYA31    SETGTAAJPL11
     C           KEYA31    REDPEAAJPL11                  82
     C           *IN82     IFEQ '0'
     C                     Z-ADDCJSDAI    S7SDAI
     C                     MOVELCJSSYO    S7SSYO
     C                     MOVELCJHAKO    S7HAKO
     C                     Z-ADDCJBRYO    S7BRYO
     C                     Z-ADDCJSHAK    S7SHAK
     C           CJSDSS    LOKUPTAB5      TAB6           20
     C   20                Z-ADDTAB6      @@SHAK
     C                     ENDIF
     C                     EXSR #SB670
     C                     WRITEABNPP111
      *
     CSR         ESB200    ENDSR
      *---------------------------*
      *間口数　指示かんばん
      *---------------------------*
     CSR         #SB670    BEGSR
      *
     C                     Z-ADD0         WKMAX   70
     C                     Z-ADD0         MAGS    30
     C           C2KMAX    MULT C2PROL    WKMAX
     C           WKMAX     DIV  @@SHAK    S7NSIZ
     C                     MVR            AMR     73
     C           AMR       IFNE 0
     C                     ADD  1         S7NSIZ
     C                     ENDIF
      *
     CSR         ESB670    ENDSR
