     H            Y.                                    1
     H** AFDR99 *******************************************************
     H* DATE CHECK
     H*     PARM1(IN)= 8.0 (YMD)
     H*     PARM2(IN)= 3.0 (DAYS)
     H*     PARM3(IN)= 1 (0=ALL DAYS 1=OMIT HOLIDAYS)
     H*     PARM4(OUT)=8.0 (YMD)
     H*
     H**************************************************************************
     FAGDPL12 IF  E           K        DISK
      *---------------------------------------------------
     I            DS
     I                                        1   80W@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80F8YMD
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
      *---------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           IN      80
     C                     PARM           DAYS    30
     C                     PARM           ID      1
     C                     PARM           OUT     80
      *
     C           K#KEY     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
      *
     C           DAYS      IFLT *ZERO
     C                     MOVE *ON       *IN50
     C                     Z-SUBDAYS      @@D     30
     C                     ELSE
     C                     MOVE *OFF      *IN50
     C                     Z-ADDDAYS      @@D     30
     C                     ENDIF
      *
     C                     Z-ADDIN        W@YMD
     C                     Z-ADD*ZERO     @@CNT   30
     C           DAYS      IFEQ *ZERO
     C                     Z-ADDIN        OUT
     C                     MOVE *ON       *INLR
     C                     RETRN
     C                     ENDIF
      *
     C           K#KEY     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C   50                READPAGDPL12                  90
     C  N50                READ AGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           ID        IFEQ '0'
     C                     ADD  1         @@CNT
     C                     ELSE
     C           F8HIRU    IFEQ *BLANK
     C                     ADD  1         @@CNT
     C                     ENDIF
     C                     ENDIF
      *
     C           @@CNT     IFEQ @@D
     C                     Z-ADDF8YMD     OUT
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
