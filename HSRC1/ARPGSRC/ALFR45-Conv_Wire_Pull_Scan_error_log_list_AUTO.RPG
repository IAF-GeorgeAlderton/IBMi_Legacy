     H            Y.
      ** ALFR45 ********************************************
      *  CONVEYANCE WIRE PULL SCAN ERROR LOG LIST          *
      *                                                    *
      * LEC   18/03/12 CREATE(COPY FROM ALFR02)            *
      ******************************************************
     FALFPL45 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FALBPL30 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *
     E                    TBL     1   1 50
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
     I            DS
     I                                        1   80W@SCDT
     I                                        1   40W@SCYY
     I                                        5   60W@SCMM
     I                                        7   80W@SCDD
     I            DS
     I                                        1   80W@ECDT
     I                                        1   40W@ECYY
     I                                        5   60W@ECMM
     I                                        7   80W@ECDD
      *
     C           K#01      KLIST
     C                     KFLD           W@SCDT
     C                     KFLD           W@STTM
     C           K#01      SETLLALFPL45
      *
     C                     DO   *HIVAL
      *
     C                     READ ALFPL45                  99
     C   99                LEAVE
      *
     C           WECODT    IFEQ W@ECDT
     C           WECOTM    ANDGTW@EDTM
     C                     LEAVE
     C                     ENDIF
      *
     C           W@1STP    IFEQ *ON
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     MOVEL*OFF      W@1STP
     C                     ENDIF
      *
     C                     MOVELWEWKCD    K@TMCD  60
     C           K@TMCD    CHAINALBPL30              97
     C  N97                MOVELALWKNM    P@WKNM 20
     C   97                MOVEL*BLANK    P@WKNM
      *
     C                     MOVELWERBAR    WKRBAR 33
     C                     MOVELWEIBAR    WKIBAR 33
      *
     C                     EXCPT@DTL
     C                     MOVEL*ON       PMRFLG
      *
     C                     ENDDO
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
      * INITIAL SET
      *-----------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           PMSHFT  1
     C                     PARM           PMSCDT  8
     C                     PARM           PMRFLG  1
     C                     MOVEL*OFF      PMRFLG
      *
     C                     TIME           WSDT
      *
     C           PMSCDT    IFNE *BLANK
     C                     MOVELPMSCDT    W@SCDT
     C                     MOVELPMSCDT    W@ECDT
     C                     ELSE
     C                     MOVELWSSDAT    W@SCDT
     C                     MOVELWSSDAT    W@ECDT
     C                     END
      *
     C                     SELEC
     C           PMSHFT    WHEQ '1'
     C                     Z-ADD070000    W@STTM  60
     C                     Z-ADD145959    W@EDTM  60
     C           PMSHFT    WHEQ '2'
     C                     Z-ADD150000    W@STTM
     C                     Z-ADD225959    W@EDTM
     C           PMSHFT    WHEQ '3'
     C           K#AGDP    KLIST
     C                     KFLD           W@SCYY
     C                     KFLD           W@SCMM
     C                     KFLD           W@SCDD
     C           K#AGDP    CHAINAGDPL12              98
     C           *IN98     IFEQ *OFF
     C                     READPAGDPL12                  98
     C           *IN98     IFEQ *OFF
     C                     Z-ADDF8KAYY    W@SCYY
     C                     Z-ADDF8KAMM    W@SCMM
     C                     Z-ADDF8KADD    W@SCDD
     C                     END
     C                     END
     C                     Z-ADD230000    W@STTM
     C                     Z-ADD065959    W@EDTM
     C                     OTHER
     C                     Z-ADD000000    W@STTM
     C                     Z-ADD000000    W@EDTM
     C                     ENDSL
      *
     C                     MOVEL*ON       W@1STP  1
      *
     C                     ENDSR
      *
     OQPRINT  E   01           @HED
     O                         #PGM      10
     O                         TBL,1     72
     O                                   87 'DATE'
     O                         WSSDATY   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O        E   02           @HED
     O                                   87 'TIME'
     O                         WSSTM6    98 '  :  :  '
     O        E   03           @HED
     O                                   15 'SCANNED DATE AT'
     O                         W@SCDTY   26
     O                                   36 'SHIFT#:'
     O                         PMSHFT    38
     O        E   05           @HED
     O                                    4 'TIME'
     O                                   20 'TEAM MEMBER'
     O                                   34 'F/I'
     O                                   42 'SCREEN'
     O                                   58 'ERROR MESSAGE'
     O                                   75 'PART ID'
     O                                   98 'MATERIAL NAME'
     O                                  110 'DIAMETER'
     O                                  123 'INTO LOCN'
     O        E 1              @DTL
     O                         WECOTM     8 ' 0:  :  '
     O                         P@WKNM    29
     O                         WEFORI    33
     O                         WEERSC    40
     O                         WEEMSG    65
     O                         WEZETI    73
     O                         WEMATN   100
     O                         WEDIAM1  109
     O                         WELOC2   118
     O                         WELOC3   121
     O        E 1              @DTL
     O                                   22 'Wire -'
     O                         WEWBAR    43
     O                                   54 'Rtvl -'
     O                         WKRBAR    88
     O                                   97 'Locn -'
     O                         WKIBAR   131
