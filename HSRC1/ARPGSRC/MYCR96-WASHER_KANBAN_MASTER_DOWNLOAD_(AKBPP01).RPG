     C                     EXSR #INIT
      *
     C           *LOVAL    SETLLAKBPL01A
     C                     DO   *HIVAL
     C                     READ AKBPL01A                 98
     C   98                LEAVE
      * IGNORE
     C           L1SKJY    IFEQ 'D'
     C           L1STYY    ORNE 9999
     C                     ITER
     C                     ENDIF
      * OUT HEADER
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     EXSR #HEAD
     C                     ENDIF
      * OUT DETAIL
     C                     EXSR #DTL
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
