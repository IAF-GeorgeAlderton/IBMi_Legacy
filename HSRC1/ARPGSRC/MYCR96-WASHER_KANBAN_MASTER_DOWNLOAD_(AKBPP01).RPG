      *------------------------------------------------------
      *  EDIT TIME
      *------------------------------------------------------
     C           #TIME     BEGSR
     C                     MOVEL$TIME     W1TIME
     C                     MOVELW1HH      W2HH
     C                     MOVELW1FF      W2FF
     C                     MOVELW2TIME    @TIME   5
     C                     ENDSR
      *------------------------------------------------------
      *  EDIT PART
      *------------------------------------------------------
     C           #PART     BEGSR
     C                     MOVEL$PART     W1PART
     C                     MOVELW1PRT1    W2PRT1
     C                     MOVELW1PRT2    W2PRT2
     C                     MOVELW1PRT3    W2PRT3
     C                     MOVELW1PRT4    W2PRT4
     C           W1PRT2    IFEQ *BLANK
     C                     MOVE *BLANK    W2PHP1
     C                     ELSE
     C                     MOVE '-'       W2PHP1
     C                     ENDIF
     C           W1PRT3    IFEQ *BLANK
     C                     MOVE *BLANK    W2PHP2
     C                     ELSE
     C                     MOVE '-'       W2PHP2
     C                     ENDIF
     C           W1PRT4    IFEQ *BLANK
     C                     MOVE *BLANK    W2PHP3
     C                     ELSE
     C                     MOVE '-'       W2PHP3
     C                     ENDIF
     C                     MOVELW2PART    @PART  20
     C                     ENDSR
