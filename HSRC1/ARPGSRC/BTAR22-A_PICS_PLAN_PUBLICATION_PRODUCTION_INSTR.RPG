      *
     C           KEY       KLIST
     C                     KFLD           BTSHN1
     C                     KFLD           BTSHN2
     C                     KFLD           BTSHN3
      *
     C           *ENTRY    PLIST
     C                     PARM           PUS    10
      *
     C                     Z-ADD*DATE     WUYMD
      *
     C           BTSKJY    IFEQ 'D'
     C           BTSKHZ    ANDLE*DATE
     C                     ELSE
      *
     C           WUYM      IFEQ BTKEYM
     C                     SETOF                     10
      *
     C*----------------------------------------*
     C*  ..平準化確定発注累積ファイル......  *
     C*----------------------------------------*
     C                     SETOF                     11
     C                     Z-ADD0         WSYOS   50
     C           KEY       CHAINAGAPL311             11
     C           *IN11     IFEQ '0'
     C           CBSKJY    ANDEQ'D'
     C           CBSKHZ    ANDLE*DATE
     C                     SETON                     11
     C                     END
     C           *IN11     IFEQ '0'
     C                     Z-ADDCBSYUY    WSYOS
     C                     END
      *
     C*----------------------*
     C*  ..マイナス箱数..  *
     C*----------------------*
     C           HMH,A     IFNE 0
     C                     SETON                     10
     C                     Z-SUBHMH,A     WHAKO   30
     C                     EXSR SUBRTN
     C                     END
      *
     C*--------------------*
     C*  ..プラス箱数..  *
     C*--------------------*
     C           HPH,A     IFNE 0
     C                     SETON                     10
     C                     Z-ADDHPH,A     WHAKO
     C                     EXSR SUBRTN
     C                     END
      *
     C           *IN10     IFEQ '1'
     C                     MOVE '*'       HZM,A
     C                     UPDATBTAPP041
     C                     END
      *
     C                     END
     C                     END
      *
     C*--------------------------------------------*
     C*  ..サブルーチン..                        *
     C*  ..Ａ－ＰＩＣＳ受注データ累積ファイル    *
     C*--------------------------------------------*
     C           SUBRTN    BEGSR
      *
     C                     Z-ADD*DATE     CQKOHZ
     C                     TIME           CQKOTI
     C                     MOVELPUS       CQKOME
     C                     MOVE BTSHN1    CQSHN1
     C                     MOVE BTSHN2    CQSHN2
     C                     MOVE BTSHN3    CQSHN3
     C           WHAKO     MULT WSYOS     CQSRYO
     C                     Z-ADD*DATE     CQTHHZ
     C                     TIME           CQTHTI
     C                     Z-ADD*DATE     CQNOHZ
     C                     Z-ADD0         CQNOBB
     C                     MOVE 'G'       CQTHAI
     C                     MOVE 'K'       CQSKKB
     C                     Z-ADDWHAKO     CQHAKO
     C                     Z-ADDWSYOS     CQSYUY
     C                     MOVE *BLANK    CQDTSY
     C                     MOVE '4'       CQDTSO
     C                     MOVE '27'      CQGYOM
     C                     Z-ADD*DATE     CQURHZ
     C                     TIME           CQURTI
     C                     MOVE 'B'       CQBNKA
     C                     MOVE BTSHN3    CQHBSB
      *
     C*------------------------------------*
     C*        売上・受注№入力。        *
     C*------------------------------------*
     C                     SETOF                     30
     C           1         CHAINAUDPPNO1             30
      *
     C*===読めない時===*
     C           *IN30     IFEQ '1'
     C                     Z-ADDUMONTH    ACTUKI
     C                     Z-ADD8500001   ACRENO
     C                     Z-ADD8500001   CQJTNO
     C                     WRITEAUDPPNO1
     C                     ELSE
      *
     C*===読めた時===*
     C           ACTUKI    IFNE UMONTH
     C                     Z-ADDUMONTH    ACTUKI
     C                     Z-ADD8500001   ACRENO
     C                     Z-ADD8500001   CQJTNO
     C                     UPDATAUDPPNO1
     C                     ELSE
     C           ACRENO    ADD  1         ACRENO
     C                     Z-ADDACRENO    CQJTNO
     C                     UPDATAUDPPNO1
     C                     END
     C                     END
      *
     C                     WRITEAU#PP111
      *
     C                     ENDSR
