     H            Y.
     F** GCQR89 *******************************************************
     F*  DIE SETTING# INQUIRY ( INQUIRY DISPLAY )                     *
     F*----------+-----+---------+------------------------------------*
     F*2022.05.13|TEC. |T.MITSUI | 22047  INITIAL VERSION.            *
     F******************************************************* GCQR89 **
     F*          FILE DEFINE                              *
     F*****************************************************
     F*==< INQUIRY SCREEN >==*
     FGCQPW89 CF  E                    WORKSTN
     F                                        #RRN1 KSFILE GCQPW89S
     F                                              KINFDS INFDS
     F*
     F*==< DIE INFORMATION DATA (3) >==*
     FGCQWP88 IF  E           K        DISK
     F*
     E*****************************************************
     E*          ARRAY DEFINE                             *
     E*****************************************************
     E                    @ENO    1   3  1   @ETX   50
     E                    @ONO    1   3  1   @OTX   50
     E*
     I*****************************************************
     I*          DATA STRACTURE DEFINE                    *
     I*****************************************************
     I*==< SYSTEM INF. >==*
     I           SDS
     I                                     *PROGRAM @@PGM
     I                                      244 253 @@WSID
     I                                      254 263 @@USER
     I                                      264 269 @@JBNO
     I*==< WORKSTATION INF. >==*
     IINFDS       DS
     I                                      273 282 $$WSNM
     I                                    B 370 3710$$CUR
     I                                    B 378 3790$$RRN
     I*==< WORK >==*
     I            DS
     I                                        1   7 W@KAT@
     I                                        1   2 W@KAT1
     I                                        4   7 W@KAT2
     I*
     C*****************************************************
     C*          PARM LIST                                *
     C*****************************************************
     C           *ENTRY    PLIST
     C                     PARM           P@BASE  60
     C                     PARM           P@EXTR  1
     C                     PARM           P@DISP  1
     C                     PARM           P@COND  2
     C*
     C*****************************************************
     C*          WORKING ITEM                             *
     C*****************************************************
     C                     MOVEL'EDT1'    S@PROC  4
     C                     Z-ADD*ZERO     S@RRN1  40
     C*
     C*****************************************************
     C*          MAIN ROUTINE                             *
     C*****************************************************
     C*
D----C           S@PROC    DOWNE'EXIT'
|    C*
|S---C                     SELEC
|+---C           S@PROC    WHEQ 'EDT1'
||   C                     EXSR #EDT1
||   C*
|+---C           S@PROC    WHEQ 'DSP1'
||   C                     EXSR #DSP1
|E---C                     ENDSL
|    C*
E----C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C*****************************************************
     C*  #EDT1                                            *
     C*****************************************************
     C           #EDT1     BEGSR
     C*
     C                     Z-ADDP@BASE    #1BASE
     C*
     C                     Z-ADD1         J       30
     C           P@EXTR    LOKUP@ENO,J                   88
I----C           *IN88     IFEQ '1'
|    C                     MOVEL@ETX,J    #1EXTR
+----C                     ELSE
|    C                     MOVEL*BLANK    #1EXTR
E----C                     ENDIF
     C*
     C                     Z-ADD1         J
     C           P@DISP    LOKUP@ONO,J                   88
I----C           *IN88     IFEQ '1'
|    C                     MOVEL@OTX,J    #1DISP
+----C                     ELSE
|    C                     MOVEL*BLANK    #1DISP
E----C                     ENDIF
     C*
     C*==< SFL CREAR >==*
     C                     SETON                     70     SFLCLR
     C*                    _____________
     C                     WRITEGCQPW89C                    ﾅﾎﾞﾎｦbﾓ hﾒa
     C*                    ~~~~~~~~~~~~~
     C                     SETOF                     70     SFLDSPCTL
     C                     Z-ADD*ZERO     #RRN1             RRN ﾒﾈｮn
     C*
     C*==< SFL WRITE >==*
     C*                    ____________
     C           *HIVAL    SETLLGCQWP88
     C                     EXSR #WP88
     C*                    ~~~~~~~~~~~~
D----C           *IN91     DOWEQ'0'
|    C           #RRN1     ANDLT9999
|    C                     MOVEL*ALL'-'   W@KAT@
|    C                     MOVELW3KAT1    W@KAT1
|    C                     MOVELW3KAT2    W@KAT2
|    C                     MOVELW@KAT@    #1KAT@
|    C                     Z-ADDW3SRYO    #1SRYO
|    C                     Z-ADDW3RQM0    #1RQM0
|    C                     Z-ADDW3RQM1    #1RQM1
|    C                     Z-ADDW3MAIS    #1MAIS
|    C                     Z-ADDW3CLN0    #1CLN0
|    C                     Z-ADDW3CLN1    #1CLN1
|    C                     Z-ADDW3SQTY    #1INVQ
|    C*
|I---C           P@EXTR    IFEQ '1'
||   C           P@EXTR    OREQ '2'
||   C                     MOVELW3CLF0    #1CLF@
||   C*
||S--C                     SELEC
||+--C           W3MAIS    WHEQ W3CLN0
|||  C                     SETOF                     41
|||  C                     SETOF                     42
|||  C*
||+--C           W3MAIS    WHGT W3CLN0
|||  C                     SETON                     41      RED
|||  C                     SETOF                     42
|||  C*
||+--C           W3MAIS    WHLT W3CLN0
|||  C                     SETOF                     41
|||  C                     SETON                     42      WHITE
||E--C                     ENDSL
||   C*
|+---C                     ELSE
||   C                     MOVELW3CLF1    #1CLF@
||   C*
||S--C                     SELEC
||+--C           W3MAIS    WHEQ W3CLN1
|||  C                     SETOF                     41
|||  C                     SETOF                     42
|||  C*
||+--C           W3MAIS    WHGT W3CLN1
|||  C                     SETON                     41      RED
|||  C                     SETOF                     42
|||  C*
||+--C           W3MAIS    WHLT W3CLN1
|||  C                     SETOF                     41
|||  C                     SETON                     42      WHITE
||E--C                     ENDSL
|E---C                     ENDIF
|    C*
|    C                     ADD  1         #RRN1
|    C*                    _____________
|    C                     WRITEGCQPW89S
|    C                     EXSR #WP88
|    C*                    ~~~~~~~~~~~~~
E----C                     ENDDO
     C*
     C*==< NEXT >==*
I----C           #RRN1     IFEQ *ZERO
|    C                     SETOF                     71     SFLDSP OFF
+----C                     ELSE
|    C                     SETON                     71     SFLDSP ON
E----C                     ENDIF
     C*
     C                     Z-ADD1         S@RRN1            SFL表示RRN
     C                     MOVEL'DSP1'    S@PROC           第３画面表示
     C*
     C           #EDT1E    ENDSR
     C*===================================================*
     C*  #WP88   GCQWP88  READ                            *
     C*===================================================*
     C           #WP88     BEGSR
     C*
     C           #WP881    TAG
     C*                    ____________
     C                     READ GCQWP88                  91
     C*                    ~~~~~~~~~~~~
     C           *IN91     CABEQ'1'       #WP88E
     C*
     C*==< SKIP RECORD >==*
S----C                     SELEC
+----C           P@EXTR    WHEQ '2'                         N   CHANGE
|    C           W3CLD0    CABEQ*ZERO     #WP881
|    C*
+----C           P@EXTR    WHEQ '3'                         N+1 CHANGE
|    C           W3CLD1    CABEQ*ZERO     #WP881
E----C                     ENDSL
     C*
     C           #WP88E    ENDSR
     C*****************************************************
     C*  #DSP1                                            *
     C*****************************************************
     C           #DSP1     BEGSR
     C*
     C                     Z-ADDS@RRN1    #RRN1
     C*                    _____________
     C                     WRITEGCQPW891
     C                     EXFMTGCQPW89C
     C*                    ~~~~~~~~~~~~~
     C                     Z-ADD$$RRN     S@RRN1
     C*
     C*==<次処理>==*
S----C                     SELEC
+----C           *IN01     WHEQ '1'                        < F1 >
|    C                     MOVEL'01'      P@COND
|    C                     MOVEL'EXIT'    S@PROC
|    C*
+----C           *IN03     WHEQ '1'                        < F3 >
|    C                     MOVEL'03'      P@COND
|    C                     MOVEL'EXIT'    S@PROC
|    C*
+----C                     OTHER                           < CTRL >
|    C                     MOVEL'DSP1'    S@PROC
E----C                     ENDSL
     C*
     C           #DSP1E    ENDSR
     C*
----+-*--1----+----2----+----3----+----4----+----5----+----6----+----7
** @ENO - @ETX
1ALL DIE
2THIS MONTH CHANGE THE NUMBER OF KANBAN SHEETS
3NEXT MONTH CHANGE THE NUMBER OF KANBAN SHEETS
** @ONO - @OTX
1DIE NUMBER
2THIS MONTH DIFFERENCE IN NUMBER OF KANBAN SHEETS
3NEXT MONTH DIFFERENCE IN NUMBER OF KANBAN SHEETS
