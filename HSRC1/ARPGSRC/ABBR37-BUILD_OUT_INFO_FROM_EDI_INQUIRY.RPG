     C                     Z-ADDBBSDAT    S1SDAT           SCHEDULE DATE
     C                     Z-ADDBBRCDT    S2RCDT           RCV DATE
     C                     Z-ADDBBSDAT    S2SDAT           SCHEDULE DATE
     C                     MOVELBBSEBN    S1SEBN           ID#
     C                     EXSR ##LAST
     C                     MOVE '-'       $SHF1
     C                     MOVE '-'       $SHF2
     C           K$SHN3    IFEQ *BLANK
     C                     MOVE ' '       $SHF2
     C           K$SHN2    IFEQ *BLANK
     C                     MOVE ' '       $SHF1
     C                     ENDIF
     C                     ENDIF
     C                     MOVE '-'       $MHF1
     C                     MOVE '-'       $MHF2
     C                     MOVE '-'       $MHF3
     C           K$MHN4    IFEQ *BLANK
     C                     MOVE ' '       $MHF3
     C           K$MHN3    IFEQ *BLANK
     C                     MOVE ' '       $MHF2
     C           K$MHN2    IFEQ *BLANK
     C                     MOVE ' '       $MHF1
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     ADD  1         X
     C                     MOVELKEY       @M,X
     C*
     C*---------------
     C*
     C                     ADD  1         RRN1
