     C                     ENDSL
      *
     C                     ENDSR
      *===============================================================
      *  指示画面チェック
      *===============================================================
     C           #CHK1     BEGSR
      *
      * RECEIVE DATE (21 22)
      *
     C           D1DAT1    IFEQ 0
     C                     SETON                     2199
     C                     MOVELER,1      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C*
     C                     MOVELD1DAT1    P$DATE
     C                     CALL 'DATR10'
     C                     PARM           P$DATE  8
     C                     PARM           P$RTN   1
     C*PRTN='1':NG
     C           P$RTN     IFEQ '1'
     C                     SETON                     2199
     C                     MOVELER,2      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
      *
     C           D1DAT2    IFEQ 0
     C                     SETON                     2299
     C                     MOVELER,1      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C*
     C                     MOVELD1DAT2    P$DATE
     C                     CALL 'DATR10'
     C                     PARM           P$DATE  8
     C                     PARM           P$RTN   1
     C*PRTN='1':NG
     C           P$RTN     IFEQ '1'
     C                     SETON                     2299
     C                     MOVELER,2      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C*
     C           D1DAT1    IFGT D1DAT2
     C                     SETON                     212299
     C                     MOVELER,3      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
      *
      * IFA PART # (23)
      *
     C*          D1SHN1
     C*          D1SHN2
     C*          D1SHN3
     C                     MOVE '-'       D1SF1
     C                     MOVE '-'       D1SF2
     C           D1SHN3    IFEQ *BLANK
     C                     MOVE ' '       D1SF2
     C           D1SHN2    IFEQ *BLANK
     C                     MOVE ' '       D1SF1
     C                     ENDIF
     C                     ENDIF
      *
      * CUSTOMER PART # (24)
      *
     C*          D1MHN1
     C*          D1MHN2
     C*          D1MHN3
     C*          D1MHN4
     C                     MOVE '-'       D1MF1
     C                     MOVE '-'       D1MF2
     C                     MOVE '-'       D1MF3
