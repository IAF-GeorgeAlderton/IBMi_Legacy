     C                     MOVE ' '       D1MF3
     C           D1MHN3    IFEQ *BLANK
     C                     MOVE ' '       D1MF2
     C           D1MHN2    IFEQ *BLANK
     C                     MOVE ' '       D1MF1
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
