      *
     C           D1DAT1    SETLLABBPL50
     C                     MOVE '        '@STEP
     C                     EXSR #SFSET
      *
S1   C           ENDRRN    IFEQ 0
     C                     SETON                     99
     C                     SETON                     2122
 S2  C           D1SHN1    IFNE *BLANK
     C           D1SHN2    ORNE *BLANK
     C           D1SHN3    ORNE *BLANK
     C                     SETON                     23
 E2  C                     ENDIF
 S2  C           D1MHN1    IFNE *BLANK
     C           D1MHN2    ORNE *BLANK
     C           D1MHN3    ORNE *BLANK
     C           D1MHN4    ORNE *BLANK
     C                     SETON                     24
 E2  C                     ENDIF
      * CUSTOMER (25)
 S2  C           D1TOKU    COMP *BLANK               2525
 S2  C           D1NONY    COMP *BLANK               2626
 S2  C           D1NKOJ    COMP *BLANK               2727
 S2  C           D1NUKE    COMP *BLANK               2828
      * DELIVERY (26)
      * FACTRY   (27)
      * DOCK     (28)
     C                     MOVELER,6      D1ERR
     C                     GOTO $CHK1Z
E1   C                     ENDIF
