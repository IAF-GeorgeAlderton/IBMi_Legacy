     C*-----------------------------------
      * ... FORECAST HISTORYORECAST DATA ACCUMULATION FILE   *.
     C*-----------------------------------
S1   C                     DO   *HIVAL
     C                     READ ABBPL50                  90
     C*   ( RECEIVE DATE )
     C  N90      BBRCDT    IFGT D1DAT2
     C                     SETON                     90
     C                     ENDIF
     C   90                LEAVE
     C*
     C*   ( BUILD OUT FLAG )
     C           BBBFLG    IFNE '1'
     C                     ITER
     C                     ENDIF
     C*
     C                     EXSR #SEL
     C           @NG       IFEQ '*'
     C                     ITER
     C                     ENDIF
     C*                               50:処理済
     C           KEY       LOKUP@M                       50:EQ
 S2  C           *IN50     IFEQ *ON
     C                     ITER
 E2  C                     ENDIF
     C*
     C                     MOVE *BLANK    S1SEL
     C                     MOVE BBTOKU    S1TOKU
     C                     MOVE BBNONY    S1NONY
     C                     MOVE BBNKOJ    S1NKOJ
     C                     MOVE BBNUKE    S1NUKE
