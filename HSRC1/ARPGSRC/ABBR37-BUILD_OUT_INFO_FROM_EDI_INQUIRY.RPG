     C                     KFLD           K$NONY  40       DELIVERY CODE
     C                     KFLD           K$NKOJ  1        FACTORY
     C                     KFLD           K$NUKE  4        DOCK
     C                     KFLD           K$MHN1  5        USER PART1
     C                     KFLD           K$MHN2  5        USER PART2
     C                     KFLD           K$MHN3  5        USER PART3
     C                     KFLD           K$MHN4  5        USER PART4
     C                     KFLD           K$RCDT  80       RCV DATE
     C                     KFLD           K$SDAT  80       SCHEDULE DATE
     C           KEY01B    KLIST
     C                     KFLD           K$NONY  40       DELIVERY CODE
     C                     KFLD           K$NKOJ  1        FACTORY
     C                     KFLD           K$NUKE  4        DOCK
     C                     KFLD           K$MHN1  5        USER PART1
     C                     KFLD           K$MHN2  5        USER PART2
     C                     KFLD           K$MHN3  5        USER PART3
     C                     KFLD           K$MHN4  5        USER PART4
     C*
     C           KEY01A    SETLLABBPL51
      *-----------------------------------
S1   C                     DO   *HIVAL
     C           KEY01B    READEABBPL51                  91
     C  N91      BBRCDT    IFGT D1DAT2
     C                     SETON                     91
     C                     ENDIF
     C   91                LEAVE
     C*   ( BUILD OUT FLAG )
     C           BBBFLG    IFNE '1'
     C                     ITER
     C                     ENDIF
     C*
     C*
     C           BBTOKU    IFNE K$TOKU
