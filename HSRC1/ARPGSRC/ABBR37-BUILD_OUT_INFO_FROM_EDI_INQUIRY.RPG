     C                     GOTO $SELZ
     C                     ENDIF
     C*
     C           D1SHN2    IFNE *BLANK
     C           D1SHN2    ANDNEBBSHN2
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C*
     C           D1SHN3    IFNE *BLANK
     C           D1SHN3    ANDNEBBSHN3
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
      *
      * CUSTMER PART#
      *
     C           D1MHN1    IFNE *BLANK
     C           D1MHN1    ANDNEBBMHN1
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C*
     C           D1MHN2    IFNE *BLANK
     C           D1MHN2    ANDNEBBMHN3
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C*
     C           D1MHN3    IFNE *BLANK
     C           D1MHN3    ANDNEBBMHN3
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C*
     C           D1MHN4    IFNE *BLANK
     C           D1MHN4    ANDNEBBMHN4
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
      *
      *('CUSTOMER')
      *
     C           D1TOKU    IFNE *BLANK
     C                     MOVE D1TOKU    $$TOKU  40
     C           $$TOKU    IFNE BBTOKU
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C                     ENDIF
      *
      *('DELIVERY CODE')
      *
     C           D1NONY    IFNE *BLANK
     C                     MOVE D1NONY    $$NONY  40
     C           $$NONY    IFNE BBNONY
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C                     ENDIF
      *
      *('FACTORY')
      *
     C           D1NKOJ    IFNE *BLANK
     C           D1NKOJ    ANDNEBBNKOJ
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
      *
      *('DOCK')
      *
     C           D1NUKE    IFNE *BLANK
     C           D1NUKE    ANDNEBBNUKE
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
      *
      *
     C           $SELZ     ENDSR
