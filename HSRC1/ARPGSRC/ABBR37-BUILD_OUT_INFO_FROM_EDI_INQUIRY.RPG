     C                     MOVELBBNUKE    K$NUKE  4        DOCK
     C                     MOVELBBMHN1    K$MHN1  5        USER PART1
     C                     MOVELBBMHN2    K$MHN2  5        USER PART2
     C                     MOVELBBMHN3    K$MHN3  5        USER PART3
     C                     MOVELBBMHN4    K$MHN4  5        USER PART4
     C                     Z-ADDBBRCDT    K$RCDT  80       RCV DATE
     C                     Z-ADDBBSDAT    K$SDAT  80       SCHEDULE DATE
     C                     MOVELBBSHN1    K$SHN1  5        IAF PART1
     C                     MOVELBBSHN2    K$SHN2  5        IAF PART2
     C                     MOVELBBSHN3    K$SHN3  2        IAF PART3
