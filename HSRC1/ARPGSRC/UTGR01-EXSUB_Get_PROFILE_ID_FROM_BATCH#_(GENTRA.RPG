     H            Y.
     F** UTGR01 ***********************************************************
     F*  GENTRAN- GET PROFILE ID FROM BATCH#
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTGR01'
     F*                    PARM           $TYP    1
     F*                    PARM           $BCH    7
     F*                    PARM           $PRF    8
     F*                    PARM           $RTN    1
     F*   IN  $TYP    1A   IN/OUT
     F*       $BCH    7A   BATCH#
     F*   OUT $PRF    8A   COMM PROFILE ID
     F*       $RTN    1A   RETURN (BLANK: OK, *: ERROR)
     F******************************************************************
     FINBCTL  IF  E           K        DISK
     FOUTCTL  IF  E           K        DISK
      *--------------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           $TYP    1
     C                     PARM           $BCH    7
     C                     PARM           $PRF    8
     C                     PARM           $RTN    1
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
     C                     MOVE *BLANK    $PRF
     C                     MOVE *BLANK    $RTN
      * EDI NUMERIC
     C                     MOVEL$BCH      $IN       P
     C                     CALL 'UTLR60'
     C                     PARM           $IN    17
     C                     PARM           $TRUE  156
     C                     PARM           $RTN1   1
     C                     Z-ADD$TRUE     $BCH#   70
      * INBOUND
     C           $TYP      IFEQ 'I'
     C           $BCH#     CHAININBCTL               98
     C           *IN98     IFEQ *OFF
     C                     MOVELIQCPID    $PRF      P
     C                     ENDIF
     C                     ENDIF
      * OUTBOUND
     C           $TYP      IFEQ 'O'
     C           $BCH#     CHAINOUTCTL               98
     C           *IN98     IFEQ *OFF
     C                     MOVELOQCPID    $PRF      P
     C                     ENDIF
     C                     ENDIF
      *
     C           $PRF      IFEQ *BLANK
     C                     MOVEL'ZMOD'    $PRF      P
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
