     C           *IN95     DOUEQ*ON
     C           KEYTKR    READEAAGPL031                 95
     C           *IN95     IFEQ '0'
     C           O4SKJY    ANDEQ*BLANK
     C           O4STHZ    ANDEQ99999999
     C                     Z-ADDO4KMAX    @MAXS
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
