     C                     KFLD           F3NONY
      *
     C           K#ADG     KLIST
     C                     KFLD           W@YY
     C                     KFLD           W@MM
     C                     KFLD           W@DD
      *
     C                     MOVE '01'      @@ID    2
     C                     Z-ADD*DATE     W@YMD
     C                     SUB  1         W@MM
     C           W@MM      IFLT 1
     C                     ADD  12        W@MM
     C                     SUB  1         W@YY
     C                     ENDIF
     C                     Z-ADDW@YY      WYY
     C                     Z-ADDW@MM      WMM
     C                     Z-ADDWMMYY     D@FRM
     C                     Z-ADDWMMYY     D@TO
      *
     C                     Z-ADD1         D@CPY
