     C                     ENDSR
      *-----------------------------------------------
     C           #SCRN1    BEGSR
      *-----------------------------------------------
      *
     C                     EXFMTDSP01
      *
     C           *INKC     IFEQ *ON
     C                     MOVE '99'      @@ID
     C                     ELSE
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
      *
     C                     MOVEACMD,1     ARY
     C                     MOVE D@CPY     @CPY    2
     C                     MOVEA@CPY      ARY,54
     C                     MOVEAARY       P@CMD
     C                     Z-ADD75        P@LEN
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN QPRINT
      *
     C                     EXSR #WRT
     C                     EXSR #PRT
      *
     C                     MOVE '99'      @@ID
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------
     C           #CHK1     BEGSR
      *-----------------------------------------------
      *
     C                     SETOF                     99
     C                     MOVEA'00000000'*IN,61
     C           D@FRM     IFEQ *ZERO
     C                     SETON                     6199
     C                     ELSE
     C                     Z-ADDD@FRM     WMMYY
     C                     Z-ADDWMM       W@MM
     C                     Z-ADDWYY       W@YY
     C                     Z-ADD1         W@DD
     C           K#ADG     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ELSE
     C                     Z-ADDW@YMD     W@FRM   80
     C                     ENDIF
     C                     ENDIF
      *
     C           D@TO      IFEQ *ZERO
     C                     Z-ADDD@FRM     D@TO
     C                     ENDIF
      *
     C           D@TO      IFEQ *ZERO
     C                     SETON                     6299
     C                     ELSE
     C                     Z-ADDD@TO      WMMYY
     C                     Z-ADDWMM       W@MM
     C                     Z-ADDWYY       W@YY
     C                     Z-ADD1         W@DD
     C           K#ADG     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6299
     C                     ELSE
     C                     Z-ADD31        W@DD
     C                     Z-ADDW@YMD     W@TO    80
     C                     ENDIF
     C                     ENDIF
      *
     C           D@CPY     IFEQ 0
     C                     SETON                     6499
     C                     ENDIF
      *
     C           D@TOP     IFEQ *ZERO
     C                     SETON                     6399
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------
     C           #WRT      BEGSR
      *-----------------------------------------------
     C                     MOVE *BLANK    W@PART
     C                     Z-ADD*ZERO     W@DATE  80
     C                     Z-ADD*ZERO     @CT     50
     C                     Z-ADD*ZERO     @KB     50
      *
     C           W@FRM     SETLLAH#PP70
     C           *IN80     DOUEQ*ON
     C                     READ AH#PP70                  80
     C  N80      AHDATE    COMP W@TO                 80
     C           *IN80     IFEQ *OFF
     C           AHASJP    ANDNE*BLANK
     C                     WRITEAH#WP761
     C                     ENDIF
     C                     ENDDO
      *
     C                     CLOSEAH#WP76
     C                     OPEN AH#WP76
      *
     C                     MOVE *BLANK    W@PART
     C                     Z-ADD*ZERO     @@CNT   50
     C                     Z-ADD*ZERO     @@YLW   30
     C                     Z-ADD*ZERO     @@ORG   30
     C           *LOVAL    SETLLAH#WP761
     C           *IN80     DOUEQ*ON
     C                     READ AH#WP761                 80
     C           *IN80     IFEQ *OFF
     C           AHPART    IFNE W@PART
     C           @@CNT     ANDNE*ZERO
     C                     MOVE W@PART    AWPART
     C                     Z-ADD@@CNT     AWCONT
     C                     Z-ADD@@YLW     AWYELW
     C                     Z-ADD@@ORG     AWORNG
     C                     WRITEAH#WP771
      *
     C                     Z-ADD*ZERO     @@CNT
     C                     Z-ADD*ZERO     @@YLW   30
     C                     Z-ADD*ZERO     @@ORG   30
     C                     ENDIF
      *
     C                     ADD  1         @@CNT
     C           AHCOLR    IFEQ 'O'
     C                     ADD  1         @@ORG
     C                     ELSE
     C                     ADD  1         @@YLW
     C                     ENDIF
     C                     MOVE AHPART    W@PART
     C                     ENDIF
     C                     ENDDO
      *
     C           @@CNT     IFNE *ZERO
     C                     MOVE W@PART    AWPART
     C                     Z-ADD@@CNT     AWCONT
     C                     Z-ADD@@YLW     AWYELW
     C                     Z-ADD@@ORG     AWORNG
     C                     WRITEAH#WP771
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------
     C           #PRT      BEGSR
      *-----------------------------------------------
     C                     TIME           @@TIME  60
     C                     MOVE *ALL'-'   @@LN  198
     C                     MOVE *OFF      *IN98
     C                     Z-ADD*ZERO     @RANK   30
     C                     Z-ADD*ZERO     @CONT   50
      * PAST 6 MONTH
     C                     EXSR #MON
      *
     C                     CLOSEAH#WP77
     C                     OPEN AH#WP77
      *
     C           *HIVAL    SETLLAH#WP77
     C           *IN80     DOUEQ*ON
     C                     READ AH#WP77                  80
     C           *IN80     IFEQ *OFF
      *
     C           @CONT     IFNE AWCONT
     C                     ADD  1         @RANK
     C           @RANK     IFGT D@TOP
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
      *
     C                     MOVE *BLANK    KANSY
     C                     Z-ADD*ZERO     @MAXS   40
     C           K#FCX     CHAINAAMPL11              95
     C           *IN95     IFEQ *OFF
     C           1         DO   15        K       20
     C           NKAN,K    IFEQ 'C'
     C           NKAN,K    OREQ 'D'
     C           NKAN,K    OREQ 'E'
     C           NKAN,K    OREQ '0'
      *
     C                     MOVE NKAN,K    KANSY   1
     C                     MOVELNTOK,K    @@TKR
     C                     Z-ADDKANK,K    KHIB
     C                     LEAVE
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           KANSY     IFNE *BLANK
      * # OF KANBAN
     C                     EXSR #KANQ
     C                     ENDIF
     C                     ENDIF
      *
     C           K#FCX     CHAINFCEPL11              96
      * 20% OF THE SETTING QTY
     C           *IN96     IFEQ *OFF
     C*****      FCGK01    DIV  FCCD01    W@SET   90H
     C*****      W@SET     MULT 20        W@SET
     C           FCGK01    MULT 0.25      @@SET   90H
     C*****      W@SET     MULT 0.25      @@SET   90H
     C                     ELSE
     C                     Z-ADD*ZERO     @@SET
     C                     ENDIF
      *
     C           AWCONT    COMP @CONT                1010
     C                     Z-ADDAWCONT    @CONT
      *
     C           AWPRT2    COMP *BLANK               0101
     C           AWPRT3    COMP *BLANK               0202
      *
      * MONTHLY RESULT
     C                     EXSR #ACT
      * MONTHLY FORECAST
     C                     EXSR #FRC
      *
     C                     MOVE *BLANK    CST
     C                     MOVE *BLANK    CUS
     C                     Z-ADD*ZERO     K
     C                     Z-ADD*ZERO     L       20
     C           K#FCX     SETLLMBDPL01
     C           *IN95     DOUEQ*ON
     C           K#FCX     READEMBDPL01                  95
     C           *IN95     IFEQ *OFF
     C           F3SKJY    ANDEQ*BLANK
     C                     XFOOTQTX       @@QTY   90
     C           @@QTY     IFNE *ZERO
     C                     MOVEL*BLANK    W5KMEI 15
     C           K#GAD     CHAINGADPL11              90
     C                     MOVELB5KMEI    W5KMEI
     C           W5KMEI    LOKUPCST                      11
     C           *IN11     IFEQ *OFF
     C                     ADD  1         K
     C           K         IFGT 20
     C                     LEAVE
     C                     ENDIF
     C                     MOVELW5KMEI    CST,K
     C                     ADD  1         L
     C                     MOVELW5KMEI    CUS,L
     C           L         IFEQ 4
     C           K         IFEQ 4
     C   OF                EXCPT@HED
     C                     EXCPT@DTL
     C                     ELSE
     C   OF                EXCPT@HED
     C                     EXCPT@DTL2
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     L
     C                     MOVE *BLANK    CUS
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           L         IFGT *ZERO
     C           K         IFLE 4
     C   OF                EXCPT@HED
     C                     EXCPT@DTL
     C                     ELSE
     C   OF                EXCPT@HED
     C                     EXCPT@DTL2
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *--------------------------------------------------
     C           #MON      BEGSR
      *--------------------------------------------------
     C                     MOVE *BLANK    MON
     C                     Z-ADD*MONTH    M       20
     C                     Z-ADD3         K
     C                     DO   3
     C                     ADD  1         K
     C                     SUB  1         M
     C           M         IFLT 1
     C                     ADD  12        M
     C                     ENDIF
     C                     MOVE MN,M      MON,K
     C                     ENDDO
      *
     C                     Z-ADD*MONTH    M       20
     C                     Z-ADD3         K
     C                     DO   3
     C                     MOVE MN,M      MON,K
     C                     ADD  1         M
     C                     SUB  1         K
     C           M         IFGT 12
     C                     SUB  12        M
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *--------------------------------------------------
     C           #KANQ     BEGSR
      *--------------------------------------------------
     C                     SELEC
     C           KANSY     WHEQ 'C'
     C           KEYTKR    SETLLAAFPL031
     C           *IN95     DOUEQ*ON
     C           KEYTKR    READEAAFPL031                 95
     C           *IN95     IFEQ '0'
     C           A3SKJY    ANDEQ*BLANK
     C           A3STHZ    ANDEQ99999999
      *
     C                     Z-ADDA3KMAX    @MAXS
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C*------------------*
     C*  .. TUNNEL ..  *
     C*------------------*
