     C           1         DO   3         K
     C                     ADD  1         @T
     C           QTY,K     SUB  FCGK01    @@ANS   70
     C           @@ANS     IFLT *ZERO
     C                     Z-SUB@@ANS     @@ANS
     C                     ENDIF
     C           @@ANS     IFGE @@SET
