TCHK3C                     PARM           PMXPL            MAX.BOX.PALLET
TCHK3C                     PARM           P@PRT
TCHK3C                     ENDSL
     C                     ENDDO
     C                     ENDIF
      *********************
      * PRINT CUSTOM SHEET
      *********************
     C           D@P3      IFEQ 'Y'                        CUSTOMS SHEET
      *
JW8  C           D@CP3     IFEQ 0
 |   C                     Z-ADD1         CX
 |   C                     ELSE
 |   C                     Z-ADDD@CP3     CX
 |   C                     ENDIF
 |   C           CX        IFGT 7
 |   C                     Z-ADD6         CX
JW8  C                     ENDIF
      *
     C**JW8      PSIRE     IFEQ '2021'                     HCM PLANT1
     C**         PSIRE     OREQ '2022'                     HCM PLANT2
     C**         PSIRE     OREQ '2020'                     SHOWA CANADA
TCHKEC**         PSIRE     OREQ '3318'                     TBCA
TCHKJC**         PSIRE     OREQ '2019'                     HCM AP PLASMAN
JW2  C**         PSIRE     OREQ '0466'                     ADVIC
     C**         PSIRE     OREQ '3062'                     DENSO MEXICO
     C**         PSIRE     OREQ '3070'                     DENSO
     C**         PSIRE     OREQ '3086'                     DENSO CANADA
     C**                   Z-ADDYACUST    CX
     C**                   ENDIF
      *
TCHK5C                     MOVE PNOBI     @@BIN   2
     C                     Z-ADDPWEIG     @@WEI   52
     C                     DO   CX
     C                     CALL 'AB#C3S'                   PRINT CUSTOM SHEET
     C                     PARM           XSIRE
     C                     PARM           PSIRK
     C                     PARM           PNOHZ
     C                     PARM           @@BIN
     C                     PARM           @@WEI
     C                     PARM           PDOCK
     C                     PARM           PODRN
     C                     PARM           P@PRT
JWH  C                     PARM           D@P6
     C                     ENDDO
     C                     ENDIF
      * N/A (NOT USE)
     C**         D@P4      IFEQ 'Y'
     C**                   CALL 'AB#C3O'
     C**                   PARM           P@PRT
     C**                   ENDIF
      * PRINT CONTAINER CHECK LIST
     C           D@P5      IFEQ 'Y'                        CONTAINER CHECK LIST
     C                     CALL 'AB#C46'
     C                     PARM           P@PRT
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     CX
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN AB#PP31
      *
     C                     CLEARAB#WP601
     C                     MOVELXSIRE     SINONY
     C                     MOVELPSIRK     SIFACT
     C                     MOVELWWDOCK    SIDOCK
     C                     MOVELWNOYY     SINOYY
     C                     MOVELWNOMM     SINOMM
     C                     MOVELWNODD     SINODD
     C           SINONY    CHAINFGBPL01              95
     C                     MOVELB2SMEI    SICUST
     C                     Z-ADD@BOX      SICONT
     C                     WRITEAB#WP601
      *
     C                     Z-ADD*ZERO     @BOX
     C                     MOVE *BLANK    WWODRN
      *
     C                     ENDSR
      *********************************************
      * CREATE WORK FILE FOR PICK-UP LIST RTN     *
      *********************************************
     C           @CRTWF    BEGSR
      *
     C                     MOVE *BLANK    @HNDA   1
     C                     OPEN ABWPP3W
     C                     OPEN ABWPL3W
     C                     CLEARABWPP3W1
     C*                    MOVE PNOBI     PNOBIP  2        CHG BIN TO CHAR
      *
     C                     MOVE PNOHZ     WNOHZ
     C                     MOVE PNOBI     WNOBN   20
     C                     MOVE PSIRE     WNONY   40
     C                     MOVE PSIRE     KNONY
     C                     Z-ADD*ZERO     @BOX    30
     C                     SETOF                     89
      *
     C           KEY1      SETLLAB#PL131
     C           *IN90     DOUEQ*ON
     C           KEY1      READEAB#PL131                 90
B1   C           *IN90     IFEQ *OFF
      *
B2   C           BASKJY    IFEQ 'D'
     C**JW       BASKHZ    ANDLE*DATE
     C                     ITER
E2   C                     END
     C*
     C* SELECTED ALL DOCK
B2   C           PDOCK     IFNE '    '
B3   C           PDOCK     ANDNEBANUKE
     C                     ITER
E2   C                     END
     C*
     C* SELECTED FACTORY
B2   C           PSIRK     IFNE BANKOJ
     C                     ITER
E2   C                     END
     C*
     C* SELECTED BIN
B2   C           WNOBN     IFNE BANOBN
     C                     ITER
E2   C                     END
     C*
     C* SELECTED ORDER#
B2   C           PODRN     IFNE *BLANK
B3   C           PODRN     ANDNEBAODRN
     C                     ITER
E2   C                     END
     C*
     C* GET SUPPLIER FOR PRINT
     C                     SETOF                     60
     C           KEY4      CHAINAB#PL90              60
     C           *IN60     IFEQ '0'
     C                     MOVELYASUPP    ISIRE
     C                     ELSE
     C                     ITER
E3   C                     END
     C*
%0003C* GET SHIPPING #
     C                     MOVEL*BLANK    ISHP#
     C                     Z-ADD1         WWNOBN
     C           K#4G      CHAINGADPL41              62
     C           *IN62     IFEQ '0'
     C           B4SKJY    IFEQ 'D'
     C                     ELSE
     C*
     C           WDAT      IFGE B4CHDT
     C                     MOVELB4NSHP    ISHP#            NEW
     C                     ELSE
     C                     MOVELB4OSHP    ISHP#            OLD
     C                     ENDIF
     C*
     C                     ENDIF
     C*
     C                     ENDIF
     C*
     C* SET VALUES NOT REQUIRED CALCULATIONS
     C                     Z-ADDBANOHZ    INOHZ
     C                     Z-ADDBANOBN    INOTM
     C                     MOVELBANUKE    INUKE
     C                     MOVELBAODRN    IODRN
     C                     MOVELBASBAN    ISBAN
     C                     MOVELBAMHIN    IMHN
     C                     Z-ADDBASRYO    ISRYO
     C                     MOVELBASHN1    ISHN1
     C                     MOVELBASHN2    ISHN2
     C                     MOVELBASHN3    ISHN3
     C                     Z-ADDBATOKU    ITOKU
     C                     MOVE BANONY    INONY
     C                     MOVELBANKOJ    INKOJ
      * ASN# FOR HONDA
     C           BATOKU    IFEQ 0295
     C           BATOKU    OREQ 0390
     C           BATOKU    OREQ 0294
     C           BATOKU    OREQ 0296
TCHKHC           BATOKU    OREQ 3135
TCHKHC           BATOKU    OREQ 0391
JW   C           BATOKU    OREQ 1602
JW   C           BATOKU    OREQ 0400
     C                     MOVE '1'       @HNDA   1
      * ?? THERE IS NO CASE BAINVN=BLANK IN HONDA ORDER ?? JW
     C           BAINVN    IFEQ *BLANK
     C           W@8       IFEQ *BLANK
     C                     EXSR #HINV
     C                     ENDIF
     C                     MOVELW@8       BAINVN
     C                     UPDATAB#PL131
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVELBAINVN    IINV#
     C           BANONY    IFEQ 3503
     C           BANONY    OREQ 3504
     C                     MOVELBAODRN    IINV#     P
     C                     ENDIF
JW2   * TTAI
 |   C           BANONY    IFEQ 3556
 JWA C           BANONY    OREQ 4022
 |   C                     MOVELBAINVN    IINV#     P
JW2  C                     ENDIF
      *
     C* SET QUANTITY / CONTAINERS
     C           BAUSYS    IFEQ *ZERO
JWB  C           BAUSYS    OREQ 1
      *
     C           BASYOS    IFEQ *ZERO
JWB  C           BASYOS    OREQ 1
     C                     Z-ADDBASRYO    ISYOS
     C                     ELSE
     C                     Z-ADDBASYOS    ISYOS
     C                     END
     C*
     C                     ELSE
     C                     Z-ADDBAUSYS    ISYOS
     C                     END
      *
     C           ISYOS     IFNE *ZERO
     C           BASRYO    DIV  ISYOS     @@ANS   50
     C                     MVR            @@MVR   50
     C           @@MVR     IFNE *ZERO
     C                     ADD  1         @@ANS
     C                     ENDIF
     C                     ADD  @@ANS     @BOX
     C                     ENDIF
     C*
     C* SET LOCATION
     C           KEY2      SETLLFCEPL011
     C           #PART     TAG
     C           KEY2      READEFCEPL011                 91
B02  C           *IN91     IFEQ '0'
     C*
     C           A2GSKD    IFEQ 'D'
     C                     GOTO #PART
     C                     END
     C*
     C           PNOHZ     IFGE A2DATE                     LOCATION
     C                     MOVE A2STRK    FCLOC1           NEW
     C                     MOVE A2STRT    FCLOC2
     C                     MOVE A2STRR    FCLOC3
     C                     MOVE A2STRD    FCLOC4
     C*
     C                     ELSE
     C                     MOVE A2KTRK    FCLOC1           OLD
     C                     MOVE A2KTRT    FCLOC2
     C                     MOVE A2KTRR    FCLOC3
     C                     MOVE A2KTRD    FCLOC4
     C                     END
     C                     Z-ADDA2KASI    W2KASI  72
     C*
     C* NOT READ FCEPL01
     C                     ELSE
     C                     MOVE *BLANK    FCLOC1
     C                     MOVE *BLANK    FCLOC2
     C                     MOVE *BLANK    FCLOC3
     C                     MOVE *BLANK    FCLOC4
     C                     Z-ADD*ZERO     W2KASI
B02  C                     END
     C*
     C* CALUCULATE THE NUMBER OF BOXES
     C           BASRYO    DIV  ISYOS     FC#BOX
     C                     MVR            WHAK1   40
     C           WHAK1     IFNE 0
     C                     ADD  1         FC#BOX
     C                     END
     C*
     C* CALUCULATE THE TOTAL WEIGHT PAR PART
     C* (QTY/CONTAINER) * (FINISHED WEIGHT) = NET WEIGHT PER BOX(G)
     C* NET WEIGHT + BOX WEIGHT             = GROSS WEIGHT PER BOX(G)
     C* (GROSS WEIGHT PER BOX) * # OF BOX   = TOTAL WEIGHT / PART(G)
     C* (TOTAL WEIGHT PER PART) / 1000      = TOTAL WEIGHT / PART(KG)
     C           ISYOS     MULT W2KASI    WKOT1   92
     C           WKOT1     MULT FC#BOX    WKOT1
     C           WKOT1     DIV  1000      FCWEGH  62
     C                     ADD  PWEIG     FCWEGH
     C*
     C                     WRITEABWPP3W1
     C  N89                SETON                     89
     C*
     C                     ENDIF
     C                     ENDDO
E1    *
     C                     CLOSEABWPP3W
     C                     CLOSEABWPL3W
      *
      *
     C                     ENDSR
      **************************************************
      *                                                *
      **************************************************
     C           #HINV     BEGSR
      *
     C                     MOVEL'HONDA'   K@KWD1    P
     C                     MOVEL'ASN# '   K@KWD2    P
     C           K#PCT     CHAINAB#PPCT              90
     C           *IN90     IFEQ *OFF
     C                     ADD  1         CTNBR1
     C           CTNBR1    IFGT 99999999
     C                     Z-ADD1         CTNBR1
     C                     ENDIF
     C                     UPDATAB#PPCT1
     C                     ELSE
     C                     CLEARAB#PPCT1
     C                     MOVELK@KWD1    CTKEY1
     C                     MOVELK@KWD2    CTKEY2
     C                     ADD  1         CTNBR1
     C                     WRITEAB#PPCT1
     C                     ENDIF
      *
     C                     MOVE CTNBR1    @@8     8
     C           '0'       CHECK@@8       X       20     10
     C           *IN10     IFEQ *ON
     C           8         SUB  X         XX      20
     C                     ADD  1         XX
     C           XX        SUBST@@8:X     W@8     8
     C                     ELSE
     C                     MOVE @@8       W@8
     C                     ENDIF
      *
     C                     ENDSR
      *=======================
JWE   * LOG
 .    *=======================
 .   C           #LOG      BEGSR
 .    *
     C                     CLEARAB#PP2U1
     C                     Z-ADDWDAT      U2CRHZ
     C                     Z-ADDNOW       U2CRTM
     C                     MOVEL#USER     U2CRUS
     C                     MOVEL#WSID     U2CRWS
     C                     MOVEL#PGM      U2CRPG
      *
     C                     MOVELPSIRE     U2NONY
     C                     MOVELPSIRK     U2NKOJ
     C                     MOVELPDOCK     U2NUKE
     C                     MOVELPNOHZ     U2NOHZ
     C                     Z-ADDPNOBI     U2NOBN
     C                     Z-ADDPWEIG     U2WGT
     C                     MOVELPODRN     U2ODRN
     C                     MOVELD@P1      U2@P1            PACKING LIST
     C                     MOVELD@P2      U2@P2            MIXED PALLET SHEET
     C                     MOVELD@P3      U2@P3            CUSTOMS SHEET
     C                     MOVELD@P5      U2@P5            CONTAINER CHECK LIST
JWH  C**                   MOVELD@P6      U2@P6
     C                     MOVELD@PRT     U2PRT
 .    *
 .   C                     WRITEAB#PP2U1
 .    *
JWE  C                     ENDSR
      ********************************************************************
