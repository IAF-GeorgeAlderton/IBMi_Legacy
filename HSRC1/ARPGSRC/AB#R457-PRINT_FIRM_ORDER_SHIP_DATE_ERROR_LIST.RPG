 |3  C           W@NPLX    IFNE *BLANK
 ||   * OLD
 ||  C           KEY0      SETLLAB#PL151
 ||  C           *IN90     DOUEQ*ON
 ||  C           KEY0      READEAB#PL151                 90
 ||   *
 ||  C           *IN90     IFEQ *OFF
 ||  C           BASKJY    ANDEQ*BLANK
 ||  C           BANOBN    ANDEQINOBN
 ||  C           BANOHZ    ANDNEINOHZ
 ||  C                     MOVE *OFF      *IN10
 ||  C                     EXSR #DIFF
 ||  C                     LEAVE
 ||  C                     ENDIF
 ||   *
 ||  C                     ENDDO
 ||   * %0003 PLEX
 |3  C                     ELSE
 ||   * GET SERIAL NUMBER FOR MANIFEST
 ||2 C           *IN10     IFEQ '1'
 ||| C                     Z-ADDINONY     K@DELV
 ||| C                     MOVEL*BLANK    K@ODRN
 ||| C                     MOVELIODRN     K@ODRN
 |||  *
 ||| C           KEYN1     CHAINAB#NP401             21
 |||1C           *IN21     IFEQ '0'
 |||| * UPDATE
 ||||C                     Z-ADDN4NMBR    @CONT   40
 ||||C                     ADD  1         N4NMBR
 ||||C                     Z-ADD*DATE     N4UDAT
 ||||C                     TIME           N4UTIM
 ||||C                     MOVEL#PGM      N4UPGM
 ||||C                     UPDATAB#NP401
 |||| * ADD
 |||1C                     ELSE
 ||||C                     Z-ADD1         N4NMBR
 ||||C                     Z-ADD1         @CONT
 ||||C                     ADD  1         N4NMBR
 ||||C                     Z-ADD*DATE     N4UDAT
 ||||C                     TIME           N4UTIM
 ||||C                     MOVEL#PGM      N4UPGM
 ||||C                     Z-ADDK@DELV    N4KWF1
 ||||C                     MOVELK@ODRN    N4KWC1
 ||||C                     WRITEAB#NP401
 |||1C                     ENDIF
 |||  *
 ||| C                     MOVELIODRN     IINVN
 ||| C                     MOVE '0000000' IINVN
 ||| C                     MOVE @CONT     IINVN
 ||| C*
 ||2 C                     ENDIF
 |3  C                     ENDIF
 4   C                     ENDIF
