     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C                     EXSR #INIT
      *
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVELCMD,1     D@CMD1
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
      * F1: END
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * ENTR
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C           RRN1      IFGE 1
     C                     MOVEL'02'      W@ID
     C                     ENDIF
     C                     ENDIF
     C*
     C                     ENDSL
     C*
     C                     ENDSR
     C*------------------------------------------------------
     C*  CHECK
     C*------------------------------------------------------
     C           #CHK1     BEGSR
     C*
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
     C                     MOVE *OFF      *IN99
     C                     MOVE *OFF      *IN90
     C* ERROR
     C           D@TOKU    IFEQ 0
     C           D@NONY    ANDEQ0
     C                     MOVE ERR,3     D@MSG            ENTER CUST/DELIV
     C                     SETON                     616299
     C                     GOTO XCHK1
     C                     END
      * IF NO ERROR ....
     C                     Z-ADDD@TOKU    D#TOKU  40
     C                     Z-ADDD@NONY    D#NONY  40
     C                     MOVELD@NUKE    D#NUKE  4
      * GET NAME
     C                     MOVE *BLANK    $DLV
     C           D@NONY    IFNE 0
     C                     MOVELD@NONY    $DLV
     C                     ELSE
     C           D@TOKU    IFNE 0
     C                     MOVELD@TOKU    $DLV
     C                     ENDIF
     C                     ENDIF
     C                     CALL 'UTLR62'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTN    1
     C                     MOVEL$NAME1    D@NAM
      *
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C                     ENDIF
      *
     C           RRN1      IFEQ 0
     C                     MOVE ERR,1     D@MSG            NO DATA
     C                     MOVE *ON       *IN61
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C           XCHK1     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVELCMD,4     D@CMD1
     C                     Z-ADDW@RCNO    #RCNO
      *
     C                     WRITEDSP99
      *
     C                     MOVE *ON       *IN53
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN53
      *
     C           @@REC     IFNE 0
     C                     Z-ADD@@REC     W@RCNO
     C                     END
     C*
     C                     SELEC
      * F1: END
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * F5: SELECT ALL
     C           *INKE     WHEQ *ON
     C                     EXSR #ALL
      * F12: BACK
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
     C                     MOVE *BLANK    D@MSG
      * ENTR KEY
     C                     OTHER
     C           D@TOKU    IFNE D#TOKU                     HEADER CHANGED
     C           D@NONY    ORNE D#NONY
     C           D@NUKE    ORNE D#NUKE
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C                     ENDIF
     C                     ELSE
     C                     EXSR #CHK2                      HEADER NOT CHANGED
     C                     END
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      * SET "X" IN SELECT IELD
      *------------------------------------------------------
     C           #ALL      BEGSR
      *
     C                     Z-ADD0         RRN1
      * CHECK SELECT
     C                     DO   *HIVAL
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL01                98
     C   98                LEAVE
      *
     C           S@SLCT    IFEQ *BLANK
     C                     MOVE 'X'       S@SLCT
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      * SET SFL01
      *------------------------------------------------------
     C           #SET1     BEGSR
      * CLEAR SFL01
     C                     Z-ADD0         RRN1    40
     C                     MOVE *ON       *IN54
     C                     WRITECTL01
     C                     MOVE *OFF      *IN54
     C                     Z-ADD0         Z       40
     C                     Z-ADD0         YM
      *
     C                     MOVE *ON       *IN56
     C                     MOVE *OFF      *IN90
     C                     MOVE *BLANK    SVMHN1
      *
     C           D@TOKU    IFNE 0
      *
     C           D@TOKU    IFEQ 9999
     C           0000      SETLLABBPL53C
     C                     ELSE
     C           D@TOKU    SETLLABBPL53C
     C                     ENDIF
      *
     C                     ELSE
     C           D@NONY    SETLLABBPL53B
     C                     END
      *
     C           *IN90     DOUEQ*ON
      *
     C           D@TOKU    IFNE 0
      *
     C           D@TOKU    IFEQ 9999
     C                     READ ABBPL53C                 90
     C                     ELSE
     C           D@TOKU    READEABBPL53C                 90
     C                     ENDIF
      *
     C                     ELSE
     C           D@NONY    READEABBPL53B                 90
     C                     END
     C   90                LEAVE
      *
     C           D@TOKU    IFNE 0
     C           D@TOKU    ANDNEBBTOKU
     C                     ITER
     C                     END
      *
     C           D@NONY    IFNE 0
     C           D@NONY    ANDNEBBNONY
     C                     ITER
     C                     END
      *
     C           D@NUKE    IFNE *BLANK
     C           D@NUKE    ANDNEBBNUKE
     C                     ITER
     C                     END
      *
     C           BBMHN1    IFNE SVMHN1
     C           BBMHN2    ORNE SVMHN2
     C           BBMHN3    ORNE SVMHN3
     C           BBTOKU    ORNE SVTOKU
     C           BBNONY    ORNE SVNONY
     C           BBNUKE    ORNE SVNUKE
     C                     CLEARSFL01
     C                     MOVELBBMHN1    S@MHN1
     C                     MOVELBBMHN2    S@MHN2
     C                     MOVELBBMHN3    S@MHN3
     C                     MOVELBBTOKU    S@TOKU
     C                     MOVELBBNONY    S@NONY
     C                     MOVELBBNUKE    S@NUKE
      * GET QPC
     C                     MOVELBBTOKU    $TOKU
     C                     MOVELBBNONY    $NONY
     C                     MOVELBBMHIN    $MHIN
     C                     MOVE 'USR'     $HTYP
     C                     MOVELTODAY     $DATE
     C                     CALL 'UTLR35D'
     C                     PARM           $TOKU   4
     C                     PARM           $NONY   4
     C                     PARM           $MHIN  20
     C                     PARM           $HTYP   3
     C                     PARM           $DATE   8
     C                     PARM           $SYOS   6
     C                     PARM           $RTN    1
     C                     MOVEL$SYOS     @NUM6   60
     C                     Z-ADD@NUM6     S@QPC
      * FORD DEMAND
     C                     MOVEL@DATE     $END
     C                     MOVELS@NONY    $NONY
     C                     MOVELS@MHIN    $MHIN
     C                     CALL 'UEXR41D'
     C                     PARM           $END    8
     C                     PARM           $NONY   4
     C                     PARM           $MHIN  20
     C                     PARM           $PLNT   5
     C                     PARM           $YTDQ   9
     C                     MOVE $YTDQ     NUM9    90
     C                     Z-ADDNUM9      S@FRDQ
      * IAF YTD SHIP
     C                     CALL 'UEXR41B'
     C                     PARM           $END    8
     C                     PARM           $NONY   4
     C                     PARM           $MHIN  20
     C                     PARM           $YTDQ   9
     C                     MOVE $YTDQ     NUM9
     C                     Z-ADDNUM9      S@IAFQ
     C           S@IAFQ    SUB  S@FRDQ    S@DIFF
      * GET ADD-ON ERROR
     C                     MOVELBBNUKE    $NUKE
     C                     CALL 'UEXR41F'
     C                     PARM           $NONY
     C                     PARM           $NUKE   4
     C                     PARM           $MHIN
     C                     PARM           $STT    1
      *
     C           $STT      IFEQ 'Y'
     C                     MOVE '*'       S@ADD
     C                     ELSE
     C                     MOVE ' '       S@ADD
     C                     ENDIF
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDIF
      * SAVE
     C                     MOVELBBMHN1    SVMHN1  5
     C                     MOVELBBMHN2    SVMHN2  5
     C                     MOVELBBMHN3    SVMHN3  5
     C                     Z-ADDBBTOKU    SVTOKU  40
     C                     Z-ADDBBNONY    SVNONY  40
     C                     MOVELBBNUKE    SVNUKE  4
      *
     C                     ENDDO
      *
     C           RRN1      IFEQ 0
     C                     MOVE ERR,1     D@MSG
     C                     MOVE *ON       *IN61
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     Z-ADD1         W@RCNO  40
      *
     C                     ENDSR
      *------------------------------------------------------
      * CHECK 2ND SCREEN
      *------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     Z-ADD0         RRN1
      * CHECK SELECT
     C                     DO   *HIVAL
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL01                98
     C   98                LEAVE
      *
     C           S@SLCT    IFEQ *BLANK
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE *BLANK    S@SLCT
     C                     MOVE S@MHIN    D@MHIN
     C                     UPDATSFL01
      *
     C                     MOVE S@NONY    @@NONY  4
     C                     MOVE S@NONY    D2NONY
     C                     MOVE S@NUKE    D2NUKE
      *
     C                     EXSR #SET2
      *
     C           RRN2      IFGE 1
     C                     EXSR #SCRN3
     C                     ENDIF
      *
     C           W@ID      IFEQ '02'
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVEL'02'      W@ID
      *
     C                     ENDSR
      *------------------------------------------------------
      * SET SFL02
      *------------------------------------------------------
     C           #SET2     BEGSR
      *
     C                     Z-ADD0         DAT
     C                     Z-ADD0         @P      20
     C                     MOVE S@MHN1    K@MHN1
     C                     MOVE S@MHN2    K@MHN2
     C                     MOVE S@MHN3    K@MHN3
     C                     MOVE S@MHN4    K@MHN4
     C                     MOVE S@NONY    K@NONY
     C                     MOVE S@NUKE    K@NUKE
      * RECEIVED DATE
     C                     Z-ADDTODAY     K@RCDT
      *
     C                     Z-ADD1         @PAGE   20
     C                     Z-ADD0         XXRRN2  40
     C                     EXSR #SET22
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #SET22    BEGSR
      *------------------------------------------------------
     C                     Z-ADD0         RRN2    40
     C                     MOVE *ON       *IN52
     C                     WRITECTL02
     C                     MOVE *OFF      *IN52
     C                     Z-ADD0         DT1
     C                     Z-ADD0         DTE
     C                     Z-ADD99999999  DT2
     C                     Z-ADD0         X       30
     C                     Z-ADD0         Y       30
     C                     Z-ADD0         @PDAT   80
      *
     C           K#KEY     SETGTABBPL53B
     C                     DO   *HIVAL
     C           K#KEYX    REDPEABBPL53B                 90
     C   90                LEAVE
      *
     C           BBSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * RCV DATE
     C           BBRCDT    LOKUPDT1                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         X
      *
     C           X         IFEQ 8
     C                     Z-ADDBBRCDT    @PDAT   80
     C                     LEAVE
     C                     ENDIF
      *
     C           X         IFEQ 1
     C           BBRCDT    LOKUPDAT                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         @P
     C                     Z-ADDBBRCDT    DAT,@P
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADDBBRCDT    DT1,X
     C                     Z-ADDBBRCDT    DTE,X
     C                     ENDIF
      * SHP DATE
     C           BBSDAT    LOKUPDT2                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         Y
     C           Y         IFLE 100
     C                     Z-ADDBBSDAT    DT2,Y
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     SORTADT2
      *
     C           1         DO   99        Y
     C           DT2,Y     IFEQ 99999999
     C                     LEAVE
     C                     ENDIF
      *
     C                     CLEARSFL02
     C                     ADD  1         RRN2
     C                     Z-ADDDT2,Y     S@DATE
     C                     Z-ADDDT2,Y     H@DATE
     C           H@DATE    IFLE *DATE
     C                     Z-ADDRRN2      XXRRN2  40
     C                     ENDIF
     C                     WRITESFL02
     C                     ENDDO
      *
     C           1         DO   7         X
     C           DT1,X     IFEQ 0
     C                     LEAVE
     C                     ENDIF
      *
     C                     Z-ADDDT1,X     K@RCDT
     C           K#KEY     SETLLABBPL53B
     C                     DO   *HIVAL
     C           K#KEY     READEABBPL53B                 90
     C   90                LEAVE
      *
     C           BBSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADD1         Y
     C           BBSDAT    LOKUPDT2,Y                    10
     C           *IN10     IFEQ *ON
     C           Y         ANDLE100
     C           Y         CHAINSFL02                90
     C                     ADD  BBSQTY    QTY,X
      * EDIT QTY
     C                     MOVELQTY,X     $IN       P
     C                     CALL 'EDTR05C'
     C                     PARM           $IN     9
     C                     PARM           $OUT   11
     C                     MOVE $OUT      XTY,X
      *
     C                     UPDATSFL02
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDDO
      *
     C                     Z-ADDXXRRN2    W@RCN1  40
     C           W@RCN1    IFEQ 0
     C                     ADD  1         W@RCN1
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  DISPLAY PREVIOUS SCREEN
      *------------------------------------------------------
     C           #PRV      BEGSR
      *
     C                     ADD  1         @PAGE
     C                     Z-ADD@PDAT     K@RCDT
     C                     EXSR #SET22
     C           RRN2      IFEQ 0
     C                     EXSR #NXT
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  DISPLAY NEXT SCREEN
      *------------------------------------------------------
     C           #NXT      BEGSR
      *
     C                     SUB  1         @PAGE
     C           @PAGE     IFEQ 0
     C                     Z-ADD1         @PAGE
     C                     ELSE
     C                     Z-ADD@PAGE     X
     C                     Z-ADDDAT,X     K@RCDT
     C                     EXSR #SET22
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   3RD SCREEN
      *------------------------------------------------------
     C           #SCRN3    BEGSR
      *
     C           @PAGE     IFEQ 1
     C                     MOVELCMD,2     D@CMD1
     C                     ELSE
     C                     MOVELCMD,3     D@CMD1
     C                     ENDIF
      *
     C                     Z-ADDW@RCN1    #RCNO1
      *
     C                     WRITEDSP992
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL02
     C                     MOVE *OFF      *IN51
      *
     C           @@REC     IFNE 0
     C                     Z-ADD@@REC     W@RCN1
     C                     END
      *
     C                     SELEC
      * F1: END
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * F12: 2ND SCREEN
     C           *INKL     WHEQ *ON
     C                     MOVEL'02'      W@ID
      * F8: DATE DOWN
     C           *INKH     WHEQ *ON
     C           @PAGE     ANDNE1
     C                     EXSR #NXT
      * F9: DATE UP
     C           *INKI     WHEQ *ON
     C                     EXSR #PRV
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           #INIT     BEGSR
      *
     C           K#KEY     KLIST
     C                     KFLD           K@NONY  40
     C                     KFLD           K@MHN1  5
     C                     KFLD           K@MHN2  5
     C                     KFLD           K@MHN3  5
     C                     KFLD           K@MHN4  5
     C                     KFLD           K@NUKE  4
     C                     KFLD           K@RCDT  80
      *
     C           K#KEYX    KLIST
     C                     KFLD           K@NONY  40
     C                     KFLD           K@MHN1  5
     C                     KFLD           K@MHN2  5
     C                     KFLD           K@MHN3  5
     C                     KFLD           K@MHN4  5
     C                     KFLD           K@NUKE  4
      *
     C                     MOVEL'01'      W@ID    2
     C                     Z-ADD0         DTE
     C                     TIME           SDATE
      *
     C                     Z-ADD1         W@SHFT  20
     C                     Z-ADD0         #RCNO1  40
     C                     Z-ADD0         #RCNO   40
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         RRN2    40
      * GET NEXT BUSINESS DAY
     C                     CALL 'UTLR02N'
     C                     PARM           $DT8    8
     C                     MOVEL$DT8      @DATE   80
     C                     MOVEL$DT8      D@NOHZ
      *
     C                     ENDSR
      *------------------------------------------------------
** CMD (61)........2.........3.........4.........5.........6.
F1:END                                                         01
F1:END   F12:BACK      F9:Prev->   Page Up/Down                02
