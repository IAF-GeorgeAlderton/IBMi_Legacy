     FABBPW53 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                        RRN2  KSFILE SFL02
     F                                              KINFDS @INFDS
     FABBPL53BIF  E           K        DISK
     FABBPL53CIF  E           K        DISK
     F            ABBPP531                          KRENAMEABBPP53C
      *------------------------------------------------------------
     E                    CMD     1   5 61
     E                    ERR     1   3 70
     E                    DT1         7  8 0
     E                    DT2       100  8 0
     E                    QTY         7  7 0
     E                    XTY         7  9
      *
     E                    DTE         7  6 0
      *
     E                    D@M         9  3
     E                    DAT        50  8 0
     E                    YM          9  6 0
     E                    W9YM        9  6 0
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1  540W9YM
     I                                        1   60W9YM01
     I                                        7  120W9YM02
     I                                       13  180W9YM03
     I                                       19  240W9YM04
     I                                       25  300W9YM05
     I                                       31  360W9YM06
     I                                       37  420W9YM07
     I                                       43  480W9YM08
     I                                       49  540W9YM09
     I            DS
     I                                        1  49 QTY
     I                                        1   70H@QTY1
     I                                        8  140H@QTY2
     I                                       15  210H@QTY3
     I                                       22  280H@QTY4
     I                                       29  350H@QTY5
     I                                       36  420H@QTY6
     I                                       43  490H@QTY7
     I            DS
     I                                        1  63 XTY
     I                                        1   9 S@QTY1
     I                                       10  18 S@QTY2
     I                                       19  27 S@QTY3
     I                                       28  36 S@QTY4
     I                                       37  45 S@QTY5
     I                                       46  54 S@QTY6
     I                                       55  63 S@QTY7
     I            DS
     I                                        1  42 DTE
     I                                        1   60D@DAT1
     I                                        7  120D@DAT2
     I                                       13  180D@DAT3
     I                                       19  240D@DAT4
     I                                       25  300D@DAT5
     I                                       31  360D@DAT6
     I                                       37  420D@DAT7
     I            DS
     I                                        1  20 BBMHIN
     I                                        1   5 BBMHN1
     I                                        6  10 BBMHN2
     I                                       11  15 BBMHN3
     I                                       16  20 BBMHN4
     I            DS
