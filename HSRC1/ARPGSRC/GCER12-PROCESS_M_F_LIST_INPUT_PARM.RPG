      *
     C                     MOVE PFDAT     FPDAT
     C                     SETOF                     21
     C                     ADD  1         RECD    40
     C                     TIME           WTIME   60
      *
     C           *IN22     IFEQ '0'
     C                     SETON                     2122
      *
     C                     SETOF                     02
     C           US        CHAINRGAPL111             02
     C           *IN02     IFEQ '0'
     C           J8SKJY    IFNE 'D'
     C                     MOVELJ8NAME    WUS    15
     C                     MOVELJ8NAME    WNS     9
     C                     END
     C                     END
      *
