     C           FTANZ     COMP 'S'                      19
      *
     C                     END
      *
     C                     SETOF                     41
     C                     MOVE *BLANK    KOT
     C                     Z-ADD0         KBM
     C           KEY       CHAINAAMPL111             41
     C           *IN41     IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     41
     C                     END
     C           *IN41     IFEQ '0'
      *
     C                     Z-ADD1         A       20
     C                     Z-ADD0         B       20
     C           1         DO   15        A
     C                     MOVELNUKH,A    WUKH    80
     C           *DATE     IFLT WUKH
     C           OKOT,A    IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE OKOT,A    KOT,B
     C                     Z-ADDOKBM,A    KBM,B
     C                     END
     C                     ELSE
     C           NKOT,A    IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE NKOT,A    KOT,B
     C                     Z-ADDNKBM,A    KBM,B
     C                     END
     C                     END
     C                     END
     C                     END
      *
