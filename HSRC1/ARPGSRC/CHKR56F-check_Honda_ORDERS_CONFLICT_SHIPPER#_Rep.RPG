     H            Y.
     F***CHKR56F****************************************************************
     F*  PROGRAM    : CHECK HONDA ORDERS CONFLICT SHIPPER#                     *
     F*             : READ AB#PL1N                                             *
     F*  WRITTEN    : 2020.06.08                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#PL2F1IF  E           K        DISK
     FAB#PL2F3IF  E           K        DISK
     F            AB#PP2F1                          KRENAMEAB#PP2F3
     FQPRINT  O   F     132     OF     PRINTER
      * RENAME FIELD
     IAB#PP2F3    01
     I              AFASNO                          XXASNO
     I              AFNONY                          XXNONY
     I              AFSHDT                          XXSHDT
     I              AFBIN                           XXBIN
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           TODAY     SETLLAB#PL2F1
     C                     DO   *HIVAL
     C                     READ AB#PL2F1                 98
     C   98                LEAVE
      * SAME ORDER?
     C           AFSHDT    IFEQ SVSHDT
     C           AFASNO    ANDEQSVASNO
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #CHK1
     C           *IN85     IFEQ *ON
     C                     EXSR #PRINT
     C                     ENDIF
      *
     C                     Z-ADDAFSHDT    SVSHDT
     C                     MOVELAFASNO    SVASNO
     C                     Z-ADDAFNONY    SVNONY
     C                     Z-ADDAFBIN     SVBIN
      *
     C                     ENDDO
      *
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  CHECK DUPLICATER ASN#                             *
      *----------------------------------------------------*
     C           #CHK1     BEGSR
      *
     C                     MOVE *OFF      *IN85
      * READ PAST SHIPPER#
     C           AFASNO    SETLLAB#PP2F3
     C                     DO   *HIVAL
     C           AFASNO    READEAB#PP2F3                 98
     C   98                LEAVE
      *
     C           AFNONY    IFNE XXNONY
     C           AFSHDT    ORNE XXSHDT
     C           AFBIN     ORNE XXBIN
     C                     MOVE *ON       *IN85
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C                     MOVE *BLANK    $RTN
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
      *
     C                     Z-ADD0         SVSHDT  80
     C                     MOVE *BLANK    SVASNO  8
     C                     Z-ADD0         SVNONY  40
     C                     Z-ADD0         SVBIN   20
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** CHECK HONDA ORDER'
     O                                   60 'S SHIPPER# CONFLICTI'
     O                                   80 'ON **               '
     O                                   89 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                                  106 'P.'
     O                         PAGE  Z  110
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   12 'CUST'
     O                                   17 'DELV'
     O                                   26 'SHP_DATE'
     O                                   33 'BIN#'
     O                                   38 'ODR#'
     O                                   48 'PART'
     O        E 1              @DTL
     O                         SEQ#  1 +000
     O                         AFTOKU  +003
     O                         AFNONY  +001
     O                         AFSHDT  +001 '    /  /  '
     O                         AFBIN   +002
     O                         AFASNO  +002
     O                         AFMHIN  +002
