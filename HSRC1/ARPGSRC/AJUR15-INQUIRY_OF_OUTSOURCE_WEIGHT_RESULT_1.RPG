     F*****************************************************************
     FAJUPW15 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFREC1
     F                                              KINFDS INFDS
      * OUTSOURCE WEIGHT RESULT 1                *
     FAJUPL10 IF  E           K        DISK
      *================================================================
     E                    ER      1  10 78
      *================================================================
     IINFDS       DS
     I                                    B 378 3790$$RRN
     I****************************
     I*プログラム状況データ構造*
     I****************************
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W$JBNO
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *---------------------------------------------
      *計量　日付＋時刻
     I            DS
     I                                        1  120D1KEDT
     I                                        1   80D1KED2
     I                                        9  120D1KET2
     I            DS
     I                                        1  120U1KEDT
     I                                        1   80U1KEID
     I                                        9  120U1KEIT
      * PART NUMBER
     I            DS
     I                                        1  14 U1HIN
     I                                        1   5 U1HIN1
     I                                        6   6 U1HF1
     I                                        7  11 U1HIN2
     I                                       12  12 U1HF2
     I                                       13  14 U1HIN3
      * ORDER+PAGE
     I            DS
     I                                        1   6 S1THP1
     I                                        1   3 U1THI1
     I                                        4   4 S1THF1
     I                                        5   6 U1PAG1
     I            DS
     I                                        1   6 S1THP2
     I                                        1   3 U1THI2
     I                                        4   4 S1THF2
     I                                        5   6 U1PAG2
     I            DS
     I                                        1   6 S1THP3
     I                                        1   3 U1THI3
     I                                        4   4 S1THF3
     I                                        5   6 U1PAG3
     I            DS
     I                                        1   6 S1THP4
     I                                        1   3 U1THI4
     I                                        4   4 S1THF4
     I                                        5   6 U1PAG4
      *================================================================
     C*
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      * INITIALIZE
      *===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
      *
     C                     CLEARDSP01
     C                     TIME           @TIME
     C                     MOVEL*BLANK    D1MKKB           MACHINE NO
     C                     Z-ADD0         D1KED1           DATE FROM
     C                     Z-ADD0         D1KET1           TIME FROM
     C                     Z-ADD0         D1KED2           DATE TO
     C                     Z-ADD0         D1KET2           TIME TO
     C                     MOVEL*BLANK    D1ERR
     C*
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
      *===============================================================
      * SCREEN 1
      *===============================================================
     C           #DSP1     BEGSR
     C                     EXFMTDSP01
     C                     MOVEA'00000000'*IN,11           11-18
     C                     MOVEA'0'       *IN,99
      *----*
     C                     SELEC
     C* F1 *
     C           *INKA     WHEQ *ON
     C                     MOVE '#END    '@STEP
     C******
     C                     OTHER
     C                     MOVE '#CHK1   '@STEP
     C                     ENDSL
      *----*
     C                     ENDSR
      *===============================================================
      * CHECK SCREEN1
      *===============================================================
     C           #CHK1     BEGSR
      **
      ** MACHINE NO (11)
      **
     C           D1MKKB    IFEQ *BLANK
     C                     SETON                     1199
     C                     MOVELER,1      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
      **
      ** WEIGHTING DATE TIME
      **
     C           D1KED1    IFEQ 0                          DATE FROM
     C                     SETON                     1299
     C                     MOVELER,2      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
     C           D1KED2    IFEQ 0                          DATE FROM
     C                     SETON                     1499
     C                     MOVELER,2      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
     C           D1KED1    IFGT D1KED2                     DATE FROM
     C                     SETON                     121499
     C                     MOVELER,3      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
      *
      * OUTSOURCE WEIGHT RESULT 1                *
      *
     C           KEY01     KLIST
     C                     KFLD           D1MKKB
     C                     KFLD           D1KED1
     C                     KFLD           D1KET1
      * SFLCLR
     C                     SETON                     73
     C                     WRITESFCTL1
     C                     SETOF                     73
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         ENDRRN  40
      *
     C           KEY01     SETLLAJUPL10
     C                     EXSR #SFSET
     C*-------------------------
     C*
     C           ENDRRN    IFEQ 0                           NO DATA
     C                     MOVEA'11111'   *IN,11
     C                     SETON                     99
     C                     MOVELER,4      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
      *-------------------------
     C           @CHK1     TAG
      *-------------------------
     C           *IN99     IFEQ *OFF
     C                     MOVE '#DSP2   '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *===============================================================
      *===============================================================
     C           #SFSET    BEGSR
     C                     Z-ADDENDRRN    RRN1
     C                     Z-ADD0         CTR     40
      *-------------------------
     C                     DO   *HIVAL
     C           D1MKKB    READEAJUPL10                  90
     C   90                LEAVE
     C           U1SKJY    IFEQ 'D'                        DELETE FLAG
     C           U1SKHZ    ANDLE@SYSHZ                     DELETE DATE
     C                     ITER
     C                     ENDIF
      *計量　日付＋時刻
     C           U1KEDT    IFGT D1KEDT
     C                     SETON                     90
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVE *BLANK    S1SLCT
     C                     Z-ADDU1KEID    S1KEID           WEIGHTING DATE
     C                     Z-ADDU1KEIT    S1KEIT           WEIGHTING TIME
     C*
     C                     MOVE '-'       U1HF1
     C                     MOVE '-'       U1HF2
     C           U1HIN3    IFEQ *BLANK                     PART NUMBER
     C                     MOVE ' '       U1HF2
     C           U1HIN2    IFEQ *BLANK                     PART NUMBER
     C                     MOVE ' '       U1HF1
     C                     ENDIF
     C                     ENDIF
     C                     MOVELU1HIN     S1HIN            PART NUMBER
     C* ORDER+PAGE
     C                     MOVE *BLANK    S1THF1
     C                     MOVE *BLANK    S1THF2
     C                     MOVE *BLANK    S1THF3
     C                     MOVE *BLANK    S1THF4
     C           U1PAG1    IFNE *BLANK
     C                     MOVE '-'       S1THF1
     C                     ENDIF
     C           U1PAG2    IFNE *BLANK
     C                     MOVE '-'       S1THF2
     C                     ENDIF
     C           U1PAG3    IFNE *BLANK
     C                     MOVE '-'       S1THF3
     C                     ENDIF
     C           U1PAG4    IFNE *BLANK
     C                     MOVE '-'       S1THF4
     C                     ENDIF
     C*
     C                     MOVELU1ZBR1    S1ZBR1           MATERIAL BARCODE 1
     C                     MOVELU1ZBR2    S1ZBR2           MATERIAL BARCODE 2
      *
     C                     MOVELU1KANR    S1KANR           MANAGEMENT INSTRUC
     C                     MOVELU1ZETI    S1ZETI           ID NUMBER
     C                     MOVELU12JKA    S12JKA           SECONDARY PROCESSING
     C                     MOVELU1TASY    S1TASY           OBJECT OUTSIDE
     C                     MOVELU1SYUK    S1SYUK           OUTGOING EFFECTIVE
     C                     MOVELU1HKBR    S1HKBR           CONTAINER TYPE(BCR)
     C                     MOVELU1HNTE    S1HNTE           PART NUMBER INPUT
     C                     MOVELU1SYTE    S1SYTE           ACCOMMODATED QUANT
     C                     Z-ADDU1SYUY    S1SYUY           ACCOMMODATED QTY
     C                     MOVELU1HKFA    S1HKFA           CONTAINER TYPE(FAM)
     C                     MOVELU1TATE    S1TATE           COMPLETION UNIT WEIGH
     C                     Z-ADDU1TANJ    S1TANJ           COMP UNIT WEIGHT
     C                     Z-ADDU1MTAN    S1MTAN           COMP UNIT MASTER WEIG
     C                     Z-ADDU1WAIT    S1WAIT           WEIGHTING WEIGHT
     C                     Z-ADDU1TMAI    S1TMAI           NUMBER OF SURPLUS
     C                     MOVELU1GAFR    S1GAFR           APPEARANCE DEFEC
     C                     MOVELU1BINN    S1BINN           BIN NO.
     C                     MOVELU1KECD    S1KECD           MEASUREMENT WORKER
     C                     ADD  1         RRN1
     C                     ADD  1         CTR
     C                     WRITESFREC1
     C           CTR       IFGE 15
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *-------------------------
     C                     Z-ADDRRN1      ENDRRN
     C                     Z-ADDRRN1      #RCNO1
     C                     ENDSR
      *===============================================================
      * SCREEN 2
      *===============================================================
     C           #DSP2     BEGSR
      *
     C                     WRITEDSP02
     C                     SETON                     7172
     C                     EXFMTSFCTL1
     C                     SETOF                     7172
      *
     C                     Z-ADD$$RRN     #RCNO1
      *
     C                     SELEC
     C* ( F1 ) END
     C           *INKA     WHEQ *ON
     C                     MOVE '#END    '@STEP
     C* ( F3 ) GO BACK
     C           *INKC     WHEQ *ON
     C                     MOVE '#DSP1   '@STEP
     C* ROLL UP
     C           *IN74     WHEQ *ON
     C           *IN90     ANDEQ*OFF
     C                     EXSR #SFSET
     C                     MOVE '#DSP2   '@STEP
     C                     OTHER
     C                     EXSR #SFCHK
     C                     ENDSL
      *
     C                     ENDSR
      *===============================================================
      *===============================================================
      *===============================================================
     C           #SFCHK    BEGSR
     C*
      *-------------------------
     C                     DO   ENDRRN    RRN1
     C           RRN1      CHAINSFREC1               91
     C   91                LEAVE
     C*
     C           S1SLCT    IFNE *BLANK
     C                     EXSR ##DSP3
     C           @STEP     IFEQ '#END    '
     C                     LEAVE
     C                     ENDIF
     C                     MOVE *BLANK    S1SLCT
     C                     UPDATSFREC1
     C                     ENDIF
     C                     ENDDO
      *-------------------------
     C                     ENDSR
      *===============================================================
      * SCREEN 3
      *===============================================================
     C           ##DSP3    BEGSR
      *-------------------------*
     C           @DSP3     TAG
      *-------------------------*
     C                     EXFMTDSP03
     C                     SELEC
     C* ( F1 ) END
     C           *INKA     WHEQ *ON
     C                     MOVE '#END    '@STEP
     C* ( F3 ) GO BACK
     C           *INKC     WHEQ *ON
     C                     OTHER
     C                     GOTO @DSP3
     C                     ENDSL
      *
     C                     ENDSR
