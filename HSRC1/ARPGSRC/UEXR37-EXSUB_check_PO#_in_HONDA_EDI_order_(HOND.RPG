     H            Y.
      ** AB#RH5 **********************************************
      *  HONDA - CHECK PO# IN HONDA EDI ORDER                *
      *   (COMPARE FIRST 6 CHARACTER OF ORDER# )             *
      *  J.WATANABE  11.18.2020                              *
      *------------------------------------------------------*
      *  CALLING SEQ.
      *                    CALL 'UEXR37'
      *                    PARM           $NONY   4
      *                    PARM           $ODRN  10
      *                    PARM           $MHIN  20
      *                    PARM           $RTN    1
      *   IN  $NONY   4A DELIVERY#
      *       $ODRN: 10A ORDER#
      *       $MHIN: 20A USER PART#
      *   OUT $RTN :  1A RETURN (BLANK:OK, *:NO GOOD)
      ********************************************************
     FEDIPP45 IF  E           K        DISK
     FAB#EL92SIF  E           K        DISK
     FAB#EL90SIF  E           K        DISK
      *
     I            DS
     I                                        1  20 K5MHN
     I                                        1   5 K5MHN1
     I                                        6  10 K5MHN2
     I                                       11  15 K5MHN3
     I                                       16  20 K5MHN4
      *-----------------------------------------------------------*
      *     M  A  I  N  L  I  N  E                                *
      *-----------------------------------------------------------*
      *
     C                     EXSR #INIT
      *
     C                     EXSR #MAIN
      *
     C                     SETON                     LR
     C                     RETRN
      *************************************************************
      * MAIN
      *************************************************************
     C           #MAIN     BEGSR
      *
      * GET USER PART
     C                     MOVE *BLANK    @MHN30 30
     C                     MOVEL$NONY     K5NONY
     C                     MOVEL$MHIN     K5MHN
     C           K#PP45    SETLLEDIPP45
     C                     DO   *HIVAL
     C           K#PP45    READEEDIPP45                  51
     C   51                LEAVE
     C                     MOVELE5UPRT    @MHN30
     C                     ITER
     C                     ENDDO
     C           @MHN30    IFEQ *BLANK
     C                     MOVE '1'       $RTN
     C                     GOTO @END1
     C                     ENDIF
      *
      * CHECK AB#EP92 (EDI862) **********
     C                     MOVEL@ODR20    @ODR6   6
     C                     MOVEL@ODR6     @ODR20    P
     C           @ODR20    SETLLAB#EL92S
     C                     DO   *HIVAL
     C                     READ AB#EL92S                 52
     C   52                LEAVE
     C                     MOVELA9ODRN    A9ODR6  6
     C           A9ODR6    IFNE @ODR6
     C                     LEAVE
     C                     ENDIF
     C           A9QNTY    IFEQ 0
     C                     ITER
     C                     ENDIF
     C           A9MHIN    IFNE @MHN30
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE *BLANK    $RTN
     C                     GOTO @END1
     C                     ENDDO
      *
      * CHECK AB#EP90 (EDI850) **********
     C           @ODR20    SETLLAB#EL90S
     C                     DO   *HIVAL
     C                     READ AB#EL90S                 53
     C   53                LEAVE
     C                     MOVELAEODRN    AEODR6  6
     C           AEODR6    IFNE @ODR6
     C                     LEAVE
     C                     ENDIF
     C           AEQNTY    IFEQ 0
     C                     ITER
     C                     ENDIF
     C           AEMHIN    IFNE @MHN30
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE *BLANK    $RTN
     C                     GOTO @END1
     C                     ENDDO
      *
     C           @END1     ENDSR
      *************************************************************
      * INITIALIZE
      *************************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4
     C                     PARM           $ODRN  10
     C                     PARM           $MHIN  20
     C                     PARM           $RTN    1
      *
     C           K#PP45    KLIST
     C                     KFLD           K5NONY  40
     C                     KFLD           K5MHN1  5
     C                     KFLD           K5MHN2  5
     C                     KFLD           K5MHN3  5
     C                     KFLD           K5MHN4  5
      *
     C                     MOVE '*'       $RTN
     C                     MOVEL$ODRN     @ODR20 20
      *
     C                     ENDSR
