     FGVGPW10 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL010
     F                                        RRN2  KSFILE SFL020
     F                                              KINFDS @INFDS
     FAKBPL07 IF  E           K        DISK
     FBBCDDM06IF  E           K        DISK
      *------------------------------------------------------------
     I@INFDS      DS
     I                                     *STATUS  @STTS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME(6) + DATE(8)
     I            DS
     I                                        1  140WWTIME
     I                                        1   60WTIME
     I                                        1   40WTIM4
     I                                        1   20WTIMHH
     I                                        3   40WTIMMM
     I                                        7  120WSDATE
     I                                        9  120@@YM4
     I                                        7  120@@YM6
     I                                        7  140@@YMD
     I                                        7  100@@YY
     I                                       11  120@@MM
     I                                       13  140@@DD
      *
     I            DS
     I                                        1  14 W@IHIN
     I                                        1   5 W@IHN1
     I                                        6   6 W@IHNA
     I                                        7  11 W@IHN2
     I                                       12  12 W@IHNB
     I                                       13  14 W@IHN3
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C                     EXSR #SETL
     C           *IN99     IFEQ *OFF
     C                     EXSR #INQL
     C                     END
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
     C*
     C                     TIME           WWTIME
     C*
     C                     ENDSR
     C*------------------------------------------------------
     C*   SET DATA LIST FOR SFL010
     C*------------------------------------------------------
     C           #SETL     BEGSR
     C*
     C                     MOVEL*ON       *IN41
     C                     WRITECTL010
     C                     MOVEL*OFF      *IN41
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD0111      K@TOKU
     C           *LOVAL    SETLLAKBPL07
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AKBPL07                  89
     C   89                LEAVE
     C*
     C           L1SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           L1STYY    IFEQ 9999
     C           L1BMON    ANDEQ8990
     C                     ELSE
     C                     ITER
     C                     END
      *
     C           K#B06     KLIST
     C                     KFLD           K@TOKU  40
     C                     KFLD           L1SHN1
     C                     KFLD           L1SHN2
     C                     KFLD           K@SHN3  5
     C                     MOVELL1SHN3    K@SHN3
     C           K#B06     SETGTBBCDDM06
     C*
     C                     DO   *HIVAL
     C*
     C           K#B06     REDPEBBCDDM06                 88
     C   88                LEAVE
     C           BCKEH8    IFLT @@YMD
     C                     LEAVE
     C                     END
     C           BCSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C*
     C                     CLEARSFL010
     C*
     C                     MOVEL*BLANK    W@IHIN
     C                     MOVELBCHIN1    W@IHN1
     C           BCHIN2    IFNE *BLANK
     C                     MOVEL'-'       W@IHNA
     C                     END
     C                     MOVELBCHIN2    W@IHN2
     C           BCHIN3    IFNE *BLANK
     C                     MOVEL'-'       W@IHNB
     C                     END
     C                     MOVELBCHIN3    W@IHN3
     C                     MOVELW@IHIN    S1IHIN
     C                     MOVELBCHIN1    H1IHN1
     C                     MOVELBCHIN2    H1IHN2
     C                     MOVELBCHIN3    H1IHN3
     C*
     C                     Z-ADDBCKSH8    S1KSH8
     C                     Z-ADDBCKEH8    S1KEH8
     C                     Z-ADDBCKTNK    S1KTNK
     C*
     C                     ADD  1         RRN1
     C                     WRITESFL010
     C           RRN1      IFEQ 9999
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*------------------------------------------------------
     C*   DISP LIST(CTL010)
     C*------------------------------------------------------
     C           #INQL     BEGSR
     C*
     C                     Z-ADD1         W@RRN1  40
     C*
     C                     DO   *HIVAL
     C*
     C                     WRITEFMT099
     C                     Z-ADDW@RRN1    #RCN01
     C                     EXFMTCTL010
     C                     MOVEL*BLANK    D99MSG
     C   KA
     COR KL                LEAVE
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W@RRN1
     C                     END
     C*
     C                     Z-ADD*ZERO     RRN1    40
     C*
     C                     DO   *HIVAL
     C*
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL010               87
     C   87                LEAVE
     C*
     C           S1SLCT    IFNE *BLANK
     C                     MOVEL*BLANK    S1SLCT
     C                     MOVEL*ON       *IN46
     C                     UPDATSFL010
     C                     MOVEL*OFF      *IN46
     C                     EXSR #SETD
     C                     EXSR #INQD
     C   KA                LEAVE
     C                     END
     C*
     C                     ENDDO
     C   KA                LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*------------------------------------------------------
     C*   SET DATA DETAIL FOR SFL020
     C*------------------------------------------------------
     C           #SETD     BEGSR
     C*
     C                     MOVEL*ON       *IN51
     C                     WRITECTL020
     C                     MOVEL*OFF      *IN51
     C                     Z-ADD*ZERO     RRN2    40
      *
     C           K#B06D    KLIST
     C                     KFLD           K@TOKU  40
     C                     KFLD           H1IHN1
     C                     KFLD           H1IHN2
     C                     KFLD           K@IHN3  5
     C                     MOVELH1IHN3    K@IHN3
     C           K#B06D    SETGTBBCDDM06
     C*
     C                     DO   *HIVAL
     C*
     C           K#B06D    REDPEBBCDDM06                 86
     C   86                LEAVE
     C           BCSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C*
     C                     CLEARSFL020
     C*
     C                     MOVELS1IHIN    D2IHIN
     C                     Z-ADDBCKSH8    S2KSH8
     C                     Z-ADDBCKEH8    S2KEH8
     C                     Z-ADDBCKTNK    S2KTNK
     C*
     C                     ADD  1         RRN2
     C                     Z-ADDRRN2      S2SEQ#
     C                     WRITESFL020
     C           RRN2      IFEQ 9999
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*------------------------------------------------------
     C*   DISP DETAIL(CTL020)
     C*------------------------------------------------------
     C           #INQD     BEGSR
     C*
     C                     Z-ADD1         W@RRN2  40
     C*
     C                     DO   *HIVAL
     C*
     C                     WRITEFMT099
     C                     Z-ADDW@RRN2    #RCN02
     C                     EXFMTCTL020
     C                     MOVEL*BLANK    D99MSG
     C   KA
     COR KL                LEAVE
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W@RRN2
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
