     H            Y.
     F** ALDR27 *********************************************
     F* SERVICE PARTS - ORDER SHORTAGES                     *
     F*    LEC.  2021.05.21                                 *
     F*******************************************************
     FALDPW27 CF  E                    WORKSTN      KINFDS @INFDS
     FAB#PL1L IF  E           K        DISK
     FAB#PL44CIF  E           K        DISK
     FAB#PL71 UF  E           K        DISK
     FALDWP27 UF  E                    DISK                      A
     E                    ER      1   4 65
      *
     I@INFDS      DS
     I                                     *STATUS  @STTS
      *
     I            DS
     I                                        1  18 D1BARC
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  140SDATE
     I                                        7  100SDYY
     I                                       11  120SDMM
     I                                       13  140SDDD
     I                                        1   60STIME
     I                                        1   20STHH
     I                                        3   40STMM
      *
     I            DS
     I                                        1   80SHID
     I                                        1   40EKNOYY
     I                                        5   60EKNOMM
     I                                        7   80EKNODD
      *
     I            DS
     I                                        1  12 IPART
     I                                        1   5 EKSHN1
     I                                        6  10 EKSHN2
     I                                       11  12 EKSHN3
      *
     I            DS
     I                                        1  20 CPART
     I                                        1  12 CPART1
     I                                        1   5 EKMHN1
     I                                        6  10 EKMHN2
     I                                       11  15 EKMHN3
     I                                       16  20 EKMHN4
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           WORKER  6
     C                     PARM           WUSRID 10
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C           K#1L      KLIST
     C                     KFLD           NONY    40
     C                     KFLD           EKNOYY
     C                     KFLD           EKNOMM
     C                     KFLD           EKNODD
     C                     KFLD           EKNUKE
     C                     KFLD           EKODRN
     C                     KFLD           EKMHN1
     C                     KFLD           EKMHN2
     C                     KFLD           EKMHN3
      *
     C           K#44C     KLIST
     C                     KFLD           NONY
     C                     KFLD           SHID
     C                     KFLD           ORDN   15
     C                     KFLD           EKMHN1
     C                     KFLD           EKMHN2
     C                     KFLD           EKMHN3
     C                     KFLD           EKMHN4
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     MOVELWORKER    USRCD   6
     C                     CLEARDSP01
      *
      *   DUMMY READ
     C                     READ ALDWP27             N    77
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C                     WRITEDSP01
     C                     READ ALDPW27                7171
      *
      **********           EXFMTDSP01
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     3199
      *
     C           *IN71     IFEQ '1'
     C           @STTS     ANDEQ1331
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB200
     C                     ENDIF
      *
     C                     TIME           WTIME
     C           *INKC     IFEQ *ON
     C                     MOVEL'99'      DSPSW   2
     C                     GOTO ESB200
     C                     ENDIF
      *
     C                     EXSR #CHK01
      *
     C           *IN99     IFEQ *OFF
     C                     EXSR #SB500
     C                     ADD  1         D1SHRT
     C                     ELSE
     C                     EXSR #SB999
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
     C                     ENDIF
      *
     C                     CLEARD1BARC
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *瀗疢�⒳�痧�　　　　　　　　　　　　　　　　　　�
      *----------------------------------------------------*
     CSR         #CHK01    BEGSR
      *
     C                     Z-ADD*ZERO     ORDQTY
      *
      * check barcode...
     C           D1BARC    IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVELER,1      MSG
     C                     GOTO ECHK01
     C                     ENDIF
      *
      * check label file...
     C           D1BARC    CHAINAB#PL71             N50
      *
     C                     SELEC
     C           *IN50     WHEQ *ON
     C                     SETON                     3199
     C                     MOVELER,3      MSG
     C                     GOTO ECHK01
     C           *IN50     WHEQ *OFF
     C           EKSKJY    ANDEQ'D'
     C           EKKOME    ANDEQ'SHORT'
     C                     SETON                     3199
     C                     MOVELER,2      MSG
     C                     GOTO ECHK01
     C           *IN50     WHEQ *OFF
     C           EKSKJY    ANDEQ'D'
     C           EKKOME    ANDNE'SHORT'
     C                     SETON                     3199
     C                     MOVELER,3      MSG
     C                     GOTO ECHK01
     C                     ENDSL
      *
     C                     MOVELEKSYOS    QPC     50
      * check order file...
     C                     EXSR GETQTY
     C           ORDQTY    IFEQ *ZERO
     C                     SETON                     3199
     C                     MOVELER,4      MSG
     C                     ENDIF
      *
     CSR         ECHK01    ENDSR
      *----------------------------------------------------*
      * Display Error Message                              *
      *----------------------------------------------------*
     CSR         #SB999    BEGSR
      *
     C                     MOVELMSG       P1ERR
     C                     CALL 'AM#R08'
     C                     PARM           P1ERR  25
      *
     CSR         ESB999    ENDSR
      *----------------------------------------------------*
      * End the Program                                    *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * Write to Shortage Workfile - ALDWP27               *
      *----------------------------------------------------*
     C           #SB500    BEGSR
      *
     C                     CLEARALDWP271
     C                     MOVELWORKER    W1KOME
     C                     MOVELW#PGM     W1KPGM
     C                     Z-ADDSDATE     W1SSHZ
     C                     Z-ADDSTIME     W1SSTI
      *
     C                     MOVELEKSERL    W1SERL
     C                     MOVELSHID      W1SHID
     C                     MOVELEKDETM    W1SHIT
     C                     MOVELEKNONY    W1NONY
     C                     MOVELEKNUKE    W1NUKE
     C                     MOVELEKODRN    W1ORD#
     C                     MOVELCPART     W1MHN
     C                     MOVELIPART     W1SHN
     C                     MOVELEKSYOS    W1QPC
     C                     MOVELEKNOBN    W1NOBN
     C                     EXSR GETQTY
     C                     MOVELBAHPOS    W1HPOS
     C                     MOVELBALIN#    W1LIN#
     C                     MOVELBALIN#    W1LINE
     C                     Z-ADDBAIAF#    W1IAF#
     C                     EXSR GETLIN
     C                     EXSR GETRDA
     C                     WRITEALDWP271
      *
     C                     EXSR #SB525
      *
     C                     ENDSR
      *----------------------------------------------------*
      * Call Pgm to Update Order Files - Adjust Quantity.  *
      *----------------------------------------------------*
     C           #SB525    BEGSR
      *
     C           D1BARC    CHAINAB#PL71              50
     C           *IN50     IFEQ *OFF
     C                     MOVEL'D'       EKSKJY
     C                     MOVEL'SHORT'   EKKOME
     C                     Z-ADDSDYY      EKSKYY
     C                     Z-ADDSDMM      EKSKMM
     C                     Z-ADDSDDD      EKSKDD
     C                     Z-ADDSDYY      EKKOYY
     C                     Z-ADDSDMM      EKKOMM
     C                     Z-ADDSDDD      EKKODD
     C                     Z-ADDSTHH      EKKOHH
     C                     Z-ADDSTMM      EKKOMN
     C                     UPDATAB#PP701
     C                     ENDIF
      *
     C                     Z-ADDBAODER    QTYORD  50
     C                     MOVELEKNONY    NONY#   40
      *
     C                     CALL 'ALDC27H'
     C                     PARM           CPART1
     C                     PARM           NONY#
     C                     PARM           SHID
     C                     PARM           EKODRN
     C                     PARM           EKNUKE
     C                     PARM           QTYORD
     C                     PARM           WORKER
      *
     C                     ENDSR
      *----------------------------------------------------*
      * Get Ordered Qty from the Order File.               *
      *----------------------------------------------------*
     C           GETQTY    BEGSR
      *
     C                     MOVELEKNONY    NONY
      *
     C           K#1L      SETLLAB#PL1L
      *
     C                     DO   *HIVAL
     C           K#1L      READEAB#PL1L                  50
      *
     C           *IN50     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C           BASKJY    IFNE *BLANK
     C           BAODRN    ORNE EKODRN
     C           BANUKE    ORNE EKNUKE
     C           BAUSYS    ORNE QPC
     C                     ITER
     C                     ENDIF
      *
      * ordered qty...
     C                     Z-ADDBAODER    W1ODER
     C                     Z-ADDBAODER    ORDQTY  50
      *
     C                     LEAVE
      *
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      * Get Orignial PO Line Number from EDI file.         *
      *----------------------------------------------------*
     C           GETLIN    BEGSR
      *
     C           W1LINE    IFEQ *BLANKS
      *
     C                     MOVELEKNONY    NONY
     C                     MOVELEKODRN    ORDN
      *
     C           K#44C     SETLLAB#PL44C
      *
     C                     DO   *HIVAL
     C           K#44C     READEAB#PL44C                 50
      *
     C           *IN50     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C           DANUKE    IFNE EKNUKE
     C                     ITER
     C                     ENDIF
      *
      * line number...
     C                     MOVELDALINE    W1LINE
     C                     MOVELDALINE    W1LIN#
      *
     C                     LEAVE
      *
     C                     ENDDO
      *
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
     C           GETRDA    BEGSR
      *
     C                     MOVELSHID      SHPDAT
     C                     MOVE *BLANKS   RDADAT
      *
     C                     CALL 'UTLR10'
     C                     PARM           SHPDAT  8
     C                     PARM '+'       SIGN    1
     C                     PARM '0115'    DAYS    4
     C                     PARM 'Y'       IAFNO   1
     C                     PARM           RDADAT  8
     C                     PARM           RTN     1
      *
     C                     MOVELRDADAT    W1RDA
      *
     C                     ENDSR
      *----------------------------------------------------*
**
SCAN SERIAL BARCODE.
NO LABEL DATA.
ALREADY SHORTED.
NO ORDER DATA.
