     C           KEY1      KLIST
     C                     KFLD           WCPNY
      *
     C           KEY2      KLIST
     C                     KFLD           IINOU
     C                     KFLD           IIKJCD
     C                     KFLD           IIUKCD
      *
     C                     TIME           WTIME
     C                     SETOF                     50
     C           KEY2      CHAINEHAPL10              50
     C           *IN50     IFEQ '1'
     C                     GOTO ICEAGE
     C                     ENDIF
      *
     C           E#SKJY    IFEQ 'D'
     C           E#SKHZ    ANDLEWUDAT
     C                     GOTO ICEAGE
     C                     ENDIF
     C                     MOVE E#CPNY    WCPNY   1
      *
     C                     SETOF                     60
     C           KEY1      CHAINEAEPL86              60
     C           *IN60     IFEQ '1'
     C                     GOTO ICEAGE
     C                     ENDIF
      *
     C           EASKJY    IFEQ 'D'
     C           EASKHZ    ANDLE*DATE
     C                     GOTO ICEAGE
     C                     ENDIF
      *
     C                     MOVE *BLANK    EEHAKK           発行済ﾎ[hﾞ
     C                     Z-ADD0         EEHAYY           発行日年
     C                     Z-ADD0         EEHAMM           発行日月
     C                     Z-ADD0         EEHADD           発行日日
      *
     C                     Z-ADDIINOU     EENONY           納入先
     C                     MOVELIIKJCD    EENKOJ           工場
     C                     MOVELIIUKCD    EENUKE           受入
     C                     MOVELIIUSHN    EEUHIN           ユーザー品番
     C                     Z-ADDIINOYY    EENOYY           納入日（年）
     C                     Z-ADDIINOMM    EENOMM           納入日（月）
     C                     Z-ADDIINODD    EENODD           納入日（日）
     C                     Z-ADDIINOSU    EESRYO           納入数
     C                     MOVELIINOBN    EENOBN           納品書番号
     C                     Z-ADDIITKCD    EETOKU           得意先
     C                     Z-ADDIIHAKO    EEHAKO           箱数
     C           IIAMRI    IFNE 0
     C           EEHAKO    ADD  1         EEHAKO           箱数
     C                     END
     C                     WRITEEAEPP891
      *
     C           ICEAGE    TAG
