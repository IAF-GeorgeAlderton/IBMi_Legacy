     H            Y.
     F** NBBR02 ****************************
     F* .. IAF PRODUCT DEMAND FORECAST PART NO LIST || *.
     F* I-HASADA 88.03.23 *
     F**************************** NBBR02 **
     FNBBTL02 IP  E           K        DISK
     FNBBPL11 IF  E           K        DISK
     FNBBPR02 O   E             90     PRINTER
     E                    HIZ         6  2 0             日付
     E                    HKI         2  1               機械的性質
     E                    HTU         2  1               通称サイズ
     E                    HKU         3  1               首下長さ
     E                    CKI         3  1               機械的性質ﾒﾇn
     E                    CTU         2  1               通称サイズﾒﾇn
     E                    CKU         3  1               首下長さﾒﾇn
     E                    WSU         6  8 0             内示数
     E                    WKS         6  7 1             重量
     INBBTL021    01
     I                                              NBKIKIL1
     I                                              NBTUSZL1
     I                                              NBKUBIL1
     I            DS
     I                                        1  120HIZ
     I                                        1   20WM1
     I                                        3   40WM2
     I                                        5   60WM3
     I                                        7   80WM4
     I                                        9  100WM5
     I                                       11  120WM6
     I            DS
     I                                        1  480WSU
     I                                        1   80WSU1
     I                                        9  160WSU2
     I                                       17  240WSU3
     I                                       25  320WSU4
     I                                       33  400WSU5
     I                                       41  480WSU6
     I            DS
     I                                        1  421WKS
     I                                        1   71WKS1
     I                                        8  141WKS2
     I                                       15  211WKS3
     I                                       22  281WKS4
     I                                       29  351WKS5
     I                                       36  421WKS6
     I            DS
     I                                        1   60WYM
     I                                        1   40WYY
     I                                        5   60WMM
     I            DS
     I                                        1   3 WTUSZ
     I                                        1   1 WTUS1
     I                                        2   3 WTUS2
     I            DS
     I                                        1   5 WKUBI
     I                                        1   2 WKUB1
     I                                        3   5 WKUB2
     C           KEY       KLIST
     C                     KFLD           NBSHN1
     C                     KFLD           NBSHN2
     C                     KFLD           NBSHN3
     C                     KFLD           IYM
      *
     C                     SETOF                     50
     C           *IN02     IFEQ '0'
     C                     SETON                     0250
     C           *ENTRY    PLIST
     C                     PARM           PYM     6
     C                     MOVE PYM       IYM     60
     C                     Z-ADDIYM       WYM
     C                     Z-ADD0         HIZ
      *
     C*------------------*
     C*   ..後日付..   *
     C*------------------*
     C                     MOVE WMM       HIZ,1
     C                     Z-ADD1         A       10
     C           2         DO   6         A
     C           WMM       IFEQ 12
     C                     Z-ADD01        WMM
     C                     ELSE
     C                     ADD  1         WMM
     C                     END
     C                     Z-ADDWMM       HIZ,A
     C                     END
      *
     C* ----見出し----
     C                     WRITENBBPR021
     C                     END
      *
     C           *INL1     IFEQ '1'
     C                     SETON                     50
     C                     Z-ADD0         TSU1
     C                     Z-ADD0         TSU2
     C                     Z-ADD0         TSU3
     C                     Z-ADD0         TSU4
     C                     Z-ADD0         TSU5
     C                     Z-ADD0         TSU6
      *
     C                     Z-ADD0         TKS1
     C                     Z-ADD0         TKS2
     C                     Z-ADD0         TKS3
     C                     Z-ADD0         TKS4
     C                     Z-ADD0         TKS5
     C                     Z-ADD0         TKS6
      *
     C                     MOVE *BLANK    CKI
     C                     MOVE *BLANK    CTU
     C                     MOVE *BLANK    CKU
      *
     C                     MOVE NBTUSZ    CTUSZ   2
     C                     MOVE NBKUBI    CKUBI   3
     C                     MOVEANBKIKI    HKI
     C                     MOVEACTUSZ     HTU
     C                     MOVEACKUBI     HKU
      *
     C*----------------------*
     C*   ..機械的性質..   *
     C*----------------------*
     C                     SETOF                     03
     C                     Z-ADD1         A
     C           1         DO   2         A
     C           HKI,A     IFEQ '0'
     C                     MOVE *BLANK    HKI,A
     C                     ELSE
     C                     SETON                     03
     C                     END
     C  N03                END
      *
     C*----------------------*
     C*   ..通称サイズ..   *
     C*----------------------*
     C                     SETOF                     03
     C                     Z-ADD1         A
     C           1         DO   2         A
     C           HTU,A     IFEQ '0'
     C                     MOVE *BLANK    HTU,A
     C                     ELSE
     C                     SETON                     03
     C                     END
     C  N03                END
      *
     C*--------------------*
     C*   ..首下長さ..   *
     C*--------------------*
     C                     SETOF                     03
     C                     Z-ADD1         A
     C           1         DO   3         A
     C           HKU,A     IFEQ '0'
     C                     MOVE *BLANK    HKU,A
     C                     ELSE
     C                     SETON                     03
     C                     END
     C  N03                END
      *
     C*----------------------*
     C*   ..機械的性質..   *
     C*----------------------*
     C                     Z-ADD1         A
     C                     Z-ADD0         B       10
     C           1         DO   2         A
     C           HKI,A     IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE HKI,A     CKI,B
     C                     END
     C                     END
     C                     SETOF                     03
     C                     Z-ADD1         A
     C           1         DO   3         A
     C           CKI,A     IFEQ *BLANK
     C                     SETON                     03
     C                     MOVE 'T'       CKI,A
     C                     END
     C  N03                END
     C                     MOVEACKI       WKIKI
      *
     C*----------------------*
     C*   ..通称サイズ..   *
     C*----------------------*
     C                     Z-ADD1         A
     C                     Z-ADD0         B
     C           1         DO   2         A
     C           HTU,A     IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE HTU,A     CTU,B
     C                     END
     C                     END
     C                     MOVE 'M'       WTUS1
     C                     MOVEACTU       WTUS2
      *
     C*--------------------*
     C*   ..首下長さ..   *
     C*--------------------*
     C                     Z-ADD1         A
     C                     Z-ADD0         B
     C           1         DO   3         A
     C           HKU,A     IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE HKU,A     CKU,B
     C                     END
     C                     END
     C                     MOVE 'L='      WKUB1
     C                     MOVEACKU       WKUB2
     C                     END
      *
     C* ----見出し----
     C   90                SETON                     50
     C   90                WRITENBBPR021
     C                     SETOF                     90
      *
     C                     SETOF                     03
     C           KEY       CHAINNBBPL111             03
     C           *IN03     IFEQ '0'
      *
     C*----------------------*
     C*   ..明細内示数..   *
     C*----------------------*
     C                     Z-ADDNCSRY1    WSU1
     C                     Z-ADDNCSRY2    WSU2
     C                     Z-ADDNCSRY3    WSU3
     C                     Z-ADDNCSRY4    WSU4
     C                     Z-ADDNCSRY5    WSU5
     C                     Z-ADDNCSRY6    WSU6
      *
     C*--------------------*
     C*   ..明細重量..   *
     C*--------------------*
     C                     Z-ADD1         A
     C           1         DO   6         A
     C           WSU,A     MULT NBSOZI    WSRY1  132
     C           WSRY1     DIV  1000      WKS,A
     C                     MVR            WSRY2   71
     C           WSRY2     IFNE 0
     C                     ADD  0.1       WKS,A
     C                     END
     C                     END
      *
     C*----------------------*
     C*   ..合計内示数..   *
     C*----------------------*
     C                     ADD  WSU1      TSU1
     C                     ADD  WSU2      TSU2
     C                     ADD  WSU3      TSU3
     C                     ADD  WSU4      TSU4
     C                     ADD  WSU5      TSU5
     C                     ADD  WSU6      TSU6
      *
     C*--------------------*
     C*   ..合計重量..   *
     C*--------------------*
     C                     ADD  WKS1      TKS1
     C                     ADD  WKS2      TKS2
     C                     ADD  WKS3      TKS3
     C                     ADD  WKS4      TKS4
     C                     ADD  WKS5      TKS5
     C                     ADD  WKS6      TKS6
      *
     C*----------------------*
     C*   ..総合計重量..   *
     C*----------------------*
     C                     ADD  WKS1      XKS1
     C                     ADD  WKS2      XKS2
     C                     ADD  WKS3      XKS3
     C                     ADD  WKS4      XKS4
     C                     ADD  WKS5      XKS5
     C                     ADD  WKS6      XKS6
      *
     C* ----明細----
     C                     WRITENBBPR022
     C                     END
      *
     C* ----合計----
     CL1                   WRITENBBPR023
     C* ----総合計----
     CLR                   WRITENBBPR024
