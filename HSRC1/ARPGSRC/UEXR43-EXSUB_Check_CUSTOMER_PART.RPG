     H            Y.
      ** UEXR43 ****************************************************
      *  CHECK CUSTOMER PART                                       *
      *  JW     2021.05.24                                         *
      **************************************************************
      *  CALLING SEQ.                                              *
     C*                    CALL 'UEXR43 '
     C*                    PARM           $MHIN  20
     C*                    PARM           $RTN    1
     F*   IN  $MHIN  20A  CUSTOMER PART                            *
     F*   OUT $RTN    1A  RETURN FLAG (BLANK=OK,                   *
     F*                   Y = POSSIBLE                             *
     F*                   N = CUSTOMER PART INPOSSIBLE             *
      **************************************************************
     FAB#PL0U IF  E           K        DISK
     FFAAPL05 IF  E           K        DISK
      ***********************************************************
     I            DS
     I                                        1  20 KMHIN
     I                                        1   5 KMHN1
     I                                        6  10 KMHN2
     I                                       11  15 KMHN3
     I                                       16  20 KMHN4
      ****************************************************
      * MAIN ROUTINE
      ****************************************************
     C                     EXSR #INIT
      * CHECK BY SALES
     C                     EXSR #CHK1
      * CHECK BY COMMON
     C           OKFLG     IFEQ 'N'
     C                     EXSR #CHK2
     C                     ENDIF
      *
     C                     MOVELOKFLG     $RTN
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ****************************************************
      * CHECK BY SALES
      ****************************************************
     C           #CHK1     BEGSR
      *
     C           K#PL0U    KLIST
     C                     KFLD           KMHN1
     C                     KFLD           KMHN2
     C                     KFLD           KMHN3
     C                     KFLD           KMHN4
      *
     C                     MOVEL$MHIN     KMHIN
     C           K#PL0U    SETLLAB#PL0U
     C                     DO   *HIVAL
     C           K#PL0U    READEAB#PL0U                  98
     C   98                LEAVE
      *
     C           B1SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE 'Y'       OKFLG
     C                     LEAVE
     C                     ENDDO
      *
     C                     ENDSR
      ****************************************************
      * CHECK BY COMMON MASTER
      ****************************************************
     C           #CHK2     BEGSR
      *
     C                     MOVEL$MHIN     KMHIN
     C           K#PL0U    SETLLFAAPL05
     C                     DO   *HIVAL
     C           K#PL0U    READEFAAPL05                  98
     C   98                LEAVE
      *
     C           B7SKBN    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE 'Y'       OKFLG
     C                     LEAVE
     C                     ENDDO
      *
     C                     ENDSR
      ****************************************************
      * INITIALIZE
      ****************************************************
     C           #INIT     BEGSR
     C*
     C           *ENTRY    PLIST
     C                     PARM           $MHIN  20        IN
     C                     PARM           $RTN    1        OUT
      *
     C                     MOVE 'N'       OKFLG   1
      *
     C                     ENDSR
