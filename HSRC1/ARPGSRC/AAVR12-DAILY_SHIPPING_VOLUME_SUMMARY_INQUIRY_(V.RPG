     C                     MOVEL$SIZE     A2SIZ
     C           A2SRT     IFEQ '9'
     C                     MOVEL'OTHER'   A2SIZ     P
     C                     ENDIF
      *********************Z-ADD$DSVB     A2BOX
      *********************Z-ADD$DSVQ     A2QTY
JW3  C                     Z-ADD$DSVB2    A2BOX
JW3  C                     Z-ADD$DSVQ2    A2QTY
      *
     C                     MOVELM6SHIN    A2SHIN
     C                     MOVEL$ZETI     A2ZETI
     C                     MOVEL$LLOC     LOC6
     C                     MOVELLOC1      XLOC1
     C                     MOVELLOC2      XLOC2
     C                     MOVELLOC3      XLOC3
     C                     MOVELLOC4      XLOC4
     C                     MOVELXLOC      A2LLOC
     C                     MOVEL$FPRC     A2FPRC
     C                     MOVEL$FMCN     A2FMCN
     C                     MOVEL$PRC      A2PRC
     C                     MOVEL$MCN      A2MCN
     C*********************Z-ADD$MSET     A2MSET
JW3  C                     Z-ADD$MSET2    A2MSET
     C                     Z-ADD$QPC      A2QPC
     C                     MOVELPFLG      A2FLG1
     C                     MOVEL'1'       A2PRC#
