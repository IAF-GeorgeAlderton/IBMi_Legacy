     C                     MOVE TARKHK    WHAKO   40
     C                     MOVE TARHSU    WHASU   50
     C                     MOVE TASURY    WSURYO  70
     C                     Z-ADDTATANK    WTANK   73
     C                     Z-ADDTASHIR    WSHIR   40
     C                     EXCPTDAT
     C                     MOVE '1'       MIT     1
     C                     END
     C*
     C                     SETOF                     59
