     I                                        6   8 WKTHNO
     I                                        9   9 WKUN2
     I                                       10  10 WKKAIS
     I                                        1  10 WSNO
     C**********************
     C*   KLIST の作成   *
     C**********************
     C           #KEY1     KLIST
     C                     KFLD           #HB1    4
  K.YC                     KFLD           #HB2    3
     C                     KFLD           #HB3    10
     C           #KEY2     KLIST
     C                     KFLD           #KAKO   40
     C                     KFLD           #HIN1   5
     C                     KFLD           #HIN2   5
     C                     KFLD           #HIN3   2
     C*
     C           *ENTRY    PLIST
     C                     PARM           PARM1   8
     C                     PARM           @SHAKO  1
     C                     PARM           MIT     1
     C                     MOVE PARM1     @SHIME  80
     C                     Z-ADD@SHIME    WSHIME  80
     C           *IN81     DOWEQ'0'
     C                     READ ATAWP601                 81
     C           *IN81     CABEQ'1'       LAST
     C**********************
     C*見出し処理        *
     C**********************
     C                     SETOF                     111213
     C           TASHIR    IFNE WKSHIR
     C           WKHINB    IFNE *BLANK
     C           TAHINB    IFNE WKHINB
     C                     ADD  2         LCTR    30
     C                     WRITEATAPR613
     C                     MOVE *ZERO     @GOKEI
     C                     END
     C                     END
     C           *IN35     IFEQ '1'
     C                     WRITEATAPR614
     C                     MOVE *ZERO     @SOKEI
     C                     MOVE *ZERO     @GOKEI
     C                     END
     C                     MOVE TASHIR    @SCODE
     C                     MOVE TASHIR    #WKEY   40
     C           #WKEY     CHAINFGBPL01              55
     C           *IN55     IFEQ '0'
     C                     MOVELB2SMEI    @SINAM
     C                     ELSE
     C                     MOVE *BLANK    @SINAM
     C                     END
     C                     MOVE WYEAR     @NEN
     C                     MOVE WMONTH    @TUKI
     C                     MOVE WDAY      @HI
     C                     ADD  1         @PAGE
     C                     MOVE *ZERO     LCTR    30
     C                     WRITEATAPR611
     C                     END
     C           TASHIR    IFEQ WKSHIR
     C           WKHINB    IFNE *BLANK
     C           TAHINB    IFNE WKHINB
     C                     ADD  2         LCTR    30
     C                     WRITEATAPR613
     C   39                SETOF                         39
     C                     MOVE *ZERO     @GOKEI
     C                     END
     C                     END
     C                     END
     **
     C           LCTR      IFGE 51
     C                     ADD  1         @PAGE
     C                     WRITEATAPR611
     C                     MOVE *ZERO     LCTR
     C                     END
     C**********************
     C*明細表処理        *
     C**********************
     C                     ADD  1         LCTR
     **
     C                     MOVE TAZENO    #HB1
     C                     MOVE TATHNO    #HB2
     C                     MOVE TABKAS    #HB3
     C           #KEY1     CHAINAS#PL121             31
     C           *IN31     IFEQ '0'
     C                     MOVE WYEAR     CUKIYY
     C                     MOVE WMONTH    CUKIMM
     C                     MOVE WDAY      CUKIDD
     C           @SHAKO    IFNE 'G'
     C                     EXCPTCHG
     C                     END
     C           CUFBMN    IFEQ *ZERO
     C           TASURY    IFLT TAHOSO
     C           TATANK    MULT TAHOSO    @KING
     C                     MOVE TAHOSO    @BIKO
     C                     SETON                       11
     C                     ELSE
     C           TATANK    MULT TASURY    @KING
     C                     END
     C                     END
     C           CUFBMN    IFNE *ZERO
     C                     MOVE *ZERO     @KING
     C           CUFBMN    IFEQ CUKAKO
     C                     SETON                       12
     C                     SETOF                       11
     C           TASURY    ADD  CUFSRY    WKFSY   70
     C           WKFSY     IFLT TAHOSO
     C                     SETON                       11
     C           TAHOSO    MULT TATANK    @KING
     C                     ELSE
     C           TASURY    MULT TATANK    @KING
     C                     END
     C                     ELSE
     C                     MOVE *ZERO     WKFSY
     C           TASURY    ADD  CUFSRY    WKFSY
     C           WKFSY     IFLT TAHOSO
     C                     SETON                       11
     C           TAHOSO    MULT TATANK    @KING
     C                     ELSE
     C                     SETON                       13
     C                     MOVE CUFSRY    @FRY
     C           WKFSY     MULT TATANK    @KING
     C                     END
     C                     END
     C                     END
     C                     END
     C                     MOVEA'1'       *IN,35
     C                     MOVE TAZENO    WKZENO
     C                     MOVE TATHNO    WKTHNO
     C                     MOVE '-'       WKUN1
     C           TABKAS    IFEQ *ZERO
     C                     MOVE *BLANK    WKUN2
     C                     MOVE *BLANK    WKKAIS
     C                     ELSE
     C                     MOVE '-'       WKUN2
     C                     MOVE TABKAS    WKKAIS
     C                     END
     C                     MOVE WSNO      @HYO1
     C                     MOVE TAKNHZ    @KEN
     C                     MOVE TAHIN1    @HIN1
     C                     MOVE TAHIN2    @HIN2
     C                     MOVE TAHIN3    @HIN3
     C                     MOVE TAHSYR    @SYORI
     C                     MOVE TASYUY    @SYUYO
     C                     MOVE TARKHK    @HAKO
     C                     MOVE TARHSU    @HASU
     C                     MOVE TASURY    @SURYO
     C                     Z-ADDTATANK    @TANK
     C           @HIN3     COMP *BLANK                   10
     C                     MOVE TASHIR    #KAKO   40
     C                     MOVE TAHIN1    #HIN1
     C                     MOVE TAHIN2    #HIN2
     C                     MOVE TAHIN3    #HIN3
     C           #KEY2     CHAINAASPL111             59
     C*
     C                     WRITEATAPR612
