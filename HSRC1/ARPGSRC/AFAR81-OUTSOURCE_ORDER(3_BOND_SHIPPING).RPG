     C           *INKD     ANDEQ*OFF
     C           *INKE     ANDEQ*OFF
     C                     TIME           WTMDT
     C                     Z-ADD20000000  W1KSDT
     C                     ADD  WYMD      W1KSDT
     C                     Z-ADDWHMS      W1KSTM
     C                     MOVELPUSR      W1USER
