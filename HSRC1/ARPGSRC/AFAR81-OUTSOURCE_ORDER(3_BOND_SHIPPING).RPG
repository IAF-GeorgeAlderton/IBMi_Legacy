      * CHECK DIVISION TO MAKE SURE THIS IS A 3 BOND PART
      *
     C           @DIVCH    BEGSR
      *
     C                     MOVE *BLANK    @KK
     C           KEY1      CHAINAAMPL11              91
      *
     C           1         DO   15        X       30
     C                     MOVELCHG,X     @CHG
     C           @CHGDT    IFGT *DATE
     C                     MOVELKX,X      @K#,X            KANBAN
     C                     Z-ADDDEX,X     @DEP,X           DEPARTMENT
     C                     ELSE
     C                     MOVELKK,X      @K#,X            KANBAN
     C                     Z-ADDDP,X      @DEP,X           DEPARTMENT
     C                     END
     C                     ENDDO
     C           1         DO   15        X       30
     C           @DEP,X    IFEQ W#ATOB
     C           @K#,X     IFNE *BLANK
     C                     MOVE @K#,X     @KK     1
     C                     LEAVE
     C                     ELSE
     C                     MOVE 'E'       @KK
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
