     H            Y.
     F******************************************************
     F*日付の入力                                        *
     F*             T.SAKASHITA         2018.07.18         *
     F******************************************************
     FINPPW02 CF  E                    WORKSTN
      *
     E                    ER      1  10 60
      *
     C           *ENTRY    PLIST
     C                     PARM           P@TITL 40
     C                     PARM           P@TEX1 50
     C                     PARM           P@TEX2 50
     C                     PARM           P@TEX3 50
     C                     PARM           P@TEX4 50
     C                     PARM           P@TEX5 50
     C                     PARM           P@TEX6 50
     C                     PARM           P@DATE  80
     C                     PARM           P@RTN   2
      *
     C                     MOVE *BLANK    P@RTN
      *
     C                     MOVELP@TITL    TITL
     C                     MOVELP@TEX1    TEXT1
     C                     MOVELP@TEX2    TEXT2
     C                     MOVELP@TEX3    TEXT3
     C                     MOVELP@TEX4    TEXT4
     C                     MOVELP@TEX5    TEXT5
     C                     MOVELP@TEX6    TEXT6
     C                     Z-ADDP@DATE    DATE
      *
     C           @DSP01    TAG
      *
     C                     EXFMTINPPW021
     C                     SETOF                     1199
     C                     MOVEL*BLANK    MSG
      *
     C           *IN01     IFEQ '1'
     C                     MOVE '01'      P@RTN
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           DATE      IFLE 0
     C                     MOVELER,1      MSG
     C                     SETON                     1199
     C                     GOTO @DSP01
     C                     END
      *
     C                     MOVE DATE      P#DATE
     C                     MOVEL'1'       P#MOD
     C                     MOVEL*BLANK    P#RTN
     C                     CALL 'DATR11'
     C                     PARM           P#DATE  8
     C                     PARM           P#MOD   1
     C                     PARM           P#RTN   1
      * ERROR
     C           P#RTN     IFNE '0'
     C                     MOVELER,1      MSG
     C                     SETON                     1199
     C                     GOTO @DSP01
     C                     END
      *
     C                     Z-ADDDATE      P@DATE
      *
     C                     MOVE 'IN'      P@RTN
      *
     C                     SETON                     LR
     C                     RETRN
      *
** ER
E-01 INCORRECT DATE.
