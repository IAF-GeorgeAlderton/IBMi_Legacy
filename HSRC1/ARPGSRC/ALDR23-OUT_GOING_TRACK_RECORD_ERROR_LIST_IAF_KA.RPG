     C           *ENTRY    PLIST
     C                     PARM           PUS    10
      *
      *--------------------*
      *  ALDR23 EXECUSION  *
     C*--------------------*
     C           *IN80     IFEQ '0'
     C                     SETON                     80
     C                     MOVE PUS       US     10
     C                     TIME           WTIME  140
     C                     MOVE *BLANK    PUSNM  15
     C                     CALL 'APLR00'
     C                     PARM           US
     C                     PARM           PUSNM
     C                     MOVELPUSNM     TANNAM  8
     C                     WRITEALDPR201
     C                     Z-ADD0         CNT     50
     C                     GOTO JUMP
     C                     ENDIF
      *
     C           *IN95     IFEQ '1'
     C                     WRITEALDPR201
     C                     SETOF                     95
     C                     ENDIF
      *
     C           JUMP      TAG
     C                     MOVE SHN1      OSHN1
     C                     MOVE SHN2      OSHN2
     C                     MOVE SHN3      OSHN3
     C                     Z-ADDSYYY      OSYYY
     C                     Z-ADDSYMM      OSYMM
     C                     Z-ADDSYDD      OSYDD
     C                     Z-ADDSYJI      OSYJI
     C                     Z-ADDSYFN      OSYFN
