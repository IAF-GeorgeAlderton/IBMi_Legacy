     C                     MOVE MHN3      OMHN3
     C                     MOVE MHN4      OMHN4
     C                     Z-ADDNONY      ONONY
     C                     MOVE NKOJ      ONKOJ
     C                     MOVE NUKE      ONUKE
     C                     Z-ADDUSYS      OUSYS
     C                     SETOF                     30
     C                     MOVE *BLANK    OTYPE
     C           EFF       LOKUPTAB1      TAB2           30
     C   30                MOVELTAB2      OTYPE
     C                     SETOF                     30
     C                     MOVE *BLANK    OEROR
     C           EROR      LOKUPTAB3      TAB4           30
     C   30                MOVELTAB4      OEROR
     C                     WRITEALDPR202
     C           CNT       ADD  1         CNT
     CLR                   Z-ADDCNT       OCNT
     CLR                   WRITEALDPR203
