     H            Y.
     F** AJ#R77 *********************************************
     F* PRIORITY LIST(HD,RL,OQ,SURFACE TREATMENT)           *
     F*              ITS.        2015.05.13                 *
     F*******************************************************
     FAJ#WP76 IF  E           K        DISK
     FAJ#PR77 O   E             55     PRINTER
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTITM
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     C                     TIME           WTIME
      *
     C                     READ AJ#WP761                 80
     C                     EXSR #SB100
     C                     MOVELW3SECT    SVSECT  2
     C                     MOVEL*BLANK    SVBLK2  2
     C           *IN80     DOWEQ'0'
     C           *IN55     IFEQ '1'
     C           W3SECT    ORNE SVSECT
     C                     WRITEAJ#PR779
     C                     EXSR #SB100
     C                     MOVELW3SECT    SVSECT  2
     C                     ENDIF
     C                     EXSR #SB400
     C                     READ AJ#WP761                 80
     C                     ENDDO
      *
     C                     WRITEAJ#PR779
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVELW3SECT    P1SECT
     C                     MOVELWTIYY     P1DAYY
     C                     MOVELWTIMM     P1DAMM
     C                     MOVELWTIDD     P1DADD
     C                     MOVELTIMHH     P1TIHH
     C                     MOVELTIMMM     P1TIMM
     C                     MOVELTIMSS     P1TISS
     C                     MOVEL*ALL'-'   P1LIN
     C                     WRITEAJ#PR771
     C                     SETOF                     55
     C                     MOVEL*BLANK    SVBLK2  2
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C           W3BLK2    IFEQ SVBLK2
     C                     MOVEL*BLANK    P2BLK2
     C                     ELSE
     C                     MOVELW3BLK2    P2BLK2
     C                     MOVELW3BLK2    SVBLK2
     C                     ENDIF
     C                     MOVELW3TK01    P2TK01
     C                     MOVELW3TK02    P2TK02
     C                     MOVELW3TK03    P2TK03
     C                     MOVELW3TK04    P2TK04
     C                     MOVELW3TK05    P2TK05
     C                     MOVELW3TK06    P2TK06
     C                     MOVELW3TK07    P2TK07
     C                     MOVELW3TK08    P2TK08
     C                     MOVELW3TK09    P2TK09
     C                     MOVELW3TK10    P2TK10
     C                     WRITEAJ#PR772
     C                     MOVEL*ALL'-'   P8LIN
     C                     WRITEAJ#PR778
      *
     CSR         ESB400    ENDSR
