     C           *ENTRY    PLIST
     C                     PARM           US     10        ﾏｰﾅﾞｰ
     C                     PARM           PKOSN   1        ﾃcﾆ]hﾎﾞ]
     C                     PARM           PSHN1   5        ﾆｫob ﾍ]ﾌﾞ] 1
     C                     PARM           PSHN2   5                   2
     C                     PARM           PSHN3   2                   3
     C                     MOVE PSHN1     USHN1
     C                     MOVE PSHN2     USHN2
     C                     MOVE PSHN3     USHN3
      *
     C           ACAL1     PLIST
     C                     PARM           US
     C                     PARM           USHN1
     C                     PARM           USHN2
     C                     PARM           USHN3
      *
     C           ACAL2     PLIST
     C                     PARM           US
     C                     PARM           WKUBN
     C                     PARM           @SHN1
     C                     PARM           @SHN2
     C                     PARM           @SHN3
      *
     C           KEY1      KLIST
     C                     KFLD           PSHN1
     C                     KFLD           PSHN2
     C                     KFLD           PSHN3
      *
     C           PKOSN     IFEQ '0'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C                     SETOF                     01
     C           KEY1      CHAINAAMPL111             01
     C           *IN01     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C                     SETOF                     0102
     C                     Z-ADD1         A       20
     C           'ARS'     LOKUPNKTI,A                   01
     C           *IN01     IFEQ '1'
     C                     SETON                     02
     C           USHIN     IFEQ NSHN,A
     C                     CALL 'AAVR29'  ACAL1
     C                     END
     C                     END
      *
     C           *IN02     IFEQ '0'
     C                     SETOF                     01
     C                     Z-ADD1         A
     C           'ARS'     LOKUPOKTI,A                   01
     C           *IN01     IFEQ '1'
     C           USHIN     IFEQ OSHN,A
     C                     CALL 'AAVR38'  ACAL1
     C                     END
     C                     END
     C                     END
      *
     C                     MOVE *BLANK    WOHIN  12
     C                     MOVE *BLANK    WNHIN  12
      *
     C                     SETOF                     01
     C                     Z-ADD1         A
     C           'ARS'     LOKUPOKTI,A                   01
     C           *IN01     IFEQ '1'
     C                     MOVE OSHN,A    WOHIN
     C                     END
      *
     C                     SETOF                     01
     C                     Z-ADD1         A
     C           'ARS'     LOKUPNKTI,A                   01
     C           *IN01     IFEQ '1'
     C                     MOVE NSHN,A    WNHIN
     C                     END
      *
     C           WNHIN     IFNE *BLANK
     C           USHIN     IFEQ WNHIN
     C           WOHIN     IFNE WNHIN
     C                     MOVE '01'      WKUBN   2
     C                     MOVE WNHIN     @SHIN
     C                     CALL 'AAVR34'  ACAL2
     C                     ELSE
      *
     C                     MOVE '02'      WKUBN
     C                     MOVE WNHIN     @SHIN
     C                     CALL 'AAVR34'  ACAL2
     C                     END
     C                     END
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
