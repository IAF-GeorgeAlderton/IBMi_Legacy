     H            Y.
     F** UUUR01 *********************************************
     F*  CLEAR FORECAST SUMMARY (ABAWL10=ABAWP10)           *
     F*  J.WATANABE  2021.02.04                             *
     F*-----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UUUR01'
     F*                    PARM           $NONY   4
     F*                    PARM           $NKOJ   1
     F*                    PARM           $NUKE   4
     F*                    PARM           $MHN1   5
     F*                    PARM           $MHN2   5
     F*                    PARM           $MHN3   5
     F*                    PARM           $MHN4   5
     F*                    PARM           $DATE   6
     F*                    PARM           $QTY    9
     F*                    PARM           $RTN    1
     F*  IN  $NONY :  4A DELIVERY#
     F*      $NKOJ :  1A FACTORY
     F*      $NUKE :  4A DOCK
     F*      $MHN1 :  5S USER PART1
     F*      $MHN2 :  5A USER PART2
     F*      $MHN3 :  5S USER PART3
     F*      $MHN4 :  5A USER PART4
     F*      $DATE :  6A SCHEDULE DATE (YYYYMM)
     F*      $QTY  :  9A MONTHLY TOTAL
     F*  OUT $RTN  :  1A RETURN (*=ERROR, BLNAK=NO ERROR)
     F******************************************************
     FABAWL10 UF  E           K        DISK
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      *
     C           K#KEY     CHAINABAWL10              99
      *
     C           *IN99     IFEQ *OFF
     C           ABNNSU    ANDEQ@QTY
     C                     Z-ADD0         ABNNSU
     C                     Z-ADD0         ABNN01
     C                     Z-ADD0         ABNN02
     C                     Z-ADD0         ABNN03
     C                     Z-ADD0         ABNN04
     C                     Z-ADD0         ABNN05
     C                     Z-ADD0         ABNN06
     C                     Z-ADD0         ABNN07
     C                     Z-ADD0         ABNN08
     C                     Z-ADD0         ABNN09
     C                     Z-ADD0         ABNN10
     C                     Z-ADD0         ABNN11
     C                     Z-ADD0         ABNN12
     C                     Z-ADD0         ABNN13
     C                     Z-ADD0         ABNN14
     C                     Z-ADD0         ABNN15
     C                     Z-ADD0         ABNN16
     C                     Z-ADD0         ABNN17
     C                     Z-ADD0         ABNN18
     C                     Z-ADD0         ABNN19
     C                     Z-ADD0         ABNN20
     C                     Z-ADD0         ABNN21
     C                     Z-ADD0         ABNN22
     C                     Z-ADD0         ABNN23
     C                     Z-ADD0         ABNN24
     C                     Z-ADD0         ABNN25
     C                     Z-ADD0         ABNN26
     C                     Z-ADD0         ABNN27
     C                     Z-ADD0         ABNN28
     C                     Z-ADD0         ABNN29
     C                     Z-ADD0         ABNN30
     C                     Z-ADD0         ABNN31
     C                     UPDATABAWP101
     C                     MOVE *BLANK    $RTN
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $MHN1   5
     C                     PARM           $MHN2   5
     C                     PARM           $MHN3   5
     C                     PARM           $MHN4   5
     C                     PARM           $DATE   6
     C                     PARM           $QTY    9
     C                     PARM           $RTN    1
      *
     C           K#KEY     KLIST
     C                     KFLD           KBNONY  40
     C                     KFLD           KBNKOJ  1
     C                     KFLD           KBNUKE  4
     C                     KFLD           KBMHN1  5
     C                     KFLD           KBMHN2  5
     C                     KFLD           KBMHN3  5
     C                     KFLD           KBMHN4  5
     C                     KFLD           KBDATE  60
      *
     C                     MOVE '*'       $RTN
     C                     MOVEL$NONY     KBNONY
     C                     MOVEL$NKOJ     KBNKOJ
     C                     MOVEL$NUKE     KBNUKE
     C                     MOVEL$MHN1     KBMHN1
     C                     MOVEL$MHN2     KBMHN2
     C                     MOVEL$MHN3     KBMHN3
     C                     MOVEL$MHN4     KBMHN4
     C                     MOVEL$DATE     KBDATE
     C                     MOVEL$QTY      @QTY    90
      *
     C                     ENDSR
