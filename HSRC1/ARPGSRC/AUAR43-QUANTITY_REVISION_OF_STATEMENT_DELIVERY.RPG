      * QUANTITY REVISION OF STATEMENT DELIVERY M/F AND CREATE OF SALES DATA *
      * PROGRAM ID.  : AUAR43. <RPG>                                         *
      * CREATE DATE. : 1997/MAR/22.                                          *
      * AUTHOR.      : S.OHTAKE.                                             *
      ************************************************************************
     FFCCPL11 UF  E           K        DISK
     FAB#WP10 O   E                    DISK                      A
     E                    XM          2  3 0             
     E                    XS          2  5 0             
     E                    XK          2  7 0             
     I            DS
     I                                        1   40UNONY
     I                                        5   5 UNKOJ
     I                                        6   9 UNUKE
     I                                       10  100UBIN
     I            DS
     I                                        1   80UNOBI
     I                                        1   40UYY
     I                                        5   60UMM
     I                                        7   80UDD
     I            DS
     I                                        1   80B4SKHZ
     I                                        1   40B4SKYY
     I                                        5   60B4SKMM
     I                                        7   80B4SKDD
     I            DS
     I                                        1   80B4GNHZ
     I                                        1   40B4GNYY
     I                                        5   60B4GNMM
     I                                        7   80B4GNDD
     I            DS
     I                                        1   80B4KNHZ
     I                                        1   40B4KNYY
     I                                        5   60B4KNMM
     I                                        7   80B4KNDD
     I            DS
     I                                        1   60XM
     I                                        1   30B4KNMI
     I                                        4   60B4GKMI
     I            DS
     I                                        1  140XK
     I                                        1   70B4KSRO
     I                                        8  140B4GSRO
     I            DS
     I                                        1  100XS
     I                                        1   50B4KINP
     I                                        6  100B4GINP
     I            DS
     I                                        1  20 B4UH
     I                                        1   5 B4MHN1
     I                                        6  10 B4MHN2
     I                                       11  15 B4MHN3
     I                                       16  20 B4MHN4
      *
     C           DCKEY     KLIST
     C                     KFLD           UMM
     C                     KFLD           WNONY
     C                     KFLD           WNKOJ
     C                     KFLD           WNUKE
     C                     KFLD           WSBAN
     C                     KFLD           WHN1
     C                     KFLD           WHN2
     C                     KFLD           WHN3
     C                     KFLD           WHN4
      *
     C           *ENTRY    PLIST
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNOBI   8
     C                     PARM           PBIN    1
     C                     PARM           SWITCH  8
     C                     PARM           PORD   10
      *
     C                     MOVE PNONY     UNONY
     C                     MOVE PNKOJ     UNKOJ
     C                     MOVE PNOBI     UNOBI
     C                     MOVE PBIN      UBIN
     C                     MOVE PORD      WORD   10
      *
     C                     Z-ADDUNONY     WNONY   40
     C                     MOVE UNKOJ     WNKOJ   1
     C                     MOVE *BLANK    WNUKE   4
     C                     MOVE *BLANK    WSBAN   4
     C                     MOVE *BLANK    WHN1    5
     C                     MOVE *BLANK    WHN2    5
     C                     MOVE *BLANK    WHN3    5
     C                     MOVE *BLANK    WHN4    5
      *
     C           DCKEY     SETLLFCCPL111
      *
     C           STEP01    TAG
     C                     SETOF                     01
     C                     READ FCCPL111                 01
      *
     C           *IN01     IFEQ '1'
     C                     GOTO END
     C                     END
      *
     C           UNONY     IFNE B4NONY
     C                     GOTO END
     C                     END
      *
     C           B4SKBN    IFEQ 'D'
     C           B4SKHZ    IFLE *DATE
     C                     GOTO STEP01
     C                     END
     C                     END
      *
     C           UBIN      DIV  2         WUBIN1  10
     C                     MVR            WUBIN2  20
      *
     C           WUBIN2    IFNE 0
     C           XM,1      IFEQ 0
     C                     GOTO STEP01
     C                     END
     C                     ELSE
      *
     C           XM,2      IFEQ 0
     C                     GOTO STEP01
     C                     END
     C                     END
      *
     C           WUBIN2    IFNE 0
     C                     Z-ADDUNOBI     B4KNHZ
     C                     Z-ADDUBIN      B4KBIN
     C                     ELSE
     C                     Z-ADDUNOBI     B4GNHZ
     C                     Z-ADDUBIN      B4GBIN
     C                     END
      *
     C                     ADD  1         B4KAIK
      *
     C           WUBIN2    IFNE 0
     C                     ADD  XK,1      B4RUIK
     C                     ELSE
     C                     ADD  XK,2      B4RUIK
     C                     END
      *
     C                     EXSR OUTSUB
      *
     C           WUBIN2    IFNE 0
     C                     MOVE *BLANK    B4KNBS
     C                     Z-ADD0         B4KNHZ
     C                     Z-ADD0         B4KBIN
     C                     Z-ADD0         B4KNMI
     C                     Z-ADD0         B4KINP
     C                     Z-ADD0         B4KSRO
     C                     Z-ADD0         B4KURS
     C                     ELSE
      *
     C                     MOVE *BLANK    B4GNBN
     C                     Z-ADD0         B4GNHZ
     C                     Z-ADD0         B4GBIN
     C                     Z-ADD0         B4GKMI
     C                     Z-ADD0         B4GINP
     C                     Z-ADD0         B4GSRO
     C                     Z-ADD0         B4GURS
     C                     END
      *
     C                     UPDATFCCPL111
      *
     C                     GOTO STEP01
      *
     C           END       TAG
     C                     SETON                     LR
     C                     RETRN
      *
      ******************************
      *  AB#WP10  OUTPUT ROUTINE   *
      ******************************
     C           OUTSUB    BEGSR
     C                     MOVE 'U'       W1USRI
     C                     MOVE 'K'       W1ODKE
     C                     MOVE *BLANK    W1TEIS
     C                     Z-ADDB4TOKU    W1TOKU
     C                     MOVE B4TKOJ    W1TKOJ
     C                     MOVE B4TUKE    W1TUKE
     C                     Z-ADDB4NONY    W1NONY
     C                     MOVE B4NKOJ    W1NKOJ
     C                     MOVE B4NUKE    W1NUKE
     C                     MOVE B4MHN1    W1UHN1
     C                     MOVE B4MHN2    W1UHN2
     C                     MOVE B4MHN3    W1UHN3
     C                     MOVE B4MHN4    W1UHN4
     C                     MOVE *BLANK    W1SHN1
     C                     MOVE *BLANK    W1SHN2
     C                     MOVE *BLANK    W1SHN3
     C                     MOVE B4KANR    W1KANR
     C                     MOVELWORD      W1ODNO
     C                     Z-ADD0         W1ODED
     C                     MOVE *BLANK    W1NOBN
     C                     MOVE 'C'       W1NOKB
     C                     Z-ADDUYY       W1NOYY
     C                     Z-ADDUMM       W1NOMM
     C                     Z-ADDUDD       W1NODD
     C                     Z-ADDUBIN      W1NOBI
     C                     MOVE *BLANK    W1SENO
     C                     Z-ADD0         W1TANK
     C                     MOVE *BLANK    W1TAKB
     C                     MOVE 'C'       W1SUTN
     C                     Z-ADD0         W1KING
     C                     Z-ADD0         W1JYRY
     C                     Z-ADD0         W1JYRM
     C                     Z-ADD0         W1JYRD
     C                     MOVE *BLANK    W1JKKB
     C                     MOVE *BLANK    W1KENS
     C                     Z-ADD0         W1SEIY
     C                     Z-ADD0         W1SEIM
     C                     Z-ADD0         W1SEID
     C                     Z-ADD0         W1SIMY
     C                     Z-ADD0         W1SIMM
     C                     Z-ADD0         W1SIMD
     C                     MOVE *BLANK    W1JUNJ
     C                     MOVE *BLANK    W1MACH
     C                     Z-ADD0         W1MACY
     C                     Z-ADD0         W1MACM
     C                     Z-ADD0         W1MACD
     C                     Z-ADD0         W1GETU
     C                     MOVE *BLANK    W1KURK
     C                     MOVE B4SBAN    W1SEBN
     C                     MOVE B4UH      W1UHIN
     C                     Z-ADD0         W1LTNO
     C                     Z-ADD0         W1PANO
     C                     MOVE *BLANK    W1MIKB
     C                     Z-ADD0         W1MIHK
     C                     Z-ADD0         W1MISU
     C                     MOVE *BLANK    W1STKB
     C                     Z-ADD0         W1RECN
     C                     Z-ADD*YEAR     W1URIY
     C                     Z-ADD*MONTH    W1URIM
     C                     Z-ADD*DAY      W1URID
     C                     MOVE *BLANK    W1TKKB
     C                     MOVE *BLANK    W1TUKA
     C                     Z-ADD0         W1RATE
     C                     MOVE *BLANK    W1BANK
     C                     MOVE *BLANK    W1KOZN
     C                     Z-ADD0         W1PAYY
     C                     Z-ADD0         W1PAYM
     C                     Z-ADD0         W1PAYD
     C                     Z-ADD0         W1PKIN
     C                     Z-ADD0         W1SAGK
     C                     MOVE 'S'       W1SYBT
     C                     MOVE '4'       W1SOBT
     C                     MOVE '04'      W1GYOM
      *
     C           WUBIN2    IFNE 0
     C                     Z-ADDXK,1      W1NOSU
     C                     Z-ADDXM,1      W1HAKO
     C                     Z-ADDXS,1      W1SYUY
     C                     ELSE
     C                     Z-ADDXK,2      W1NOSU
     C                     Z-ADDXM,2      W1HAKO
     C                     Z-ADDXS,2      W1SYUY
     C                     END
      *
     C                     WRITEAB#WP101
      *
     C                     ENDSR
