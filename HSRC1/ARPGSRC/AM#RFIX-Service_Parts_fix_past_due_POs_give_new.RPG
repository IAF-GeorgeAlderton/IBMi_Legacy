     H            Y.
     F** AM#RFIX  *******************************************
     F* SERVICE PARTS - ORDER FILE                          *
     F*******************************************************
     FAM#PP432IF  E           K        DISK
     FAB#PL1M IF  E           K        DISK
     FAB#PL44CIF  E           K        DISK
     FALDWP27 UF  E                    DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  140SDATE
     I                                        7  100SDYY
     I                                       11  120SDMM
     I                                       13  140SDDD
     I                                        1   60STIME
     I                                        1   20STHH
     I                                        3   40STMM
      *
     I            DS
     I                                        1   80SHID
     I                                        1   40NOYY
     I                                        5   60NOMM
     I                                        7   80NODD
      *
     I            DS
     I                                        1  10 M1ODDD
     I                                        1   4 M1YY
     I                                        5   5 DSH1
     I                                        6   7 M1MM
     I                                        8   8 DSH2
     I                                        9  10 M1DD
      *
     I            DS
     I                                        1   80DDD
     I                                        1   40DDDYY
     I                                        5   60DDDMM
     I                                        7   80DDDDD
      *
     I            DS
     I                                        1  12 IPART
     I                                        1   5 M1SHN1
     I                                        6  10 M1SHN2
     I                                       11  12 M1SHN3
      *
     I            DS
     I                                        1  20 CPART
     I                                        1   5 M1MHN1
     I                                        6  10 M1MHN2
     I                                       11  15 M1MHN3
     I                                       16  20 M1MHN4
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           NWSHID  8
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
      *
     C                     READ AM#PP432                 50
     C           *IN50     DOWEQ*OFF
      *
     C                     MOVELM1MHN     CPART
     C                     MOVELM1YY      DDDYY
     C                     MOVELM1MM      DDDMM
     C                     MOVELM1DD      DDDDD
      *
     C           DDD       IFGE SDATE
     C                     LEAVE
     C                     ENDIF
      *
     C                     EXSR WRTPO
     C                     EXSR WRTLIN
     C                     EXSR WRTWF
      *
     C                     READ AM#PP432                 50
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
      *
     C           NWSHID    IFNE *BLANKS
     C                     MOVELNWSHID    SHID
     C                     ELSE
     C                     EXSR GETRDA
     C                     ENDIF
      *
     C           K#1M      KLIST
     C                     KFLD           M1SHN1
     C                     KFLD           M1SHN2
     C                     KFLD           M1SHN3
     C                     KFLD           NONY    40
     C                     KFLD           DDDYY
     C                     KFLD           DDDMM
     C                     KFLD           DDDDD
      *
     C           K#44C     KLIST
     C                     KFLD           NONY
     C                     KFLD           DDD
     C                     KFLD           ORDN   15
     C                     KFLD           M1MHN1
     C                     KFLD           M1MHN2
     C                     KFLD           M1MHN3
     C                     KFLD           M1MHN4
      *
      *
      *   DUMMY READ
     C                     READ ALDWP27             N    77
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
     C           GETRDA    BEGSR
      *
     C                     MOVELSDATE     SHPDAT
     C                     MOVE *BLANKS   RDADAT
      *
     C                     CALL 'UTLR10'
     C                     PARM           SHPDAT  8
     C                     PARM '+'       SIGN    1
     C                     PARM '0030'    DAYS    4
     C                     PARM 'Y'       IAFNO   1
     C                     PARM           RDADAT  8
     C                     PARM           RTN     1
      *
     C                     MOVELRDADAT    SHID
      *
     C                     ENDSR
      *----------------------------------------------------*
      * Get Original PO line from Order File and Rewrite   *
      *
     C           WRTPO     BEGSR
      *
     C                     Z-ADD323       NONY
      *
     C           K#1M      SETLLAB#PL1M
      *
     C                     DO   *HIVAL
     C           K#1M      READEAB#PL1M                  50
      *
     C           *IN50     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C           BAODRN    IFNE M1ODRN
     C           BANUKE    ORNE M1HOME
     C                     ITER
     C                     ENDIF
      *
     C                     LEAVE
      *
     C                     ENDDO
      *
     C           *IN50     IFEQ *OFF
     C                     MOVE *BLANK    BASKJY
     C                     MOVEL'QFIXR'   BAKOME
     C                     Z-ADDM1UQTY    BAODER
     C                     Z-ADDM1UQTY    BASRYO
     C                     Z-ADDNOYY      BANOYY
     C                     Z-ADDNOMM      BANOMM
     C                     Z-ADDNODD      BANODD
     C                     Z-ADD*ZERO     BAURYY
     C                     Z-ADD*ZERO     BAURMM
     C                     Z-ADD*ZERO     BAURDD
     C                     Z-ADD*ZERO     BADEYY
     C                     Z-ADD*ZERO     BADEMM
     C                     Z-ADD*ZERO     BADEDD
     C                     WRITEAB#PL1M1
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      * Get Orig PO Line Number from EDI file and Rewrite  *
      *
     C           WTRLIN    BEGSR
      *
     C                     MOVELM1ODRN    ORDN
      *
     C           K#44C     SETLLAB#PL44C
      *
     C                     DO   *HIVAL
     C           K#44C     READEAB#PL44C                 50
      *
     C           *IN50     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C           DANUKE    IFNE M1HOME
     C                     ITER
     C                     ENDIF
      *
     C                     LEAVE
      *
     C                     ENDDO
      *
     C           *IN50     IFEQ *OFF
     C                     Z-ADDSDATE     DAKYMD
     C                     Z-ADDSTIME     DAKTIM
     C                     MOVEL'QFIXR'   DAKOME
     C                     Z-ADDSHID      DANYMD
     C                     WRITEAB#PP441
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      * Write to Shortage Workfile - ALDWP27               *
      *
     C           WRTWF     BEGSR
      *
     C                     CLEARALDWP291
     C                     MOVEL'QFIXR'   W1KOME
     C                     MOVELW#PGM     W1KPGM
     C                     Z-ADDSDATE     W1SSHZ
     C                     Z-ADDSTIME     W1SSTI
      *
     C                     MOVELDDD       W1SHID
     C                     MOVELSHID      W1RDA
     C                     MOVELNONY      W1NONY
     C                     MOVELM1NUKE    W1NUKE
     C                     MOVELM1ODRN    W1ORD#
     C                     MOVELCPART     W1MHN
     C                     MOVELM1UQTY    W1QPC
     C                     WRITEALDWP291
      *
     C                     ENDSR
      *----------------------------------------------------*
