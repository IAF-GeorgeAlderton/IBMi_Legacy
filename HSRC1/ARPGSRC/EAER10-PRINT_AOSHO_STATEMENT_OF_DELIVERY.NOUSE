      *     ﾌﾃﾇc  ﾌﾇc  ･  ibﾅ]  mﾞ  ynxﾓ    *
      *-------------------------------------*
     C                     Z-ADD0         WHASU   60
     C                     Z-ADD0         WHAKO   30
      *
     C           @@SYUY    IFEQ 0
     C                     Z-ADD0         WHAKO
     C                     GOTO STEPX
     C                     END
      *
     C           IINOSU    IFLT @@SYUY
     C                     Z-ADD1         WHAKO
     C                     ELSE
     C           IINOSU    DIV  @@SYUY    WHAKO
     C                     MVR            WHASU
     C           WHASU     IFNE 0
     C                     ADD  1         WHAKO
     C                     END
     C                     END
