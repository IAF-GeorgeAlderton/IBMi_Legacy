     H            Y.
     H** UEXR02 ********************************************
     H*  PROGRAM: EXSUB - SYNCHRONIZING AB#PPA1            *
     H*                                                    *
     H*  WRITTEN: JW (SRA)   2017.09.12                    *
     H*----------------------------------------------------*
      *  CALLING SEQ.
      *                    CALL 'UEXR02'
      *                    PARM           POPT    1
      *                    PARM           PANONY  40
      *                    PARM           PANKOJ  1
      *                    PARM           PANUKE  4
      *                    PARM           PANOHZ  80
      *                    PARM           PANOBN  20
      *                    PARM           PAODRN 10
      *                    PARM           PAMHIN 20
      *                    PARM           PAFROM 10
      *                    PARM           PAFIL1 10
      *                    PARM           PAFIL2 20
      *                    PARM           PAFIL3 20
      *                    PARM           PRTN    1
      *
      *   IN K POPT    1A    OPTION (D=DELT, U=UPD)
      *      K PANONY  4 0   DELIVERY#
      *      K PANKOJ  1A    FACTORY
      *      K PANUKE  4A    DOCK
      *      K PANOHZ  8 0   SHIP DATE
      *      K PANOBN  2 0   BIN#
      *      K PAODRN 10A    PO#
      *      K PAMHIN 20A    USER PART
      *        PAFROM 10     PGM FROM
      *        PAFIL1 10     FIL1
      *        PAFIL2 20     FIL2
      *        PAFIL3 20     FIL3
      *   OUT  PRTN    1A    RETURN FLAG (BLANK=OK, *=ERROR)
      ******************************************************
     FAB#PL1J IF  E           K        DISK
     FAB#PLAJ UF  E           K        DISK
      *--------------------------------------------------------
      * RENAME FIELD
     IAB#PLAJ1    01
     I              BASKJY                          XASKJY
     I              BASKHZ                          XASKHZ
     I              BASKYY                          XASKYY
     I              BASKMM                          XASKMM
     I              BASKDD                          XASKDD
     I              BASKTM                          XASKTM
     I              BASKME                          XASKME
     I              BASKPG                          XASKPG
     I              BAKOHZ                          XAKOHZ
     I              BAKOYY                          XAKOYY
     I              BAKOMM                          XAKOMM
     I              BAKODD                          XAKODD
     I              BAKOHH                          XAKOHH
     I              BAKOSS                          XAKOSS
     I              BAKOME                          XAKOME
     I              BANOPG                          XANOPG
     I              BASIRE                          XASIRE
     I              BASIRK                          XASIRK
     I              BATOKU                          XATOKU
     I              BANONY                          XANONY
     I              BANKOJ                          XANKOJ
     I              BANUKE                          XANUKE
     I              BASBAN                          XASBAN
     I              BAMHIN                          XAMHIN
     I              BAMHN1                          XAMHN1
     I              BAMHN2                          XAMHN2
     I              BAMHN3                          XAMHN3
     I              BAMHN4                          XAMHN4
     I              BASHIN                          XASHIN
     I              BASHN1                          XASHN1
     I              BASHN2                          XASHN2
     I              BASHN3                          XASHN3
     I              BANOHZ                          XANOHZ
     I              BANOYY                          XANOYY
     I              BANOMM                          XANOMM
     I              BANODD                          XANODD
     I              BANOTM                          XANOTM
     I              BAINVN                          XAINVN
     I              BAODRN                          XAODRN
     I              BASRYO                          XASRYO
     I              BASYOS                          XASYOS
     I              BATANK                          XATANK
     I              BAURHZ                          XAURHZ
     I              BAURYY                          XAURYY
     I              BAURMM                          XAURMM
     I              BAURDD                          XAURDD
     I              BAURTM                          XAURTM
     I              BAURME                          XAURME
     I              BAURPG                          XAURPG
     I              BACARD                          XACARD
     I              BARCOD                          XARCOD
     I              BAALFL                          XAALFL
     I              BANOBN                          XANOBN
     I              BAUSYS                          XAUSYS
     I              BAODER                          XAODER
     I              BAHENK                          XAHENK
     I              BAJYKB                          XAJYKB
     I              BAEDIK                          XAEDIK
     I              BARESE                          XARESE
     I              BADEYY                          XADEYY
     I              BADEMM                          XADEMM
     I              BADEDD                          XADEDD
     I              BAPGID                          XAPGID
      *
ADD  I              BAPAL#                          XAPAL#
ADD  I              BAPALT                          XAPALT
ADD  I              BAPLNT                          XAPLNT
ADD  I              BAEDII                          XAEDII
ADD  I              BASHCD                          XASHCD
ADD  I              BAREVN                          XAREVN
ADD  I              BACTTP                          XACTTP
ADD  I              BAORD#                          XAORD#
      *
ADD  I              BACRHZ                          XACRHZ
ADD  I              BACRTM                          XACRTM
ADD  I              BACRME                          XACRME
ADD  I              BACRPG                          XACRPG
      *
ADD  I              BAFLG1                          XAFLG1
ADD  I              BADAT1                          XADAT1
ADD  I              BAFLD1                          XAFLD1
ADD  I              BAFLD2                          XAFLD2
      *
     I            DS
     I                                        1   80XAKODT
     I                                        1   40XAKOYY
     I                                        5   60XAKOMM
     I                                        7   80XAKODD
     I            DS
     I                                        1   80XASKDT
     I                                        1   40XASKYY
     I                                        5   60XASKMM
     I                                        7   80XASKDD
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        1   20WSHH
     I                                        3   40WSMN
     I                                        5   60WSSS
     I                                        7  100WSYY
     I                                       11  120WSMM
     I                                       13  140WSDD
     I                                        1   40WSTM4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
      *
     C                     EXSR #INIT
      *
     C                     SELEC
      * UPDATE
     C           POPT      WHEQ 'U'
     C           KEY       CHAINAB#PL1J              95
     C           *IN95     IFEQ *OFF
     C                     EXSR #UPD
     C                     ENDIF
      * DELETE
     C           POPT      WHEQ 'D'
     C                     EXSR #DLT
     C                     ENDSL
      *
      * CHECK COUNTER
     C           @CNT      IFGE 1
     C                     MOVE *BLANK    PRTN
     C                     ELSE
     C                     MOVE '*'       PRTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *=============================================================
      *  UPDATE PROCESS
      *=============================================================
     C           #UPD      BEGSR
      * READ PPA1
     C                     MOVE *OFF      *IN96
     C           KEY       SETLLAB#PLAJ
     C           *IN96     DOWEQ*OFF
     C           KEY       READEAB#PLAJ                  96
     C           *IN96     IFEQ *OFF
      *
     C                     SELEC
      * AB#R1H
     C           PAFROM    WHEQ 'AB#R1H '
     C                     EXSR AB#R1H
      * AB#RA8
     C           PAFROM    WHEQ 'AB#RA8 '
     C                     EXSR AB#RA8
      *
     C                     ENDSL
      *
     C                     UPDATAB#PLAJ1
     C                     ADD  1         @CNT
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *=============================================================
      *  UPDATE FOR AB#R1H
      *=============================================================
     C           AB#R1H    BEGSR
      *
     C           PAFIL1    IFEQ *BLANK
     C                     MOVEL#USER     XAKOME
     C                     ELSE
     C                     MOVELPAFIL1    XAKOME
     C                     ENDIF
      *
     C           PAFIL2    IFEQ *BLANK
     C                     MOVELPAFROM    XANOPG
     C                     ELSE
     C                     MOVELPAFIL2    XANOPG
     C                     ENDIF
      *
     C                     Z-ADDBASYOS    XASYOS
     C                     Z-ADDBASRYO    XASRYO
     C                     Z-ADDBASRYO    XAODER
      *
     C                     MOVELBARESE    XARESE
     C                     Z-ADDTODAY     XAKODT
     C                     Z-ADDWSHH      XAKOHH
     C                     Z-ADDWSMN      XAKOSS
      *
     C                     ENDSR
      *=============================================================
      *  UPDATE FOR AB#RA8
      *=============================================================
     C           AB#RA8    BEGSR
      *
     C           PAFIL1    IFNE *BLANK
     C                     MOVELPAFIL1    LTR4    4
     C                     MOVELLTR4      XANOTM
     C                     ENDIF
      *
     C           PAFIL2    IFNE *BLANK
     C                     MOVELPAFIL2    XAINVN
     C                     ENDIF
      *
     C                     Z-ADDTODAY     XAKODT
     C                     Z-ADDWSHH      XAKOHH
     C                     Z-ADDWSMN      XAKOSS
     C                     MOVELPAFROM    XANOPG
     C                     MOVEL#USER     XAKOME
      *
     C                     ENDSR
      *=============================================================
      *  DELETE PROCESS
      *=============================================================
     C           #DLT      BEGSR
      *
     C                     MOVE *OFF      *IN97
     C           KEY       SETLLAB#PLAJ
     C           *IN97     DOWEQ*OFF
     C           KEY       READEAB#PLAJ                  97
     C           *IN97     IFEQ *OFF
     C           XASKJY    ANDNE'D'
      *
     C           PAFIL2    IFEQ *BLANK
     C                     MOVEL#PGM      XASKPG
     C                     ELSE
     C                     MOVELPAFIL2    XASKPG
     C                     ENDIF
      *
     C                     MOVEL'D'       XASKJY
     C                     Z-ADDTODAY     XASKDT
     C                     Z-ADDNOW       XASKTM
     C                     MOVEL#USER     XASKME
      *
     C                     UPDATAB#PLAJ1
     C                     ADD  1         @CNT
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *=============================================================
      *  INITIAL PROCESS
      *=============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           POPT    1
     C                     PARM           PANONY  40       KEY
     C                     PARM           PANKOJ  1        KEY
     C                     PARM           PANUKE  4        KEY
     C                     PARM           PANOHZ  80       KEY
     C                     PARM           PANOBN  20       KEY
     C                     PARM           PAODRN 10        KEY
     C                     PARM           PAMHIN 20        KEY
     C                     PARM           PAFROM 10
     C                     PARM           PAFIL1 10
     C                     PARM           PAFIL2 20
     C                     PARM           PAFIL3 20
     C                     PARM           PRTN    1
      *
     C           KEY       KLIST
     C                     KFLD           PANONY
     C                     KFLD           PANKOJ
     C                     KFLD           PANUKE
     C                     KFLD           PANOHZ
     C                     KFLD           PANOBN
     C                     KFLD           PAODRN
     C                     KFLD           PAMHIN
      *
     C                     MOVE *BLANK    PRTN
     C                     TIME           WSDT
     C                     Z-ADD0         @CNT    30
      *
     C                     ENDSR
