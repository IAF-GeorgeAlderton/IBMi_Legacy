     H            Y.
      ** AB#R13H ************************************************
      *  CREATE UNIVERSAL EDI ASN DATA (HONDA)                  *
      *  J.WATANABE   2025.04.29                                *
      ***********************************************************
     FAB#EL59 IF  E           K        DISK
     FAB#EL14 IF  E           K        DISK
     F            AB#EP141                          KRENAMEAB#EP14X
     FAB#EP14 O   E                    DISK
      ***********************************************************
     E                    TBL     1   5 30
      ***********************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      254 263 #USER
      ***********************************************************
      * MAIN ROUTINE
      ***********************************************************
     C                     EXSR #INIT
      * OUTPUT AB#EP14
     C           *LOVAL    SETLLAB#EL59
     C                     DO   *HIVAL
     C                     READ AB#EL59                  98
     C   98                LEAVE
      * CHECK DUPLICATE
     C                     EXSR #CHK1
     C           *IN85     IFEQ *ON
     C                     ITER
     C                     ENDIF
      *
     C                     CLEARAB#EP141
     C                     MOVELTBL,1     E4PRTN
     C                     Z-ADDTODAY     E4RCHZ
     C                     Z-ADDNOW       E4RCTM
     C                     MOVELNOW       E4RCT4
     C                     Z-ADDE1TOKU    E4TOKU
     C                     Z-ADDE1NONY    E4NONY
     C                     MOVELE1NKOJ    E4NKOJ
     C                     MOVELE1NUKE    E4NUKE
     C                     Z-ADDE1NOHZ    E4NOHZ
     C                     MOVELE1SHID    E4SHID
     C                     Z-ADDE1NBIN    E4NOBN
     C                     MOVE ' '       E4BCH#
     C                     MOVEL'856'     E4TRID
     C                     MOVELE1ASN     E4REF#
     C                     MOVELE1INVN    E4ASN#
     C                     MOVELE1ORDN    E4ODRN
      * GET PACKING LIST#
     C                     MOVELE1NOHZ    $NOHZ
     C                     MOVELE1TOKU    $CUST
     C                     MOVELE1NONY    $NONY
     C                     MOVELE1NKOJ    $NKOJ
     C                     MOVELE1NUKE    $NUKE
     C                     MOVELE1NBIN    $BINN
     C                     MOVEL'00000000'$RLHZ
     C                     MOVELE1ORDN    $ODRN
     C                     CALL 'UTLR51D'
     C                     PARM           $NOHZ   8
     C                     PARM           $CUST   4
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $BINN   2
     C                     PARM           $RLHZ   8
     C                     PARM           $ODRN  10
     C                     PARM           $PICK#  9
     C                     MOVEL$PICK#    E4PL#
      * GET PLANT/SHIP TO
     C                     MOVELE1NONY    $NONY
     C                     MOVELE1ORDN    $ODRN
     C                     CALL 'UEXR09B'
     C                     PARM           $NONY   4
     C                     PARM           $ODRN  10
     C                     PARM           $PLNT   3
     C                     PARM           $SHCD  10
     C                     MOVEL$PLNT     E4PLNT
     C                     MOVEL$SHCD     E4SHCD
      *
     C                     Z-ADDTODAY     E4CRHZ
     C                     Z-ADDNOW       E4CRTM
     C                     MOVEL#PGM      E4CRPG
     C                     MOVEL#USER     E4CRUS
      *
      * GET BATCH#
     C                     MOVELE4PRTN    $PRTN
     C                     MOVELE4REF#    $REF#
     C                     CALL 'UEXC58HA'
     C                     PARM           $PRTN  30
     C                     PARM           $REF#  14
     C                     PARM           $RCVD   8
     C                     PARM           $RCVT   6
     C                     PARM           $BCH#   7
     C                     PARM           $INT#  14
      *
     C           $BCH#     IFNE *ZERO
     C                     MOVEL$BCH#     E4BCH#
     C                     MOVEL$INT#     E4INT#
     C**                   MOVEL$RCVD     E4RCHZ
     C**                   MOVEL$RCVT     E4RCTM
     C**                   MOVEL$RCVT     E4RCT4
     C                     ENDIF
      *
     C                     WRITEAB#EP141
      *
     C                     ADD  1         @REC
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *=================================================
      * CHECK SUPLICATE
      *=================================================
     C           #CHK1     BEGSR
      *
     C                     MOVE *OFF      *IN85
      *
     C           E1SHID    SETLLAB#EL14
     C                     DO   *HIVAL
     C           E1SHID    READEAB#EL14                  98
     C   98                LEAVE
      * CHECK DUPLICATE
     C           E1NONY    IFNE E4NONY
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE *ON       *IN85
     C                     ENDDO
      *
     C                     ENDSR
      *=================================================
      * INITIAL SET
      *=================================================
     C           #INIT     BEGSR
      *
     C                     TIME           SDATE
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         @REC    60
      *
     C                     ENDSR
** TBL (30A) ......2.........3
HONDA NAEDIPRD                   01
                                 02
                                 03
                                 04
                                 05
