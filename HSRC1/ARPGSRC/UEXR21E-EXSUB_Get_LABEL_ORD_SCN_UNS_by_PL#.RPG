     H            Y.
     F** UEXR21E*******************************************************
     F*  PROGRAM: EXSUB - GET LABEL ORD/SCN/UNS BY PACKING LIST#      *
     F*  WRITTEN: JW (SRA) 2023.07.27                                 *
     F*---------------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UEXR21E'
     F*                    PARM           $SERL   9
     F*                    PARM           $ORD    6
     F*                    PARM           $SCN    6
     F*                    PARM           $UNS    6
     F*                    PARM           $RTN    1
     F*  IN  $SERL   9A  PACKING LIST#
     F*  OUT $ORD    6A  ORDER   BOX
     F*      $SCN    6A  SCANNED BOX
     F*      $ORD    6A  UNSCAN  BOX
     F*      $RTN    1A  RETURN (*=ERROR, BLANK=OK)
     F******************************************************
     FAB#PL76 IF  E           K        DISK
     FAB#PL1J IF  E           K        DISK
      *===================================================
     I            DS
     I                                        1   80PUNOHZ
     I                                        1   40PUNOYY
     I                                        5   60PUNOMM
     I                                        7   80PUNODD
      * SYSTEM DATE
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      *
     C           $SERL     CHAINAB#PL76              99
     C           *IN99     IFEQ *ON
     C                     MOVE '*'       $RTN
     C                     GOTO ENDP
     C                     ENDIF
      *
     C                     MOVELPUNONY    KNONY
     C                     MOVELPUNKOJ    KNKOJ
     C                     MOVELPUNUKE    KNUKE
     C                     MOVELPUNOHZ    KNOHZ
     C                     MOVELPUBINN    KNOBN
     C           K#1J      SETLLAB#PL1J
      * LOOP
     C                     DO   *HIVAL
     C           K#1J      READEAB#PL1J                  98
     C   98                LEAVE
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           PUODRN    IFNE *BLANK
     C           PUODRN    ANDNEBAODRN
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELBANONY    $NONY
     C                     MOVELBANKOJ    $NKOJ
     C                     MOVELBANUKE    $NUKE
     C                     MOVELBANOHZ    $NOHZ
     C                     MOVELBANOBN    $NOBN
     C                     MOVELBAMHIN    $MHIN
     C                     MOVELBAODRN    $ODRN
     C                     CALL 'UEXR21D'
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $NOHZ   8
     C                     PARM           $NOBN   2
     C                     PARM           $MHIN  20
     C                     PARM           $ODRN  10
     C                     PARM           $ORD    6
     C                     PARM           $SCN    6
     C                     PARM           $UNS    6
      *
     C                     MOVEL$ORD      @ORD
     C                     MOVEL$SCN      @SCN
     C                     MOVEL$UNS      @UNS
      *
     C                     ADD  @ORD      @ORDT   60
     C                     ADD  @SCN      @SCNT   60
     C                     ADD  @UNS      @UNST   60
     C                     ENDDO
      *
     C                     MOVEL@ORDT     $ORD
     C                     MOVEL@SCNT     $SCN
     C                     MOVEL@UNST     $UNS
      *
     C           ENDP      TAG
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SERL   9        IN
     C                     PARM           $ORD    6        OUT
     C                     PARM           $SCN    6        "
     C                     PARM           $UNS    6        "
     C                     PARM           $RTN    1        "
      *
     C           K#1J      KLIST
     C                     KFLD           KNONY   40
     C                     KFLD           KNKOJ   1
     C                     KFLD           KNUKE   4
     C                     KFLD           KNOHZ   80
     C                     KFLD           KNOBN   20
      *
     C                     MOVE *ZERO     $ORD
     C                     MOVE *ZERO     $SCN
     C                     MOVE *ZERO     $UNS
     C                     MOVE *BLANK    $RTN
     C                     Z-ADD0         @ORD    60
     C                     Z-ADD0         @SCN    60
     C                     Z-ADD0         @UNS    60
     C                     Z-ADD0         @ORDT   60
     C                     Z-ADD0         @SCNT   60
     C                     Z-ADD0         @UNST   60
      *
     C                     ENDSR
