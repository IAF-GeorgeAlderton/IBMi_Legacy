     H            Y.
     F** AM#RB1 *********************************************
     F* SHIPPING PROGRESS                                   *
     F*    ITS.             2015.06.22                      *
     F*******************************************************
     FAL#PL03 IF  E           K        DISK
     FAM#WPB1 UF  E           K        DISK                      A
     FAM#WPB3 UF  E           K        DISK                      A
     FAB#PP65 IF  E           K        DISK
     FAB#PL15 IF  E           K        DISK
     FAB#PL13 IF  E           K        DISK
     FAM#PPB1 IF  E           K        DISK
      *
     I            DS
     I                                        1  140KKFI
     I                                        1   80KKFIXD
     I                                        9  140KKFIXT
      *
     I            DS
     I                                        1  12 CAMHN
     I                                        1   5 CAMHN1
     I                                        6  10 CAMHN2
     I                                       11  12 CAMHN3
      *
     I            DS
     I                                        1   80K@NYMD
     I                                        1   40K@NOYY
     I                                        5   60K@NOMM
     I                                        7   80K@NODD
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  140SDATE
     I                                        1   60STIME
      *
     I            DS
     I                                        1  140WKAST
     I                                        1   80WKASTD
     I                                        9  140WKASTT
      *
     I            DS
     I                                        1  140WKAED
     I                                        1   80WKAEDD
     I                                        9  140WKAEDT
      *
     I            DS
     I                                        1  140W1AST
     I                                        1   80W1ASTD
     I                                        9  140W1ASTT
      *
     I            DS
     I                                        1  140W1AED
     I                                        1   80W1AEDD
     I                                        9  140W1AEDT
      *
     I            DS
     I                                        1  140A6DE
     I                                        1   40A6DEYY
     I                                        5   60A6DEMM
     I                                        7   80A6DEDD
     I                                        9  140A6DETM
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1SHID  8
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     TIME           WTIME
     C                     EXSR #SB400
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C           KEY01     KLIST
     C                     KFLD           P1SHID
      *
     C                     MOVEL'0'       GET     1
     C                     TIME           WTIME
     C           KEY01     SETLLAL#PL031
     C                     READ AL#PL031                 80
     C           *IN80     DOWEQ'0'
     C           CASKJY    IFEQ 'D'
     C           CASKHZ    ANDLESDATE
     C                     ELSE
     C           CAFIXD    IFNE 0
     C                     EXSR #SB710
     C           GETAB#    IFEQ '1'
     C                     EXSR #SB720
     C                     EXSR #SB500
     C                     EXSR #SB530
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     READ AL#PL031                 80
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      * AM#WPB1                                            *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYW6     KLIST
     C                     KFLD           CASHID
     C                     KFLD           CASHIT
     C                     KFLD           CASURT
     C                     KFLD           CATRKB
      *
     C           KEYW6     CHAINAM#WPB11             46
     C           *IN46     IFEQ '0'
     C                     ADD  1         W1BOX
     C                     ADD  WKSUM3    W1SUMI
     C                     UPDATAM#WPB11
     C                     ELSE
     C                     CLEARAM#WPB11
     C                     MOVELCASHID    W1SHID
     C                     MOVELCASHIT    W1SHIT
     C                     MOVELCASURT    W1SURT
     C                     MOVELCATRKB    W1TRKB
     C                     Z-ADD1         W1BOX
     C                     Z-ADDWKSUM3    W1SUMI
     C                     Z-ADD0         W1KPLT
     C                     Z-ADD0         W1COMP
     C                     EXSR #YARD
     C                     WRITEAM#WPB11
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      * YARD                                               *
      *----------------------------------------------------*
     CSR         #YARD     BEGSR
      *
     C           KEYB      KLIST
     C                     KFLD           CASHID
     C                     KFLD           CASHIT
     C                     KFLD           CASURT
     C                     KFLD           CATRKB
      *
     C           KEYB      CHAINAM#PPB11             46
     C           *IN46     IFEQ '0'
     C                     MOVELRBYARD    W1YARD
     C                     ENDIF
      *
     CSR         EYARD     ENDSR
      *-----------------------------------------------------
      *  AM#WPB3
      *-----------------------------------------------------
     CSR         #SB530    BEGSR
      *
     C           KEY33     KLIST
     C                     KFLD           CASHID
     C                     KFLD           CASHIT
     C                     KFLD           CASURT
     C                     KFLD           CATRKB
     C                     KFLD           CAIAFB
     C                     KFLD           CAIAFP
      *
     C           KEY33     CHAINAM#WPB31             24
     C           *IN24     IFEQ '0'
     C                     ADD  1         W3BOX
     C           CAPLDT    IFEQ 0
     C                     ELSE
     C                     ADD  1         W3SUMI
     C                     ENDIF
     C                     UPDATAM#WPB31
     C                     ELSE
     C                     CLEARAM#WPB31
     C                     MOVELCASHID    W3SHID
     C                     MOVELCASHIT    W3SHIT
     C                     MOVELCASURT    W3SURT
     C                     MOVELCATRKB    W3TRKB
     C                     MOVELCAIAFB    W3IAFB
     C                     MOVELCAIAFP    W3IAFP
     C                     Z-ADD1         W3BOX
     C           CAPLDT    IFEQ 0
     C                     Z-ADD0         W3SUMI
     C                     ELSE
     C                     Z-ADD1         W3SUMI
     C                     ENDIF
     C                     WRITEAM#WPB31
     C                     ENDIF
      *
     CSR         ESB530    ENDSR
      *----------------------------------------------------*
      *受注データ                                        *
      *----------------------------------------------------*
     CSR         #SB710    BEGSR
      *
     C                     MOVE CATOKU    KKTOKU  40
     C                     MOVE CANONY    KKNONY  40
     C                     MOVE CANKOJ    KKNKOJ  1
     C                     MOVELCANUKE    KKNUKE  4
     C                     MOVELCAORD#    K@ODRN 10
     C                     MOVELCAORD#    @@INVN 16
     C                     MOVE CASHID    K@NYMD
     C                     MOVELCASHIT    @SHTM   40
     C                     MOVELCAMHN1    KKMHN1
     C                     MOVELCAMHN2    KKMHN2
     C                     MOVELCAMHN3    KKMHN3
     C                     MOVEL*BLANK    KKMHN4
     C           K#15      KLIST
     C                     KFLD           KKTOKU  40
     C                     KFLD           KKNONY  40
     C                     KFLD           KKNKOJ  1
     C                     KFLD           KKNUKE  4
     C                     KFLD           KKMHN1  5
     C                     KFLD           KKMHN2  5
     C                     KFLD           KKMHN3  5
     C                     KFLD           K@MHN4  5
     C                     KFLD           K@ODRN
     C                     KFLD           K@NOYY
     C                     KFLD           K@NOMM
     C                     KFLD           K@NODD
     C           K#13      KLIST
     C                     KFLD           KKNONY  40
     C                     KFLD           K@NOYY
     C                     KFLD           K@NOMM
     C                     KFLD           K@NODD
     C                     KFLD           KKNUKE  4
     C                     KFLD           KKMHN1  5
     C                     KFLD           KKMHN2  5
     C                     KFLD           KKMHN3  5
     C                     KFLD           KKMHN4  5
      *
     C                     MOVEL'0'       GETAB#  1
     C           K#15      SETLLAB#PL15
     C           K#15      READEAB#PL15                  92
     C           *IN92     DOWEQ'0'
     C           GETAB#    ANDEQ'0'
     C           BASKJY    IFEQ 'D'
     C**JW       BASKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'1'       GETAB#  1
     C                     ENDIF
     C           K#15      READEAB#PL15                  92
     C                     ENDDO
      *
     C           GETAB#    IFEQ '0'
     C           K#13      SETLLAB#PL13
     C           K#13      READEAB#PL13                  92
     C           *IN92     DOWEQ'0'
     C           BASKJY    IFEQ 'D'
     C**JW       BASKHZ    ANDLE*DATE
     C                     ELSE
     C           BAINVN    IFEQ @@INVN
     C                     MOVEL'1'       GETAB#  1
     C                     ENDIF
     C                     ENDIF
     C           K#13      READEAB#PL13                  92
     C                     ENDDO
     C                     ENDIF
      *
     CSR         ESB710    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB720    BEGSR
      *
     C                     Z-ADD0         WKAST
     C                     Z-ADD0         WKAED
     C                     Z-ADD0         WKSUM3  10
     C           K#65      KLIST
     C                     KFLD           K@DEST  5
     C                     KFLD           K@NUKE  4
     C                     KFLD           K@ORNO 12
     C                     KFLD           K@KANO  4
     C                     KFLD           K@BOXN  4
     C                     MOVELCANAMC    K@DEST  5
     C                     MOVELCADOCK    K@NUKE  4
     C                     MOVELCAORD#    K@ORNO 12
     C                     MOVELCAKNB#    K@KANO  4
     C                     MOVELCABOX#    K@BOXN  4
     C                     MOVEL'0'       GET65   1
     C           K#65      SETLLAB#PP65
     C           K#65      READEAB#PP65             N    90
     C           *IN90     DOWEQ'0'
     C           GET65     ANDEQ'0'
     C           A6SKJY    IFEQ *BLANK
     C                     MOVEL'1'       GET65
     C                     Z-ADDA6DE      WKAST
     C                     Z-ADDA6DE      WKAED
     C                     ENDIF
     C           K#65      READEAB#PP65             N    90
     C                     ENDDO
      *
     C           GET65     IFEQ '1'
     C                     ADD  1         WKSUM3  10
     C                     ENDIF
      *
     CSR         ESB720    ENDSR
