      *-------------------------------------------------------------------------
      *          #DSP10   テーブル　自動圧縮処理
      *-------------------------------------------------------------------------
     C           #DSP10    BEGSR
      *
     C                     CLEAR@KTD                       *工程コード
     C                     CLEAR@BMD                       *工程部門
     C                     CLEAR@BND                       *工程部門
     C                     CLEAR@NOD                       *機械№
     C                     Z-ADD*ZERO     W@WKMX  20       *工程MAX
     C                     Z-ADD*ZERO     I
      *
     C                     DO   15        J                ¬DO_01
      *入力あり
     C           @KT,J     IFNE *BLANK                     ~¬IF_01
     C           @BM,J     ORNE *ZERO
     C           @NO,J     ORNE *BLANK
     C                     ADD  1         I
     C                     MOVEL@KT,J     @KTD,I           *工程コード
     C                     Z-ADD@BM,J     @BMD,I           *工程部門
     C                     MOVEL@BN,J     @BND,I           *工程部門名
     C                     MOVEL@NO,J     @NOD,I           *機械№
     C                     END                             _｢IF_01
     C                     END                             ｢DO_01
      *再セット
     C                     CLEAR@KT                        *工程コード
     C                     CLEAR@BM                        *工程部門
     C                     CLEAR@BN                        *工程部門名
     C                     CLEAR@NO                        *機械№
      *
     C                     DO   15        J                ¬DO_01
     C                     MOVEL@KTD,J    @KT,J            *工程コード
     C                     Z-ADD@BMD,J    @BM,J            *工程部門
     C                     MOVEL@BND,J    @BN,J            *工程部門名
     C                     MOVEL@NOD,J    @NO,J            *機械№
     C           @KT,J     IFNE *BLANK                     ~¬IF_01
     C           @BM,J     ORNE *ZERO
     C           @NO,J     ORNE *BLANK
     C                     Z-ADDJ         W@WKMX           *工程MAX
     C                     END                             _｢IF_01
     C                     END                             ｢DO_01
      *最大工程取り直し
     C           W@WKMX    IFNE *ZERO                      ¬IF_01
     C           W@KMAX    IFNE W@WKMX                     ~¬IF_02
     C                     Z-ADDW@WKMX    W@KMAX           *工程MAX
     C                     END                             _｢IF_02
     C                     END                             ｢IF_01
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #DBOUT   Ｄ．Ｂ　アクセス処理
      *-------------------------------------------------------------------------
     C           #DBOUT    BEGSR
      * ADD/CHANGE
     C           P@KKBN    IFEQ '1'                        ¬IF_01
     C           P@KKBN    OREQ '2'
      *
      *工程マスタワークファイル(MRHWP31)
     C                     EXSR #WRT10                     * WRITE
      *使用方法区分による処理（部品メンテ共用）
     C           P@SHBN    IFEQ *BLANK                     ~¬IF_02
      *部品マスタワークファイル(MRHWP21)
     C                     EXSR #UPD10                     * UPDAT
     C                     END                             _｢IF_02
      *
     C                     END                             ｢IF_01
      *
      * NEXT-CONTROL
     C                     MOVEL'END  '   W@NEXT
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #WRT10   工程マスタワークファイル(MRHWP31)出力処理
      *-------------------------------------------------------------------------
     C           #WRT10    BEGSR
      *
     C                     DO   15        J                ¬DO_01
      *入力あり
     C           @KT,J     IFNE *BLANK                     ~¬IF_01
     C                     CLEARMRHWP311
      *
     C                     MOVELP@SHN1    W3JHN1           * INHOUSE PART NUMBER
     C                     MOVELP@SHN2    W3JHN2           * INHOUSE PART NUMBER
     C                     MOVELP@SHN3    W3JHN3           * INHOUSE PART NUMBER
     C                     MOVELW@SEHI    W3SEHI           * PRODUCT INSTRUCTION
     C                     MOVELW@TEHI    W3TEHI           * PRODUCTION ORDER IN
      *
     C                     Z-ADDJ         W3KSEQ           *工程順序
     C                     MOVEL@KT,J     W3MKTE           *工程コード
     C                     Z-ADD@BM,J     W3MBMN           *工程部門
     C                     MOVEL@NO,J     W3MSNO           *機械№
      *
     C                     WRITEMRHWP311
     C                     END                             _｢IF_01
      *
     C                     END                             ｢DO_01
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #UPD10   部品マスタワークファイル(MRHWP21)更新処理
      *-------------------------------------------------------------------------
     C           #UPD10    BEGSR
      *部品マスタワークファイル(MRHWP21)
     C                     MOVELP@SHN1    W2SHN1           *社内品番１
     C                     MOVELP@SHN2    W2SHN2           *社内品番２
     C                     MOVELP@SHN3    W2SHN3           *社内品番３
     C                     MOVELW@SEHI    W2SEHI           *製品区分
     C                     MOVELW@TEHI    W2TEHI           *手配区分
     C           W2KEY     CHAINMRHWP211             98
     C           *IN98     IFEQ '0'                        ¬IF_01
     C                     Z-ADDD1OQTP    W2OQTP           *焼入れ温度
     C                     Z-ADDD1KPTM    W2KPTM           *焼入れ時間
     C                     Z-ADDD1TMTP    W2TMTP           *焼戻し温度
     C                     Z-ADDD1CO2     W2CO2            *ＣＯ２濃度
     C                     Z-ADDD1BSK1    W2BSK1           *バスケット１
     C                     Z-ADDD1BSK2    W2BSK2           *バスケット２
     C                     Z-ADDD1BSK3    W2BSK3           *バスケット３
     C                     Z-ADDD1BSK4    W2BSK4           *バスケット４
     C                     Z-ADDD1OQLT    W2OQLT           *ＯＱロット
     C                     Z-ADDD1LATP    W2LATP           *ＬＡＮ／ＡＯＱ温度
     C                     Z-ADDD1LATM    W2LATM           *ＬＡＮ／ＡＯＱ処理
     C                     Z-ADDD1MKSU    W2MKSU           *メッキ係数
     C                     Z-ADDD1BLSU    W2BLSU           *バレル数
      *
     C                     UPDATMRHWP211
      *
     C                     END                             ｢IF_01
      *
     C                     ENDSR
