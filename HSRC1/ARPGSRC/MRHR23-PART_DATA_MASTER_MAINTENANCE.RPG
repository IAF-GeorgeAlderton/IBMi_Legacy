%03   * ADHPL80 QUENCHING CONDITION M/F      *
↓  *----------------------------------------------------------------
     C           #ADHP8    BEGSR
      *
     C           KEY80     KLIST
     C                     KFLD           D1ZAIC  3        MATERIAL CODE
     C                     KFLD           D1KIKI  31       MATERIAL PROPERTIES
      *
     C           KEY80     SETLLADHPL80
     C                     DO   *HIVAL
     C           KEY80     READEADHPL80                  89
     C   89                LEAVE
     C           J8SKJY    IFEQ 'D'
     C           J8SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C* *
      *工程     J8ATOK         3A         COLHDG('PRESENT PROCESS CODE')
      *           J8PCLS         3A         COLHDG('PART CLASS')
     C           J8HOJI    IFEQ D1KPTM
     C           J8ONDO    ANDEQD1TMTP
     C           J8CO2P    ANDEQD1CO2
     C                     LEAVE
     C                     ENDIF
     C* *
     C                     ENDDO
      *
      *
     C           *IN89     IFEQ *ON
     C           D1ZAIC    IFNE $$ZAIC                     MATERIAL CODE
     C           D1KIKI    ORNE $$KIKI                     MATERIAL PROPERTIES
     C           D1KPTM    ORNE $$KPTM
     C           D1TMTP    ORNE $$TMTP
     C           D1CO2     ORNE $$CO2
     C   99                SETOF                     89
     C  N99                MOVEL@MS,19    D1EMSG    P      * ERR MSG
     C  N99                SETON                     727374
     C  N99                SETON                     99
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *================================================================
      *
      *================================================================
     C           #WARNI    BEGSR
     C           1         CHAINADHPP89              60
     C   60                MOVE *BLANK    J8PASS
     C                     MOVE *BLANK    D9PASS
     C*
     C                     MOVEL*BLANK    $$ZAIC  3
     C                     Z-ADD0         $$KIKI  31
     C                     Z-ADD0         $$KPTM  30
     C                     Z-ADD0         $$TMTP  30
     C                     Z-ADD0         $$CO2   32
      *
     C           $WARN1    TAG
     C                     EXFMTMRHPW239
     C                     SETOF                     99
     C*
     C   KC                GOTO $WARN9
     C           D9PASS    IFNE J8PASS
     C                     SETON                     99
     C                     GOTO $WARN1
     C                     ENDIF
     C*
     C                     MOVELD1ZAIC    $$ZAIC
     C                     Z-ADDD1KIKI    $$KIKI
     C                     Z-ADDD1KPTM    $$KPTM
     C                     Z-ADDD1TMTP    $$TMTP
     C                     Z-ADDD1CO2     $$CO2
     C           $WARN9    TAG
     C                     ENDSR
