     H            Y.
     F** AM#R45 *********************************************
     F* PALLET CONDITION SCAN                               *
     F*    LEC              2019.06.20                      *
     F*******************************************************
     FAM#PW45 CF  E                    WORKSTN
     FALBPL30 IF  E           K        DISK
     FAL#PP21 IF  E           K        DISK
     FGADPL15 IF  E           K        DISK
     FAM#PP45 UF  E           K        DISK                      A
     E                    ER      1   3 40
      *
     IMAN         DS
     I                                        1  25 MAN1
     I                                       26  50 MAN2
      *
      * 2D MANIFEST BARCODE
     I            DS
     I                                        1  50 MF
     I                                        1   5 MFNAMC
     I                                        3   5 MFTYPE
     I                                        6  10 MFSUPP
     I                                       11  12 MFDOCK
     I                                       13  24 MFORD#
     I                                       25  33 MFMRTE
     I                                       34  36 MFSDCK
     I                                       37  38 MFPALT
     I                                       39  40 MFMROS
     I                                       41  44 MFSKID
     I                                       44  44 MFSIDE
     I                                       45  50 MFFILR
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  140SDATE
     I                                        1   60STIME
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           WORKER  6
     C                     PARM           WUSRID 10
      *----------------------------------------------------*
      *   M  A  I  N  L  I  N  E                           *
      *----------------------------------------------------*
     C                     EXSR #INIT
     C           DSPSW     DOUEQ'99'
     C                     EXSR #MAIN
     C                     ENDDO
     C                     EXSR #END
      *----------------------------------------------------*
      * INITIALIZE                                         *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C                     MOVELWORKER    WKCD    60
     C           WKCD      CHAINALBPL30              61
     C           *IN61     IFEQ *ON
     C                     MOVE *BLANKS   ALWKNM
     C                     ENDIF
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     CLEARMAN
      *
     C           #GAD15    KLIST
     C                     KFLD           C2NONY
      *
     C                     ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C           #MAIN     BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB100
     C                     ENDDO
      *
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB200
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *　⒳�痧���Ğ��鰋瘏　　　　　　　　　　　　　�
      *----------------------------------------------------*
     C           #SB100    BEGSR
      *
     C                     EXFMTDSP01
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     3199
      *
     C                     TIME           WTIME
     C           *IN01     IFEQ *ON
     C                     MOVEL'99'      DSPSW   2
     C                     GOTO ESB100
     C                     ENDIF
      *
     C           *IN05     IFEQ *ON
     C                     MOVE '02'      DSPSW
     C                     GOTO ESB100
     C                     ENDIF
      *
     C           MAN       IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVELER,1      MSG
     C                     GOTO ESB100
     C                     ENDIF
      *
     C                     MOVELMAN       MF
      *
     C           MFNAMC    CHAINAL#PP21              55
     C           *IN55     IFEQ *OFF
     C           #GAD15    CHAINGADPL15              55
     C           *IN55     IFEQ *OFF
     C                     MOVELB5KMEI    PNAME  20
     C                     ELSE
     C                     MOVELER,2      MSG
     C                     SETOF                     3199
     C                     GOTO ESB100
     C                     ENDIF
     C                     ELSE
     C                     MOVELER,2      MSG
     C                     SETOF                     3199
     C                     GOTO ESB100
     C                     ENDIF
      *
     C                     EXSR #CHKMF
     C           FOUND     IFEQ 'N'
     C                     MOVE *BLANK    DAMG    1
     C                     EXSR #SB500
     C                     ENDIF
      *
     C                     CLEARMAN
      *
     C                     MOVEL'01'      DSPSW
      *
     C           ESB100    ENDSR
      *----------------------------------------------------*
      *　⒳�痧���樝槮疤�樚鯟�⒳樠　　　　　　　　　�
      *----------------------------------------------------*
     C           #SB200    BEGSR
      *
     C                     EXFMTDSP02
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     3199
      *
     C                     TIME           WTIME
      *
      * if f3, then go back to screen 1.
     C           *IN03     IFEQ *ON
     C                     CLEARMAN
     C                     MOVEL'01'      DSPSW
     C                     GOTO ESB200
     C                     ENDIF
      *
      * check manifest screen for errors.
     C           MAN       IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVELER,1      MSG
     C                     GOTO ESB200
     C                     ENDIF
      *
     C                     MOVELMAN       MF
      *
     C           MFNAMC    CHAINAL#PP21              55
     C           *IN55     IFEQ *OFF
     C           #GAD15    CHAINGADPL15              55
     C           *IN55     IFEQ *OFF
     C                     MOVELB5KMEI    PNAME
     C                     ELSE
     C                     MOVELER,2      MSG
     C                     SETOF                     3199
     C                     GOTO ESB200
     C                     ENDIF
     C                     ELSE
     C                     MOVELER,2      MSG
     C                     SETOF                     3199
     C                     GOTO ESB200
     C                     ENDIF
      *
     C                     EXSR #CHKMF
      *
     C           FOUND     IFEQ 'N'
     C                     MOVE 'Y'       DAMG
     C                     EXSR #SB500
     C                     ENDIF
      *
     C                     CLEARMAN
      *
     C                     MOVEL'01'      DSPSW
      *
     C           ESB200    ENDSR
      *----------------------------------------------------*
      *　瀗疢�▦�疴��黬�砑ⓓ�鰚疙玦�濰�疤　　　　�
      *----------------------------------------------------*
     C           #CHKMF    BEGSR
      *
     C                     MOVE 'N'       FOUND   1
     C                     MOVE *BLANK    MFSIDE
      *
     C           MF        CHAINAM#PP45              55
     C           *IN55     IFEQ *OFF
     C                     MOVE 'Y'       FOUND
      *
     C                     DO   *HIVAL
      *
     C                     MOVE D1DAMG    SCDAMG
     C                     EXFMTDSP03
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     3199
      *
     C           SCDAMG    IFNE 'Y'
     C           SCDAMG    ANDNE'N'
     C                     MOVELER,3      MSG
     C                     SETON                     3199
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           SCDAMG    IFEQ 'N'
     C                     MOVE *BLANK    SCDAMG
     C                     ENDIF
      *
     C                     MOVELWORKER    D1USCD
     C                     MOVELALWKNM    D1USNM
     C                     MOVE SCDAMG    D1DAMG
     C                     UPDATAM#PP451
      *
     C                     CLEARMAN
      *
     C                     MOVELPNAME     LSNAME
     C                     MOVELMFORD#    LSORD#
     C                     MOVELMFDOCK    LSNUKE
     C                     MOVELMFPALT    LSPALT
     C                     MOVELMFMROS    LSMRSO
     C           SCDAMG    IFEQ 'Y'
     C                     MOVEL'Damaged 'LSCOND
     C                     ELSE
     C                     MOVEL'Good    'LSCOND
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      * WRITE TO PALLET CONDITION SCAN FILE - AM#PP45.     *
      *----------------------------------------------------*
     C           #SB500    BEGSR
      *
     C                     CLEARAM#PP451
     C                     Z-ADDSDATE     D1SSHZ
     C                     Z-ADDSTIME     D1SSTI
     C                     MOVELWORKER    D1USCD
     C                     MOVELALWKNM    D1USNM
      *
     C                     MOVELMF        D12D
     C                     MOVELMFNAMC    D1NAMC
     C                     MOVELPNAME     D1NAME
     C                     MOVELMFSUPP    D1SUPP
     C           D1SUPP    IFEQ '14060'
     C           D1SUPP    OREQ '1731B'
     C                     MOVEL'IAF'     D1SNAM
     C                     ELSE
     C                     MOVEL'OFFRT'   D1SNAM
     C                     ENDIF
     C                     MOVELMFDOCK    D1NUKE
     C                     MOVELMFORD#    D1ORD#
     C                     MOVELMFPALT    D1PALT
     C                     MOVELMFMROS    D1MRSO
     C                     MOVEL'Y'       D1RECV
     C                     MOVELDAMG      D1DAMG
      *
     C                     WRITEAM#PP451
      *
     C                     MOVELPNAME     LSNAME
     C                     MOVELMFORD#    LSORD#
     C                     MOVELMFDOCK    LSNUKE
     C                     MOVELMFPALT    LSPALT
     C                     MOVELMFMROS    LSMRSO
     C           DAMG      IFEQ 'Y'
     C                     MOVEL'Damaged 'LSCOND
     C                     ELSE
     C                     MOVEL'Good    'LSCOND
     C                     ENDIF
      *
     C           ESB500    ENDSR
      *
      *----------------------------------------------------*
      * END PROGRAM.                                       *
      *----------------------------------------------------*
     C           #END      BEGSR
     C                     SETON                     LR
     C                     RETRN
     C                     ENDSR
      *----------------------------------------------------*
**
INPUT MANIFEST BARCODE.
INVALID MANIFEST BARCODE.
INVALID, ENTER Y OR N
