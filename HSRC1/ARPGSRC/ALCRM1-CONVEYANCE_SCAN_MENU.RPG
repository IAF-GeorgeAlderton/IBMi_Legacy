     H            Y.
     F** ALCRM1 *********************************************
     F* SHIPPING SCAN MENU
     F*    LEC.             2015.10.27                      *
     F*******************************************************
     FALCPWM1 CF  E                    WORKSTN
     FALBPL30 IF  E           K        DISK
     E                    ER      1  11 65
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  14 SDATE
     I                                        1   6 STIME
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           WORKER  6
     C                     PARM           WUSRID 10
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     MOVELWORKER    USRCD
     C                     Z-ADD0         D1SEL
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTDSP01
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*BLANK    WPGM    6
     C                     MOVEL*BLANK    P2PGM  10
     C                     SETOF                     3199
      *
     C                     TIME           WTIME
     C           *IN03     IFEQ '1'
     C                     MOVEL'99'      DSPSW   2
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           P1        PLIST
     C                     PARM           POPR    6
     C                     PARM           PUSR   10
      *
     C                     MOVE WORKER    POPR    6        SET WORKER ID
     C                     MOVE WORKER    POPR2   60       SET WORKER ID
      *
     C                     SETOF                     98
     C           POPR2     SETGTALBPL301
     C                     DO   *HIVAL
     C           POPR2     REDPEALBPL301                 98
     C   98                LEAVE
     C           ALSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C                     MOVELALWKNM    W1USNM 20
     C                     ENDDO
      *
     C                     MOVELW1USNM    PUSR   10        SET WORKER ID
      *
     C                     SELEC
      * 4POINT SCAN
     C           D1SEL     WHEQ 1
     C                     MOVEL'ALCC01'  WPGM
      * WASHER SCAN
     C           D1SEL     WHEQ 2
     C                     MOVEL'ALFC01'  WPGM
      * ASJ WASHER SCAN
     C           D1SEL     WHEQ 3
     C                     MOVEL'GDMC810' WPGM
      * OUTSOURCE SCAN
     C           D1SEL     WHEQ 4
     C                     MOVEL'ALDC02'  WPGM
      * BPT SCAN
     C           D1SEL     WHEQ 5
     C                     MOVEL'ALEC01'  WPGM
      * 3POINT SCAN
     C           D1SEL     WHEQ 6
     C                     MOVEL'ALCRM2'  WPGM
      *
     C                     OTHER
      *
     C                     SETON                     3199
     C                     MOVELER,1      MSG
     C                     EXSR #SB999
     C                     GOTO ESB210
     C                     ENDSL
      *
      * CREATE SIGN-ON INFO
     C                     MOVELWPGM      P2PGM  10
     C                     MOVE WORKER    P2WKR   6
     C                     MOVELW1USNM    P2WKN  20
     C                     CALL 'ALDRZ6'
     C                     PARM           P2PGM
     C                     PARM           P2WKR
     C                     PARM           P2WKN
      * CALL PROCESS
     C                     CALL WPGM
     C                     Z-ADD0         D1SEL
      *
      * DELETE SIGN-ON INFO
     C                     CALL 'ALDRZ7'
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
      *
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * ERR                                                *
      *----------------------------------------------------*
     CSR         #SB999    BEGSR
      *
     C                     MOVELMSG       P1ERR
     C                     CALL 'AM#R08'
     C                     PARM           P1ERR  25
     C                     SETOF                     3199
     C                     MOVEL*BLANK    MSG
      *
     CSR         ESB999    ENDSR
**
INPUT NO. ERR




