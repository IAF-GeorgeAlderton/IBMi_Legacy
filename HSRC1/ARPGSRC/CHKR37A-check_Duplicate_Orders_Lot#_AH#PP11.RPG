     H            Y.
     F***CHKR37A ***************************************************************
     F*  PROGRAM    : CHECK DUPLICATE ORDERS/LOT#                              *
     F*             : RUN IN FCKC00 (10:10AM BY JOBSCDE)                       *
     F*  WRITTEN    : JW (SRA) 2022.04.01                                      *
     F**************************************************************************
     FAH#TL25 IF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1  12 CFIPAR
     I                                        1   5 CFHIN1
     I                                        6  10 CFHIN2
     I                                       11  12 CFHIN3
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ AH#TL25                  98
     C   98                LEAVE
      *
     C           CFSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           CFIPAR    IFEQ SVIPAR
     C                     ADD  1         LCNT
     C                     ELSE
     C           LCNT      IFGE 950
     C                     EXSR #PRINT
     C                     ENDIF
     C                     Z-ADD1         LCNT
     C                     MOVELCFIPAR    SVIPAR
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C                     MOVE *BLANK    $RTN
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     MOVE *BLANK    SVIPAR 12
     C                     Z-ADD0         LCNT    40
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   35 '** PART/LOT# IS CLOS'
     O                                   55 'ING MAX 999 ** (AH#P'
     O                                   75 'P11)                '
     O                                   79 'DATE'
     O                         TODAY     82 '    .  .  '
     O                         NOW       92 '  :  :  '
     O                                   95 'P.'
     O                         PAGE  Z   99
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   12 'PART#'
     O                                   28 '# OF LOT'
     O        E 1              @DTL
     O                         SEQ#    +001
     O                         SVIPAR  +002
     O                         LCNT  1 +004
