     C*
     C                     MOVE BAODRN    I2ORDR           ORDER #
     C                     MOVE BAODRN    I2ODRN           ORDER #
     C                     Z-ADDBASRYO    @@SRYO
     C*
     C                     MOVE WIPAR     I2IPAR           INTERNAL PART
     C                     MOVE PNOHZ     I2SHDT           SHIP DATE
      *
     C* CALUCULATE THE TOTAL WEIGHT PAR PART
     C* (QTY/CONTAINER) * (FINISHED WEIGHT) = NET WEIGHT PER BOX(G)
     C* (NET WEIGHT PER BOX) / 1000      = TOTAL WEIGHT / PART(KG)
     C           WSYS      MULT @@KASI    WKOT1   92
     C           WKOT1     DIV  1000      WKOT2   92
     C           WKOT2     MULT 2.2046    WKOT2
     C                     Z-ADDWKOT2     PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     I2WEIT           QTY
     C*
      ** WRITE A MASTER LABEL
     C           *IN99     IFEQ *OFF
B2   C           @#LAB     IFNE *ZERO
     C                     Z-ADD@#LAB     Q
     C                     ELSE
     C                     Z-ADDW#LAB     Q
     C                     ENDIF
     C                     ADD  1         WSEQ##
B3   C           1         DO   Q
      *
     C                     MOVEL@@QTY     I2QTY
     C                     WRITEAB#WP2I1
      *
JW5  C                     MOVEL'AB#WP2I 'IXWRKF    P
.    C                     EXSR #XP01
      *
     C                     ENDDO
     C                     MOVE *ON       *IN99
     C                     ENDIF
      ****
     C                     Z-ADDWSYS      PIQTY
     C                     MOVE *BLANK    POQTY
