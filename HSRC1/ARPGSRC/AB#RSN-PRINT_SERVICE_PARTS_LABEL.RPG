     C                     MOVE *BLANK    H2LOC2
     C                     MOVE *BLANK    H2LOC3
     C                     MOVE *BLANK    H2LOC4
     C           KEY2      SETLLFCEPL011
     C           #PART1    TAG
     C           KEY2      READEFCEPL011                 91
B02  C           *IN91     IFEQ '0'
     C*
