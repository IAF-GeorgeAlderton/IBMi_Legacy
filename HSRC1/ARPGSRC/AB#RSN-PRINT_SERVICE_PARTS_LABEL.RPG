     C* GET PART NAME
     C           KEY2      CHAINFCEPL30              91
     C           *IN91     IFEQ *OFF
     C           F3GSKD    ANDEQ*BLANK
     C                     MOVELF3SMEI    I2PNAM           PART NAME
     C                     MOVE F3ZETI    I2ZETI           ABSOLUTE #
     C                     Z-ADDF3KASI    @@KASI
     C           PNOHZ     IFGE F3TYMD                     LOCATION
     C                     MOVE F3STRK    I2LOC1           NEW
     C                     MOVE F3STRT    I2LOC2
     C                     MOVE F3STRR    I2LOC3
     C                     MOVE F3STRD    I2LOC4
     C*
     C                     ELSE
     C                     MOVE F3KTRK    I2LOC1           OLD
     C                     MOVE F3KTRT    I2LOC2
     C                     MOVE F3KTRR    I2LOC3
     C                     MOVE F3KTRD    I2LOC4
     C                     END
      *
     C                     ELSE
TCHK3C                     MOVEL*BLANK    F3ZETI
     C                     MOVE *BLANK    I2PNAM
     C                     MOVE *BLANK    I2LOC1
     C                     MOVE *BLANK    I2LOC2
     C                     MOVE *BLANK    I2LOC3
     C                     MOVE *BLANK    I2LOC4
     C           KEY2      SETLLFCEPL011
     C           #PART8    TAG
     C           KEY2      READEFCEPL011                 91
B02  C           *IN91     IFEQ '0'
     C*
     C*          A2GSKD    IFEQ 'D'
     C*                    GOTO #PART8
     C*                    END
     C                     MOVELA2SMEI    I2PNAM           PART NAME
     C                     MOVE A2ZETI    I2ZETI           ABSOLUTE #
     C                     Z-ADDA2KASI    @@KASI
     C*
     C           A2GSKD    IFEQ *BLANK
     C           PNOHZ     IFGE A2DATE                     LOCATION
