     C*
     C                     ELSE                                      1
     C                     MOVE *BLANK    I2ADDR           STORE ADDRESS
     C                     END
     C*
     C                     MOVE BAODRN    I2ORDR           ORDER #
     C                     MOVE BAODRN    I2ODRN           ORDER #
     C                     MOVE #PGM      I2PGM            PROGRAM NAME
     C           PNONY     IFEQ '0323'
TCHK7C                     MOVEL*BLANK    @5
     C                     MOVELPNODD     @5      5
     C                     MOVE DC,PNOMM  @1      1
     C           @5        CAT  @1:0      @5        P
     C                     MOVE PY        @1
     C           @5        CAT  @1:0      @5        P
     C                     MOVEL@5        I2FLD1
     C                     ENDIF
     C*
