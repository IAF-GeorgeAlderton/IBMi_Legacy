     C                     MOVELPOQTY     @@QTY1  5        QTY
      *
     C                     MOVELPOQTY     I2UNIT           QTY/CONT
      *
B1   C           *IN88     IFEQ '1'
     C*
     C* USER SELECTED NUMBER OF LABEL
B2   C           @#LAB     IFNE *ZERO
     C                     Z-ADD@#LAB     Q
B3   C           1         DO   Q
     C                     EXSR @NMBR
     C                     MOVE N3NMBR    I2SERL
     C                     MOVELPNONY     I2SERL
      *
     C           @@SRYO    IFGE WSYS
     C                     Z-ADDWSYS      PIQTY
     C                     ELSE
     C                     Z-ADD@@SRYO    PIQTY
     C                     ENDIF
      *
     C                     SUB  WSYS      @@SRYO
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     I2QTY            QTY
     C                     MOVELPOQTY     @@QTY1  5        QTY
      *
     C                     MOVELPOQTY     I2UNIT           QTY/CONT
      *
     C                     EXSR #PP70
     C                     ADD  1         WSEQ##
     C                     DO   W#LAB
     C                     WRITEAB#WP2I1
      *
JW5  C                     MOVEL'AB#WP2I 'IXWRKF    P
.    C                     EXSR #XP01
      *
E3   C                     END
E3   C                     END
     C                     GOTO #READ8
     C*
     C                     ELSE
     C           @FLAG     IFEQ *BLANK
     C                     GOTO #READ8
     C                     END
     C*
E2   C                     END
E1   C                     END
     C*
     C* USER ONLY MARKED
     C*
     C           BASRYO    DIV  WSYS      Q
     C                     MVR            WRST
     C           WRST      IFNE *ZERO
     C                     ADD  1         Q
     C                     END
      ** WRITE A MASTER LABEL
     C           *IN99     IFEQ *OFF
     C                     MOVEL@@QTY     I2QTY
     C                     WRITEAB#WP2I1
      *
JW5  C                     MOVEL'AB#WP2I 'IXWRKF    P
.    C                     EXSR #XP01
      *
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     MOVEL@@QTY1    I2QTY
     C*
     C           1         DO   Q
     C*
     C                     ADD  1         WSEQ##
     C                     EXSR @NMBR
     C                     MOVE N3NMBR    I2SERL
     C                     MOVELPNONY     I2SERL
     C                     EXSR #PP70
      *
     C           @@SRYO    IFGE WSYS
     C                     Z-ADDWSYS      PIQTY
     C                     ELSE
     C                     Z-ADD@@SRYO    PIQTY
     C                     ENDIF
      *
     C                     SUB  WSYS      @@SRYO
     C                     MOVE *BLANK    POQTY
