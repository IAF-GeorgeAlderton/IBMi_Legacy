     C                     MOVEAWKBLAK    *IN,30
     C                     SETOF                     87
     C*
     C                     SELEC
B02  C           *INKC     WHEQ '1'
     C                     MOVE '9'       WKDSP
     C* F12: BACK
     C           *INKL     WHEQ *ON
     C                     MOVE '1'       WKDSP
      * ENTR KEY
     C                     OTHER
     C                     EXSR @CHK2
     C* F5: PROCESS
B03  C           *INKE     IFEQ '1'
     C*
     C* CHECK OK?
     C           *IN30     ANDEQ'0'
     C                     EXSR @WRT2
     C                     EXSR @CLRS
     C                     END
     C                     ENDSL
     C*
     C                     ENDSR
     C***********************************************************
     C* # OF PARTS
     C***********************************************************
     C           @ITEM     BEGSR
      *
     C                     Z-ADD*ZERO     @ITM    30
     C                     MOVE PNONY     WNONY   40
      *
     C           KEY1      SETLLAB#PL13
     C           *IN93     DOUEQ*ON
     C           KEY1      READEAB#PL131                 93
     C           *IN93     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           PORD#     IFNE *BLANK
     C           PORD#     ANDNEBAODRN
     C                     ITER
     C                     ENDIF
     C           BIN       IFNE *ZERO
     C           BANOBN    ANDNEBIN
     C                     ITER
     C                     ENDIF
     C           PNUKE     IFNE *BLANK
     C           BANUKE    ANDNEPNUKE
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         @ITM
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C***********************************************************
     C* @CHK1:CHECK ITEMS ON 1ST. SCREEN
     C***********************************************************
     C           @CHK1     BEGSR
     C*
     C* DELIVERY CODE BLANK ?
     C           PNONY     IFEQ *BLANK
     C                     SETON                     3031
     C                     MOVELER,1      MSG
     C                     GOTO #CHK1
     C                     END
JW5   * CHECK HONDA
 .   C                     MOVELPNONY     NUM4    40
 .   C           NUM4      CHAINAB#PL2A6             86
 .   C           *IN86     IFEQ *OFF
     C                     SETON                     3031
 .   C                     MOVELER,15     MSG
 .   C                     GOTO #CHK1
JW5  C                     ENDIF
     C*
     C* FACTORY CODE BLANK ?
     C           PNKOJ     IFEQ *BLANK
     C                     SETON                     3032
     C                     MOVELER,2      MSG
     C                     GOTO #CHK1
     C                     END
     C*
     C* DOCK CODE BLANK ?
     C           PNUKE     IFEQ *BLANK
     C                     SETON                     3033
     C                     MOVELER,3      MSG
     C                     GOTO #CHK1
     C                     END
     C*
     C* SHIPPING DATE
     C           PNOHZ     IFEQ 0
     C                     SETON                     3034
     C                     MOVELER,4      MSG
     C                     GOTO #CHK1
     C                     END
      *
     C           PNOMM     IFLT 1
     C           PNOMM     ORGT 12
     C                     SETON                     3034
     C                     MOVELER,5      MSG
     C                     GOTO #CHK1
     C                     END
      *
     C           PNODD     IFLT 1
     C           PNODD     ORGT 31
     C                     SETON                     3034
     C                     MOVELER,5      MSG
     C                     GOTO #CHK1
     C                     END
     C* BIN
     C           BIN       IFEQ 0
     C                     SETON                     3035
     C                     MOVELER,6      MSG
     C                     GOTO #CHK1
     C                     END
JW5   * CHECK ORDER
 .   C                     EXSR @ITEM
 .   C           @ITM      IFEQ 0
 .   C                     SETON                     3031
 .   C                     MOVELER,16     MSG
 .   C                     GOTO #CHK1
JW5  C                     ENDIF
     C*
     C           #CHK1     ENDSR
     C***********************************************************
     C* @CHK2:CHECK SFL
     C***********************************************************
     C           @CHK2     BEGSR
     C*
     C                     SETOF                     89
     C                     Z-ADD1         RRN
     C                     DO   W1RRN
     C           RRN       CHAINSFL01                94
     C*
     C           *IN94     IFEQ '0'
     C           @FLAG     IFNE *BLANK
     C           @#LAB     ORNE *ZERO
     C                     SETON                     89
     C                     END
     C                     END
     C*
     C* NOT USE # OF LABELS FOR ASI
     C           PNONY     IFEQ '0871'
JW4  C           PNONY     OREQ '0873'
