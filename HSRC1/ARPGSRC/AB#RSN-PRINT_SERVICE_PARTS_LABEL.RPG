     C*
     C* ORDER# SELECTED ?
     C           PORD#     IFNE *BLANK
     C           PORD#     IFNE BAODRN
     C                     GOTO #READ8
     C                     END
     C                     END
     C*
     C           BIN       IFNE BANOBN
     C                     GOTO #READ8
     C                     END
     C*
     C           BAUSYS    IFEQ *ZERO
     C           BASYOS    ANDEQ*ZERO
     C                     MOVELWMHIN     I2PART           PART
     C                     MOVE *ALL'*'   I2SBAN           KANBAN #
     C                     MOVE *ALL'*'   I2QTY            QTY
     C                     MOVE *ALL'*'   I2DOCK           DOCK CODE
     C                     MOVE *ALL'*'   I2ADDR           STORE ADDRESS
     C                     MOVE *ALL'*'   I2SIRE           CUSTOMER CODE
     C                     MOVE *ALL'*'   I2PNAM           PART NAME
     C                     MOVE *ALL'*'   I2IPAR           INTERNAL PART
