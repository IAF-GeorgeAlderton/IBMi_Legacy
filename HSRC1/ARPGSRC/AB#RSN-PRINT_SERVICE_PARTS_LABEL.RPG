     C                     MOVELPOQTY     @@QTY1  5        QTY
      *
     C                     MOVELPOQTY     I2UNIT           QTY/CONT
      *
     C                     DO   W#LAB
     C                     WRITEAB#WP2I1
      *
JW5  C                     MOVEL'AB#WP2I 'IXWRKF    P
.    C                     EXSR #XP01
      *
     C                     END
