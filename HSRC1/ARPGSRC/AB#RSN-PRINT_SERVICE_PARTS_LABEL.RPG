     C                     MOVE H2LOC2    EKLOC2
     C                     MOVE H2LOC3    EKLOC3
     C                     MOVE H2LOC4    EKLOC4
     C*
B1   C           *IN88     IFEQ '1'
     C* USER SELECTED NUMBER OF LABEL
     C           @#LAB     IFNE *ZERO
     C                     Z-ADD@#LAB     Q
     C                     MOVE WSYS      H2SYOS           QTY
     C*
     C           1         DO   Q
     C           @@SRYO    IFGE WSYS
     C                     MOVE WSYS      H2SYOS
     C                     ELSE
     C                     MOVE @@SRYO    H2SYOS
     C                     ENDIF
     C                     SUB  WSYS      @@SRYO
     C                     EXSR @NMBR
     C                     MOVE N3NMBR    H2SERL
     C                     MOVELPNONY     H2SERL
      *
     C                     EXSR #PP70
     C                     DO   W#LAB
     C                     WRITEAB#WP2L1
      *
JW5  C                     MOVEL'AB#WP2L 'IXWRKF    P
.    C                     EXSR #XP01
      *
     C                     END
     C                     END
     C                     GOTO #READ0
     C*
     C                     ELSE
     C           @FLAG     IFEQ *BLANK
     C                     GOTO #READ0
     C                     END
     C*
E2   C                     END
E1   C                     END
     C*
     C* USER ONLY MARKED
     C           BASRYO    DIV  WSYS      Q
     C                     MVR            WRST    40
     C           WRST      IFNE *ZERO
