     H            Y.
     F** BTCR02 *********************************************
     F* UPDATE PT PLAN PUBLICATION MANAGEMENT M/F           *
     F*    ITS.             2013.11.14                      *
     F*******************************************************
     FBTCWP01 IF  E                    DISK
     FAGDPL12 IF  E           K        DISK
     FBTCWP02 O   E                    DISK                      A
      *
     I            DS
     I                                        1   80F8KA
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
      *
     I            DS
     I                                        1   80##DT
     I                                        1   40##YY
     I                                        5   60##MM
     I                                        7   80##DD
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  140SDATE
     I                                        1   60STIME
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C                     READ BTCWP011                 80
     C           *IN80     DOWEQ'0'
     C                     EXSR #SB400
     C                     READ BTCWP011                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C           KEYDT     KLIST
     C                     KFLD           ##YY
     C                     KFLD           ##MM
     C                     KFLD           ##DD
     C                     Z-ADD1         X       30
     C                     Z-ADDW1YMD1    ##DT
     C                     Z-ADDW1BOX     WKBOX   30
     C           W1TIMS    MULT W1BOX1    WKBOX1  30
     C           KEYDT     SETLLAGDPL121
     C                     READ AGDPL121                 20
     C           *IN20     DOWEQ'0'
     C           X         ANDLEW1TIMS
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    OREQ *BLANK
     C                     EXSR #SB500
     C                     ADD  1         X
     C                     ENDIF
     C                     READ AGDPL121                 20
     C                     ENDDO
      *
     C           WKBOX     SUB  WKBOX1    WKSA    30
     C                     MOVEL'0'       GET     1
     C           WKSA      IFGT 0
     C           *IN20     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    OREQ *BLANK
     C                     EXSR #SB510
     C                     MOVEL'1'       GET     1
     C                     ENDIF
     C                     READ AGDPL121                 20
     C                     ENDDO
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARBTCWP021
     C                     MOVELW1GRP     W2GRP
     C                     MOVELW1SEQ     W2SEQ
     C                     MOVELW1SHN1    W2SHN1
     C                     MOVELW1SHN2    W2SHN2
     C                     MOVELW1SHN3    W2SHN3
     C                     Z-ADDF8KA      W2KEHZ
     C           W1SIGN    IFEQ '-'
     C                     Z-ADDW1BOX1    W2MH
     C                     ELSE
     C                     Z-ADDW1BOX1    W2PH
     C                     ENDIF
     C                     WRITEBTCWP021
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB510    BEGSR
      *
     C                     CLEARBTCWP021
     C                     MOVELW1GRP     W2GRP
     C                     MOVELW1SEQ     W2SEQ
     C                     MOVELW1SHN1    W2SHN1
     C                     MOVELW1SHN2    W2SHN2
     C                     MOVELW1SHN3    W2SHN3
     C                     Z-ADDF8KA      W2KEHZ
     C           W1SIGN    IFEQ '-'
     C                     Z-ADDWKSA      W2MH
     C                     ELSE
     C                     Z-ADDWKSA      W2PH
     C                     ENDIF
     C                     WRITEBTCWP021
      *
     CSR         ESB510    ENDSR
