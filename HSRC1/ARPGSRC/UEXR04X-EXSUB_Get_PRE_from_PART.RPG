     I                                        6   6 K@BAN4
      *
     I            DS
     I                                        1   6 K#BANA
     I                                        1   1 K#BAN1
     I                                        2   3 K#BAN2
     I                                        4   5 K#BAN3
     I                                        6   6 K#BAN4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
      *
     C                     EXSR #INIT
      *
     C           KEYCF1    SETLLAH#TL191
     C           KEYCF2    READEAH#TL191                 21
     C           *IN21     DOWEQ'0'
     C           CFSKJY    IFEQ 'D'
     C           CFSKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #SB410
     C                     ENDIF
     C           KEYCF2    READEAH#TL191                 21
     C                     ENDDO
      *
     C                     MOVELMINO      P@MINO
     C                     MOVELMINASI    P@MINA
     C                     MOVELPRE       P@PRE
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------*
      * ALDRS1                                           *
      *--------------------------------------------------*
     C           #SB410    BEGSR
      *
     C                     MOVE CFCHYU    PHCHYU
     C                     MOVE CFZENO    PHZENO
     C                     MOVE CFTHNO    PHTHNO
     C                     MOVE CFHTHZ    PHHTHZ
     C                     CALL 'ALDRS1'
     C                     PARM           PHCHYU  1
     C                     PARM           PHZENO  4
     C                     PARM           PHTHNO  3
     C                     PARM           PHHTHZ  8
     C                     PARM           PHMAIS  4
     C                     MOVE PHMAIS    @@MAIS  40
     C           @@MAIS    IFLT CFMAIS
     C                     EXSR #SB411
     C                     ENDIF
      *
     C           ESB410    ENDSR
      *--------------------------------------------------*
      * LOAD,UNLOAD                                      *
      *--------------------------------------------------*
     C           #SB411    BEGSR
      *
     C                     Z-ADD0         P@PKHZ
     C                     MOVEL*BLANK    W1PDAY  1
     C                     EXSR ##PIC
      *
     C                     Z-ADD0         P@WIHZ
     C                     MOVEL*BLANK    W1WDAY  1        PROCESS DATE
     C                     EXSR ##WIN
     C           W1WDAY    IFEQ *BLANK
     C                     EXSR ##WIN2
     C                     ENDIF
     C                     SETOF                     79
     C           'SB '     LOKUPOKO                      79
     C           W1WDAY    IFEQ *BLANK
     C           *IN79     IFEQ '1'
     C                     EXSR ##WIN3
     C                     ENDIF
     C                     ENDIF
      * SCALE DATE/TIME
     C                     Z-ADD0         P@KEHZ
     C                     MOVEL*BLANK    W1KDAY  1        SCALE DATE
     C                     EXSR ##KEI
     C           W1KDAY    IFEQ *BLANK
     C                     EXSR ##KEI2
     C                     ENDIF
      * PURCHASE DATE/TIME
     C                     MOVEL*BLANK    P@OTHZ
     C                     MOVEL*BLANK    W1ODAY  1        SCALE DATE
     C                     EXSR ##OUTS
      *
     C                     SELEC
     C           W1WDAY    WHEQ *BLANK
     C           W1KDAY    ANDEQ*BLANK
     C           W1PDAY    ANDEQ*BLANK
     C           W1ODAY    ANDEQ*BLANK
     C           CFHT      IFLE WWCM
     C                     ADD  CFMAIS    MINO
     C                     ENDIF
     C           W1WDAY    WHEQ '1'
     C           W1KDAY    OREQ '1'
     C           W1PDAY    OREQ '1'
     C           W1ODAY    OREQ '1'
     C                     EXSR #SB420
     C                     EXSR #SB421
     C           CFMAIS    SUB  XFMAIS    WFMAIS
     C                     SUB  SAITE     WFMAIS
     C           W1WDAY    IFEQ '1'
     C           W1KDAY    OREQ '1'
     C           W1ODAY    OREQ '1'
     C                     ADD  WFMAIS    MINASI
     C                     ENDIF
     C           W1WDAY    IFEQ *BLANK
     C           W1KDAY    ANDEQ*BLANK
     C           W1ODAY    ANDEQ*BLANK
     C           W1PDAY    ANDEQ'1'
     C                     ADD  WFMAIS    PRE
     C                     ENDIF
     C                     ENDSL
      *
     C           ESB411    ENDSR
      *--------------------------------------------------*
      * MINASI                                           *
      *--------------------------------------------------*
     CSR         #SB420    BEGSR
      *
     C                     Z-ADD0         WFMAIS  30
     C                     Z-ADD0         XFMAIS  30
     C                     Z-ADD0         SAITE   30
     C           K#L30     KLIST
     C                     KFLD           CFZENO
     C                     KFLD           CFTHNO
     C           K#L30     SETLLALDPL301
     C           K#L30     READEALDPL301                 16
     C           *IN16     DOWEQ'0'
     C           A3SYDT    IFGE CFHTHZ
     C                     Z-ADD*ZERO     I       30
      *
     C           WKCKSU    CHECKA3PAGE                   25
     C           *IN25     IFEQ '1'
     C                     MOVEL'01'      A3PAGE
     C                     ENDIF
      *
     C                     MOVE A3PAGE    I
     C           I         IFLE CFMAIS
     C                     ADD  1         XFMAIS
     C                     ENDIF
     C                     ENDIF
     C           K#L30     READEALDPL301                 16
     C                     ENDDO
      *
      *
     CSR         ESB420    ENDSR
      *--------------------------------------------------*
      * MINASI                                           *
      *--------------------------------------------------*
     CSR         #SB421    BEGSR
      *
     C           K#AD01    KLIST
     C                     KFLD           K@KSKB  1
     C                     KFLD           CFZENO
     C                     KFLD           CFTHNO
     C                     MOVEL'A'       K@KSKB
     C           K#AD01    SETLLADAPL01
     C           K#AD01    READEADAPL01                  91
     C           *IN91     DOWEQ'0'
     C           ADDTKB    IFEQ 'S'
     C           NUM       CHECKADPGNO                   90
     C           *IN90     IFEQ '0'
     C                     MOVELADPGNO    W@A2@2  20
     C           W@A2@2    IFLE CFMAIS
     C           CFHTHZ    ANDLTADKODT
     C                     ADD  1         SAITE
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           K#AD01    READEADAPL01                  91
     C                     ENDDO
      *
     CSR         ESB421    ENDSR
      *===============================================================
      *         PICUP DATE/TIME
      *===============================================================
     CSR         ##PIC     BEGSR
      *
     C                     CALL 'ALCRS1'
     C                     PARM           CFCHYU  1
     C                     PARM CFZENO    CFZENO  4
     C                     PARM CFTHNO    CFTHNO  3
     C                     PARM CFHTHZ    P@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@PKHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@PKTM  60       WORK ADMITTABLE TIME
      *
     C           P@PKHZ    IFNE 0
     C                     MOVEL'1'       W1PDAY
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *         PROCESS DATE/TIME 1
      *===============================================================
     CSR         ##WIN     BEGSR
     C                     CALL 'AJSR1Z'
     C                     PARM CFHIN1    P@HIN1  5        PART NUMBER 1
     C                     PARM CFHIN2    P@HIN2  5        PART NUMBER 2
     C                     PARM CFHIN3    P@HIN3  2        PART NUMBER 3
     C                     PARM CFTHNO    P@THAI  3        PRODUCTION ORDER
     C                     PARM CFHTHZ    P@HTHZ  80       KANBAN PUBLICATION
      *                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
      *
     C           P@WIHZ    IFNE 0
     C                     MOVEL'1'       W1WDAY
     C                     ENDIF
      *
     CSR                   ENDSR
      *===============================================================
      *       PROCESS DATE/TIME 2
      *===============================================================
     CSR         ##WIN2    BEGSR
     C                     CALL 'AJSR2Z'
     C                     PARM CFHIN1    P@HIN1  5        PART NUMBER 1
     C                     PARM CFHIN2    P@HIN2  5        PART NUMBER 2
     C                     PARM CFHIN3    P@HIN3  2        PART NUMBER 3
     C                     PARM CFTHNO    P@THAI  3        PRODUCTION ORDER
     C                     PARM CFHTHZ    P@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
      *
     C           P@WIHZ    IFNE 0
     C                     MOVEL'1'       W1WDAY
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *        PROCESS DATE/TIME 3
      *===============================================================
     CSR         ##WIN3    BEGSR
     C                     CALL 'ALMR0Z'
     C                     PARM CFHIN1    P@HIN1  5        PART NUMBER 1
     C                     PARM CFHIN2    P@HIN2  5        PART NUMBER 2
     C                     PARM CFHIN3    P@HIN3  2        PART NUMBER 3
     C                     PARM CFTHNO    P@THAI  3        PRODUCTION ORDER
     C                     PARM CFHTHZ    P@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
      *
     C           P@WIHZ    IFNE 0
     C                     MOVEL'1'       W1WDAY
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *      SCALES DATE/TIME 1
      *===============================================================
     CSR         ##KEI     BEGSR
     C                     CALL 'AJHR2Z'
     C                     PARM CFHIN1    P@HIN1  5        PART NUMBER 1
     C                     PARM CFHIN2    P@HIN2  5        PART NUMBER 2
     C                     PARM CFHIN3    P@HIN3  2        PART NUMBER 3
     C                     PARM CFTHNO    P@THAI  3        PRODUCTION ORDER
     C                     PARM CFHTHZ    P@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@KEHZ  80       WEIGHING DATE
     C                     PARM           P@KETM  60       WEIGHING TIME
      *
     C           P@KEHZ    IFNE 0
     C                     MOVEL'1'       W1KDAY
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *        SCALES DATE/TIME 2
      *===============================================================
     CSR         ##KEI2    BEGSR
     C                     CALL 'AJHR2W'
     C                     PARM CFHIN1    P@HIN1  5        PART NUMBER 1
     C                     PARM CFHIN2    P@HIN2  5        PART NUMBER 2
     C                     PARM CFHIN3    P@HIN3  2        PART NUMBER 3
     C                     PARM CFTHNO    P@THAI  3        PRODUCTION ORDER
     C                     PARM CFHTHZ    P@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@KEHZ  80       WEIGHING DATE
     C                     PARM           P@KETM  60       WEIGHING TIME
      *
     C           P@KEHZ    IFNE 0
     C                     MOVEL'1'       W1KDAY
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *         PURCHASE DATE/TIME
      *===============================================================
     C           ##OUTS    BEGSR
      *
     C                     CALL 'AFARS1'
     C                     PARM           CFCHYU  1
     C                     PARM CFZENO    CFZENO  4
     C                     PARM CFTHNO    P@THAI  3        PRODUCTION ORDER
     C                     PARM CFHTHZ    P@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@OTHZ  8
     C                     PARM           P@PNHZ  8
     C                     PARM           P@RCHZ  8
     C                     PARM           P@OMAI  4
      *
     C                     MOVE P@OTHZ    W@OTHZ  80
     C           W@OTHZ    IFNE 0
     C                     MOVEL'1'       W1ODAY
     C                     ENDIF
     C*
     C                     ENDSR
      *=============================================================
      *                    INITIAL PROCESS
      *=============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@BHB1  5
     C                     PARM           P@BHB2  5
     C                     PARM           P@BHB3  2
     C                     PARM           P@MINO 11
     C                     PARM           P@MINA 11
     C                     PARM           P@PRE  11
      *
     C                     MOVE *ALL'0'   P@MINO
     C                     MOVE *ALL'0'   P@MINA
     C                     MOVE *ALL'0'   P@PRE
      *
     C                     Z-ADD0         MINO   110
     C                     Z-ADD0         MINASI 110
     C                     Z-ADD0         PRE    110
      *
     C           KEYCF1    KLIST
     C                     KFLD           P@BHB1
     C                     KFLD           P@BHB2
     C                     KFLD           P@BHB3
     C                     KFLD           WW10YY
     C                     KFLD           WW10MM
     C                     KFLD           WW10DD
      *
     C           KEYCF2    KLIST
     C                     KFLD           P@BHB1
     C                     KFLD           P@BHB2
     C                     KFLD           P@BHB3
      *
     C                     Z-ADD0         WWTOHZ  80
     C                     Z-ADD0         WWZNHZ  80
     C                     Z-ADD0         WWYOHZ  80
     C                     Z-ADD0         WWCIBI  20
     C                     READ AAIPL111                 20
     C           *IN20     IFEQ '0'
     C                     Z-ADDCDTOHZ    WWTOHZ
     C                     Z-ADDCDZNHZ    WWZNHZ
     C                     Z-ADDCDYOHZ    WWYOHZ
     C                     Z-ADDCDCIBI    WWCIBI
     C                     ENDIF
      * 10DAYS
     C           KEYF8     KLIST
     C                     KFLD           K1YY    40
     C                     KFLD           K1MM    20
     C                     KFLD           K1DD    20
     C                     Z-ADDWWTOHZ    K1HZ
     C                     Z-ADD0         WW10DY  80
     C                     Z-ADD1         X       20
     C           KEYF8     SETGTAGDPL121
     C                     READPAGDPL121                 20
     C           *IN20     DOWEQ'0'
     C           X         ANDLE10
     C           F8HIRU    IFEQ *BLANK
     C                     Z-ADDF8KA      WW10DY
     C                     ADD  1         X
     C                     ENDIF
     C                     READPAGDPL121                 20
     C                     ENDDO
      * PICK UP COMPLETE
     C                     Z-ADD1         X
     C                     Z-ADD0         WWBIN   20
     C           X         DOWLE24
     C           DT,X      IFNE *BLANK
     C                     Z-ADDBI,X      WWBIN
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
     C                     Z-ADDWWTOHZ    WWCMHZ
     C           WWBIN     SUB  3         WWCMBB
     C           WWCMBB    IFLE 0
     C                     Z-ADDWWZNHZ    WWCMHZ
     C                     ADD  WWCIBI    WWCMBB
     C                     ENDIF
      *
     C                     ENDSR
