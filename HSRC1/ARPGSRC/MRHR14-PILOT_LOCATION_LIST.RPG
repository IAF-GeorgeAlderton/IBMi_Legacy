     H            Y.
     F** MRHR14 ******************************************
     F* PILOT LOCATION LIST                              *
     F*   ITS.    2014.05.16                             *
     F****************************************************
     FMRHWP13 IF  E           K        DISK
     FMRHPR14 O   E             55     PRINTER
      *
     I            DS
     I                                        1  14 D1SHN
     I                                        1   5 D1SHN1
     I                                        6   6 D1SF1
     I                                        7  11 D1SHN2
     I                                       12  12 D1SF2
     I                                       13  14 D1SHN3
      *
     I            DS
     I                                        1   9 D1TKR
     I                                        1   1 D1TKR1
     I                                        2   2 D1TF1
     I                                        3   4 D1TKR2
     I                                        5   5 D1TF2
     I                                        6   7 D1TKR3
     I                                        8   8 D1TF3
     I                                        9   9 D1TKR4
      *
     I            DS
     I                                        1  12 W0HIN
     I                                        1   5 W0HIN1
     I                                        6  10 W0HIN2
     I                                       11  12 W0HIN3
      *
     I            DS
     I                                        1   7 W0LN
     I                                        1   4 W0LNO1
     I                                        5   7 W0LNO2
      *
     I            DS
     I                                        1   80H1IYMD
     I                                        1   2 H1IMM
     I                                        3   4 H1IDD
     I                                        5   8 H1IYY
     I*<<システム日時>>
     I            DS
     I                                        1  140S@TIME
     I                                        1   60S@HMS
     I                                        1   20S@TMHH
     I                                        3   40S@TMMM
     I                                        5   60S@TMSS
     I                                        7  140S@YYMD
     I                                        7  100S@DYYY
     I                                       11  120S@DYMM
     I                                       13  140S@DYDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *-------------------*
      * INIT              *
      *-------------------*
     C                     EXSR #SB100
     C                     READ MRHWP131                 81
     C           *IN81     DOWEQ'0'
     C           *IN55     IFEQ '1'
     C                     WRITEMRHPR141
     C                     SETOF                     55
     C                     ENDIF
     C                     EXSR #SB400
     C                     READ MRHWP131                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-------------------*
      * TITLE             *
      *-------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           S@TIME
     C                     Z-ADD0         H1IYMD
     C                     MOVE S@DYMM    H1IMM
     C                     MOVE S@DYDD    H1IDD
     C                     MOVE S@DYYY    H1IYY
     C                     WRITEMRHPR141
     C                     SETOF                     55
      *
     CSR         ESB100    ENDSR
      *-------------------*
      * DETAIL            *
      *-------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVELW0BAN1    D1BAN1
     C                     MOVELW0BAN2    D1BAN2
     C                     MOVELW0BAN3    D1BAN3
     C                     MOVELW0BAN4    D1BAN4
     C                     Z-ADDW0HAKO    D1HAKO
     C                     MOVEL*BLANK    D1SHN
     C           W0HIN     IFNE *BLANK
     C                     MOVELW0HIN1    D1SHN1
     C                     MOVEL'-'       D1SF1
     C                     MOVELW0HIN2    D1SHN2
     C                     MOVEL'-'       D1SF2
     C                     MOVELW0HIN3    D1SHN3
     C                     ENDIF
     C                     MOVEL*BLANK    D1THI
     C           W0LN      IFNE *BLANK
     C           D1THI     CAT  W0LNO1:0  D1THI
     C           D1THI     CAT  '-':0     D1THI
     C           D1THI     CAT  W0LNO2:0  D1THI
     C                     ENDIF
      *
     C                     MOVELW0DVNM    D1DVNM
     C                     MOVELW0DPNM    D1DPNM
      *
     C                     MOVEL*BLANK    D1FINT
     C                     MOVEL*BLANK    D1TKR
     C           W2STRK    IFNE *BLANK
     C                     MOVELW2STRK    D1TKR1
     C                     MOVEL'-'       D1TF1
     C                     MOVELW2STRT    D1TKR2
     C                     MOVEL'-'       D1TF2
     C                     MOVELW2STRR    D1TKR3
     C                     MOVEL'-'       D1TF3
     C                     MOVELW2STRD    D1TKR4
     C                     MOVELD1TKR     D1FINT
     C                     ENDIF
      *
     C                     MOVEL*BLANK    D1SERT
     C                     MOVEL*BLANK    D1TKR
     C           W3STRK    IFNE *BLANK
     C                     MOVELW3STRK    D1TKR1
     C                     MOVEL'-'       D1TF1
     C                     MOVELW3STRT    D1TKR2
     C                     MOVEL'-'       D1TF2
     C                     MOVELW3STRR    D1TKR3
     C                     MOVEL'-'       D1TF3
     C                     MOVELW3STRD    D1TKR4
     C                     MOVELD1TKR     D1SERT
     C                     ENDIF
      *
     C                     WRITEMRHPR142
      *
     CSR         ESB400    ENDSR
