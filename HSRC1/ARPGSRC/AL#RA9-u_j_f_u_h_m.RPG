     H            Y.
     F** AL#RA9  *******************************************
     F*発行データから再発行ワーク作成                    *
     F*      ITS.        2015.06.15                        *
     F******************************************************
     FAL#PL72 IF  E           K        DISK
     FAL#WPA9 UF  E           K        DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1DATE  80
     C                     PARM           P9CMD   2
      *
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      *
     C           KEYC1     KLIST
     C                     KFLD           KKKADT  80
      *
     C                     MOVE P1DATE    KKKADT
     C           KEYC1     SETLLAL#PL721
     C           KEYC1     READEAL#PL721                 81
     C           *IN81     DOWEQ'0'
     C           C7SKJY    IFEQ 'D'
     C           C7SKHZ    ANDLESDATE
     C                     ELSE
     C                     EXSR #SB500
     C                     ENDIF
     C           KEYC1     READEAL#PL721                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AL#WP49
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C           KEYW0     KLIST
     C                     KFLD           C7FIXD
     C                     KFLD           C7FIXT
     C                     KFLD           C7TRKB
     C                     KFLD           C7IAFB
      *
     C           KEYW0     CHAINAL#WPA91             22
     C           *IN22     IFEQ '0'
     C                     ADD  C7BOX     W9BOX
     C                     ADD  1         W9KPLT
     C                     UPDATAL#WPA91
     C                     ELSE
     C                     CLEARAL#WPA91
     C                     MOVEL*BLANK    W9SEL
     C                     MOVELC7SURT    W9SURT
     C                     Z-ADDC7EXTR    W9EXTR
     C                     Z-ADDC7FIXD    W9FIXD
     C                     Z-ADDC7FIXT    W9FIXT
     C                     Z-ADDC7TIMS    W9TIMS
     C                     Z-ADDC7BOX     W9BOX
     C                     Z-ADD1         W9KPLT
     C                     MOVELC7TRKB    W9TRKB
     C                     MOVELC7IAFB    W9IAFB
     C                     MOVELC7SHI1    W9SHI1
     C                     MOVELC7SHI2    W9SHI2
     C                     MOVELC7SHI3    W9SHI3
     C                     WRITEAL#WPA91
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
