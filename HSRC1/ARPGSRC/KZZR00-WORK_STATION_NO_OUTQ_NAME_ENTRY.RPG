     H            Y.
     F** KZZR00 ******************************************
     F* ...WORK STATION NO OUTQ-NAME INPUT              *
     F* ...TYPE K=KANA , G=KANJI PRTG KANJIOUTQ *
     F*         I-HASADA                91.05.23         *
     F****************************************** KZZR00 **
     FAJEPL01 IF  E           K        DISK
     I            DS
     I                                        1  10 UWS
     I                                        1   2 UKEY
     C           *ENTRY    PLIST
     C                     PARM           WSID   10
     C                     PARM           PRT     7
     C                     PARM           TYPE    1
     C                     PARM           PRTG   10
     C                     MOVE WSID      UWS
      *
     C           KPAR1     PLIST
     C                     PARM           PKINO   1
      *
     C           KEY1      KLIST
     C                     KFLD           PKINO
     C                     KFLD           UKEY
      *
     C                     CALL 'AJEC06'  KPAR1
      *
     C                     SETOF                     01
     C           KEY1      CHAINAJEPL011             01
     C           *IN01     IFEQ '0'
     C                     MOVE H4SPLF    PRT
     C                     MOVE H4WSTY    TYPE
     C                     MOVELH4SPIG    PRTG
     C                     ELSE
      *
     C           PKINO     IFEQ '1'
     C                     MOVE 'QPRINT ' PRT
     C                     MOVE 'G'       TYPE
     C                     MOVEL'QPRINTE' PRTG
     C                     END
      *
     C           PKINO     IFEQ '2'
     C                     MOVE 'QPRINTJ' PRT
     C                     MOVE 'G'       TYPE
     C                     MOVEL'QPRINTJ' PRTG
     C                     END
      *
     C           PKINO     IFEQ '3'
     C           PKINO     OREQ '4'
     C                     MOVE 'QPRINT ' PRT
     C                     MOVE 'G'       TYPE
     C                     MOVEL'QPRINT ' PRTG
     C                     END
     C                     END
      *
     C                     CALL 'AJEC12'
      *
     C                     SETON                     LR
     C                     RETRN
