     C*================================================================
     C*           PARM LIST                                          *
     C*================================================================
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C*================================================================
     C*           KEY LIST                                           *
     C*================================================================
     C*** INPORT GOODS UNIT PRICE M/F *** (GDKPL01)
     C           ISKEY2    KLIST
     C                     KFLD           D1VEND
     C                     KFLD           D1TYPE
     C                     KFLD           D1HIN
     C*
     C* AOYAMA PRODUCTION PLACE CALENDAR FILE(INCLUDE HOLIDAY)
     C           F8KEY     KLIST
     C                     KFLD           WWYY
     C                     KFLD           WWMM
     C                     KFLD           WWDD
     C*================================================================
     C*           MAIN ROUTINE                                       *
     C*================================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#SET1   '#SET1
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C           @STEP     CASEQ'#CHK2U  '#CHK2
     C           @STEP     CASEQ'#UPD    '#UPD
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*================================================================
     C*  INIT
     C*================================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     SETON                     OF
     C                     MOVE '1'       D1UPDT
     C                     MOVE *BLANK    D1VEND
     C                     MOVE *BLANK    D1TYPE
     C                     MOVE *BLANK    D1HIN
     C                     MOVE *BLANK    D1TYPE
     C                     MOVE *BLANK    D1ERR
     C*
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
     C*================================================================
     C*  DSP1
     C*================================================================
     C           #DSP1     BEGSR
     C                     EXFMTDSP01
     C                     MOVE '#CHK1   '@STEP
     C* < F1=ON >
     C           *INKA     IFEQ *ON
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C                     ENDSR
     C*================================================================
     C*  CHK1
     C*================================================================
     C           #CHK1     BEGSR
     C                     MOVEA'0000'    *IN,11           <11 - 14>
     C                     MOVEA'0'       *IN,99           <99>
     C                     MOVE *BLANK    D1ERR
     C*
     C** UPDATE **
     C*
     C           D1UPDT    IFNE '0'
     C           D1UPDT    ANDNE'1'
     C           D1UPDT    ANDNE'2'
     C  N99                MOVELMSG,1     D1ERR
     C                     SETON                     9911
     C                     ENDIF
     C*
     C** VENDOR **
     C*
     C                     MOVE *BLANK    D2VDNM
     C           D1VEND    IFEQ *BLANK
     C  N99                MOVELMSG,4     D1ERR
     C                     SETON                     9912
     C                     ELSE
     C                     MOVELD1VEND    B2CODE
     C           B2CODE    CHAINFGBPL011             90
     C           *IN90     IFEQ *ON
     C  N99                MOVELMSG,7     D1ERR
     C                     SETON                     9912
     C                     ELSE
     C                     MOVELB2SMEI    D2VDNM
     C                     ENDIF
     C                     ENDIF
     C*
     C** PART TYPE **
     C*
     C                     Z-ADD1         J       20
     C           D1TYPE    LOKUPPT,J                     90
S1   C           *IN90     IFEQ *OFF
     C  N99                MOVELMSG,1     D1ERR
     C                     SETON                     9913
X1   C                     ELSE
     C                     MOVELPTN,J     D2PTNM
E1   C                     ENDIF
     C*
     C** PARTS NO *
     C*
     C           D1HIN     IFEQ *BLANK
     C  N99                MOVELMSG,4     D1ERR
     C                     SETON                     9914
     C                     ENDIF
     C*
     C** PARTS NO ??????????????????????
     C*
     C           D1TYPE    IFEQ '0'                        FNINSHED PARTS
     C           D1TYPE    OREQ '3'                        WASHER
     C           D1TYPE    OREQ '6'                        HALF-FINISHED PARTS
     C           D1HINX    IFNE *BLANK                     <HIN 13-20
     C  N99                MOVELMSG,9     D1ERR
     C                     SETON                     9914
     C                     ENDIF
     C                     ENDIF
     C*
     C           D1TYPE    IFEQ 'K'                        DIE
     C           D1HINY    IFNE *BLANK                     <HIN 9-20
     C  N99                MOVELMSG,9     D1ERR
     C                     SETON                     9914
     C                     ENDIF
     C                     ENDIF
     C*
     C** FILE **
     C*
S1   C           *IN99     IFEQ *OFF
     C           ISKEY2    SETGTGDKPL011
     C                     MOVE ' '       @@SAKJ  1
     C                     DO   *HIVAL
     C           ISKEY2    REDPEGDKPL011            N    90
     C   90                LEAVE
     C           ISSKJY    IFEQ 'D'                        DELETE CODE
     C           ISSKHZ    ANDLE*DATE                      DELETE DATE
     C                     MOVE '1'       @@SAKJ
     C                     ITER
     C                     ENDIF
     C                     LEAVE
     C                     ENDDO
     C*
 S2  C           *IN90     IFEQ *ON
     C  N99                MOVELMSG,2     D1ERR
     C                     SETON                     9914
 E2  C                     ENDIF
     C*
E1   C                     ENDIF
     C*
      *
     C           *IN99     IFEQ *ON
     C                     MOVE '#DSP1   '@STEP
     C                     ELSE
     C                     MOVE '#SET1   '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
     C*================================================================
      *  SET1
     C*================================================================
     C           #SET1     BEGSR
     C*
     C                     MOVEA'0000'    *IN,15           <15-18>
     C                     MOVEA'0'       *IN,51           <51>
     C                     MOVEA'0'       *IN,99           <99>
     C                     MOVE *BLANK    D2ERR
     C                     MOVELD1VEND    D2VEND
     C                     MOVELD1TYPE    D2TYPE
     C                     MOVELD1HIN     D2HIN
     C*
S1   C           D1TYPE    IFEQ '0'                        FNINSHED PARTS
     C           D1TYPE    OREQ '3'                        WASHER
     C           D1TYPE    OREQ '6'                        HALF-FINISHED PARTS
     C                     MOVE *BLANK    D2HIN
     C                     MOVE *BLANK    WWHIN
     C                     MOVE D1HIN1    WWHIN1
     C                     MOVE D1HIN2    WWHIN2
     C                     MOVE D1HIN3    WWHIN3
     C                     MOVE '-'       WWH1
 S2  C           WWHIN3    IFNE *BLANK
     C                     MOVE '-'       WWH2
 E2  C                     ENDIF
     C                     MOVELWWHIN     D2HIN
E1   C                     ENDIF
     C*
S1   C           D1TYPE    IFEQ 'K'                        DIE
     C                     MOVE *BLANK    D2HIN
     C                     MOVE *BLANK    WWKATA
     C                     MOVE D1KAT1    WWKAT1
     C                     MOVE D1KAT2    WWKAT2
     C                     MOVE D1KAT3    WWKAT3
     C                     MOVE D1KAT4    WWKAT4
     C                     MOVE '-'       WWKA1
     C                     MOVE '-'       WWKA2
     C                     MOVE '-'       WWKA3
 S2  C           WWKAT4    IFEQ *BLANK
     C                     MOVE ' '       WWKA3
  S3 C           WWKAT3    IFEQ *BLANK
     C                     MOVE ' '       WWKA2
  E3 C                     ENDIF
 E2  C                     ENDIF
     C                     MOVELWWKATA    D2HIN
E1   C                     END
     C*
     C** FILE **
     C*
     C** SFLCLR **
     C                     SETON                     21
     C                     WRITECTL01
     C                     SETOF                     21
     C                     Z-ADD*ZERO     RRN     40
     C                     Z-ADD*ZERO     LSTRRN  40
     C**
     C           ISKEY2    SETGTGDKPL011
     C*--------------------
S1   C                     DO   *HIVAL
     C           ISKEY2    REDPEGDKPL011            N    90
     C   90                LEAVE
     C           ISSKJY    IFEQ 'D'                        DELETE CODE
     C           ISSKHZ    ANDLE*DATE                      DELETE DATE
     C                     ITER
     C                     ENDIF
     C*
     C                     Z-ADDISSTHZ    S1STDT
     C                     Z-ADDISENHZ    S1ENDT
     C                     Z-ADDISTKP1    S1SEA
     C                     Z-ADDISTKP2    S1AIR
     C                     ADD  1         RRN
     C                     WRITESFL01
E1   C                     ENDDO
     C*--------------------
     C                     Z-ADDRRN       LSTRRN
     C*
     C                     MOVELNAME,2    D2UPNM
     C*
     C                     MOVE '#DSP2   '@STEP
     C*
     C                     ENDSR
     C*================================================================
     C*  DSP2
     C*================================================================
     C           #DSP2     BEGSR
     C                     WRITEDSP02
     C                     SETON                     20
     C                     EXFMTCTL01
     C                     SETOF                     20
     C                     MOVE '#CHK2   '@STEP
     C* < F3=ON >
     C           *INKC     IFEQ *ON
     C                     MOVEA'0'       *IN,99           <99>
     C                     MOVE '#INIT   '@STEP
     C                     ENDIF
     C* < F5=ON >
     C           *INKE     IFEQ *ON
     C                     MOVE '#CHK2U  '@STEP
     C                     ENDIF
     C                     ENDSR
     C*================================================================
     C*  CHK2
     C*================================================================
     C           #CHK2     BEGSR
     C                     MOVEA'0000'    *IN,15           <15-18>
     C                     MOVEA'0'       *IN,99           <99>
     C                     MOVE *BLANK    D2ERR
     C*
     C                     Z-ADD0         @@STDT  80
     C                     Z-ADD0         @@ENDT  80
     C                     Z-ADD0         @@NXST  80       NEXT-STSRT
     C                     Z-ADD0         @@SEA  145
     C                     Z-ADD0         @@AIR  145
     C*--------------------
     C*--------------------
S1   C                     DO   LSTRRN    RRN
     C           RRN       CHAINSFL01                90
     C   90                LEAVE
     C                     MOVEA'0000'    *IN,15           <15-18>
     C                     MOVEA'0'       *IN,98           <98>
     C*
     C           S1STDT    IFEQ 0
     C           S1ENDT    ANDEQ0
     C           S1SEA     ANDEQ0
     C           S1AIR     ANDEQ0
     C                     ELSE
     C                     EXSR #SFCHK
     C                     ENDIF
      *
     C                     UPDATSFL01
E1   C                     ENDDO
     C*--------------------
     C*--------------------
     C*
     C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK2U  '
     C                     MOVE '#UPD    '@STEP
     C                     ELSE
     C                     MOVE '#DSP2   '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
     C*================================================================
     C*
     C*================================================================
     C           #SFCHK    BEGSR
      *
      * STARTING DATE *
      *
S1   C           S1STDT    IFEQ *ZERO
     C  N99                MOVELMSG,4     D2ERR
     C                     SETON                     159998
X1   C                     ELSE
     C                     Z-ADDS1STDT    WWYMD
     C           F8KEY     CHAINAGDPL12              91
 S2  C           *IN91     IFEQ *ON
     C  N99                MOVELMSG,6     D2ERR
     C  N99                SETON                     159998
 E2  C                     ENDIF
E1   C                     ENDIF
      *
      * ENDING DATE *
      *
S1   C           S1ENDT    IFEQ *ZERO
     C  N99                MOVELMSG,4     D2ERR
     C                     SETON                     169998
X1   C                     ELSE
 S2  C           S1ENDT    IFNE 99999999
     C                     Z-ADDS1ENDT    WWYMD
     C           F8KEY     CHAINAGDPL12              91
  S3 C           *IN91     IFEQ *ON
11/17C* N99                MOVELMSG,6     D2ERR
11/17C* N99                SETON                     169998
  X3 C                     ELSE
  S4 C           @@STDT    IFNE 0
     C           S1ENDT    ANDGE@@STDT
     C  N99                MOVELMSG,5     D2ERR
     C  N99                SETON                     169998
  E4 C                     ENDIF
  E3 C                     ENDIF
 E2  C                     ENDIF
E1   C                     ENDIF
      *
      *
S1   C           S1STDT    IFGT S1ENDT
     C  N99                MOVELMSG,5     D2ERR
     C  N99                SETON                       1516
     C  N99                SETON                     9899
E1   C                     ENDIF
      *
      *  UNIT PRICE  BY SEA
      *
S1   C           S1SEA     IFEQ *ZERO
     C  N99                MOVELMSG,4     D2ERR
     C  N99                SETON                     179899
E1   C                     ENDIF
     C*
S1   C           *IN98     IFEQ *OFF
     C                     Z-ADDS1STDT    @@STDT  80
     C                     Z-ADDS1ENDT    @@ENDT  80
     C                     Z-ADDS1SEA     @@SEA  145
     C                     Z-ADDS1AIR     @@AIR  145
E1   C                     ENDIF
     C*
     C                     ENDSR
     C*================================================================
      *    UPD
     C*================================================================
     C           #UPD      BEGSR
      *
      * DELETE
      *
     C           ISKEY2    SETLLGDKPL011
     C*--------------------
S1   C                     DO   *HIVAL
     C           ISKEY2    READEGDKPL011                 90
     C   90                LEAVE
     C           ISSKJY    IFEQ 'D'                        DELETE CODE
     C           ISSKHZ    ANDLE*DATE                      DELETE DATE
     C                     ITER
     C                     ENDIF
     C*
     C                     DELETGDKPL011
E1   C                     ENDDO
     C*--------------------
      *
      * WRITE
      *
     C*--------------------
S1   C                     DO   LSTRRN    RRN
     C           RRN       CHAINSFL01                90
     C   90                LEAVE
     C*
     C           S1STDT    IFEQ 0
     C           S1ENDT    ANDEQ0
     C           S1SEA     ANDEQ0
     C           S1AIR     ANDEQ0
     C                     ELSE
     C                     MOVE ' '       ISSKJY           DELETE CODE
     C                     Z-ADD0         ISSKDT           DELETE DATE
     C                     Z-ADD*DATE     ISKODT
     C                     TIME           W@TIME
     C                     Z-ADDW@HM      ISKOHS
     C                     MOVELPPUSER    ISKOME
     C                     MOVELD2VEND    ISVEND
     C                     MOVELD2TYPE    ISTYPE
     C                     MOVELD1HIN     ISHIN
     C                     MOVEL*BLANK    ISNAME           PARTS NAME
     C                     MOVEL*BLANK    ISKIGO           RATE MARK
     C                     Z-ADD0         ISRATE           RATE
     C                     Z-ADDS1STYY    ISSTYY
     C                     Z-ADDS1STMM    ISSTMM
     C                     Z-ADDS1STDD    ISSTDD
     C                     Z-ADDS1ENYY    ISENYY
     C                     Z-ADDS1ENMM    ISENMM
     C                     Z-ADDS1ENDD    ISENDD
     C                     Z-ADDS1SEA     ISTKP1
     C                     Z-ADDS1AIR     ISTKP2
     C                     WRITEGDKPL011
     C                     ENDIF
      *
E1   C                     ENDDO
     C*--------------------
     C                     MOVE '#INIT   '@STEP
     C*--------------------
     C                     ENDSR
     C*================================================================
**  NAME  **
"0":DELETE
"1":CHANGE
"2":ADD
**  PT
0 FINISHED PARTS
6 HALF-FINESHED PARTS
3 WASHER
M MACHINERY
W WIRE
S INDIRECT MATERIAL
R WIRE ROD
P MACHINERY PARTS
K DIE
**  MSG  **
INPUT ERROR.
UNIT PRICE MASTER FILE NOT FOUND.
UNIT PRICE MASTER FILE FOUND.
NO INPUT ERROR.
DATA OVERLAP.
INCORRECT DATE.
DETAIL M/F <CODE COMPLETION> NOT FOUND.
INPUT ERROR. ONLY THE LATEST RECORD CAN BE ERASED.
INPUT ERROR. THE DIGITS FOR PART NUMBER IS TOO LONG.
