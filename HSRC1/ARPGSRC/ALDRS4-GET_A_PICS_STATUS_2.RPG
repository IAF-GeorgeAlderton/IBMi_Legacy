     H            Y/
      *** ALDRS4 *************************************
      *  GET STATUS OF EACH PAGE A-PICS              *
      *     2019.09.25         T-SAKAKI              *
      ************************************* ALDRS4 ***
     FALDPL39 IF  E           K        DISK
     FADAPL06 IF  E           K        DISK
     FALCPL07 IF  E           K        DISK
      *
     I            DS
     I                                        1   80A3SYDT
     I                                        1   40A3SYYY
     I                                        5   60A3SYMM
     I                                        7   80A3SYDD
     I            DS
     I                                        1   80ADKODT
     I                                        1   40ADKOYY
     I                                        5   60ADKOMM
     I                                        7   80ADKODD
      *
     I            DS
     I                                        1   80K@HTHZ
     I                                        1   40K@SYYY
     I                                        5   60K@SYMM
     I                                        7   80K@SYDD
      *
     C           *ENTRY    PLIST
     C                     PARM           P@CHYU  1
     C                     PARM           P@ZENO  4
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
     C                     PARM           P@THNO  3
     C                     PARM           P@PAGE  2
     C                     PARM           P@HTHZ  8
     C                     PARM           P@BFLG  1         BZ/DS MACHINE
     C                     PARM           P@AFLG  1         JC MACHINE
     C                     PARM           P@SBFL  1         SB工程有無
     C                     PARM           P@MAIS  4
     C                     PARM           P9ALD3  40       出荷照合済み
     C                     PARM           P9ADA1  40       再手配
     C                     PARM           P9NYKO  40       入庫済み
     C                     PARM           P9SRT   40        SRT(CONVEYANCE)
     C                     PARM           P9OUK   40        OUTSOURCE処理後
     C                     PARM           P9BZK   40        BZ計量済み
     C                     PARM           P9DSK   40        DS計量済み
     C                     PARM           P9JCK   40        JC計量済み
     C                     PARM           P9SBK   40        SB計量済み
     C                     PARM           P9LOQK  40        LOQ排出済み
     C                     PARM           P9OUI   40        OUTSOURCE処理中
     C                     PARM           P9BZI   40        BZ投入中
     C                     PARM           P9DSI   40        DS投入中
     C                     PARM           P9JCI   40        JC投入中
     C                     PARM           P9SBI   40        SB投入中
     C                     PARM           P9LOQI  40        LOQ投入中
     C                     PARM           P9PLOU  40        OUTSOURCE出荷前
     C                     PARM           P9PLBZ  40        BZ設備前
     C                     PARM           P9PLDS  40        DS設備前
     C                     PARM           P9PLJC  40        JC設備前
     C                     PARM           P9PLSB  40        SB設備前
     C                     PARM           P9PLLO  40        LOQ設備前
     C                     PARM           P9PRE   40       ＣＶ集荷後
     C                     PARM           P9LPLD  80        LAST PRE DATE
     C                     PARM           P9LPLT  60        LAST PRE TIME
      *
     C                     MOVE P@CHYU    K@CHYU  1
     C                     MOVE P@ZENO    K@ZENO  4
     C                     MOVE P@THNO    K@THNO  3
     C                     MOVE P@HTHZ    K@HTHZ  80
     C                     MOVE P@PAGE    K@PAGE  2
     C                     MOVE P@HIN1    K@SHN1  5
     C                     MOVE P@HIN2    K@SHN2  5
     C                     MOVE P@HIN3    K@SHN3  2
      *
     C           ALDKES    KLIST
     C                     KFLD           K@ZENO  4
     C                     KFLD           K@THNO  3
     C                     KFLD           K@PAGE  2
     C                     KFLD           K@SYYY  40
     C                     KFLD           K@SYMM  20
     C                     KFLD           K@SYDD  20
      *
     C           ALDKEY    KLIST
     C                     KFLD           K@ZENO  4
     C                     KFLD           K@THNO  3
     C                     KFLD           K@PAGE  2
      *
     C           ALJKEY    KLIST
     C                     KFLD           K@ZENO  4
     C                     KFLD           K@THNO  3
      *
     C                     Z-ADD0         @CNT
     C                     Z-ADD0         P9ALD3
     C                     Z-ADD0         P9ADA1
     C                     Z-ADD0         P9NYKO
     C                     Z-ADD0         P9SRT
     C                     Z-ADD0         P9OUK
     C                     Z-ADD0         P9BZK
     C                     Z-ADD0         P9DSK
     C                     Z-ADD0         P9JCK
     C                     Z-ADD0         P9SBK
     C                     Z-ADD0         P9LOQK
     C                     Z-ADD0         P9OUI
     C                     Z-ADD0         P9BZI
     C                     Z-ADD0         P9DSI
     C                     Z-ADD0         P9JCI
     C                     Z-ADD0         P9SBI
     C                     Z-ADD0         P9LOQI
     C                     Z-ADD0         P9PLOU
     C                     Z-ADD0         P9PLBZ
     C                     Z-ADD0         P9PLDS
     C                     Z-ADD0         P9PLJC
     C                     Z-ADD0         P9PLSB
     C                     Z-ADD0         P9PLLO
     C                     Z-ADD0         P9PRE
     C                     Z-ADD0         P9LPLD
     C                     Z-ADD0         P9LPLT
      *
     C                     MOVE P@HTHZ    Q@HTHZ
      *
     C           ALDKES    SETLLALDPL39
     C                     DO   *HIVAL
     C           ALDKEY    READEALDPL39                  77
     C   77                LEAVE
     C***        A3SYDT    IFLT K@HTHZ
     C***                  ITER
     C***                  END
     C                     ADD  1         @CNT    40
     C                     ADD  1         P9ALD3
     C                     ENDDO
      *
     C           ADAKES    KLIST
     C                     KFLD           K@CHYU  1
     C                     KFLD           K@ZENO  4
     C                     KFLD           K@THNO  3
     C                     KFLD           K@SYYY  40
     C                     KFLD           K@SYMM  20
     C                     KFLD           K@SYDD  20
      *
     C           ADAKEY    KLIST
     C                     KFLD           K@CHYU  1
     C                     KFLD           K@ZENO  4
     C                     KFLD           K@THNO  3
      *
     C           ADAKES    SETLLADAPL06
     C                     DO   *HIVAL
     C           ADAKEY    READEADAPL06                  77
     C   77                LEAVE
     C                     MOVELADPGNO    BDPGNO  2
     C           BDPGNO    IFNE P@PAGE
     C                     ITER
     C                     ENDIF
     C                     ADD  1         @CNT    40
     C                     ADD  1         P9ADA1
     C                     LEAVE
     C                     ENDDO
      *
     C                     MOVE @CNT      P@MAIS
     C                     Z-ADD0         P9SRT
      *
     C           @CNT      IFEQ 0
     C                     EXSR #SB401                     入庫
     C                     ELSE
     C                     EXSR #END
     C                     ENDIF
      *
     C           P9NYKO    IFEQ 0
     C                     EXSR #SB411                     SRT
     C                     ELSE
     C                     EXSR #END
     C                     ENDIF
      *
     C           P9SRT     IFEQ 0
     C                     EXSR #SBK                       KEIRYO
     C                     ELSE
     C                     EXSR #END
     C                     ENDIF
      *
     C           P9OUK     IFEQ 0
     C           P9BZK     ANDEQ0
     C           P9DSK     ANDEQ0
     C           P9JCK     ANDEQ0
     C           P9SBK     ANDEQ0
     C           P9LOQK    ANDEQ0
     C                     EXSR #SBI                       TONYU
     C                     ELSE
     C                     EXSR #END
     C                     ENDIF
      *
     C           P9OUI     IFEQ 0
     C           P9BZI     ANDEQ0
     C           P9DSI     ANDEQ0
     C           P9JCI     ANDEQ0
     C           P9SBI     ANDEQ0
     C           P9LOQI    ANDEQ0
     C                     EXSR ##PLOD                     設備前
     C                     ELSE
     C                     EXSR #END
     C                     ENDIF
      *
     C           P9PLOU    IFEQ 0
     C           P9PLBZ    ANDEQ0
     C           P9PLDS    ANDEQ0
     C           P9PLJC    ANDEQ0
     C           P9PLSB    ANDEQ0
     C           P9PLLO    ANDEQ0
     C           P9PRE     ANDEQ0
     C                     EXSR ##PIC                      PRE
     C                     ELSE
     C                     EXSR #END
     C                     ENDIF
      *
     C                     EXSR #END
      *
     C           #END      BEGSR
     C                     EXSR #CLOSE
     C                     SETON                     LR
     C                     RETRN
     C           EEND      ENDSR
      *--------------------------------------------------*
      *入庫                                            *
      *--------------------------------------------------*
     CSR         #SB401    BEGSR
      *
     C                     CALL 'ALDRTA'
     C                     PARM           P@ZENO  4
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PRODUCTION ORDER
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@CODT  80
     C                     PARM           P@COTM  60
     C                     PARM           P#OPN   1
      *
     C           P@CODT    IFNE 0
     C                     ADD  1         P9NYKO
     C                     ENDIF
      *
     CSR         ESB401    ENDSR
      *--------------------------------------------------*
      * SRT                                              *
      *--------------------------------------------------*
     CSR         #SB411    BEGSR
      *
     C           K@ALC     KLIST
     C                     KFLD           K@SHN1  5
     C                     KFLD           K@SHN2  5
     C                     KFLD           K@SHN3  2
     C                     KFLD           K@THNO  3
     C           K@ALC     SETLLALCPL07
      *
     C           *IN95     DOWEQ*OFF
     C           K@ALC     READEALCPL07                  95
1    C           *IN95     IFEQ *OFF
|     *
|2   C           A8DATE    IFGE K@HTHZ
||   C           A8ERR     ANDEQ*BLANK
||   C           A8PAG     ANDEQK@PAGE
||   C                     MOVELA8BRC2    LTR3    3
||3  C           LTR3      IFEQ 'SRT'
|||  C                     ADD  1         P9SRT
|||  C                     LEAVE
||3  C                     ENDIF
|2   C                     ENDIF
|     *
1    C                     ENDIF
      *
     C                     ENDDO
      *
     CSR         ESB411    ENDSR
      *===============================================================
      *         外注日・時刻
      *===============================================================
     C           #OUTS     BEGSR
      *
     C                     CALL 'ALDRT1'
     C                     PARM           P@CHYU  1
     C                     PARM           P@ZENO  4
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PRODUCTION ORDER
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@OTHZ  80
     C                     PARM           P@PNHZ  80
     C                     PARM           P@RCHZ  80
     C                     PARM           P@OUI   4
     C                     PARM           P#OPN   1
      *
     C                     MOVE P@OUI     W@OUI   40
     C                     ADD  W@OUI     P9OUI
     C*
     C                     ENDSR
      *--------------------------------------------------*
      *計量                                            *
      *--------------------------------------------------*
     CSR         #SBK      BEGSR
      *
     C                     EXSR #OUTK                      OUT SOURCE
     C           P9OUK     IFEQ 0
     C                     EXSR ##KEI
     C                     ENDIF
     C           P9OUK     IFEQ 0
     C           P9JCK     ANDEQ0
     C                     EXSR ##KEI2
     C                     ENDIF
     C           P9OUK     IFEQ 0
     C           P9JCK     ANDEQ0
     C           P9JCI     ANDEQ0
     C                     EXSR ##KEI3
     C                     ENDIF
     C           P9OUK     IFEQ 0
     C           P9JCK     ANDEQ0
     C           P9JCI     ANDEQ0
     C           P9DSK     ANDEQ0
     C                     EXSR ##KEI4
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *         外注日・時刻
      *===============================================================
     C           #OUTK     BEGSR
      *
     C                     CALL 'ALDRT1'
     C                     PARM           P@CHYU  1
     C                     PARM           P@ZENO  4
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PRODUCTION ORDER
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@OTHZ  80
     C                     PARM           P@PNHZ  80
     C                     PARM           P@RCHZ  80
     C                     PARM           P@OUI   4
     C                     PARM           P#OPN   1
      *
     C                     MOVE P@OUI     W@OUI   40
     C           P@RCHZ    IFNE 0
     C                     ADD  W@OUI     P9OUK
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *         計量日・時刻   JC
      *===============================================================
     CSR         ##KEI     BEGSR
      *
     C                     CALL 'ALDRT2'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PRODUCTION ORDER
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@KEHZ  80       WEIGHING DATE
     C                     PARM           P@KETM  60       WEIGHING TIME
     C                     PARM           P#OPN   1
      *
     C           P@KEHZ    IFNE 0
     C                     ADD  4         P9JCK
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *         投入日・時刻    JC
      *===============================================================
     CSR         ##KEI2    BEGSR
      *
     C                     CALL 'ALDRT3'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PRODUCTION ORDER
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@KEHZ  80       WEIGHING DATE
     C                     PARM           P@KETM  60       WEIGHING TIME
     C                     PARM           P#OPN   1
      *
     C                     MOVELP@AFLG    AFLG    1
      *
     C           P@KEHZ    IFNE 0
     C           AFLG      IFEQ '1'
     C                     ADD  1         P9JCI
     C                     ELSE
     C                     ADD  1         P9JCK
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *         計量日・時刻  DS
      *===============================================================
     CSR         ##KEI3    BEGSR
      *
     C                     CALL 'ALDRT4'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PRODUCTION ORDER
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
      *
     C                     MOVELP@BFLG    BFLG    1
      *
     C           P@WIHZ    IFNE 0
      * BFLG = '1' DS1,2,3,4
     C           BFLG      IFEQ '1'
     C                     ADD  2         P9DSK
     C                     ELSE
     C                     ADD  4         P9DSK
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------*
      *投入                                            *
      *--------------------------------------------------*
     CSR         #SBI      BEGSR
      *
     C                     EXSR #OUTS                      OUT SOURCE
     C           P9OUI     IFEQ 0
     C                     EXSR ##WIN
     C                     ENDIF
     C           P9OUI     IFEQ 0
     C           P9BZI     ANDEQ0
     C                     EXSR ##WIN2
     C                     ENDIF
     C           P9OUI     IFEQ 0
     C           P9BZI     ANDEQ0
     C           P9DSI     ANDEQ0
     C                     EXSR ##WIN3
     C                     ENDIF
     C           P9OUI     IFEQ 0
     C           P9BZI     ANDEQ0
     C           P9DSI     ANDEQ0
     C           P9SBI     ANDEQ0
     C                     EXSR ##WIN4
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *         投入日・時刻 BZ
      *===============================================================
     CSR         ##WIN     BEGSR
     C                     CALL 'ALDRT5'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
      *                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
      *
     C           P@WIHZ    IFNE 0
     C                     ADD  1         P9BZI
     C                     ENDIF
      *
     CSR                   ENDSR
      *===============================================================
      *         投入日・時刻  DS
      *===============================================================
     CSR         ##WIN2    BEGSR
     C                     CALL 'ALDRT6'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
      *
     C           P@WIHZ    IFNE 0
     C                     ADD  1         P9DSI
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *         投入日・時刻   SB
      *===============================================================
     CSR         ##WIN3    BEGSR
     C                     CALL 'ALDRT7'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
      *
     C           P@SBFL    IFEQ '1'
     C           P@WIHZ    IFNE 0
     C                     ADD  4         P9SBI
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *         投入日・時刻  LOQ
      *===============================================================
     CSR         ##WIN4    BEGSR
     C                     CALL 'ALDRTC'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@ZENO  4
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
     C                     PARM           Q@MAIS  30
     C                     PARM           P#OPN   1
      *
     C           P@WIHZ    IFNE 0
     C                     ADD  Q@MAIS    P9LOQI
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *         計量日・時刻  BZ
      *===============================================================
     CSR         ##KEI4    BEGSR
     C                     CALL 'ALDRT8'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
      *
     C           P@WIHZ    IFNE 0
     C                     ADD  4         P9BZK
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *設備前 計量日・時刻  BZ
      *===============================================================
     CSR         ##PLOD    BEGSR
     C                     CALL 'ALDRTB'
     C                     PARM           P@CHYU  1
     C                     PARM           P@ZENO  4
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@PLJC  40       設備前JC
     C                     PARM           P@PLBZ  40       設備前BZ
     C                     PARM           P@PLDS  40       設備前DS
     C                     PARM           P@PLSB  40       設備前SB
     C                     PARM           P@PLOU  40       設備前OUTSOURCE
     C                     PARM           P@PRE   40        PRE
     C                     PARM           P@LPLD  80        LAST PRE DATE
     C                     PARM           P@LPLT  60        LAST PRE TIME
     C                     PARM           P#OPN   1
      *
     C                     ADD  P@PLJC    P9PLJC
     C                     ADD  P@PLBZ    P9PLBZ
     C                     ADD  P@PLDS    P9PLDS
     C                     ADD  P@PLSB    P9PLSB
     C                     ADD  P@PLOU    P9PLOU
     C                     ADD  P@PRE     P9PRE
      *
     C                     Z-ADDP@LPLD    P9LPLD
     C                     Z-ADDP@LPLT    P9LPLT
      *
     C                     ENDSR
      *===============================================================
      *         　　　・時刻
      *===============================================================
     CSR         ##PIC     BEGSR
      *
     C                     CALL 'ALDRT9'
     C                     PARM           P@CHYU  1
     C                     PARM           P@ZENO  4
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PRODUCTION ORDER
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@PKHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@PKTM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
      *
     C           P@PKHZ    IFNE 0
     C                     ADD  1         P9PRE
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------*
      * CLOSE FILE                                       *
      *--------------------------------------------------*
     CSR         #CLOSE    BEGSR
      *
     C                     MOVEL'9'       P#OPN   1
      *
     C                     CALL 'ALDRT1'
     C                     PARM           P@CHYU  1
     C                     PARM           P@ZENO  4
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PRODUCTION ORDER
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@OTHZ  80
     C                     PARM           P@PNHZ  80
     C                     PARM           P@RCHZ  80
     C                     PARM           P@OUI   4
     C                     PARM           P#OPN   1
      *
     C                     CALL 'ALDRT2'
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THNO  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PRODUCTION ORDER
     C                     PARM           Q@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
