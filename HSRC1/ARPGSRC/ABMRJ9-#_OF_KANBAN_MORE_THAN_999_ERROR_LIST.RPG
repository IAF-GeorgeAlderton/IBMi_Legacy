     C           KEYFC1    CHAINFCEPL011             25
     C           *IN25     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     25
     C                     ENDIF
     C           *IN25     IFEQ '0'
     C                     MOVELA2STRK    P2ATK1
     C                     MOVELA2STRT    P2ATK2
     C                     MOVELA2STRR    P2ATK3
     C                     MOVELA2STRD    P2ATK4
     C                     Z-ADDA2GEHZ    P2GEHZ
     C                     Z-ADDA2TAHZ    P2TAHZ
     C                     ENDIF
      *
     C                     MOVEL*BLANK    P2SHIN
     C           W0SHN1    CAT  '-':0     P2SHIN
     C           P2SHIN    CAT  W0SHN2:0  P2SHIN
     C           P2SHIN    CAT  '-':0     P2SHIN
     C           P2SHIN    CAT  W0SHN3:0  P2SHIN
