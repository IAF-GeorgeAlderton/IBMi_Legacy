      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
     C                     TIME           WTIME
      *
     C                     Z-ADDUDATE     @HYMD
     C                     SETON                     55
     C           *HIVAL    SETGTABMWP701
     C                     READPABMWP701                 87
     C           *IN87     DOWEQ'0'
     C           *IN55     IFEQ '1'
     C                     WRITEABMPRJ91
     C                     SETOF                     55
     C                     ENDIF
     C                     EXSR #SB001
     C                     READPABMWP701                 87
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------*
      * FCEPP01                                          *
      *--------------------------------------------------*
     CSR         #SB001    BEGSR
      *
     C           KEYFC1    KLIST
     C                     KFLD           W0SHN1
     C                     KFLD           W0SHN2
     C                     KFLD           W0SHN3
