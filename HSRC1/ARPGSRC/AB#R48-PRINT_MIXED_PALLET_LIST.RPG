     C           *ENTRY    PLIST
     C                     PARM           PMXPL   30
JW   C                     PARM           PNONY   4
      *
TCH55C                     MOVE '===='    BA1     4
   | C                     MOVE '===='    BA2     4
      *
     C           P#CMD     PLIST
     C                     PARM           #CHR    1
     C                     PARM           #L1     6
     C                     PARM           #L2     6
     C                     PARM           #L3     6
     C                     PARM           #L4     6
     C                     PARM           #L5     6
     C                     PARM           #L6     6
     C                     PARM           #L7     6
   | C                     PARM           #L8     6
TCH55 *
     C           KEY1      KLIST
     C                     KFLD           KTOKU   40       CUSTOMER CODE
     C                     KFLD           KNONY   40       DELIVERY CODE
      *
     C           KEY2      KLIST
     C                     KFLD           KTOKU
     C                     KFLD           KNONY
     C                     KFLD           INUKE
     C                     KFLD           IMHN1
     C                     KFLD           IMHN2
     C                     KFLD           IMHN3
     C                     KFLD           IMHN4
      *
 JW1 C                     MOVEL'R48 '    WPGM
      *
 GA  C                     SETOF                     11
 GA  C           ITOKU     IFEQ 5149
 GA  C                     SETON                     11
 GA  C                     MOVE IMHN1     WPART1
 GA  C                     MOVE IMHN2     WPART2
 GA  C                     MOVE IMHN3     WPART3
 GA  C                     END
 GA  C*
 GA  C                     MOVE '-'       FLD1
 GA  C                     MOVE '-'       FLD2
 GA  C                     MOVE '-'       FLD3
 GA  C                     MOVE '-'       FLD4
 GA  C                     MOVE *BLANK    FLD5
 GA  C                     SETOF                     60
GA310C           ITOKU     IFEQ 0295
GA310C           ITOKU     OREQ 0296
     C                     SETON                     60
 GA  C                     MOVE IMHN1     NPART1
 GA  C                     MOVE IMHN2     NPART2
 GA  C                     MOVE IMHN3     NPART3
 GA  C                     MOVE NMHN1     PART1
 GA  C                     MOVE NMHN2     PART2
 GA  C                     MOVE NMHN3     PART3
 GA  C                     MOVE NMHN4     PART4
 GA  C                     MOVE PARTA     PART   17
     C                     END
 GA  C           ITOKU     IFEQ 0390
     C                     SETON                     60
 GA  C                     MOVE IMHN1     NPART1
 GA  C                     MOVE IMHN2     NPART2
 GA  C                     MOVE IMHN3     NPART3
 GA  C                     MOVE NMHN1     PART5
 GA  C                     MOVE NMHN2     PART6
 GA  C                     MOVE NMHN3     PART7
 GA  C                     MOVE NMHN4     PART8
 GA  C                     MOVELPARTB     PART   17
 GA  C                     END
 GA  C*
 GA  C                     SETOF                     12
 GA  C           ITOKU     IFEQ 0291
 GA  C                     SETON                     12
 GA  C                     MOVE IMHN1     WPART4
 GA  C                     MOVE IMHN2     WPART5
 GA  C                     MOVE IMHN3     WPART6
 GA  C                     END
     C*
     C*-         *INL1     IFEQ '0'
     C                     ADD  FC#BOX    WHAKO
     C*---                 ENDIF
      *
     C                     MOVE YYYY      WNOYY
     C                     MOVE MM        WNOMM
     C                     MOVE DD        WNODD
     C                     MOVE '/'       WNO1
     C                     MOVE '/'       WNO2
      *
     C           *IN70     IFEQ '1'
JW3  C                     ADD  1         @@SKD
     C                     WRITEAB#PR441
JW2  C                     Z-ADD13        LIN#
     C                     SETOF                     70
     C                     END
      *
     CL1                   EXSR SUBR
     CL3                   EXSR DOCR
