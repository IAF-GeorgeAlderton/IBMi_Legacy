     C                     ENDSR
JW3   *========================================
      * OUTPUT AB#PP71
      *========================================
     C           #PP71     BEGSR
      * GET PACKING LIST#
     C                     MOVELINOHZ     $NOHZ   8
     C                     MOVELITOKU     $CUST
     C                     MOVELINONY     $NONY
     C                     MOVELINKOJ     $NKOJ
     C                     MOVELINUKE     $NUKE
     C                     MOVELINOTM     $BINN
     C                     MOVEL'00000000'$RLHZ
     C                     MOVE *BLANK    $ODRN
     C                     CALL 'UTLR51'
     C                     PARM           $NOHZ   8
     C                     PARM           $CUST   4
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $BINN   2
     C                     PARM           $RLHZ   8
     C                     PARM           $ODRN  10
     C                     PARM           $PICK#  9
     C                     PARM           $RTN    1
      * IF FIRST PACKING#, DELETE PAST RECORD
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     EXSR #DLT
     C                     ENDIF
      *
     C                     CLEARAB#PP711
     C                     Z-ADDTODAY     MPCRHZ           CRT DATE
     C                     Z-ADDNOW       MPCRTM           CRT TIME
     C                     MOVEL#USER     MPCRUS           CRT USER
     C                     MOVEL#PGM      MPCRPG           CRT PGM
     C                     MOVEL#WSID     MPCRWS           CRT WSID
     C                     MOVEL$PICK#    MPSERL           PACKING LIST#
      *
     C                     Z-ADD@@SKD     MPPAL#           PALLET#
     C                     Z-ADDITOKU     MPTOKU           CUST CODE
     C                     Z-ADDINONY     MPNONY           DELIV CODE
     C                     MOVELINKOJ     MPNKOJ           FACTORY
     C                     MOVELINUKE     MPNUKE           DOCK
     C                     MOVELIMHN1     MPMHN1           USER PART1
     C                     MOVELIMHN2     MPMHN2           USER PART2
     C                     MOVELIMHN3     MPMHN3           USER PART3
     C                     MOVELIMHN4     MPMHN4           USER PART4
     C                     Z-ADDINOHZ     MPNOHZ           SHIP DATE
     C                     Z-ADDINOTM     MPNOBN           BIN
     C                     MOVELIODRN     MPODRN           ORDER NO
     C                     MOVELISBAN     MPSBAN           KANBAN#
      * VALUE
     C           WHAKO     MULT ISYOS     MPSRYO           ORDER QTY
     C                     Z-ADDISYOS     MPSYOS           QTY/BOX
     C                     Z-ADDWHAKO     MPHAKO           BOX
     C                     MOVELISHN1     MPSHN1           IAF PART1
     C                     MOVELISHN2     MPSHN2           IAF PART2
     C                     MOVELISHN3     MPSHN3           IAF PART3
     C                     MOVELFCLOC1    MPLOC1           LOC 1
     C                     MOVELFCLOC2    MPLOC2           LOC 2
     C                     MOVELFCLOC3    MPLOC3           LOC 3
     C                     MOVELFCLOC4    MPLOC4           LOC 4
     C                     Z-ADD0         MPTPAL           TTL PALLET#
      *
     C                     WRITEAB#PP711
      *
JW3  C                     ENDSR
      *========================================
JW3   * DELETE PAST RECORD
      *========================================
     C           #DLT      BEGSR
      *
     C           $PICK#    SETLLAB#PP71
     C                     DO   *HIVAL
     C           $PICK#    READEAB#PP71                  98
     C   98                LEAVE
      *
     C           MPSKJY    IFEQ *BLANK
     C                     MOVE 'D'       MPSKJY
     C                     Z-ADDTODAY     MPSKHZ
     C                     UPDATAB#PP711
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *========================================
     C* PRINT LARGE CHRACTER
      *========================================
     C           #LARG     BEGSR
     C                     MOVELWNOMM     WW,1
     C                     MOVE WNOMM     WW,2
     C                     MOVELWNODD     WW,3
     C                     MOVE WNODD     WW,4
     C           1         DO   4         CC      10
     C                     MOVE *BLANKS   #L1
     C                     MOVE *BLANKS   #L2
     C                     MOVE *BLANKS   #L3
     C                     MOVE *BLANKS   #L4
     C                     MOVE *BLANKS   #L5
     C                     MOVE *BLANKS   #L6
     C                     MOVE *BLANKS   #L7
     C                     MOVE *BLANKS   #L8
     C                     MOVE WW,CC     #CHR
     C                     CALL 'AB#R4P'  P#CMD
     C           CC        IFEQ 1
     C                     MOVE #L1       #11
     C                     MOVE #L2       #12
     C                     MOVE #L3       #13
     C                     MOVE #L4       #14
     C                     MOVE #L5       #15
     C                     MOVE #L6       #16
     C                     MOVE #L7       #17
     C                     MOVE #L8       #18
     C                     ENDIF
     C           CC        IFEQ 2
     C                     MOVE #L1       #21
     C                     MOVE #L2       #22
     C                     MOVE #L3       #23
     C                     MOVE #L4       #24
     C                     MOVE #L5       #25
     C                     MOVE #L6       #26
     C                     MOVE #L7       #27
     C                     MOVE #L8       #28
     C                     ENDIF
     C           CC        IFEQ 3
     C                     MOVE #L1       #31
     C                     MOVE #L2       #32
     C                     MOVE #L3       #33
     C                     MOVE #L4       #34
     C                     MOVE #L5       #35
     C                     MOVE #L6       #36
     C                     MOVE #L7       #37
     C                     MOVE #L8       #38
     C                     ENDIF
     C           CC        IFEQ 4
     C                     MOVE #L1       #41
     C                     MOVE #L2       #42
     C                     MOVE #L3       #43
     C                     MOVE #L4       #44
     C                     MOVE #L5       #45
     C                     MOVE #L6       #46
     C                     MOVE #L7       #47
     C                     MOVE #L8       #48
     C                     ENDIF
   | C                     ENDDO
TCH66C                     ENDSR
