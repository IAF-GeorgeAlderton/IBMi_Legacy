     C                     MOVEL*BLANKS   SSBAN   4        KANBAN#
     C                     Z-ADD*DATE     PHZ8
     C                     TIME           WTIME
JW3  C                     ADD  1         @@SKD
     C                     WRITEAB#PR441
JW2  C                     Z-ADD13        LIN#
     C                     ENDIF
      *
     C                     MOVE IMHN1     WMHN1
