GA   C                     MOVELIMHN9     WMHN11
     C*
 KK  C*                    Z-ADDFC#BOX    WHAKO
     C                     ADD  WHAKO     THAKO
     C                     ADD  WHAKO     SHAKO
      *
     C                     Z-ADDITOKU     KTOKU
     C                     Z-ADDINONY     KNONY            DELIVERY CODE
     C           KEY2      SETGTAB#PP85
     C           *IN90     DOUEQ*ON
     C           KEY2      REDPEAB#PP85                  90
     C           *IN90     IFEQ *OFF
     C           A5DATE    ANDLEINOHZ
     C                     MOVELA5SBAN    WSBAN     P
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     MOVELISBAN     WSBAN     P
     C                     ENDIF
      *
     C           THAKO     IFLE PMXPL
     C           *IN55     OREQ *OFF
     C           *INL1     ANDEQ*ON
      *
JW2  C           LIN#      IFGT 46
 |   C                     WRITEAB#PR449
JW3  C                     ADD  1         @@SKD
 |   C                     WRITEAB#PR441
 |   C                     Z-ADD13        LIN#
JW2  C                     ENDIF
JW3   * OUT AB#PP71
     C           WHAKO     IFNE 0
"    C                     EXSR #PP71
     C                     ENDIF
      *
     C                     WRITEAB#PR442
     C                     ADD  1         LIN#
      *
     C                     Z-ADD0         WHAKO
     C                     ELSE
     C           SHAKO     SUB  WHAKO     THAKO
TCH55C                     EXSR #LARG
     C                     WRITEAB#PR443
JW2  C                     ADD  20        LIN#
     C                     Z-ADDWHAKO     SHAKO
     C                     Z-ADDWHAKO     THAKO
     C                     SETON                     70
