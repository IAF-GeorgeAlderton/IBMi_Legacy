     H            Y.
     F** ALBR57 *********************************************
     F* 2 POINT BOX DUMP VERIFICATION SCAN                  *
     F*   LEC .................     2016.02.17              *
     F*******************************************************
     FALBPW57 CF  E                    WORKSTN
     FFCETL11 IF  E           K        DISK
      *                  prefix(A2)    part information master file (logical)
     FALBPP57 O   E                    DISK
      *                  prefix(AR)    retrieval scan results file
      *
     E                    ER      1   7 60
      *
     I            DS
     I                                        1  14 D1SHN
     I                                        1   5 D1SHN1
     I                                        6   6 D1SF1
     I                                        7  11 D1SHN2
     I                                       12  12 D1SF2
     I                                       13  14 D1SHN3
      *
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I            DS
     I                                        1   80A2TRHZ
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60HHMMSS
     I                                        7  140WDATE
     I                                        7  100WYY
     I                                       11  120WMM
     I                                       13  140WDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           POPR    6
     C                     PARM           PITANT 10
      *
      *----------------------------------------------------*
      * MAINLINE                                           *
      *----------------------------------------------------*
     C                     MOVEL'01'      DSPSW   2
      *
     C           DSPSW     DOUEQ'99'
      *
     C                     SELEC
     C           DSPSW     WHEQ '01'
     C                     EXSR #SB100
     C           DSPSW     WHEQ '02'
     C                     EXSR #SB200
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *
      *----------------------------------------------------*
      * FIRST SCREEN - Display Screen for Retrieval Kanban *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     EXFMTALBPW571
     C                     SETOF                     9931
      *
      *
     C           *IN01     IFEQ *ON
     C                     MOVEL'99'      DSPSW
     C                     MOVE *BLANKS   D1BAR1
     C                     GOTO ESB100
     C                     ENDIF
      *
     C           D1BAR1    IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,6      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D1BAR1
     C                     GOTO ESB100
     C                     ENDIF
      *
      * CHECK DIGIT - if check digit is not correct, display
      * error screen.
     C                     MOVELD1BAR1    PMAREA
     C                     MOVEL'014'     PMBYTE
     C           1         SUBSTD1BAR1:15 WKCHK   1
     C                     EXSR GETCDG
     C           WKCHK     IFNE PMCHK
     C                     SETON                     99
     C                     MOVELER,2      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D1BAR1
     C                     GOTO ESB100
     C                     ENDIF
      *
     C                     MOVEL*BLANK    W1SHN1  5
     C                     MOVEL*BLANK    W1SHN2  5
     C                     MOVEL*BLANK    W1SHN3  2
     C                     MOVEL*BLANK    W1TBN1  1
     C                     MOVEL*BLANK    W1TBN2  2
     C                     MOVEL*BLANK    W1TBN3  2
     C                     MOVEL*BLANK    W1TBN4  1
     C                     MOVEL*BLANK    W1ZETI  4
     C                     MOVEL*BLANK    D1ZETI  4
      * get item absolute (zeti)
     C           4         SUBSTD1BAR1:2  D1ZETI
      *
      * get part information from PART INFORMATION M/F
     C           D1ZETI    CHAINFCETL111             21
     C           *IN21     IFEQ *OFF
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ENDIF
      *
     C           *IN21     IFEQ *OFF
     C                     MOVELA2BHB1    W1SHN1
     C                     MOVELA2BHB2    W1SHN2
     C                     MOVELA2BHB3    W1SHN3
      *
     C                     TIME           WTIME
      *
     C           A2TRHZ    IFGT WDATE
      * old location code
     C                     MOVELA2KTRK    W1TBN1  1
     C                     MOVELA2KTRT    W1TBN2  2
     C                     MOVELA2KTRR    W1TBN3  2
     C                     MOVELA2KTRD    W1TBN4  1
     C                     ELSE
      * else new location code
     C                     MOVELA2STRK    W1TBN1  1
     C                     MOVELA2STRT    W1TBN2  2
     C                     MOVELA2STRR    W1TBN3  2
     C                     MOVELA2STRD    W1TBN4  1
     C                     ENDIF
      *
     C                     ELSE
     C                     SETON                     99
     C                     MOVELER,3      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D1BAR1
     C                     GOTO ESB100
     C                     ENDIF
      *
     C                     MOVEL*BLANK    D1SHN
     C                     MOVELW1SHN1    D1SHN1
     C                     MOVEL'-'       D1SF1
     C                     MOVELW1SHN2    D1SHN2
     C           W1SHN3    IFNE *BLANK
     C                     MOVEL'-'       D1SF2
     C                     MOVELW1SHN3    D1SHN3
     C                     ENDIF
     C                     MOVEL'02'      DSPSW
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * SCREEN TWO  - Display Screen to Input P/T KANBAN   *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C                     EXFMTALBPW572
     C                     SETOF                     9931
      *
     C           *IN01     IFEQ *ON
     C                     MOVEL'01'      DSPSW
     C                     MOVEL*BLANK    D2BAR1
     C                     MOVEL*BLANK    D1BAR1
     C                     GOTO ESB200
     C                     ENDIF
      *
      * if P/T KANBAN is blank, display error and start over.
     C           D2BAR1    IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,4      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D2BAR1
     C                     GOTO ESB200
     C                     ENDIF
      *
     C           1         SUBSTD2BAR1:1  BCID    1
     C           BCID      IFNE 'I'
     C                     MOVEL'NG'      WKOKNG
     C                     MOVE '07'      ERRCOD
     C                     EXSR #SB500
     C                     MOVEL*BLANK    D2BAR1
     C                     SETON                     99
      * display error screen...
     C                     MOVELER,7      D9ERR
     C                     EXSR #SB290
     C                     GOTO ESB200
     C                     ENDIF
      *
      * CHECK DIGIT - call program to get check digit and compare
      *  to make sure it's correct.
      *
     C                     MOVELD2BAR1    PMAREA
     C                     MOVEL'016'     PMBYTE
     C           1         SUBSTD2BAR1:17 WKCHK   1
      *
     C                     EXSR GETCDG
      *
      * if check digits don't match, display error, go back to screen2.
     C           WKCHK     IFNE PMCHK
     C                     SETON                     99
     C                     MOVELER,2      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D2BAR1
     C                     GOTO ESB200
     C                     ENDIF
      *
     C                     MOVEL*BLANK    W2SHN1  5
     C                     MOVEL*BLANK    W2SHN2  5
     C                     MOVEL*BLANK    W2SHN3  2
     C                     MOVEL*BLANK    W2ABN1  1
     C                     MOVEL*BLANK    W2ABN2  2
     C                     MOVEL*BLANK    W2ABN3  2
     C                     MOVEL*BLANK    W2ABN4  1
     C                     MOVEL*BLANK    D2ZETI  4
      *
      * get part information from PART INFORMATION M/F
      *
     C           4         SUBSTD2BAR1:2  D2ZETI
     C           D2ZETI    CHAINFCETL111             21
      *
     C           *IN21     IFEQ *OFF
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ENDIF
      *
      * part number found and not marked for delete.
     C           *IN21     IFEQ *OFF
     C                     MOVELA2BHB1    W2SHN1
     C                     MOVELA2BHB2    W2SHN2
     C                     MOVELA2BHB3    W2SHN3
      *
     C           A2TRHZ    IFGT WDATE
      * old location code
     C                     MOVELA2KTRK    W2ABN1  1
     C                     MOVELA2KTRT    W2ABN2  2
     C                     MOVELA2KTRR    W2ABN3  2
     C                     MOVELA2KTRD    W2ABN4  1
     C                     ELSE
      * else new location code
     C                     MOVELA2STRK    W2ABN1  1
     C                     MOVELA2STRT    W2ABN2  2
     C                     MOVELA2STRR    W2ABN3  2
     C                     MOVELA2STRD    W2ABN4  1
     C                     ENDIF
      *
     C                     ENDIF
      *
      *
      * check to make sure it's a match.
     C           D2ZETI    IFEQ D1ZETI
     C                     MOVEL'OK'      WKOKNG  2
     C                     MOVE *BLANKS   ERRCOD  2
     C                     EXSR #SB500
      * display ok screen...
     C                     EXFMTALBPW095
     C                     ELSE
     C                     MOVEL'NG'      WKOKNG
     C                     MOVE '07'      ERRCOD
     C                     EXSR #SB500
     C                     MOVEL*BLANK    D2BAR1
     C                     SETON                     99
      * display error screen...
     C                     MOVELER,7      D9ERR
     C                     EXSR #SB290
     C                     GOTO ESB200
     C                     ENDIF
      *
     C                     MOVEL*BLANK    D1BAR1
     C                     MOVEL*BLANK    D2BAR1
     C                     MOVEL'01'      DSPSW
      *
     CSR         ESB200    ENDSR
      *
      *-----------------------------------------------------------------------*
      * ALBPP57 - Write Record to Box Dump Scan File                          *
      *-----------------------------------------------------------------------*
     C           #SB500    BEGSR
      *
      * write to ALBPP57
     C                     TIME           WTIME
     C                     CLEARALBPP571
     C                     Z-ADDWDATE     AVKODT
     C                     Z-ADDHHMMSS    AVKOTM
     C                     MOVELW#WSID    AVWSID
     C                     MOVELPITANT    AVUSER
     C                     MOVELW#JBNO    AVJOBN
     C                     MOVELW#PGM     AVKOPG
     C                     MOVELPOPR      AVWKCD
     C                     Z-ADDWDATE     AVCODT
     C                     Z-ADDHHMMSS    AVCOTM
      *
     C                     MOVELD1BAR1    AVRBAR
     C                     MOVELW1SHN1    AVRHN1
     C                     MOVELW1SHN2    AVRHN2
     C                     MOVELW1SHN3    AVRHN3
     C                     MOVELD1ZETI    AVRZET
     C           3         SUBSTD1BAR1:6  AVRTEH
     C           2         SUBSTD1BAR1:9  AVRPAG
     C                     MOVELW1TBN1    AVRBN1
     C                     MOVELW1TBN2    AVRBN2
     C                     MOVELW1TBN3    AVRBN3
     C                     MOVELW1TBN4    AVRBN4
      *
     C                     MOVELD2BAR1    AVABAR
     C                     MOVELD2ZETI    AVAZET
     C                     MOVELW2SHN1    AVAHN1
     C                     MOVELW2SHN2    AVAHN2
     C                     MOVELW2SHN3    AVAHN3
     C                     MOVELW2ABN1    AVABN1
     C                     MOVELW2ABN2    AVABN2
     C                     MOVELW2ABN3    AVABN3
     C                     MOVELW2ABN4    AVABN4
     C           6         SUBSTD2BAR1:6  AVPTOR
     C           4         SUBSTD2BAR1:13 AVPTLT
      *
     C                     MOVELWKOKNG    AVOKNG
     C                     MOVELERRCOD    AVERCD
     C                     WRITEALBPP571
      *
     C                     ENDSR
      *
      *----------------------------------------------------*
      * Call Program to Get Check Digit                    *
      *----------------------------------------------------*
     C           GETCDG    BEGSR
      *
     C                     CALL 'ALBRCC'
     C                     PARM           PMAREA100        INPUT DATA
     C                     PARM           PMBYTE  3        LENGTH
     C                     PARM           PMCHK   1        CHECKS DIGITS
     C                     PARM           PMRTCD  1        RETRN CODE
      *
     C                     ENDSR
      *
      *----------------------------------------------------*
      * ERROR SCREEN - Display Error on Screen             *
      *----------------------------------------------------*
     C           #SB290    BEGSR
      *
     C                     WRITEALBPW098
     C                     EXFMTALBPW099
      *
     C                     ENDSR
      *----------------------------------------------------*
**
INPUT LOCATION BARCODE.
CHECK DIGIT ERROR.
PARTS MASTER ERROR.
INPUT PASSTHRU KANBAN.
INVALID LOCATION.
INPUT RETRIEVAL KANBAN.
WRONG KANBAN.
