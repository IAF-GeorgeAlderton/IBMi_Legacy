     H            Y.
     F** AB#R0I3 ***************************************************************
     F*  PROGRAM    : CHECK & FIX HONDA DUPLICATE ORDER                        *
     F*  WRITTEN    : 2020.06.11                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#PL2P UF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *---------------------------------------------------
     I            DS
     I                                        1  140@DATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ***********************************************************
     C                     EXSR #INIT
      *
     C                     MOVE 'Y'       FIRST   1
     C           K#PL2P    SETLLAB#PL2P
     C                     DO   *HIVAL
     C           K#PL2P    READEAB#PL2P                  98
     C   98                LEAVE
      * IGNORE
     C           ACUPID    IFNE ' '
     C                     ITER
     C                     ENDIF
     C           ACQNTY    IFEQ 0
     C                     ITER
     C                     ENDIF
      * IGNORE
     C           ACQNTY    IFEQ @QNTY
     C                     ITER
     C                     ENDIF
      * UPDATE
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     EXSR #PRINT
      *
     C           $UPD      IFEQ 'Y'
     C                     Z-ADD@QNTY     ACQNTY
     C                     Z-ADDTODAY     ACKYMD
     C                     Z-ADDNOW       ACKTIM
     C                     MOVEL#PGM      ACKPGM
     C                     MOVEL#PGM      ACAUTH
     C                     MOVE 'CHG'     ACAUTH
     C                     UPDATAB#PP2A1
     C                     ENDIF
      *
     C                     ITER
     C                     ENDIF
      * CHANGE QTY
     C                     MOVE 'D'       ACUPID
     C                     Z-ADDTODAY     ACKYMD
     C                     Z-ADDNOW       ACKTIM
     C                     MOVEL#PGM      ACKPGM
     C                     MOVEL#PGM      ACAUTH
     C                     MOVE 'DLT'     ACAUTH
     C                     EXSR #PRINT
      *
     C           $UPD      IFEQ 'Y'
     C                     UPDATAB#PP2A1
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $UPD    1
     C                     PARM           P@PLSH
     C                     PARM           P@NONY
     C                     PARM           P@NKOJ
     C                     PARM           P@NUKE
     C                     PARM           P@BIN
     C                     PARM           P@ODRN
     C                     PARM           P@MHN1
     C                     PARM           P@MHN2
     C                     PARM           P@MHN3
     C                     PARM           P@MHN4
     C                     PARM           @QNTY
     C                     PARM           @CNT    20
     C                     PARM           $RTN    1
      *
     C           K#PL2P    KLIST
     C                     KFLD           P@PLSH
     C                     KFLD           P@NONY
     C                     KFLD           P@NKOJ
     C                     KFLD           P@NUKE
     C                     KFLD           P@BIN
     C                     KFLD           P@ODRN
     C                     KFLD           P@MHN1
     C                     KFLD           P@MHN2
     C                     KFLD           P@MHN3
     C                     KFLD           P@MHN4
      *
     C                     MOVE *BLANK    $RTN
     C                     TIME           @DATE
     C                     Z-ADD0         SEQ#    50
     C                     Z-ADD88        LIN#    30
      *
     C           *LIKE     DEFN ACPLSH    P@PLSH
     C           *LIKE     DEFN ACNONY    P@NONY
     C           *LIKE     DEFN ACNKOJ    P@NKOJ
     C           *LIKE     DEFN ACNUKE    P@NUKE
     C           *LIKE     DEFN ACBIN     P@BIN
     C           *LIKE     DEFN ACODRN    P@ODRN
     C           *LIKE     DEFN ACMHN1    P@MHN1
     C           *LIKE     DEFN ACMHN2    P@MHN2
     C           *LIKE     DEFN ACMHN3    P@MHN3
     C           *LIKE     DEFN ACMHN4    P@MHN4
     C           *LIKE     DEFN ACQNTY    @QNTY
      *
     C                     ENDSR
      ************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                         $UPD      12
     O                                   40 '** FIX HONDA DUPLICA'
     O                                   60 'TE ORDER (S/B COMBIN'
     O                                   80 'ED) (PP2A) **       '
     O                         TODAY     98 '    .  .  '
     O                         NOW      108 '0 :  :  '
     O                                  112 'P.'
     O                         PAGE  Z  116
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   18 'SHP_DATE'
     O                                   26 'DELV'
     O                                   29 'F'
     O                                   34 'DOCK'
     O                                   40 'BIN#'
     O                                   47 'ORDER#'
     O                                   68 'PART1'
     O                                   75 'PART2'
     O                                   82 'PART3'
     O                                   89 'PART4'
     O                                   98 'ACQNTY'
     O                                  111 'TO_BE_QTY'
     O                                  117 'COUNT'
     O        E 1              @DTL
     O                         SEQ#  Z +000
     O                         ACUPID  +002
     O                         P@PLSH  +002 '    /  /  '
     O                         P@NONY  +002
     O                         P@NKOJ  +002
     O                         P@NUKE  +002
     O                         P@BIN   +002
     O                         P@ODRN  +002
     O                         P@MHN1  +002
     O                         P@MHN2  +002
     O                         P@MHN3  +002
     O                         P@MHN4  +002
     O                         ACQNTYZ +000
     O                         @QNTY Z +000
     O                         @CNT  Z +006
