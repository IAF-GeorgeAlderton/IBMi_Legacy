     H            Y.
      ** ALDR71 *************************************************
      * SHIFT MASTER MAINTENANCE                                *
      *   PROGRAM-ID.  :  ALDR71                                *
      *                                                         *
      *                                                         *
      *
      ************************************************* ALDR75 **
     FALDPW71 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FALDPL70 UF  E           K        DISK                      A
     FALBPL30 IF  E           K        DISK
      *------------------------------------------------------------
     E                    CMD     1   2 78
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
      *   MAIN ROUTINE
      *--------------------------------------------------------
     C           @@ID      DOUEQ'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C           @@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *--------------------------------------------------------
      * INITIALIZE
      *--------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#70      KLIST
     C                     KFLD           D@SHFT
     C                     KFLD           S@OPER
      *
     C           K#7X      KLIST
     C                     KFLD           D@SHFT
     C                     KFLD           H@OPER
      *
     C                     MOVE '01'      @@ID    2
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @@RRN   40
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  1ST SCREEN
      *--------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C                     MOVE '02'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  CHECK
      *--------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C           D@SHFT    IFLT '1'
     C           D@SHFT    ORGT '3'
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  CLEAR
      *--------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,61
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  SET DATA
      *--------------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1
     C           D@SHFT    SETLLALDPL70
     C           *IN80     DOUEQ*ON
     C           D@SHFT    READEALDPL70                  80
     C           *IN80     IFEQ *OFF
     C           A7SKJY    ANDEQ*BLANK
      *
     C                     CLEARSFL01
     C                     MOVE A7OPER    S@OPER
     C                     MOVE A7OPER    H@OPER
     C                     MOVE A7OPER    K@OPER  60
     C           K@OPER    CHAINALBPL30              90
     C           *IN90     IFEQ *OFF
     C                     MOVELALWKNM    S@OPNM
     C                     ENDIF
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     DO   50
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDDO
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  2ND SCREEN
      *--------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      @@ID
     C                     OTHER
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
     C                     MOVE '01'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  CHECK
      *--------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     EXSR #CLR
     C                     Z-ADD*ZERO     WRRN    40
     C           *IN80     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                80
     C           *IN80     IFEQ *OFF
     C                     MOVE *OFF      *IN61
     C                     MOVE *BLANK    S@OPNM
     C           S@OPER    IFNE *BLANK
     C                     MOVE S@OPER    K@OPER  60
     C           K@OPER    CHAINALBPL30              90
     C           *IN90     IFEQ *OFF
     C                     MOVELALWKNM    S@OPNM
     C                     ELSE
     C                     SETON                     6199
     C                     ENDIF
     C                     ENDIF
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  UPDATE
      *--------------------------------------------------------
     C           #UPD      BEGSR
      *
     C                     Z-ADD*ZERO     WRRN    40
     C           *IN80     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                80
     C           *IN80     IFEQ *OFF
     C           S@OPER    ANDNEH@OPER
      *
     C           H@OPER    IFNE *BLANK
     C           K#7X      CHAINALDPL70              90
     C           *IN90     IFEQ *OFF
     C                     MOVE 'D'       A7SKJY
     C                     Z-ADD*DATE     A7SKDT
     C                     TIME           A7SKTM
     C                     MOVEL#USER     A7USER
     C                     UPDATALDPP701
     C                     ENDIF
     C                     ENDIF
      *
     C           S@OPER    IFNE *BLANK
     C           K#70      CHAINALDPL70              90
     C           *IN90     IFEQ *OFF
     C                     MOVE *BLANK    A7SKJY
     C                     Z-ADD*ZERO     A7SKDT
     C                     TIME           A7SKTM
     C                     MOVEL#USER     A7USER
     C                     UPDATALDPP701
     C                     ELSE
     C                     CLEARALDPP701
     C                     Z-ADD*DATE     A7UDAT
     C                     TIME           A7UTIM
     C                     MOVEL#USER     A7USER
     C                     MOVE D@SHFT    A7SHFT
     C                     MOVE S@OPER    A7OPER
     C                     WRITEALDPP701
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
**  CMD
F1:END
F1:END      F5:UPDATE      F12:GO BACK
