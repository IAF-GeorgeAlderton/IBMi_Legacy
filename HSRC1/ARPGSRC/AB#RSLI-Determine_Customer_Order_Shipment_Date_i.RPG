     H            Y.
     F** AB#RSLI  *****************************************************
     F* DETERMINE CUSTOMER ORDER SHIPMENT DATE IF IT'S ON A SLIDE     *
     F*   LEC              CREATE  2023/06/15
     F*****************************************************************
     FAB#PP16 IF  E           K        DISK
      *
     I            DS
     I                                        1   80E4SKHZ
     I                                        1   40E4SKYY
     I                                        5   60E4SKMM
     I                                        7   80E4SKDD
      *
     C           *ENTRY    PLIST
     C                     PARM           PTOKU   40
     C                     PARM           PNONY   40
     C                     PARM           PNUKE   4
     C                     PARM           PSHDT   80
     C                     PARM           PSLIDE  1
     C                     PARM           PSLDT   80
      *
     C           KEY1      KLIST
     C                     KFLD           PTOKU
     C                     KFLD           PNONY
     C                     KFLD           PNUKE
      *
      *******************************************************************
      *  check to see if cust/delv/dock was on a slide on this ship date
     C                     MOVE 'N'       PSLIDE
     C           KEY1      CHAINAB#PP16              50
     C           *IN50     DOWEQ*OFF
      *
     C           SLSKJY    IFEQ *BLANK
      *
     C           PSHDT     IFGE SLFRDT
     C           PSHDT     ANDLESLTODT
     C                     MOVE 'Y'       PSLIDE
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
      *
     C           KEY1      READEAB#PP16                  50
     C                     ENDDO
      *
      * if it's on a slide, get the slide ship date...
      *
     C           PSLIDE    IFEQ 'Y'
     C                     MOVELPSHDT     SHPDAT
     C                     Z-ADDSL#DAY    #DAYS4  40
     C                     MOVEL#DAYS4    #DAYS
     C                     CALL 'UTLR10'
     C                     PARM           SHPDAT  8
     C                     PARM '+'       SIGN    1
     C                     PARM           #DAYS   4
     C                     PARM 'Y'       IAFNO   1
     C                     PARM           SLSHDT  8
     C                     PARM           RTN     1
      *
     C                     MOVELSLSHDT    PSLDT
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ******************************************************************
