      *    購買熱処理メッキかんばんマスター*
      ****************************************
     C           KANSY     IFEQ '7'
     C           OLMI      CHAINAAXPL101             26
     C           *IN26     IFEQ '1'
     C                     EXSR $SB900
     C                     EXCPTDT
     C                     GOTO END
     C                     END
      *
     C                     MOVE '-'       HI1
     C           SYNI03    IFEQ *BLANK
     C                     MOVE *BLANK    HI2
     C                     ELSE
     C                     MOVE '-'       HI2
     C                     END
     C                     MOVE '-'       HIK1
     C                     MOVE '-'       HIK2
     C           L9TKR4    IFEQ *BLANK
     C                     MOVE *BLANK    HIK3
     C                     ELSE
     C                     MOVE '-'       HIK3
     C                     END
      *
     C                     MOVE TKORK     TKOB
     C                     MOVE L9KMAX    MISU
     C                     Z-ADDL9UZAR    @MAX
     C                     EXCPTDT
     C                     SETON                     77
     C                     END
      *
     C           END       TAG
      *
     CLRN77                SETON                     U1
      **********************************
      * 品番のテーブル　サブルーチン *
      **********************************
     C           SYTE      BEGSR
     C                     Z-ADD1         K       20
     C           SLOP11    TAG
     C           K         IFLE 15
     C                     Z-ADDKANK,K    KHIB
     C           KHIZ      IFGT *DATE
     C                     MOVE OTOK,K    SYTO,K
     C                     MOVE OKAN,K    SYKA,K
     C                     ELSE
     C                     MOVE NTOK,K    SYTO,K
     C                     MOVE NKAN,K    SYKA,K
     C                     END
     C                     ADD  1         K
     C                     GOTO SLOP11
     C                     END
     C                     Z-ADD15        K
     C           SLOP12    TAG
     C           K         IFGE 1
     C           SYTO,K    IFEQ *BLANK
     C                     SUB  1         K
     C                     GOTO SLOP12
     C                     END
     C                     MOVE SYTO,K    KEYTO   6
     C                     MOVE SYKA,K    KANSY   1
     C                     Z-ADDKANK,K    KHIB
     C                     END
     C                     ENDSR
      *--------------------------------------------------*
      *  各マスターＮｏｔＦｏｕｎｄ時作成              *
      *--------------------------------------------------*
     CSR         $SB900    BEGSR
     C                     MOVE KEYT1     WKBAN1
     C                     MOVE KEYT2     WKBAN2
     C                     MOVE KEYT3     WKBAN3
     C                     MOVE KEYT4     WKBAN4
     C                     MOVE '-'       HIF
     C                     MOVE '-'       HIG
     C           WKBAN4    IFEQ *BLANK
     C                     MOVE *BLANK    HIH
     C                     ELSE
     C                     MOVE '-'       HIH
     C                     END
     C                     MOVE WKBANC    TKOB
     C                     Z-ADD0         MISU
     CSR         $S900E    ENDSR
      ********************
      * 出力レイアウト *
      ********************
     OAAVWP41 E                DT
     O                         HNBA      14
     O                         TKOB      23
     O                         MISU      26
     O                         @ASJ      29
     O                         @MAX      32
     O                         @SBX      36
     O                         @ACT      40
