     C           HNBAN     KLIST
     C                     KFLD           SYNI01
     C                     KFLD           SYNI02
     C                     KFLD           SYNI03
      *
     C           OLMI      KLIST
     C                     KFLD           KEYT1
     C                     KFLD           KEYT2
     C                     KFLD           KEYT3
     C                     KFLD           KEYT4
     C                     KFLD           KNE
     C                     KFLD           KTU
     C                     KFLD           KHI
     C                     KFLD           KBIN
      *
     C           *IN99     IFEQ *OFF
     C           K#AGD     KLIST
     C                     KFLD           @YEAR   40
     C                     KFLD           @MONTH  20
      * CURRENT MONTH
     C                     Z-ADD*YEAR     @YEAR
     C                     Z-ADD*MONTH    @MONTH
     C           K#AGD     SETLLAGDPL12
     C                     Z-ADD*ZERO     @CNT    31
     C           *IN90     DOUEQ*ON
     C           K#AGD     READEAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ITER
     C                     ENDIF
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         @CNT
     C                     ELSE
     C                     ADD  0.5       @CNT
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      * LAST MONTH
     C                     SUB  1         @MONTH
     C           @MONTH    IFEQ *ZERO
     C                     ADD  12        @MONTH
     C                     SUB  1         @YEAR
     C                     ENDIF
     C           K#AGD     SETLLAGDPL12
     C                     Z-ADD*ZERO     @CNTX   31
     C           *IN90     DOUEQ*ON
     C           K#AGD     READEAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ITER
     C                     ENDIF
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         @CNTX
     C                     ELSE
     C                     ADD  0.5       @CNTX
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *IN99
     C                     ENDIF
     C*
     C                     Z-ADD0         MISU
      *
     C                     MOVE *BLANK    @ASJ    3
     C                     Z-ADD*ZERO     @MAX    30
      ****************
      * 品番・区別 *
      ****************
     C           HNBAN     CHAINAAMPL111             25
     C           *IN25     IFEQ '1'
     C                     GOTO END
     C                     END
     C                     EXSR SYTE
      *
     C           KANSY     IFEQ *BLANK
     C                     GOTO END
     C                     END
      *
     C           KANSY     IFNE 'C'
     C           KANSY     ANDNE'D'
     C           KANSY     ANDNE'E'
     C           KANSY     ANDNE'0'
      * MSK 98.04.06
     C           KANSY     ANDNE'1'
     C           KANSY     ANDNE'2'
     C           KANSY     ANDNE'4'
     C           KANSY     ANDNE'6'
     C           KANSY     ANDNE'7'
     C           KANSY     ANDNE'A'
     C           KANSY     ANDNE'B'
     C           KANSY     ANDNE'F'
     C                     EXSR $SB900
     C                     EXCPTDT
      *
     C                     GOTO END
     C                     END
      *
     C           HNBAN     CHAINFCEPL01              25
     C           *IN25     IFEQ *OFF
     C           @CNT      IFNE 0
     C           A2GEKN    DIV  @CNT      @SET   113H
     C                     ENDIF
     C           A2SSYS    IFNE 0
     C           @SET      DIV  A2SSYS    @SBX    41H
     C                     ENDIF
      *
     C                     ENDIF
      * ACTUAL SHIPMENT
     C                     Z-ADD*ZERO     @ACTQ  110
     C           HNBAN     SETLLMBDPL01
     C           *IN25     DOUEQ*ON
     C           HNBAN     READEMBDPL01                  25
     C           *IN25     IFEQ *OFF
     C                     ADD  F3TNSU    @ACTQ
     C                     ENDIF
     C                     ENDDO
      *
     C           A2SSYS    IFNE 0
     C           @ACTQ     DIV  A2SSYS    @BOX   113H
     C           @CNTX     IFNE 0
     C           @BOX      DIV  @CNTX     @ACT    41H
     C                     ENDIF
     C                     ENDIF
