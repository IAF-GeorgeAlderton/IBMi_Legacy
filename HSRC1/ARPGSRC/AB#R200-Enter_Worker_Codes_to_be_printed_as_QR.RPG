     H            Y.
     F** AB#R200  *******************************************
     F* ENTER WORKER CODES TO BE PRINTED AS QR              *
     F*    LEC              2024.09.11                      *
     F*******************************************************
     FAB#PW200CF  E                    WORKSTN
     FALBPL30 IF  E           K        DISK
     FAB#WP200O   E                    DISK                      A
     E                    ER      1   2 30
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  140SDATE
     I                                        1   60STIME
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
      *
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB100
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * SCREEN 1 - GET WORKER CODE                         *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     EXFMTFMT100
     C                     MOVEL*BLANK    F1ERR
     C                     SETOF                     6199
      *
     C           *INKC     IFEQ *ON
     C                     MOVEL'99'      DSPSW   2
     C                     GOTO ESB100
     C                     ENDIF
      *
     C           *INKI     IFEQ *ON
     C                     CALL 'ALBC34'
     C                     GOTO ESB100
     C                     ENDIF
      *
      * validate worker code...
     C           F1WKCD    IFEQ *ZERO
     C                     SETON                     6199
     C                     MOVELER,1      F1ERR
     C                     GOTO ESB100
     C                     ENDIF
      *
     C           F1WKCD    CHAINALBPL30              51
      *
     C           *IN51     IFEQ *OFF
     C           ALSKJY    ANDEQ'D'
     C                     MOVE *ON       *IN51
     C                     MOVE *ON       *IN61
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C           *IN51     IFEQ *ON
     C                     MOVELER,2      F1ERR
     C                     GOTO ESB100
     C                     ENDIF
      *
      * get confirmation for correct worker code...
     C                     Z-ADDALWKCD    F2WKCD
     C                     MOVELALWKNM    F2WKNM
      *
     C                     EXFMTFMT200
     C           *INKL     IFEQ *ON
     C                     Z-ADD*ZERO     F1WKCD
     C                     GOTO ESB100
     C                     ENDIF
      *
      * write worker code to be printed...
     C                     Z-ADDF1WKCD    W1WKCD
     C                     MOVELALWKNM    W1WKNM
     C                     MOVELALDPCD    W1DPCD
     C                     WRITEAB#WP201
      *
      * add to total...
     C                     ADD  1         F1CNT
     C                     Z-ADD*ZERO     F1WKCD
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
**
INPUT WORKER CODE
WORKER CODE NOT FOUND
