     H            Y.
     F** MRAR01 *********************************************
     F* NEW PRODUCTION CONTROL                              *
     F*     TRANCOM ITS.           2012.09.11               *
     F*******************************************************
     FMRAPW01 CF  E                    WORKSTN
     FMRAPL01 IF  E           K        DISK
      *
     E                    ER      1  15 60
      *
     I            DS
     I                                        1   80M1SKHZ
     I                                        1   40M1SKYY
     I                                        5   60M1SKMM
     I                                        7   80M1SKDD
      *
     I            DS
     I                                        1  12 D1SHN
     I                                        1   5 D1SHN1
     I                                        6  10 D1SHN2
     I                                       11  12 D1SHN3
      *
     C           *ENTRY    PLIST
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1SEKB  1
     C                     PARM           P1PRKB  1
     C                     PARM           PCMD    2
      *
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVEL'01'      DSPSW   2
     C                     MOVEL*BLANK    P1SHN1  5
     C                     MOVEL*BLANK    P1SHN2  5
     C                     MOVEL*BLANK    P1SHN3  2
     C                     MOVEL*BLANK    P1SEKB  1
     C                     MOVEL*BLANK    P1PRKB  1
     C                     MOVEL*BLANK    PCMD
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTMRAPW011
     C                     SETOF                     313233
     C                     SETOF                     99
     C                     MOVEL*BLANK    D1ERR
      * F1
     C           *IN01     IFEQ '1'
     C                     MOVEL'01'      PCMD
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1SHN     IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVELER,1      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1SEKB    IFEQ '1'
     C           D1SEKB    OREQ '2'
     C                     ELSE
     C                     SETON                     3299
     C                     MOVELER,2      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1PRKB    IFEQ '1'
     C           D1PRKB    OREQ '2'
     C           D1PRKB    OREQ '3'
     C           D1PRKB    OREQ '4'
     C                     ELSE
     C                     SETON                     3399
     C                     MOVELER,3      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           KEYM11    KLIST
     C                     KFLD           #KSHN1  5
     C                     KFLD           #KSHN2  5
     C                     KFLD           #KSHN3  2
     C                     KFLD           #KSEKB  1
     C                     MOVELD1SHN1    #KSHN1
     C                     MOVELD1SHN2    #KSHN2
     C                     MOVELD1SHN3    #KSHN3
     C                     MOVELD1SEKB    #KSEKB
     C                     MOVEL'0'       GET     1
     C           KEYM11    SETLLMRAPL011
     C           KEYM11    READEMRAPL011                 20
     C           *IN20     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           M1SKJY    IFEQ 'D'
     C           M1SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           KEYM11    READEMRAPL011                 20
     C                     ENDDO
     C           GET       IFEQ '1'
     C                     SETON                     313233
     C                     SETON                     99
     C                     MOVELER,4      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     MOVELD1SHN1    P1SHN1
     C                     MOVELD1SHN2    P1SHN2
     C                     MOVELD1SHN3    P1SHN3
     C                     MOVELD1SEKB    P1SEKB
     C                     MOVELD1PRKB    P1PRKB
     C                     MOVEL'05'      PCMD
     C                     MOVEL'99'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
**
ER-1 INPUT INHOUSE PART NO.
ER-2 INPUT PART OR COMPONENT.(1,2)
ER-3 INPUT PRODUCTION LOCATION.(1,2,3,4)
ER-4 ALREADY REGISTED.
ER-5
ER-6
ER-7
ER-8
