     C                     MOVELKOT,32    KOTXX
     C                     MOVELKSE,32    KSEXX
     C           KEY2      SETGTGCQTL321
     C                     DO   *HIVAL
     C           F15       READEGCQTL321                 10
     C           *IN,10    IFEQ '0'
      *
     C*  SELECT
     C*
     C           DFSKJY    IFEQ 'D'
     C           DFSKHZ    CABLE*DATE     STP31
     C                     END
      *
     C           KEY1      CHAINAAMPL111             11
     C           *IN,11    IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,11
     C                     END
     C           *IN,11    IFEQ '1'
     C                     MOVE *BLANK    CKKO
     C                     Z-ADD*ZERO     CKBM
     C                     Z-ADD*ZERO     CKHZ
     C                     MOVE *BLANK    CKQK
     C                     Z-ADD*ZERO     CKQB
     C                     END
      *
     C                     MOVEA'0'       *IN,11
     C                     Z-ADD0         BUMXX
     C                     DO   15        J
     C                     Z-ADDCKHZ,J    Z06
     C           *DATE     IFGE Z06
     C           DFKOTI    IFEQ CKKO,J
     C                     Z-ADDCKBM,J    BUMXX
     C                     MOVEA'1'       *IN,11
     C                     END
     C                     ELSE
     C           DFKOTI    IFEQ CKQK,J
     C                     Z-ADDCKQB,J    BUMXX
     C                     MOVEA'1'       *IN,11
     C                     END
     C                     END
     C  N11                END
      *
     C           BUMCD     IFNE 0
     C           BUMCD     CABNEBUMXX     STP31
     C                     END
      *
     C           *IN,90    IFEQ '0'
     C                     MOVE *BLANK    HIN
     C                     MOVE *BLANK    BUM
     C                     MOVE *BLANK    KOT
     C                     MOVE *BLANK    KSE
     C                     Z-ADD0         I
     C                     MOVEA'1'       *IN,90
     C                     END
      *
     C                     ADD  1         I
     C           I         COMP 32                   88
     C           I         CABGT32        STP32
      *
     C                     MOVE *BLANK    F14
     C                     MOVELDFSHN1    F14A
     C                     MOVEL'-'       F14B
     C                     MOVELDFSHN2    F14C
     C                     MOVEL'-'       F14D
     C                     MOVELDFSHN3    F14E
     C                     MOVELF14       HIN,I
     C                     MOVELBUMXX     BUM,I
     C                     MOVELDFKOTI    KOT,I
     C                     MOVELDFKSEI    KSE,I
     C                     END
      *
     C           STP31     TAG
     C  N10                END
      *
     C           STP32     TAG
     C           *IN,90    IFEQ '0'
     C                     MOVELMSG,5     ERR
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP20
     C                     END
      *
     C                     GOTO STP20
     C                     END
      *
     C*  PRESS ROLL-DOWN
     C*
     C           *IN,82    IFEQ '1'
     C                     MOVEA'0'       *IN,88
      *
     C           HIN,1     IFEQ *BLANK
     C                     MOVELMSG,6     ERR
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP20
     C                     END
      *
     C                     MOVEA'0'       *IN,90
     C                     MOVE *BLANK    F14
     C                     MOVELHIN,1     F14
     C                     MOVELKOT,1     KOTXX
     C                     MOVELKSE,1     KSEXX
     C           KEY2      SETLLGCQTL321
     C                     DO   *HIVAL
     C                     READPGCQTL321                 10
     C           *IN,10    IFEQ '0'
     C           F15       ANDNEDFKATA
     C                     MOVEA'1'       *IN,10
     C                     END
     C           *IN,10    IFEQ '0'
      *
     C*  SELECT
     C*
     C           DFSKJY    IFEQ 'D'
     C           DFSKHZ    CABLE*DATE     STP41
     C                     END
      *
     C           KEY1      CHAINAAMPL111             11
     C           *IN,11    IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,23
     C                     END
     C           *IN,11    IFEQ '1'
     C                     MOVE *BLANK    CKKO
     C                     Z-ADD*ZERO     CKBM
     C                     Z-ADD*ZERO     CKHZ
     C                     MOVE *BLANK    CKQK
     C                     Z-ADD*ZERO     CKQB
     C                     END
      *
     C                     MOVEA'0'       *IN,11
     C                     Z-ADD0         BUMXX
     C                     DO   15        J
     C                     Z-ADDCKHZ,J    Z06
     C           *DATE     IFGE Z06
     C           DFKOTI    IFEQ CKKO,J
     C                     Z-ADDCKBM,J    BUMXX
     C                     MOVEA'1'       *IN,11
     C                     END
     C                     ELSE
     C           DFKOTI    IFEQ CKQK,J
     C                     Z-ADDCKQB,J    BUMXX
     C                     MOVEA'1'       *IN,11
     C                     END
     C                     END
     C  N11                END
      *
     C           BUMCD     IFNE 0
     C           BUMCD     CABNEBUMXX     STP41
     C                     END
      *
     C           *IN,90    IFEQ '0'
     C                     Z-ADD1         I
     C           *BLANK    LOKUPHIN,I                    11
     C                     MOVE *BLANK    HIN
     C                     MOVE *BLANK    BUM
     C                     MOVE *BLANK    KOT
     C                     MOVE *BLANK    KSE
     C                     Z-ADD33        I
     C                     MOVEA'1'       *IN,90
     C                     END
      *
     C                     SUB  1         I
     C           I         CABLT1         STP42
      *
     C                     MOVE *BLANK    F14
     C                     MOVELDFSHN1    F14A
     C                     MOVEL'-'       F14B
     C                     MOVELDFSHN2    F14C
     C                     MOVEL'-'       F14D
     C                     MOVELDFSHN3    F14E
     C                     MOVELF14       HIN,I
     C                     MOVELBUMXX     BUM,I
     C                     MOVELDFKOTI    KOT,I
     C                     MOVELDFKSEI    KSE,I
     C                     END
      *
     C           STP41     TAG
     C  N10                END
      *
     C           STP42     TAG
     C           *IN,90    IFEQ '0'
