     C*-----------------------*
     C*  EXFMT < 1>       *
     C*-----------------------*
     C           STP10     TAG
     C                     WRITEGCQPW341
     C                     READ GCQPW34                999001TIME 
      *
     C           *INKA     IFEQ '1'
     C                     MOVEL'1'       *INLR
     C                     RETRN
     C                     END
      *
     C                     MOVEA'00000'   *IN,01
     C                     MOVEA'00000'   *IN,06
     C                     MOVE *BLANK    ERR
     C           *IN,99    IFEQ '1'
     C           @STTS     ANDEQ1331
     C                     MOVELMSG,7     ERR
     C                     GOTO STP10
     C                     END
      *
     C*   (1)  
     C*
     C           KAT1      IFEQ *BLANK
     C           KAT2      ANDEQ*BLANK
     C                     MOVELMSG,1     ERR
     C                     MOVEA'11'      *IN,01
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP10
     C                     END
      *
     C                     MOVE *BLANK    F15
     C                     MOVELKAT1      F15A
     C                     MOVEL'-'       F15B
     C                     MOVELKAT2      F15C
     C           F15       SETLLGCQTL321                 10
     C           *IN,10    IFEQ '0'
     C                     MOVELMSG,2     ERR
     C                     MOVEA'11'      *IN,01
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP10
     C                     END
      *
     C           BUMCD     IFNE 0
     C                     Z-ADD1         I       50
     C           BUMCD     LOKUPXBUM,I                   10
     C           *IN,10    IFEQ '0'
     C                     MOVELMSG,3     ERR
     C                     MOVEA'1'       *IN,03
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP10
     C                     END
     C                     END
      *
     C*    
     C*
     C                     SETOF                     77
     C                     MOVE *BLANK    HIN
     C                     MOVE *BLANK    BUM
     C                     MOVE *BLANK    KOT
     C                     MOVE *BLANK    KSE
     C                     Z-ADD0         I
     C                     Z-ADD0         KENSU
      *
     C           F15       SETLLGCQTL321
     C                     DO   *HIVAL
     C           F15       READEGCQTL321                 10
     C           *IN,10    IFEQ '0'
      *
     C*  SELECT
     C*
     C           DFSKJY    IFEQ 'D'
     C           DFSKHZ    CABLE*DATE     STP11
     C                     END
      *
     C           KEY1      KLIST
     C                     KFLD           DFSHN1
     C                     KFLD           DFSHN2
     C                     KFLD           DFSHN3
     C           KEY1      CHAINAAMPL111             11
     C           *IN,11    IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,11
     C                     END
     C           *IN,11    IFEQ '1'
     C                     MOVE *BLANK    CKKO
     C                     Z-ADD*ZERO     CKBM
     C                     Z-ADD*ZERO     CKHZ
     C                     MOVE *BLANK    CKQK
     C                     Z-ADD*ZERO     CKQB
     C                     END
      *
     C                     MOVEA'0'       *IN,11
     C                     Z-ADD0         BUMXX   40
     C                     DO   15        J       50
     C                     Z-ADDCKHZ,J    Z06     80
     C           *DATE     IFGE Z06
     C           DFKOTI    IFEQ CKKO,J
     C                     Z-ADDCKBM,J    BUMXX
     C                     MOVEA'1'       *IN,11
     C                     END
     C                     ELSE
     C           DFKOTI    IFEQ CKQK,J
     C                     Z-ADDCKQB,J    BUMXX
     C                     MOVEA'1'       *IN,11
     C                     END
     C                     END
     C  N11                END
      *
     C           BUMCD     IFNE 0
     C           BUMCD     CABNEBUMXX     STP11
     C                     END
      *
     C                     ADD  1         KENSU
     C           *IN77     IFEQ '0'
     C                     ADD  1         I
      *
     C           I         IFGT 32
     C                     SETON                     7788
     C                     ELSE
      *
     C                     MOVE *BLANK    F14
     C                     MOVELDFSHN1    F14A
     C                     MOVEL'-'       F14B
     C                     MOVELDFSHN2    F14C
     C                     MOVEL'-'       F14D
     C                     MOVELDFSHN3    F14E
     C                     MOVELF14       HIN,I
     C                     MOVELBUMXX     BUM,I
     C                     MOVELDFKOTI    KOT,I
     C                     MOVELDFKSEI    KSE,I
     C                     END
     C                     END
     C                     END
      *
     C           STP11     TAG
     C  N10                END
      *
     C           I         IFEQ 0
