      *
     C                     MOVE *BLANK    PSW     1
      *
     C           STP00     TAG
     C                     MOVE *BLANK    KAT1
     C                     MOVE *BLANK    KAT2
     C                     Z-ADD0         BUMCD
     C                     MOVE *BLANK    ERR
     C                     MOVEA'00000'   *IN,01
     C                     MOVEA'00000'   *IN,06
     C                     MOVEA'0'       *IN,99
