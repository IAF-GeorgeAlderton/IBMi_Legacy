     FUAAPW01 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        SFLRRNKSFILE SFLREC
     FFAAPL02 IF  E           K        DISK
     E                    ERR     1   3 78
     IINFDS       DS
     I                                      273 282 WSNAME
     I* SUBFILE START LINE DATA BASEKEY SAVE
     I            DS
     I                                        10033 SKEYDS
     I* SUBFILE LAST LINE DATA BASEKEY SAVE
     I            DS
     I                                        10033 EKEYDS
     I* SEARCH LOVAL KEY
     I            DS
     I                                     00010004 LVKY01
     I                                     00050008 LVKY02
     I                                     00090009 LVKY03
     I                                     00100013 LVKY04
     I                                     00140018 LVKY05
     I                                     00190023 LVKY06
     I                                     00240028 LVKY07
     I                                     00290033 LVKY08
     I                                        10033 LVKYDS
     I* SEARCH HIVAL KEY
     I            DS
     I                                     00010004 HVKY01
     I                                     00050008 HVKY02
     I                                     00090009 HVKY03
     I                                     00100013 HVKY04
     I                                     00140018 HVKY05
     I                                     00190023 HVKY06
     I                                     00240028 HVKY07
     I                                     00290033 HVKY08
     I                                        10033 HVKYDS
     I* DATA BASE KEY WORK FIELD
     I            DS
     I                                     000100040FLKY01
     I                                     000500080FLKY02
     I                                     00090009 FLKY03
     I                                     00100013 FLKY04
     I                                     00140018 FLKY05
     I                                     00190023 FLKY06
     I                                     00240028 FLKY07
     I                                     00290033 FLKY08
     I                                        10033 FKEYDS
     I* DATA BASE FULL KEY
     I            DS
     I                                     000100040B7TOKU
     I                                     000500080B7NONY
     I                                     00090009 B7NKJO
     I                                     00100013 B7NUKE
     I                                     00140018 B7MHN1
     I                                     00190023 B7MHN2
     I                                     00240028 B7MHN3
     I                                     00290033 B7MHN4
     I                                        10033 DBKEY
     C* DB FULL KEY
     C           FULKEY    KLIST
     C                     KFLD           FLKY01
     C                     KFLD           FLKY02
     C                     KFLD           FLKY03
     C                     KFLD           FLKY04
     C                     KFLD           FLKY05
     C                     KFLD           FLKY06
     C                     KFLD           FLKY07
     C                     KFLD           FLKY08
     C* LINES SET-UP
     C                     Z-ADD19        LINES   30
     C/SPACE 2
     C***********************************************
     C* MAIN ROUTINE                                *
     C***********************************************
     C           PUT01     TAG
     C                     EXFMTSCR1
     C* COMMAND KEY CHECK
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C* INPUT FIELD CHECK
     C           WSKY01    IFEQ *ZERO
     C                     MOVE ERR,1     ERRMSG 78
     C                     GOTO ERR01
     C                     END
     C*       *****************************************             *USER*
     C*      *        INSERT OTHER CHECK ROUTINE       *            *USER*
     C*     *       * SAMPLE *                          *           *USER*
     C*     *              MOVE ERR,X     ERRMSG        *           *USER*
     C*      *             GOTO ERR01                  *            *USER*
     C*       *****************************************             *USER*
     C* HIVAL/LOVAL/FULLKEY  INITIALIZE
     C                     MOVE *HIVAL    HVKYDS
     C                     MOVE *LOVAL    LVKYDS
     C                     MOVE *ZERO     FLKY01
     C                     MOVE *ZERO     FLKY02
     C                     MOVE *BLANK    FLKY03
     C                     MOVE *BLANK    FLKY04
     C                     MOVE *BLANK    FLKY05
     C                     MOVE *BLANK    FLKY06
     C                     MOVE *BLANK    FLKY07
     C                     MOVE *BLANK    FLKY08
     C* HIVAL/LOVAL/FULLKEYY SET
     C                     MOVE WSKY01    HVKY01
     C                     MOVE WSKY01    LVKY01
     C                     MOVE WSKY01    FLKY01
     C           WSKY02    IFNE *ZERO
     C                     MOVE WSKY02    HVKY02
     C                     MOVE WSKY02    LVKY02
     C                     MOVE WSKY02    FLKY02
     C                     END
     C           WSKY03    IFNE *BLANK
     C                     MOVE WSKY03    HVKY03
     C                     MOVE WSKY03    LVKY03
     C                     MOVE WSKY03    FLKY03
     C                     END
     C           WSKY04    IFNE *BLANK
     C                     MOVE WSKY04    HVKY04
     C                     MOVE WSKY04    LVKY04
     C                     MOVE WSKY04    FLKY04
     C                     END
     C           WSKY05    IFNE *BLANK
     C                     MOVE WSKY05    HVKY05
     C                     MOVE WSKY05    LVKY05
     C                     MOVE WSKY05    FLKY05
     C                     END
     C           WSKY06    IFNE *BLANK
     C                     MOVE WSKY06    HVKY06
     C                     MOVE WSKY06    LVKY06
     C                     MOVE WSKY06    FLKY06
     C                     END
     C           WSKY07    IFNE *BLANK
     C                     MOVE WSKY07    HVKY07
     C                     MOVE WSKY07    LVKY07
     C                     MOVE WSKY07    FLKY07
     C                     END
     C           WSKY08    IFNE *BLANK
     C                     MOVE WSKY08    HVKY08
     C                     MOVE WSKY08    LVKY08
     C                     MOVE WSKY08    FLKY08
     C                     END
     C* DB-READ SUBROUTINE
     C                     SETON                     9091
     C                     EXSR SFLSTR
     C                     SETOF                     9091
     C   99                GOTO PUT01
     C                     GOTO PUT02
     C/SPACE 1
     C           ERR01     TAG
     C                     SETON                     99
     C                     GOTO PUT01
     C/SPACE 2
     C* SECOND SCREEN
     C           PUT02     TAG
     C                     WRITESCR2
     C                     DO   *HIVAL
     C   99                SETON                     98
     C  N99                SETON                     9798
     C                     EXFMTSFLCTL
     C                     SETOF                     9798
     C* COMMAND KEY CHECK
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C  N91N92             GOTO PUT01
     C* CALL DB-READ SUBROUTINE
     C                     EXSR SFLSTR
     C                     END
     C/EJECT
     C***********************************************
     C* DB-READ & STORE SUBROUTINE                  *
     C***********************************************
     C           SFLSTR    BEGSR
     C                     Z-ADD*ZERO     LINECT
     C/SPACE 2
     C* ROLL-UP(DB-POINTER SET)
     C           *IN91     IFEQ '1'
     C                     Z-ADD1         SFLRRN  40
     C* FIRST CALL ?
     C           *IN90     IFEQ '1'
     C           FULKEY    SETLLFAAPL02
     C* NORMAL ROLL-UP
     C                     ELSE
     C           LAST      IFEQ '*'
     C                     MOVE ERR,2     ERRMSG
     C                     GOTO ERRSTR
     C                     END
     C* PREVIOUS END KEY SET
     C                     MOVE EKEYDS    FKEYDS
     C           FULKEY    SETGTFAAPL02
     C                     END
     C/SPACE 2
     C* ROLL-DOWN(DB-POINTER SET)
     C                     ELSE
     C           PAGCNT    SUB  1         PAGWRK  30
     C           PAGWRK    IFLE *ZERO
     C                     MOVE ERR,2     ERRMSG
     C                     GOTO ERRSTR
     C                     END
     C* PREVIOUS START KEY SET
     C                     MOVE SKEYDS    FKEYDS
     C           FULKEY    SETLLFAAPL02
     C                     Z-ADDLINES     SFLRRN
     C                     END
     C/SPACE 2
     C* FIRST CYCLE FIELD INITIALIZE
     C           *IN90     IFEQ '1'
     C                     Z-ADD*ZERO     PAGCNT
     C                     END
     C* SFLCLR
     C                     SETON                     96
     C                     WRITESFLCTL
     C                     SETOF                     96
     C/SPACE 2
     C* DB-READ LOOP
     C                     DO   *HIVAL
     C           *IN91     IFEQ '1'
     C           STEP01    TAG
     C                     READ FAAPL02                  20
     C  N20      B7SKBN    CABEQ'D'       STEP01
     C   20                SETON                     94
     C                     ELSE
     C           STEP02    TAG
     C                     READPFAAPL02                  20
     C  N20      B7SKBN    CABEQ'D'       STEP02
     C                     END
     C* END OF FILE GROUP
     C           *IN20     CABEQ'1'       LPOUT
     C* RANGE CHECK
     C           DBKEY     CABLTLVKYDS    LPOUT
     C           DBKEY     IFGT HVKYDS
     C                     SETON                     94
     C                     GOTO LPOUT
     C                     END
     C* DB-FIELD TO WORK-STATION FIELD
     C*       *****************************************             *USER*
     C*      *     INSERT ADDTIONAL STATEMENT          *            *USER*
     C*      *       FOR USER DEFINED FIELDS           *            *USER*
     C*       *****************************************             *USER*
     C                     ADD  1         LINECT  30
     C                     WRITESFLREC
     C* START LINE KEY SAVE
     C           SFLRRN    IFEQ 1
     C                     MOVE DBKEY     SKEYDS
     C           *IN91     CABEQ'0'       LPOUT
     C                     END
     C* LAST LINE KEY SAVE
     C           SFLRRN    IFEQ LINES
     C                     MOVE DBKEY     EKEYDS
     C           *IN91     CABEQ'1'       LPOUT
     C                     END
     C           *IN91     IFEQ '1'
     C                     ADD  1         SFLRRN
     C                     ELSE
     C                     SUB  1         SFLRRN
     C                     END
     C                     END
     C*
     C/SPACE 2
     C           LPOUT     TAG
     C           LINECT    IFEQ *ZEROS
     C                     MOVE ERR,3     ERRMSG
     C                     GOTO ERRSTR
     C                     END
     C* PAGE  CONTROL
     C           *IN91     IFEQ '1'
     C                     ADD  1         PAGCNT  30
     C           LINECT    IFLT LINES
     C                     MOVE '*'       LAST    1
     C                     ELSE
     C                     MOVE *BLANK    LAST
     C                     END
     C                     ELSE
     C                     MOVE *BLANK    LAST
     C                     SUB  1         PAGCNT
     C                     END
     C*
     C                     GOTO ENDSTR
     C           ERRSTR    TAG
     C                     SETON                     99
     C           ENDSTR    ENDSR
