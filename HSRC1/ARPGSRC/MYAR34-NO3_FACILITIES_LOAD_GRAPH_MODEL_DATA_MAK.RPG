     H            Y.
      ** MYAR34 ****************************************
      *  NO.3 FACILITIES LOAD GRAPH MODEL DATA MAKING  *
      * 設備負荷グラフ№３機種データ作成             *
      *    I-HASADA                 2013/03/11         *
      **************************************** MYAR34 **
     FMYAWP3B IP  F     100            DISK
     FMYANP32 IF  E           K        DISK
     FMYAWP34 O   F     200            DISK
      *
     IMYAWP3B AA  01
     I                                        1   3 IKOTE L1
     I                                        4  13 IKKNO L1
     I                                       14  190IKAIT
     I                                       20  242IBRIT
     I                                       25  270IDNKI
     I                                       28  330IDNTI
      *
     C           KEY1      KLIST
     C                     KFLD           IKOTE
     C                     KFLD           IKKNO
      *
     C           *IN10     IFEQ '0'
     C                     SETON                     10
     C                     EXCPTHD
     C                     END
      *
     C           *INL1     IFEQ '1'
     C                     Z-ADD0         WREC1   40
     C                     Z-ADD0         WREC2   40
     C                     Z-ADD0         WREC3   40
     C                     Z-ADD0         WREC4   40
     C                     Z-ADD0         WKAIT   70
     C                     Z-ADD0         WBRIT   62
     C                     Z-ADD0         WDNKI   40
     C                     Z-ADD0         WDNTI   70
     C                     END
      *
     C           IKAIT     IFNE 0
     C                     ADD  1         WREC1
     C                     ADD  IKAIT     WKAIT
     C                     END
      *
     C           IBRIT     IFNE 0
     C                     ADD  1         WREC2
     C                     ADD  IBRIT     WBRIT
     C                     END
      *
     C           IDNKI     IFNE 0
     C                     ADD  1         WREC3
     C                     ADD  IDNKI     WDNKI
     C                     END
      *
     C           IDNTI     IFNE 0
     C                     ADD  1         WREC4
     C                     ADD  IDNTI     WDNTI
     C                     END
      *
     CL1                   EXSR SUBR
      *
      *
      *@@@@@@@@@@@*
      *  ﾅﾎﾞﾓｰk]  *
      *@@@@@@@@@@@*
     C           SUBR      BEGSR
      *
     C                     Z-ADD0         TKAIT   60
     C                     Z-ADD0         TBRIT   52
     C                     Z-ADD0         TDNKI   30
     C                     Z-ADD0         TDNTI   51
      *
     C           WREC1     IFNE 0
     C           WKAIT     DIV  WREC1     TKAIT     H
     C                     END
      *
     C           WREC2     IFNE 0
     C           WBRIT     DIV  WREC2     TBRIT     H
     C                     END
      *
     C           WREC3     IFNE 0
     C           WDNKI     DIV  WREC3     TDNKI     H
     C                     END
      *
     C           WREC4     IFNE 0
     C           WDNTI     DIV  WREC4     TDNT    60H
     C           TDNT      DIV  60        TDNTI     H
     C                     END
      *
      *================
      * 機種設備台数
     C                     Z-ADD0         TRECD   40
     C           KEY1      SETLLMYANP321
     C                     DO   *HIVAL
     C                     SETOF                     11
     C           KEY1      READEMYANP321                 11
     C           *IN11     IFEQ '0'
     C                     ADD  1         TRECD
     C                     END
     C  N11                END
      *
     C                     ENDSR
      *
     OMYAWP34 E                HD
     O                                      'PROCESS CORD'
     O                                      ','
     O                                      'MODEL (MACHINE FORM)'
     O                                      ','
     O                                      'MACHINE NUMBER '
     O                                      'REVOLUTIONS<AVARAGE>'
     O                                      ','
     O                                      'MOVABLE RATE<AVARAGE>'
     O                                      ','
     O                                      'MAKING ARRANGEMENTS '
     O                                      'NUMBER TIMES<AVARAGE>'
     O                                      ','
     O                                      'MAKING ARRANGEMENTS '
     O                                      'TIME(H)<AVARAGE>'
     O                                      ','
     O                                      'FACILITIES NUMBER'
      *
     O        T        L1
     O                                      '="'
     O                         IKOTE
     O                                      '"'
     O                                      ','
     O                                      '="'
     O                         IKKNO
     O                                      '"'
     O                                      ','
     O                         TKAIT 3
     O                                      ','
     O                         TBRIT 3
     O                                      ','
     O                         TDNKI 3
     O                                      ','
     O                         TDNTI 3
     O                                      ','
     O                         TRECD 3
