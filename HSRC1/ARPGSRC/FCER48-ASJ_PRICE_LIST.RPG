     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      *
     C           K#KEY1    KLIST
     C                     KFLD           K@SHN1  5
     C                     KFLD           K@SHN2  5
     C                     KFLD           K@SHN3  2
     C           K#KEY2    KLIST
     C                     KFLD           K@KAT1  2
     C                     KFLD           K@KAT2  4
     C                     KFLD           K@KAT3  1
     C           K#K11     KLIST
     C                     KFLD           K@SHN1  5
     C                     KFLD           K@SHN2  5
     C                     KFLD           K@SHN3  2
     C                     KFLD           K@TOKU
      *
     C                     Z-ADD0111      K@TOKU  40
     C                     Z-ADD0111      K@NONY  40
     C                     MOVE '01'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *  1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     MOVE *ON       *IN10
     C                     WRITEDSP01
     C                     EXSR #WRT
     C                     MOVE '99'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
      *
     C           D@OPT1    IFLT '1'
     C           D@OPT1    ORGT '2'
     C                     SETON                     9961
     C                     ENDIF
      *
     C           D@OPT2    IFNE *BLANK
     C           D@OPT2    ANDNE'1'
     C                     SETON                     9962
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  WRITE
      *------------------------------------------------------
     C           #WRT      BEGSR
      *
     C                     MOVEA'000'     *IN,1
      *
     C                     SELEC
     C           D@OPT1    WHEQ '1'
     C                     MOVE *ON       *IN01
     C                     MOVEACMD,1     P@CMD
     C                     Z-ADD17        P@LEN
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN FCEWP481
     C                     EXSR #WRT1
      *
     C           D@OPT1    WHEQ '2'
     C                     MOVE *ON       *IN03
     C                     MOVEACMD,2     P@CMD
     C                     Z-ADD17        P@LEN
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN FCEWP483
     C                     EXSR #WRT2
     C                     ENDSL
      *
     C                     ENDSR
      *-------------------------------------------------------
      *  PT/WASHER
      *-------------------------------------------------------
     C           #WRT1     BEGSR
      *
     C           *LOVAL    SETLLBBCDDM
     C           *IN80     DOUEQ*ON
     C                     READ BBCDDM                   80
     C           *IN80     IFEQ *OFF
     C           BCSKJY    ANDEQ*BLANK
     C                     MOVE BCSHN1    K@SHN1
     C                     MOVE BCSHN2    K@SHN2
     C                     MOVE BCSHN3    K@SHN3
      *
     C           K@SHN1    CAT  '-':0     FAPART    P
     C           FAPART    CAT  K@SHN2:0  FAPART    P
     C           K@SHN3    IFNE *BLANK
     C           FAPART    CAT  '-':0     FAPART    P
     C           FAPART    CAT  K@SHN3:0  FAPART    P
     C                     ENDIF
      *
     C           K#K11     SETGTBBCDDM
     C           *IN90     DOUEQ*ON
     C           K#K11     REDPEBBCDDM                   90
     C           *IN90     IFEQ *OFF
     C           BCSKJY    ANDEQ*BLANK
      *
     C           D@OPT2    IFEQ *BLANK
     C           WTO       ANDGE*DATE
     C           D@OPT2    OREQ '1'
      *
     C                     Z-ADDBCKTNK    FAPRCE
     C                     Z-ADDWVALD     FAFROM
     C                     Z-ADDWTO       FATO
     C                     WRITEFCEWP48A
     C           D@OPT2    IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           K#KEY1    SETGTBBCDDM
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-------------------------------------------------------
      *  DIE
      *-------------------------------------------------------
     C           #WRT2     BEGSR
      *
     C           *LOVAL    SETLLGKGDDM
     C           *IN80     DOUEQ*ON
     C                     READ GKGDDM                   80
     C           *IN80     IFEQ *OFF
     C           GKSKJY    ANDEQ*BLANK
     C                     MOVE GKKAT1    K@KAT1
     C                     MOVE GKKAT2    K@KAT2
     C                     MOVE GKKAT3    K@KAT3
     C           K@KAT1    CAT  '-':0     FCPART    P
     C           FCPART    CAT  K@KAT2:0  FCPART    P
     C           K@KAT3    IFNE *BLANK
     C           FCPART    CAT  '-':0     FCPART    P
     C           FCPART    CAT  K@KAT3:0  FCPART    P
     C                     ENDIF
      *
     C           K#KEY2    SETGTGKGDDM
     C           *IN90     DOUEQ*ON
     C           K#KEY2    REDPEGKGDDM                   90
     C           *IN90     IFEQ *OFF
     C           GKSKJY    ANDEQ*BLANK
      *
     C           D@OPT2    IFEQ *BLANK
     C           WTO3      ANDGE*DATE
     C           D@OPT2    OREQ '1'
     C                     Z-ADDGKNHTN    FCPRCE
     C                     Z-ADDWVALD3    FCFROM
     C                     Z-ADDWTO3      FCTO
     C                     WRITEFCEWP48C
      *
     C           D@OPT2    IFEQ *BLANK
     C           K#KEY2    SETGTGKGDDM
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
      *
     C                     ENDSR
      *
      *------------------------------------------------------
**  CMD
CLRPFM FCEWP481
CLRPFM FCEWP483
