     H            Y.
     F** EDTR05 ***********************************************************
     F*  CONVERT NUMERIC : (CHARACTER TO NUMERIC)  /EDIT
     F*  IF DECIMAL > 6, ---> DECIMAL=6  (NOT ERROR)
     F*   ** '0.123456789   ' --> '000000000.123456'
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'EDTR05'
     F*                    PARM           $IN    17
     F*                    PARM           $TRUE  156
     F*                    PARM           $RTN    1
     F*   IN  $IN    17A   SOURCE NUMBER  (EX. 0.018____)
     F*   OUT $TRUE  15,6  TRUE NUMERIC VALUE
     F*       $RTN    1A   RETURN (BLANK: OK, *: ERROR)
     F*
     F*   ** DECIMAL POINT SHOULD BE <= 6 DIGITS
     F*   ** INTEGER       SHOULD BE <= 9 DIGITS
     F*   ** MAX 999,999,999.999999
     F*   ** MIN 0.000001 (-)
     F*   ** '710    ' --> '000000710.000000'
     F*   ** '0.123456789   ' --> '000000000.123456'
     F*********************************************************************
     E                    IN         17  1
     E                    OT         17  1
     E                    OT2        17  1
     F******************************************************************
     C                     EXSR #INIT
      *
     C                     Z-ADD18        IX               A  FOR A TO B
     C                     Z-ADD18        IY               B  FOR A TO B
     C                     Z-ADD0         IZ      20       COUNT
     C                     Z-ADD0         DEC#    20
     C                     Z-ADD0         INT#    20
     C                     Z-ADD0         TEMP   178
     C                     MOVE '+'       SIGN    1
     C                     MOVEA$IN       IN
     C* EXAMIN FROM BACKWARD
     C                     DO   *HIVAL
     C                     SUB  1         IX
      * END
     C           IX        IFEQ 0
     C                     LEAVE
     C                     ENDIF
      * MINUS FLAG
     C           IN,IX     IFEQ '-'
     C                     MOVE '-'       SIGN
     C                     ITER
     C                     ENDIF
      * DECIMAL POINT
     C           IN,IX     IFEQ '.'
     C           DEC#      IFEQ 0
     C                     Z-ADDIZ        DEC#
     C                     ENDIF
     C                     ITER
     C                     ENDIF
      * IGNORE
     C           IN,IX     IFEQ *BLANK
     C           IN,IX     OREQ ','
     C                     ITER
     C                     ENDIF
      * NUMERIC ERROR
     C           IN,IX     IFLT '0'
     C           IN,IX     ORGT '9'
     C                     MOVE '*'       $RTN
     C                     LEAVE
     C                     ENDIF
      * MOVE VALUE
     C                     SUB  1         IY
     C                     MOVE IN,IX     OT,IY
      * COUNT DECEMAL POINT DIGITS
     C                     ADD  1         IZ
      *
     C                     ENDDO
      *                    ========
      *
     C           $RTN      IFEQ '*'
     C                     GOTO @ENDP
     C                     ENDIF
      *
      * IF DECIMAL POINT > 6, THEN ADJUST
     C           DEC#      IFGT 6
     C           DEC#      SUB  6         IY
     C           1         DO   17        IX
     C                     ADD  1         IY
     C           IY        IFGE 18
     C                     LEAVE
     C                     ENDIF
     C                     MOVE OT,IX     OT2,IY
     C                     ENDDO
     C                     MOVEAOT2       OT
     C                     Z-ADD6         DEC#
     C                     ENDIF
      * INTEGER > 9. ERROR
     C           IZ        SUB  DEC#      INT#
     C           INT#      IFGT 9
     C                     MOVE '*'       $RTN
     C                     GOTO @ENDP
     C                     ENDIF
      *
     C                     MOVEAOT        LTR17  17
     C                     SELEC
     C           DEC#      WHEQ 0
     C                     MOVE LTR17     N090
     C                     Z-ADDN090      TEMP
     C           DEC#      WHEQ 1
     C                     MOVE LTR17     N101
     C                     Z-ADDN101      TEMP
     C           DEC#      WHEQ 2
     C                     MOVE LTR17     N112
     C                     Z-ADDN112      TEMP
     C           DEC#      WHEQ 3
     C                     MOVE LTR17     N123
     C                     Z-ADDN123      TEMP
     C           DEC#      WHEQ 4
     C                     MOVE LTR17     N134
     C                     Z-ADDN134      TEMP
     C           DEC#      WHEQ 5
     C                     MOVE LTR17     N145
     C                     Z-ADDN145      TEMP
     C           DEC#      WHEQ 6
     C                     MOVE LTR17     N156
     C                     Z-ADDN156      TEMP
     C                     ENDSL
      *
     C           SIGN      IFEQ '-'
     C                     MULT -1        TEMP
     C                     ENDIF
      *
     C                     Z-ADDTEMP      $TRUE
      *
     C           @ENDP     TAG
     C                     SETON                     LR
     C                     RETRN
      *==========================================================
      * INITIAL VALUE
      *==========================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $IN    17
     C                     PARM           $TRUE  156
     C                     PARM           $RTN    1
      *
     C                     Z-ADD0         $TRUE
     C                     MOVE *BLANK    $RTN
     C                     MOVE *ALL' '   IN
     C                     MOVE *ALL'0'   OT
     C                     MOVE *ALL'0'   OT2
     C                     Z-ADD0         IX      20
     C                     Z-ADD0         IY      20
     C                     Z-ADD0         N090    90
     C                     Z-ADD0         N101   101
     C                     Z-ADD0         N112   112
     C                     Z-ADD0         N123   123
     C                     Z-ADD0         N134   134
     C                     Z-ADD0         N145   145
     C                     Z-ADD0         N156   156
      *
     C                     ENDSR
