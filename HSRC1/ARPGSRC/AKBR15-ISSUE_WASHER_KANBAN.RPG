     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------------*
      *   INITIAL  SET                                     *
      *----------------------------------------------------*
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@END   1
      *
     C                     MOVE '1'       P@END
      *
     C           KEYT21    KLIST
     C                     KFLD           #KBMON  40
     C           K#AAP     KLIST
     C                     KFLD           L1JOK6
     C                     KFLD           L1KCD1
      *----------------------------------------------------*
     C                     TIME           @TIME   60
     C                     Z-ADD*DATE     HYMD8   80
      *----------------------------------------------------*
     C           K#KEY     KLIST
     C                     KFLD           D@LOC1
     C                     KFLD           D@LOC2
     C                     KFLD           D@LOC3
     C                     KFLD           D@LOC4
     C           K#KEYX    KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
      *
     C                     MOVEL'01'      W@ID    2
      *
     C                     ENDSR
      *--------------------------------------------------------
      *   1ST SCREEN
      *--------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #OUT
     C           D@LOC     CAT  MSG,2:1   D@MSG     P
     C                     MOVE *BLANK    D@LOC1
     C                     MOVE *BLANK    D@LOC2
     C                     MOVE *BLANK    D@LOC3
     C                     MOVE *BLANK    D@LOC4
     C                     MOVE *BLANK    D@PRT1
     C                     MOVE *BLANK    D@PRT2
     C                     MOVE *BLANK    D@PRT3
     C                     Z-ADD*ZERO     D@QTY
     C                     Z-ADD*ZERO     D@#KAN
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *--------------------------------------------------------
      *   CHECK
      *--------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     MOVEA'00000000'*IN,61
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    D@MSG
      *
     C           D@LOC     IFEQ *BLANK
     C                     SETON                     6199
     C                     ENDIF
     C           D@PRT1    IFEQ *BLANK
     C                     SETON                     6299
     C                     ENDIF
     C           D@QTY     IFEQ *ZERO
     C                     SETON                     6299
     C                     ENDIF
     C           D@#KAN    IFEQ *ZERO
     C                     SETON                     6399
     C                     ENDIF
      *
     C                     Z-ADD1         WKLTX   31
TCHK1C                     Z-ADD*ZERO     W@ROTO  20
     C           K#KEY     SETLLAKBPL01
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAKBPL01                  90
     C           *IN90     IFEQ *OFF
     C           L1SKJY    ANDEQ*BLANK
     C           L1STHZ    ANDEQ99999999
     C                     Z-ADDL1BMON    #KBMON
     C                     MOVE L1ZETI    #ZETI
     C                     MOVE L1KCD1    #KCD1
     C                     Z-ADDL1KSKB    WKKSKB
TCHK1C                     Z-ADDL1ROTO    W@ROTO
     C                     Z-ADDL1LTIM    WKLTX
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
TCHK1C           W@ROTO    IFEQ *ZERO
TCHK1C                     Z-ADD1         W@ROTO
     C                     END
      *
     C           *IN90     IFEQ *ON
     C                     Z-ADD*ZERO     W@ROTO  20
     C           K#KEY     SETLLADHPL03
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEADHPL03                  90
     C           *IN90     IFEQ *OFF
     C           J6SKJY    ANDEQ*BLANK
     C           J6STHZ    ANDEQ99999999
     C           J6ATKX    ANDEQ'R'
     C                     Z-ADDJ6ATOB    #KBMON
     C                     MOVE J6ZETI    #ZETI
     C                     MOVE J6KCD1    #KCD1
     C                     Z-ADDJ6KSNK    WKKSKB
     C                     Z-ADDJ6LOTO    W@ROTO
     C                     Z-ADDJ6TOLT    WKLTX   31
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C           W@ROTO    IFEQ *ZERO
     C                     Z-ADD1         W@ROTO
     C                     END
     C                     ENDIF
      *
     C           *IN90     IFEQ *ON
     C           K#KEYX    CHAINFCEPL01              90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDA2SIRE    #KBMON
     C                     MOVE A2ZETI    #ZETI
     C                     MOVE A2AK31    WKKSKB
     C                     MOVE A2BDAI    #KCD1
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN90     IFEQ *ON
     C                     SETON                     6299
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      * COMPONENTS  KANBAN DATA                            *
      *----------------------------------------------------*
     C           #OUT      BEGSR
      *
     C           KEYT21    SETLLGCKPL211
     C           *IN21     DOUEQ*ON
     C           KEYT21    READEGCKPL211                 21
     C           *IN21     IFEQ *OFF
     C           T2SKJY    ANDEQ*BLANK
     C                     MOVELT2NAMN    WKNAME
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADDD@QTY     WKSYOS
     C                     MOVE '-'       WKF1
     C                     MOVE '-'       WKF2
     C           D@PRT3    IFEQ *BLANK
     C                     MOVE *BLANK    WKF2
     C                     END
     C                     Z-ADDD@QTY     WKSYOS  60
     C                     Z-ADDWKLTX     WKLTIM  31
     C                     MOVE 'G'       WKSYOT  1
     C                     MOVE D@LOC     WKTKRO  6
      * A CIRCULATION
     C                     Z-ADDD@#KAN    WKHMAS  30
      *
     C                     MOVE '1'       WKCON   1
     C                     MOVE *BLANK    NAME   16
     C                     Z-ADD1         WKSTNO  30
     C                     Z-ADD1         WKEDNO  30
     C                     MOVE *BLANK    WKBARC
     C                     EXCPTFILE
     C                     MOVE *BLANK    WKCON
     C                     SETON                       U1
     C                     Z-ADD1         WKHKNO  30
      *
      *DIVIDE BY KANBAN SHEETS
     C                     SETOF                       22
     C                     DO   *HIVAL
     C                     MOVE WKNAME    NAME   16
     C                     MOVE '2'       WKCON   1
     C                     SUB  1         WKHMAS         22
     C                     Z-ADDWKHKNO    WKSTNO
     C                     Z-ADDD@#KAN    WKEDNO
      *
     C                     MOVE *BLANK    BARSET
      *
     C                     MOVE WKEDIT    BARSET
     C                     MOVE '*'       STRBAR
     C                     MOVE '*'       ENDBAR
      *
      *
     C                     MOVE *BLANK    W22    22
      *
     C                     EXCPTFILE
     C                     MOVE *BLANK    P@END
     C                     ADD  1         WKHKNO
     C  N22                END
      *
     C                     MOVE *BLANK    WKCON
      *
     C                     ENDSR
      *----------------------------------------------------*
     OAKBWP11AE                FILE
     O                         WKCON      1
     O                         WKSTNO     4
     O                         WKEDNO     7
     O                         NAME      23
     O                         @SHIN     37
     O                         WKBARC    52
     O                         WKLTIM    55
     O                         WKSYOS    61
     O                         WKSYOT    62
     O                         WKTKRO    68
     O                         HYMD8     76
     O                         W22       98
     O                         WKEDNO   101
TCHK1O                         W@ROTO   103
