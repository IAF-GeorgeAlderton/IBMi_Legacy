     H            Y.
     F** AH#RY6 ********************************
     F* CREATE A-PICS DATA OF NO SCAN          *
     F* JW     2019.01.18                      *
     F******************************************
     FAH#WPY1 IF  E           K        DISK
     FAH#WPY2 O   E           K        DISK
      *
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ******************************************
     C                     TIME           @SDATE
      *
     C                     DO   *HIVAL
     C                     READ AH#WPY1                  98
     C   98                LEAVE
      *
     C                     EXSR #MOVE
      *
     C                     WRITEAH#WPY21
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *=========================================
      * MOVE
      *=========================================
     C           #MOVE     BEGSR
     C                     Z-ADDIHTHZ     I2HTHZ
     C                     MOVELISHIN     I2SHIN
     C                     MOVELILOCA     I2LOCA
     C                     MOVELIZETI     I2ZETI
     C                     MOVELITHAI     I2THAI
     C                     Z-ADDIMAIS     I2MAIS
     C                     Z-ADDIBOX1     I2BOX1
     C                     MOVELIPOS1     I2POS1
     C                     Z-ADDIBOX2     I2BOX2
     C                     Z-ADDIRAT1     I2RAT1
     C                     MOVELIPOS2     I2POS2
     C                     Z-ADDIRAT2     I2RAT2
     C                     Z-ADDIBIN      I2BIN
      *
     C                     Z-ADDTODAY     I2CRHZ
     C                     Z-ADDNOW       I2CRTM
     C                     MOVEL#USER     I2CRUS
     C                     MOVEL#WSID     I2CRWS
     C                     MOVEL#PGM      I2CRPG
      *
     C                     ENDSR
