     C           #ITEM     BEGSR
     C*
     C*
     C           'OFFLIN'  CHAINGDGPL301             90
S1   C           *IN90     IFEQ *ON
     C                     MOVE *BLANK    IFSKJY
     C                     Z-ADD0         IFSKYY
     C                     Z-ADD0         IFSKMM
     C                     Z-ADD0         IFSKDD
     C                     Z-ADD*DATE     IFKOHZ
     C                     TIME           IFKOTM
     C                     MOVEL@@USID    IFKOME
     C                     MOVEL'OFFLIN'  IFKEY
     C                     Z-ADD1         IFNO
     C                     Z-ADD1         D1ODR4
     C                     Z-ADD0         IFMONT
     C                     Z-ADD*YEAR     IFYEAR
     C                     WRITEGDGPL301
X1   C                     ELSE
     C                     Z-ADD*DATE     IFKOHZ
     C                     TIME           IFKOTM
     C                     MOVEL@@USID    IFKOME
     C           IFNO      ADD  1         D1ODR4
     C           D1ODR3    IFEQ 0
