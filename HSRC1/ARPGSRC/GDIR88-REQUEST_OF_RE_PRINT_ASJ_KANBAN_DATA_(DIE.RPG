     C                     MOVEL'ITEMOF'  IFKEY
     C                     Z-ADD0         IFNO
     C                     Z-ADD0         IFMONT
     C                     Z-ADD*YEAR     IFYEAR
     C                     WRITEGDGPL301
E1   C                     ENDIF
     C*
     C                     Z-ADDIFNO      W1NO    50
S1   C           IFYEAR    IFNE *YEAR
     C                     Z-ADD0         W1NO
