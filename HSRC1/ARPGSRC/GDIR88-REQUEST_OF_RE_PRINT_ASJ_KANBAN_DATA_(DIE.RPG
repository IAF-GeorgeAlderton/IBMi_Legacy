     C                     ENDIF
     C                     Z-ADDD1ODR4    IFNO
     C                     Z-ADD*YEAR     IFYEAR
     C                     UPDATGDGPL301
E1   C                     ENDIF
     C*
     C*
     C           'ITEMOF'  CHAINGDGPL301             92
S1   C           *IN92     IFEQ *ON
     C                     MOVE *BLANK    IFSKJY
     C                     Z-ADD0         IFSKYY
     C                     Z-ADD0         IFSKMM
     C                     Z-ADD0         IFSKDD
     C                     Z-ADD*DATE     IFKOHZ
     C                     TIME           IFKOTM
