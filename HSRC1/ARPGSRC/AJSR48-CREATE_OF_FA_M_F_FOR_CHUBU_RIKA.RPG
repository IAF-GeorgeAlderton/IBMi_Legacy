     H            Y.                                                      DAD000
     F** AJSR48 **********************************
     F* CREATE OF FA M/F FOR CHUBU RIKA
     F*         INSTRUCTION KANBAN M/F         *
     F* C:N.HAYAKAWA           1993.07.16        *
     F********************************************
     FCADTL04 IF  E           K        DISK
     FAJSPL01 IF  E           K        DISK
     FAJSWP48 O   F     488            DISK                      A
     C********************************
     C*指示かんばんマスターの読込み*
     C********************************
     C           *LOVAL    SETLLCADTL041
     C                     SETOF                     10
     C           SJLOOP    TAG
     C                     READ CADTL041                 10
     C           *IN10     IFEQ '1'
     C                     GOTO SIJEND
     C                     ELSE
     C           C2SKJY    IFEQ 'D'
     C           C2SKHZ    IFLE *DATE
     C                     GOTO SJLOOP
     C                     END
     C                     END
     C                     END
     C*有効日・失効日のチェック*
     C           C2UKHZ    IFLE *DATE
     C           C2STHZ    ANDGT*DATE
     C                     ELSE
     C                     GOTO SJLOOP
     C                     END
     C**********************************
     C*    ＦＡマスターにチェイン    *
     C**********************************
     C                     SETOF                     99
     C           KEY1      KLIST
     C                     KFLD           C2SHN1
     C                     KFLD           C2SHN2
     C                     KFLD           C2SHN3
     C           KEY1      SETLLAJSPL011
     C                     SETOF                     20
     C           LOOP1     TAG
     C           KEY1      READEAJSPL011                 20
     C           *IN20     IFEQ '0'
     C*引ける*
     C           J1SKJY    IFEQ 'D'
     C           J1SKHZ    IFLE *DATE
     C                     GOTO LOOP1
     C                     END
     C                     END
     C*引けない*
     C                     ELSE
     C                     SETON                     99
     C                     END
     C**********************************
     C*         更新区分入力         *
     C**********************************
     C           *IN99     IFEQ '1'
     C                     MOVE '0'       UPKBN   1
     C                     MOVE ' '       SYKBN   1
     C                     Z-ADD0         JISEN   31
     C                     ELSE
     C                     MOVE '1'       UPKBN
     C                     MOVE J1MKSK    SYKBN
     C                     Z-ADDJ1MKJI    JISEN
     C                     END
     C*
     C                     EXCPTDTA
     C                     GOTO SJLOOP
     C**************************
     C*         終了         *
     C**************************
     C           SIJEND    TAG
     C                     SETON                     LR
     C                     RETRN
     OAJSWP48 EADD             DTA
