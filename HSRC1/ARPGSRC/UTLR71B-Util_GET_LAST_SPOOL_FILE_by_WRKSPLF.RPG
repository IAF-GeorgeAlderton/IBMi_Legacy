     H            Y.
     F** UTLR71B *****************************************************
     F*  GET LAST SPOOL FILE BY WRKSPLF                              *
     F*  JW       2023.11.01                                         *
     F****************************************************************
     FTXT132  IF  E                    DISK
      *---------------------------------------------------------------
     I            DS
     I                                        1 132 WTXT
     I                                        2   2 W2
     I                                        2  11 WFILE
     I                                       13  22 WUSER
     I                                       24  33 WDEV
     I                                       35  44 WUDAT
     I                                       46  48 WSTS
     I                                      101 106 WFL#
     I                                      108 117 WJOB
     I                                      119 124 WNBR
     I                                      125 132 WQUE
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ******************************************************
      *                    MAIN PROCESS
      ******************************************************
      * INITIAL SET
     C                     EXSR #INIT
      * LOOP
     C                     DO   *HIVAL
     C                     READ TXT132                   91
     C   91                LEAVE
      * SAVE
     C                     MOVELFLD132    WTXT
     C           W2        IFNE *BLANK
     C           WSTS      ANDEQ'RDY'
     C           WFILE     ANDEQ'QPRINT '
     C                     MOVELWJOB      $JOB
     C                     MOVELWUSER     $USER
     C                     MOVELWNBR      $NBR
     C                     MOVELWFILE     $FILE
     C                     MOVELWFL#      $FL#
     C                     ENDIF
      *
     C                     ENDDO
      * EDIT FILE#
     C                     MOVEL$FL#      $FLD1     P
     C                     CALL 'UUUR05'
     C                     PARM           $FLD1  25
     C                     PARM           $FLD2  25
     C                     MOVEL$FLD2     $FL#
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ******************************************************
      *                  INITIAL ROUTINE
      ******************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $JOB   10
     C                     PARM           $USER  10
     C                     PARM           $NBR    6
     C                     PARM           $FILE  10
     C                     PARM           $FL#    6
      *
     C                     MOVE *BLANK    $JOB
     C                     MOVE *BLANK    $USER
     C                     MOVE *BLANK    $NBR
      *
     C                     ENDSR
