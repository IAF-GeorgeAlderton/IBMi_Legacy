     H            Y.                                    1
      ***ALQR9V*****************************************************************
      *  QD PULL SCAN FROM OUTSOURCE                                           *
      *
      * LEC   11/08/2023  CREATE
      **************************************************************************
     FALQPW9V CF  E                    WORKSTN
     FAFDPP9V IF  E           K        DISK
     FFCEPL07 IF  E           K        DISK
     FALQPP9V UF  E           K        DISK                      A
      *
      **************************************************************************
     E                    ERR     1  10 20
      **************************************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60WSSTM6
     I                                        1   40WSSTM4
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  140WSSDAT
     I                                        9  140WSSYMD
     I                                        7  120WSSYM
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
      *
     I            DS
     I                                        1  20 F2BAR
     I                                        1   4 X@ZETI
     I                                        5   5 X@LOC1
     I                                        6   6 X@LC2A
     I                                        6   7 X@LOC2
     I                                        8   9 X@LOC3
     I                                       10  10 X@LOC4
     I                                       11  20 X@BCHK
      *
     I            DS
     I                                        1 128 AFLOT
     I                                        1   8 AFLT01
     I                                        9  16 AFLT02
     I                                       17  24 AFLT03
     I                                       25  32 AFLT04
     I                                       33  40 AFLT05
     I                                       41  48 AFLT06
     I                                       49  56 AFLT07
     I                                       57  64 AFLT08
     I                                       65  72 AFLT09
     I                                       73  80 AFLT10
     I                                       81  88 AFLT11
     I                                       89  96 AFLT12
     I                                       97 104 AFLT13
     I                                      105 112 AFLT14
     I                                      113 120 AFLT15
     I                                      121 128 AFLT16
      *
     I            DS
     I                                        1 128 AQLOT
     I                                        1   8 AQLT01
     I                                        9  16 AQLT02
     I                                       17  24 AQLT03
     I                                       25  32 AQLT04
     I                                       33  40 AQLT05
     I                                       41  48 AQLT06
     I                                       49  56 AQLT07
     I                                       57  64 AQLT08
     I                                       65  72 AQLT09
     I                                       73  80 AQLT10
     I                                       81  88 AQLT11
     I                                       89  96 AQLT12
     I                                       97 104 AQLT13
     I                                      105 112 AQLT14
     I                                      113 120 AQLT15
     I                                      121 128 AQLT16
      *
     I            DS
     I                                        1  15 W3BAR
     I                                        1   1 W3TYPE
     I                                        2   5 W3ZETI
     I                                        6   8 W3TEHI
     I                                        9  10 W3PAGE
     I                                       11  11 W32KAK
     I                                       12  12 W3TASY
     I                                       13  13 W3YUKO
     I                                       14  14 W3HASY
     I                                       15  15 W3CHKD
      *
     IQR          DS
     I                                        1   3 BCTYPE
     I                                        1 256 QR1
     I                                      257 512 QR2
      *
     I            DS
     I                                        1   8 W4LOT
     I                                        1   7 W4LOT1
     I                                        8   8 W4CHKD
      *
     I            DS
     I                                        1   60W@YYMM
     I                                        1   40W@YYYY
     I                                        5   60W@MMMM
      *
     I            DS
     I                                        1  12 A2BHB
     I                                        1   5 A2BHB1
     I                                        6  10 A2BHB2
     I                                       11  12 A2BHB3
      *
     I            DS
     I                                        1  20 LOCN
     I                                        1   4 LZETI
     I                                        5  10 LLOCN
     I                                        6   9 LLOCN4
     I                                        6   7 LLOC67
     I                                        8   9 LLOC89
     C           *ENTRY    PLIST
     C                     PARM           PWKCD   6
      *
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'20'      #FMT20
     C           @@ID      CASEQ'30'      #FMT30
      *****      @@ID      CASEQ'40'      #FMT40
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      **************************************************************************
      *         INITIALIZE
      **************************************************************************
     C           *INZSR    BEGSR
      *
      * for kanban check digit...
     C           P#BRC     PLIST
     C                     PARM           PMAREA100
     C                     PARM           PMBYTE  3
     C                     PARM           PMCHK   1
     C                     PARM           PMRTCD  1
      *
     C                     TIME           WSDT
      *
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
      *
     C                     MOVEL'20'      @@ID    2
      *
     C                     ENDSR
      *************************************************************************
      *    LOCATION SCREEN
      **************************************************************************
     C           #FMT20    BEGSR
      *
     C                     EXFMTFMT200
     C                     MOVEL*BLANK    F2ERR
     C                     MOVEL*BLANK    F99ER1
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      @@ID
     C                     OTHER
     C                     EXSR #CHK20
     C           *IN99     IFEQ *OFF
     C                     MOVEL'30'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
      *    LOCATION SCREEN CHECK
      **************************************************************************
     C           #CHK20    BEGSR
      *
     C                     SETOF                     6199
      *
     C                     DO
      *
     C           F2BAR     IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,5     F2ERR
     C                     MOVELERR,5     F99ER1
     C                     LEAVE
     C                     ENDIF
      *
      * verify location scan was for a Z-rack, or
      *        outsource overflow...
     C           X@LC2A    IFNE 'Z'
     C           F2BAR     ANDNE'OSOV'
     C                     MOVE *BLANKS   F2BAR
     C                     SETON                     9961
     C                     MOVELERR,5     F2ERR
     C                     MOVELERR,5     F99ER1
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVELF2BAR     LOCN
      *
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     ENDIF
      *
     C                     ENDSR
      *************************************************************************
      *     PLASTIC KANBAN SCREEN
      **************************************************************************
     C           #FMT30    BEGSR
      *
     C                     EXFMTFMT300
     C                     MOVEL*BLANK    F3ERR
     C                     MOVEL*BLANK    F99ER1
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'20'      @@ID
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     OTHER
     C                     EXSR #CHK30
      ********   *IN99     IFEQ *OFF
      ********             MOVEL'40'      @@ID
      ********             ENDIF
     C           *IN99     IFEQ *OFF
     C                     EXSR DLTDUP
     C                     EXSR #WRTOK
     C                     EXFMTFMT900
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     MOVEL'20'      @@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
      *     PLASTIC KANBAN SCREEN CHECK
      **************************************************************************
     C           #CHK30    BEGSR
      *
     C                     SETOF                     6199
      *
     C                     MOVELF3BAR     QR
     C           BCTYPE    IFEQ 'B01'
      *
      * create code39 from QR....
     C                     MOVEL*BLANK    P9BAR  20
     C                     CALL 'UEXR13'
     C                     PARM           QR1
     C                     PARM           QR2
     C                     PARM           P9BAR
     C                     MOVELP9BAR     W3BAR
     C                     ELSE
     C                     MOVELF3BAR     W3BAR
     C                     ENDIF
      *
     C                     DO
      *
     C           W3BAR     IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     F3ERR
     C                     MOVELERR,1     F99ER1
     C                     LEAVE
     C                     ENDIF
      * check digit...
     C                     MOVELW3BAR     PMAREA    P
     C                     MOVE '014'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,3     F3ERR
     C                     MOVELERR,3     F99ER1
     C                     LEAVE
     C                     ENDIF
      *
     C           PMCHK     IFNE W3CHKD
     C                     SETON                     9961
     C                     MOVELERR,3     F3ERR
     C                     MOVELERR,3     F99ER1
     C                     LEAVE
     C                     ENDIF
      *
      * check part id matches...
     C           W3ZETI    IFNE LZETI
     C           F2BAR     ANDNE'OSOV'
     C                     SETON                     9961
     C                     MOVELERR,7     F3ERR
     C                     MOVELERR,7     F99ER1
     C                     LEAVE
     C                     ENDIF
      *
      * check to see if plastic kanban has already been scanned.
     C           W3BAR     IFNE *BLANK
     C                     EXSR CHKDUP
     C           *IN99     IFEQ *ON
     C                     MOVELERR,2     F3ERR
     C                     MOVELERR,2     F99ER1
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
      * verify plastic kanban has been scanned to outsource...
     C                     MOVELW3BAR     KYBAR
     C           KYBAR     CHAINAFDPP9V              91
      *
     C           *IN91     DOWEQ*OFF
      *
     C           AFSKJY    IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
      *
     C           KYBAR     READEAFDPP9V                  91
     C                     ENDDO
      *
     C           *IN91     IFEQ *ON
     C                     SETON                     9961
     C                     MOVELERR,9     F3ERR
     C                     MOVELERR,9     F99ER1
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     ENDIF
      *
     C                     ENDSR
      *************************************************************************
      *     LOT ID SCREEN
      **************************************************************************
     C           #FMT40    BEGSR
      *
     C                     EXFMTFMT400
     C                     MOVEL*BLANK    F4ERR
     C                     MOVEL*BLANK    F99ER1
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'30'      @@ID
     C                     CLEARFMT400
      *
     C                     OTHER
     C                     EXSR #CHK40
      *
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR DLTDUP
     C                     EXSR #WRTOK
     C                     EXFMTFMT900
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     MOVEL'99'      @@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
      *     LOT ID SCREEN CHECK
      **************************************************************************
     C           #CHK40    BEGSR
      *
     C                     MOVELF4LOT     W4LOT
     C                     SETOF                     9961
      *
     C                     DO
      *
     C           F4LOT     IFEQ *BLANK
     C           F4LT01    ANDEQ*BLANK
     C           F4LT02    ANDEQ*BLANK
     C           F4LT03    ANDEQ*BLANK
     C           F4LT04    ANDEQ*BLANK
     C           F4LT05    ANDEQ*BLANK
     C           F4LT06    ANDEQ*BLANK
     C           F4LT07    ANDEQ*BLANK
     C           F4LT08    ANDEQ*BLANK
     C                     SETON                     9961
     C                     MOVELERR,4     F4ERR
     C                     MOVELERR,4     F99ER1
     C                     LEAVE
     C                     ENDIF
      *
     C           F4LOT     IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
      * check digit...
     C                     MOVELW4LOT1    PMAREA    P
     C                     MOVE '007'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,4     F4ERR
     C                     MOVELERR,4     F99ER1
     C                     ENDIF
      *
     C           PMCHK     IFNE W4CHKD
     C                     SETON                     9961
     C                     MOVELERR,3     F4ERR
     C                     MOVELERR,3     F99ER1
     C                     LEAVE
     C                     ENDIF
      *
     C   99                LEAVE
      *
     C           F4LOT     IFEQ F4LT01
     C           F4LOT     OREQ F4LT02
     C           F4LOT     OREQ F4LT03
     C           F4LOT     OREQ F4LT04
     C           F4LOT     OREQ F4LT05
     C           F4LOT     OREQ F4LT06
     C           F4LOT     OREQ F4LT07
     C                     SETON                     9961
     C           F4ERR     IFEQ *BLANK
     C                     MOVELERR,8     F4ERR
     C                     MOVELERR,8     F99ER1
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C                     SELEC
     C           F4LT01    WHEQ *BLANK
     C                     MOVELF4LOT     F4LT01
     C                     MOVEL*BLANK    F4LOT
     C           F4LT02    WHEQ *BLANK
     C                     MOVELF4LOT     F4LT02
     C                     MOVEL*BLANK    F4LOT
     C           F4LT03    WHEQ *BLANK
     C                     MOVELF4LOT     F4LT03
     C                     MOVEL*BLANK    F4LOT
     C           F4LT04    WHEQ *BLANK
     C                     MOVELF4LOT     F4LT04
     C                     MOVEL*BLANK    F4LOT
     C           F4LT05    WHEQ *BLANK
     C                     MOVELF4LOT     F4LT05
     C                     MOVEL*BLANK    F4LOT
     C           F4LT06    WHEQ *BLANK
     C                     MOVELF4LOT     F4LT06
     C                     MOVEL*BLANK    F4LOT
     C           F4LT07    WHEQ *BLANK
     C                     MOVELF4LOT     F4LT07
     C                     MOVEL*BLANK    F4LOT
     C           F4LT08    WHEQ *BLANK
     C                     MOVELF4LOT     F4LT08
     C                     MOVEL*BLANK    F4LOT
     C                     ENDSL
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     ENDIF
      *
     C                     ENDSR
      **************************************************************************
      *       WRITE A OK RECORD
      **************************************************************************
     C           #WRTOK    BEGSR
      *
     C                     CLEARALQPP9V1
      *
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    AQCODT
     C                     Z-ADDWSSTM6    AQCOTM
     C                     MOVELPWKCD     AQCOWK
     C                     MOVEL#PGM      AQCOPG
      *
     C                     MOVELAFBIN#    AQBIN#
     C                     MOVELF2BAR     AQLBAR
     C                     MOVELLZETI     AQLZET
     C                     MOVELLLOCN4    AQLOCN
     C                     MOVELW3BAR     AQPBAR
     C                     MOVELF3BAR     AQPBQR
     C                     MOVELW3ZETI    AQPZET
      *
     C           W3ZETI    CHAINFCEPL07              51
     C           *IN51     IFEQ *OFF
     C                     MOVELA2BHB1    AQPHN1
     C                     MOVELA2BHB2    AQPHN2
     C                     MOVELA2BHB3    AQPHN3
     C                     ENDIF
      *
     C                     MOVELAFLOT     AQLOT
      *
     C                     WRITEALQPP9V1
      *
     C                     ENDSR
     C* ****************************************************
      * if plastic bcode is already in another LOCN, delete*
      * ****************************************************
     C           DLTDUP    BEGSR
      *
     C                     MOVELW3BAR     KYBAR  20 P
     C                     MOVEL#PGM      PPGM   10 P
     C                     CALL 'AFDR9U'
     C                     PARM           PWKCD
     C                     PARM           PPGM
     C                     PARM           KYBAR
      *
     C                     ENDSR
      * ****************************************************
      * verify plastic kanban bc hasn't been scanned yet   *
      * ****************************************************
     C           CHKDUP    BEGSR
      *
     C                     MOVELW3BAR     KYBAR
     C           KYBAR     CHAINALQPP9V              91
      *
     C           *IN91     DOWEQ*OFF
      *
     C           AQSKJY    IFEQ *BLANK
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C           KYBAR     READEALQPP9V                  91
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
** ERR
KANBAN ERROR                     #01
ALREADY SCANNED                  #02
CHECK DIGIT ERROR                #03
LOT ID ERROR                     #04
INVALID LOCATION                 #05
BIN NUM NOT ACTIVE               #06
PART # MISMATCH                  #07
DUPLICATE LOT ID                 #08
NOT FOUND IN O/S                 #09
                                 #10
