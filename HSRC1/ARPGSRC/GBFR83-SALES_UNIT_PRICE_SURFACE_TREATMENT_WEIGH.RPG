     C******************************************************
     C* M-NO BF.6.2        PARM ﾉ cinﾒ                     *
     C******************************************************
     C           *ENTRY    PLIST
     C                     PARM           PTOKU   4
     C                     PARM           PLKBN   1
     C                     PARM           PTKOJ   1
     C           *IN01     IFEQ '0'
     C                     SETON                     01
     C                     Z-ADD*DATE     YYMD
     C                     Z-ADDSYY       DYY
     C                     Z-ADDSMD       DMD
     C                     MOVE PTOKU     UTOKU   40
     C                     MOVE MD,1      HD
     C                     MOVE *BLANK    TMEIG
     C                     MOVE '-'       F1
     C                     MOVE '-'       F2
     C                     SETOF                     02
     C           UTOKU     CHAINFGBPL011             02
     C           *IN02     IFEQ '0'
     C                     MOVELB2SMEI    TMEIG
     C                     END
     C                     END
     C******************************************************
     C* M-NO BF.6.3.1      mﾞ-j ﾉ ﾑvﾃv                     *
     C******************************************************
     C           GDTOKU    IFNE UTOKU
     C                     SETON                     LR
     C                     GOTO END
     C                     END
     C           *INL4     IFEQ '1'
     C                     MOVE GDKKEY    KKEY    1
     C                     MOVE GDSME1    MEK1
     C                     MOVE GDSME2    MEK2
     C                     MOVE GDSME3    MEK3
     C                     Z-ADDGDSZKB    SAIZ    20
     C                     MOVE GDTKOJ    TKOJ    1
     C                     WRITEGBFPR831
     C                     Z-ADD0         L       20
     C                     ELSE
     C           *INL3     IFEQ '1'
     C                     MOVE GDSME1    MEK1
     C                     MOVE GDSME2    MEK2
     C                     MOVE GDSME3    MEK3
     C                     Z-ADDGDSZKB    SAIZ    20
     C                     MOVE GDTKOJ    TKOJ    1
     C                     ELSE
     C           *INL2     IFEQ '1'
     C                     Z-ADDGDSZKB    SAIZ    20
     C                     MOVE GDTKOJ    TKOJ    1
     C                     ELSE
     C           *INL1     IFEQ '1'
     C                     MOVE GDTKOJ    TKOJ    1
     C                     END
     C                     END
     C                     END
     C                     END
     C******************************************************
     C* M-NO BF.6.3.2      mﾞ-j xbﾅb m]c                  *
     C******************************************************
     C           GDDKBN    IFEQ 'N'
     C           GDSRYO    MULT GDKANJ    PJRYO  130
     C           JRYOG     ADD  PJRYO     JRYOG  130
     C           SRYO      ADD  GDSRYO    SRYO   110
     C           NTAN      IFEQ 0
     C                     Z-ADDGDGGEN    NTAN    75
     C                     END
     C                     END
     C           GDDKBN    IFEQ 'O'
     C           QTAN      IFEQ 0
     C                     Z-ADDGDGGEN    QTAN    75
     C                     END
     C                     END
     C           END       TAG
     CL1         JRYOG     DIV  1000      JRYO    90H
     CL1         JRYO      MULT NTAN      NKIN   112H
     CL1         JRYO      MULT QTAN      QKIN   112H
     CL1         QKIN      SUB  NKIN      SKIN   102
     CL1         SJRYO     ADD  JRYO      SJRYO   90
     CL1         SSRYO     ADD  SRYO      SSRYO  110
     CL1         SQKIN     ADD  QKIN      SQKIN  112
     CL1         SNKIN     ADD  NKIN      SNKIN  112
     CL1         SSKIN     ADD  SKIN      SSKIN  102
     CL1                   WRITEGBFPR832
     CL1         L         ADD  1         L
     CL1         P         ADD  1         P       30
     CL1                   Z-ADD0         JRYOG
     CL1                   Z-ADD0         JRYO
     CL1                   Z-ADD0         SRYO
     CL1                   Z-ADD0         QTAN
     CL1                   Z-ADD0         QKIN
     CL1                   Z-ADD0         NTAN
     CL1                   Z-ADD0         NKIN
     CL1                   Z-ADD0         SKIN
     CL1         *INL2     IFEQ '0'
     CL1         L         IFGE 53
     CL1                   WRITEGBFPR831
     CL1                   Z-ADD0         L
     CL1                   END
     CL1                   END
     CL2         ZJRYO     ADD  SJRYO     ZJRYO   90
     CL2         ZSRYO     ADD  SSRYO     ZSRYO  110
     CL2         ZQKIN     ADD  SQKIN     ZQKIN  112
     CL2         ZNKIN     ADD  SNKIN     ZNKIN  112
     CL2         ZSKIN     ADD  SSKIN     ZSKIN  102
     CL2         PLKBN     IFEQ '3'
     CL2         P         IFGT 1
     CL2                   WRITEGBFPR833
     CL2         L         ADD  1         L
     CL2                   END
     CL2                   END
     CL2                   Z-ADD0         P
     CL2                   Z-ADD0         SJRYO
     CL2                   Z-ADD0         SSRYO
     CL2                   Z-ADD0         SQKIN
     CL2                   Z-ADD0         SNKIN
     CL2                   Z-ADD0         SSKIN
