     C* #SCRN3 :
     C***********************************************************
     C           #SCRN3    BEGSR
     C*
     C                     DO
     C*
     C                     EXSR @SET3
     C           RRN3      IFEQ *ZERO
     C                     MOVEL*ON       *IN99
     C                     MOVELER,8      MSG
     C                     LEAVE
     C                     END
     C                     MOVEL*BLANK    MSG
