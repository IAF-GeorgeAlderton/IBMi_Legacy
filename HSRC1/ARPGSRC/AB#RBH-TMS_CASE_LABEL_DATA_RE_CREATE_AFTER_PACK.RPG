     C           @@DSP     DOWNE'99'
     C           @@DSP     CASEQ'01'      #SCRN1
     C           @@DSP     CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-------------------------------------------------------
      * INITIALIZE
      *-------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           P2        PLIST
     C                     PARM           PIQTY  300       NUMERIC QTY
     C                     PARM           POQTY  30        CHAR    QTY
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
     C***********************************************************************
     C* KEY1                                                                *
     C***********************************************************************
     C           K#66X     KLIST
     C                     KFLD           K@CUST
     C                     KFLD           K@NONY
     C                     KFLD           K@NKOJ
     C                     KFLD           K@NUKE
     C                     KFLD           K@NOHZ
     C                     KFLD           K@NBIN
     C                     KFLD           K@MLBL  8
     C*
     C                     MOVE '01'      @@DSP   2
     C                     MOVE *ALL'0'   WKBLAK 10
     C*
     C                     MOVE *BLANK    F2NONY
     C                     MOVE *BLANK    F2NKOJ
     C                     MOVE *BLANK    F2NUKE
     C                     Z-ADD*ZERO     F2NOHZ
     C                     MOVEL*BLANK    F2ODRN
     C                     Z-ADD*ZERO     F2NOBN
      *
     C                     ENDSR
     C***********************************************************
     C* BARCODE ENTRY
     C***********************************************************
     C           #SCRN1    BEGSR
      *
     C                     EXFMTFMT010
      *
     C                     SELEC
     C           *INKI     WHEQ *ON
     C                     MOVE '02'      @@DSP
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@DSP
     C                     OTHER
     C                     EXSR @CHK1
     C* CHECK OK?
     C           *IN99     IFEQ '0'
     C                     EXSR #SCRN3
     C           *INKC     IFEQ *ON
     C                     MOVE '99'      @@DSP
     C                     END
     C           *IN99     IFEQ *ON
     C                     MOVEL*ON       *IN31
     C                     ELSE
     C                     MOVE *BLANK    D@BARC
     C                     END
     C                     END
     C                     ENDSL
      *
     C                     ENDSR
     C***********************************************************
     C* BARCODE ENTRY
     C***********************************************************
     C           @CHK1     BEGSR
      *
     C                     MOVEAWKBLAK    *IN,30
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     8799
     C           D@BARC    CHAINAB#PL76              90
     C           *IN90     IFEQ *ON
     C                     SETON                     9931
     C                     MOVE ER,13     MSG
     C                     ELSE
     C                     Z-ADDPUCUST    K@CUST  40
     C                     MOVELPUNONY    K@NONY  40
     C                     MOVELPUNKOJ    K@NKOJ  1
     C                     MOVELPUNUKE    K@NUKE  4
     C                     Z-ADDPUBINN    K@NBIN  20
     C                     Z-ADDPUNDAT    K@NOHZ  80
     C                     MOVELPUODRN    K@ODRN 10
     C                     ENDIF
      *
     C                     ENDSR
     C***********************************************************
     C* @MANUALLY
     C***********************************************************
     C           #SCRN2    BEGSR
     C*
     C                     EXFMTFMT020
     C* CLEAR MSG
     C                     MOVEAWKBLAK    *IN,30
     C                     SETOF                     8799
     C*
     C                     SELEC
     C           *INKC     WHEQ '1'
     C                     MOVE '99'      @@DSP
     C*
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      @@DSP
     C                     OTHER
     C                     EXSR @CHK2
     C* CHECK OK?
     C           *IN99     IFEQ '0'
     C                     EXSR #SCRN3
     C           *INKC     IFEQ *ON
     C                     MOVE '99'      @@DSP
     C                     END
     C           *IN99     IFEQ *ON
     C                     SETON                     313233
     C                     SETON                     343537
     C                     ELSE
     C                     MOVE *BLANK    F2NONY
     C                     MOVE *BLANK    F2NKOJ
     C                     MOVE *BLANK    F2NUKE
     C                     MOVE *BLANK    F2ODRN
     C                     Z-ADD*ZERO     F2NOHZ
     C                     Z-ADD*ZERO     F2NOBN
     C                     END
     C                     END
      *
     C                     ENDSL
     C*
     C                     ENDSR
     C***********************************************************
     C* @CHK2:CHECK ITEMS ON 2ND. SCREEN
     C***********************************************************
     C           @CHK2     BEGSR
     C*
     C                     MOVEAWKBLAK    *IN,30
     C                     MOVE *BLANK    MSG
     C                     SETOF                     8799
     C* DELIVERY CODE BLANK ?
     C           F2NONY    IFEQ *BLANK
     C                     SETON                     9931
     C                     MOVELER,1      MSG
     C                     GOTO #CHK2
     C                     END
     C*
     C* FACTORY CODE BLANK ?
     C           F2NKOJ    IFEQ *BLANK
     C                     SETON                     9932
     C                     MOVELER,2      MSG
     C                     GOTO #CHK2
     C                     END
     C*
     C* DOCK CODE BLANK ?
     C           F2NUKE    IFEQ *BLANK
     C                     SETON                     9933
     C                     MOVELER,3      MSG
     C                     GOTO #CHK2
     C                     END
     C*
     C* SHIPPING DATE
     C           F2NOHZ    IFEQ 0
     C                     SETON                     9934
     C                     MOVELER,4      MSG
     C                     GOTO #CHK2
     C                     END
      *
     C           F2NOMM    IFLT 1
     C           F2NOMM    ORGT 12
     C                     SETON                     9934
     C                     MOVELER,5      MSG
     C                     GOTO #CHK2
     C                     END
      *
     C           F2NODD    IFLT 1
     C           F2NODD    ORGT 31
     C                     SETON                     9934
     C                     MOVELER,5      MSG
     C                     GOTO #CHK2
     C                     END
     C* BIN       *
     C           F2NOBN    IFEQ 0
     C                     SETON                     9935
     C                     MOVELER,6      MSG
     C                     GOTO #CHK2
     C                     END
     C* ORDER#    *
     C           F2ODRN    IFEQ *BLANK
     C                     SETON                     9937
     C                     MOVELER,15     MSG
     C                     GOTO #CHK2
     C                     END
     C*
     C           K#1A      KLIST
     C                     KFLD           K@NOHZ
     C                     KFLD           K@NBIN
     C                     KFLD           K@NONY
     C                     KFLD           K@NKOJ
     C                     KFLD           K@NUKE
     C                     KFLD           K@ODRN
     C                     Z-ADDF2NOHZ    K@NOHZ  80
     C                     Z-ADDF2NOBN    K@NBIN  20
     C                     MOVELF2NONY    K@NONY  40
     C                     MOVELF2NKOJ    K@NKOJ  1
     C                     MOVELF2NUKE    K@NUKE  4
     C                     MOVELF2ODRN    K@ODRN 10
      *
     C           K#1A      SETLLAB#PL1A
     C           *IN90     DOUEQ*ON
     C           K#1A      READEAB#PL1A                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C                     Z-ADDBATOKU    K@CUST
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     MOVEA'11111'   *IN,31
     C                     MOVEL*ON       *IN37
     C                     SETON                     99
     C                     MOVELER,12     MSG
     C                     ENDIF
     C*
     C           #CHK2     ENDSR
