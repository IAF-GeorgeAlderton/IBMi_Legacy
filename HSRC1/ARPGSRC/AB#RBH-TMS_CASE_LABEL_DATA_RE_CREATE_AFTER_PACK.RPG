     C*
     C                     DO   *HIVAL
     C*
     C           K#67      READEAB#PL67                  90
     C           *IN90     IFEQ *ON
     C                     LEAVE
     C                     END
     C*
     C                     CLEARSFL030
     C*
     C                     MOVELA6MHN1    W@MHN1
     C                     MOVEL'-'       W@MHNA
     C                     MOVELA6MHN2    W@MHN2
     C                     MOVELW@MHIN    S3MHIN
     C                     MOVELA6MLBL    S3MLBL
     C                     MOVELA6MHN1    H3MHN1
     C                     MOVELA6MHN2    H3MHN2
     C                     MOVELA6MHN3    H3MHN3
     C                     MOVELA6MHN4    H3MHN4
     C                     MOVELA6SHN1    H3SHN1
     C                     MOVELA6SHN2    H3SHN2
     C                     MOVELA6SHN3    H3SHN3
     C*
     C                     Z-ADDA6SRYO    S3SRYO
     C*
