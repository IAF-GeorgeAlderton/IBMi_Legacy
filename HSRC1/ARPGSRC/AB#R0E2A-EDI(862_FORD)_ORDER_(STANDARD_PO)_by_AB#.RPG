     H            Y.
     F** AB#R0E2A************************************************
     F*  EDI(862 FORD) ORDER (STANDARD PO) BY AB#EP50 (V02)     *
     F*  JW    2022.01.11                                       *
     F***********************************************************
     FAB#EP50 IF  E           K        DISK
     FAB#PLF1 O   E           K        DISK
      ****************************************************
     E                    IPAR       30  1
     E                    OPAR       20  1
      ****************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I**          DS
     I**                                      1  20 A5MHIN
     I**                                      1   5 A5MHN1
     I**                                      6  10 A5MHN2
     I**                                     11  15 A5MHN3
     **                                      16  20 A5MHN4
     I            DS
     I                                        1  20 F5MHIN
     I                                        1   5 F5MHN1
     I                                        6  10 F5MHN2
     I                                       11  15 F5MHN3
     I                                       16  20 F5MHN4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ****************************************************
     C                     EXSR #INIT
      *
     C           *LOVAL    SETLLAB#EP50
     C                     DO   *HIVAL
     C                     READ AB#EP50                  98
     C   98                LEAVE
      * RESET QTY
AD   C           A5SIDT    IFNE SVSIDT                     ISSUE DATE
     C           A5STID    ORNE SVSTID                     PLANT
     C           A5DOCK    ORNE SVDOCK                     DOCK
     C           A5PART    ORNE SVPART                     PART
     C                     Z-ADD0         @SHP
     C                     ENDIF
     C           A5QTY2    SUB  A5YSQY    @QTY   100
     C                     SUB  @SHP      @QTY
      * ADJ
     C           @QTY      IFLE 0
     C                     Z-ADD0         @QTY
     C                     ENDIF
      *
     C                     EXSR #EDIT
     C                     WRITEAB#PPF11
      * SAVE
ADD  C                     Z-ADDA5SIDT    SVSIDT           ISSUE DATE
     C                     MOVELA5STID    SVSTID           PLANT
     C                     MOVELA5DOCK    SVDOCK           DOCK
     C                     MOVELA5PART    SVPART           PART
     C                     Z-ADDF5NOHZ    SVNOHZ           SHIP DATE
     C                     ADD  F5QTY     @SHP             SHIP QTY
      *
     C                     ENDDO
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
     C***********************************************************
     C* EDIT DATA
     C***********************************************************
     C           #EDIT     BEGSR
      *
     C                     Z-ADDTODAY     F5CRDT
     C                     Z-ADDNOW       F5CRTM
     C                     Z-ADD5149      F5TOKU
      *
     C                     MOVELA5STID    $PLNT
     C                     MOVELA5DOCK    $DOCK
     C                     CALL 'UTLR34A'
     C                     PARM           $PLNT   5
     C                     PARM           $DOCK   4
     C                     PARM           $NONY   4
     C                     PARM           $RTN    1
     C                     MOVEL$NONY     F5NONY
      *
     C                     MOVELA5DOCK    F5NUKE
     C                     Z-ADDA5DLDT    F5NOHZ
     C                     Z-ADD@QTY      F5QTY
     C                     MOVELA5PONO    F5ODRN    P
     C                     MOVEL'11111'   F5INVN    P
     C                     MOVEL'862'     F5EDIT    P
      * PART
     C                     MOVEAA5PART    IPAR
     C                     MOVE *BLANK    OPAR
     C                     Z-ADD0         M       20
     C*
     C           1         DO   30        N       20
     C           IPAR,N    IFNE *BLANK
     C                     ADD  1         M
     C                     MOVE IPAR,N    OPAR,M
     C                     ENDIF
     C                     ENDDO
     C*
     C                     MOVEAOPAR      F5MHIN
     C                     MOVEAOPAR      F5IPAR
     C                     Z-ADDTODAY     F5DATE
     C                     Z-ADDNOW       F5TIME
      *
     C                     MOVELA5TPCD    F5TPCD
     C                     MOVELA5TSID    F5TSID
     C                     MOVELA5SPCD    F5SPCD
     C                     MOVELA5REF#    F5REF#
     C                     MOVELA5POR#    F5POR#
     C                     MOVELA5SIDT    F5SIDT
     C                     MOVELA5HSDT    F5HSDT
     C                     MOVELA5HEDT    F5HEDT
     C                     MOVELA5STIQ    F5STIQ
     C                     MOVELA5STID    F5STID
     C                     MOVELA5IDCD    F5IDCD
     C                     MOVELA5PART    F5PART
     C                     MOVELA5DOCK    F5DOCK
     C                     MOVELA5ALFL    F5ALFL
     C                     MOVELA5RALF    F5RALF
     C                     MOVELA5UBM1    F5UBM1
     C                     MOVELA5PKCD    F5PKCD
     C                     MOVELA5QTY1    F5QTY1
     C                     MOVELA5WEIT    F5WEIT
     C                     MOVELA5UBM2    F5UBM2
     C                     MOVELA5EQMT    F5EQMT
     C                     MOVELA5QTY2    F5QTY2
     C                     MOVELA5DLDT    F5DLDT
     C                     MOVELA5IPAR    F5IPAR
      *
      * PART
     C                     MOVEAA5PART    IPAR
     C                     MOVE *BLANK    OPAR
     C                     Z-ADD0         M       20
     C           1         DO   30        N       20
     C           IPAR,N    IFNE *BLANK
     C                     ADD  1         M
     C                     MOVE IPAR,N    OPAR,M
     C                     ENDIF
     C                     ENDDO
     C                     MOVEAOPAR      F5IPAR
      *
     C                     MOVELA5LRDT    F5LRDT
     C                     MOVELA5LRQY    F5LRQY
     C                     MOVELA5LSDT    F5LSDT
     C                     MOVELA5LSQY    F5LSQY
     C                     MOVELA5YRDT    F5YRDT
     C                     MOVELA5YRQY    F5YRQY
     C                     MOVELA5YSDT    F5YSDT
     C                     MOVELA5YSQY    F5YSQY
     C                     MOVELA5EXCD    F5EXCD
     C                     MOVELA5RDCD    F5RDCD
     C                     MOVELA5PONO    F5PONO
     C                     MOVELA5STFC    F5STFC
     C                     MOVEL#PGM      F5CRPG
      *
     C                     MOVE *BLANK    F5FLG1
     C                     MOVE *BLANK    F5FLG2
     C                     MOVE *BLANK    F5FLG3
     C                     MOVE *BLANK    F5FLD1
     C                     MOVE *BLANK    F5FLD2
     C                     Z-ADD0         F5VAL1
     C                     Z-ADD0         F5VAL2
      *
     C                     ENDSR
      *--------------------------------------------------
      * INITIALIZE
      *--------------------------------------------------
     C           #INIT     BEGSR
      *
     C           K#01      KLIST
     C                     KFLD           K5DATE  80
     C                     KFLD           K5STID  5
     C                     KFLD           K5NUKE  4
     C                     KFLD           K5STFC  5
     C                     KFLD           K5PART 40
      *
     C                     TIME           SDATE
     C                     Z-ADD0         SVSIDT  80       ISSUE DATE
     C                     MOVE *BLANK    SVSTID  5        PLANT
     C                     MOVE *BLANK    SVDOCK  4        DOCK
     C                     MOVE *BLANK    SVPART 40        PART
     C                     Z-ADD0         SVNOHZ  80       SHIP DATE
     C                     Z-ADD0         @SHP   100       SHIP QTY
      *
     C                     ENDSR
