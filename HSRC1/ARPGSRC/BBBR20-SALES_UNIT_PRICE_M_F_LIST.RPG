     F******************************************BBBR20**
     FBBBPW20 CF  E                    WORKSTN
     FBBCPL02 IF  E           K        DISK
     FBBDPL02 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FBBBWP20 O   F     100            DISK
     E                    ER      1   4 60
     I            DS
     I                                        1  28 BCKEY
     I                                        1   40BCTKCD
     I                                        5   80BCNONY
     I                                        9   9 BCKOJO
     I                                       10  13 BCNUKE
     I                                       14  18 BCHIN1
     I                                       19  23 BCHIN2
     I                                       24  28 BCHIN3
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
      *-------------------------------------------------*
      *   PROGRAM START    (BBCR20)                     *
      *-------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           NO      1
     C                     PARM           TOKU    4
      *
     C           KEY       KLIST
     C                     KFLD           BCTKCD
     C                     KFLD           BCNONY
     C                     KFLD           BCKOJO
     C                     KFLD           BCNUKE
     C                     KFLD           BCHIN1
     C                     KFLD           BCHIN2
     C                     KFLD           BCHIN3
      *
      *  fﾞx] 1  ﾉ  ﾎｧｰﾓnﾞ  hﾒaｰ
      *
     C                     Z-ADD0         @@NO
     C                     MOVE *BLANK    @@TOKU
      *
      *  fﾞx] 1   ﾆｬlﾒｭh  ( ﾍｭcﾆg . xｮﾈｰﾆﾞ  hﾒaｰ)
      *
     C           STEP1     TAG
     C                     EXFMTBBBPW201
     C                     SETOF                     010299
     C                     MOVE *BLANK    MSG
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
      *
      *  fﾞx] 1  ﾉ  ﾎｧｰﾓnﾞ  kｩｮh
      *
     C           @@NO      IFEQ 1
     C           @@NO      OREQ 2
     C           @@NO      OREQ 3
     C           @@NO      OREQ 4
     C                     ELSE
     C                     SETON                     0199
     C                     MOVELER,1      MSG
     C                     GOTO STEP1
     C                     END
      *
     C           @@NO      IFEQ 1
     C           @@NO      OREQ 2
     C           @@TOKU    IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVELER,2      MSG
     C                     GOTO STEP1
     C                     END
     C                     END
      *
     C           @@NO      IFEQ 3
     C           @@NO      OREQ 4
     C           @@TOKU    IFNE *BLANK
     C                     SETON                     0299
     C                     MOVELER,4      MSG
     C                     GOTO STEP1
     C                     END
     C                     END
      *
     C                     MOVE @@TOKU    WWTOKU  40
      *
     C           @@NO      IFEQ 1
     C           @@NO      OREQ 2
     C                     SETOF                     30
     C           WWTOKU    CHAINFGBPL01              30
     C           *IN,10    IFEQ '0'
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C                     END
     C           *IN,30    IFEQ '1'
     C                     SETON                     0299
     C                     MOVELER,3      MSG
     C                     GOTO STEP1
     C                     END
     C                     END
      *
     C  NKE                GOTO STEP1
      *
      *  ﾒﾇn NO   =   1 OR 2       ﾉ      ﾆｭﾒ
      *
     C           @@NO      IFEQ 1
     C           @@NO      OREQ 2
      *
     C                     MOVEL*BLANK    WWKEY  28
     C                     SETOF                     10
     C           WWTOKU    SETGTBBCPL021
     C                     DO   *HIVAL
     C           WWTOKU    REDPEBBCPL021                 10
     C           *IN10     IFEQ '0'
     C           BCSKJY    IFEQ 'D'
     C           BCSKHZ    ANDLE*DATE
     C                     GOTO @@END
     C                     END
     C                     END
      *
     C           *IN10     IFEQ '0'
     C           BCKEY     IFNE WWKEY
      *
     C                     SETOF                     20
     C           KEY       SETGTBBDPL02
     C           STEP2     TAG
     C           KEY       REDPEBBDPL02                  20
     C           *IN,20    IFEQ '0'
     C           BDSKJY    IFEQ 'D'
     C           BDSKHZ    ANDLE*DATE
     C                     GOTO STEP2
     C                     END
     C                     END
     C           *IN,20    IFEQ '0'
     C                     Z-ADDBDKTNK    WWRTNK  92
     C                     Z-ADDBDKSYY    WWRSYY  40
     C                     Z-ADDBDKSMM    WWRSMM  20
     C                     Z-ADDBDKSDD    WWRSDD  20
     C                     Z-ADDBDKEYY    WWREYY  40
     C                     Z-ADDBDKEMM    WWREMM  20
     C                     Z-ADDBDKEDD    WWREDD  20
     C                     ELSE
     C                     Z-ADD0         WWRTNK
     C                     Z-ADD0         WWRSYY
     C                     Z-ADD0         WWRSMM
     C                     Z-ADD0         WWRSDD
     C                     Z-ADD0         WWREYY
     C                     Z-ADD0         WWREMM
     C                     Z-ADD0         WWREDD
     C                     END
      *
     C                     Z-ADDBCTKCD    WWTKCD  40
     C                     Z-ADDBCNONY    WWNONY  40
     C                     MOVELBCKOJO    WWKOJO  1
     C                     MOVELBCNUKE    WWNUKE  4
     C                     MOVELBCHIN1    WWHIN1  5
     C                     MOVELBCHIN2    WWHIN2  5
     C                     MOVELBCHIN3    WWHIN3  5
     C                     Z-ADDBCKTNK    WWGTNK  92
     C                     Z-ADDBCKSYY    WWGSYY  40
     C                     Z-ADDBCKSMM    WWGSMM  20
     C                     Z-ADDBCKSDD    WWGSDD  20
     C                     Z-ADDBCKEYY    WWGEYY  40
     C                     Z-ADDBCKEMM    WWGEMM  20
     C                     Z-ADDBCKEDD    WWGEDD  20
      *
     C                     SETON                     U1
     C                     EXCPT@@@
     C                     MOVELBCKEY     WWKEY
     C                     END
     C                     END
     C           @@END     TAG
     C  N10                END
     C                     END
      *
      *
      *  ﾒﾇn NO   =   3 OR 4       ﾉ      ﾆｭﾒ
      *
     C           @@NO      IFEQ 3
     C           @@NO      OREQ 4
      *
     C           @@NO      CABEQ3                    50
     C           @@NO      CABEQ4                    60
      *
     C                     MOVEL*BLANK    WWKEY
     C                     SETOF                     10
     C           *HIVAL    SETGTBBCPL021
     C                     DO   *HIVAL
     C                     READPBBCPL021                 10
     C           *IN10     IFEQ '0'
     C           BCSKJY    IFEQ 'D'
     C           BCSKHZ    ANDLE*DATE
     C                     GOTO @END
     C                     END
     C                     END
      *
     C           *IN10     IFEQ '0'
     C           BCKEY     IFNE WWKEY
      *
     C                     SETOF                     70
     C           BCTKCD    CHAINFGBPL01              70
     C           *IN,70    IFEQ '0'
     C   50      B2GRUP    CABNE'3'       @END
     C   60      B2GRUP    CABNE'2'       @END
      *
     C                     SETOF                     20
     C           KEY       SETGTBBDPL02
     C           STEP3     TAG
     C           KEY       REDPEBBDPL02                  20
     C           *IN,20    IFEQ '0'
     C           BDSKJY    IFEQ 'D'
     C           BDSKHZ    ANDLE*DATE
     C                     GOTO STEP3
     C                     END
     C                     END
     C           *IN,20    IFEQ '0'
     C                     Z-ADDBDKTNK    WWRTNK
     C                     Z-ADDBDKSYY    WWRSYY
     C                     Z-ADDBDKSMM    WWRSMM
     C                     Z-ADDBDKSDD    WWRSDD
     C                     Z-ADDBDKEYY    WWREYY
     C                     Z-ADDBDKEMM    WWREMM
     C                     Z-ADDBDKEDD    WWREDD
     C                     ELSE
     C                     Z-ADD0         WWRTNK
     C                     Z-ADD0         WWRSYY
     C                     Z-ADD0         WWRSMM
     C                     Z-ADD0         WWRSDD
     C                     Z-ADD0         WWREYY
     C                     Z-ADD0         WWREMM
     C                     Z-ADD0         WWREDD
     C                     END
     C                     END
      *
     C                     Z-ADDBCTKCD    WWTKCD
     C                     Z-ADDBCNONY    WWNONY
     C                     MOVELBCKOJO    WWKOJO
     C                     MOVELBCNUKE    WWNUKE
     C                     MOVELBCHIN1    WWHIN1
     C                     MOVELBCHIN2    WWHIN2
     C                     MOVELBCHIN3    WWHIN3
     C                     Z-ADDBCKTNK    WWGTNK
     C                     Z-ADDBCKSYY    WWGSYY
     C                     Z-ADDBCKSMM    WWGSMM
     C                     Z-ADDBCKSDD    WWGSDD
     C                     Z-ADDBCKEYY    WWGEYY
     C                     Z-ADDBCKEMM    WWGEMM
     C                     Z-ADDBCKEDD    WWGEDD
      *
     C                     SETON                     U1
     C                     EXCPT@@@
     C                     MOVELBCKEY     WWKEY
     C                     END
     C                     END
     C           @END      TAG
     C  N10                END
     C                     END
      *
     C                     MOVE @@NO      NO      1
     C                     MOVE @@TOKU    TOKU    4
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *
      *
     OBBBWP20 E                @@@
     O                         WWTKCD     4
     O                         WWNONY     8
     O                         WWKOJO     9
     O                         WWNUKE    13
     O                         WWHIN1    18
     O                         WWHIN2    23
     O                         WWHIN3    28
     O                         WWGTNK    37
     O                         WWGSYY    41
     O                         WWGSMM    43
     O                         WWGSDD    45
     O                         WWGEYY    49
     O                         WWGEMM    51
     O                         WWGEDD    53
     O                         WWRTNK    62
     O                         WWRSYY    66
     O                         WWRSMM    68
     O                         WWRSDD    70
     O                         WWREYY    74
     O                         WWREMM    76
     O                         WWREDD    78
