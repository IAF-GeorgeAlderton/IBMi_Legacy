     C           @SCRN1    BEGSR
     C**************************************************************************
     C                     EXFMTALDPW011                   E-KANBAN
     C*
     C                     SELEC
     C           *INKB     WHEQ *ON
     C                     EXSR #TOT
     C                     EXFMTALDPW996
     C           *INKE     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR @CHK1
     C           *IN30     IFEQ *ON
     C                     EXFMTALDPW998
     C                     MOVE '01'      ERRSCR  2
     C                     EXSR WRTERR
     C                     MOVE *BLANK    MSG
     C                     ELSE
     C                     MOVE '02'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *----------------------------------------------
     C           @CHK1     BEGSR
      *----------------------------------------------
     C                     SETOF                     3033
     C                     MOVE *BLANK    MSG
      *
     C           BARCD0    IFEQ *BLANK
     C                     SETON                     3033
     C                     MOVE ERR,6     MSG
     C                     MOVE '06'      ERRID   2
     C                     ELSE
     C           BARCD0    SETLLAB#PL71
     C           *IN90     DOUEQ*ON
     C           BARCD0    READEAB#PL71             N    90
     C           *IN90     IFEQ *OFF
     C           EKDEYY    IFNE *ZERO
     C                     SETON                     3033
     C                     MOVE ERR,8     MSG
     C                     MOVE '08'      ERRID
     C                     GOTO #CHK1
     C                     ELSE
     C                     MOVE EKNONY    DELIVL  4
     C                     MOVE EKNUKE    DOCK    4
     C                     MOVE EKNKOJ    FACTRY  1
     C                     MOVE EKZETI    IDCD    4
     C                     MOVE EKSYOS    HQTY    70
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     MOVE ERR,6     MSG
     C                     MOVE '06'      ERRID
     C                     SETON                     3330
      *
     C                     ELSE
      *
     C           EKZETI    CHAINFCETL11              90
      *
     C           K#FC6     CHAINFCEPL60              91
     C           *IN91     IFEQ *OFF
     C           F6APDT    IFEQ *ZERO
     C           F6APDT    ORGT *DATE
     C                     MOVE ERR,12    MSG
     C                     MOVE '12'      ERRID
     C                     SETON                     3330
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
      *  TOTAL QTY CHECK
     C           *IN30     IFEQ *OFF
     C                     EXSR @QTYCK
     C                     ENDIF
      *
     C           #CHK1     ENDSR
      *----------------------------------------------
     C           @QTYCK    BEGSR
      *----------------------------------------------
     C                     MOVE EKNONY    @@NONY
     C                     MOVE EKNOBN    @@NOBN
     C                     MOVE EKNONY    WWNONY
     C                     MOVE EKNOBN    WWNOBN
     C                     Z-ADD*ZERO     @@SRYO  90
     C           K#AB15    SETLLAB#PL15
     C           *IN91     DOUEQ*ON
     C           K#AB15    READEAB#PL15                  91
     C           *IN91     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C                     Z-ADDBASRYO    @@SRYO  90
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           @@SRYO    IFEQ *ZERO
     C                     SETON                     3033
     C                     MOVE ERR,10    MSG
     C                     MOVE '10'      ERRID
     C                     ELSE
      *
     C                     Z-ADD*ZERO     @@QTY   70
     C           K#AP70    SETLLAB#PL70
     C           *IN91     DOUEQ*ON
     C           K#AP70    READEAB#PL70                  91
     C           *IN91     IFEQ *OFF
     C           EKSKJY    ANDEQ*BLANK
     C           EKHENK    ANDEQ*BLANK
     C                     ADD  EKSRYO    @@QTY
     C                     ENDIF
     C                     ENDDO
      *
     C           @@QTY     IFGE @@SRYO
     C                     SETON                     3033
     C                     MOVE ERR,9     MSG
     C                     MOVE '09'      ERRID
     C                     ENDIF
      *
     C                     ENDIF
