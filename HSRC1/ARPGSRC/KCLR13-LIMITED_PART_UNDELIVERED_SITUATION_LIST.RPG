     C*----------------------*
     C* 区分入力　チェック *
     C*----------------------*
     C           LOP0      TAG
     C                     SETOF                     KAKBKE
     C                     SETOF                     KH9998
     C                     MOVEA'0000'    *IN,01
     C                     MOVEA'0'       *IN,06
     C                     MOVEA'000'     *IN,10
     C                     Z-ADD0         IBMN
     C                     Z-ADD0         INOY
     C                     MOVE *BLANK    IKOJ
     C                     MOVE *BLANK    IUKR
     C                     Z-ADD0         FHIZ
     C                     Z-ADD0         THIZ
     C                     Z-ADD0         SBUNO   40
     C                     MOVE *BLANK    KUBN
     C                     MOVE *BLANK    @TEHI
     C                     MOVE *BLANK    NBUNO
     C                     MOVE *BLANK    NNONY
     C                     MOVE *BLANK    NKOJY
     C                     MOVE *BLANK    NUKER
     C                     MOVE *BLANK    OBUNO
     C                     MOVE *BLANK    ONONY
     C                     MOVE *BLANK    OKOJY
     C                     MOVE *BLANK    OUKER
     C                     Z-ADD0         O       30
     C                     DO   *HIVAL
     C           LOP1      TAG
     C                     SETOF                     KB
     C                     EXFMTKCLPW131
     C                     MOVEA'0000'    *IN,01
     C                     MOVEA'0'       *IN,06
     C                     MOVEA'000'     *IN,10
     C                     SETOF                     99
     C                     SETON                     98
     C* ＣＭＤ－１ *
     C           *INKA     IFEQ '1'
     C                     SETON                     LRU1
     C                     RETRN
     C                     END
     C* 発行区分チェック *
     C           KUBN      IFEQ '1'
     C           KUBN      OREQ '2'
     C           KUBN      OREQ '3'
     C           KUBN      OREQ '4'
     C           KUBN      OREQ '5'
     C                     ELSE
     C                     SETON                     0199
     C                     MOVELER,1      MSG
     C                     GOTO LOP1
     C                     END
      *
     C           @TEHI     IFNE 'Z'
     C           @TEHI     ANDNE'S'
     C                     SETON                     0699
     C                     MOVE ER,8      MSG
     C                     GOTO LOP1
     C                     END
     C***  ﾒﾇn jbnﾓ ﾉ ﾆｬcﾈb   1994.05.23 S.OHTAKE   ***
     C                     MOVE @TEHI     WTEHI
     C* ＣＭＤ－５ *
     C           *INKE     IFEQ '1'
     C           KUBN      IFEQ '3'
     C           KUBN      OREQ '4'
     C           KUBN      OREQ '5'
      * 部門指定 *
     C           KUBN      IFEQ '3'
     C                     Z-ADD1         D
     C           1         DO   O         D
     C           IBMN,D    IFEQ 0
     C                     SETON                     0199
     C                     MOVELER,2      MSG
     C                     GOTO LOP1
     C                     END
     C           INOY,D    IFEQ 0
     C           IKOJ,D    ANDEQ*BLANK
     C           IUKR,D    ANDEQ*BLANK
     C                     ELSE
     C                     SETON                     0199
     C                     MOVE ER,9      MSG
     C                     GOTO LOP1
     C                     END
     C                     END
     C                     END
      * 納入先指定 *
     C           KUBN      IFEQ '4'
     C                     Z-ADD1         D
     C           1         DO   O         D
     C           INOY,D    IFEQ 0
     C                     SETON                     0199
     C                     MOVELER,2      MSG
     C                     GOTO LOP1
     C                     END
     C           IBMN,D    IFEQ 0
     C           IKOJ,D    ANDEQ*BLANK
     C           IUKR,D    ANDEQ*BLANK
     C                     ELSE
     C                     SETON                     0199
     C                     MOVELER,10     MSG
     C                     GOTO LOP1
     C                     END
     C                     END
     C                     END
      * 納入先、工場、受入指定 *
     C           KUBN      IFEQ '5'
     C                     Z-ADD1         D
     C           1         DO   O         D
     C           IBMN,D    IFNE 0
     C                     SETON                     0199
     C                     MOVELER,14     MSG
     C                     GOTO LOP1
     C                     END
     C           INOY,D    IFEQ 0
     C           IKOJ,D    OREQ *BLANK
     C           IUKR,D    OREQ *BLANK
     C                     SETON                     0199
     C                     MOVELER,11     MSG
     C                     GOTO LOP1
     C                     END
     C                     END
     C                     END
     C                     Z-ADDO         HIR     30
     C                     ELSE
     C                     Z-ADD1         HIR
     C                     END
     C                     MOVE FHIZ      FH
     C                     MOVE THIZ      TH
     C                     GOTO START
     C                     END
     C* ＣＭＤ－８ *
     C           *INKH     IFEQ '1'
     C                     GOTO LOP0
     C                     END
     C* 未納日付のチェック *
     C*
     C*-- 合成ＫＥＹ --*
     C                     SETOF                     05
     C           KEY1      SETLLAGDPL12                  05
     C           *IN,05    IFEQ '0'
     C                     SETON                     0299
     C                     MOVELER,3      MSG
     C                     GOTO LOP1
     C                     END
     C           THIZ      IFEQ 0
     C                     Z-ADDFHIZ      THIZ
     C                     ELSE
     C                     SETOF                     05
     C           KEY2      SETLLAGDPL12                  05
     C           *IN,05    IFEQ '0'
     C                     SETON                     0399
     C                     MOVELER,3      MSG
     C                     GOTO LOP1
     C                     END
     C                     END
     C           FHIZ      IFGT THIZ
     C                     SETON                     0299
     C                     MOVELER,4      MSG
     C                     GOTO LOP1
     C                     END
     C* 部門CHEK *
     C           KUBN      IFEQ '3'
     C                     Z-ADD0         SBUNO
     C                     MOVE NBUNO     SBUNO
     C                     SETOF                     05
     C           SBUNO     SETLLFGBPL011                 05
     C           *IN,05    IFEQ '0'
     C                     SETON                     0499
     C                     MOVELER,6      MSG
     C                     GOTO LOP1
     C                     END
     C                     END
     C* 納入先CHEK *
     C           KUBN      IFEQ '4'
     C                     Z-ADD0         SBUNO
     C                     MOVE NNONY     SBUNO
     C                     SETOF                     05
     C           SBUNO     SETLLFGBPL011                 05
     C           *IN,05    IFEQ '0'
     C                     SETON                     1099
     C                     MOVELER,12     MSG
     C                     GOTO LOP1
     C                     END
     C                     END
     C* 納入先、工場、受入CHEK *
     C           KUBN      IFEQ '5'
     C                     Z-ADD0         KNONY   40
     C                     MOVE *BLANK    KKOJY   1
     C                     MOVE *BLANK    KUKER   4
     C                     MOVELNNONY     KNONY
     C                     MOVELNKOJY     KKOJY
     C                     MOVELNUKER     KUKER
     C                     SETOF                     05
      *
     C           KEY3      CHAINGADTL171             05
     C           *IN,05    IFEQ '1'
     C                     SETON                     101112
     C                     SETON                     99
     C                     MOVELER,13     MSG
     C                     GOTO LOP1
     C                     END
     C                     END
     C* 登録 *
     C           *INKB     IFEQ '1'
     C           KUBN      IFEQ '1'
     C           KUBN      OREQ '2'
     C                     SETON                     0199
     C                     MOVELER,7      MSG
     C                     GOTO LOP1
     C                     ELSE
     C           99        IFLT O
     C                     SETON                     99
     C                     MOVELER,5      MSG
     C                     GOTO LOP1
     C                     ELSE
     C                     ADD  1         O
      * 配列に入力 *
     C                     MOVE NBUNO     IBMN,O
     C                     MOVE NNONY     INOY,O
     C                     MOVE NKOJY     IKOJ,O
     C                     MOVE NUKER     IUKR,O
     C                     MOVE NBUNO     OBUNO
     C                     MOVE NNONY     ONONY
     C                     MOVE NKOJY     OKOJY
     C                     MOVE NUKER     OUKER
     C                     MOVE *BLANK    NBUNO
     C                     MOVE *BLANK    NNONY
     C                     MOVE *BLANK    NKOJY
     C                     MOVE *BLANK    NUKER
      *
     C                     END
     C                     END
     C                     END
     C                     END
     C*------------------*
     C* マスター　作成 *
     C*------------------*
     C           START     TAG
     C                     Z-ADD0         @BMN
     C                     READ DC#PL111                 30
     C           *IN,30    IFEQ '1'
     C                     SETON                     LR
     C   LR                RETRN
     C                     END
     C           P5SKJY    IFEQ 'D'
     C                     GOTO START
     C                     ELSE
     C           SKHZ      IFGE *DATE
     C                     GOTO START
     C                     END
     C                     END
      *
     C                     SETOF                     67
     C                     MOVE 'Z'       $TEHI   1
     C           KEY       CHAINFCEPL011             67
     C           *IN67     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     67
     C                     END
     C           *IN67     IFEQ '0'
     C                     MOVE A2TEHI    $TEHI
     C                     END
      *
     C           @TEHI     IFNE $TEHI
     C                     GOTO START
     C                     END
      *
     C                     EXSR KOTEI
     C* 購買 *
     C           KUBN      IFEQ '2'
     C                     Z-ADD1         O
     C                     SETOF                     67
     C           1         DO   A         O
     C           BMN,O     LOKUPKOBMN                    67
     C   67                END
     C   67                GOTO START
     C                     END
     C* 部門指定 *
     C           KUBN      IFEQ '3'
     C                     Z-ADD1         O
     C                     SETOF                     67
     C           1         DO   HIR       O
     C                     Z-ADD1         D       20
     C           1         DO   A         D
     C           IBMN,O    IFEQ BMN,D
     C                     SETON                     67
     C                     END
     C  N67                END
     C  N67                END
     C  N67                GOTO START
     C                     END
     C* 納入先指定 *
     C           KUBN      IFEQ '4'
     C                     Z-ADD1         O
     C                     SETOF                     67
     C           1         DO   HIR       O
     C           INOY,O    IFEQ P5NONY
     C                     SETON                     67
     C                     END
     C  N67                END
     C  N67                GOTO START
     C                     END
     C* 部門、納入先、工場、受入指定 *
     C           KUBN      IFEQ '5'
     C                     Z-ADD1         O
     C                     SETOF                     67
     C           1         DO   HIR       O
     C           INOY,O    IFEQ P5NONY
     C           IKOJ,O    ANDEQP5NKOJ
     C           IUKR,O    ANDEQP5NUKE
     C                     SETON                     67
     C                     END
     C  N67                END
     C  N67                GOTO START
     C                     END
     C*
     C           *IN,20    IFEQ '0'
     C                     MOVE '.'       KA
     C                     MOVE '-'       HI
     C                     MOVE '-'       HI2
     C                     MOVE '-'       HI3
     C                     MOVE '-'       HI4
     C                     MOVE '-'       HI5
     C                     MOVE '-'       HI6
     C                     MOVE '-'       HI7
     C                     Z-ADD*DATE     HIZK
     C                     SETON                     20
     C                     BITOF'01234567'DDD     1
     C                     BITON'4567'    DDD
     C                     END
     C                     MOVE *BLANK    KTEI
     C                     MOVE *BLANK    KAKO
     C                     Z-ADD0         GNKI
     C                     MOVE *BLANK    NBN
     C* 納入日の検索 *
     C                     Z-ADD1         B       20
     C                     SETOF                     50
     C           1         DO   A         B
     C           KUBN      IFEQ '2'
     C                     SETOF                     25
     C           BMN,B     LOKUPKOBMN                    25
     C           *IN,25    IFEQ '1'
     C                     GOTO NLOOP
     C                     END
     C                     END
     C           KUBN      IFEQ '3'
     C                     SETOF                     26
     C           BMN,B     LOKUPIBMN                     26
     C           *IN,26    IFNE '1'
     C                     GOTO NLOOP
     C                     END
     C                     END
     C                     MOVELNKI,B     CNKI1   20
     C* ﾉcg r] ﾉ i]ﾅh *
     C           P5NOMM    IFEQ 1
     C           P5NOMM    OREQ 2
     C           P5NOMM    OREQ 3
     C           CNKI1     IFEQ 10
     C           CNKI1     OREQ 11
     C           CNKI1     OREQ 12
     C           P5NOYY    SUB  1         YNKI    40
     C                     ELSE
     C                     Z-ADDP5NOYY    YNKI
     C                     END
     C                     ELSE
     C                     Z-ADDP5NOYY    YNKI
     C                     END
     C*
