     H            Y.
     F** GDKR61 ********************************
     F*  DAILY ACCOUNT PAYABLE PROCESS         *
     F*      A.MAMIYA        2000.11.07        *
     F******************************** GDKR61 **
     FGDKPL0C IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     E                    #TY     1   4  1   WTY    15
     E                    #CD     1   2  1   WCD     4
     I            DS
     I                                        1   80ITSKHZ
     I                                        1   40ITSKYY
     I                                        5   60ITSKMM
     I                                        7   80ITSKDD
     I            DS
     I                                        1   80ITKOHZ
     I                                        1   40ITKOYY
     I                                        5   60ITKOMM
     I                                        7   80ITKODD
     I            DS
     I                                        1   60ITKOTI
     I                                        1   20ITKOHH
     I                                        3   40ITKOSS
     I            DS
     I                                        1   80ITMMHZ
     I                                        1   40ITMMYY
     I                                        5   60ITMMMM
     I                                        7   80ITMMDD
     I            DS
     I                                        1   80ITHTHZ
     I                                        1   40ITHTYY
     I                                        5   60ITHTMM
     I                                        7   80ITHTDD
     I            DS
     I                                        1   80ITUKHZ
     I                                        1   40ITUKYY
     I                                        5   60ITUKMM
     I                                        7   80ITUKDD
     I            DS
     I                                        1   80ITSAHZ
     I                                        1   40ITSAYY
     I                                        5   60ITSAMM
     I                                        7   80ITSADD
     I            DS
     I                                        1   80ITSIHZ
     I                                        1   40ITSIYY
     I                                        5   60ITSIMM
     I                                        7   80ITSIDD
     I            DS
     I                                        1   60WSIHZ
     I                                        1   40WSIYY
     I                                        5   60WSIMM
     C           *ENTRY    PLIST
     C                     PARM           PVEND   4
     C                     PARM           PSIHZ   60
     C                     PARM           PFLG    1
     C*
     C                     MOVELPVEND     WVEND   4
     C                     Z-ADDPSIHZ     WSIHZ   60
     C*
     C           KEY1      KLIST
     C                     KFLD           WSIYY
     C                     KFLD           WSIMM
     C                     KFLD           WVEND
     C*
     C                     MOVEL*BLANK    WTYPE   1
     C                     MOVEL*BLANK    WTYNM  10
     C                     SETOF                     90
     C           KEY1      SETLLGDKPL0C1
     C                     DO   *HIVAL
     C                     MOVEL*BLANK    WFLG    1
     C                     MOVEL*BLANK    WCARRY  4
     C           KEY1      READEGDKPL0C1                 90
     C           *IN90     IFEQ '0'
     C           ITSKJY    IFEQ 'D'
     C           ITSKHZ    ANDLE*DATE
     C                     ELSE
     C           ITTYPE    IFNE WTYPE
     C           *INOF     OREQ '1'
     C                     MOVELITTYPE    WTYPE
     C*TYPE CODE
     C                     Z-ADD1         X       20
     C           ITTYPE    LOKUP#TY,X                    30
     C   30                MOVELWTY,X     WTYNM
     C                     EXCPT#HED
     C                     SETOF                     OF
     C                     MOVEL'1'       PFLG
     C                     END
     C*CARRY CODE
     C                     Z-ADD1         X       20
     C           ITYUSO    LOKUP#CD,X                    30
     C   30                MOVELWCD,X     WCARRY
     C*UNIT PRICE ERR
     C           ITTAN     IFEQ 0
     C                     MOVEL'*'       WFLG
     C                     END
     C*
     C                     EXCPT#DTL
     C                     END
     C                     END
     C  N90                ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     OQPRINT  E   02           #HED
     O                                    7 'GDKR61'
     O                                   68 '*** DAILY ACCOUNT PAYABL'
     O                                   78 'E LIST ***'
     O                                  103 'DATE :'
     O                         *YEAR   +  1
     O                                 +  0 '/'
     O                         UMONTH  +  0
     O                                 +  0 '/'
     O                         UDAY    +  0
     O                                  121 'PAGE :'
     O                         PAGE  Z +  0
     O        E   03           #HED
     O                                   15 'PAYMENT DATE :'
     O                         ITSIYY  +  1
     O                                 +  0 '/'
     O                         ITSIMM  +  0
     O                                   34 'TYPE :'
     O                         ITTYPE  +  0
     O                         WTYNM   +  1
     O        E   05           #HED
     O                                    9 'INVOICE'
     O                                   19 'ORDER NO.'
     O                                   28 'ITEM NO.'
     O                                   33 'PLT.'
     O                                   39 'SNBOX'
     O                                   48 'PART NO.'
     O                                   65 'QTY.'
     O                                   72 'BOX'
     O                                   89 'IAF UNIT PRICE'
     O                                   99 'AMOUNT'
     O                                  119 'RECEIVE DAY'
     O                                  125 'CARRY'
     O        E   0607         #HED
     O                                    9 '-------'
     O                                   19 '---------'
     O                                   28 '--------'
     O                                   33 '----'
     O                                   39 '-----'
     O                                   60 '--------------------'
     O                                   68 '-------'
     O                                   74 '-----'
     O                                   92 '-----------------'
     O                                  107 '--------------'
     O                                  119 '-----------'
     O                                  125 '-----'
     O        E  1             #DTL
     O                         WFLG       1
     O                         ITINVO     8
     O                         ITODER    17
     O                         ITITEM    25
     O                                 +  0 '-'
     O                         ITIKBN  +  0
     O                         ITPARE    33
     O                         ITBXNO    38
     O                         ITHIN     60
     O                         ITSRY Z   68
     O                         ITHAKOZ   74
     O                         ITTAN 1   92
     O                         ITKIN 1  107
     O                         ITUKYY   112
     O                                 +  0 '/'
     O                         ITUKMM  +  0
     O                                 +  0 '/'
     O                         ITUKDD  +  0
     O                         WCARRY   124
** #TY/WTY
0FINISHED
3WASHER
6HALF-FINISHED
KDIE
