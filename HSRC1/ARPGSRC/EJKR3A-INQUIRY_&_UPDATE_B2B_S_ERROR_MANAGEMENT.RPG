     H            Y.
     F** EJKR3A *******************************************
     F* INQUIRY & UPDATE B2B_S ERROR MANAGEMENT FILE      *
     F*  T.SAKAKI         2016.12.13                      *
     F*****************************************************
     FEJKPW3A CF  E                    WORKSTN
     F                                              KINFDS WSINF
     F                                        RRN1  KSFILE SFREC1
      *
     FEJKPP55 UF  E           K        DISK
      *================================================================
     E                    ER      1  10 60
      *================================================================
     IWSINF       DS
     I                                    B 370 3710$$CURS
     I*
     I                                    B 378 3790$$RRN
     I           SDS
     I                                     *PROGRAM @@PGM
     I                                      244 253 @@WSID
     I                                      254 263 @@USER
     I                                      264 269 @@JBNO
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *
     I              '0123456789'          C         DIGITS
      *================================================================
      * KEY LIST
      *================================================================
     C           KEY1      KLIST
     C                     KFLD           S1HAHZ
     C                     KFLD           S1HATM
     C                     KFLD           S1JOBN
     C                     KFLD           S1PGMN
      *================================================================
      * MAIN
      *================================================================
     C                     MOVE '#INZ    '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INZ    '#INZ
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C           @STEP     CASEQ'#CHK2 F5'#CHK2
     C           @STEP     CASEQ'#UPDAT  '#UPDAT
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
      *================================================================
      * INTIALIZE
      *================================================================
     C           #INZ      BEGSR
      *
     C                     MOVE *ALL'0'   *IN
     C                     TIME           @TIME
     C                     MOVE '#CHK1   '@STEP
      *
     C                     ENDSR
      *================================================================
      * 1ST SCREEN CHECK
      *================================================================
     C           #CHK1     BEGSR
      *
     C                     EXSR #SFSET
      *
     C           @STEP     IFNE '#END    '
     C                     MOVE '#DSP2   '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
      *================================================================
     C           #SFSET    BEGSR
     C* SFLCLR
     C                     SETON                     73
     C                     WRITESFCTL1
     C                     SETOF                     73
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         ENDRRN  40
     C*
     C           *LOVAL    SETLLEJKPP55
      *-----------------------------------
S1   C                     DO   *HIVAL
     C                     READ EJKPP55                  90
     C   90                LEAVE
     C*
 S2  C           D1SKJY    IFEQ 'D'
     C           D1SKHZ    ANDLE@SYSHZ
     C                     ITER
 E2  C                     ENDIF
     C*
 S2  C           D1TAHZ    IFNE 0
     C                     ITER
 E2  C                     ENDIF
     C*  **
     C                     MOVE *BLANK    S1SEL
     C                     Z-ADDD1HAHZ    S1HAHZ
     C                     Z-ADDD1HATM    S1HATM
     C                     MOVELD1JOBN    S1JOBN
     C                     MOVELD1PGMN    S1PGMN
     C                     SETOF                     2122
     C                     ADD  1         RRN1
     C                     WRITESFREC1
     C*
E1   C                     ENDDO
      *-----------------------------------
     C*
     C           RRN1      IFEQ 0
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C*
     C                     Z-ADDRRN1      ENDRRN
     C                     Z-ADD1         RRN1
     C*
     C                     ENDSR
      *================================================================
      * 2ND SCREEN
      *================================================================
     C           #DSP2     BEGSR
     C*
     C                     SETON                     7172
     C                     WRITEDSP02
     C                     EXFMTSFCTL1
     C                     SETOF                     717199
     C                     Z-ADD$$RRN     TOPRRN  40
     C                     Z-ADD$$RRN     RRN1
     C*----------
     C                     MOVE '#CHK2   '@STEP
     C*----------
     C* < PAGE UP >
     C   75                MOVE '#DSP2   '@STEP
     C*----------
     C* < F3 > END
     C   KC                MOVE '#END    '@STEP
     C*----------
     C* < F5 > UPDATE
     C   KE                MOVE '#CHK2 F5'@STEP
     C*----------
     C                     ENDSR
      *================================================================
      * 2ND SCREEN CHECK
      *================================================================
     C           #CHK2     BEGSR
     C                     Z-ADD0         ERRRRN  40
     C                     Z-ADD0         $$KEN1  40
     C                     Z-ADD0         $$KENM  40
      *-----------------------------------
S1   C                     DO   ENDRRN    RRN1
     C           RRN1      CHAINSFREC1               95
     C   95                LEAVE
     C                     SETOF                     21
     C*
 S2  C           S1SEL     IFNE ' '
     C           S1SEL     ANDNE'1'
     C                     MOVELER,4      D2MSG
     C                     SETON                     2199
     C                     Z-ADDRRN1      ERRRRN  40
 X2  C                     ELSE
  S3 C           S1SEL     IFEQ '1'
  S4 C           $$KENM    IFNE 0
     C                     MOVELER,6      D2MSG
     C                     SETON                     2199
     C                     Z-ADDRRN1      ERRRRN  40
  X4 C                     ELSE
     C                     ADD  1         $$KEN1
  E4 C                     ENDIF
  E3 C                     ENDIF
      *-----------------------------------
 E2  C                     ENDIF
     C           S1SEL     COMP '1'                      22
     C                     UPDATSFREC1
E1   C  N99                ENDDO
      *-----------------------------------
S1   C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK2 F5'
     C           $$KEN1    ANDEQ0
     C                     MOVELER,5      D2MSG
     C                     SETON                       99
E1   C                     ENDIF
      *
S1   C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK2 F5'
     C                     MOVEL'#UPDAT  '@STEP
X1   C                     ELSE
     C           ERRRRN    IFNE 0
     C                     Z-ADDERRRRN    RRN1
     C                     ELSE
     C                     Z-ADDTOPRRN    RRN1
     C                     ENDIF
     C                     MOVE '#DSP2   '@STEP
E1   C                     ENDIF
      *
     C                     ENDSR
      *================================================================
      * UPDATE
      *================================================================
     C           #UPDAT    BEGSR
      *-----------------------------------
S1   C                     DO   ENDRRN    RRN1
     C           RRN1      CHAINSFREC1               95
     C   95                LEAVE
     C*
 S2  C           S1SEL     IFEQ '1'
     C           KEY1      CHAINEJKPP55              96
     C           *IN96     IFEQ *OFF
     C                     Z-ADD@SYSHZ    D1KOHZ
     C                     Z-ADD@SYSTM    D1KOTM
     C                     Z-ADD@SYSHZ    D1TAHZ
     C                     Z-ADD@SYSTM    D1TATM
     C                     MOVEL@@USER    D1KOME
     C                     MOVEL@@PGM     D1KOPG
     C                     UPDATEJKPP551
     C                     ENDIF
 E2  C                     ENDIF
E1   C                     ENDDO
      *-----------------------------------
      *-----------------------------------
      *-----------------------------------
     C                     MOVE '#CHK1   '@STEP
      *
     C                     ENDSR
      *================================================================
** ER
ER-01 INPUT START DATE.
ER-02 INCORRECT DATE.
ER-03 NO DATA.
ER-04 "1" SELECT OR "M" DETAIL.
ER-05 SELECT DATA.
ER-06 CANNOT USE BOTH "1" SELECT AND "M" DETAIL.
ER-07 INCORRECT TIME.
ER-08 " " ALL OR "E" ERROR.
ER-09
ER-10
