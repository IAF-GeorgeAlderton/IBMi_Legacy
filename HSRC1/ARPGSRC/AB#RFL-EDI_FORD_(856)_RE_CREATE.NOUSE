     C*************************************************************
     C           PNOHZ     IFGE 20021111
     C           PNONY     ANDEQ'5150'
     C                     MOVE *ON       *IN87
     C                     ELSE
     C                     MOVE *OFF      *IN87
     C                     ENDIF
     C*
     C                     SETON                     88OF
     C                     TIME           WWTIME
     C                     Z-ADDPNOBN     KNOBN   20
     C                     Z-ADD*ZERO     N       20       IPAR COUNTER
     C                     Z-ADD*ZERO     M       20       OPAR COUNTER
     C                     MOVE PNONY     WNONY
     C                     MOVE PNOHZ     WNOHZ
     C                     MOVE PREHZ     WREHZ
     C                     MOVELPNUKE     KNUKE   4
     C                     MOVE *BLANK    WWPART 12
     C*
     C* READ ADDRESS MASTER & CHECK CUM FLAG(INCLUDE OR NOT INCLUDE SHIP)
     C           PNONY     CHAINABF9P011             93
     C           *IN93     IFEQ '1'
     C                     MOVE 'B'       PFLG
     C                     GOTO #END
     C                     END
     C*
     C           KEY1      SETLLABF6P011
     C           KEY1      READEABF6P011                 90
     C           *IN90     DOWEQ'0'
     C*
     C           FCSKJY    IFEQ ' '
     C*
     C           FCPRNT    IFEQ 'A'
     C*
     C*
     C* 1ST. RECORD
     C           *IN88     IFEQ '1'
     C                     Z-ADDPNOBN     WNOBN   10
     C                     SETOF                     91
     C           KEY2      SETLLABF4P011
     C                     DO   *HIVAL
     C           KEY2      READEABF4P011                 91
     C           *IN91     IFEQ '0'
     C           YBSKJY    IFEQ 'D'
     C           YBSKHZ    ANDLE*DATE
     C                     ELSE
     C                     GOTO @JUMP
     C                     END
     C                     END
     C  N91                ENDDO
     C*
     C           @JUMP     TAG
     C           *IN91     IFEQ '0'
     C*
     C                     ELSE
     C   OF                EXCPTHD
     C   OF                SETOF                     OF
     C                     EXCPTERR1
     C                     GOTO #END
     C                     END
     C*
     C                     MOVEL*BLANK    WPLAN   5
     C*                    MOVEL*BLANK    WMAST   1
     C                     MOVE FCDELY    @DELY   40
     C           KEY4      SETGTABFDL01R
     C           *IN20     DOUEQ*ON
     C           KEY4      REDPEABFDL01R                 20
     C           *IN20     IFEQ '0'
     C                     SELEC
     C           QASKJY    WHEQ 'D'
     C           QASKHZ    ANDLE*DATE
     C                     ITER
     C           QAEFHZ    WHGT *DATE
     C                     ITER
     C                     OTHER
     C                     LEAVE
     C                     ENDSL
     C                     END
     C                     END
     C*
     C           *IN20     IFEQ '0'
     C                     MOVELQAPLAN    WPLAN   5
     C                     SETOF                     21
     C           KEY5      CHAINAB#PL141             21
     C           *IN21     IFEQ '0'
     C           BASKJY    IFEQ 'D'
     C**JW       BASKHZ    ANDLE*DATE
     C                     SETON                     21
     C                     END
     C                     END
     C*
     C*          *IN21     IFEQ '0'
     C*          BAJYKB    ANDEQ*BLANK
     C*                    MOVEL'C'       WMAST
     C*                    END
     C                     END
     C*
     C*          WMAST     IFEQ *BLANK
     C*          PFREI     IFEQ *BLANK
     C*                    MOVEL'M'       WMAST
     C*                    ELSE
     C*                    MOVEL'A'       WMAST
     C*                    END
     C*                    END
     C*
     C                     MOVE *ZERO     @@WEIT  82
     C           YBWEIT    ADD  YBTARE    @@WEIT
     C                     MOVE *ZERO     WWWEIT
     C                     Z-ADD@@WEIT    WBWEIT
     C                     MOVE WBINTE    WWINTE
     C                     MOVE '.'       WWDECP
     C                     MOVE WBDEC     WWDEC
     C                     MOVELYBMANI    WBMANI 11
     C*
     C                     EXCPTD010
     C                     EXCPTD020
     C                     EXCPTD030
     C                     SETOF                     88
     C                     END
     C*
     C* IF PALETTE DATA,WRITE 040
     C           FCPBCD    IFEQ 'M'
     C                     Z-ADDFCSEQ#    P21
     C                     MOVE *BLANK    P22
     C                     CALL 'AB#R2K'  P2
     C                     MOVELP22       WSEQ1   9
     C*
     C                     EXCPTD040
     C*
     C* IF BOX DATA, WRITE 050
     C                     ELSE
     C*
     C* SET QTY / CONTAINERS
     C                     Z-ADDFCUQTY    P21
     C                     MOVE *BLANK    P22
     C                     CALL 'AB#R2K'  P2
     C                     MOVELP22       WQTY    6
     C*
     C* SET SERIAL #
     C                     Z-ADDFCSEQ#    P21
     C                     MOVE *BLANK    P22
     C                     CALL 'AB#R2K'  P2
     C                     MOVELP22       WSEQ2   9
     C*
     C* SET UNIT PRICE(OMIT BLANK FROM CUSTOMER PART)
     C                     MOVEAFCCPAR    IPAR
     C                     MOVE *BLANK    OPAR
     C                     Z-ADD1         M
     C*
     C           1         DO   20        N
     C           IPAR,N    IFNE *BLANK
     C                     MOVE IPAR,N    OPAR,M
     C                     ADD  1         M
     C                     END
     C                     END
     C*
     C                     MOVE WCCUST    #TOKU   4
     C                     MOVE WNONY     #NONY   4
     C                     MOVE '0'       #NKOJ   1
     C                     MOVE FCDOCK    #NUKE   4
     C                     MOVEAOPAR      #MHIN  20
     C                     MOVE WNOHZ     #HIZK   8
     C                     Z-ADD0         #TANK  105
     C                     MOVE *BLANK    #CHEK   1
     C*
     C                     CALL 'FBCR10'
     C                     PARM           #TOKU
     C                     PARM           #NONY
     C                     PARM           #NKOJ
     C                     PARM           #NUKE
     C                     PARM           #MHIN
     C                     PARM           #HIZK
     C                     PARM           #TANK
     C                     PARM           #CHEK
     C* EDIT DECIMAL POSTION
B05  C           #TANK     IFEQ *ZERO
     C                     MOVE '*'       PFLG
     C   OF                EXCPTHD
     C   OF                SETOF                     OF
     C                     EXCPTERR2
E05  C                     END
     C*
     C                     Z-ADD#TANK     @TANK
     C                     MOVE *ZERO     WTANK
     C                     Z-ADD#INTE     WINTE
     C                     MOVE '.'       WDECP
     C                     MOVEL#DEC      WDEC
     C*
     C* SET CUMULATIVE QTY.
     C           WWPART    IFNE #MHIN
     C                     MOVEL#MHIN     WWPART
     C*
     C                     MOVELF9DOCK    KDELY   4
     C                     MOVEL#MHIN     KPART  12
     C           KEY3      CHAINABFAP01R             92
     C           *IN92     IFEQ '0'
     C*
     C           F9FLAG    IFEQ ' '
     C********   FCRQTY    ADD  CFCAMT    WWCAMT  90
     C                     Z-ADDCFCAMT    WWCAMT  90
     C                     Z-ADDWWCAMT    P21
     C                     MOVE *BLANK    P22
     C                     CALL 'AB#R2K'  P2
     C                     MOVELP22       WCAMT   9
     C*
     C                     ELSE
     C*******    CFCAMT    SUBDDFCRQTY    WWCAMT
     C                     Z-ADDCFCAMT    WWCAMT
      *
     C                     Z-ADDWWCAMT    P21
     C                     MOVE *BLANK    P22
     C                     CALL 'AB#R2K'  P2
     C                     MOVELP22       WCAMT
     C                     END
     C*
     C* NEW PART ?
     C                     ELSE
     C*
     C                     MOVE '*'       PFLG
     C   OF                EXCPTHD
     C   OF                SETOF                     OF
     C                     EXCPTERR3
     C                     END
     C                     END
     C*
     C                     EXCPTD050
     C                     END
     C*
     C                     END
     C                     END
     C*
     C           KEY1      READEABF6L02                  90
     C                     END
