     H            Y.
     F** AAHRSB ********************************************
     F*引き取りかんばん旧番地・旧収容数取得              *
     F* GET OLD LOCATION/OLD CAPACITY OF WITHDRAWAL KANBAN *
     F*      T.SAKASHITA                   2006.11.22      *
     F******************************************** AAFRSB **
     FAAHTL06 IF  E           K        DISK
      *
     C           *ENTRY    PLIST
     C                     PARM           PHIN1   5
     C                     PARM           PHIN2   5
     C                     PARM           PHIN3   2
     C                     PARM           PSTYY   40
     C                     PARM           PSTMM   20
     C                     PARM           PSTDD   20
     C                     PARM           PSBIN   20
     C                     PARM           OATK1   1
     C                     PARM           OATK2   2
     C                     PARM           OATK3   2
     C                     PARM           OATK4   1
     C                     PARM           OSSYS   50
     C                     PARM           OSSYT   1
      **
     C                     MOVELPHIN1     WHIN1   5
     C                     MOVELPHIN2     WHIN2   5
     C                     MOVELPHIN3     WHIN3   2
     C                     Z-ADDPSTYY     WSTYY   40
     C                     Z-ADDPSTMM     WSTMM   20
     C                     Z-ADDPSTDD     WSTDD   20
     C                     Z-ADDPSBIN     WSBIN   20
     C                     MOVE *BLANK    OATK1   1
     C                     MOVE *BLANK    OATK2   2
     C                     MOVE *BLANK    OATK3   2
     C                     MOVE *BLANK    OATK4   1
     C                     Z-ADD0         OSSYS   50
     C                     MOVE *BLANK    OSSYT   1
      *
     C           AAHKEY    KLIST
     C                     KFLD           WHIN1
     C                     KFLD           WHIN2
     C                     KFLD           WHIN3
     C                     KFLD           WSTYY
     C                     KFLD           WSTMM
     C                     KFLD           WSTDD
     C                     KFLD           WSBIN
     C           AAHKY2    KLIST
     C                     KFLD           WHIN1
     C                     KFLD           WHIN2
     C                     KFLD           WHIN3
      *パラメータのめっきかんばんを探す。
     C           AAHKEY    SETGTAAHTL061
     C                     DO   *HIVAL
     C           AAHKEY    REDPEAAHTL061                 55
     C   55                LEAVE
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    ANDLE*DATE
     C                     ITER
     C                     END
     C                     LEAVE
     C                     ENDDO
     C   55                EXSR #SB300
      *見つかっためっきかんばんの一つ前のかんばんを探す。
     C                     DO   *HIVAL
     C           AAHKY2    REDPEAAHTL061                 55
     C   55                LEAVE
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    ANDLE*DATE
     C                     ITER
     C                     END
     C                     LEAVE
     C                     ENDDO
      *
     C   55                EXSR #SB300
      *
     C                     MOVE L6MTK1    OATK1
     C                     MOVE L6MTK2    OATK2
     C                     MOVE L6MTK3    OATK3
     C                     MOVE L6MTK4    OATK4
     C                     MOVE L6SYOS    OSSYS
     C                     MOVE L6SYOT    OSSYT
      *
     C                     EXSR #SB300
      *
      *----------------------------------------------------*
      *   終了処理                                       *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
