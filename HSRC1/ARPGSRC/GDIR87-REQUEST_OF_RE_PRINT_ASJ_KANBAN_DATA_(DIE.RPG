      *     <<
     C*===============================================================
     C           *ENTRY    PLIST
     C                     PARM           P@SYS   8
     C*===============================================================
     C*  START  PROGRAM
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#CHK1U  '#CHK1
     C           @STEP     CASEQ'#ADD    '#ADD
     C           @STEP     CASEQ'#SFSET  '#SFSET
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C           @STEP     CASEQ'#CHK2U  '#CHK2
     C           @STEP     CASEQ'#DELETE '#DEL
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     MOVE *BLANK    D1MSG            エラー
     C*
     C                     Z-ADD1         X       20
     C           P@SYS     LOKUPTBL,X                    90
     C           *IN90     IFEQ *ON
     C                     MOVE TOKU,X    @TOKU
     C                     ELSE
     C                     MOVE TOKU,4    @TOKU
     C                     ENDIF
     C*
     C                     MOVE *BLANK    D1KAT1
     C                     MOVE *BLANK    D1KAT2
     C                     MOVE *BLANK    D1KAT3
     C                     MOVE *BLANK    D1KAT4
     C                     Z-ADD0         D1MAIS
     C*
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
      *===============================================================
      *  画面１　表示
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     EXFMTDSP01
     C                     SETOF                     111299
     C                     MOVE *BLANK    D1MSG
     C*
     C                     MOVE '#CHK1   '@STEP
     C*  < F1 >  END JOB
     C           *INKA     IFEQ *ON
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C*  < F5 >  INPUT OK
     C           *INKE     IFEQ *ON
     C                     MOVE '#CHK1U  '@STEP
     C                     ENDIF
     C*  < F12 >  INQUIRY
     C           *INKL     IFEQ *ON
     C                     MOVE '#SFSET  '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  画面１　チェック
      *===============================================================
     C           #CHK1     BEGSR
     C                     CLEARGDIWP871
     C*----------
     C* DIE NO.
     C*----------
     C           D1KAT1    IFEQ *BLANK
     C           D1KAT2    ANDEQ*BLANK
     C                     SETON                     1199
     C                     MOVELMSG,1     D1MSG
     C                     ENDIF
     C*
     C           KEY01     KLIST
     C                     KFLD           D1KAT1
     C                     KFLD           D1KAT2
     C                     KFLD           D1KAT3
      *
      *
     C           KEY01     SETGTGCQPL121
     C                     Z-ADD0         G1ISYS  70       収容数
     C*--------------------
     C                     DO   *HIVAL
     C           KEY01     REDPEGCQPL121                 90
     C   90                LEAVE
     C           T6SKJY    IFEQ 'D'
     C           T6SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C*
     C           *DATE     IFGE T6KIHZ
     C                     Z-ADDT6SYOS    G1ISYS
     C                     MOVE T6SYOT    G1IHAK
     C                     MOVE T6TKR1    G1ITK1
     C                     MOVE T6TKR2    G1ITK2
     C                     MOVE T6TKR3    G1ITK3
     C                     MOVE T6TKR4    G1ITK4
     C                     Z-ADDT6SRYO    G1GEKN
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C*--------------------
     C           *IN90     IFEQ *ON
     C                     SETON                     1199
     C                     MOVELMSG,2     D1MSG
     C                     ENDIF
     C*    入力済
     C           *IN99     IFEQ *OFF
     C           KEY01     SETLLGDIWP87                  90:EQ
     C           *IN90     IFEQ *ON
     C                     SETON                     1199
     C                     MOVELMSG,3     D1MSG
     C                     ENDIF
     C                     ENDIF
     C*--------------------
     C                     MOVE 'K'       G1SKBN  1        製品区分
     C                     MOVE *BLANK    G1ZETI  4        絶対番号
     C*
     C  N99      D1MAIS    IFEQ 0
     C                     SETON                     1299
     C                     MOVELMSG,4     D1MSG
     C                     ENDIF
     C*----------
S1   C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK1U  '
     C                     MOVE '#ADD    '@STEP
X1   C                     ELSE
     C                     MOVE '#DSP1   '@STEP
E1   C                     ENDIF
     C*
     C                     ENDSR
     C*===============================================================
     C*===============================================================
     C*   << ADD   >>
     C*===============================================================
     C           #ADD      BEGSR
     C*
     C                     Z-ADD@@TOKU    G1TOKU
     C                     MOVE @@TKOJ    G1TKOJ
     C                     MOVE @@TUKE    G1TUKE
     C                     Z-ADD@@NONY    G1NONY
     C                     MOVE @@NKOJ    G1NKOJ
     C                     MOVE @@NUKE    G1NUKE
     C                     MOVE D1KAT1    G1KAT1
     C                     MOVE D1KAT2    G1KAT2
     C                     MOVE D1KAT3    G1KAT3
     C                     MOVE D1KAT4    G1KAT4
     C                     Z-ADDD1MAIS    G1MAIS
     C                     MOVE 'S'       G1HANY
     C           G1MAIS    MULT G1ISYS    G1JCHU
     C                     WRITEGDIWP871
     C*
     C                     MOVE *BLANK    D1KAT1
     C                     MOVE *BLANK    D1KAT2
     C                     MOVE *BLANK    D1KAT3
     C                     MOVE *BLANK    D1KAT4
     C                     Z-ADD0         D1MAIS
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
     C*===============================================================
     C*   << SFSET >>
     C*===============================================================
     C           #SFSET    BEGSR
     C                     SETON                     73    SFLCLR
     C                     WRITESFCTL
     C                     SETOF                     73
     C                     Z-ADD0         RRN1    40
     C*
     C* DAYLY ORDER DATA BEFOR ADDING FILE
     C           *LOVAL    SETLLGDIWP87
     C*--------------------
S1   C                     DO   *HIVAL
     C                     READ GDIWP87                  90
     C   90                LEAVE
     C*
     C                     SETOF                     21
     C                     MOVE *BLANK    S1DEL            DELETE
     C                     MOVE *BLANK    S1KAT            DIE NO.
     C                     MOVE G1KAT1    S1KAT1           DIE NO1
     C                     MOVE G1KAT2    S1KAT2           DIE NO2
     C                     MOVE G1KAT3    S1KAT3           DIE NO3
     C                     MOVE G1KAT4    S1KAT4           DIE NO3
     C                     MOVE '-'       S1HF1
     C                     MOVE '-'       S1HF2
     C                     MOVE '-'       S1HF3
     C                     Z-ADDG1MAIS    S1MAIS           QTY
     C                     ADD  1         RRN1
     C                     WRITESFREC1
E1   C                     ENDDO
     C*--------------------
     C                     Z-ADDRRN1      ENDRRN  40
     C                     Z-ADD1         RRN
     C                     MOVE '#DSP2   '@STEP
     C*
     C                     ENDSR
      *===============================================================
      *  画面２　表示
      *===============================================================
     C           #DSP2     BEGSR
     C*
     C                     WRITEDSP02
     C           ENDRRN    IFNE 0
     C                     SETON                     71
     C                     ENDIF
     C                     SETON                     72
     C                     EXFMTSFCTL
     C                     SETOF                     717299
     C                     MOVE *BLANK    D2MSG
     C                     Z-ADD$$RRN     TOPRRN  40
     C*
     C                     MOVE '#CHK2   '@STEP
     C*  < F3 >  BACK
     C           *INKC     IFEQ *ON
     C                     MOVE *BLANK    D1KAT1
     C                     MOVE *BLANK    D1KAT2
     C                     MOVE *BLANK    D1KAT3
     C                     MOVE *BLANK    D1KAT4
     C                     Z-ADD0         D1MAIS
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C*  < F5 >  DELETE OK
     C           *INKE     IFEQ *ON
     C                     MOVE '#CHK2U  '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  画面２　チェック
      *===============================================================
     C           #CHK2     BEGSR
     C*
     C                     Z-ADD0         @SEL    40
     C                     Z-ADD0         ERRRRN  40
     C                     Z-ADD0         CHGRRN  40
     C*--------------------
S1   C                     DO   ENDRRN    RRN1
     C           RRN1      CHAINSFREC1               91
     C   91                LEAVE
     C                     SETOF                     21
     C*
 S2  C           S1DEL     IFNE *BLANK
     C           S1DEL     ANDNE'0'
     C                     MOVELMSG,5     D2MSG
     C                     SETON                     2199
     C                     Z-ADDRRN1      ERRRRN
 E2  C                     ENDIF
     C           S1DEL     IFEQ '0'                        DELETE
     C                     ADD  1         @SEL
     C                     ENDIF
     C*
     C                     UPDATSFREC1
E1   C  N99                ENDDO
     C*--------------------
     C*          @SEL      IFEQ 0
     C*                    MOVELMSG,5     D2MSG
     C*                    SETON                     99
     C*                    ENDIF
     C*
S1   C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK2U  '
     C                     MOVE '#DELETE '@STEP
X1   C                     ELSE
 S2  C           ERRRRN    IFNE 0
     C                     Z-ADDERRRRN    RRN
 X2  C                     ELSE
     C                     Z-ADDTOPRRN    RRN
 E2  C                     ENDIF
     C                     MOVE '#DSP2   '@STEP
E1   C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *   DELETE
      *===============================================================
     C           #DEL      BEGSR
     C*
     C           KEY02     KLIST
     C                     KFLD           S1KAT1
     C                     KFLD           S1KAT2
     C                     KFLD           S1KAT3
     C                     KFLD           S1KAT4
     C*--------------------
S1   C                     DO   ENDRRN    RRN1
     C           RRN1      CHAINSFREC1               91
     C   91                LEAVE
     C*
     C           S1DEL     IFEQ '0'                        DELETE
     C           KEY02     CHAINGDIWP87              95
     C  N95                DELETGDIWP871
     C                     ENDIF
E1   C                     ENDDO
     C*--------------------
     C                     MOVE '#SFSET  '@STEP
     C*
     C                     ENDSR
