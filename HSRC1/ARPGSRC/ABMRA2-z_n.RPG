     FABMWP12 IF  E           K        DISK
     FABMWPA0 O   E                    DISK                      A
      *
     I            DS
     I                                        1   80W@DATE
     I                                        1   40W@DAYY
     I                                        5   60W@DAMM
     I                                        7   80W@DADD
      *
     I            DS
     I                                        1  20 W1MHN
     I                                        1   5 W1MHN1
     I                                        6  10 W1MHN2
     I                                       11  15 W1MHN3
     I                                       16  20 W1MHN4
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P@DTYM  60
     C                     PARM           P@SHN1  5
     C                     PARM           P@SHN2  5
     C                     PARM           P@SHN3  2
      *
     C                     TIME           WTIME
      *
     C           KEY11     KLIST
     C                     KFLD           K@DTYM  60
     C                     KFLD           K@SHN1  5
     C                     KFLD           K@SHN2  5
     C                     KFLD           K@SHN3  2
     C                     Z-ADDP@DTYM    K@DTYM
     C                     MOVELP@SHN1    K@SHN1
     C                     MOVELP@SHN2    K@SHN2
     C                     MOVELP@SHN3    K@SHN3
     C           KEY11     SETLLABMWP121
     C           KEY11     READEABMWP121                 87
     C           *IN87     DOWEQ'0'
     C           W1TOKU    IFNE 0
     C                     EXSR #SB001
     C                     ENDIF
     C           KEY11     READEABMWP121                 87
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------*
      *                                                  *
      *--------------------------------------------------*
     CSR         #SB001    BEGSR
      *
     C                     Z-ADD0         W3USM  110
     C                     ADD  W1USM1    W3USM
     C***                  ADD  W1USM2    W3USM
     C***                  ADD  W1USM3    W3USM
     C***                  DIV  3         W3USM
     C           W3USM     IFEQ 0
     C                     Z-ADD0         RITU    73
     C                     ELSE
     C           W1FSMN    DIV  W3USM     RITU    73
     C                     ENDIF
     C           W1FSMN    IFNE 0
     C           W3USM     ORNE 0
     C           RITU      IFGE 1.25
     C           RITU      ORLE 0.75
     C                     EXSR #SB005
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB001    ENDSR
      *--------------------------------------------------*
      *                                                  *
      *--------------------------------------------------*
     CSR         #SB005    BEGSR
      *
