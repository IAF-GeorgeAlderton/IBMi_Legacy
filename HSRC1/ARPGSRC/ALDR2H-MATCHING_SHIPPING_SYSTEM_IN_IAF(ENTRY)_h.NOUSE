     C           @SCRN4    BEGSR
      *
     C                     EXFMTDSP04
     C*
   B1C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR @CHK4
     C           *IN30     IFEQ *ON
     C                     EXFMTDSP98
