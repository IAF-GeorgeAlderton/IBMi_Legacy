      *
     C                     ENDSR
      *--------------------------------------------------------
     C           @CHK4     BEGSR
      *--------------------------------------------------------
     C                     SETOF                     30
     C                     MOVE *BLANK    MSG
     C* EDIT PART NUMBER
     C                     Z-ADD2         K       20
     C                     Z-ADD0         L       20
     C                     MOVEABARHON    HON
     C                     MOVEA*BLANK    HNO
B03  C           2         DO   19        K
B04  C           HON,K     IFNE ' '
     C           HON,K     ANDNE'-'
     C                     ADD  1         L
     C                     MOVE HON,K     HNO,L
E04  C                     END
E03  C                     END
     C*
     C* GET CUTOMER CODE FROM DELIVERY CODE
     C*
     C                     MOVE *BLANK    PTOKU
     C                     MOVE *BLANK    PNONY
     C                     MOVE *BLANK    PNKOJ
     C                     MOVE *BLANK    PMHIN
     C                     MOVE *BLANK    PSHIN
     C                     MOVE *BLANK    PFLG
     C*
     C           WELIVL    SETLLGADPP111
     C           #READ1    TAG
     C           WELIVL    READEGADPP111                 92
B03  C           *IN92     IFEQ '0'
B04  C           B5SKJY    IFEQ 'D'
     C                     GOTO #READ1
E04  C                     END
     C*
     C                     MOVE B5TOKU    PTOKU
     C                     MOVE B5NONY    PNONY
     C                     MOVE B5NKOJ    PNKOJ
     C                     MOVE DOCK      PNUKE
     C                     MOVEAHNO       PMHIN
E03  C                     END
     C*
     C* EXCHANGE USER PART # TO IAF PART
     C                     CALL 'BBHR50'  P1
     C                     MOVE PSHIN     WKPNO
     C*
     C* GET ABSOLUTE NUMBER
     C                     SETOF                     89
     C           KEY1      SETLLFCEPL011
     C           #READ2    TAG
     C           KEY1      READEFCEPL011                 93
B03  C           *IN93     IFEQ '0'
B04  C           A2GSKD    IFNE 'D'
     C*
     C* CHECK ABSOLUTE #(HONDA LABEL & AIAG)
     C                     SETON                     89
B05  C           A2ZETI    IFEQ IDCD
     C                     SETON                     26
     C*
     C                     ELSE
     C                     SETON                     30
B06  C           MSG       IFEQ *BLANK
     C                     MOVE ERR,4     MSG
     C                     MOVE '04'      A5ERID
     C                     END
     C                     END
     C*
     C                     ELSE
     C                     GOTO #READ2
     C                     END
E03  C                     END
     C*
     C           *IN89     IFEQ '0'
     C                     SETON                     30
     C           MSG       IFEQ *BLANK
     C                     MOVE ERR,4     MSG
      *
     C                     MOVE '04'      A5ERID
     C*
     C                     END
     C                     END
     C*
     C           *IN30     IFEQ *ON
     C                     MOVE '04'      A5ERPS
     C                     Z-ADD*DATE     A5KSDT
     C                     TIME           A5KSTM
     C                     MOVELWORKER    A5OPER
     C                     MOVELWWBRCD    A5SERL
     C                     WRITEALDPP501
     C                     MOVE *BLANK    BARHON
