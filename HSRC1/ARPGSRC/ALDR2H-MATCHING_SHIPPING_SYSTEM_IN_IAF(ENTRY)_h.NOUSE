     C**************************************************************************
     C           @CHK32    BEGSR
      *
     C* APICS,KOTEI KANBAN(15 DIGITS) ERROR
     C           NODGT     IFEQ *BLANK                     APICS,KOTEI
     C*                    SETON                     3039
     C*          MSG       IFEQ *BLANK
     C*                    MOVE ERR,1     MSG
     C*                    MOVE '01'      A5ERID
     C*****                END
     C                     END
     C* KANBAN KUBUN OK?
   B1C           *IN30     IFEQ '0'
   B2C           BARKBN    IFEQ 'I'
     C* ERROR
     C                     ELSE
     C                     SETON                     3039
   B3C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
     C                     MOVE '01'      A5ERID
   E3C                     END
   E2C                     END
   E1C                     END
     C* ZETAI NO CHECK
   B1C           *IN30     IFEQ '0'
   B2C           A2ZETI    IFEQ IDNO7
     C*
     C                     ELSE
     C                     SETON                     3039
   B3C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
     C                     MOVE '01'      A5ERID
   E3C                     END
   E2C                     END
   E1C                     END
      * CHECK DIGIT
     C                     MOVELIIAF      PMAREA    P
