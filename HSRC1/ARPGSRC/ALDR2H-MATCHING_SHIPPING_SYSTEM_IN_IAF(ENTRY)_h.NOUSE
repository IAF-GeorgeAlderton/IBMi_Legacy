     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C  N30                MOVELERR,1     MSG
     C                     MOVE '01'      A5ERID
     C                     SETON                     3039
     C                     ELSE
