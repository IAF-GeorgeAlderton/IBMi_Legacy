     C* EDIT PART NUMBER
      * DENSO
     C           DELIVL    IFEQ '3032'
     C                     Z-ADD2         K       20
     C                     Z-ADD0         L       20
     C                     MOVEABARDEN    DEN
     C                     MOVEA*BLANK    DNO
B03  C           2         DO   14        K
B04  C           DEN,K     IFNE ' '
     C           DEN,K     ANDNE'-'
     C                     ADD  1         L
     C                     MOVE DEN,K     DNO,L
E04  C                     END
E03  C                     END
     C*
     C                     MOVEADNO       @@DMHN 20 P
     C           @@DMHN    IFNE @@MHIN
     C                     SETON                     30
     C                     MOVE ERR,4     MSG
     C                     MOVE '04'      A5ERID
     C                     MOVE '04'      A5ERPS
     C                     Z-ADD*DATE     A5KSDT
     C                     TIME           A5KSTM
     C                     MOVELWORKER    A5OPER
     C                     MOVELWWBRCD    A5SERL
     C                     WRITEALDPP501
     C                     ENDIF
      *
     C                     ELSE
      * NALP
   B1C                     MOVEANALP      AR11
     C                     MOVE *BLANK    AR12
     C                     Z-ADD*ZERO     Y       20
     C           1         DO   10        X       20
     C           AR11,X    IFNE *BLANK
     C           AR11,X    ANDNE'-'
     C                     ADD  1         Y
     C                     MOVE AR11,X    AR12,Y
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAAR12      @10    10
     C           @10       IFNE @MHN10
     C                     MOVE *ON       *IN30
     C                     MOVE ERR,4     MSG
     C                     MOVE '04'      A5ERID
     C                     MOVE '04'      A5ERPS
     C                     Z-ADD*DATE     A5KSDT
     C                     TIME           A5KSTM
     C                     MOVELWORKER    A5OPER
     C                     MOVELBARCD0    A5SERL
     C                     WRITEALDPP501
     C                     ENDIF
     C                     ENDIF
