     C                     Z-ADDHQTY      A1SSYS           UNIT QTY
     C                     Z-ADDHQTY      A1USYS           USER UNIT QTY
     C                     MOVE DELIVL    A1NONY           DELIVERY POINY
     C                     MOVE FACTRY    A1NKOJ                    FACTORY
     C                     MOVE DOCK      A1NUKE                    RECV
     C                     MOVE *BLANK    A1TOPX           TOPIX CODE
     C                     MOVE *BLANK    A1SALE           EFU/KANBAN
     C                     MOVE *BLANK    A1UPAG           BOTTOM KANBAN ISSU#
     C                     MOVE @@SERL    A1SERL
     C                     WRITEALDPP201
     C*
     C                     EXSR #ASJ
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @WRT(A-PICS,KOTENAI KANBAN FILE)
     C**************************************************************************
     C           @WRT3     BEGSR
     C*
     C                     CLEARALDPP301
     C                     TIME           WSDT
     C                     Z-ADDWSSYYY    A3KSYY
     C                     Z-ADDWSSMMM    A3KSMM                  MONTH
     C                     Z-ADDWSSDDD    A3KSDD                  DAY
     C                     Z-ADDWSSHHH    A3KSJI                  HOUR
     C                     Z-ADDWSSNNN    A3KSPN                  MINUTE
     C                     MOVE WUSRID    A3KSNA           AS USER-ID
     C                     MOVE IAPICS    WAPICS           A-PICS KANBAN
     C                     MOVE A2BHB1    A3SHN1           INTERNAL PART
     C                     MOVE A2BHB2    A3SHN2           INTERNAL PART
     C                     MOVE A2BHB3    A3SHN3           INTERNAL PART
     C                     Z-ADDSYY       A3SYYY
     C                     Z-ADDSMM       A3SYMM
     C                     Z-ADDSDD       A3SYDD
     C                     Z-ADDWSSHHH    A3SYJI           BIN
     C                     Z-ADDWSSNNN    A3SYFN
     C* FINISHED STORAGE(PART MASTER LOCATION)
     C           WSDATE    IFGE WQDATE
     C                     MOVE A2STRK    A3TKR1           NEW
     C                     MOVE A2STRT    A3TKR2
     C                     MOVE A2STRR    A3TKR3
     C                     MOVE A2STRD    A3TKR4
     C*
     C                     ELSE
     C                     MOVE A2STRK    A3TKR1           OLD
     C                     MOVE A2STRT    A3TKR2
     C                     MOVE A2STRR    A3TKR3
     C                     MOVE A2STRD    A3TKR4
     C                     END
     C*
     C                     MOVE WORKER    A3OPER           WORKER
     C                     MOVE *BLANK    A3MHN1           USER PART
     C                     MOVE *BLANK    A3MHN2
     C                     MOVE *BLANK    A3MHN3
     C                     MOVE *BLANK    A3MHN4
     C                     Z-ADDHQTY      A3SSYS           UNIT QTY
     C                     Z-ADDHQTY      A3USYS           USER UNIT QTY
     C                     MOVE DELIVL    A3NONY           DELIVERY POINY
     C                     MOVE FACTRY    A3NKOJ                    FACTORY
     C                     MOVE DOCK      A3NUKE                    RECV
     C                     MOVE *BLANK    A3TOPX           TOPIX CODE
     C                     MOVE *BLANK    A3SALE           EFU/KANBAN
     C                     MOVE @@SERL    A3SERL
     C                     WRITEALDPP301
     C*
     C                     ENDSR
     C**************************************************************************
     C*      WRITE RECORDS IN ORDER FILE TO ASJ
     C**************************************************************************
     C           #ASJ      BEGSR
      *
     C                     CLEARGDGPP051
     C                     Z-ADD*YEAR     IAKOYY
     C                     Z-ADD*MONTH    IAKOMM
     C                     Z-ADD*DAY      IAKODD
     C                     MOVELWORKER    IAKOME
     C                     Z-ADDWSSHHH    IAKOHH                  HOUR
     C                     Z-ADDWSSNNN    IAKOSS                  MINUTE
     C                     MOVE A1ORDR    IAODER
     C                     MOVE A1ZETI    IAZETI
     C                     MOVE A1SEHI    IASEIH
     C                     MOVE A1LOTN    IARENB
     C                     MOVE A1SHN1    IAHIN1
     C                     MOVE A1SHN2    IAHIN2
     C                     MOVE A1SHN3    IAHIN3
     C                     Z-ADDA1SSYS    IASYOS
     C                     ADD  1         IAMAIS
     C                     Z-ADD*YEAR     IAHAYY
     C                     Z-ADD*MONTH    IAHAMM
     C                     Z-ADD*DAY      IAHADD
     C                     WRITEGDGPP051
      *
     C                     ENDSR
     C**************************************************************************
     C*                    @WRT (2-D BARCODE)
     C**************************************************************************
     C           @WRTX     BEGSR
      *
     C                     CLEARAB#PP651
     C                     Z-ADD*DATE     A6KDAT
     C                     TIME           A6TIME
     C                     MOVEL#USER     A6KOME
     C                     MOVELDEST      A6DEST
     C                     MOVE K@TOKU    A6TOKU
     C                     MOVE @@NONY    A6NONY
     C                     MOVE @@NONY    WWNONY
     C                     MOVE @@NONY    DELIVL
     C                     MOVE K@NKOJ    A6NKOJ
     C                     MOVE K@NUKE    A6NUKE
     C                     MOVE K@NUKE    DOCK
     C                     MOVE K@NKOJ    FACTRY  1
     C                     MOVE A2ZETI    A6ZETI
     C                     MOVE LOTS      A6SYOS
     C                     MOVE LOTS      A6SRYO
     C                     MOVE LOTS      HQTY
     C                     MOVELSBAN      A6KANO
     C                     MOVE BXNBR     A6BOXN
     C                     MOVELORNO      A6ORNO
     C                     MOVELK11       A6SHN1
     C                     MOVELK12       A6SHN2
     C                     MOVELK13       A6SHN3
     C                     MOVE SHDT      K@NYMD
     C                     Z-ADDK@NOYY    A6NOYY
     C                     Z-ADDK@NOMM    A6NOMM
     C                     Z-ADDK@NODD    A6NODD
     C                     Z-ADD@@NBN     A6NOBN
     C                     Z-ADD*YEAR     A6DEYY
     C                     Z-ADD*MONTH    A6DEMM
     C                     Z-ADD*DAY      A6DEDD
     C                     TIME           A6DETM
     C                     MOVELK@MHN1    A6MHN1
     C                     MOVELK@MHN2    A6MHN2
     C                     MOVELK@MHN3    A6MHN3
     C                     MOVELK@MHN4    A6MHN4
     C           BARKBN    IFNE 'I'
     C                     MOVE IAPICS    WAPICS           A-PICS KANBAN
     C                     MOVELA3TEHI    A6LTNO
     C                     MOVELA3PAGE    A6ISNO
     C                     ELSE
     C                     MOVE IIAF      WIAF             IAF KANBAN
     C                     MOVE A1LOTN    A6LTNO
     C                     ENDIF
     C                     WRITEAB#PP651
      *
     C                     CLEARAB#PP701
     C                     MOVE *ALL'9'   @@14   140
     C           @@NONY    CHAINAB#NP30              97
     C                     Z-ADD*DATE     N3UDAT
     C                     TIME           N3UTIM
     C                     MOVEL#PGM      N3UPGM
     C                     MOVEL#USER     N3UUSR
     C                     MOVEL#WSID     N3UWIS
     C                     MOVE WWNONY    N3NONY
     C           *IN97     IFEQ *ON
     C                     Z-ADD1         N3NMBR
     C                     WRITEAB#NP301
     C                     ELSE
     C                     ADD  1         N3NMBR
     C           N3NMBR    IFEQ @@14
     C                     Z-ADD1         N3NMBR
     C                     ENDIF
     C                     UPDATAB#NP301
     C                     ENDIF
     C                     MOVE N3NMBR    EKSERL
     C                     MOVELWWNONY    EKSERL
     C                     MOVEL#USER     EKKOME
     C                     MOVE A6NONY    EKNONY
     C                     MOVE A6NKOJ    EKNKOJ
     C                     MOVE A6NUKE    EKNUKE
     C                     MOVE A6ZETI    EKZETI
     C                     MOVE LOTS      EKSYOS
     C                     MOVELA6ORNO    EKODRN
     C                     MOVE A6SHN1    EKSHN1
     C                     MOVE A6SHN2    EKSHN2
     C                     MOVE A6SHN3    EKSHN3
     C                     MOVE A6NOYY    EKNOYY
     C                     MOVE A6NOMM    EKNOMM
     C                     MOVE A6NODD    EKNODD
     C                     Z-ADDA6TOKU    EKTOKU
     C                     MOVELA6MHN1    EKMHN1
     C                     MOVELA6MHN2    EKMHN2
     C                     MOVELA6MHN3    EKMHN3
     C                     MOVELA6MHN4    EKMHN4
     C                     MOVE A6NOBN    EKNOBN
     C                     MOVELA2STRK    EKLOC1
     C                     MOVELA2STRT    EKLOC2
     C                     MOVELA2STRR    EKLOC3
     C                     MOVELA2STRD    EKLOC4
     C                     Z-ADD*YEAR     EKKOYY
     C                     Z-ADD*MONTH    EKKOMM
     C                     Z-ADD*DAY      EKKODD
     C                     TIME           WSDT
     C                     Z-ADDWSSHHH    EKKOHH
     C                     Z-ADDWSSNNN    EKKOMN
     C                     Z-ADD*YEAR     EKDEYY
     C                     Z-ADD*MONTH    EKDEMM
     C                     Z-ADD*DAY      EKDEDD
     C                     TIME           EKDETM
     C                     MOVE EKSYOS    EKSRYO
     C           BARKBN    IFNE 'I'
     C                     MOVE IAPICS    WAPICS           A-PICS KANBAN
     C                     MOVELA3TEHI    EKLTNO
     C                     MOVELA3PAGE    EKISNO
     C                     ELSE
     C                     MOVE IIAF      WIAF             IAF KANBAN
     C                     MOVE A1LOTN    EKLTNO
     C                     ENDIF
     C                     MOVE EKSERL    @@SERL 18
     C                     WRITEAB#PP701
      *
     C                     TIME           WSDT
     C           BARKBN    IFEQ 'I'
     C                     EXSR @WRT2                      IAF FILE
     C                     ELSE
     C                     EXSR @WRT3                      APICS FILE
     C                     END
     C*
      *
     C                     ENDSR
