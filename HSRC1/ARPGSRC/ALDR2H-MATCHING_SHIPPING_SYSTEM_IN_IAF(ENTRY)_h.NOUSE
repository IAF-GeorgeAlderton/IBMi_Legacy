     C                     ENDSR
     C**************************************************************************
     C*  APICS KANBAN
     C**************************************************************************
     C           @CHK31    BEGSR
     C* ZETAI NO CHECK
   B1C           *IN30     IFEQ '0'
   B2C           A2ZETI    IFEQ IDNO7
     C*
     C                     ELSE
     C                     SETON                     3039
   B3C           MSG       IFEQ *BLANK
     C                     MOVE ERR,1     MSG
     C                     MOVE '01'      A5ERID
   E3C                     END
   E2C                     END
   E1C                     END
      *  3-BOND CHECK
     C           *IN30     IFEQ *OFF
     C           POS       ANDNE'POS'
     C                     MOVE IAPICS    WAPICS           A-PICS KANBAN
     C           K#KEY1    CHAINAAMPL11              99
     C           *IN99     IFEQ *OFF
     C           K@SUPP    LOKUPBMN                      98
     C           *IN98     IFEQ *ON
      *
     C           K#KEY     CHAINAFAPL82              99
     C           *IN99     IFEQ *ON
     C                     MOVE ERR,7     MSG
     C                     MOVE '07'      A5ERID
     C                     SETON                     3929
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      * CHECK DIGIT
     C                     MOVELBARKAN    PMAREA    P
     C                     MOVE '014'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C  N30                MOVELERR,1     MSG
     C                     MOVE '01'      A5ERID
     C                     SETON                     3039
     C                     ELSE
     C           PMCHK     IFNE CHKD8
     C  N30                MOVELERR,1     MSG
     C                     MOVE '01'      A5ERID
     C                     SETON                     3039
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN30     IFEQ *ON
     C           *IN29     OREQ *ON
     C                     MOVE '03'      A5ERPS
     C                     Z-ADD*DATE     A5KSDT
     C                     TIME           A5KSTM
     C                     MOVELWORKER    A5OPER
     C                     MOVELWWBRCD    A5SERL
     C                     WRITEALDPP501
     C                     ENDIF
     C*
     C                     ENDSR
     C**************************************************************************
