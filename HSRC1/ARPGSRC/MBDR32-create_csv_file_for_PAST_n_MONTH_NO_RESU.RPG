JW2  I                                      141 150 M2LC15
 |    * PART
 |   I            DS
     I**JW4                                   1  12 S@SHN
JW4  I                                        1  14 S@SHN
     I                                        1   5 S@SHN1
 |   I                                        6   6 DMMY1
 |   I                                        7  11 S@SHN2
 |   I                                       12  12 DMMY2
JW2  I                                       13  14 S@SHN3
JW3  I           SDS
 |   I                                        1   8 #PGM
 |   I                                      244 253 #WSID
JW3  I                                      254 263 #USER
      *=================================================================
      *                    MAIN                                        =
      *=================================================================
     C                     EXSR #INZ
      *
     C           *IN95     DOWEQ*OFF
     C                     READ MBDWP31                  95
     C           *IN95     IFEQ *OFF
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELM1SHN1    SVSHN1  5
     C                     MOVELM1SHN2    SVSHN2  5
     C                     MOVELM1SHN3    SVSHN3  2
     C                     Z-ADD0         @LAST   80
     C                     Z-ADD99        @PAST   20
     C                     MOVEA*BLANK    NON
     C                     MOVEA*BLANK    NAM
     C                     ENDIF
      * BREAK?
     C           M1SHN1    IFNE SVSHN1
     C           M1SHN2    ORNE SVSHN2
     C           M1SHN3    ORNE SVSHN3
     C                     EXSR #BREAK
     C                     ENDIF
      * DETAIL
     C                     MOVELM1LOC     SVLOC   9
     C           M1PAST    IFLT @PAST
     C                     Z-ADDM1PAST    @PAST
     C                     ENDIF
     C           M1LAST    IFGT @LAST
     C                     Z-ADDM1LAST    @LAST
     C                     ENDIF
      * STORE DELIV#
     C           M1NONY    CHAINFGBPL01              99
     C           *IN99     IFEQ *ON
     C                     CLEARB2SMEI
     C                     ENDIF
     C           1         DO   10        IX
     C           NON,IX    IFEQ *BLANK
     C                     MOVELM1NONY    NON,IX
     C                     MOVELB2SMEI    NAM,IX
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDDO
      * LAST BREAK?
     C           FIRST     IFEQ 'N'
     C                     EXSR #BREAK
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C*======================*
     C* BREAK                *
     C*======================*
     C           #BREAK    BEGSR
      * GET PRODUCTION INFO.
     C           K@FCEP    CHAINFCEPL01              99
     C           *IN99     IFEQ *ON
     C                     GOTO RESET
     C                     ENDIF
      * SERVICE PART
     C           K@FCEP    CHAINFCEPL30              98
     C           *IN98     IFEQ *ON
     C                     CLEARF3STRK
     C                     CLEARF3STRT
     C                     CLEARF3STRR
     C                     CLEARF3STRD
     C                     ENDIF
      * SET HIPHEN
     C                     MOVELSVSHN1    MXSHN1
     C                     MOVELSVSHN2    MXSHN2
     C                     MOVELSVSHN3    MXSHN3
      * OUTPUT HEADER
     C           HEAD      IFEQ 'Y'
     C                     MOVE 'N'       HEAD
     C                     CLEARMBDWP321
     C                     MOVEL@HEAD     M2SHIN
     C                     WRITEMBDWP321
     C                     ENDIF
      * GET SERVICE FLAG (0323 10YEARS SHIP)
     C                     EXSR #SRVC
      * UPDATE MBDWP32------------------------------------
     C                     MOVELXSHN      K60    60 P
     C           K60       CHAINMBDWP32              97
     C           *IN97     IFEQ *OFF
     C                     Z-ADD@LAST     M2LAST
     C                     Z-ADD@PAST     M2PAST
     C                     MOVEANON       M2NON
     C                     MOVEANAM       M2NAM
     C                     UPDATMBDWP321
      *
     C                     ELSE
     C                     CLEARMBDWP321
     C                     MOVELXSHN      M2SHIN    P
     C                     MOVELSVLOC     M2LOC
     C                     Z-ADDA2SSYS    M2QPC
     C                     Z-ADDA2TAHZ    M2TAHZ
     C                     Z-ADD@LAST     M2LAST
     C                     Z-ADD@PAST     M2PAST
     C                     Z-ADDA2GEKN    M2GEKN
     C                     MOVELSLOC      M2SLOC
     C                     MOVE @SRV      M2SRVC
JW2   * LOCATION
 |   C                     MOVEA*BLANK    M2L
 |   C                     MOVELM2SHIN    S@SHN
 |   C                     MOVELS@SHN1    K@SHN1
 |   C                     MOVELS@SHN2    K@SHN2
 |   C                     MOVELS@SHN3    K@SHN3
 |   C           K@AAMP    CHAINAAMPL11              91
 |   C**N91      CKSKJY    IFEQ 'D'
 |   C**         CKSKHZ    ANDLE*DATE
 |   C**                   SETON                     91
 |   C**                   ENDIF
 |   C           *IN91     IFEQ *OFF
 |   C           1         DO   15        IY      20
 |   C                     MOVE *BLANK    @LOC1
 |   C           KHZ,IY    IFEQ 0
 |   C                     MOVE *BLANK    M2L,IY
 |   C                     ELSE
 |   C                     MOVELKHZ,IY    $CHKDT  80
 |   C                     MOVELKQT,IY    @LOC1            ě�鰖濰�ĝ
 |   C           *DATE     IFGE $CHKDT
 |   C                     MOVELKNB,IY    @LOC1            ��鰖濰�ĝ
 |   C                     ENDIF
 |   C                     MOVEL@LOC11    @LOC21
 |   C                     MOVEL@LOC12    @LOC22
 |   C                     MOVEL@LOC13    @LOC23
 |   C                     MOVEL@LOC14    @LOC24
 |   C                     MOVEL@LOC2     M2L,IY
 |   C                     ENDIF
 |   C                     ENDDO
JW2  C                     ENDIF
      *
     C                     MOVEANON       M2NON
     C                     MOVEANAM       M2NAM
     C                     WRITEMBDWP321
     C                     ENDIF
      * RESET ----------------------------------------
     C           RESET     TAG
     C                     MOVELM1SHN1    SVSHN1
     C                     MOVELM1SHN2    SVSHN2
     C                     MOVELM1SHN3    SVSHN3
     C                     Z-ADD0         @LAST
     C                     Z-ADD99        @PAST
     C                     MOVEA*BLANK    NON
     C                     MOVEA*BLANK    NAM
      *
     C           EBREAK    ENDSR
     C*=======================================
     C* GET SERVICE FLAG (0323 10YEARS SHIP)
     C*=======================================
     C           #SRVC     BEGSR
      *
     C                     MOVE 'N'       @SRV    1
     C                     MOVE *OFF      *IN96
     C           K@MBDP    SETLLMBDPL14
     C           *IN96     DOWEQ*OFF
     C           K@MBDP    READEMBDPL14                  96
     C           *IN96     IFEQ *OFF
     C           F4TNEN    IFGE @10YRS
     C                     MOVE 'Y'       @SRV
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C*======================*
     C* INITIALIZE           *
     C*======================*
     C           #INZ      BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           XMON    20
     C                     PARM           XUSR    2
      *
     C           K@FCEP    KLIST
     C                     KFLD           SVSHN1
     C                     KFLD           SVSHN2
     C                     KFLD           SVSHN3
      *
JW2  C           K@AAMP    KLIST
JW2  C                     KFLD           K@SHN1  5
JW2  C                     KFLD           K@SHN2  5
JW2  C                     KFLD           K@SHN3  2
      *
     C           K@MBDP    KLIST
     C                     KFLD           SVSHN1
     C                     KFLD           SVSHN2
     C                     KFLD           SVSHN3
     C                     KFLD           XNONY
      *
     C                     MOVE 'Y'       FIRST   1
     C                     MOVE 'Y'       HEAD    1
     C                     MOVE '-'       H1A     1
     C                     MOVE '-'       H1B     1
     C                     MOVE '-'       H2A     1
     C                     MOVE '-'       H2B     1
     C                     MOVE '-'       H2C     1
     C                     MOVE '-'       H3A     1
     C                     MOVE '-'       H3B     1
     C                     MOVE '-'       H3C     1
     C                     MOVE '-'       HI1
     C                     MOVE '-'       HI2
     C                     MOVE '-'       HI3
     C                     Z-ADD0323      XNONY   40
     C                     Z-ADD*DATE     @TODAY
     C           @TDYYY    SUB  10        @10YRS  40
JW3  C                     MOVEL#USER     XUSR
      *
      * SET TITLE
     C                     Z-ADDXMON      IX      20
     C                     MOVELTLS1,1    @HEAD
     C                     MOVELIX        @HEAD2
     C                     MOVEL@TODAY    @HEAD3
     C                     MOVEL' :MBDCP3'@HEAD4
      *
     C           EINZ      ENDSR
      *==========================================================
**  TLS1
 ** PAST 00 MONTH NO RESULT LIST **  AS OF YYYYMMDD
