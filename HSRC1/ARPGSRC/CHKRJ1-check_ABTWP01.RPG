     H            Y.
     F*=========================================================================
     F*  PROGRAM    : CHKRJ1                                                   *
     F*  FUNCTION   : CHECK ABTWP32                                            *
     F*=========================================================================
     FABTWP01 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *
     I* SYSTEM TIME
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *====================================================
     C                     EXSR #INIT
      *
     C           *LOVAL    SETLLABTWP01
     C                     DO   *HIVAL
     C                     READ ABTWP01                  98
     C   98                LEAVE
      *
     C                     MOVELW1LZET    $ZETI
     C                     CALL 'UEXR35B'
     C                     PARM           $ZETI   4
     C                     PARM           $RTN    1
      *
     C           $RTN      IFEQ 'Y'
     C                     EXSR #PRINT
     C                     ENDIF
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
      *
     C                     EXCPT@HDR
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                                    6 'CHKRJ1'
     O                                   40 '** ABTWP32 PT PART C'
     O                                   60 'HECK LIST **        '
     O                                   99 'DATE'
     O                         TODAY    102 '    .  .  '
     O                         NOW      112 '  :  :  '
     O                                  115 'P.'
     O                         PAGE  Z  119
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   10 'ZETI'
     O                                   16 'PART1'
     O                                   22 'PART2'
     O                                   25 'P3'
     O                                   36 'SHIP_DATE'
     O                                   40 'BIN'
     O                                   40 'PART3'
     O                                   45 'ORD#'
     O                                   60 'SHP_DATE'
     O        E 1              @DTL
     O                         SEQ#  Z +001
     O                         W1LZET  +001
     O                         W1LPR1  +001
     O                         W1LPR2  +001
     O                         W1LPR3  +001
     O                         W1ODAT  +001 '    /  /  '
     O                         W1CNT   +001
     O                         W1TOKU  +001
     O                         W1NONY  +001
     O                         W1NKOJ  +001
     O                         W1NUKE  +001
     O                         W1NODT  +001 '    /  /  '
     O                         W1NOBN  +001
     O                         W1ODRN  +001
     O                         W1MHN1  +001
     O                         W1MHN2  +001
     O                         W1MHN3  +001
