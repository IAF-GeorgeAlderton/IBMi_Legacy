     H            Y/
     F***************************************************
     F*  SERVICE PART LIST DATA SELECT                  *
     F*                                                 *
     F*                                                 *
     F* TCHK1 05/07/09 CREATE                           *
     F***************************************************
     FFCEPL30 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FFCEWP30 O   E                    DISK
      *------------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           *LOVAL    SETLLFCEPL30
     C*
     C                     DO   *HIVAL
     C*
     C                     READ FCEPL30                  99
     C   99                LEAVE
     C           F3GSKD    IFNE *BLANK
     C                     ITER
     C                     END
     C*
     C           K#FCEP    KLIST
     C                     KFLD           F3BHB1
     C                     KFLD           F3BHB2
     C                     KFLD           F3BHB3
     C           K#FCEP    CHAINFCEPL01              90
     C           *IN90     IFEQ *OFF
     C           A2GSKD    ANDNE*BLANK
     C                     MOVE *ALL'*'   F3PTRK
     C                     MOVE *ALL'*'   F3PTRT
     C                     MOVE *ALL'*'   F3PTRR
     C                     MOVE *ALL'*'   F3PTRD
     C                     ENDIF
     C*
     C                     WRITEFCEWP301
     C*
     C                     ENDDO
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
