     H            Y/
     F***************************************************
     F*  SCANNED KANBAN INQUIRY (TO ASJ)                *
     F*                                                 *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FGDAPW20 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                        RRN2  KSFILE SFL02
     F                                        RRN3  KSFILE SFL03
     F                                        RRN4  KSFILE SFL04
     F                                              KINFDS @INFDS
     FGDGPL2W IF  E           K        DISK
     FGDAPL05 IF  E           K        DISK
     FGDIWP01 IF  E           K        DISK
      *------------------------------------------------------------
     E                    CMD     1   2 78
     E                    AR1         5  1
     E                    AR2         6  1
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   60W@YM
     I                                        1   40W@YY
     I                                        5   60W@MM
     I            DS
     I                                        1   80K@YMD
     I                                        1   60K@YM
     I                                        1   40K@YY
     I                                        5   60K@MM
     I            DS
     I                                        1   80IAYMD
     I                                        1   60IAYM
     I                                        1   40IAKOYY
     I                                        5   60IAKOMM
     I                                        7   80IAKODD
     I            DS
     I                                        1   80IGYMD
     I                                        1   60IGYM
     I                                        1   40IGKOYY
     I                                        5   60IGKOMM
     I                                        7   80IGKODD
     I            DS
     I                                        1   8 S@KATA
     I                                        1   2 S@DIE1
     I                                        3   6 S@DIE2
     I                                        7   7 S@DIE3
     I                                        8   8 S@DIE4
     I            DS
     I                                        1   80IVHADT
     I                                        1   60IVYM
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C           W@ID      CASEQ'03'      #SCRN3
     C           W@ID      CASEQ'04'      #SCRN4
     C           W@ID      CASEQ'05'      #SCRN5
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#KY1     KLIST
     C                     KFLD           K@SHN1  5
     C                     KFLD           K@SHN2  5
     C                     KFLD           K@SHN3  2
     C           K#KY11    KLIST
     C                     KFLD           K@SHN1  5
     C                     KFLD           K@SHN2  5
     C                     KFLD           K@SHN3  2
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C           K#KY21    KLIST
     C                     KFLD           K@KATA  8
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C           K#KY2     KLIST
     C                     KFLD           K@KATA
     C           K#KY31    KLIST
     C                     KFLD           K@ZAIS 15
     C                     KFLD           K@ZAIK  52
     C                     KFLD           K@YMD   80
     C           K#KY3     KLIST
     C                     KFLD           K@ZAIS 15
     C                     KFLD           K@ZAIK  52
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     RRN2    40
     C                     Z-ADD*ZERO     RRN3    40
     C                     Z-ADD*ZERO     RRN4    40
     C                     Z-ADD*ZERO     @@RRN   40
     C                     MOVEL'01'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     SELEC
      * PART
     C           D@OPTN    WHEQ '1'
     C                     EXSR #SET1
     C                     MOVEL'02'      W@ID
      * DIE
     C           D@OPTN    WHEQ '2'
     C                     EXSR #SET2
     C                     MOVEL'03'      W@ID
      * MATERIAL
     C           D@OPTN    WHEQ '3'
     C                     EXSR #SET3
     C                     MOVEL'04'      W@ID
     C                     ENDSL
      *
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C           D@TO      IFEQ *ZERO
     C                     Z-ADDD@FRM     D@TO
     C                     ENDIF
      *
     C           D@TO      IFEQ *ZERO
     C           D@FRM     ANDEQ*ZERO
     C                     SETON                     6199
     C                     ELSE
     C           D@TO      IFLT D@FRM
     C                     SETON                     6199
     C                     ENDIF
     C                     ENDIF
      *
     C           D@OPTN    IFLT '1'
     C           D@OPTN    ORGT '3'
     C                     SETON                     6299
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      *   PART INFORMATION
      *------------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1
      *
     C           *LOVAL    SETLLGDGPL2W
     C           *IN80     DOUEQ*ON
     C                     READ GDGPL2W                  80
     C           *IN80     IFEQ *OFF
     C           IASKJY    ANDEQ*BLANK
     C                     MOVE IAHIN1    K@SHN1
     C                     MOVE IAHIN2    K@SHN2
     C                     MOVE IAHIN3    K@SHN3
     C                     Z-ADDD@FRM     K@YMD
     C                     CLEARSFL01
     C           K#KY11    SETLLGDGPL2W
     C           *IN81     DOUEQ*ON
     C           K#KY1     READEGDGPL2W                  81
     C           *IN81     IFEQ *OFF
     C           IAYMD     IFGT D@TO
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  IAMAIS    S@KQTY
     C                     ENDIF
     C                     ENDDO
      *
     C           S@KQTY    IFGT *ZERO
     C                     ADD  1         RRN1
     C                     MOVE K@SHN1    S@PRT1
     C                     MOVE K@SHN2    S@PRT2
     C                     MOVE K@SHN3    S@PRT3
     C                     WRITESFL01
     C                     ENDIF
      *
     C           K#KY1     SETGTGDGPL2W
     C                     ENDIF
     C                     ENDDO
      *
     C           RRN1      IFEQ *ZERO
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     Z-ADD1         #RCNO1
      *
     C                     ENDSR
      *------------------------------------------------------
      *  2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
     C                     Z-ADD@@REC     #RCNO1
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      W@ID
     C                     OTHER
     C                     EXSR #CHK2
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK 2ND SCREEN
      *------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     MOVE W@ID      XXID    2
     C                     Z-ADD*ZERO     W@RRN   40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         W@RRN
     C           W@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           S@SLCT    IFNE *BLANK
     C                     MOVE *BLANK    S@SLCT
     C                     UPDATSFL01
     C                     MOVE S@PRT1    K@SHN1
     C                     MOVE S@PRT2    K@SHN2
     C                     MOVE S@PRT3    K@SHN3
     C           S@PRT1    CAT  '-':0     D@NAME    P
     C           D@NAME    CAT  S@PRT2:0  D@NAME    P
     C           S@PRT3    IFNE *BLANK
     C           D@NAME    CAT  '-':0     D@NAME    P
     C           D@NAME    CAT  S@PRT3:0  D@NAME    P
     C                     ENDIF
      *
     C                     EXSR #SET41
     C                     MOVE '05'      W@ID
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR DETAIL SCREEN
      *------------------------------------------------------
     C           #SET41    BEGSR
      *
     C                     MOVE *ON       *IN54
     C                     WRITECTL04
     C                     MOVE *OFF      *IN54
     C                     Z-ADD*ZERO     RRN4
     C                     Z-ADD*ZERO     WYMD    80
     C                     CLEARSFL04
      *
     C           K#KY11    SETLLGDGPL2W
     C           *IN81     DOUEQ*ON
     C           K#KY1     READEGDGPL2W                  81
     C           *IN81     IFEQ *OFF
     C           IAYMD     IFGT D@TO
     C                     LEAVE
     C                     ENDIF
      *
     C           WYMD      IFNE *ZERO
     C           WYMD      ANDNEIAYMD
     C                     ADD  1         RRN4
     C                     Z-ADDWYMD      S@DAT
     C                     WRITESFL04
     C                     CLEARSFL04
     C                     ENDIF
      *
     C                     ADD  IAMAIS    S@QTY
     C                     Z-ADDIAYMD     WYMD
     C                     ENDIF
     C                     ENDDO
      *
     C           S@QTY     IFNE *ZERO
     C                     ADD  1         RRN4
     C                     Z-ADDWYMD      S@DAT
     C                     WRITESFL04
     C                     CLEARSFL04
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   DETAIL SCREEN
      *------------------------------------------------------
     C           #SCRN5    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN53
     C                     EXFMTCTL04
     C                     MOVE *OFF      *IN53
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVELXXID      W@ID
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  DIE
      *------------------------------------------------------
     C           #SET2     BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL02
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN2
      *
     C           *LOVAL    SETLLGDIWP01
     C           *IN80     DOUEQ*ON
     C                     READ GDIWP01                  80
     C           *IN80     IFEQ *OFF
     C                     MOVE IGKATA    K@KATA
     C                     Z-ADDD@FRM     K@YMD
     C                     CLEARSFL02
     C           K#KY21    SETLLGDIWP01
     C           *IN81     DOUEQ*ON
     C           K#KY2     READEGDIWP01                  81
     C           *IN81     IFEQ *OFF
     C           IGYMD     IFGT D@TO
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  IGMAIS    S@KQTY
     C                     ENDIF
     C                     ENDDO
      *
     C           S@KQTY    IFGT *ZERO
     C                     ADD  1         RRN2
     C                     MOVE K@KATA    S@KATA
     C                     WRITESFL02
     C                     ENDIF
      *
     C           K#KY2     SETGTGDIWP01
     C                     ENDIF
     C                     ENDDO
      *
     C           RRN2      IFEQ *ZERO
     C                     CLEARSFL02
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C                     ENDIF
      *
     C                     Z-ADD1         #RCNO2
      *
     C                     ENDSR
      *------------------------------------------------------
      *  3RD SCREEN
      *------------------------------------------------------
     C           #SCRN3    BEGSR
      *
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL02
     C                     MOVE *OFF      *IN51
     C                     Z-ADD@@REC     #RCNO2
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      W@ID
     C                     OTHER
     C                     EXSR #CHK3
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK 2ND SCREEN
      *------------------------------------------------------
     C           #CHK3     BEGSR
      *
     C                     MOVE W@ID      XXID    2
     C                     Z-ADD*ZERO     W@RRN   40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         W@RRN
     C           W@RRN     CHAINSFL02                90
     C           *IN90     IFEQ *OFF
     C           S@SLCT    IFNE *BLANK
     C                     MOVE *BLANK    S@SLCT
     C                     UPDATSFL02
     C                     MOVE S@KATA    K@KATA
     C                     MOVELK@KATA    D@NAME    P
      *
     C                     EXSR #SET42
     C                     MOVE '05'      W@ID
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR DETAIL SCREEN
      *------------------------------------------------------
     C           #SET42    BEGSR
      *
     C                     MOVE *ON       *IN54
     C                     WRITECTL04
     C                     MOVE *OFF      *IN54
     C                     Z-ADD*ZERO     RRN4
     C                     Z-ADD*ZERO     WYMD    80
     C                     CLEARSFL04
      *
     C           K#KY21    SETLLGDIWP01
     C           *IN81     DOUEQ*ON
     C           K#KY2     READEGDIWP01                  81
     C           *IN81     IFEQ *OFF
     C           IGYMD     IFGT D@TO
     C                     LEAVE
     C                     ENDIF
      *
     C           WYMD      IFNE *ZERO
     C           WYMD      ANDNEIGYMD
     C                     ADD  1         RRN4
     C                     Z-ADDWYMD      S@DAT
     C                     WRITESFL04
     C                     CLEARSFL04
     C                     ENDIF
      *
     C                     ADD  IGMAIS    S@QTY
     C                     Z-ADDIGYMD     WYMD
     C                     ENDIF
     C                     ENDDO
      *
     C           S@QTY     IFNE *ZERO
     C                     ADD  1         RRN4
     C                     Z-ADDWYMD      S@DAT
     C                     WRITESFL04
     C                     CLEARSFL04
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   MATERIAL
      *------------------------------------------------------
     C           #SET3     BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL03
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN3
      *
     C           *LOVAL    SETLLGDAPL05
     C           *IN80     DOUEQ*ON
     C                     READ GDAPL05                  80
     C           *IN80     IFEQ *OFF
     C                     MOVE IVZAIS    K@ZAIS
     C                     Z-ADDIVZAIK    K@ZAIK
     C                     Z-ADDD@FRM     K@YMD
     C                     CLEARSFL03
     C           K#KY31    SETLLGDAPL05
     C           *IN81     DOUEQ*ON
     C           K#KY3     READEGDAPL05                  81
     C           *IN81     IFEQ *OFF
     C           IVHADT    IFGT D@TO
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  IVMAIS    S@KQTY
     C                     ENDIF
     C                     ENDDO
      *
     C           S@KQTY    IFGT *ZERO
     C                     ADD  1         RRN3
     C                     MOVE K@ZAIS    S@ZAIS
     C                     Z-ADDK@ZAIK    S@ZAIK
     C                     WRITESFL03
     C                     ENDIF
      *
     C           K#KY3     SETGTGDAPL05
     C                     ENDIF
     C                     ENDDO
      *
     C           RRN3      IFEQ *ZERO
     C                     CLEARSFL03
     C                     ADD  1         RRN3
     C                     WRITESFL03
     C                     ENDIF
      *
     C                     Z-ADD1         #RCNO3
      *
     C                     ENDSR
      *------------------------------------------------------
      *  4TH SCREEN
      *------------------------------------------------------
     C           #SCRN4    BEGSR
      *
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL03
     C                     MOVE *OFF      *IN51
     C                     Z-ADD@@REC     #RCNO3
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      W@ID
     C                     OTHER
     C                     EXSR #CHK4
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK 4TH SCREEN
      *------------------------------------------------------
     C           #CHK4     BEGSR
      *
     C                     MOVE W@ID      XXID    2
     C                     Z-ADD*ZERO     W@RRN   40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         W@RRN
     C           W@RRN     CHAINSFL03                90
     C           *IN90     IFEQ *OFF
     C           S@SLCT    IFNE *BLANK
     C                     MOVE *BLANK    S@SLCT
     C                     UPDATSFL03
     C                     MOVE S@ZAIS    K@ZAIS
     C                     Z-ADDS@ZAIK    K@ZAIK
     C                     MOVE S@ZAIK    @5      5
     C                     MOVEA@5        AR1
     C                     MOVE *BLANK    AR2
     C                     Z-ADD*ZERO     Y       20
     C                     MOVE *OFF      *IN10
     C           1         DO   5         X       20
     C                     ADD  1         Y
     C           X         IFEQ 4
     C                     MOVE '.'       AR2,Y
     C                     ADD  1         Y
     C  N10                MOVE *ON       *IN10
     C                     ENDIF
     C           *IN10     IFEQ *OFF
     C           AR1,X     ANDEQ*ZERO
     C                     MOVE *BLANK    AR2,Y
     C                     ELSE
     C                     MOVE AR1,X     AR2,Y
     C                     ENDIF
     C           AR1,X     IFNE *ZERO
     C           *IN10     ANDEQ*OFF
     C                     MOVE *ON       *IN10
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAAR2,Y     @6      6
      *
     C           S@ZAIS    CAT  @6:2      D@NAME    P
      *
     C                     EXSR #SET43
     C                     MOVE '05'      W@ID
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR DETAIL SCREEN
      *------------------------------------------------------
     C           #SET43    BEGSR
      *
     C                     MOVE *ON       *IN54
     C                     WRITECTL04
     C                     MOVE *OFF      *IN54
     C                     Z-ADD*ZERO     RRN4
     C                     Z-ADD*ZERO     WYMD    80
     C                     CLEARSFL04
      *
     C           K#KY31    SETLLGDAPL05
     C           *IN81     DOUEQ*ON
     C           K#KY3     READEGDAPL05                  81
     C           *IN81     IFEQ *OFF
     C           IVHADT    IFGT D@TO
     C                     LEAVE
     C                     ENDIF
      *
     C           WYMD      IFNE *ZERO
     C           WYMD      ANDNEIVHADT
     C                     ADD  1         RRN4
     C                     Z-ADDWYMD      S@DAT
     C                     WRITESFL04
     C                     CLEARSFL04
     C                     ENDIF
      *
     C                     ADD  IVMAIS    S@QTY
     C                     Z-ADDIVHADT    WYMD
     C                     ENDIF
     C                     ENDDO
      *
     C           S@QTY     IFNE *ZERO
     C                     ADD  1         RRN4
     C                     Z-ADDWYMD      S@DAT
     C                     WRITESFL04
     C                     CLEARSFL04
     C                     ENDIF
      *
     C                     ENDSR
**  CMD
F1:END
F1:END       F12:GO BACK
