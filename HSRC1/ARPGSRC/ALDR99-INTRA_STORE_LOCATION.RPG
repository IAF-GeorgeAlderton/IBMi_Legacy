     H            Y.
     F** ALDR99 *********************************************
     F* INTRA STORE LOCATION                                *
     F*   HOTTA.                  2019.02.05                *
     F*******************************************************
     FALDPW99 CF  E                    WORKSTN
     FFCETL11 IF  E           K        DISK
     FABHTL06 IF  E           K        DISK
     FADHTL06 IF  E           K        DISK
     FAAFTL06 IF  E           K        DISK
     FAAPPL06 IF  E           K        DISK
     FAANPL06 IF  E           K        DISK
     FAKBPL06 IF  E           K        DISK
     FALDPP35 O   E                    DISK
      *
     E                    ER      1  25 60
     E                    KBN        32 20
      *
     I            DS
     I                                        1  14 D2SHN
     I                                        1   5 D2SHN1
     I                                        6   6 D2SF1
     I                                        7  11 D2SHN2
     I                                       12  12 D2SF2
     I                                       13  14 D2SHN3
      *
     I            DS
     I                                        1  20 D1BAR1
     I                                        1   4 X@ZETI
     I                                        5   5 X@LOC1
     I                                        6   7 X@LOC2
     I                                        8   9 X@LOC3
     I                                       10  10 X@LOC4
     I            DS
     I                                        1  20 D2BAR2
     I                                        1   1 BCTYPE
      *MEKI
     I                                        2   5 A@ZETI
     I                                        6   8 A@LOT#
      *PTKANBAN
     I                                        2   5 P@ZETI
     I                                        6  11 P@ORDN
     I                                       13  16 P@LOTN
     I                                        6  11 P@ORD#
     I                                       12  12 P@KCD1
     I                                       13  16 P@LOT#
      *INTER
     I                                        2   5 #2ZETI
     I                                        6   7 #2BMNA
     I                                        8   8 #2KDAI
     I                                        9  11 #2KOTI
     I                                       12  14 #2HKNO
      *AKB
     I                                        6   9 #3SIRE
     I                                       10  10 #3KCD1
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I            DS
     I                                        1   80A2TRHZ
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
      *
     I            DS
     I                                        1   80L7SKHZ
     I                                        1   40L7SKYY
     I                                        5   60L7SKMM
     I                                        7   80L7SKDD
      *
     I            DS
     I                                        1   80L7STHZ
     I                                        1   40L7STYY
     I                                        5   60L7STMM
     I                                        7   80L7STDD
      *
     I            DS
     I                                        1   80M1SKHZ
     I                                        1   40M1SKYY
     I                                        5   60M1SKMM
     I                                        7   80M1SKDD
     I            DS
     I                                        1  140WTIME
     I                                        1   20WJI
     I                                        3   40WFN
     I                                        5   60WSC
     I                                        7  140WDATE
     I                                        7  100WYY
     I                                       11  120WMM
     I                                       13  140WDD
      *
     I            DS
     I                                        1   80IEYMD
     I                                        1   40IESKOY
     I                                        5   60IESKOM
     I                                        7   80IESKOD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           POPR    6
     C                     PARM           PITANT 10
     C                     PARM           PISECT  1
      *
      *----------------------------------------------------*
      * MAINLINE                                           *
      *----------------------------------------------------*
     C                     MOVEL'01'      DSPSW   2
      *
     C           DSPSW     DOUEQ'99'
      *
     C                     SELEC
     C           DSPSW     WHEQ '01'
     C                     EXSR #SB100
     C           DSPSW     WHEQ '02'
     C                     EXSR #SB200
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *
      *----------------------------------------------------*
      * FIRST SCREEN - Display Screen for Location Entry   *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     EXFMTALDPW991
     C                     SETOF                     9931
     C                     MOVEL*BLANKS   D9ERR
      *
     C                     MOVEL*BLANK    FNCHK1  5
     C                     MOVEL*BLANK    FNCHK2  2
     C           5         SUBSTD1BAR1:1  FNCHK1
     C*
     C           FNCHK1    IFEQ 'XXXXX'
     C           2         SUBSTD1BAR1:6  FNCHK2
     C           FNCHK2    IFEQ '01'
     C                     SETON                     01
     C                     ELSE
     C                     SETON                     99
     C                     MOVELER,6      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D1BAR1
     C                     GOTO ESB100
     C                     ENDIF
     C                     ENDIF
      *
      * if any Function Key was hit other than F1, just display
      * screen 1 again.
     C                     SELEC
     C           *IN01     WHEQ '1'
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB100
     C           *IN02     WHEQ '1'
     C           *IN03     OREQ '1'
     C           *IN04     OREQ '1'
     C           *IN05     OREQ '1'
     C           *IN06     OREQ '1'
     C           *IN07     OREQ '1'
     C           *IN08     OREQ '1'
     C           *IN09     OREQ '1'
     C           *IN10     OREQ '1'
     C           *IN11     OREQ '1'
     C           *IN12     OREQ '1'
     C                     GOTO ESB100
     C                     OTHER
     C                     ENDSL
      *
     C           D1BAR1    IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D1BAR1
     C                     GOTO ESB100
     C                     ENDIF
      *
      * CHECK DIGIT - if check digit is not correct, display
      * error screen.
     C*******              MOVELD1BAR1    PMAREA
     C*******              MOVEL'010'     PMBYTE
     C*******    1         SUBSTD1BAR1:8  WKCHK   1
     C********             EXSR #SB600
     C*******    WKCHK     IFNE PMCHK
     C*******              SETON                     99
     C*******              MOVELER,2      D9ERR
     C*******              EXSR #SB290
     C*******              MOVEL*BLANK    D1BAR1
     C*******              GOTO ESB100
     C*******              ENDIF
      *
     C                     MOVEL*BLANK    W1SHN1  5
     C                     MOVEL*BLANK    W1SHN2  5
     C                     MOVEL*BLANK    W1SHN3  2
     C                     MOVEL*BLANK    W1TBN1  1
     C                     MOVEL*BLANK    W1TBN2  2
     C                     MOVEL*BLANK    W1TBN3  2
     C                     MOVEL*BLANK    W1TBN4  1
     C                     MOVEL*BLANK    D1ZETI  4
     C           4         SUBSTD1BAR1:1  D1ZETI
      *
     C                     TIME           WTIME
      *
      * get part information from PART INFORMATION M/F
      *
     C           D1ZETI    CHAINFCETL111             21
     C           *IN21     IFEQ *OFF
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ENDIF
      *
     C           *IN21     IFEQ *OFF
     C                     MOVELA2BHB1    W1SHN1
     C                     MOVELA2BHB2    W1SHN2
     C                     MOVELA2BHB3    W1SHN3
      *
     C********** A2TRHZ    IFGT WDATE
      * old location code
     C**********           MOVELA2KTRK    W1TBN1  1
     C**********           MOVELA2KTRT    W1TBN2  2
     C**********           MOVELA2KTRR    W1TBN3  2
     C**********           MOVELA2KTRD    W1TBN4  1
     C**********           ELSE
      * else new location code
     C**********           MOVELA2STRK    W1TBN1  1
     C**********           MOVELA2STRT    W1TBN2  2
     C**********           MOVELA2STRR    W1TBN3  2
     C**********           MOVELA2STRD    W1TBN4  1
     C**********           ENDIF
      *
     C                     ENDIF
      *
     C                     MOVELD1BAR1    D2BAR1
     C                     MOVEL*BLANK    D2SHN
     C                     MOVELW1SHN1    D2SHN1
     C                     MOVEL'-'       D2SF1
     C                     MOVELW1SHN2    D2SHN2
     C                     MOVEL'-'       D2SF2
     C                     MOVELW1SHN3    D2SHN3
     C                     MOVEL*BLANK    D2BAR2
     C                     Z-ADD0         D2CNT
     C                     MOVEL'02'      DSPSW
      *
     CSR         ESB100    ENDSR
      *------------------------------------------------------*
      * SECOND SCREEN - Display Screen to Input APICS KANBAN *
      *------------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C                     EXFMTALDPW992
     C                     SETOF                     9931
     C                     MOVEL*BLANKS   D9ERR
     C*
     C                     MOVEL*BLANK    FNCHK1
     C                     MOVEL*BLANK    FNCHK2
     C           5         SUBSTD2BAR2:1  FNCHK1
      *
     C           FNCHK1    IFEQ 'XXXXX'
     C           2         SUBSTD2BAR2:6  FNCHK2
      *
     C           FNCHK2    IFEQ '03'
     C                     SETON                     01
     C                     ELSE
     C                     SETON                     99
     C                     MOVELER,6      D9ERR
     C                     EXSR #SB290
     C                     GOTO ESB200
     C                     ENDIF
      *
     C                     ENDIF
      *
      *
      * if any Function Key was hit other than F1, just display
      * screen 2 again.
     C                     SELEC
     C           *IN01     WHEQ '1'
     C                     MOVEL'01'      DSPSW
     C                     MOVEL*BLANK    D1BAR1
     C                     GOTO ESB200
     C           *IN02     WHEQ '1'
     C           *IN03     OREQ '1'
     C           *IN04     OREQ '1'
     C           *IN05     OREQ '1'
     C           *IN06     OREQ '1'
     C           *IN07     OREQ '1'
     C           *IN08     OREQ '1'
     C           *IN09     OREQ '1'
     C           *IN10     OREQ '1'
     C           *IN11     OREQ '1'
     C           *IN12     OREQ '1'
     C                     GOTO ESB200
     C                     OTHER
     C                     ENDSL
      *
      * if APICS KANBAN is blank, display error and start over.
     C           D2BAR2    IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,4      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D2BAR2
     C                     GOTO ESB200
     C                     ENDIF
      *
     C           #3SIRE    IFNE '2323'
     C           #3SIRE    ANDNE'2525'
      * CHECK DIGIT - call program to get check digit and compare
      *  to make sure it's correct.
      *
      *  if kanban barcode starts with an "I" then it's a Pass Thru
      *   kanban, so it will be 16 chars instead of 14 like the apics kanban
      *
     C           1         SUBSTD2BAR2:1  BCID
     C           BCID      IFEQ 'I'
     C                     MOVELD2BAR2    PMAREA
     C                     MOVEL'016'     PMBYTE
     C           1         SUBSTD2BAR2:17 WKCHK   1
     C                     EXSR #SB600
     C                     ELSE
     C                     MOVELD2BAR2    PMAREA
     C                     MOVEL'014'     PMBYTE
     C           1         SUBSTD2BAR2:15 WKCHK   1
     C                     EXSR #SB600
     C                     END
      *
      *
      * if check digits don't match, display error, go back to screen2.
     C           WKCHK     IFNE PMCHK
     C                     SETON                     99
     C                     MOVELER,2      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D2BAR2
     C                     GOTO ESB200
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVEL*BLANK    W2SHN1  5
     C                     MOVEL*BLANK    W2SHN2  5
     C                     MOVEL*BLANK    W2SHN3  2
     C                     MOVEL*BLANK    W2ABN1  1
     C                     MOVEL*BLANK    W2ABN2  2
     C                     MOVEL*BLANK    W2ABN3  2
     C                     MOVEL*BLANK    W2ABN4  1
     C                     MOVEL*BLANK    D2ZETI  4
      *
      * get part information from PART INFORMATION M/F
      *
     C           4         SUBSTD2BAR2:2  D2ZETI
     C           D2ZETI    CHAINFCETL111             21
      *
     C           *IN21     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ENDIF
      *
      * part number found and not marked for delete.
     C           *IN21     IFEQ '0'
     C                     MOVELA2BHB1    W2SHN1
     C                     MOVELA2BHB2    W2SHN2
     C                     MOVELA2BHB3    W2SHN3
      *
     C********** A2TRHZ    IFGT WDATE
      * old location code
     C**********           MOVELA2KTRK    W2ABN1  1
     C**********           MOVELA2KTRT    W2ABN2  2
     C**********           MOVELA2KTRR    W2ABN3  2
     C**********           MOVELA2KTRD    W2ABN4  1
     C**********           ELSE
      * else new location code
     C**********           MOVELA2STRK    W2ABN1  1
     C**********           MOVELA2STRT    W2ABN2  2
     C**********           MOVELA2STRR    W2ABN3  2
     C**********           MOVELA2STRD    W2ABN4  1
     C**********           ENDIF
      *
     C                     ENDIF
      *
     C           KEYKAN    KLIST
     C                     KFLD           W2SHN1
     C                     KFLD           W2SHN2
     C                     KFLD           W2SHN3
     C                     MOVEL'0'       GETKAN  1
     C           BCTYPE    IFEQ 'I'
     C                     SELEC
     C           P@KCD1    WHEQ '0'
     C                     EXSR #AAP01
     C           P@KCD1    WHEQ '6'
     C                     EXSR #AAN01
     C           P@KCD1    WHEQ '3'
     C                     EXSR #AKB01
     C                     ENDSL
     C                     ENDIF
      *
     C           BCTYPE    IFGE '0'
     C           BCTYPE    ANDLE'9'
     C                     SELEC
     C           #2KDAI    WHEQ 'A'
     C           #2KDAI    OREQ 'Y'
     C                     EXSR #ABH01
     C           #2KDAI    WHEQ 'B'
     C                     EXSR #ADH01
     C                     ENDSL
     C                     ELSE
     C                     EXSR #AAF01
     C                     ENDIF
      *
     C           #3KCD1    IFEQ '3'
     C           #3SIRE    IFEQ '2323'
     C           #3SIRE    OREQ '2525'
     C                     EXSR #AKB02
     C                     ENDIF
     C                     ENDIF
     C*
      *
     C           GETKAN    IFEQ '0'
     C                     SETON                     99
     C                     MOVELER,10     D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D2BAR2
     C                     GOTO ESB200
     C                     ENDIF
      *
      * if this was an apics kanban,
     C           1         SUBSTD2BAR2:1  BCD     1
      *
      * check to make sure it's NOT in the last 32 kanbans scanned.
      *   if so, set error as duplicate kanban.
     C           D2BAR2    LOKUPKBN                      41
     C           *IN41     IFEQ *ON
     C                     MOVEL'NG'      WKOKNG
     C                     MOVELER,7      D9ERR
     C                     MOVE '07'      ERRCOD  2
     C                     EXSR #SB500
     C                     SETON                     99
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D2BAR2
     C                     GOTO ESB200
     C                     ENDIF
      * check to make sure it's a match.
     C           D2ZETI    IFEQ D1ZETI
     C                     MOVEL'OK'      WKOKNG  2
     C                     MOVE *BLANKS   ERRCOD
     C                     EXSR #SB500
     C                     EXSR #SB509
     C                     ADD  1         D2CNT
     C                     ELSE
     C                     MOVEL'NG'      WKOKNG
     C                     MOVE '05'      ERRCOD
     C                     EXSR #SB500
     C                     SETON                     99
     C                     MOVELER,5      D9ERR
     C                     EXSR #SB290
     C                     ENDIF
      *
     C                     MOVEL*BLANK    D2BAR2
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * ABHPP01
      *----------------------------------------------------*
     CSR         #ABH01    BEGSR
      *
     C                     SETOF                         83
     C           KEYKAN    SETLLABHTL061
     C           KEYKAN    READEABHTL061                 83
     C           *IN83     DOWEQ'0'
     C           GETKAN    ANDEQ'0'
     C           M6SKJY    IFEQ 'D'
     C           M6SKHZ    ANDLEWDATE
     C                     ELSE
     C           M6STHZ    IFGT WDATE
     C           M6JBN1    IFEQ X@LOC1
     C           M6JBN2    ANDEQX@LOC2
     C           M6JBN3    ANDEQX@LOC3
     C           M6JBN4    ANDEQX@LOC4
     C                     MOVEL'1'       GETKAN
     C                     MOVELM6JBN1    W2ABN1  1
     C                     MOVELM6JBN2    W2ABN2  2
     C                     MOVELM6JBN3    W2ABN3  2
     C                     MOVELM6JBN4    W2ABN4  1
     C                     MOVEL*BLANK    W2ORDN
     C                     MOVEL*BLANK    W2LOTN
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYKAN    READEABHTL061                 83
     C                     ENDDO
      *
     CSR         EABH01    ENDSR
      *----------------------------------------------------*
      * ADHPP01
      *----------------------------------------------------*
     CSR         #ADH01    BEGSR
      *
     C                     SETOF                         83
     C           KEYKAN    SETLLADHTL06
     C           KEYKAN    READEADHTL06                  83
     C           *IN83     DOWEQ'0'
     C           GETKAN    ANDEQ'0'
     C           J6SKJY    IFEQ 'D'
     C           J6SKHZ    ANDLEWDATE
     C                     ELSE
     C           J6STHZ    IFGT WDATE
     C           J6ATK1    IFEQ X@LOC1
     C           J6ATK2    ANDEQX@LOC2
     C           J6ATK3    ANDEQX@LOC3
     C           J6ATK4    ANDEQX@LOC4
     C                     MOVEL'1'       GETKAN
     C                     MOVELJ6ATK1    W2ABN1  1
     C                     MOVELJ6ATK2    W2ABN2  2
     C                     MOVELJ6ATK3    W2ABN3  2
     C                     MOVELJ6ATK4    W2ABN4  1
     C                     MOVEL*BLANK    W2ORDN
     C                     MOVEL*BLANK    W2LOTN
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYKAN    READEADHTL06                  83
     C                     ENDDO
      *
     CSR         EADH01    ENDSR
      *----------------------------------------------------*
      * AAFPP01
      *----------------------------------------------------*
     CSR         #AAF01    BEGSR
      *
     C                     SETOF                         83
     C           KEYKAN    SETLLAAFTL061
     C           KEYKAN    READEAAFTL061                 83
     C           *IN83     DOWEQ'0'
     C           GETKAN    ANDEQ'0'
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLEWDATE
     C                     ELSE
     C           A3STHZ    IFGT WDATE
     C           A3ATK1    IFEQ X@LOC1
     C           A3ATK2    ANDEQX@LOC2
     C           A3ATK3    ANDEQX@LOC3
     C           A3ATK4    ANDEQX@LOC4
     C                     MOVEL'1'       GETKAN
     C                     MOVELA3ATK1    W2ABN1  1
     C                     MOVELA3ATK2    W2ABN2  2
     C                     MOVELA3ATK3    W2ABN3  2
     C                     MOVELA3ATK4    W2ABN4  1
     C                     MOVEL*BLANK    W2ORDN  6
     C                     MOVEL*BLANK    W2LOTN  4
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYKAN    READEAAFTL061                 83
     C                     ENDDO
      *
     CSR         EAAF01    ENDSR
      *----------------------------------------------------*
      * AAPPP01
      *----------------------------------------------------*
     CSR         #AAP01    BEGSR
      *
     C                     SETOF                         83
     C           KEYKAN    SETLLAAPPL061
     C           KEYKAN    READEAAPPL061                 83
     C           *IN83     DOWEQ'0'
     C           GETKAN    ANDEQ'0'
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    ANDLEWDATE
     C                     ELSE
     C           L5STHZ    IFGT WDATE
     C           L5TKR1    IFEQ X@LOC1
     C           L5TKR2    ANDEQX@LOC2
     C           L5TKR3    ANDEQX@LOC3
     C           L5TKR4    ANDEQX@LOC4
     C                     MOVEL'1'       GETKAN
     C                     MOVELL5TKR1    W2ABN1  1
     C                     MOVELL5TKR2    W2ABN2  2
     C                     MOVELL5TKR3    W2ABN3  2
     C                     MOVELL5TKR4    W2ABN4  1
     C                     MOVELP@ORDN    W2ORDN  6
     C                     MOVELP@LOTN    W2LOTN  4
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYKAN    READEAAPPL061                 83
     C                     ENDDO
      *
     CSR         EAAP01    ENDSR
      *----------------------------------------------------*
      * AANPP01
      *----------------------------------------------------*
     CSR         #AAN01    BEGSR
      *
     C                     SETOF                         83
     C           KEYKAN    SETLLAANPL061
     C           KEYKAN    READEAANPL061                 83
     C           *IN83     DOWEQ'0'
     C           GETKAN    ANDEQ'0'
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    ANDLEWDATE
     C                     ELSE
     C           L7STHZ    IFGT WDATE
     C           L7TKR1    IFEQ X@LOC1
     C           L7TKR2    ANDEQX@LOC2
     C           L7TKR3    ANDEQX@LOC3
     C           L7TKR4    ANDEQX@LOC4
     C                     MOVEL'1'       GETKAN
     C                     MOVELL7TKR1    W2ABN1  1
     C                     MOVELL7TKR2    W2ABN2  2
     C                     MOVELL7TKR3    W2ABN3  2
     C                     MOVELL7TKR4    W2ABN4  1
     C                     MOVELP@ORDN    W2ORDN  6
     C                     MOVELP@LOTN    W2LOTN  4
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYKAN    READEAANPL061                 83
     C                     ENDDO
      *
     CSR         EAAN01    ENDSR
      *----------------------------------------------------*
      * AKBPP01  PT
      *----------------------------------------------------*
     CSR         #AKB01    BEGSR
      *
     C                     SETOF                         83
     C           D2ZETI    SETLLAKBPL061
     C           D2ZETI    READEAKBPL061                 83
     C           *IN83     DOWEQ'0'
     C           GETKAN    ANDEQ'0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    ANDLEWDATE
     C                     ELSE
     C           L1STHZ    IFGT WDATE
     C           L1TKR1    IFEQ X@LOC1
     C           L1TKR2    ANDEQX@LOC2
     C           L1TKR3    ANDEQX@LOC3
     C           L1TKR4    ANDEQX@LOC4
     C                     MOVEL'1'       GETKAN
     C                     MOVELL1TKR1    W2ABN1  1
     C                     MOVELL1TKR2    W2ABN2  2
     C                     MOVELL1TKR3    W2ABN3  2
     C                     MOVELL1TKR4    W2ABN4  1
     C                     MOVELP@ORDN    W2ORDN  6
     C                     MOVELP@LOTN    W2LOTN  4
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           D2ZETI    READEAKBPL061                 83
     C                     ENDDO
      *
     CSR         EAKB01    ENDSR
      *----------------------------------------------------*
      * AKBPP01  LOCAL VENDER
      *----------------------------------------------------*
     CSR         #AKB02    BEGSR
      *
     C                     SETOF                         83
     C           D2ZETI    SETLLAKBPL061
     C           D2ZETI    READEAKBPL061                 83
     C           *IN83     DOWEQ'0'
     C           GETKAN    ANDEQ'0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    ANDLEWDATE
     C                     ELSE
     C           L1STHZ    IFGT WDATE
     C                     MOVEL'1'       GETKAN
     C                     MOVEL*BLANK    W2ORDN  6
     C                     MOVEL*BLANK    W2LOTN  4
     C                     ENDIF
     C                     ENDIF
     C           D2ZETI    READEAKBPL061                 83
     C                     ENDDO
      *
     CSR         EAKB02    ENDSR
      *----------------------------------------------------*
      * ALDPP35 - Write Record to Final Store Location     *
      *----------------------------------------------------*
     C           #SB500    BEGSR
      * write to ALDPP35
     C                     TIME           WTIME
     C                     CLEARALDPP351
     C                     Z-ADDWDATE     A9KODT
     C                     TIME           A9KOTM
     C                     MOVELW#WSID    A9WSID
     C                     MOVELW#USER    A9USER
     C                     MOVELW#JBNO    A9JOBN
     C                     MOVELW#PGM     A9KOPG
     C                     MOVELPOPR      A9WOKR
     C                     Z-ADDWDATE     A9CODT
     C                     TIME           A9COTM
     C                     MOVELD1BAR1    A9LBAR
     C                     MOVELD1ZETI    A9LZET
     C                     MOVELW1SHN1    A9LHN1
     C                     MOVELW1SHN2    A9LHN2
     C                     MOVELW1SHN3    A9LHN3
     C                     MOVELW1TBN1    A9TBN1
     C                     MOVELW1TBN2    A9TBN2
     C                     MOVELW1TBN3    A9TBN3
     C                     MOVELW1TBN4    A9TBN4
     C                     MOVELD2BAR2    A9ABAR
     C                     MOVELD2ZETI    A9AZET
     C                     MOVELW2SHN1    A9AHN1
     C                     MOVELW2SHN2    A9AHN2
     C                     MOVELW2SHN3    A9AHN3
     C                     MOVELW2ABN1    A9ABN1
     C                     MOVELW2ABN2    A9ABN2
     C                     MOVELW2ABN3    A9ABN3
     C                     MOVELW2ABN4    A9ABN4
      *
      * PASS THRU kanban barcodes start with an I...
      * if barcode is a pass thru kanban, then blank out
      * apics product and page numbers.
     C           1         SUBSTD2BAR2:1  BCID    1
     C           BCTYPE    IFGE '0'
     C           BCTYPE    ANDLE'9'
     C                     MOVEL*BLANK    A9TEHA
     C                     MOVEL*BLANK    A9PAGE
     C                     ELSE
     C           3         SUBSTD2BAR2:6  A9TEHA
     C           2         SUBSTD2BAR2:9  A9PAGE
     C                     ENDIF
     C                     MOVE *BLANKS   A9PTOR
     C                     MOVE *BLANKS   A9PTLT
      *
     C                     MOVELWKOKNG    A9OKNG
     C                     MOVELERRCOD    A9ERCD
     C                     MOVELPISECT    A9SECT
     C                     MOVELW2ORDN    A9ORDN
     C                     MOVELW2LOTN    A9LOTN
     C                     WRITEALDPP351
      *
      * if there are no errors, write to shipping output files.
     C           D9ERR     IFEQ *BLANKS
      *
      * save kanban barcode with the last 32 successful scans.
     C                     EXSR SAVKBN
      *
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      * NZTPP01 - INTRA KANBAN STATUS                      *
      *----------------------------------------------------*
     C           #SB509    BEGSR
|     *
|||  C                     MOVEL*BLANK    @@BARA256
|||  C                     MOVEL*BLANK    @@BARB256
|||  C                     MOVEL*BLANK    WORK10 10
|||  C                     MOVELPOPR      WORK10
|||  C                     MOVEL*BLANK    WORK20 20
|||  C                     MOVELPITANT    WORK20
|    C                     CALL 'UEXR16'
|    C                     PARM           D2BAR2
|    C                     PARM           @@BARA
|    C                     PARM           @@BARB
|     *
|    C                     PARM           W2ABN1
|    C                     PARM           W2ABN2
|    C                     PARM           W2ABN3
|    C                     PARM           W2ABN4
|    C                     PARM           W2SHN1
|    C                     PARM           W2SHN2
|    C                     PARM           W2SHN3
|     *
|    C                     PARM           WORK10
|    C                     PARM           WORK20
|    C                     PARM           W#PGM
|    C                     PARM '1'       P9TYPE  1
|    C                     PARM ' '       P9RTN   1
      *
     C                     ENDSR
      *----------------------------------------------------*
      * Call Program to Get Check Digit                    *
      *----------------------------------------------------*
     C           #SB600    BEGSR
      *
     C                     CALL 'ALBRCC'
     C                     PARM           PMAREA100        INPUT DATA
     C                     PARM           PMBYTE  3        LENGTH
     C                     PARM           PMCHK   1        CHECKS DIGITS
     C                     PARM           PMRTCD  1        RETRN CODE
      *
     C                     ENDSR
      *
      *----------------------------------------------------*
      * ERROR SCREEN - Display Error on Screen             *
      *----------------------------------------------------*
     C           #SB290    BEGSR
      *
     C           D9ERR     IFEQ ER,5
      *
     C*  PASSWORD LOCK
     C***                  Z-ADD1         P1PGM
     C                     MOVE PISECT    P1PGM
     C                     MOVELD9ERR     P1ERR
     C                     MOVELW#PGM     P1PID
     C                     MOVELPOPR      P1KOME    P
     C                     Z-ADD*ZERO     P1DTTM
     C                     CALL 'AM#R09'
     C                     PARM           P1PGM   20
     C                     PARM           P1ERR  25
     C                     PARM           P1PID  10
     C                     PARM           P1KOME 10
     C                     PARM           P1DTTM 140
     C                     MOVEL*ON       W@ERCK  1
      *
     C                     ELSE
      *
     C                     WRITEALDPW998
     C                     EXFMTALDPW999
      *
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      * Save Kanban barcode with the last 32 scanned.      *
      *----------------------------------------------------*
     C           SAVKBN    BEGSR
      *
     C           IX        IFEQ 32
     C                     Z-ADD1         IX      20
     C                     ELSE
     C                     ADD  1         IX
     C                     ENDIF
      *
     C                     MOVELD2BAR2    KBN,IX
      *
     C                     ENDSR
      *
      *----------------------------------------------------*
**
INPUT LOCATION BARCODE.
CHECK DIGIT ERROR.
PARTS MASTER ERROR.
INPUT STORE IN KANBAN.
NONMATCH ERROR.
FNC KEY ERROR.
DUPLICATE KANBAN.
APICS STOP ALERT.
PT STOP ALERT.
NO KANBAN M/F.
