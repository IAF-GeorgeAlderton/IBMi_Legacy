     H            Y.
     F** DFAR01 *******************************************
     F* 指示かんばん工程納期遅れ照会・条件指定          *
     F*  2024.09.20   M.OKUMURA                           *
     F*****************************************************
     F*         ファイル定義                            *
     F*****************************************************
     F*==<条件指定画面>==*
     FDFAPW01 CF  E                    WORKSTN
     F*
     F*
     E*****************************************************
     E*         配列定義                                *
     E*****************************************************
     E                    @MSG    1  10 60                xｮﾈｰﾆﾞ
     E*
     I*****************************************************
     I*         データ構造                              *
     I*****************************************************
     I*==< SYSTEM情報>==*
     I           SDS
     I                                     *PROGRAM @@PGM
     I                                      244 253 @@WSID
     I                                      254 263 @@USER
     I                                      264 269 @@JBNO
     I*
     C*****************************************************
     C*         パラメータ　ＬＩＳＴ                    *
     C*****************************************************
     C*==<受取・受渡>==*
     C           *ENTRY    PLIST
     C                     PARM           P@NDTF  80       工程納期(FROM)
     C                     PARM           P@NDTT  80       工程納期(TO)
     C***                  PARM           P@USR3  1        押込み方式
     C***                  PARM           P@USR5  1        ロット
     C***                  PARM           P@USR8  1        後補充
     C***                  PARM           P@USRB  1        Ⅱ
     C                     PARM           P@COND  2         CONDITION
     C*
     C*==< DATR10 >==*
     C           P@DA10    PLIST
     C                     PARM           P@DATE  8
     C                     PARM           P@RCD1  1
     C*
     C*****************************************************
     C*         キー　ＬＩＳＴ                          *
     C*****************************************************
     C*
     C*
     C*****************************************************
     C*         内部ＷＯＲＫ項目                        *
     C*****************************************************
     C                     MOVEL'EDT1'    S@PROC  4        処理制御
     C*
     C*****************************************************
     C*         メインルーチン                          *
     C*****************************************************
     C*
D----C           S@PROC    DOWNE'EXIT'
|    C*
|S---C                     SELEC
|+---C           S@PROC    WHEQ 'EDT1'
||   C                     EXSR $EDT1
||   C*
|+---C           S@PROC    WHEQ 'DSP1'
||   C                     EXSR $DSP1
||   C*
|+---C           S@PROC    WHEQ 'CHK1'
||   C                     EXSR $CHK1
|E---C                     ENDSL
|    C*
E----C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C*****************************************************
     C*  $EDT1  条件指定画面初期設定                    *
     C*****************************************************
     C           $EDT1     BEGSR
     C*
     C*==<初期値>==*
S----C                     SELEC
+----C           P@COND    WHEQ '00'
|    C           P@COND    OREQ '05'
|    C                     Z-ADD*ZERO     D#NDTF           工程納期FROM
|    C                     Z-ADD99999999  D#NDTT           工程納期TO
|    C***                  MOVEL*BLANK    D#USR3           押込み方式
|    C***                  MOVEL*BLANK    D#USR5           ロット
|    C***                  MOVEL*BLANK    D#USR8           後補充
|    C***                  MOVEL*BLANK    D#USRB           Ⅱ
|    C*
|    C                     MOVEA'00'      *IN,31           標識31-36
|    C                     SETOF                     99
|    C                     MOVEL*BLANK    D#MSG1            xｮﾈｰﾆﾞ
|    C*
+----C                     OTHER
|    C                     Z-ADDP@NDTF    D#NDTF           工程納期FROM
|    C                     Z-ADDP@NDTT    D#NDTT           工程納期TO
|    C***                  MOVELP@USR3    D#USR3           押込み方式
|    C***                  MOVELP@USR5    D#USR5           ロット
|    C***                  MOVELP@USR8    D#USR8           後補充
|    C***                  MOVELP@USRB    D#USRB           Ⅱ
|    C*
|    C                     MOVEA'11'      *IN,31           標識31-36
|    C                     SETON                     99
|    C                     MOVEL@MSG,1    D#MSG1            xｮﾈｰﾆﾞ
|    C*
E----C                     ENDSL
     C*
     C*==<次処理>==*
     C                     MOVEL'DSP1'    S@PROC
     C*
     C           $EDT1E    ENDSR
     C*****************************************************
     C*  $DSP1  条件指定画面表示                        *
     C*****************************************************
     C           $DSP1     BEGSR
     C*
     C*==<画面表示>==*   _____________
     C                     EXFMTDFAPW011
     C*                    ~~~~~~~~~~~~~
     C*==<次処理>==*
S----C                     SELEC
+----C           *IN01     WHEQ '1'                        < F1 >
|    C                     Z-ADD*ZERO     P@NDTF           工程納期(FROM)
|    C                     Z-ADD*ZERO     P@NDTT           工程納期(TO)
|    C***                  MOVEL*BLANK    P@USR3           押込み方式
|    C***                  MOVEL*BLANK    P@USR5           ロット
|    C***                  MOVEL*BLANK    P@USR8           後補充
|    C***                  MOVEL*BLANK    P@USRB           Ⅱ
|    C                     MOVEL'01'      P@COND            CONDITION
|    C                     MOVEL'EXIT'    S@PROC
|    C*
+----C           *IN05     WHEQ '1'                        < F5 >
|    C                     MOVEL'CHK1'    S@PROC
|    C*
+----C                     OTHER                           <実行>
|    C                     MOVEL'CHK1'    S@PROC
E----C                     ENDSL
     C*
     C           $DSP1E    ENDSR
     C*****************************************************
     C*  $CHK1  条件指定画面チェック                    *
     C*****************************************************
     C           $CHK1     BEGSR
     C*
     C*==<初期hﾒa >==*
     C                     MOVEA'00'      *IN,31           標識31-36
     C                     SETOF                     99
     C                     MOVEL*BLANK    D#MSG1            xｮﾈｰﾆﾞ
     C*
     C*==<工程納期>==*
     C*        ( FROM )
I----C           D#NDTF    IFNE *ZERO
|    C                     MOVE D#NDTF    P@DATE
|    C                     MOVEL'0'       P@RCD1
|    C                     CALL 'DATR10'  P@DA10
|I---C           P@RCD1    IFNE '0'
||   C                     MOVEL@MSG,2    D#MSG1
||   C                     SETON                     3199
||   C                     MOVEL'DSP1'    S@PROC
||   C                     GOTO $CHK1E
|E---C                     ENDIF
|    C*
|I---C           D#NDTF    IFGE *DATE
||   C                     MOVEL@MSG,6    D#MSG1
||   C                     SETON                     3199
||   C                     MOVEL'DSP1'    S@PROC
||   C                     GOTO $CHK1E
|E---C                     ENDIF
E----C                     ENDIF
     C*
     C*        ( TO )
S----C                     SELEC
+----C           D#NDTT    WHEQ *ZERO
|    C                     MOVEL@MSG,3    D#MSG1
|    C                     SETON                     3299
|    C                     MOVEL'DSP1'    S@PROC
|    C                     GOTO $CHK1E
|    C*
+----C           D#NDTT    WHEQ 99999999
|    C*
+----C                     OTHER
|    C                     MOVE D#NDTT    P@DATE
|    C                     MOVEL'0'       P@RCD1
|    C                     CALL 'DATR10'  P@DA10
|I---C           P@RCD1    IFNE '0'
||   C                     MOVEL@MSG,2    D#MSG1
||   C                     SETON                     3299
||   C                     MOVEL'DSP1'    S@PROC
||   C                     GOTO $CHK1E
|E---C                     ENDIF
|    C*
|I---C           D#NDTT    IFGE *DATE
||   C                     MOVEL@MSG,6    D#MSG1
||   C                     SETON                     3299
||   C                     MOVEL'DSP1'    S@PROC
||   C                     GOTO $CHK1E
|E---C                     ENDIF
E----C                     ENDSL
     C*
I----C           D#NDTF    IFGT D#NDTT
|    C                     MOVEL@MSG,4    D#MSG1
|    C                     SETON                     313299
|    C                     MOVEL'DSP1'    S@PROC
|    C                     GOTO $CHK1E
E----C                     ENDIF
     C*
     C*==<押込み方式>==*
I----C***        D#USR3    IFNE *BLANK
|    C***        D#USR3    ANDNE'X'
|    C***                  MOVEL@MSG,5    D#MSG1
|    C***                  SETON                     3399
|    C***                  MOVEL'DSP1'    S@PROC
|    C***                  GOTO $CHK1E
E----C***                  ENDIF
     C*
     C*==<ロット>==*
I----C***        D#USR5    IFNE *BLANK
|    C***        D#USR5    ANDNE'X'
|    C***                  MOVEL@MSG,5    D#MSG1
|    C***                  SETON                     3499
|    C***                  MOVEL'DSP1'    S@PROC
|    C***                  GOTO $CHK1E
E----C***                  ENDIF
     C*
     C*==<後補充>==*
I----C***        D#USR8    IFNE *BLANK
|    C***        D#USR8    ANDNE'X'
|    C***                  MOVEL@MSG,5    D#MSG1
|    C***                  SETON                     3599
|    C***                  MOVEL'DSP1'    S@PROC
|    C***                  GOTO $CHK1E
E----C***                  ENDIF
     C*
     C*==<Ⅱ>==*
I----C***        D#USRB    IFNE *BLANK
|    C***        D#USRB    ANDNE'X'
|    C***                  MOVEL@MSG,5    D#MSG1
|    C***                  SETON                     3699
|    C***                  MOVEL'DSP1'    S@PROC
|    C***                  GOTO $CHK1E
E----C***                  ENDIF
     C*
     C*==<押込み方式・ロット・後補充・Ⅱ>==*
I----C***        D#USR3    IFEQ *BLANK
|    C***        D#USR5    ANDEQ*BLANK
|    C***        D#USR8    ANDEQ*BLANK
|    C***        D#USRB    ANDEQ*BLANK
|    C***                  MOVEL@MSG,3    D#MSG1
|    C***                  SETON                     333435
|    C***                  SETON                     3699
|    C***                  MOVEL'DSP1'    S@PROC
|    C***                  GOTO $CHK1E
E----C***                  ENDIF
     C*
     C*==<次処理>==*
I----C           *IN05     IFEQ '1'
|    C                     Z-ADDD#NDTF    P@NDTF           工程納期(FROM)
|    C                     Z-ADDD#NDTT    P@NDTT           工程納期(TO)
|    C***                  MOVELD#USR3    P@USR3           押込み方式
|    C***                  MOVELD#USR5    P@USR5           ロット
|    C***                  MOVELD#USR8    P@USR8           後補充
|    C***                  MOVELD#USRB    P@USRB           Ⅱ
|    C                     MOVEL'05'      P@COND            CONDITION
|    C                     MOVEL'EXIT'    S@PROC
+----C                     ELSE
|    C                     MOVEL'DSP1'    S@PROC
E----C                     ENDIF
     C*
     C           $CHK1E    ENDSR
     C*
----+-*--1----+----2----+----3----+----4----+----5----+----6----+----7
** @MSG :メッセージテーブル
E-01 NO DATA
E-02 INPUT DATE
E-03 NEEDS INPUT
E-04 TO DATE IS PAST THAN FROM DATE

E-06 INPUT DATE BEFORE THAN YESTERDAY




