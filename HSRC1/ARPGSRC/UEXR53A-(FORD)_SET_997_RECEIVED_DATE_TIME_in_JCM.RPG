     H            Y.
      ** UEXR53A ***************************************************
      *  (FORD) SET 997 RECEIVED DATE/TIME IN JCMPP11              *
      *  JW     2024.08.06                                         *
      **************************************************************
      *  CALLING SEQ.
      *                    CALL 'UEXR53A'
      *                    PARM           $DATE   8
      *                    PARM           $TIME   6
      *                    PARM           $RTN    1
      *   IN  $DATE   8A  RECEIVE DATE (BLANK=SYSTEM TIME)
      *   IN  $TIME   6A  RECEIVE TIME (BLANK=SYSTEM TIME)
      *   OUT $RTN    1A  RETURN (BLANK=OK, *=ERROR EXISTS)
      ***********************************************************
     FAB#PP6U IF  E                    DISK
     FJCMPL11BUF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      ***********************************************************
     E                    MSG     1   3 40
     IAB#PP6U1    01
     I              M6AK101                         M6AK11
     I              M6AK102                         M6AK12
     I              M6AK201                         M6AK21
     I              M6AK202                         M6AK22
     I              M6AK301                         M6AK31
     I              M6AK302                         M6AK32
     I              M6AK304                         M6AK34
     I              M6AK401                         M6AK41
     I              M6AK402                         M6AK42
     I              M6AK403                         M6AK43
     I              M6AK901                         M6AK91
     I              M6AK902                         M6AK92
     I              M6AK903                         M6AK93
     I              M6AK904                         M6AK94
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      ***********************************************************
      *  MAIN ROUTINE
      ***********************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ AB#PP6U                  98
     C   98                LEAVE
      *
     C                     Z-ADDM6AK12    NUM90   90
     C                     MOVELNUM90     GC10   10
     C           GC10      CHAINJCMPL11B             99
     C           *IN99     IFEQ *ON
     C                     MOVELMSG,1     XMSG   30
     C                     MOVE '*'       $RTN
     C                     CLEARJCMPP111
     C                     EXSR #PRINT
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADD@DATE     J1KOHZ           997 DATE
     C                     Z-ADD@TIME     J1KOTM           997 TIME
     C                     MOVELM6AK22    J1SKME           TRANS#
     C                     MOVE M6AK91    J1CRME           A=ACCEPT
     C                     UPDATJCMPP111
     C                     MOVELMSG,2     XMSG
     C                     EXSR #PRINT
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT#HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      * DETAIL
     C                     ADD  1         SEQ#
     C                     EXCPT#DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      ***********************************************************
      * INITIAL SETTING
      ***********************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $DATE   8
     C                     PARM           $TIME   6
     C                     PARM           $RTN    1
      *
     C                     MOVE ' '       $RTN
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
      *
     C           $DATE     IFEQ *BLANK
     C                     MOVELTODAY     @DATE   80
     C                     ELSE
     C                     MOVEL$DATE     @DATE
     C                     ENDIF
      *
     C           $TIME     IFEQ *BLANK
     C                     MOVELNOW       @TIME   60
     C                     ELSE
     C                     MOVEL$TIME     @TIME
     C                     ENDIF
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           #HDR
     O                                    8 'UEXR53A'
     O                                   45 '** FORD 997 RECEIVE '
     O                                   65 'MSG **              '
     O                                   71 'DATE'
     O                         TODAY     74 '    .  .  '
     O                         NOW       84 '  :  :  '
     O                                   88 'P.'
     O                         PAGE  Z   92
     O        E   03           #HDR
     O                                    5 'SEQ#'
     O                                   17 'RCV_DATE'
     O                                   26 'RCV_TIME'
     O                                   37 'TRANS#'
     O                                   41 'A'
     O                                   49 'ASN#'
     O                                   62 'CONTROL#'
     O                                   68 'DELV'
     O                                   79 'SHP_DATE'
     O                                   85 'BN#'
     O                                   93 'SHID'
     O                                  105 'STATUS'
     O        E 1              #HDR
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O                                  120 '--------------------'
     O                                  130 '----------'
     O        E 1              #DTL
     O                         SEQ#    +001
     O                         J1KOHZ  +002 '    /  /  '
     O                         J1KOTM  +002 '0 :  :  '
     O                         M6AK22  +002
     O                         M6AK91  +002
     O                         J1ASN#  +002
     O                         M6AK12  +002
     O                         J1NONY  +002
     O                         J1NOHZ  +002 '    /  /  '
     O                         J1BIN   +002
     O                         J1SHID  +002
     O                         XMSG    +003
** MSG(40) ........2.........3.........4
GROUP CTL# NOT EXIST !!
ACCEPTED...

