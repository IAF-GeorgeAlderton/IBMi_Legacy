     H            Y.                                                      DAD000
     F** AJSR45 **********************************
     F* CREATE  FA M/F FOR PLATING
     F*          ARRS M/F                      *
     F* C:N.HAYAKAWA           1993.01.21        *
     F********************************************
     FAAFTL01 IF  E           K        DISK
     FAAGTL01 IF  E           K        DISK
     FOABPL01 IF  E           K        DISK
     FAJSPL01 IF  E           K        DISK
     FAJSWP46 O   F     197            DISK                      A
     C****************************
     C*ＡＲＲＳマスターの読込み*
     C****************************
     C           *LOVAL    SETLLOABPL011
     C                     SETOF                     10
     C           ARSLOP    TAG
     C                     READ OABPL011                 10
     C           *IN10     IFEQ '1'
     C                     GOTO ARSEND
     C                     ELSE
     C           OBSKJY    IFEQ 'D'
     C           OBSKHZ    IFLE *DATE
     C                     GOTO ARSLOP
     C                     END
     C                     END
     C                     END
     C******************************************
     C*メッキかんばんマスターに有るかチェック*
     C******************************************
     C           KEY1      KLIST
     C                     KFLD           OBHIN1
     C                     KFLD           OBHIN2
     C                     KFLD           OBHIN3
     C           KEY1      SETLLAAFTL011
     C                     SETOF                     10
     C           MELOOP    TAG
     C                     READ AAFTL011                 10
     C*ファイル終了チェック*
     C           *IN10     IFEQ '1'
     C                     GOTO MKEND
     C                     END
     C*品番違いチェック*
     C           A31HB5    IFNE OBHIN1
     C                     GOTO MKEND
     C                     END
     C           A32HB5    IFNE OBHIN2
     C                     GOTO MKEND
     C                     END
     C           A33HB2    IFNE OBHIN3
     C                     GOTO MKEND
     C                     END
     C*レコード削除チェック*
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    IFLE *DATE
     C                     GOTO MELOOP
     C                     END
     C                     END
     C*失効日が９９９９９９のチェック*
     C           A3STHZ    IFNE 99999999
     C                     GOTO MELOOP
     C                     END
     C*品番有ったら終了*
     C                     GOTO ARSLOP
     C           MKEND     TAG
     C********************************************
     C*トンネルかんばんマスターに有るかチェック*
     C********************************************
     C           KEY1      SETLLAAGTL011
     C                     SETOF                     10
     C           TOLOOP    TAG
     C                     READ AAGTL011                 10
     C*ファイル終了チェック*
     C           *IN10     IFEQ '1'
     C                     GOTO TOEND
     C                     END
     C*品番違いチェック*
     C           O4SHN1    IFNE OBHIN1
     C                     GOTO TOEND
     C                     END
     C           O4SHN2    IFNE OBHIN2
     C                     GOTO TOEND
     C                     END
     C           O4SHN3    IFNE OBHIN3
     C                     GOTO TOEND
     C                     END
     C*レコード削除チェック*
     C           O4SKJY    IFEQ 'D'
     C           O4SKHZ    IFLE *DATE
     C                     GOTO TOLOOP
     C                     END
     C                     END
     C*失効日が９９９９９９のチェック*
     C           O4STHZ    IFNE 99999999
     C                     GOTO TOLOOP
     C                     END
     C*品番有ったら終了*
     C                     GOTO ARSLOP
     C           TOEND     TAG
     C**********************************
     C*    ＦＡマスターにチェイン    *
     C**********************************
     C                     SETOF                     99
     C           KEY1      SETLLAJSPL011
     C                     SETOF                     20
     C           LOOP1     TAG
     C           KEY1      READEAJSPL011                 20
     C           *IN20     IFEQ '0'
     C*引ける*
     C           J1SKJY    IFEQ 'D'
     C           J1SKHZ    IFLE *DATE
     C                     GOTO LOOP1
     C                     END
     C                     END
     C*引けない*
     C                     ELSE
     C                     SETON                     99
     C                     END
     C**********************************
     C*         更新区分入力         *
     C**********************************
     C           *IN99     IFEQ '1'
     C                     MOVE '0'       UPKBN   1
     C                     MOVE ' '       SYKBN   1
     C                     Z-ADD0         JISEN   31
     C                     ELSE
     C                     MOVE '1'       UPKBN
     C                     MOVE J1MKSK    SYKBN
     C                     Z-ADDJ1MKJI    JISEN
     C                     END
     C*
     C                     EXCPTDTA
     C                     GOTO ARSLOP
     C**************************
     C*         終了         *
     C**************************
     C           ARSEND    TAG
     C                     SETON                     LR
     C                     RETRN
     OAJSWP46 EADD             DTA
