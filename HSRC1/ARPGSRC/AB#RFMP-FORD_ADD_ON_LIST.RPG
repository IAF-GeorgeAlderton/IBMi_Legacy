     FABF2L02 IF  E           K        DISK
     FABFEP01 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FABF9P01 IF  E           K        DISK
     FABFDL01 IF  E           K        DISK
     FABFAP01 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FAB#PL15 IF  E           K        DISK
     F**AB#WP451O   F     256            DISK
     FABFBP10 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     FQPRINT2 O   F     132     OV     PRINTER
     F****************************************************
TCHK7E                    P1      1   3 12
TCHK7E                    P2      1   3 20
TCHKCE                    GRP2    1   3  4
     E****************************************************
     I* RELEASED DATE(PARAMETER)
     I            DS
     I                                        1   80@RDAT
     I                                        1   40PRYYYY
     I                                        5   60PRMMMM
     I                                        7   80PRDDDD
     I            DS
     I                                        1   80@SDAT
     I                                        1   40PSYYYY
     I                                        5   60PSMMMM
     I                                        7   80PSDDDD
     I* RELEASED DATE(PARAMETER)
     I            DS
     I                                        1   8 WRDATE
     I                                        1   80WRDAT
     I                                        1   40WRYYYY
     I                                        5   60WRMMMM
     I                                        7   80WRDDDD
     I* SHIPPING DATE(PARAMETER)
     I            DS
     I                                        1   8 WSDATE
     I                                        1   80WSDAT
     I                                        1   40WSYYYY
     I                                        5   60WSMMMM
     I                                        7   80WSDDDD
     I* TIME
     I            DS
     I                                        1  140WTMDT
     I                                        1   60WTIME
     I                                        9  140WDATE
TCHK8I                                        9  100WDAYY
TCHK8I                                       11  120WDAMM
TCHK8I                                       13  140WDADD
     I                                        7  140TODAY
      * DELETE DATE(YYYYMMDD) PART MASTER
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     I* CHANGE DATE(PART MASTER)
     I            DS
     I                                        1   80A2SSHZ
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
     I* PLANT(ROUTE FILE)
     I            DS
     I                                        1   5 QAPLAN
TCHKGI*                                       1   4 K11
TCHKGI                                        1   5 K11
     I            DS
     I                                        1   80QASKHZ
     I                                        1   40QASKYY
     I                                        5   60QASKMM
     I                                        7   80QASKDD
     I            DS
     I                                        1   80QAEFHZ
     I                                        1   40QAEFYY
     I                                        5   60QAEFMM
     I                                        7   80QAEFDD
     I* PART NUMBER(INTERNAL PART=NO BLANKS)
     I            DS
     I                                        1  12 @SHIN
     I                                        1   5 WHIN1
     I                                        6  10 WHIN2
     I                                       11  12 WHIN3
     I* PART NUMBER(USER PART)
     I            DS
     I                                        1  20 WMHIN
     I                                        1   5 WMHN1
     I                                        6  10 WMHN2
     I                                       11  15 WMHN3
     I                                       16  20 WMHN4
     I* INVOICE NUMBER(OUT FILE)
     I            DS
     I                                        1   6 WINV#
     I                                        1   3 WINV1
     I                                        4   60WINV2
     I* ROUTE CODE(RIGHT 3 DIGITS)
     I            DS
     I                                        1   4 QAROUT
     I                                        2   4 WROUT
     I            DS
     I                                        1   80XXYMD
     I                                        1   40XXYY
     I                                        5   60XXMM
     I                                        7   80XXDD
     I            DS
     I                                        1   80F8KYMD
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
TCHK6I            DS
TCHK6I                                        1   5 CFDOCK
TCHK6I                                        1   2 CFDK@2
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     C***********************************************************
     C           *ENTRY    PLIST
     C                     PARM           PRDAT   8        RELEASE DATE
     C                     PARM           PSDAT   8        SHIP DATE
     C                     PARM           PTODAY  8        TODAY
      *
     C**                   PARM           PRYY    4
     C**                   PARM           PRMM    2
     C**                   PARM           PRDD    2
     C**                   PARM           PSYY    4
     C**                   PARM           PSMM    2
     C**                   PARM           PSDD    2
     C**                   PARM           PSIRE   4
     C**                   PARM           PGRP    1
     C**                   PARM           PBIN#   20
      *
     C                     MOVELPRDAT     @RDAT
     C                     MOVELPSDAT     @SDAT
     C                     MOVE *BLANK    PSIRE   4
     C                     MOVE *BLANK    PGRP    1
     C                     MOVE *BLANK    PBIN#   20
     C* ABFAP01
     C           KEY1      KLIST
     C                     KFLD           K11              PLANT
     C                     KFLD           K12              DOCK(RECIVING)
     C* ABF2L02
     C           KEY5      KLIST
     C                     KFLD           QAPLAN           PLANT + A
     C                     KFLD           QADOCK           DOCK
     C                     KFLD           K21              INTERNAL PART
     C                     KFLD           CFSIDT           SCHEDULE ISSUE DATE
     C                     KFLD           CFPOR#           ORDER #
     C                     KFLD           CFREF#           REFERENCE #
     C* ABF2L02
     C           KEY2      KLIST
     C                     KFLD           QAPLAN           PLANT + A
     C                     KFLD           QADOCK           DOCK
     C                     KFLD           K21              INTERNAL PART
     C                     KFLD           CFSIDT           SCHEDULE ISSUE DATE
     C                     KFLD           CFPOR#           ORDER #
     C                     KFLD           CFREF#           REFERENCE #
     C                     KFLD           K22              SHIP DATE
     C* ABFEP01
     C           KEY3      KLIST
     C                     KFLD           WSYYYY           SHIP YYYY
     C                     KFLD           WSMMMM                MMMM
     C* FCEPL01
     C           KEY4      KLIST
     C                     KFLD           WHIN1            INTERNAL PART
     C                     KFLD           WHIN2
     C                     KFLD           WHIN3
     C* AB#PL15
     C           KEY6      KLIST
     C                     KFLD           WTOKU            BATOKU
     C                     KFLD           WNONY              NONY
     C                     KFLD           WNKOJ              NKOJ
     C                     KFLD           WNUKE            BANUKE
     C                     KFLD           WMHN1              MHN1
     C                     KFLD           WMHN2              MHN2
     C                     KFLD           WMHN3            BAMHN3
     C                     KFLD           WMHN4              MHN4
     C                     KFLD           WODRN              ODRN
     C                     KFLD           WSYYYY           BANOYY
     C                     KFLD           WSMMMM             NOMM
     C                     KFLD           WSDDDD             NODD
TCHK5C*                    KFLD           WBIN             BANOBN
     C****                 KFLD           WRYYYY             DEYY
     C****                 KFLD           WRMMMM             DEMM
     C***                  KFLD           WRDDDD           BADEDD
     C           K#FD      KLIST
     C                     KFLD           QAPLAN           PLANT + A
     C                     KFLD           QADOCK           DOCK
     C           K#AB      KLIST
     C                     KFLD           WTOKU            BATOKU
     C                     KFLD           WNONY              NONY
     C                     KFLD           WNKOJ              NKOJ
     C                     KFLD           WNUKE            BANUKE
     C                     KFLD           WMHN1              MHN1
     C                     KFLD           WMHN2              MHN2
     C                     KFLD           WMHN3            BAMHN3
     C                     KFLD           WMHN4              MHN4
     C                     KFLD           WODRN              ODRN
     C                     KFLD           @@YYYY  40       BANOYY
     C                     KFLD           @@MMMM  20         NOMM
     C                     KFLD           @@DDDD  20         NODD
     C           K#ABX     KLIST
     C                     KFLD           WTOKU            BATOKU
     C                     KFLD           WNONY              NONY
     C                     KFLD           WNKOJ              NKOJ
     C                     KFLD           WNUKE            BANUKE
     C                     KFLD           WMHN1              MHN1
     C                     KFLD           WMHN2              MHN2
     C                     KFLD           WMHN3            BAMHN3
     C                     KFLD           WMHN4              MHN4
     C                     KFLD           WODRN              ODRN
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
TCH23C*
     C           K#ADF     KLIST
     C                     KFLD           K@NONY  40
     C                     KFLD           K@DOCK  4
TCH23C*
     C           PSIRE     IFNE *BLANK
     C                     MOVE PSIRE     @@NONY  40
     C                     ELSE
     C                     Z-ADD*ZERO     @@NONY
     C                     ENDIF
     C***********************************************************
     C*
     C                     EXSR @INZ
     C                     EXSR @MAIN
     C                     EXSR @END
     C***********************************************************
     C* INITIALIZE WORK AREA
     C***********************************************************
     C           @INZ      BEGSR
     C*
     C                     TIME           WTMDT
     C                     MOVELPTODAY    TODAY
     C*
     C                     Z-ADD*ZERO     WQTY2  100
     C                     Z-ADD*ZERO     WQTY3  100
     C                     Z-ADD*ZERO     WSUMQ  100
     C                     SETON                     OF
     C                     SETOF                     77
     C*
     C                     Z-ADDPRYYYY    WRYYYY
     C                     Z-ADDPRMMMM    WRMMMM
     C                     Z-ADDPRDDDD    WRDDDD
     C                     Z-ADDPSYYYY    WSYYYY
     C                     Z-ADDPSMMMM    WSMMMM
     C                     Z-ADDPSDDDD    WSDDDD
     C*
     C* NOT WORKING DAY?
     C           WRDATE    IFNE WSDATE
     C                     SETON                     89
     C                     END
      *
     C                     Z-ADDTODAY     K@YMD
     C                     Z-ADD1         @@CNT   30
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     ADD  1         @@CNT
     C           @@CNT     IFEQ 5
     C                     Z-ADDF8KYMD    W@LMT   80
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C*
     C                     ENDSR
     C***********************************************************
     C* MAIN
     C***********************************************************
     C           @MAIN     BEGSR
     C*
     C* NIRVANA PLANT EXISTS IN ROUTE MASTER
     C* READ AND PROCESS ALL ROUTE MASTER RECORD
TCH23C           *LOVAL    SETLLABFDL01R
TCH23C                     READ ABFDL01R                 90
TCHK9C*
B01  C           *IN90     DOWEQ'0'
  |  C                     Z-ADDQANONY    K@NONY
     C                     MOVE QADOCK    K@DOCK
TCHK9C*
TCHK9C           QAPLAN    IFEQ '0095A'
TCHK9C                     GOTO @@SKP1
TCHK9C                     END
TCHKHC           PGRP      IFEQ '3'
TCHK9C           QANONY    IFEQ 5120
TCHK9C           QANONY    OREQ 5100
TCHK9C           QANONY    OREQ 5111
TCHK9C           QANONY    OREQ 5115
TCHK9C           QANONY    OREQ 5130
TCHK9C           QANONY    OREQ 5118
TCHK9C           QANONY    OREQ 5140
TCHK9C           QANONY    OREQ 5135
TCHK9C           QANONY    OREQ 5102
TCHKEC           QANONY    OREQ 5141
TCHKEC           QANONY    OREQ 5119
TCHKHC           QANONY    OREQ 5116
TCHKHC           QANONY    OREQ 5114
TCHKIC           QANONY    OREQ 5121
TCHKJC           QANONY    OREQ 5138
TCHKKC           QANONY    OREQ 5113
TCHKLC           QANONY    OREQ 5112
TCHKMC           QANONY    OREQ 5166
TCHKFC*TCHKE     QANONY    OREQ 0001
TCHKHC                     ELSE
TCHK9C                     GOTO @@SKP1
TCHK9C                     END
TCHKHC                     END
TCHK9C*
%0001C           QASKJY    IFEQ *BLANK
     C           QAEFHZ    ANDLETODAY
TCHK9C*
TCHK9C*          @@NONY    IFEQ *ZERO
TCHK9C*          @@NONY    ORNE *ZERO
TCHK9C*          @@NONY    ANDEQQANONY
TCHK9C*
TCHK9C           @@NONY    IFEQ *ZERO
TCHK9C*
TCHK9C                     MOVELQANONY    W@A004  4
TCHK9C           W@A004    LOKUPGRP2                     86
TCHK9C           PGRP      IFEQ '1'
TCHK9C           *IN86     ANDEQ*ON
TCHK9C                     GOTO @@SKP2
TCHK9C                     END
TCHK9C           PGRP      IFEQ '2'
TCHK9C           *IN86     ANDEQ*OFF
TCHK9C                     GOTO @@SKP2
TCHK9C                     END
TCHK9C*
TCHK9C                     ELSE
TCHK9C*
TCHK9C           @@NONY    IFNE QANONY
TCHK9C                     GOTO @@SKP2
TCHK9C                     END
TCHK9C*
TCHK9C                     END
TCH23C*
  |  C**                   Z-ADDQANONY    K@NONY
     C**                   MOVE QADOCK    K@DOCK
      *
     C           K#ADF     SETGTABFDL01R
     C           *IN88     DOUEQ*ON
     C           K#ADF     REDPEABFDL01R                 88
     C           *IN88     IFEQ *ON
     C           K#ADF     SETGTABFDL01R
     C                     LEAVE
     C                     ELSE
%0001C           QASKJY    IFEQ 'D'
%0001C           QASKHZ    ANDLETODAY
%0001C                     ITER
     C                     ENDIF
     C           QAEFHZ    IFGT TODAY
%0001C                     ITER
     C                     ENDIF
     C                     LEAVE
      *
     C                     ENDIF
   | C                     ENDDO
TCH23C*
     C*
     C* SET ROUTE CODE TO INVOICE#
     C                     MOVE WROUT     WINV1
     C*
     C* READ ADDRESS MASTER
     C           QAPLAN    CHAINABF9P01              93
B02  C           *IN93     IFEQ '1'
TCHK1C           *INOF     IFEQ *ON
TCHK1C                     EXCPT#HED1
TCHK1C                     EXCPT#HED2
TCHK1C                     SETOF                     OF
TCHK1C                     END
TCHK1C                     MOVEL'  '      W#MARK  2
TCHK1C           *IN96     IFEQ *OFF
TCHK1C           WSURY     IFGT BASRYO
TCHK1C                     MOVEL'++'      W#MARK
TCHK1C                     END
TCHK1C                     END
     C                     EXCPT#DTL1
E02  C                     END
     C*
     C* READ EDI KEY FILE
     C                     MOVELQADOCK    K12     4
     C           KEY1      SETLLABFAP01R
     C           KEY1      READEABFAP01R                 91
B02  C           *IN91     DOWEQ'0'
TCHK2C           CFDLCD    IFNE *BLANK
TCHK2C                     GOTO @@SKP
TCHK2C                     END
     C*
     C* READ FORD EDI FILE
     C           CFSIDT    CABLTW@LMT     @@SKP
      *
     C                     MOVELCFPART    K21    20
TCHK7C                     Z-ADD1         WW      10
TCHK7C           CFPART    LOKUPP1,WW                    10
TCHK7C   10                MOVELP2,WW     K21
     C                     Z-ADDWRDAT     K22     80
     C           KEY2      CHAINABF2P011             92
B03  C           *IN92     IFEQ '0'
     C*
     C* SET AB#WP451(INPUT FILE FOR AB#R45)
     C                     MOVE 'AVRT'    WSIRE   4        SUPPLIER CODE
     C                     MOVE 'A'       WSIRK   1        FACTORY  CODE
     C                     MOVE '5149'    WTOKU   40       CUSTOMER CODE
     C                     MOVE QANONY    WNONY   40       DELIVERY CODE
     C                     MOVE '0'       WNKOJ   1        FACTORY  CODE
     C                     MOVELQADOCK    WNUKE   4        RECEIVING   E
     C                     MOVE *BLANK    WSBAN   4        NUMBER      E
     C                     MOVE *BLANK    WMHIN
     C                     MOVELAFIPAR    WMHIN  20        PART NUMBER E
JW1  C                     MOVELAFPART    WMHIN2 20        USER PART   E
     C                     Z-ADDWSDAT     WNYMD   80       DELIVERY DATE
     C                     MOVEL'11111'   WODRN  10        ORDER #     E
      *
     C                     Z-ADD*ZERO     XXQTY   90
     C                     Z-ADD*ZERO     XXYMD
     C                     Z-ADD*ZERO     WQTY2
     C                     Z-ADD*ZERO     WSURY
TCHK8C           AFLSDT    IFNE *ZERO
     C           20000000  ADD  AFLSDT    XXYMD
TCHK8C                     ELSE
TCHK8C           2000      ADD  WDAYY     XXYY
TCHK8C                     END
     C                     Z-ADDXXYY      @@YYYY
     C                     Z-ADDXXMM      @@MMMM
     C                     Z-ADDXXDD      @@DDDD
     C           K#AB      SETGTAB#PL15
     C           *IN97     DOUEQ*ON
     C           K#ABX     READEAB#PL15                  97
     C           *IN97     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BANOHZ    IFGE WSDAT
     C                     LEAVE
     C                     ENDIF
     C                     ADD  BASRYO    XXQTY
     C                     ENDIF
     C                     ENDDO
      * XXQTY = YTD QTY FROM PP10
     C*
     C* NOT WORKING DAY,RE-CULUCULATE
     C           *IN89     IFEQ '1'
TCHK3C           AFQTY2    SUB  AFYSQY    WQTY2            ORDERED QTY
TCHK3C                     SUB  XXQTY     WQTY2
TCHK3C                     Z-ADDWQTY2     WSURY   70
     C*
     C                     ELSE
     C*
     C* REQUESTED CUM - SHIPPED CUM
      *
      *
     C           AFQTY2    SUB  AFYSQY    WQTY2            ORDERED QTY
     C                     SUB  XXQTY     WQTY2
     C                     Z-ADDWQTY2     WSURY   70
     C                     END
      *
B04  C           WQTY2     IFGT *ZERO
     C*
     C                     EXSR #ER1
     C*
     C***** GET UNIT QUANTITY
     C                     MOVELWTOKU     PTOKU   4
     C                     MOVELWNONY     PNONY   4
     C                     MOVELWNKOJ     PNKOJ   1
     C                     MOVELWNUKE     PNUKE   4
     C                     MOVELWMHIN     @MHIN  20
     C                     MOVELWMHIN     WMHIN  20
     C                     MOVEL*BLANK    @SHIN  12
     C                     MOVEL*BLANK    @FLG    1
     C*
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU
     C                     PARM           PNONY
     C                     PARM           PNKOJ
     C                     PARM           PNUKE
     C                     PARM           @MHIN
     C                     PARM           @SHIN
     C                     PARM           @FLG
     C*
     C* GET QTY./CONT. FROM PART MASTER
     C           KEY4      SETLLFCEPL011
     C           #READ1    TAG
     C           KEY4      READEFCEPL011                 94
B05  C           *IN94     IFEQ '0'
B06  C           A2GSKD    ANDEQ*BLANK
     C*
B06  C           A2SSHZ    IFLE TODAY
     C                     Z-ADDA2SSYS    WSYOS   60
     C                     ELSE
     C                     Z-ADDA2KSYS    WSYOS
E06  C                     ENDIF
     C*
E04  C                     ENDIF
     C*
     C* CHECK FRACTION OR NOT
B04  C           WSYOS     IFNE *ZERO
     C           WQTY2     DIV  WSYOS     WQTY2
     C                     MVR            WREST   40
B05  C           WREST     IFNE *ZERO
E05  C                     END
     C*
E04  C                     ENDIF
     C*
     C                     Z-ADD*ZERO     WNOTM   40       INVOICE TIME
     C                     Z-ADD*ZERO     WUSYS   60       USER QTY/CONT.
TCHKBC           PBIN#     IFNE *ZERO
TCHKBC                     MOVELPBIN#     WBIN
TCHKBC                     ELSE
   | C           QAROUT    CHAINABFBP10              95
     C           *IN95     IFEQ *OFF
     C                     MOVE B1BINN    WBIN    20
     C                     ELSE
   | C                     MOVE '06'      WBIN
TCH23C                     ENDIF
TCHKBC                     END
     C                     MOVELAFALFL    WALFL   4        FEED LINE
     C*
     C* GET INVOICE NUMBER(ROUTE + JULIAN DATE)
     C           KEY3      CHAINABFEP01              95
B04  C           *IN95     IFEQ '0'
     C           QB#DAY    ADD  WSDDDD    WINV2
     C*
     C                     ELSE
     C                     Z-ADD*ZERO     WINV2
E04  C                     END
     C*
     C                     MOVELAFRALF    WRLOC   4
     C*
     C                     MOVE *OFF      *IN87
      *
     C           KEY6      SETLLAB#PL151
     C           *IN96     DOUEQ*ON
     C           KEY6      READEAB#PL151                 96
     C           *IN96     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C                     MOVE *ON       *IN87
TCHK1C           *INOF     IFEQ *ON
TCHK1C                     EXCPT#HED1
TCHK1C                     EXCPT#HED2
TCHK1C                     SETOF                     OF
TCHK1C                     END
TCHK1C                     MOVEL'  '      W#MARK
TCHK1C           *IN96     IFEQ *OFF
TCHK1C           WSURY     IFGT BASRYO
TCHK1C                     MOVEL'++'      W#MARK
TCHK1C                     END
TCHK1C                     END
     C                     EXCPT#DTL1
     C** 77                EXCPTDT
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN87     IFEQ *OFF
TCHK1C           *INOF     IFEQ *ON
TCHK1C                     EXCPT#HED1
TCHK1C                     EXCPT#HED2
TCHK1C                     SETOF                     OF
TCHK1C                     END
TCHK1C                     MOVEL'  '      W#MARK
TCHK1C           *IN96     IFEQ *OFF
TCHK1C           WSURY     IFGT BASRYO
TCHK1C                     MOVEL'++'      W#MARK
TCHK1C                     END
TCHK1C                     END
     C                     EXCPT#DTL1
     C** 77                EXCPTDT
     C                     ENDIF
      *
E03  C                     ENDIF
     C*
     C                     ENDIF
     C*
     C           @@SKP     TAG
     C           KEY1      READEABFAP01R                 91
     C                     ENDDO
     C*
TCHK9C*                    ENDIF
TCH23C*          K#FD      SETGTABFDP01R
TCHK9C           @@SKP2    TAG
TCH23C           K#ADF     SETGTABFDL01R
     C                     ENDIF
TCH23C*                    READ ABFDP01R                 90
TCHK9C           @@SKP1    TAG
TCH23C                     READ ABFDL01R                 90
     C                     ENDDO
     C*
     C                     ENDSR
     C***********************************************************
     C* END
     C***********************************************************
     C           @END      BEGSR
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C                     ENDSR
     C***********************************************************
     C***********************************************************
     C* CUM QTY ERROR
     C***********************************************************
     C           #ER1      BEGSR
     C*
     C                     Z-ADD*YEAR     @@YYYY
     C                     Z-ADD*MONTH    @@MMMM
     C                     Z-ADD*DAY      @@DDDD
     C                     Z-ADD*ZERO     @@QTY   90
     C           K#AB      SETLLAB#PL15
     C           *IN97     DOUEQ*ON
     C           K#ABX     READEAB#PL15                  97
     C           *IN97     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BANOHZ    IFGE WSDAT
     C                     LEAVE
     C                     ENDIF
     C                     ADD  BASRYO    @@QTY
     C                     ENDIF
     C                     ENDDO
      *
     C                     ADD  CFCAMT    @@QTY
     C           @@QTY     IFGT AFQTY2
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HEDE
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
      *
     C                     EXCPT@DETE
     C                     ENDIF
     C*
     C                     ENDSR
     C********************************************************
     OQPRINT  E    2           #HED1
     O       OR        OF
     O                                    9 'AB#RFMP'
