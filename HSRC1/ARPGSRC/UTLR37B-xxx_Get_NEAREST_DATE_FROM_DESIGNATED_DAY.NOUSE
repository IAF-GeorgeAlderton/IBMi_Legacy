     H            Y.
     F** UTLR37B ***************************************************
     F*  PROGRAM: GET NEAREST DATE FROM DESIGNATED DAY OF THE WEEK *
     F*           (SELECT 1 DATE FROM 1 TARGET DAY)                *
     F*           (CHECK UTLR37 FOR 2 TARGET DAY)                  *
     F*  WRITTEN: JW (SRA)                                         *
     F*           2019.05.13                                       *
     F*------------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR37B'
     F*                    PARM           $DT8    8
     F*                    PARM           $SIGN   1
     F*                    PARM           $DAY    3
     F*                    PARM           $MAX    1
     F*                    PARM           $TGT8   8
     F*                    PARM           $RTN    1
     F*   IN  $DT8  :  8A BASE DATE  (YYYYMMDD)
     F*       $SIGN :  1A + OR -
     F*       $DAY  :  3A DAY OF THE WEEK (MON, TUE, WED, THU, FRI, SAT OR SUN)
     F*       $MAX  :  1A (Y/N) (Y:MAX 7 DAYS, N=MAX 6 DAYS)
     F*   OUT $TGT8 :  8A TARGET DATE
     F*       $RTN  :  1A RETURN FLAG (BLANK=OK, *=ERROR)
     F*   -------------------------------------------------
     F*   EX.
     F*   IN  $DT8  :  8A "20191216"
     F*       $SIGN :  1A "-"
     F*       $DAY  :  3A "FRI"
     F*       $MAX  :  1A "Y"
     F*   OUT $TGT8 :  8A "20191213"  <-- LAST FRIDAY
     F*       $RTN  :  1A " "
     F*
     F******************************************************
     FAGDPL12 IF  E           K        DISK
      *--------------------------------------------------------
     I            DS
     I                                        1   80K@DT
     I                                        1   40K@DTYY
     I                                        5   60K@DTMM
     I                                        7   80K@DTDD
     I            DS
     I                                        1   80F8KA
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
      *
     C                     EXSR #INIT
      * CHECK DAY
     C                     MOVE *BLANK    @YOBI   10
     C                     SELEC
     C           $DAY      WHEQ 'MON'
     C                     Z-ADD1         @YOBI
     C           $DAY      WHEQ 'TUE'
     C                     Z-ADD2         @YOBI
     C           $DAY      WHEQ 'WED'
     C                     Z-ADD3         @YOBI
     C           $DAY      WHEQ 'THU'
     C                     Z-ADD4         @YOBI
     C           $DAY      WHEQ 'FRI'
     C                     Z-ADD5         @YOBI
     C           $DAY      WHEQ 'SAT'
     C                     Z-ADD6         @YOBI
     C           $DAY      WHEQ 'SUN'
     C                     Z-ADD7         @YOBI
     C                     OTHER
     C                     MOVEL$DT8      $TGT8
     C                     MOVE '*'       $RTN
     C                     ENDSL
      *
     C           $RTN      IFEQ *BLANK
     C                     SELEC
     C           $SIGN     WHEQ '+'
     C                     EXSR #ADD
     C           $SIGN     WHEQ '-'
     C                     EXSR #SUB
     C                     OTHER
     C                     MOVE '*'       $RTN
     C                     ENDSL
     C                     ENDIF
      * SET PARAMETER
     C           $RTN      IFEQ *BLANK
     C           $MAX      IFNE 'Y'
     C           CNT       ANDGE7
     C                     MOVEL$DT8      $TGT8
     C                     ELSE
     C                     MOVEL@TGT8     $TGT8
     C                     ENDIF
     C                     ENDIF
      *
     C           @END      TAG
     C                     SETON                     LR
     C                     RETRN
      *=============================================================
      *                    ADD DAYS
      *=============================================================
     C           #ADD      BEGSR
      *
     C           KEY       SETGTAGDPL12
     C                     MOVE *OFF      *IN98
     C           *IN98     DOWEQ*OFF
     C                     READ AGDPL12                  98
     C           *IN98     IFEQ *OFF
      * COUNT
     C                     ADD  1         CNT
      * END
     C           F8YOBI    IFEQ @YOBI
     C                     Z-ADDF8KA      @TGT8
     C                     MOVE *ON       *IN98
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *=============================================================
      *                    SUBTRACT DAYS
      *=============================================================
     C           #SUB      BEGSR
      *
     C           KEY       SETLLAGDPL12
     C                     MOVE *OFF      *IN98
     C           *IN98     DOWEQ*OFF
     C                     READPAGDPL12                  98
     C           *IN98     IFEQ *OFF
      * COUNT
     C                     ADD  1         CNT
      * END
     C           F8YOBI    IFEQ @YOBI
     C                     Z-ADDF8KA      @TGT8
     C                     MOVE *ON       *IN98
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *=============================================================
      *                    INITIAL PROCESS
      *=============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAY    3
     C                     PARM           $MAX    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN    1
      *
     C           KEY       KLIST
     C                     KFLD           K@DTYY  40
     C                     KFLD           K@DTMM  20
     C                     KFLD           K@DTDD  20
      *
     C                     MOVEL'00000000'$TGT8
     C                     MOVE *BLANK    $RTN
     C                     MOVEL$DT8      @DT8    80
     C                     Z-ADD@DT8      K@DT
     C                     Z-ADD0         @TGT8   80
     C                     Z-ADD0         CNT     40
      *
     C                     ENDSR
