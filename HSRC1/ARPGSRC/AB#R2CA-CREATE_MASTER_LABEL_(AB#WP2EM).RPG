      *-----------------------------------------------------
      * MAIN ROUTINE
      *-----------------------------------------------------
     C                     EXSR #INIT
      *
     C                     Z-ADD0         IX      20
      *
     C           $SERL#    SETLLAB#PL71A
     C                     DO   *HIVAL
     C           $SERL#    READEAB#PL71A                 98
     C   98                LEAVE
      *
     C                     ADD  1         IX
      * FIRST TRANSACTION
     C           IX        IFEQ 1
     C                     EXSR #1ST
     C                     ENDIF
      * == EACH PART ==
      * GET USER PART#
     C                     MOVELMPMHIN    $IPART
     C                     MOVELMPNONY    $NONY
     C                     CALL 'UTLR75B'
     C                     PARM           $IPART 20
     C                     PARM           $NONY   4
     C                     PARM           $UPART 20
     C                     PARM           $RTN    1
      *
     C           $RTN      IFEQ ' '
     C                     MOVEL$UPART    MHN,IX
     C                     ELSE
     C                     MOVELMPMHIN    MHN,IX
     C                     ENDIF
      * PART NAME
     C                     MOVELMPSHIN    $SHIN
     C                     CALL 'UTLR31C'
     C                     PARM           $SHIN  12
     C                     PARM           $NAME  15
     C                     MOVEL$NAME     MNM,IX
      *
     C                     MOVELMPSBAN    SBN,IX
     C                     MOVELMPSRYO    TQY,IX
     C                     MOVELMPSYOS    PQY,IX
     C                     MOVELMPHAKO    PAC,IX
     C                     MOVEL'EA'      UOM,IX
      * GET COUNTRY OF ORIGIN
     C**                   MOVE '   '     $CGRP
     C                     MOVELMPSHIN    $PART
     C                     MOVELMPNONY    $PNONY  4
     C                     MOVE 'I'       $PTYP            IAF
     C**********           CALL 'UTLR06'
JW1  C                     CALL 'UTLR06A'
     C**                   PARM           $CGRP   3
     C                     PARM           $PART  20
     C                     PARM           $PNONY  4
     C                     PARM           $PTYP   1
     C                     PARM           $CO     3
     C**                   PARM           $RTN    1
     C           $CO       IFEQ *BLANK
     C                     MOVEL'US '     COO,IX
     C                     ELSE
     C                     MOVEL$CO       COO,IX
     C                     ENDIF
      * WEIGHT
     C                     MOVELMPSHIN    $IPAR
     C                     MOVE *BLANK    $NONY
     C                     CALL 'UTLR33B'
     C                     PARM           $IPAR  12
     C                     PARM           $NONY   4
     C                     PARM           $NET    7
     C                     PARM           $MSC    7
     C                     MOVEL$NET      @NET    72
     C                     MOVEL$MSC      @MSC    72
     C           @NET      MULT MPSRYO    NUM10  102
     C           NUM10     DIV  1000      NUM72   72
     C           @MSC      MULT MPHAKO    @WGT    72
     C                     ADD  NUM72     @WGT
     C                     MOVEL@WGT      WGT,IX
     C                     ADD  @WGT      TWGT
     C                     ADD  MPHAKO    TBOX
      *
     C                     ENDDO
      *
     C                     MOVELTWGT      E2WEIG
     C                     MOVELTBOX      E2TBOX
     C                     Z-ADDTODAY     E2CRDT
     C                     Z-ADDNOW       E2CRTM
     C                     MOVEL#USER     E2CRUS
     C                     MOVEL#WSID     E2CRWS
     C                     MOVEL#PGM      E2CRPG
      *
     C                     WRITEAB#WP2M1
JW2  C                     WRITESV#WP2M1
      *
     C                     CLEARAB#XP1A1
 |   C                     MOVEL'SV#WP2EM'IXWRKF    P
 |   C                     EXSR #XP01                      =>AB#XP01
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
      * 1ST PROCESS
      *-----------------------------------------------------
     C           #1ST      BEGSR
      *
     C                     CLEARAB#WP2M1
      * GET MASTER SERIAL#
     C                     EXSR @NMBR
      *
     C                     MOVEL$SERL#    E2PCKL
     C                     MOVELMPNUKE    E2NUKE
      * ADDRESS TO
     C                     MOVELMPNONY    PNONY
     C                     CALL 'AB#R2C2'
     C                     PARM           PNONY   4
     C                     PARM *BLANK    P@ADR1 50
     C                     PARM *BLANK    P@ADR2 50
     C                     PARM *BLANK    P@ADR3 50
     C                     PARM *BLANK    P@ADR4 50
     C                     PARM *BLANK    P@ADR5 50
     C                     PARM *BLANK    P@ADR6 50
     C                     PARM *BLANK    P@SKJY  1
     C                     MOVELP@ADR1    E2TAD1
     C                     MOVELP@ADR2    E2TAD2
     C                     MOVELP@ADR3    E2TAD3
     C                     MOVELP@ADR4    E2TAD4
     C                     MOVELP@ADR5    E2TAD5
     C                     MOVELP@ADR6    E2TAD6
      * ADDRESS FROM
     C                     MOVEL'0111'    PNONY
     C                     CALL 'AB#R2C2'
     C                     PARM           PNONY
     C                     PARM *BLANK    P@ADR1
     C                     PARM *BLANK    P@ADR2
     C                     PARM *BLANK    P@ADR3
     C                     PARM *BLANK    P@ADR4
     C                     PARM *BLANK    P@ADR5
     C                     PARM *BLANK    P@ADR6
     C                     PARM *BLANK    P@SKJY
     C                     MOVELP@ADR1    E2FAD1
     C                     MOVELP@ADR2    E2FAD2
     C                     MOVELP@ADR3    E2FAD3
     C                     MOVELP@ADR4    E2FAD4
     C                     MOVELP@ADR5    E2FAD5
     C                     MOVELP@ADR6    E2FAD6
      *
     C                     MOVELMPNOHZ    E2SHDT
     C                     MOVE *BLANK    E2SERL
     C                     MOVELMPODRN    E2ODRN
      *
     C                     MOVELMPTOKU    E2CUST
     C                     MOVELMPNONY    E2NONY
      * CUSTOMER NAME
     C                     MOVELMPNONY    PMNONY
     C                     MOVE 'D'       PMOPT
     C                     CALL 'UTLR16'
     C                     PARM           PMNONY  4
     C                     PARM           PMOPT   1
     C                     PARM           PMNAME 20
     C                     PARM           PTOKU   4
     C                     PARM           PMRTN   1
     C                     MOVELPMNAME    E2CNAM
      * SERIAL #
     C                     MOVELN3NMBR    E2SERL
     C                     MOVELMPNONY    E2SERL
     C                     MOVELMSG,1     E2LNAM
      *
     C                     MOVELMPNONY    $NONY
     C                     CALL 'UTLR62C'
     C                     PARM           $NONY   4
     C                     PARM           $SUPP  10
     C                     MOVEL$SUPP     E2SUPP
      *
     C                     ENDSR
      *-----------------------------------------------------
      * SET SERIAL #
      *-----------------------------------------------------
     C           @NMBR     BEGSR
      *
     C                     MOVE *ALL'9'   @@14   140
     C           MPNONY    CHAINAB#NP30              97
     C                     Z-ADDTODAY     N3UDAT
     C                     Z-ADDNOW       N3UTIM
     C                     MOVEL#PGM      N3UPGM
     C                     MOVEL#USER     N3UUSR
     C                     MOVEL#WSID     N3UWIS
     C                     Z-ADDMPNONY    N3NONY
     C           *IN97     IFEQ *ON
     C                     Z-ADD1         N3NMBR
     C                     WRITEAB#NP301
     C                     ELSE
     C                     ADD  1         N3NMBR
     C           N3NMBR    IFEQ @@14
     C                     Z-ADD1         N3NMBR
     C                     ENDIF
     C                     UPDATAB#NP301
     C                     ENDIF
      *
     C                     ENDSR
      *================================================================
      *  ..LABEL DATA ISSUE LOG                            *
      *================================================================
     C           #XP01     BEGSR
      *
     C                     Z-ADDTODAY     IXKOHZ           TODAY
     C                     Z-ADDNOW       IXKOTM           NOW
     C                     MOVELE2CUST    IXTOKU           CUSTOMER
     C                     MOVELE2NONY    IXNONY           DELIVERY
      **                   MOVEL 2FACT    IXNKOJ           FACTORY
     C                     MOVELE2NUKE    IXNUKE           DOCK
     C                     MOVELE2ODRN    IXODRN           ORDER #
     C                     MOVELE2SERL    IXSERL           SERIAL NUMBER
     C                     MOVELE2SHDT    IXDEDT           INVOICE DATE
      **                   MOVE           IXNOBN           INVOICE BIN
      *
     C                     MOVELE2PCKL    IXPL#
     C                     MOVEL#USER     IXKOUS
     C                     MOVEL#WSID     IXKOWS
     C                     MOVEL#PGM      IXKOPG
      *
     C                     MOVELE2MHN1    IXMHIN
     C                     MOVELMPSHIN    IXSHIN
     C                     MOVELE2LNAM    IXINVN
      *
     C                     WRITEAB#XP1A1
      *
     C                     ENDSR
      *-----------------------------------------------------
      * INITIAL SETTING
      *-----------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SERL#  9        PACKING LIST#
      *
     C                     TIME           SDATE
     C                     MOVE *BLANK    MHN
     C                     MOVE *BLANK    MNM
     C                     MOVE *BLANK    COO
     C                     MOVE *BLANK    PAC
     C                     MOVE *BLANK    PQY
     C                     MOVE *BLANK    TQY
     C                     MOVE *BLANK    UOM
     C                     MOVE *BLANK    SBN
     C                     MOVE *BLANK    WGT
     C                     Z-ADD0         TWGT    72       TOTAL WEIGHT
     C                     Z-ADD0         TBOX    50       TOTAL BOX
      *
     C                     ENDSR
** MSG ..1.........2.........3.........4..........5
MASTER LABEL                                         01
                                                     02
