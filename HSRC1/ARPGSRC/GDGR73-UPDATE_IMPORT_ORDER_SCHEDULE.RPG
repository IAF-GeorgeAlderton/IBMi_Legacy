     C                     KFLD           K@SHN2  5
     C                     KFLD           K@SHN3  2
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      *
     C                     Z-ADD21        P@LEN
     C                     MOVEACL,1      ARY
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     RRN2    40
     C                     Z-ADD*ZERO     @RRN    40
     C                     MOVEL'01'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKJ     WHEQ *ON
     C                     CALL 'GDLR45'
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     SELEC
      * MATERIAL
     C           D@OPTN    WHEQ '4'
     C                     MOVEL'03'      W@ID
     C                     EXSR #SET3
     C           D@OPTN    WHEQ '5'
     C                     MOVEL'03'      W@ID
     C                     EXSR #SET31
      * WASHER
     C           D@OPTN    WHEQ '3'
     C                     EXSR #SET2
     C                     EXSR #WSSET
     C                     MOVEL'02'      W@ID
      * PRODUCT
     C           D@OPTN    WHEQ '1'
     C                     MOVEL'02'      W@ID
     C                     EXSR #SET1
     C                     EXSR #WSSET
      * HALF FINISHED
     C           D@OPTN    WHEQ '2'
     C                     EXSR #SET11
     C                     EXSR #WSSET
     C                     MOVEL'02'      W@ID
     C                     ENDSL
      *
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     Z-ADD1         @@P     20
     C                     EXSR #CLR
      *
     C           D@OPTN    IFLT '1'
     C           D@OPTN    ORGT '5'
     C                     MOVE *ON       *IN61
     C                     MOVE *ON       *IN99
     C                     MOVE ER,1      D@MSG
     C                     ENDIF
      *
     C                     Z-ADDD@FROM    K@YMD
     C           K#ADGP    CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     MOVE *ON       *IN62
     C  N99                MOVE ER,2      D@MSG
     C                     MOVE *ON       *IN99
     C                     ELSE
     C           D@FROM    IFLE *DATE
     C                     MOVE *ON       *IN62
     C  N99                MOVE ER,7      D@MSG
     C                     MOVE *ON       *IN99
     C                     ENDIF
     C                     ENDIF
      *
      *
     C                     Z-ADDD@DDCT    K@YMD
     C           K#ADGP    CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     MOVE *ON       *IN64
     C  N99                MOVE ER,2      D@MSG
     C                     MOVE *ON       *IN99
     C                     ELSE
     C           F8HIRU    IFNE *BLANK
     C                     MOVE *ON       *IN64
     C  N99                MOVE ER,3      D@MSG
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
 %001C**         D@OPTN    IFGE '1'
     C**         D@OPTN    ANDLE'3'
     C**         F8YOBI    ANDNE3
