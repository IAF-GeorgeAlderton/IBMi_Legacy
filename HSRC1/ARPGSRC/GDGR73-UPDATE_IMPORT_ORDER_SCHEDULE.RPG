     C**N99                MOVE ER,8      D@MSG
     C**                   MOVE *ON       *IN99
 %001C**                   ENDIF
     C                     ENDIF
      *
     C           D@DAYS    IFEQ *ZERO
     C  N99                MOVE ER,4      D@MSG
     C                     SETON                     6599
     C                     ENDIF
      *
     C           D@SPDY    IFEQ *ZERO
     C  N99                MOVE ER,5      D@MSG
     C                     SETON                     6699
     C                     ENDIF
      *
      * SET DATES
     C           *IN99     IFEQ *OFF
     C           D@OPTN    IFGE '4'
     C                     EXSR #DSET2
     C                     ELSE
     C                     EXSR #DSET
     C                     ENDIF
     C                     ENDIF
      *
     C           D@DDCT    IFLE W@END
     C  N99                MOVE ER,6      D@MSG
     C                     SETON                     6499
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
