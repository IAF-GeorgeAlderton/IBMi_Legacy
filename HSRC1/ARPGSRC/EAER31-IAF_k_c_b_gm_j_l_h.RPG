     C*================================================================
     C           *ENTRY    PLIST
     C                     PARM           P@US   10        ﾏｰﾅﾞｰﾎﾟﾜﾎｧｰﾓ
     C                     PARM           P@YMD   8        IS THIS DELIVER
     C*================================================================
     C*================================================================
     C                     MOVE P@YMD     P@YMDX
     C                     Z-ADDP@YY      P@YY1
     C                     Z-ADDP@MM      P@MM1
     C                     Z-ADDP@DD      P@DD1
     C                     TIME           WTIME
     C*--------------------
     C                     DO   *HIVAL
     C                     READ DC#WP10                  90
     C   90                LEAVE
     C*
     C                     EXSR #NBR
     C                     EXSR DA#PP
     C                     UPDATDC#WP101
     C                     ENDDO
     C*--------------------
     C                     SETON                     LR
     C                     RETRN
     C* DUMMY READ
     C                     READ DA#PP11                  90
     C                     READ DC#WP11                  90
     C*================================================================
     C* ﾆﾞｬkｬcNO ﾃ]nﾜｰﾓ F
     C*================================================================
     C           #NBR      BEGSR
     C           1         CHAINDC#WP20              90
      *
     C*===読めない時===*
     C           *IN90     IFEQ '1'
     C                     Z-ADDB8SAMM    DCMM
     C                     Z-ADD00001     DCNBR
     C                     EXCPT$ADD
     C                     ELSE
     C*===読めた時===*
     C           DCMM      IFNE B8SAMM
     C                     Z-ADDB8SAMM    DCMM
     C                     Z-ADD00001     DCNBR
     C                     EXCPT$UPD
     C                     ELSE
     C           DCNBR     ADD  1         DCNBR
     C                     EXCPT$UPD
     C                     END
     C                     END
      *
     C                     ENDSR
     C*================================================================
     C* ﾆﾞｬkｬc ﾓbﾈg F
     C*================================================================
     C           DA#PP     BEGSR
     C                     TIME           WTIME
     C                     MOVE *BLANK    B8SKBN           ﾅhﾆﾞﾑﾃ-nﾞ
     C                     Z-ADD0         B8SKYY           ﾅhﾆﾞﾑﾑmbﾍﾞ YY
     C                     Z-ADD0         B8SKMM                      MM
     C                     Z-ADD0         B8SKDD                      DD
     C                     Z-ADDWYY       B8KOYY           ﾃcﾆ]ﾍﾞ YY   Y
     C                     Z-ADDWMM       B8KOMM                  MM   Y
     C                     Z-ADDWDD       B8KODD                  DD   Y
     C                     Z-ADDWJI       B8KOJI           ﾃcﾆ]ﾆﾞf] HH Y
     C                     Z-ADDWFN       B8KOFN                    MM Y
     C                     MOVELP@US      B8KONA           ﾃcﾆ]ﾅgﾞﾑcﾆzxb
     C                     Z-ADDDCNBR     B8RENO           ﾆﾞﾏkﾏcNO.
     C                     Z-ADD0         B8SAYY           ﾅhﾈbﾍﾞ YY
     C                     Z-ADD0         B8SAMM                  MM
     C                     Z-ADD0         B8SADD                  DD
     C* dﾎ､iﾞ]ﾍﾟ]ﾍｭc ﾝｰh ﾎabﾓ
     C* ﾆﾏlfmﾌbﾍﾞ
     C           B8TYMD    IFLE P@YMD1
     C                     WRITEDC#WP111
     C                     Z-ADDWYY       B8FNYY           dﾎ ﾉcﾍ]ﾆｭ ﾌｮﾃc
     C                     Z-ADDWMM       B8FNMM                  MM
     C                     Z-ADDWDD       B8FNDD                  DD
     C                     ENDIF
     C**
     C                     WRITEDA#PP111
     C                     ENDSR
     C*================================================================
     ODC#WP20 EADD             $ADD
     O                         DCMM       2
     O                         DCNBR      7
     O        E                $UPD
     O                         DCMM       2
     O                         DCNBR      7
