     C                     MOVE WTKR1     L1TKR1
     C                     MOVE WTKR2     L1TKR2
     C                     MOVE WTKR3     L1TKR3
     C                     MOVE WTKR4     L1TKR4
     C                     MOVE PKOTI     L1KKTI
     C                     Z-ADD@KBMN     L1UKOJ
     C                     MOVE PUKER     L1UKER
      *
     C*------------------------------------*
     C*  ..構成品かんばん切替マスター..  *
     C*------------------------------------*
     C                     SETOF                     10
     C                     MOVE PRECD     I
     C                     MOVE *BLANK    L1KTEI
     C                     Z-ADD0         L1BMON
     C                     MOVE *BLANK    L1SHIN
     C                     MOVE *BLANK    WMTKR
      *
     C           KEY4      CHAINAKEPL011             10
     C           *IN10     IFEQ '0'
     C           M3SKJY    ANDEQ'D'
     C           M3SKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '0'
     C                     MOVE HKO,I     L1KTEI
     C                     Z-ADDHBM,I     L1BMON
     C                     MOVE HHN,I     L1SHIN
      *
     C                     SETOF                     11
     C                     DO   *HIVAL
     C           I         SUB  1         I
     C           I         IFEQ 0
     C                     SETON                     11
     C                     ELSE
      *
     C           HBN,I     IFNE *BLANK
     C           HBN,I     IFNE '------'
     C           HBN,I     ANDNE'++++++'
     C                     MOVE HBN,I     WMTKR
     C                     SETON                     11
     C                     END
     C                     END
      *
     C                     END
     C  N11                END
     C                     END
      *
     C*------------------------------*
     C*  ..構成部品情報マスター..  *
     C*------------------------------*
     C                     SETOF                     10
     C                     MOVE *ZERO     L1ZETI
     C           KEY5      CHAINAKCPL011             10
     C           *IN10     IFEQ '0'
     C                     MOVE M1ZENO    L1ZETI
     C                     END
      *
     C                     Z-ADD@GEKN     L1KSSU
     C                     MOVE '6'       L1DTKO
     C                     MOVE *BLANK    L1DTHE
     C                     MOVE *BLANK    L1KCD1
     C                     MOVE *BLANK    L1KCD2
     C                     MOVE 'G001'    L1YOUS
      *
     C*------------------------------*
     C*  ..工程内所番地マスター..  *
     C*------------------------------*
     C                     MOVE *BLANK    WKCD1
     C                     MOVE *BLANK    WKCD2
     C           KEY2      SETGTAAJPL111
     C                     SETOF                     10
     C           KEY2      REDPEAAJPL111                 10
      *
     C           *IN10     IFEQ '0'
     C                     MOVE CJKDAI    WKCD1
     C                     MOVE CJKSYO    WKCD2
     C                     Z-ADD0         CJAKYY
     C                     Z-ADD0         CJAKMM
     C                     Z-ADD0         CJAKDD
     C                     MOVE L1SHN1    CJHIN1
     C                     MOVE L1SHN2    CJHIN2
     C                     MOVE L1SHN3    CJHIN3
     C                     MOVE WMTK1     CJMBN1
     C                     MOVE WMTK2     CJMBN2
     C                     MOVE WMTK3     CJMBN3
     C                     MOVE WMTK4     CJMBN4
     C                     UPDATAAJPL111
     C                     END
      *
     C                     MOVE WKCD1     L1KCD1
     C                     MOVE WKCD2     L1KCD2
      *
     C           *IN15     IFEQ '0'
     C                     UPDATAKBPL011
     C                     ELSE
     C                     WRITEAKBPL011
     C                     END
      *
     C                     END
     C                     ENDSR
      *
     C*---------------------------------------------------------------*
     C* #KUBN -->処理区分                                           *
     C* 5->新所番地が変わった時、旧所番地が失効日・新所番地が追加   *
     C*---------------------------------------------------------------*
     C           #SBR5     BEGSR
      *
     C*------------------*
     C*  ..旧所番地..  *
     C*------------------*
     C           POTKR     IFNE *BLANK
     C                     MOVE POTKR     WTKRO
      *
     C*--------------------------------*
     C*  ..構成品かんばんマスター..  *
     C*--------------------------------*
     C           KEY1      SETGTAKBPL011
      *
     C                     SETOF                     16
     C           KEY1      REDPEAKBPL011                 16
     C           *IN16     IFEQ '0'
     C           L1SKJY    ANDEQ'D'
     C           L1SKHZ    ANDLE*DATE
     C                     SETON                     16
     C                     END
      *
     C           *IN16     IFEQ '0'
     C                     Z-ADDL1UKBI    L1TKBI
     C                     MOVE L1TKBI    PTKBI
     C                     Z-ADD@UKHZ     L1STHZ
     C                     Z-ADD@UBIN     L1SBIN
     C                     MOVE '7'       L1DTKO
     C                     MOVE *BLANK    L1DTHE
     C                     Z-ADD*DATE     L1KOHZ
     C                     TIME           L1TIME
     C                     MOVE PUS       L1KOME
     C                     UPDATAKBPL011
     C                     END
      *
     C*------------------------------*
     C*  ..工程内所番地マスター..  *
     C*------------------------------*
     C           KEY2      SETGTAAJPL111
     C                     SETOF                     10
     C           KEY2      REDPEAAJPL111                 10
      *
     C           *IN10     IFEQ '0'
     C                     Z-ADD@UKHZ     CJAKHZ
     C                     UPDATAAJPL111
     C                     END
     C                     END
      *
     C*----------------------------*
     C*  ..新所番地　追加処理..  *
     C*----------------------------*
     C           PNTKR     IFNE *BLANK
     C                     EXSR #SBR2
     C                     END
      *
     C                     ENDSR
