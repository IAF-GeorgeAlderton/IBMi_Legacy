     C                     MOVE *BLANK    CJMBN3
     C                     MOVE *BLANK    CJMBN4
     C                     Z-ADD0         CJSLOT
     C                     UPDATAAJPL111
     C                     END
      *
     C           #STP1     TAG
     C                     END
      *
     C                     ENDSR
