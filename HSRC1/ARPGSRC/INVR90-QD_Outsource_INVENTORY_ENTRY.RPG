     C*                    MAIN ROUTINE
     C**************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'00'      #SCRN0           USER ID
     C           @@ID      CASEQ'01'      #SCRN1           APICS
     C**         @@ID      CASEQ'02'      #SCRN2           LOCATION
     C           @@ID      CASEQ'03'      #SCRN3           BIN#
     C           @@ID      CASEQ'04'      #SCRN4           CANCEL APCS
     C**         @@ID      CASEQ'05'      #SCRN5           CANCEL ASJ
     C**         @@ID      CASEQ'06'      #SCRN6           # OF KAN LOC
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C**************************************************************************
     C*         INITIALIZE
     C**************************************************************************
     C           *INZSR    BEGSR
      *
     C           P#BRC     PLIST
     C                     PARM           PMAREA100
     C                     PARM           PMBYTE  3
     C                     PARM           PMCHK   1
     C                     PARM           PMRTCD  1
     C           K#INV     KLIST
     C                     KFLD           K@DATE  80
     C                     KFLD           K@BAR  17
      *
     C           K#INVV    KLIST
     C                     KFLD           K@DATE  80
     C                     KFLD           K@PREV 17
      *
     C           KEY4      KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
      *
     C                     Z-ADD*DATE     K@DATE
      *
     C                     MOVE '00'      @@ID    2
      *
     C                     TIME           @TIME  140
     C*
     C                     ENDSR
     C*************************************************************************
     C*          USER ID ENTRY
     C*************************************************************************
     C           #SCRN0    BEGSR
      *
     C           MSG       IFEQ *BLANKS
     C                     CLEARD@USER
     C                     ENDIF
      *
     C                     EXFMTDSP00
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
TCHK1C*          D@USER    IFNE 0
TCHK1C*                    MOVE '01'      @@ID
TCHK1C*                    ENDIF
TCHK1C                     EXSR #CHK00
TCHK1C           *IN99     IFEQ *OFF
TCHK1C                     MOVEL'01'      @@ID
TCHK1C                     END
     C                     ENDSL
      *
     C                     ENDSR
TCHK1C*************************************************************************
TCHK1C* TM-CODE CHECK
TCHK1C**************************************************************************
TCHK1C           #CHK00    BEGSR
TCHK1C*
TCHK1C                     SETOF                     6199
TCHK1C*
TCHK1C                     DO
TCHK1C*
TCHK1C           D@USER    IFEQ 111111
TCHK1C           D@USER    OREQ 222222
TCHK1C                     LEAVE
TCHK1C                     END
TCHK1C*
TCHK1C           D@USER    CHAINALBPL301             90
TCHK1C           *IN90     IFEQ *OFF
TCHK1C           ALSKJY    ANDEQ*BLANK
TCHK1C                     ELSE
TCHK1C                     SETON                     6199
TCHK1C           MSG       IFEQ *BLANK
TCHK1C                     MOVELERR,6     MSG
TCHK1C                     END
TCHK1C                     END
TCHK1C*
TCHK1C                     ENDDO
TCHK1C*
TCHK1C                     ENDSR
     C**************************************************************************
     C           #SCRN1    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE *OFF      *IN99                        F5
     C                     MOVE *OFF      *IN61                        F5
     C                     MOVE *BLANK    D@ERR                        F5
     C                     MOVE '00'      @@ID
     C           *INKB     WHEQ *ON
     C                     MOVE D@APCV    K@PREV
     C           K#INVV    CHAININVPP90              96
     C           *IN96     IFEQ '0'
     C                     MOVE IVBARC    D@BARV
     C                     MOVELIVBIN#    D@BINN
     C                     MOVE '0'       *INKD
     C           *INKC     DOWNE'1'
     C           *INKD     ANDNE'1'
     C                     EXFMTDSP07
     C           *INKC     IFEQ '1'
     C                     LEAVE
     C                     ENDIF
     C           *INKD     IFEQ '1'
     C                     DELETINVPP90
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     MOVE '03'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
     C*     CHECK
     C**************************************************************************
     C           #CHK1     BEGSR
      *
     C                     MOVE *OFF      *IN99                        F5
     C                     MOVE *OFF      *IN61                        F5
     C                     MOVE *BLANK    D@ERR                        F5
      *
     C           D@APCS    IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     D@ERR
     C                     ENDIF
      *
     C                     MOVELD@APCS    K@BAR     P
      * CHECK DIGIT
     C                     MOVELD@APCS    PMAREA    P
     C                     MOVE '014'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C  N99                MOVELERR,1     D@ERR
     C                     SETON                     9961
     C                     ELSE
     C           PMCHK     IFNE WWCHK
     C  N99                MOVELERR,1     D@ERR
     C                     SETON                     9961
     C                     ENDIF
     C                     ENDIF
      *
     C           WWZETI    CHAINFCETL11              90
     C           *IN90     IFEQ *ON
     C  N99                MOVELERR,1     D@ERR
     C                     SETON                     9961
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C                     DO
     C           KEY4      CHAINAAMPL11              89
     C           *IN89     IFEQ *ON
     C           CKSKJY    ORNE *BLANK
     C  N99                MOVELERR,1     D@ERR
     C                     SETON                     9961
     C                     LEAVE
     C                     END
     C                     MOVEL*OFF      W@FND   1
     C                     Z-ADD1         X       20
     C           *ZERO     LOKUPDEP,X                    88
     C                     DO   *HIVAL
     C           X         IFGT *ZERO
     C           DEP,X     IFEQ 0111
     C           DEP,X     OREQ 8990
     C           DEP,X     OREQ 0000
     C                     ELSE
     C                     MOVEL*ON       W@FND
     C                     LEAVE
     C                     END
     C                     END
     C           X         IFLE *ZERO
     C                     LEAVE
     C                     ELSE
     C                     SUB  1         X
     C                     END
     C                     ENDDO
     C           W@FND     IFEQ *OFF
     C  N99                MOVELERR,1     D@ERR
     C                     SETON                     9961
     C                     END
     C                     ENDDO
     C                     END
      *
     C                     MOVELD@APCS    D@BAR     P
     C                     MOVE @@ID      ZZID    2
      *
     C                     ENDSR
      *----------------------------------------------
     C           #SCRN3    BEGSR
      *----------------------------------------------
     C                     EXFMTDSP03
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '01'      @@ID
     C                     SETOF                     9961
     C                     MOVE *BLANK    D@ERR                        F5
     C                     OTHER
     C                     EXSR #CHK3
     C           *IN99     IFEQ *OFF
     C                     EXSR #WRT
     C                     MOVE ZZID      @@ID
     C                     MOVE D@APCS    D@APCV 17
     C                     MOVE *BLANK    D@APCS
     C                     MOVE *BLANK    D@BIN#
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *----------------------------------------------
     C           #CHK3     BEGSR
      *----------------------------------------------
     C                     MOVE *OFF      *IN99                        F5
     C                     MOVE *OFF      *IN61                        F5
     C                     MOVE *BLANK    D@ERR                        F5
     C           D@BIN#    IFEQ *BLANK
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*     WRITE
     C**************************************************************************
     C           #WRT      BEGSR
      *
     C                     CLEARINVPP901
      *
     C                     Z-ADD*DATE     IVDATE
     C                     TIME           IVTIME
     C                     MOVELD@USER    IVUSER
     C                     MOVELD@BAR     IVBARC
     C                     MOVELA2BHB1    IVSHN1
     C                     MOVELA2BHB2    IVSHN2
     C                     MOVELA2BHB3    IVSHN3
     C                     MOVELD@BIN#    IVBIN#
     C                     MOVELDEP,X     IVSUPL
     C                     Z-ADDDEP,X     W@SUPL  40
     C           W@SUPL    CHAINFGBPL01              87
     C           *IN87     IFEQ *OFF
     C                     MOVELB2SMEI    IVSUPN
     C                     END
     C*
     C                     WRITEINVPP901
      *
     C                     ENDSR
     C**************************************************************************
     C*    4TH SCREEN (CANCEL APCIS)
     C**************************************************************************
     C           #SCRN4    BEGSR
      *
     C                     EXFMTDSP04
      *
     C                     SELEC
     C           *INKG     WHEQ *ON
     C                     MOVE '01'      @@ID
     C                     SETOF                     9961
     C                     MOVE *BLANK    D@ERR                        F5
     C                     OTHER
     C                     EXSR #CHK4
     C           *IN99     IFEQ *OFF
     C                     EXSR #DLT
      *
     C                     MOVE *BLANK    D@APCS
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
     C*     CHECK
     C**************************************************************************
     C           #CHK4     BEGSR
     C*
     C                     MOVE *BLANK    D@ERR                        F5
     C                     SETOF                     996162
      *
     C           D@APCS    IFEQ *BLANK
     C                     SETON                     9961
     C                     ELSE
     C                     MOVELD@APCS    K@BAR     P
     C           K#INV     CHAININVPP90             N90
     C           *IN90     IFEQ *ON
     C  N99                MOVELERR,3     D@ERR
     C                     SETON                     9961
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*       CANCEL
     C**************************************************************************
     C           #DLT      BEGSR
     C*
     C           K#INV     CHAININVPP90              90
     C           *IN90     IFEQ *OFF
     C                     DELETINVPP90
     C                     ENDIF
      *
     C                     ENDSR
** ERR
