     H            Y.
     F** MRAR83 *********************************************
     F* RECEIVE SEND BACK DATA FROM ASJ                     *
     F*     TRANCOM-ITS            2012.10.18               *
     F*******************************************************
     FMRBPPT2 IF  E                    DISK
      *
     FMRAPPT1 O   E                    DISK
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   40WJFF
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C                     TIME           WTIME
      *----------------------------------------------------------------
      * MRBPPT1 ---> MRAPPT1
      *----------------------------------------------------------------
     C                     SETOF                     80
     C           1         SETLLMRBPPT21
     C                     READ MRBPPT21                 80
     C           *IN80     DOWEQ'0'
     C                     EXSR #SB520
     C                     READ MRBPPT21                 80
     C                     ENDDO
      *----------------------------------------------------------------
      * EXIT
      *----------------------------------------------------------------
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------------------
      * SEND BACK DATA FROM ASJ  (PROCESS INFORMATION)
      *----------------------------------------------------------------
     CSR         #SB520    BEGSR
     C                     CLEARMRAPPT11
     C                     MOVE EWSEQN    KTSEQN
     C                     MOVE EWSHN1    KTSHN1
     C                     MOVE EWSHN2    KTSHN2
     C                     MOVE EWSHN3    KTSHN3
     C                     MOVE EWSEHI    KTSEHI
     C                     MOVE EWKENO    KTKENO
     C                     MOVE EWKENA    KTKENA
     C                     MOVE EWKEED    KTKEED
     C                     MOVE EWTEHI    KTTEHI
     C                     MOVE EWHANN    KTHANN
     C                     MOVE EWSHN4    KTSHN4
     C                     MOVE EWSAYY    KTSAYY
     C                     MOVE EWSAMM    KTSAMM
     C                     MOVE EWSADD    KTSADD
     C                     MOVE EWSATH    KTSATH
     C                     MOVE EWSATM    KTSATM
     C                     MOVE EWSATS    KTSATS
     C                     MOVE EWKSEQ    KTKSEQ
     C                     MOVE EWMKTE    KTMKTE
     C                     MOVE EWMBMN    KTMBMN
     C                     MOVE EWMSNO    KTMSNO
     C                     MOVE EWMBN1    KTMBN1
     C                     MOVE EWMBN2    KTMBN2
     C                     MOVE EWMBN3    KTMBN3
     C                     MOVE EWMBN4    KTMBN4
     C                     MOVE EWKDAI    KTKDAI
     C                     MOVE EWGKYY    KTGKYY
     C                     MOVE EWGKMM    KTGKMM
     C                     MOVE EWGKDD    KTGKDD
     C                     MOVE EWGKJI    KTGKJI
     C                     MOVE EWGKHU    KTGKHU
     C                     MOVE EWGKNM    KTGKNM
      *              ------------------
     C                     WRITEMRAPPT11
      *              ------------------
     CSR         ESB520    ENDSR
