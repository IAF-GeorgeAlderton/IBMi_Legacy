     C                     MOVELERR,4     F99ER2
     C                     LEAVE
     C                     END
     C                     MOVELL1SHN1    W3SHN1
     C                     MOVELL1SHN2    W3SHN2
     C                     MOVELL1SHN3    W3SHN3
     C*
     C                     ENDDO
     C*
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     END
     C*
     C                     ENDSR
     C*************************************************************************
     C*     4TH SCREEN(ASJ KANBAN)
     C**************************************************************************
     C           #FMT40    BEGSR
     C*
     C                     EXFMTFMT400
     C                     MOVEL*BLANK    F4ERR
     C*
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKG     WHEQ *ON
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     MOVEL*BLANK    W2SHIN
     C                     MOVEL*BLANK    W3SHIN
     C                     MOVEL*BLANK    W4SHIN
     C                     MOVE '20'      @@ID
     C                     OTHER
     C                     EXSR #CHK40
     C           *IN99     IFEQ *OFF
     C                     EXSR #WRTOK
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     MOVEL*BLANK    W2SHIN
     C                     MOVEL*BLANK    W3SHIN
     C                     MOVEL*BLANK    W4SHIN
     C                     MOVE '20'      @@ID
     C                     EXFMTFMT900
     C                     ELSE
     C                     EXSR #WRTER
     C                     END
     C                     ENDSL
     C*
     C                     ENDSR
     C**************************************************************************
     C*     4TH SCREEN CHECK
     C**************************************************************************
     C           #CHK40    BEGSR
     C*
     C                     MOVEL*BLANK    W4SHIN
     C                     MOVELF4KNBN    W4KNBN
     C                     SETOF                     9961
     C*
     C                     DO
     C*
     C           F4KNBN    IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     F4ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,3     F99ER2
     C                     LEAVE
     C                     END
     C*
     C           W4ZETI    IFNE L1ZETI
     C                     SETON                     9961
     C                     MOVELERR,1     F4ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,18    F99ER2
     C                     LEAVE
     C                     END
     C* CHECK DIGIT
     C                     MOVELW4KNBN    PMAREA    P
     C                     MOVE '016'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     F4ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,15    F99ER2
     C                     LEAVE
     C                     END
     C           PMCHK     IFNE W4CHK
     C                     SETON                     9961
     C                     MOVELERR,1     F4ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,15    F99ER2
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     ELSE
     C                     MOVELL1SHN1    W4SHN1
     C                     MOVELL1SHN2    W4SHN2
     C                     MOVELL1SHN3    W4SHN3
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*       WRITE A OK RECORD
     C**************************************************************************
     C           #WRTOK    BEGSR
     C*
     C                     CLEARALIPP011
     C*
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    A8DATE
     C                     Z-ADDWSSTM6    A8TIME
     C                     MOVEL#USER     A8USER
     C                     MOVEL#WSID     A8WSID
     C                     MOVEL#PGM      A8PGID
     C*
     C                     MOVELF1USRC    A8TMCD
     C*
     C                     MOVELW@ERR     A8ERR
     C*
     C                     MOVELF3LOC     A8BRC2
     C                     MOVELW3SHN1    A8PR21
     C                     MOVELW3SHN2    A8PR22
     C                     MOVELW3SHN3    A8PR23
     C                     MOVELW3ZETI    A8B2LZ
     C                     MOVELW3LC#1    A8B2L1
     C                     MOVELW3LC#2    A8B2L2
     C                     MOVELW3LC#3    A8B2L3
     C                     MOVELW3LC#4    A8B2L4
     C*
     C                     MOVELF2KNBN    A8BRC1
     C           W@KID     IFEQ *BLANK
     C                     MOVEL@@K       A8KIND
     C                     ELSE
     C                     MOVELW@KID     A8KIND
     C                     END
     C                     MOVELW2SHN1    A8PR11
     C                     MOVELW2SHN2    A8PR12
     C                     MOVELW2SHN3    A8PR13
     C*
     C                     MOVELF4KNBN    A8BRC3
     C                     MOVELW4SHN1    A8PR31
     C                     MOVELW4SHN2    A8PR32
     C                     MOVELW4SHN3    A8PR33
     C*
     C           W@ERR     IFNE *BLANK
     C                     MOVELF99ER1    A8EM01
     C                     MOVELF99ER2    A8EM02
     C                     END
     C*
     C                     WRITEALIPP011
     C*
     C                     ENDSR
     C**************************************************************************
     C*       WRITE A ERROR RECORD
     C**************************************************************************
     C           #WRTER    BEGSR
     C*
     C                     MOVEL'E'       W@ERR
     C*
     C                     EXSR #WRTOK
     C*
     C                     MOVEL*BLANK    W@ERR
     C*
     C                     ENDSR
     C**************************************************************************
