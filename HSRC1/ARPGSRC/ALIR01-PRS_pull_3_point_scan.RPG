     C*                    MAIN ROUTINE
     C**************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'10'      #FMT10
     C           @@ID      CASEQ'20'      #FMT20
     C           @@ID      CASEQ'30'      #FMT30
     C           @@ID      CASEQ'40'      #FMT40
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C**************************************************************************
     C*         INITIALIZE
     C**************************************************************************
     C           *INZSR    BEGSR
      * FOR KANBAN CHECK DEGIT
     C           P#BRC     PLIST
     C                     PARM           PMAREA100
     C                     PARM           PMBYTE  3
     C                     PARM           PMCHK   1
     C                     PARM           PMRTCD  1
      *
     C           K#KEY     KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
      *
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    W@DATE  80
     C                     Z-ADDWSSTM6    @@TIM   60
     C*
     C                     CLEARFMT100
     C                     CLEARFMT200
     C                     CLEARFMT300
     C                     CLEARFMT400
     C                     MOVEL*BLANK    W2SHIN
     C                     MOVEL*BLANK    W3SHIN
     C                     MOVEL*BLANK    W4SHIN
     C                     MOVEL*BLANK    W@ERR   1
     C*
     C                     MOVEL'10'      @@ID    2
     C                     MOVEL'A'       @@K     1
     C* DUMMY READ
     C                     READ ALIPP01                  98
     C*
     C                     ENDSR
     C*************************************************************************
     C*     1ST SCREEN(TM-CODE ENTRY)
     C**************************************************************************
     C           #FMT10    BEGSR
      *
     C                     EXFMTFMT100
     C                     MOVEL*BLANK    F1ERR
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK10
     C           *IN99     IFEQ *OFF
     C                     MOVE '20'      @@ID
     C                     END
     C                     ENDSL
      *
     C                     ENDSR
     C*************************************************************************
     C*     1ST SCREEN CHECK
     C**************************************************************************
     C           #CHK10    BEGSR
     C*
     C                     SETOF                     6199
     C* TM-CODE CHECK
     C           F1USRC    CHAINALBPL301             90
     C           *IN90     IFEQ *OFF
     C           ALSKJY    ANDEQ*BLANK
     C                     ELSE
     C                     SETON                     6199
     C           F1ERR     IFEQ *BLANK
     C                     MOVELERR,7     F1ERR
     C                     END
     C                     END
      *
     C                     ENDSR
     C*************************************************************************
     C*     2ND SCREEN(APICS/PLASTIC KANBAN)
     C**************************************************************************
     C           #FMT20    BEGSR
      *
     C                     SELEC
     C           @@K       WHEQ 'A'
     C                     MOVE TTL,1     F2TTL
     C           @@K       WHEQ 'P'
     C                     MOVE TTL,2     F2TTL
     C                     ENDSL
      *
     C                     EXFMTFMT200
     C                     MOVEL*BLANK    F2SERR
     C                     MOVEL*BLANK    F2ERR
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKE     WHEQ *ON
     C                     SELEC
     C           @@K       WHEQ 'A'
     C                     MOVE 'P'       @@K
     C           @@K       WHEQ 'P'
     C                     MOVE 'I'       @@K
     C                     OTHER
     C                     MOVE 'A'       @@K
     C                     ENDSL
     C                     OTHER
     C                     EXSR #CHK20
     C           *IN99     IFEQ *OFF
     C                     MOVE '30'      @@ID
     C                     ELSE
     C                     EXSR #WRTER
     C                     END
     C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
     C*     2ND SCREEN CHECK
     C**************************************************************************
     C           #CHK20    BEGSR
     C*
     C                     MOVEL*BLANK    W2SHIN
     C                     MOVE F2KNBN    W2KNBN
     C                     SETOF                     9961
     C*
     C                     DO
     C*
     C           F2KNBN    IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     F2ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,3     F99ER2
     C                     LEAVE
     C                     END
     C*
     C           @@K       IFEQ 'A'
     C           @@K       OREQ 'P'
     C           W2KANS    IFNE 'A'
     C           W2KANS    ANDNE'R'
     C                     SETON                     9961
     C                     MOVELERR,1     F2ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,8     F99ER2
     C                     END
     C                     ELSE
     C           W2KANS    IFGE '0'
     C           W2KANS    ANDLE'9'
     C                     ELSE
     C                     SETON                     9961
     C                     MOVELERR,1     F2ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,8     F99ER2
     C                     END
     C                     END
     C*
     C           W2ZETI    CHAINFCETL11              90
     C           *IN90     IFEQ *ON
     C           A2GSKD    ORNE *BLANK
     C                     SETON                     9961
     C           F2ERR     IFEQ *BLANK
     C                     MOVELERR,1     F2ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,4     F99ER2
     C                     END
     C                     ELSE
     C                     MOVELA2BHB1    W2SHN1
     C                     MOVELA2BHB2    W2SHN2
     C                     MOVELA2BHB3    W2SHN3
     C                     END
     C* CHECK DIGIT
     C                     MOVELW2KNBN    PMAREA    P
     C                     MOVE '014'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C           F2ERR     IFEQ *BLANK
     C                     MOVELERR,1     F2ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,15    F99ER2
     C                     END
     C                     END
     C           PMCHK     IFNE W2CHK
     C                     SETON                     9961
     C           F2ERR     IFEQ *BLANK
     C                     MOVELERR,1     F2ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,15    F99ER2
     C                     END
     C                     END
     C   99                LEAVE
      * PLASTIC / APICS
     C                     SELEC
     C           @@K       WHEQ 'A'
     C                     EXSR #APC
     C           @@K       WHEQ 'P'
     C                     EXSR #PLC
     C                     ENDSL
     C   99                LEAVE
     C*
     C           'PRS'     LOKUPPRC                      10
     C  N10      'PRS'     LOKUPPRO                      10
     C           *IN10     IFEQ *OFF
     C                     SETON                     9961
     C           F2ERR     IFEQ *BLANK
     C                     MOVELERR,10    F2ERR
     C                     MOVELERR,10    F99ER1
     C                     MOVELERR,11    F99ER2
     C                     END
     C                     LEAVE
     C                     END
     C*
     C           K#AEB     KLIST
     C                     KFLD           W2SHN1
     C                     KFLD           W2SHN2
     C                     KFLD           W2SHN3
     C           K#AEB     SETLLAEBPL01
     C                     DO   *HIVAL
     C           K#AEB     READEAEBPL01                  90
     C   90                LEAVE
     C           AFSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           AFKOTI    IFEQ 'PRS'
     C                     MOVELAFKHIN    WFKHIN
     C                     LEAVE
     C                     END
     C                     ENDDO
     C           *IN90     IFEQ *ON
     C                     SETON                     9961
     C           F2ERR     IFEQ *BLANK
     C                     MOVELERR,10    F2ERR
     C                     MOVELERR,10    F99ER1
     C                     MOVELERR,11    F99ER2
     C                     END
     C                     LEAVE
     C                     END
     C*
     C           K#AEB     SETLLAKBPL07
     C                     DO   *HIVAL
     C           K#AEB     READEAKBPL07                  90
     C   90                LEAVE
     C           L1SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           L1STYY    IFNE 9999
     C                     ITER
     C                     END
     C           L1BMON    IFNE 8990
     C                     ITER
     C                     END
     C                     ENDDO
     C           *IN90     IFEQ *ON
     C                     SETON                     9961
     C           F2ERR     IFEQ *BLANK
     C                     MOVELERR,10    F2ERR
     C                     MOVELERR,10    F99ER1
     C                     MOVELERR,11    F99ER2
     C                     END
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     END
     C*
     C                     ENDSR
      *----------------------------------------------
     C           #PLC      BEGSR
      *----------------------------------------------
     C                     MOVE 'P'       W@KID   1
      *
     C                     DO
     C*
     C           K#KEY     CHAINAAMPL11              90
     C           *IN90     IFEQ *ON
     C           CKSKJY    ORNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     F2ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,4     F99ER2
     C                     LEAVE
     C                     END
     C*
     C           'C'       LOKUPKK                       10
     C  N10      'C'       LOKUPKX                       10
     C           *IN10     IFEQ *OFF
     C                     SETON                     9961
     C                     MOVELERR,5     F2SERR
     C                     MOVELERR,1     F2ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,5     F99ER2
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
      *----------------------------------------------
     C           #APC      BEGSR
      *----------------------------------------------
     C                     MOVE 'A'       W@KID
     C*
     C                     DO
     C*
     C           K#KEY     CHAINAGAPL31              90
     C           *IN90     IFEQ *ON
     C           CBSKJY    ORNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,6     F2SERR
     C                     MOVELERR,1     F2ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,6     F99ER2
     C                     LEAVE
     C                     END
     C           K#KEY     CHAINAAMPL11              90
     C           *IN90     IFEQ *ON
     C           CKSKJY    ORNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     F2ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,4     F99ER2
     C                     LEAVE
     C                     END
      *
     C           CBKDAI    LOKUPKK                       10
     C  N10      CBKDAI    LOKUPKX                       10
     C           *IN10     IFEQ *OFF
     C                     SETON                     9961
     C                     MOVELERR,6     F2SERR
     C                     MOVELERR,1     F2ERR
     C                     MOVELERR,1     F99ER1
     C                     MOVELERR,6     F99ER2
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
