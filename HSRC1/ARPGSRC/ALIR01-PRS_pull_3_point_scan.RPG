     C                     OTHER
     C                     EXSR #CHK30
     C           *IN99     IFEQ *OFF
     C                     MOVE '40'      @@ID
     C                     ELSE
     C           F3LOC     IFNE *BLANK
     C                     EXSR #WRTER
