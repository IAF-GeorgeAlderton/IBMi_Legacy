     C******************************************************
     C*  START  PROGRAM <MFBR31>                           *
     C******************************************************
     C           *ENTRY    PLIST
     C                     PARM           US     10        ﾏｰﾅﾞｰ
     C                     PARM           PYMKJ   6        YY(4),MM
     C                     PARM           PKOJO   4        KOJO
     C                     PARM           PJKBN   1        0=ﾈbg｣1=ﾒ[]
     C                     MOVE *DATE     UYMD
     C                     TIME           UTIME
     C                     MOVE PYMKJ     HIZK
     C                     MOVE PKOJO     KOJO    40
     C                     MOVE PJKBN     JKBN    1
     C                     Z-ADDGMM       M       20
     C                     Z-ADD0         DN
     C                     Z-ADD0         DE
     C                     Z-ADD0         SK
     C           KOJO      IFEQ 9999
     C                     Z-ADD0         GKOJO   40
     C                     ELSE
     C                     Z-ADDKOJO      GKOJO   40
     C                     END
     C                     MOVE *BLANK    GSYS1   4
     C                     MOVE *BLANK    GSYS2   4
     C           RKEY      KLIST
     C                     KFLD           GYY
     C                     KFLD           GKOJO
     C                     KFLD           GSYS1
     C                     KFLD           GSYS2
     C           RKEYR     KLIST
     C                     KFLD           GYY
     C                     KFLD           GKOJO
     C           RKEY9     KLIST
     C                     KFLD           GYY
     C**RERUN ********CLR  **************
     C           JKBN      IFEQ '1'
     C           RKEY      SETLLMFBPL321
     C           STEP71    TAG
     C           KOJO      IFEQ 9999
     C           RKEY9     READEMFBPL321                 71
     C                     ELSE
     C           RKEYR     READEMFBPL321                 71
     C                     END
     C           *IN71     CABEQ'1'       STEP72
     C           P1SKJY    CABEQ'D'       STEP71
     C                     Z-ADD0         DN,M
     C                     Z-ADD0         DE,M
     C                     Z-ADD0         SK,M
     C                     UPDATMFBPL321
     C                     GOTO STEP71
     C                     END
     C           STEP72    TAG
     C************************************
     C                     Z-ADD0         DN
     C                     Z-ADD0         DE
     C                     Z-ADD0         SK
     C           NKEY      KLIST
     C                     KFLD           M2DTY4
     C                     KFLD           M2KJCD
     C                     KFLD           M2SYS1
     C                     KFLD           M2SYS4
     C*********初回のみの処理
     C           STEP03    TAG
     C                     SETOF                     3031
     C                     READ MFBPL201                 30
     C           *IN30     CABEQ'1'       STEP90
     C           M2HIZK    CABNEHIZK      STEP03
     C                     MOVELM2SYS2    M2SYS4  4
     C                     SETON                     77
     C           NKEY      CHAINMFBPL321             31
     C           *IN31     IFEQ '1'
     C                     MOVE *BLANK    P1SKJY
     C                     Z-ADD0         P1SKYY
     C                     Z-ADD0         P1SKMM
     C                     Z-ADD0         P1SKDD
     C                     Z-ADDUYY4      P1KOYY
     C                     Z-ADDUMM       P1KOMM
     C                     Z-ADDUDD       P1KODD
     C                     Z-ADDUHH       P1KOHH
     C                     Z-ADDUSS       P1KOSS
     C                     MOVE US        P1KOME
     C                     Z-ADDM2KJCD    P1KJCD
     C                     MOVE M2SYS1    P1SYS1
     C                     MOVELM2SYS2    P1SYS2
     C                     Z-ADDM2DTY4    P1DTY4
     C                     MOVE M2KTCD    P1KTCD
     C                     MOVE M2KIBN    P1KIBN
     C                     MOVE M2KIHS    P1KIHS
     C                     Z-ADDM2RPMH    P1RPMH
     C                     Z-ADDM2DNKI    DN,M
     C                     Z-ADDM2DEKI    DE,M
     C                     Z-ADDM2SOUG    SK,M
     C                     END
     C                     Z-ADDM2DTY4    KDTY4   40
     C                     Z-ADDM2KJCD    KKJCD   40
     C                     MOVE M2SYS1    KSYS1   4
     C                     MOVELM2SYS2    KSYS2   4
     C                     Z-ADDM2DNKI    DN,M
     C                     Z-ADDM2DEKI    DE,M
     C                     Z-ADDM2SOUG    SK,M
     C*********通常処理
     C           STEP04    TAG
     C                     SETOF                     30
     C                     READ MFBPL201                 30
     C           *IN30     CABEQ'1'       STEP90
     C           M2HIZK    CABNEHIZK      STEP04
     C           M2DTY4    IFEQ KDTY4
     C           M2KJCD    ANDEQKKJCD
     C           M2SYS1    ANDEQKSYS1
     C           M2SYS2    ANDEQKSYS2
     C           DN,M      ADD  M2DNKI    DN,M
     C           DE,M      ADD  M2DEKI    DE,M
     C           SK,M      ADD  M2SOUG    SK,M
     C                     GOTO STEP04
     C                     ELSE
     C           *IN77     IFEQ '1'
     C           *IN31     IFEQ '1'
     C                     WRITEMFBPL321
     C                     ELSE
     C                     UPDATMFBPL321
     C                     END
     C                     SETOF                     77
     C                     END
     C                     MOVELM2SYS2    M2SYS4  4
     C                     SETON                     77
     C           NKEY      CHAINMFBPL321             31
     C           *IN31     IFEQ '1'
     C                     MOVE *BLANK    P1SKJY
     C                     Z-ADD0         P1SKYY
     C                     Z-ADD0         P1SKMM
     C                     Z-ADD0         P1SKDD
     C                     Z-ADDUYY4      P1KOYY
     C                     Z-ADDUMM       P1KOMM
     C                     Z-ADDUDD       P1KODD
     C                     Z-ADDUHH       P1KOHH
     C                     Z-ADDUSS       P1KOSS
     C                     MOVE US        P1KOME
     C                     Z-ADDM2KJCD    P1KJCD
     C                     MOVE M2SYS1    P1SYS1
     C                     MOVELM2SYS2    P1SYS2
     C                     Z-ADDM2DTY4    P1DTY4
     C                     MOVE M2KTCD    P1KTCD
     C                     MOVE M2KIBN    P1KIBN
     C                     MOVE M2KIHS    P1KIHS
     C                     Z-ADDM2RPMH    P1RPMH
     C                     Z-ADD0         DN
     C                     Z-ADD0         DE
     C                     Z-ADD0         SK
     C                     END
     C                     Z-ADDM2DTY4    KDTY4   40
     C                     Z-ADDM2KJCD    KKJCD   40
     C                     MOVE M2SYS1    KSYS1   4
     C                     MOVELM2SYS2    KSYS2   4
     C                     Z-ADDM2DNKI    DN,M
     C                     Z-ADDM2DEKI    DE,M
     C                     Z-ADDM2SOUG    SK,M
     C                     GOTO STEP04
     C                     END
     C                     GOTO STEP04
     C           STEP90    TAG
     C           *IN77     IFEQ '1'
     C           *IN31     IFEQ '1'
     C                     WRITEMFBPL321
     C                     ELSE
     C                     UPDATMFBPL321
     C                     END
     C                     END
     C                     MOVEL'1'       *INLR
     C                     RETRN
