     C           *ENTRY    PLIST
     C                     PARM           PUS    15
     C******************
     C*１回のみの処理*
     C******************
     C           *IN10     IFEQ '0'
     C                     SETON                     10
     C                     TIME           WTIME   60
     C                     MOVELPUS       WNAME   9
     C                     EXCPTHD
     C*
     C                     Z-ADD0         HINKEN  30
     C                     Z-ADD0         BLRKEN  40
     C                     Z-ADD0         HINNO   30
     C                     MOVE J1HIN1    CHIN1   5
     C                     MOVE J1HIN2    CHIN2   5
     C                     MOVE J1HIN3    CHIN3   2
     C                     END
     C*総箱数カウンター＋１
     C                     ADD  1         BLRKEN
     C**************************
     C*入力品番で前工程の調査*
     C**************************
     C                     MOVE *BLANK    KOT3    3
     C                     MOVE *BLANK    KOT2    3
     C                     MOVE *BLANK    KOT1    3
     C                     MOVE *BLANK    KBN3    3
     C                     MOVE *BLANK    KBN2    3
     C                     MOVE *BLANK    KBN1    3
     C                     Z-ADD0         BMN3    40
     C                     Z-ADD0         BMN2    40
     C                     Z-ADD0         BMN1    40
     C*工程マスターで『ＢＺ』の工程を調べる*
     C           KEY1      KLIST
     C                     KFLD           J1HIN1
     C                     KFLD           J1HIN2
     C                     KFLD           J1HIN3
     C                     SETOF                     11
     C           KEY1      CHAINAAMPL111             11
     C           *IN11     IFEQ '1'
     C                     GOTO EXIT1
     C                     ELSE
     C           CKSKJY    IFEQ 'D'
     C           CKSKHZ    IFGE *DATE
     C                     GOTO EXIT1
     C                     END
     C                     END
     C                     END
     C*工程マスター現在の工程を調べる*
     C                     Z-ADD1         I       20
     C                     DO   15        I
     C                     Z-ADDCHG,I     CHG8
     C           CHG6      IFLE *DATE
     C                     MOVE SKT,I     GKT,I
     C                     MOVE SKB,I     GKB,I
     C                     Z-ADDSBM,I     GBM,I
     C                     ELSE
     C                     MOVE KKT,I     GKT,I
     C                     MOVE KKB,I     GKB,I
     C                     Z-ADDKBM,I     GBM,I
     C                     END
     C                     ENDDO
     C*現工程でＢＺ工程が有るか調べる*
     C                     Z-ADD1         I       20
     C                     DO   15        I
     C           GKT,I     IFEQ 'BZ '
     C                     GOTO BZKOT
     C                     END
     C                     ENDDO
     C                     GOTO EXIT1
     C*
     C           BZKOT     TAG
     C*１つ前工程*
     C                     SUB  1         I
     C           I         CABLE0         EXIT1
     C                     MOVE GKT,I     KOT1
     C                     MOVE GKB,I     KBN1
     C                     MOVE GBM,I     BMN1
     C*２つ前工程*
     C                     SUB  1         I
     C           I         CABLE0         EXIT1
     C                     MOVE GKT,I     KOT2
     C                     MOVE GKB,I     KBN2
     C                     MOVE GBM,I     BMN2
     C*３つ前工程*
     C                     SUB  1         I
     C           I         CABLE0         EXIT1
     C                     MOVE GKT,I     KOT3
     C                     MOVE GKB,I     KBN3
     C                     MOVE GBM,I     BMN3
     C*
     C           EXIT1     TAG
     C*１回のみ機番入力*
     C*注）機番は、データが１件の時には品番が変わった後に印字する*
     C*    ので、１つ前の品番の機番を変数に持つ（ＭＥ４のみ使用）*
     C           *IN13     IFEQ '0'
     C                     SETON                     13
     C                     MOVE KBN1      OKBN1   3
     C                     MOVE KBN2      OKBN2   3
     C                     MOVE KBN3      OKBN3   3
     C                     END
     C****************************
     C*細目マスタで部門名を引く*
     C****************************
     C                     MOVE *BLANK    BMN3N   9
     C                     MOVE *BLANK    BMN2N   9
     C                     MOVE *BLANK    BMN1N   9
     C*１つ前工程*
     C                     SETOF                     12
     C           BMN1      CHAINFGBPL011             12
     C           *IN12     IFEQ '0'
     C                     MOVELB2SMEI    BMN1N
     C                     ELSE
     C                     MOVE *BLANK    BMN1N
     C                     END
     C*２つ前工程*
     C                     SETOF                     12
     C           BMN2      CHAINFGBPL011             12
     C           *IN12     IFEQ '0'
     C                     MOVELB2SMEI    BMN2N
     C                     ELSE
     C                     MOVE *BLANK    BMN2N
     C                     END
     C*３つ前工程*
     C                     SETOF                     12
     C           BMN3      CHAINFGBPL011             12
     C           *IN12     IFEQ '0'
     C                     MOVELB2SMEI    BMN3N
     C                     ELSE
     C                     MOVE *BLANK    BMN3N
     C                     END
     C**************************
     C*品番が変わったかの処理*
     C**************************
     C           J1HIN1    IFEQ CHIN1
     C           J1HIN2    ANDEQCHIN2
     C           J1HIN3    ANDEQCHIN3
     C*前回と同じ品番*
     C*品番内カウンター＋１
     C                     ADD  1         HINNO
     C*
     C                     ELSE
     C*前回と違う品番（ＭＥ４のみ１つ前の品番のデータです）*
     C           HINNO     IFLE 1
     C                     EXCPTME4
     C                     EXSR OFCHK
     C                     END
     C*１つあける
     C                     EXCPTSP
     C                     EXSR OFCHK
     C*品番カウンターリセット
     C                     Z-ADD1         HINNO
     C*ＫＥＹ品番入力
     C                     MOVE J1HIN1    CHIN1
     C                     MOVE J1HIN2    CHIN2
     C                     MOVE J1HIN3    CHIN3
     C*機番入力
     C                     MOVE KBN1      OKBN1
     C                     MOVE KBN2      OKBN2
     C                     MOVE KBN3      OKBN3
     C*
     C                     END
     C********
     C*印字*
     C********
     C* 1 *
     C           HINNO     IFEQ 1
     C*品番点数カウンター＋１
     C                     ADD  1         HINKEN
     C                     EXCPTME1
     C*(1LINE NOT PAGE CHG)EXSR OFCHK
     C                     END
     C* 2 *
     C           HINNO     IFEQ 2
     C                     EXCPTME2
     C                     EXSR OFCHK
     C                     END
     C* 3以上 *
     C           HINNO     IFGE 3
     C                     EXCPTME3
     C                     EXSR OFCHK
     C                     END
     C**************
     C*最終の処理*
     C**************
     CLR         HINNO     IFLE 1
     CLR                   MOVE KBN1      OKBN1
     CLR                   MOVE KBN2      OKBN2
     CLR                   MOVE KBN3      OKBN3
     CLR                   EXCPTME4
     CLR                   END
     CLR                   EXCPTTO
