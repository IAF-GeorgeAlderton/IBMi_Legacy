     H            Y.
     F** ABNR05 *********************************************
     F* KANBAN M/F INFO ABHPP01
     F*    SAKAKI.         2019.04.09                       *
     F*******************************************************
     FABHPL03 IF  E                    DISK
     FABNPP01 UF  E           K        DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     I              '0123456789'          C         WKCKSU
      *
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     READ ABHPL03                  21
     C           *IN21     DOWEQ'0'
     C           M6SKJY    IFEQ 'D'
     C           M6SKHZ    ANDLESDATE
     C                     ELSE
     C           M6STHZ    IFEQ 99999999
     C                     EXSR #SB200
     C                     ENDIF
     C                     ENDIF
     C                     READ ABHPL03                  21
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------*
      *工程内かんばん検索       *
      *---------------------------*
     CSR         #SB200    BEGSR
      *
     C           KEYA31    KLIST
     C                     KFLD           K6CRDT  80
     C                     KFLD           K6KCD1  1
     C                     KFLD           K6KCD2  1
     C                     KFLD           K6LOTK  30
     C                     Z-ADDSDATE     K6CRDT
     C                     MOVEL'A'       K6KCD1
     C                     MOVEL'D'       K6KCD2
     C                     Z-ADDM6LOTK    K6LOTK
      *
     C           KEYA31    CHAINABNPP01              82
     C           *IN82     IFEQ '0'
     C                     ADD  M6KMAX    S6KMAX
     C                     ADD  M6CMAI    S6CMAI
     C                     ADD  M6DAND    S6DAND
     C                     ADD  M6KYOT    S6KYOT
     C                     ADD  M6FRYO    S6FRYO
     C                     ADD  M6SENY    S6SENY
     C                     ADD  M61NAI    S61NAI
     C                     ADD  M62NAI    S62NAI
     C                     ADD  M6JISK    S6JISK
     C                     ADD  M6AUAJ    S6AUAJ
     C                     ADD  M6OTHH    S6OTHH
     C                     UPDATABNPP011
     C                     ELSE
     C                     CLEARABNPP011
     C                     Z-ADDSDATE     S6CRDT
     C                     MOVEL'A'       S6KCD1
     C                     MOVEL'D'       S6KCD2
     C                     Z-ADDM6LOTK    S6LOTK
     C                     Z-ADDM6KMAX    S6KMAX
     C                     Z-ADDM6CMAI    S6CMAI
     C                     Z-ADDM6DAND    S6DAND
     C                     Z-ADDM6KYOT    S6KYOT
     C                     Z-ADDM6FRYO    S6FRYO
     C                     Z-ADDM6SENY    S6SENY
     C                     Z-ADDM61NAI    S61NAI
     C                     Z-ADDM62NAI    S62NAI
     C                     Z-ADDM6JISK    S6JISK
     C                     Z-ADDM6AUAJ    S6AUAJ
     C                     Z-ADDM6OTHH    S6OTHH
     C                     WRITEABNPP011
     C                     ENDIF
      *
     CSR         ESB200    ENDSR
