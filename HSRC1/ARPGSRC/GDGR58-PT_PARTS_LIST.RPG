     H            Y/
     F***************************************************
     F*   PT PARTS LIST                                   *
     F*                                                 *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FGDGPW58 CF  E                    WORKSTN
     F                                              KINFDS @INFDS
     FAAPTL01 IF  E           K        DISK
     FAANPL06 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FMBDPL01 IF  E           K        DISK
     FGADPL11 IF  E           K        DISK
     FFCEPL11 IF  E           K        DISK
     FMCENP13 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FAKBPL04 IF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
      *------------------------------------------------------------
     E                    TTL     1   3 25
     E                    QTY        20  9 2
     E                    DLV        20  4 0
     E                    NAM        20 15
     E                    CYC        20  2 0
     E                    QTYX        4  6 2
     E                    DLVX        4  4
     E                    NAMX        4 15
     E                    CYCX        4  2 0
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1  140W@TIME
     I                                        1   60W@HMS
     I                                        7  140W@YMD
     I                                        7  100W@YY
     I                                       11  120W@MM
     I                                       13  140W@DD
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   60@@MDY
     I                                        1   20@@MM
     I                                        3   40@@DD
     I                                        5   60@@YY
     I            DS
     I                                        1   80A2TYMD
     I                                        1   40A2TAYY
     I                                        5   60A2TAMM
     I                                        7   80A2TADD
     I            DS
     I                                        1   80L7STHZ
     I                                        1   40L7STYY
     I                                        5   60L7STMM
     I                                        7   80L7STDD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#FCEP    KLIST
     C                     KFLD           L5SHN1
     C                     KFLD           L5SHN2
     C                     KFLD           L5SHN3
     C           K#ADGX    KLIST
     C                     KFLD           W@YY
     C                     KFLD           W@MM
     C           K#GAD     KLIST
     C                     KFLD           F3TOKU
     C                     KFLD           F3NONY
     C           K#FCEX    KLIST
     C                     KFLD           L1SHN1
     C                     KFLD           L1SHN2
     C                     KFLD           L1SHN3
     C           K#MC      KLIST
     C                     KFLD           K@SHN1
     C                     KFLD           K@SHN2
     C                     KFLD           K@SHN3
      *
     C           *LIKE     DEFN MCSHN1    K@SHN1
     C           *LIKE     DEFN MCSHN2    K@SHN2
     C           *LIKE     DEFN MCSHN3    K@SHN3
      *
     C                     MOVEL'01'      W@ID    2
     C                     TIME           W@TIME
     C                     Z-ADDW@YY      @@YY
     C                     Z-ADDW@MM      @@MM
     C                     Z-ADDW@DD      @@DD
     C                     MOVE *ALL'-'   @@LINE198
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #PRT
     C                     MOVEL'99'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
      *
     C           D@OPTN    IFNE *BLANK
     C           D@OPTN    ANDNE'1'
     C           D@OPTN    ANDNE'2'
     C           D@OPTN    ANDNE'3'
     C                     EXSR #PRT
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   PRINT
      *------------------------------------------------------
     C           #PRT      BEGSR
      * NUMBER OF WORKING DAYS
     C                     Z-ADD*ZERO     W@DAYS  20
     C                     Z-ADDW@YY      K@YY
     C           W@MM      SUB  1         K@MM
     C           K@MM      IFEQ 0
     C                     ADD  12        K@MM
     C                     SUB  1         K@YY
     C                     ENDIF
      *
     C                     Z-ADDW@DD      K@DD
     C           K#ADGX    SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C           K#ADGX    READEAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDNE'*'
     C                     ADD  1         W@DAYS
     C                     ENDIF
     C                     ENDDO
      *
     C           D@OPTN    IFEQ *BLANK
     C                     EXSR #PRT1
     C                     EXSR #PRT2
     C                     EXSR #PRT3
     C                     ELSE
     C                     SELEC
      * FINISHED GOODS
     C           D@OPTN    WHEQ '1'
     C                     EXSR #PRT1
      * HALF FINISHED GOODS
     C           D@OPTN    WHEQ '2'
     C                     EXSR #PRT2
      * WASHER
     C           D@OPTN    WHEQ '3'
     C                     EXSR #PRT3
     C                     ENDSL
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   FINISHED GOODS
      *------------------------------------------------------
     C           #PRT1     BEGSR
      *
     C                     MOVE TTL,1     W@TTL  25 P
     C                     MOVE *OFF      *IN98
     C           *IN80     DOUEQ*ON
     C                     READ AAPTL01                  80
     C           *IN80     IFEQ *OFF
     C           L5SKJY    ANDEQ*BLANK
     C           L5STHZ    ANDEQ99999999
     C           L5TKR1    ANDEQ'0'
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
      *   BOX/DAY
     C                     EXSR #DBOX
      *
      * ACTUAL SHIPMENT
     C                     EXSR #ACT
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   BOX/DAY
      *------------------------------------------------------
     C           #DBOX     BEGSR
      *
     C           K#FCEP    CHAINFCEPL01              90
     C           *IN90     IFEQ *OFF
     C           A2SSYS    ANDNE*ZERO
      *
     C           W@DAYS    IFNE *ZERO
     C           A2GEKN    DIV  W@DAYS    W@QTY  112
     C                     MVR            W@MVR   90
     C           W@MVR     IFNE *ZERO
     C                     ADD  0.1       W@QTY
     C                     ENDIF
     C                     ELSE
     C                     Z-ADD*ZERO     W@QTY
     C                     ENDIF
      *
     C           W@QTY     DIV  A2SSYS    W@DBOX  52
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   ACTUAL SHIPMENT
      *------------------------------------------------------
     C           #ACT      BEGSR
      *
     C                     Z-ADD*ZERO     QTY
     C                     Z-ADD*ZERO     DLV
     C                     Z-ADD*ZERO     CYC
     C                     MOVE *BLANK    NAM
     C                     Z-ADD*ZERO     X       20
     C                     Z-ADD*ZERO     @@QTY   92
     C                     Z-ADD*ZERO     @@NONY  40
     C           K#FCEP    SETLLMBDPL01
     C           *IN90     DOUEQ*ON
     C           K#FCEP    READEMBDPL01                  90
     C           *IN90     IFEQ *OFF
     C           F3SKJY    ANDEQ*BLANK
      *
     C           F3NONY    IFNE @@NONY
     C           @@NONY    ANDNE*ZERO
     C           @@QTY     IFNE *ZERO
     C           @@QTY     DIV  A2SSYS    W@ACTB  92
     C           W@ACTB    DIV  W@DAYS    W@ACTB
     C                     Z-ADDW@ACTB    QTY,X
     C                     ELSE
     C                     SUB  1         X
     C                     ENDIF
     C                     Z-ADD*ZERO     @@QTY
     C                     ENDIF
      *
     C           F3NONY    IFNE @@NONY
     C           K#GAD     SETLLGADPL11
     C           *IN91     DOUEQ*ON
     C           K#GAD     READEGADPL11                  91
     C           *IN91     IFEQ *OFF
     C           B5SKJY    ANDEQ*BLANK
     C                     ADD  1         X
     C                     MOVELB5KMEI    NAM,X
     C                     Z-ADDB5HIZK    CYC,X
     C                     Z-ADDF3NONY    DLV,X
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C                     ADD  F3TNSU    @@QTY
     C                     Z-ADDF3NONY    @@NONY
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           @@NONY    IFNE *ZERO
     C           @@QTY     ANDNE*ZERO
     C           @@QTY     DIV  A2SSYS    W@ACTB
     C           W@ACTB    DIV  W@DAYS    W@ACTB
     C                     Z-ADDW@ACTB    QTY,X
     C                     Z-ADD*ZERO     @@QTY
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     QTYX
     C                     MOVE *BLANK    DLVX
     C                     Z-ADD*ZERO     CYCX
     C                     MOVE *BLANK    NAMX
     C                     Z-ADD*ZERO     Y       20
     C                     XFOOTQTY       BOXT    52
      *
      *
     C           L5SHN2    COMP *BLANK                   01
     C           L5SHN3    COMP *BLANK                   02
     C                     EXCPT@DT1
      *
     C           DLV,1     IFEQ *ZERO
     C                     EXCPT@SKP
     C                     ELSE
     C           1         DO   20        X
     C           DLV,X     IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
     C                     ADD  1         Y
     C                     Z-ADDQTY,X     QTYX,Y
     C                     MOVE DLV,X     DLVX,Y
     C                     Z-ADDCYC,X     CYCX,Y
     C                     MOVE NAM,X     NAMX,Y
     C           Y         IFEQ 4
     C                     EXCPT@DT2
     C                     Z-ADD*ZERO     QTYX
     C                     MOVE *BLANK    DLVX
     C                     Z-ADD*ZERO     CYCX
     C                     MOVE *BLANK    NAMX
     C                     Z-ADD*ZERO     Y       20
     C                     ENDIF
     C                     ENDDO
      *
     C           Y         IFNE *ZERO
     C                     EXCPT@DT2
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   HALF FINISHED GOODS
      *------------------------------------------------------
     C           #PRT2     BEGSR
      *
     C                     MOVE TTL,2     W@TTL  25 P
     C                     MOVE *OFF      *IN98
     C           *LOVAL    SETLLAANPL06
     C           *IN80     DOUEQ*ON
     C                     READ AANPL06                  80
     C           *IN80     IFEQ *OFF
     C           L7SKJY    ANDEQ*BLANK
     C           L7STHZ    ANDEQ99999999
     C           L7TKR1    ANDEQ'1'
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
      *   BOX/DAY
     C                     EXSR #DBOX
      * ACTUAL SHIPMENT
     C                     EXSR #ACT
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   WASHER
      *------------------------------------------------------
     C           #PRT3     BEGSR
      *
     C                     MOVE TTL,3     W@TTL  25 P
     C                     MOVE *OFF      *IN98
     C           *IN80     DOUEQ*ON
     C                     READ AKBPL04                  80
     C           *IN80     IFEQ *OFF
     C           L1SKJY    ANDEQ*BLANK
     C           L1STHZ    ANDEQ99999999
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED3
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
      *   PART INF
     C                     EXSR #WBOX
      *
     C           W@DBOX    IFNE *ZERO
     C           W@ACTB    ORNE *ZERO
      *
     C           L1SHN2    COMP *BLANK                   01
     C           L1SHN3    COMP *BLANK                   02
     C                     EXCPT@DTL3
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   BOX/DAY
      *------------------------------------------------------
     C           #WBOX     BEGSR
      *
      * DAILY USAGE
     C                     Z-ADD*ZERO     W@QTY
     C                     Z-ADD*ZERO     W@AQTY  90
     C                     Z-ADD*ZERO     W@DBOX
     C                     Z-ADD*ZERO     W@ACTB
     C           K#FCEX    SETLLMCENP13
     C           *IN97     DOUEQ*ON
     C           K#FCEX    READEMCENP13                  97
B01  C           *IN97     IFEQ *OFF
      *
     C                     MOVE MCSHN1    K@SHN1
     C                     MOVE MCSHN2    K@SHN2
     C                     MOVE MCSHN3    K@SHN3
      *
     C                     EXSR #USG
     C                     EXSR #WACT
     C                     ENDIF
     C                     ENDDO
      *
     C           L1SYOS    IFNE *ZERO
     C           W@QTY     DIV  L1SYOS    W@DBOX
     C           W@AQTY    DIV  L1SYOS    W@ACTB
     C           W@ACTB    DIV  W@DAYS    W@ACTB
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   DAILY USAGE
      *------------------------------------------------------
     C           #USG      BEGSR
      *
     C           K#MC      CHAINFCEPL11              90
     C           *IN90     IFEQ *OFF
     C           FCCD01    ANDNE*ZERO
     C           FCGK01    DIV  FCCD01    @@QTY     H
     C                     ADD  @@QTY     W@QTY
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   ACTUAL SHIPMENT
      *------------------------------------------------------
     C           #WACT     BEGSR
      *
     C           K#MC      SETLLMBDPL01
     C           *IN90     DOUEQ*ON
     C           K#MC      READEMBDPL01                  90
     C           *IN90     IFEQ *OFF
     C           F3SKJY    ANDEQ*BLANK
      *
     C                     ADD  F3TNSU    W@AQTY
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
      *
     C                     ENDSR
      *------------------------------------------------------
     OQPRINT  E   01           @HED
