     C*----------------------------------------------*
     C*     ...当月　翌月　翌々月　の　日付...     *
     C*----------------------------------------------*
     C                     Z-ADDYYMM      YYMM1
     C                     ADD  1         MM1
     C           MM1       IFGT 12
     C                     ADD  1         YY1
     C                     SUB  12        MM1
     C                     END
     C                     Z-ADDYYMM      YYMM2
     C                     ADD  2         MM2
     C           MM2       IFGT 12
     C                     ADD  1         YY2
     C                     SUB  12        MM2
     C                     END
