     H            Y.
      ** AB#RG9 ************************************************
      *  FORD Order Plant/Dock/IC Code Match                   *
      *                                                        *
      ************************************ AB#RG9 **************
     FAB#EP50 IF  E           K        DISK
     FABFDL03 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      ****************************************************
     E                    MSG     1   3 30
     E                    PDF       999 14               PLANT/DOCK/FACILITY
      ****************************************************
      * TIME
     I            DS
     I                                        1  120WTMDT
     I                                        1   60WTIME
     I                                        7  120WDATE
     I            DS
     I                                        1  14 PDFCOD
     I                                        1   5 A5STID
     I                                        6   9 A5DOCK
     I                                       10  14 A5STFC
     I            DS
     I                                        1   80QASKHZ
     I                                        1   40QASKYY
     I                                        5   60QASKMM
     I                                        7   80QASKDD
     I            DS
     I                                        1   80QAEFHZ
     I                                        1   40QAEFYY
     I                                        5   60QAEFMM
     I                                        7   80QAEFDD
      ***********************************************************
     C           *ENTRY    PLIST
     C                     PARM           PD      1
     C                     MOVE *BLANK    PD
      *
     C           KEY1      KLIST
     C                     KFLD           A5STID           PLANT CODE
     C                     KFLD           A5DOCK           DOCK(RECIVING)
     C                     KFLD           A5STFC           IC CODE
      ***********************************************************
      *
     C                     TIME           WTMDT
     C                     SETON                     OF
      *
     C                     EXSR @MAIN
      *
     C                     SETON                     LR
     C                     RETRN
      *
      ***********************************************************
      *    MAIN SUBROUTINE...                                  **
      *
     C           @MAIN     BEGSR
      *
     C                     READ AB#EP50                  90
     C           *IN90     DOWEQ*OFF
      *
     C           KEY1      SETLLABFDL03
     C           *IN91     DOUEQ*ON
     C           KEY1      READEABFDL03                  91
      *
      * if route deleted or not in effect yet, ignore and read next...
     C           *IN91     IFEQ *OFF
     C           QASKJY    IFEQ 'D'
     C           QASKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C           QAEFHZ    IFGT *DATE
     C                     ITER
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
      * if route, dock, ic code not found in route master print detail...
     C           *IN91     IFEQ *ON
      *
      *    check to see if not already printed....
     C           PDFCOD    LOKUPPDF,1                    10
     C           *IN10     IFEQ *OFF
      *
     C                     MOVELMSG,1     W@MSG  30
     C   OF                EXCPT#HED1
     C   OF                EXCPT#HED2
     C   OF                SETOF                     OF
     C                     ADD  1         X       40
     C                     MOVELPDFCOD    PDF,X
     C                     MOVELA5PART    PART   20
     C                     EXCPT#DTL1
     C                     MOVE *ON       PD
      *
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     READ AB#EP50                  90
     C                     ENDDO
      *
     C                     ENDSR
      ***********************************************************
     OQPRINT  E    2           #HED1
     O       OR        OF
     O                                    8 'AB#RG9'
     O                                   37 'FORD PLANT/DOCK/IC CODE '
     O                                   72 'NEW REPORT'
      *
     O        E 1              #HED1
     O       OR        OF
     O                                  131 '.         .         .'
      *
     O        E 1              #HED1
     O       OR        OF
     O                                   89 'TIME'
     O                         WTIME     98 '  :  :  '
     O                                  131 '.         .         .'
      *
     O        E 1              #HED1
     O       OR        OF
     O                                   89 'DATE'
     O                         UDATE Y   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O                                  131 '.....................'
     O        E 1              #HED2
     O       OR        OF
     O                                    6 'PLANT'
     O                                   12 'DOCK'
     O                                   23 'IC CODE'
     O                                   65 'PART#'
      *
     O        E 1              #DTL1
     O                         A5STID     6
     O                         A5DOCK    12
     O                         A5STFC    22
     O                         W@MSG     56
     O                         PART      80
**
