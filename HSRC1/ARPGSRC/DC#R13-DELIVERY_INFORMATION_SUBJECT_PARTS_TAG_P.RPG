     C           WKHAKO    ADD  1         B8HAKO
     C                     ENDIF
     C* CUSTOMER CONTRACT M/F
     C                     SETOF                     80
     C           B8NONY    CHAINKFAPL11              80    RECEIVING CO
     C           *IN80     IFEQ *ON
     C                     MOVE *BLANK    D1TOK1
     C                     MOVE *BLANK    D1TOK2
     C                     ENDIF
     C                     MOVE *BLANK    WKHIKI
     C           B8HIKI    IFEQ 'A'
     C                     MOVE COM,1     WKHIKI
     C                     ENDIF
     C           B8HIKI    IFEQ 'B'
     C                     MOVE COM,2     WKHIKI
     C                     ENDIF
     C*
     C*           BXMEYY        11      5 56TEXT('MAKE DELIVERY DATE YY')
