     C                     ENDIF
      *
     C                     MOVE '*'       @FIRST  1
      *
     C                     MOVE B8TE      B8TEHZ  80
     C*****>>    B8TEHZ    IFGT WDATE
     C*****>>              GOTO ESC
     C*****>>              ENDIF
      *
     C* NUMBER OF BOXED CALCULATION
     C           B8SRYO    DIV  B8SYUY    WKHAKO  30
     C                     MVR            B8HASU  50       ﾌﾇc
     C           B8HASU    IFEQ 0
