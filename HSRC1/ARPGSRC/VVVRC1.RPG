     H            Y.
     FVVVPPA0 IF  E           K        DISK
     FVVVWPC1 O   F     256            DISK
      *
     C           *ENTRY    PLIST
     C                     PARM           P@FILE 10
      *
     C           P@FILE    IFEQ *BLANK
     C                     MOVEL'FCEPP01' P@FILE 10
     C                     END
     C                     MOVELP@FILE    K@FILE 10
      *
     C           K@FILE    SETLLVVVPPA0
     C                     DO   *HIVAL
     C           K@FILE    READEVVVPPA0                  77
     C   77                LEAVE
     C                     ADD  1         @CNT    50
      *
     C* * *                MOVEL'TEST'    VVPNAM
      *
     C                     MOVELVVPNAM    P@PGM  10
     C                     MOVE *BLANK    P@UDAT  7
     C                     CALL 'APLC78'
     C                     PARM           P@PGM  10
     C                     PARM           P@UDAT  7
      *ＰＧＭのＳＲＣ日時
     C                     CALL 'VVVCYA'
     C                     PARM           VVPNAM
     C                     PARM           O@LIBL 10
     C                     PARM           O@FILE 10
     C                     PARM           O@MBR  10
     C                     PARM           O@SRCD 13
      * SYYMMDDJJFFSS -> YYYYMMDD JJFFSS
     C                     CALL 'APLR47'
     C                     PARM           O@SRCD 13
     C                     PARM           O@SDDT  8
     C                     PARM           O@SDTM  6
      *
     C                     MOVE O@SDDT    N@SDDT  80
     C                     MOVE O@SDTM    N@SDTM  60
      * 121212 -> 12:12:12
     C                     CALL 'TIMR90'
     C                     PARM           N@SDTM  60
     C                     PARM           W@SDTM  8
      *ソースの変更日時
     C                     CALL 'VVVCY1'
     C                     PARM           O@LIBL 10
     C                     PARM           O@FILE 10
     C                     PARM           O@MBR  10
     C                     PARM           P@CHGD 13
      * SYYMMDDJJFFSS -> YYYYMMDD JJFFSS
     C                     CALL 'APLR47'
     C                     PARM           P@CHGD 13
     C                     PARM           O@SCDT  8
     C                     PARM           O@SCTM  6
      *
     C                     MOVE O@SCDT    N@SCDT  80
     C                     MOVE O@SCTM    N@SCTM  60
      * 121212 -> 12:12:12
     C                     CALL 'TIMR90'
     C                     PARM           N@SCTM  60
     C                     PARM           W@SCTM  8
      *
     C           N@SDDT    IFEQ N@SCDT
     C           W@SDTM    ANDEQW@SCTM
     C                     MOVE 'OK'      O@FLG   2
     C                     ELSE
     C                     MOVE 'NG'      O@FLG   2
     C                     END
      *
     C  N88                EXCPTOHED
     C                     SETON                     88
     C                     EXCPTODAT
      *
     C                     ENDDO
      *
     C                     Z-ADD@CNT      @CNT
      *
     C                     SETON                     LR
     C                     RETRN
      *
     OVVVWPC1 E                OHED
     O                                      'PGM,'
     O                                      'FILE,'
     O                                      'PF,'
     O                                      'LAST USE,'
     O                                      'SRC-LIB,'
     O                                      'FILE,'
     O                                      'MBR,'
     O                                      'PGM-SRC DATE,'
     O                                      'TIME,'
     O                                      'SRC-MBR DATE,'
     O                                      'TIME,'
     O        E                ODAT
     O                         VVPNAM
     O                                      ','
     O                         VVFNAM
     O                                      ','
     O                         VVRFI
     O                                      ','
     O                         P@UDAT
     O                                      ','
     O                         O@LIBL
     O                                      ','
     O                         O@FILE
     O                                      ','
     O                         O@MBR
     O                                      ','
     O                         N@SDDT       '    /  /  '
     O                                      ','
     O                         W@SDTM
     O                                      ','
     O                         N@SCDT       '    /  /  '
     O                                      ','
     O                         W@SCTM
     O                                      ','
     O                         O@FLG
      *
