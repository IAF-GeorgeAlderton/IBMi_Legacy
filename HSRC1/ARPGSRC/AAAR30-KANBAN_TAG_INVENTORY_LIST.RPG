     H            Y.
     F** AAAR30 ********************************************************
     F* KANBAN TAG INVENTORY LIST                                      *
     F*                                                                *
     F* TCH 2000.07.28                                                 *
     F* TCH 2001.06.26 OMITTE DELETE CODE                              *
     F* TCH 2001.06.29 ADD AAPPP01                                     *
     F*                                                                *
     F* *IN90=1(NOT READ ABHPP01)                                      *
     F* *IN91=1(NOT READ ADHPP01)                                      *
     F* *IN92=1(NOT READ AAHPP01)                                      *
     F* *IN93=1(NOT READ AAFPP01)                                      *
     F* *IN94=1(NOT READ AAPPP01)                                      *
     F* UPDATE:K.OKACHI     2002.06.17     %0001
     F* UPDATE:H.AMANO      2002.11.04   CHANGE INDICATOR WHEN READ
     F*                                  AANPP01                       *
     F* 2021.01.20 DCS. T.MITSUI
     F*   CHANGE WITH THE NUMBER OF FIGURES EXPANSION OF THE "KANBAN"
     F************************ AAAR30 **********************************
     FAAPPP01 IF  E                    DISK
     FABHPP01 IF  E                    DISK
     FAAFPP01 IF  E                    DISK
     FAAHPP01 IF  E                    DISK
     FADHPP01 IF  E                    DISK
%0001FAANPP01 IF  E                    DISK
     FAAAWP30 O   E                    DISK
     I******************************************************************
     I* QTY / CONTAINERS
     I            DS
     I                                        1   5 Z6SYOS
     I                                        1   50W6SYOS
     I* # OF KANBAN
     I            DS
     I                                        1   5 Z6#KAN
     I                                        1   50W6#KAN
     I* TOTAL PIECES QTY.
     I            DS
     I                                        1  12 Z6TQT1
     I                                        1  120W6TQT1
     I* TOTAL CONTAINERS QTY
     I            DS
     I                                        1  12 Z6TQT2
     I                                        1  120W6TQT2
     I* P/LOT
     I            DS
     I                                        1   3 Z6PLOT
     I                                        1   30W6PLOT
     I* SYSTEM(TIME + DATE)
     I            DS
     I                                        1  120WWTIME
     I                                        1   6 Z6TIME
     I                                        7  12 Z6DATE
     C**************************************************************************
     C*                    MAIN ROUTINE
     C**************************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PUSR   10
     C*
     C                     EXSR @INT
     C                     EXSR @MAIN
     C                     EXSR @END
     C**************************************************************************
     C*                    @INT
     C**************************************************************************
     C           @INT      BEGSR
     C*
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @MAIN
     C**************************************************************************
     C           @MAIN     BEGSR
     C*
     C                     EXSR @KANA
     C                     EXSR @KANB
     C                     EXSR @KANC
     C                     EXSR @KAND
     C                     EXSR @KANE
%0001C                     EXSR @KANF
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @KANA(KANBAN CODE = A)
     C*******************************************************************
     C           @KANA     BEGSR
     C* KANBAN CODE=A
     C                     READ ABHPP01                  90
     C           *IN90     DOUEQ'1'
     C*
     C           M6SKJY    IFNE ' '
     C                     GOTO #READ1
     C                     END
     C*
     C           M6STYY    IFEQ 9999
     C*
     C                     CLEARAAAWP301
     C                     MOVE M6JBN1    Z6LOC1           LOCATION CODE1
     C                     MOVE M6JBN2    Z6LOC2                        2
     C                     MOVE M6JBN3    Z6LOC3                        3
     C                     MOVE M6JBN4    Z6LOC4                        4
     C                     MOVE M6HIN1    Z6PAR1           PART 1
     C                     MOVE M6HIN2    Z6PAR2                2
     C                     MOVE M6HIN3    Z6PAR3                3
     C                     MOVE M6AKT1    Z6PRC1           PROCESS CODE 1
     C                     MOVE M6KBN1    Z6PRC2                        2
     C                     Z-ADDM6SYUY    W6SYOS           QTY/CONTAINERS
     C                     Z-ADDM6LOTK    W6PLOT           P/LOT
     C                     Z-ADDM6KMAX    W6#KAN           # OF KANBAN
     C* CALUCULATE
     C* (QTY/CONTAINER) * (P/LOT) * (# OF KANBAN)
     C           W6SYOS    MULT W6PLOT    W6TQT1
     C                     MULT W6#KAN    W6TQT1           TOTAL PIECE
     C* CALUCULATE
     C* (P/LOT) * (# OF KANBAN)
     C           W6PLOT    MULT W6#KAN    W6TQT2           TOTAL CONTAINERS
     C*
     C                     MOVE 'A'       Z6KANC           KANBAN CODE
     C                     MOVE PUSR      Z6USR            USER ID
     C                     TIME           WWTIME
     C                     WRITEAAAWP301
     C*
     C                     END
     C*
     C           #READ1    TAG
     C                     READ ABHPP01                  90
     C                     END
     C*
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @KANB(KANBAN CODE = B)
     C*******************************************************************
     C           @KANB     BEGSR
     C* KANBAN CODE=B
     C                     READ ADHPP01                  91
     C           *IN91     DOUEQ'1'
     C*
     C           J6SKJY    IFNE ' '
     C                     GOTO #READ2
     C                     END
     C*
     C           J6STYY    IFEQ 9999
     C*
     C                     CLEARAAAWP301
     C                     MOVE J6ATK1    Z6LOC1           LOCATION CODE1
     C                     MOVE J6ATK2    Z6LOC2                        2
     C                     MOVE J6ATK3    Z6LOC3                        3
     C                     MOVE J6ATK4    Z6LOC4                        4
     C                     MOVE J6SHN1    Z6PAR1           PART 1
     C                     MOVE J6SHN2    Z6PAR2                2
     C                     MOVE J6SHN3    Z6PAR3                3
     C                     MOVE J6ATOK    Z6PRC1           PROCESS CODE 1
     C                     MOVE J6RONO    Z6PRC2                        2
     C                     Z-ADDJ6SYOS    W6SYOS           QTY/CONTAINERS
     C                     Z-ADDJ6LOTO    W6PLOT           P/LOT
     C                     Z-ADDJ6KMAX    W6#KAN           # OF KANBAN
     C* CALUCULATE
     C* (QTY/CONTAINER) * (P/LOT) * (# OF KANBAN)
     C           W6SYOS    MULT W6PLOT    W6TQT1
     C                     MULT W6#KAN    W6TQT1           TOTAL PIECE
     C* CALUCULATE
     C* (P/LOT) * (# OF KANBAN)
     C           W6PLOT    MULT W6#KAN    W6TQT2           TOTAL CONTAINERS
     C*
     C                     MOVE 'B'       Z6KANC           KANBAN CODE
     C                     MOVE PUSR      Z6USR            USER ID
     C                     TIME           WWTIME
     C                     WRITEAAAWP301
     C*
     C                     END
     C*
     C           #READ2    TAG
     C                     READ ADHPP01                  91
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @KANC(KANBAN CODE = C)
     C*******************************************************************
     C           @KANC     BEGSR
     C* KANBAN CODE=C
     C                     READ AAFPP01                  92
     C           *IN92     DOUEQ'1'
     C*
     C           A3SKJY    IFNE ' '
     C                     GOTO #READ3
     C                     END
     C*
     C           A3STYY    IFEQ 9999
     C*
     C                     CLEARAAAWP301
     C                     MOVE A3ATK1    Z6LOC1           LOCATION CODE1
     C                     MOVE A3ATK2    Z6LOC2                        2
     C                     MOVE A3ATK3    Z6LOC3                        3
     C                     MOVE A3ATK4    Z6LOC4                        4
     C                     MOVE A31HB5    Z6PAR1           PART 1
     C                     MOVE A32HB5    Z6PAR2                2
     C                     MOVE A33HB2    Z6PAR3                3
     C                     MOVE A3ATOK    Z6PRC1           PROCESS CODE 1
     C                     MOVE A3RAIN    Z6PRC2                        2
     C                     Z-ADDA3SSYS    W6SYOS           QTY/CONTAINERS
     C                     Z-ADD1         W6PLOT           P/LOT
     C                     Z-ADDA3KMAX    W6#KAN           # OF KANBAN
     C* CALUCULATE
     C* (QTY/CONTAINER) * (P/LOT) * (# OF KANBAN)
     C           W6SYOS    MULT W6PLOT    W6TQT1
     C                     MULT W6#KAN    W6TQT1           TOTAL PIECE
     C* CALUCULATE
     C* (P/LOT) * (# OF KANBAN)
     C           W6PLOT    MULT W6#KAN    W6TQT2           TOTAL CONTAINERS
     C*
     C                     MOVE 'C'       Z6KANC           KANBAN CODE
     C                     MOVE PUSR      Z6USR            USER ID
     C                     TIME           WWTIME
     C                     WRITEAAAWP301
     C*
     C                     END
     C*
     C           #READ3    TAG
     C                     READ AAFPP01                  92
     C                     END
     C*
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @KAND
     C*******************************************************************
     C           @KAND     BEGSR
     C*
     C                     READ AAPPP01                  94
     C           *IN94     DOUEQ'1'
     C*
     C           L5SKJY    IFNE ' '
     C                     GOTO #READ5
     C                     END
     C*
     C           L5STYY    IFEQ 9999
     C*
     C                     CLEARAAAWP301
     C                     MOVE L5TKR1    Z6LOC1           LOCATION CODE1
     C                     MOVE L5TKR2    Z6LOC2                        2
     C                     MOVE L5TKR3    Z6LOC3                        3
     C                     MOVE L5TKR4    Z6LOC4                        4
     C                     MOVE L5SHN1    Z6PAR1           PART 1
     C                     MOVE L5SHN2    Z6PAR2                2
     C                     MOVE L5SHN3    Z6PAR3                3
     C                     MOVELL5KTEI    Z6PRC1           PROCESS CODE 1
     C                     MOVE *BLANK    Z6PRC2                        2
     C                     Z-ADDL5SYOS    W6SYOS           QTY/CONTAINERS
     C                     Z-ADD1         W6PLOT           P/LOT
     C                     Z-ADDL5KMAX    W6#KAN           # OF KANBAN
     C* CALUCULATE
     C* (QTY/CONTAINER) * (P/LOT) * (# OF KANBAN)
     C           W6SYOS    MULT W6PLOT    W6TQT1
     C                     MULT W6#KAN    W6TQT1           TOTAL PIECE
     C* CALUCULATE
     C* (P/LOT) * (# OF KANBAN)
     C           W6PLOT    MULT W6#KAN    W6TQT2           TOTAL CONTAINERS
     C*
     C                     MOVE 'C'       Z6KANC           KANBAN CODE
     C                     MOVE PUSR      Z6USR            USER ID
     C                     TIME           WWTIME
     C                     WRITEAAAWP301
     C*
     C                     END
     C*
     C           #READ5    TAG
     C                     READ AAPPP01                  94
     C                     END
     C*
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @KANA(KANBAN CODE = E)
     C*******************************************************************
     C           @KANE     BEGSR
     C* KANBAN CODE=E
     C                     READ AAHPP01                  93
     C           *IN93     DOUEQ'1'
     C*
     C           L6SKJY    IFNE ' '
     C                     GOTO #READ4
     C                     END
     C*
     C           L6STYY    IFEQ 9999
     C*
     C                     CLEARAAAWP301
     C                     MOVE L6ATK1    Z6LOC1           LOCATION CODE1
     C                     MOVE L6ATK2    Z6LOC2                        2
     C                     MOVE L6ATK3    Z6LOC3                        3
     C                     MOVE L6ATK4    Z6LOC4                        4
     C                     MOVE L6SHN1    Z6PAR1           PART 1
     C                     MOVE L6SHN2    Z6PAR2                2
     C                     MOVE L6SHN3    Z6PAR3                3
     C                     MOVE L6ATOK    Z6PRC1           PROCESS CODE 1
     C                     MOVE *BLANK    Z6PRC2                        2
     C                     Z-ADDL6SYOS    W6SYOS           QTY/CONTAINERS
     C                     Z-ADD1         W6PLOT           P/LOT
     C                     Z-ADDL6KMAX    W6#KAN           # OF KANBAN
     C* CALUCULATE
     C* (QTY/CONTAINER) * (P/LOT) * (# OF KANBAN)
     C           W6SYOS    MULT W6PLOT    W6TQT1
     C                     MULT W6#KAN    W6TQT1           TOTAL PIECE
     C* CALUCULATE
     C* (P/LOT) * (# OF KANBAN)
     C           W6PLOT    MULT W6#KAN    W6TQT2           TOTAL CONTAINERS
     C*
     C                     MOVE 'E'       Z6KANC           KANBAN CODE
     C                     MOVE PUSR      Z6USR            USER ID
     C                     TIME           WWTIME
     C                     WRITEAAAWP301
     C*
     C                     END
     C*
     C           #READ4    TAG
     C                     READ AAHPP01                  93
     C                     END
     C*
     C*
     C                     ENDSR
%0001C**************************************************************************
     C*                    @KANF
     C*******************************************************************
     C           @KANF     BEGSR
     C*
     C                     READ AANPP01                  95
     C           *IN95     DOUEQ'1'
     C*
     C           L7SKJY    IFNE ' '
     C                     GOTO #READ6
     C                     END
     C*
     C           L7STYY    IFEQ 9999
     C*
     C                     CLEARAAAWP301
     C                     MOVE L7TKR1    Z6LOC1           LOCATION CODE1
     C                     MOVE L7TKR2    Z6LOC2                        2
     C                     MOVE L7TKR3    Z6LOC3                        3
     C                     MOVE L7TKR4    Z6LOC4                        4
     C                     MOVE L7SHN1    Z6PAR1           PART 1
     C                     MOVE L7SHN2    Z6PAR2                2
     C                     MOVE L7SHN3    Z6PAR3                3
     C                     MOVELL7KTEI    Z6PRC1           PROCESS CODE 1
     C                     MOVE *BLANK    Z6PRC2                        2
     C                     Z-ADDL7SYOS    W6SYOS           QTY/CONTAINERS
     C                     Z-ADD1         W6PLOT           P/LOT
     C                     Z-ADDL7KMAX    W6#KAN           # OF KANBAN
     C* CALUCULATE
     C* (QTY/CONTAINER) * (P/LOT) * (# OF KANBAN)
     C           W6SYOS    MULT W6PLOT    W6TQT1
     C                     MULT W6#KAN    W6TQT1           TOTAL PIECE
     C* CALUCULATE
     C* (P/LOT) * (# OF KANBAN)
     C           W6PLOT    MULT W6#KAN    W6TQT2           TOTAL CONTAINERS
     C*
     C                     MOVE 'F'       Z6KANC           KANBAN CODE
     C                     MOVE PUSR      Z6USR            USER ID
     C                     TIME           WWTIME
     C                     WRITEAAAWP301
     C*
     C                     END
     C*
     C           #READ6    TAG
     C*********            READ AANPP01                  94
     C                     READ AANPP01                  95
     C                     END
