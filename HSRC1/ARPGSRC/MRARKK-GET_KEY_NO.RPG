     F** MRARKK *********************************************
     F* GET KEY NO.                                         *
     F*     TRANCOM ITS.           2012.09.11               *
     F*******************************************************
     FMRAPP00 UF  E                    DISK                      A
     E                    RNO    36  36  1
     E                    @CC         5  1
     E                    WCC         5  1
      *
     C           *ENTRY    PLIST
     C                     PARM           PKENO   5
      *
     C                     MOVE *BLANK    WKKENO  5
     C           1         CHAINMRAPP001             70
     C           *IN70     IFEQ '1'
     C                     MOVE '00001'   WKKENO
     C                     MOVE '00001'   M0KENO
     C                     WRITEMRAPP001
     C                     MOVE WKKENO    PKENO
     C                     ELSE
     C                     EXSR #SUB1
     C                     MOVEAWCC       WKKENO
     C           WKKENO    IFEQ '00000'
     C                     MOVE '00001'   WKKENO
     C                     ENDIF
     C                     MOVE WKKENO    M0KENO
     C                     UPDATMRAPP001
     C                     MOVE WKKENO    PKENO
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------*
      *          ３６進にて管理                           *
      *-----------------------------------------------------*
     C           #SUB1     BEGSR
     C                     MOVEA*BLANK    @CC
     C                     MOVEA*BLANK    WCC
     C                     MOVEAM0KENO    @CC
     C                     MOVEAM0KENO    WCC
     C                     Z-ADD5         @B      20
     C                     DO   5
     C                     Z-ADD1         @A      20
     C                     SETOF                     71
     C           @CC,@B    LOKUPRNO,@A                   71
     C           *IN71     IFEQ '1'
     C           RNO,@A    IFEQ 'Z'
     C                     Z-ADD1         @A
     C                     MOVE RNO,@A    WCC,@B
     C                     SUB  1         @B
     C                     GOTO @EDO1
     C                     ELSE
     C                     ADD  1         @A
     C                     MOVE RNO,@A    WCC,@B
     C                     GOTO ESUB1
     C                     ENDIF
     C                     ENDIF
     C           @EDO1     TAG
     C                     ENDDO
     C           ESUB1     ENDSR
**
0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ
