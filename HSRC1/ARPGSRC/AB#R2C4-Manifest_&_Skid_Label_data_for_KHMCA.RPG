     H            Y.
     F** AB#R2C4 ************************************************************
     F*  MANIFEST & SKID LABEL DATA FOR KHMCA                               *
     F*                                                                     *
     F* TCHK1 11/20/07 CREATE(COPY FROM AB#R2C1)                            *
     F****************************************** AB#R2C *********************
     FAB#WP2IPIF  E           K        DISK
     FAB#PL90 IF  E           K        DISK
     FAB#WP2O O   E                    DISK
     E*****************************************************************
     I            DS
     I                                        1   5 W@PLNX
     I                                        1   1 W@PLN1
     I                                        2   2 W@PLN2
     I                                        3   3 W@PLN3
     I                                        4   4 W@PLN4
     I                                        5   5 W@PLN5
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I            DS
     I                                        1  75 WNKEY
     I                                        1   4 IPDELY
     I                                        5  12 IPSHDT
     I                                       13  17 IPDUMY
     I                                       18  21 IPDOCK
     I                                       22  31 IPORDR
     I                                       32  51 IPFLD1
     I                                       52  55 IPSBAN
     I                                       56  75 IPPART
     I                                        1  51 WNKEY1
     I            DS
     I                                        1  75 WOKEY
     I                                        1   4 WODELY
     I                                        5  12 WOSHDT
     I                                       13  17 WODUMY
     I                                       18  21 WODOCK
     I                                       22  31 WOORDR
     I                                       32  51 WOFLD1
     I                                       52  55 WOSBAN
     I                                       56  75 WOPART
     I                                        1  51 WOKEY1
     C***********************************************************************
     C                     EXSR @INZ
     C                     EXSR @MAIN
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C***********************************************************
     C* @INZ:INITIALIZE WORK AREA
     C***********************************************************
     C           @INZ      BEGSR
     C*
     C           P2        PLIST
     C                     PARM           PIQTY  300       NUMERIC QTY
     C                     PARM           POQTY  30        CHAR    QTY
     C*
     C                     Z-ADD*ZERO     W@MXPL  50
     C                     Z-ADD*ZERO     W@DCNT  50
     C                     MOVEL*BLANK    WOKEY
     C*
     C* GET THE NUMBER OF LABEL
     C           '1101'    CHAINAB#PL90              98
     C           *IN98     IFEQ '0'
     C                     Z-ADDYAMXPL    W@MXPL
     C                     Z-ADDYA#LAB    W#LAB   50
     C           W#LAB     IFNE *ZERO
     C           W#LAB     MULT W@MXPL    W@MXPL
     C                     END
     C                     END
     C*
     C                     ENDSR
     C***********************************************************
     C* @MAIN
     C***********************************************************
     C           @MAIN     BEGSR
     C*
     C           *LOVAL    SETLLAB#WP2IP
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AB#WP2IP                 99
     C   99                LEAVE
     C*
     C           WOKEY     IFEQ *BLANK
     C                     MOVELWNKEY     WOKEY
     C                     EXSR @SAVE
     C                     CALL 'AB#R2C41'
     C                     PARM           W@MXPL
     C                     PARM           WNKEY1
     C                     PARM *ZERO     W@PLNO  50
     C                     END
     C*
     C           WNKEY     IFNE WOKEY
     C                     EXSR @OUTM
     C           WNKEY1    IFNE WOKEY1
     C                     EXSR @OUTS
     C                     Z-ADD*ZERO     W@DCNT
     C                     END
     C                     MOVELWNKEY     WOKEY
     C                     EXSR @SAVE
     C                     CALL 'AB#R2C41'
     C                     PARM           W@MXPL
     C                     PARM           WNKEY1
     C                     PARM *ZERO     W@PLNO
     C                     END
     C*
     C                     ADD  1         W@DCNT
     C*
     C                     MOVELIPSIRE    W@MAXL  4
     C*
     C                     ENDDO
     C*
     C           WOKEY     IFNE *BLANK
     C                     EXSR @OUTM
     C                     EXSR @OUTS
     C                     END
     C*
     C                     ENDSR
     C* ====================================================
     C* SAVE FIELD
     C* ====================================================
     C           @SAVE     BEGSR
     C*
     C                     MOVELIPPART    W@PART 20
     C                     MOVELIPSBAN    W@SBAN  4
     C                     MOVELIPQTY     W@QTY   5
     C                     MOVELIPORDR    W@ORDR 10
     C                     MOVELIPRELS    W@RELS 15
     C                     MOVELIPTTL1    W@ULDT 10
     C                     MOVELIPDOCK    W@DOCK  4
     C                     MOVELIPSHDT    W@SHDT  8
     C                     MOVELIPFLD1    W@LODG  2
     C*
     C                     ENDSR
     C* ====================================================
     C* OUT MANIFEST
     C* ====================================================
     C           @OUTM     BEGSR
     C*
     C                     CLEARAB#WP2O1
     C*
     C                     MOVELW@PART    O2PART
     C                     MOVELW@SBAN    O2SBAN
     C                     MOVELW@QTY     O2QTY
     C                     MOVELW@DOCK    O2DOCK
     C                     MOVELW@LODG    O2ADDR
     C                     MOVELW@MAXL    O2SIRE
     C                     MOVELW@SHDT    O2SHDT
     C                     MOVELW@ORDR    O2ORDR
     C                     MOVELW@RELS    O2SERL
     C                     MOVELW@ULDT    O2FILR
     C* EDIT PALLET#
     C                     Z-ADDW@PLNO    PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     W@PLNX                       R
     C                     MOVELW@PLNX    O2DUMY
     C*
     C                     WRITEAB#WP2O1
     C*
     C                     ENDSR
     C* ====================================================
     C* OUT SKID LABEL
     C* ====================================================
     C           @OUTS     BEGSR
     C*
     C                     CLEARAB#WP2O1
     C*
     C                     MOVELW@DOCK    O2DOCK
     C                     MOVELW@LODG    O2ADDR
     C                     MOVELW@ORDR    O2ORDR
     C                     MOVELW@RELS    O2SERL
     C                     MOVELW@ULDT    O2FILR
     C* EDIT PALLET#
     C                     Z-ADDW@PLNO    PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     W@PLNX                       R
     C                     MOVELW@PLNX    O2DUMY
     C*
     C                     WRITEAB#WP2O1
     C*
     C                     ENDSR
