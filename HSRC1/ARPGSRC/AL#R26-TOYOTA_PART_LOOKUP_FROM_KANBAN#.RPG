     H            Y.
     F** AL#R26  *******************************************
     F* TOYOTA PART LOOKUP FROM KANBAN#                    *
     F*      LEC.        2023.07.20                        *
     F******************************************************
     FAL#WP26 IF  E           K        DISK
     FAL#PL01NIF  E           K        DISK
     FAL#PP26 O   E           K        DISK
      *
     I            DS
     I                                        1   5 CASHN1
     I                                        6  10 CASHN2
     I                                       11  12 CASHN3
     I                                        1  12 CASHN
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           KEY       KLIST
     C                     KFLD           CAKNB#
     C                     KFLD           CANUKE
      *
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
      *
     C                     READ AL#WP26                  50
      *
     C           *IN50     DOWEQ*OFF
      *
     C           KEY       CHAINAL#PL01N             51
     C           *IN51     IFEQ *OFF
     C                     MOVELCAMHN     ALMHIN
     C                     ELSE
     C                     MOVEL'N/F'     ALMHIN
     C                     MOVEL'N/F'     ALSHIN
     C                     ENDIF
      *
     C                     MOVELCAKNB#    ALKNB#
     C                     MOVELCANUKE    ALNUKE
      *
     C                     MOVELCATOKU    PTOKU   4
     C                     MOVELCANONY    PNONY   4
     C                     MOVELCAMHN     PMHIN  20 P
     C                     MOVEL*BLANKS   PSHIN  12
      *
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU
     C                     PARM           PNONY
     C                     PARM           CANKOJ
     C                     PARM           CANUKE
     C                     PARM           PMHIN
     C                     PARM           PSHIN
     C                     PARM           PFLG    1
      *
     C           PSHIN     IFEQ *BLANKS
     C                     MOVELCASHN     ALSHIN
     C                     ELSE
     C                     MOVELPSHIN     ALSHIN
     C                     ENDIF
      *
     C                     WRITEAL#PP261
     C                     CLEARAL#PP261
      *
     C                     READ AL#WP26                  50
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
