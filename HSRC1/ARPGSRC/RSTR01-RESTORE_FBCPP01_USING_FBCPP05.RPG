     H            Y.
      ** RSTR01 **********************************************
      *  RESTORE FBCPP01 USING FBCPP05                       *
      *  J.WATANABE  2021.03.23                              *
      ********************************************************
     FFBCPL5A IF  E           K        DISK
     FFBCPP05 IF  E           K        DISK
     F            FBCPP051                          KRENAMEFBCPP052
     FFBCPL01 UF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     I            DS
     I                                        1   80FBKOHZ
     I                                        1   40FBKOYY
     I                                        5   60FBKOMM
     I                                        7   80FBKODD
     I            DS
     I                                        1   40FBKOTM
     I                                        1   20FBKOHH
     I                                        3   40FBKOSS
     I            DS
     I                                        1   80FBTKHZ
     I                                        1   40FBTKYY
     I                                        5   60FBTKMM
     I                                        7   80FBTKDD
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *****************************************************
      *          MAIN ROUTINE                             *
      *****************************************************
     C                     EXSR #INIT
      *
     C                     Z-ADD20210322  K5PRHZ
     C                     Z-ADD20200301  K5TKHZ
     C           K#5A      SETLLFBCPL5A
     C                     DO   *HIVAL
     C           K#5A      READEFBCPL5A                  98
     C   98                LEAVE
      *
     C           F5SKJY    IFEQ 'D'
     C           F5PTYP    ORNE 'CHG'
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #UPD
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
     C*****************************************************
     C* UPDATE FBCPP01                                    *
     C*****************************************************
     C           #UPD      BEGSR
      *
     C                     Z-ADDF5TOKU    KBTOKU
     C                     Z-ADDF5NONY    KBNONY
     C                     MOVELF5NKOJ    KBNKOJ
     C                     MOVELF5NUKE    KBNUKE
     C                     MOVELF5MHN1    KBMHN1
     C                     MOVELF5MHN2    KBMHN2
     C                     MOVELF5MHN3    KBMHN3
     C                     MOVELF5MHN4    KBMHN4
     C           K#01      SETLLFBCPL01
     C                     DO   *HIVAL
     C           K#01      READEFBCPL01                  97
     C   97                LEAVE
      *
     C           FBSKJY    IFEQ 'D'
     C           FBKOHZ    ORNE 20210322
     C           FBTKHZ    ORNE 20200301
     C                     ITER
     C                     ENDIF
      * PRICE
     C                     EXSR #PRC
      *
     C           XXNTAN    IFNE 0
     C           FBNTAN    ANDNEXXNTAN
     C                     EXSR #PRINT
      *
     C           UPDFLG    IFEQ 'Y'
     C                     Z-ADDXXNTAN    FBNTAN
     C                     Z-ADDXXCHHZ    FBKOHZ
     C                     Z-ADDXXCHTM    FBKOTM
     C                     UPDATFBCPL011
     C                     ENDIF
      *
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C*****************************************************
     C* GET PREVIOUS PRICE                                *
     C*****************************************************
     C           #PRC      BEGSR
      *
     C                     Z-ADD0         XXNTAN 105
     C                     Z-ADD0         XXPRHZ  80
     C                     Z-ADD0         XXCHHZ  80
     C                     Z-ADD0         XXCHTM  60
     C           K#01      SETLLFBCPP05
     C                     DO   *HIVAL
     C           K#01      READEFBCPP05                  96
     C   96                LEAVE
      *
     C           F5SKJY    IFEQ 'D'
     C           F5PRHZ    ORGE 20210322
     C           F5TKHZ    ORNE 20200301
     C                     ITER
     C                     ENDIF
      * PRICE
     C           F5PRHZ    IFGT XXPRHZ
     C                     Z-ADDF5NTAN    XXNTAN
     C                     Z-ADDF5PRHZ    XXPRHZ
     C                     Z-ADDF5CHHZ    XXCHHZ
     C                     Z-ADDF5CHTM    XXCHTM
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
     C*****************************************************
     C* SET INITIAL VALUE                                 *
     C*****************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           UPDFLG  1
      *
     C           K#5A      KLIST
     C                     KFLD           K5PRHZ  80
     C                     KFLD           K5TKHZ  80
      *
     C           K#01      KLIST
     C                     KFLD           KBTOKU  40
     C                     KFLD           KBNONY  40
     C                     KFLD           KBNKOJ  1
     C                     KFLD           KBNUKE  4
     C                     KFLD           KBMHN1  5
     C                     KFLD           KBMHN2  5
     C                     KFLD           KBMHN3  5
     C                     KFLD           KBMHN4  5
      *
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** RESTORE FBCPP01 *'
     O                                   60 '*                   '
     O                                   89 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                                  106 'P.'
     O                         PAGE  Z  110
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   10 'CUST'
     O                                   15 'DELV'
     O                                   17 'F'
     O                                   22 'DOCK'
     O                                   32 'USER PART'
     O                                   49 'PRC_DATE'
     O                                   60 'EFT_DATE'
     O                                   75 'CURRENT'
     O                                   88 'BEFORE'
     O        E 1              @DTL
     O                         SEQ#  1 +000
     O                         FBTOKU  +001
     O                         FBNONY  +001
     O                         FBNKOJ  +001
     O                         FBNUKE  +001
     O                         FBMHN1  +001
     O                         FBMHN2  +001
     O                         FBMHN3  +001
     O                         FBKOHZ  +001 '    /  /  '
     O                         FBTKHZ  +001 '    /  /  '
     O                         FBNTAN1 +001
     O                         XXNTAN1 +001
     O                         XXCHHZ  +001 '    /  /  '
     O                         XXCHTM  +001 '0 :  :  '
