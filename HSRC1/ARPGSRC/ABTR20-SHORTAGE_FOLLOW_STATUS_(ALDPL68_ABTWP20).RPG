     H            Y.
     F** ABTR20 *********************************************
     F* SHORTAGE FOLLOW STATUS
     F*   SAKAKI.         2019.11.20                        *
JW1  F*   JW     2020.09.18 ADD PARAMETERS FOR ALOR28       *
     F*******************************************************
     FALDPL68 IF  E           K        DISK
     FABTWP20 UF  E           K        DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  140SDATE
     I                                        1   60STIME
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     TIME           WTIME
      *
     C                     READ ALDPL68                  20
     C           *IN20     DOWEQ'0'
     C           AFNODT    IFGE SDATE
     C                     EXSR #SB500
     C                     ENDIF
     C                     READ ALDPL68                  20
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYW      KLIST
     C                     KFLD           AFNONY
     C                     KFLD           AFNODT
     C                     KFLD           AFNOBN
     C                     KFLD           AFLPR1
     C                     KFLD           AFLPR2
     C                     KFLD           AFLPR3
      *
     C           KEYW      CHAINABTWP201             18
     C           *IN18     IFEQ '0'
     C                     ADD  1         W1CNT
     C                     UPDATABTWP201
     C                     ELSE
     C                     EXSR #SB510
     C                     CLEARABTWP201
     C                     Z-ADDAFNONY    W1NONY
     C                     Z-ADDAFNODT    W1NODT
     C                     MOVELAFNOBN    W1NOBN
     C                     MOVELAFLOC     W1LOC
     C                     MOVELAFLZET    W1LZET
     C                     MOVELAFLOC1    W1LOC1
     C                     MOVELAFLOC2    W1LOC2
     C                     MOVELAFLOC3    W1LOC3
     C                     MOVELAFLOC4    W1LOC4
     C                     MOVELAFLPR1    W1LPR1
     C                     MOVELAFLPR2    W1LPR2
     C                     MOVELAFLPR3    W1LPR3
     C                     Z-ADDAFODAT    W1ODAT
     C                     Z-ADDAFOTIM    W1OTIM
     C                     MOVELAFOTMC    W1OTMC
     C                     Z-ADD1         W1CNT
      *
     C                     Z-ADDP9ALD3    W1ALD3
     C                     Z-ADDP9ADA1    W1ADA1
     C                     Z-ADDP9NYKO    W1NYKO
     C                     Z-ADDP9SRT     W1SRT
     C                     Z-ADDP9OUK     W1OUK
     C                     Z-ADDP9BZK     W1BZK
     C                     Z-ADDP9DSK     W1DSK
     C                     Z-ADDP9JCK     W1JCK
     C                     Z-ADDP9SBK     W1SBK
     C                     Z-ADDP9LOQK    W1LOQK
     C                     Z-ADDP9OUI     W1OUI
     C                     Z-ADDP9BZI     W1BZI
     C                     Z-ADDP9DSI     W1DSI
     C                     Z-ADDP9JCI     W1JCI
     C                     Z-ADDP9SBI     W1SBI
     C                     Z-ADDP9LOQI    W1LOQI
     C                     Z-ADDP9PLOU    W1PLOU
     C                     Z-ADDP9PLBZ    W1PLBZ
     C                     Z-ADDP9PLDS    W1PLDS
     C                     Z-ADDP9PLJC    W1PLJC
     C                     Z-ADDP9PLSB    W1PLSB
     C                     Z-ADDP9PLLO    W1PLLO
     C                     Z-ADDP9PRE     W1PRE
     C                     Z-ADDP9CVS     W1CVS
     C                     Z-ADDP9ALL     W1ALL
     C                     Z-ADDP@BOX     W1BOX
     C                     WRITEABTWP201
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB510    BEGSR
      *
     C                     MOVELAFLPR1    PHSHN1
     C                     MOVELAFLPR2    PHSHN2
     C                     MOVELAFLPR3    PHSHN3
     C                     CALL 'ALOR28'
     C                     PARM           PHSHN1  5
     C                     PARM           PHSHN2  5
     C                     PARM           PHSHN3  2
     C                     PARM           P9ALD3  40       出荷照合済み
     C                     PARM           P9ADA1  40       再手配
     C                     PARM           P9NYKO  40       入庫済み
     C                     PARM           P9SRT   40        SRT(CONVEYANCE)
     C                     PARM           P9OUK   40        OUTSOURCE処理後
     C                     PARM           P9BZK   40        BZ計量済み
     C                     PARM           P9DSK   40        DS計量済み
     C                     PARM           P9JCK   40        JC計量済み
     C                     PARM           P9SBK   40        SB計量済み
     C                     PARM           P9LOQK  40        LOQ排出済み
     C                     PARM           P9OUI   40        OUTSOURCE処理中
     C                     PARM           P9BZI   40        BZ投入中
     C                     PARM           P9DSI   40        DS投入中
     C                     PARM           P9JCI   40        JC投入中
     C                     PARM           P9SBI   40        SB投入中
     C                     PARM           P9LOQI  40        LOQ投入中
     C                     PARM           P9PLOU  40        OUTSOURCE処理前
     C                     PARM           P9PLBZ  40        BZ設備前
     C                     PARM           P9PLDS  40        JC設備前
     C                     PARM           P9PLJC  40        DS設備前
     C                     PARM           P9PLSB  40        SB設備前
     C                     PARM           P9PLLO  40        LOQ設備前
     C                     PARM           P9PRE   40       ＣＶ集荷後
     C                     PARM           P9CVS   40       ＣＶ集荷前
     C                     PARM           P8LPLD  80        LAST PL DATE
     C                     PARM           P8LPLT  60        LAST PL TIME
     C                     PARM           P9ALL   40       発行枚数
JW1   * P/T STATUS
"    C                     PARM           P8PLPD  80       PT BF OUT DATE
"    C                     PARM           P8PLPS  40       PT SHIP PRELOAD
      *
     C                     Z-ADD0         P@BOX   30
      * BZ
     C                     Z-ADD0         P@BOXS  40
     C                     CALL 'AJSRS2'                   INPROCESS
     C                     PARM           PHSHN1
     C                     PARM           PHSHN2
     C                     PARM           PHSHN3
     C                     PARM           P@BOXS  40
     C                     ADD  P@BOXS    P@BOX
      * DS
     C                     Z-ADD0         P@BOXS
     C                     CALL 'AJSRS3'                   INPROCESS
     C                     PARM           PHSHN1  5
     C                     PARM           PHSHN2  5
     C                     PARM           PHSHN3  2
     C                     PARM           P@BOXS  40
     C                     ADD  P@BOXS    P@BOX
      * OQ
     C                     Z-ADD0         P@BOXS
     C                     CALL 'ALGRS1'                   INPROCESS
     C                     PARM           PHSHN1  5
     C                     PARM           PHSHN2  5
     C                     PARM           PHSHN3  2
     C                     PARM           P@BOXS  40
     C                     ADD  P@BOXS    P@BOX
      * LOQ
     C                     Z-ADD0         P@BOXS
     C                     CALL 'ALHRS1'                   INPROCESS
     C                     PARM           PHSHN1  5
     C                     PARM           PHSHN2  5
     C                     PARM           PHSHN3  2
     C                     PARM           P@BOXS  40
     C                     ADD  P@BOXS    P@BOX
      *
     CSR         ESB510    ENDSR
