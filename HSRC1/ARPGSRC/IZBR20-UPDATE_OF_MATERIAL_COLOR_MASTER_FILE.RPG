     H            Y.
     F** IZBR20 ********************************
     F* ..UPDATE OF MATERIAL COLOR MASTER FILE *
     F*   GBC            2000.07.27            *
     F******************************** IZBR20 **
     FIZBPW20 CF  E                    WORKSTN
      * MATERIAL COLOR MASTER FILE *
     FIZBPL20 UF  E           K        DISK                      A
      *
     E                    KOS     1   3  1   KON     6   ﾃcﾆ]hﾎﾞ]
     E                    ER      1  10 60               d[ｰxｮﾈｰﾆﾞ
      *
     I            DS
     I                                        1   80ZHSKHZ
     I                                        1   40ZHSKYY
     I                                        5   60ZHSKMM
     I                                        7   80ZHSKDD
     I            DS
     I                                        1   80ZHKOHZ
     I                                        1   40ZHKOYY
     I                                        5   60ZHKOMM
     I                                        7   80ZHKODD
     I            DS
     I                                        1   60WTIME
     I                                        1   20ZHKOHH
     I                                        3   40ZHKOSS
     C*================================================================
     C           *ENTRY    PLIST
     C                     PARM           US     10        ﾏｰﾅﾞｰ xb
      *
     C                     MOVE *BLANK    KTYPE
     C                     MOVE *BLANK    D1ZAIS
     C                     MOVE *BLANK    MTYPE
     C                     MOVE *BLANK    MZAIS
     C*------------------------------*
     C*     ...画面　－　１...     *
     C*------------------------------*
     C           STP1      TAG
     C                     EXFMTIZBPW201
     C                     SETOF                     0102
     C                     SETOF                     99
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C*----------------------------------------*
     C*     UPDATE
     C*----------------------------------------*
     C                     SETOF                     90
     C                     Z-ADD1         A       20
     C           KTYPE     LOKUPKOS,A                    90
     C           *IN90     IFEQ '0'
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
     C                     MOVE KON,A     WNAME
      *
     C*------------------------------------------*
     C*     MATERIAL
     C*------------------------------------------*
     C           D1ZAIS    IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
      *
     C*----------------------------------------*
     C*     ...マスター　の　チェック...     *
     C*----------------------------------------*
     C           D1ZAIS    CHAINIZBPL20              90
     C           KTYPE     IFEQ '2'                        :ADD
     C           *IN90     IFEQ '0'
     C           ZHSKJY    IFEQ 'D'
     C           ZHSKHZ    ANDLE*DATE
     C                     GOTO STP2
     C                     END
      *
     C                     SETON                     010299
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C           KTYPE     IFEQ '1'                        :CHANGE
     C           *IN90     IFEQ '1'
     C                     SETON                     010299
     C                     MOVE ER,5      MSG
     C                     GOTO STP1
     C                     END
      *
     C           ZHSKJY    IFEQ 'D'
     C           ZHSKHZ    ANDLE*DATE
     C                     SETON                     010299
     C                     MOVE ER,6      MSG
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C           KTYPE     IFEQ '0'                        :CANCEL
     C           *IN90     IFEQ '1'
     C                     SETON                     010299
     C                     MOVE ER,7      MSG
     C                     GOTO STP1
     C                     END
      *
     C           ZHSKJY    IFEQ 'D'
     C           ZHSKHZ    ANDLE*DATE
     C                     SETON                     010299
     C                     MOVE ER,8      MSG
     C                     GOTO STP1
     C                     END
     C                     END
     C*--------------------
     C           STP2      TAG
      *
     C                     MOVE D1ZAIS    D2ZAIS
     C           KTYPE     IFEQ '2'                        :ADD
     C                     MOVE *BLANK    ZHSKJY
     C                     Z-ADD0         ZHSKHZ
     C                     MOVE *BLANK    D2ZRCD
     C                     MOVEL*BLANK    D2ZIRO
     C                     ELSE
     C                     MOVE ZHZRCD    D2ZRCD
     C                     MOVELZHZIRO    D2ZIRO
     C                     END
      *
     C*------------------------------*
     C*          DSP02
     C*------------------------------*
     C           STP3      TAG
     C                     EXFMTIZBPW202
     C                     SETOF                     030499
      *
     C           *INKC     IFEQ '1'
     C                     MOVE *BLANK    KTYPE
     C                     MOVE *BLANK    D1ZAIS
     C                     SETOF                     010299
     C                     GOTO STP1
     C                     END
      *
     C*--------------------------------------*
     C*     ... CHECK
     C*--------------------------------------*
     C           D2ZRCD    IFEQ *BLANK
     C                     SETON                     0399
     C                     MOVE ER,9      MSG
     C                     GOTO STP3
     C                     END
     C           D2ZIRO    IFEQ *BLANK
     C                     SETON                     0499
     C                     MOVE ER,10     MSG
     C                     GOTO STP3
     C                     END
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP3
     C                     END
      *
     C           KTYPE     IFEQ '0'                        :CANCEL
     C                     MOVE 'D'       ZHSKJY
     C                     Z-ADD*DATE     ZHSKHZ
     C                     END
      *
     C                     Z-ADD*DATE     ZHKOHZ
     C                     TIME           WTIME
     C                     MOVELUS        ZHKOME
     C                     MOVE D2ZAIS    ZHZAIS
     C                     MOVE D2ZRCD    ZHZRCD
     C                     MOVELD2ZIRO    ZHZIRO
      *
     C           *IN90     IFEQ '0'
     C                     UPDATIZBPL201
     C                     ELSE
     C                     WRITEIZBPL201
     C                     END
      *
     C                     MOVE KTYPE     MTYPE
     C                     MOVE D1ZAIS    MZAIS
     C                     MOVE *BLANK    KTYPE
     C                     MOVE *BLANK    D1ZAIS
     C                     GOTO STP1
      *
      *
      *
**  KOS.KON
0CANCEL
1CHANGE
2ADD
**  ERR
E-01 UPDATE INSTRUCTION IS <0 1 2>
E-02 INPUT MATERIAL
E-03 KANBAN KIND IS <A / B / C / D / E / 0>
E-04 ADD WAS APPOINTED BUT M/F EXIST
E-05 CHANGE WAS APPOINTED BUT M/F DON'T EXIST
E-06 CHANGE WAS APPOINTED BUT M/F IS CANCELLED ALREADY
E-07 CANCEL WAS APPOINTED BUT M/F DON'T EXIST
E-08 CANCEL WAS APPOINTED BUT M/F IS CANCELLED ALREADY
E-09 INPUT MATERIAL COLOR CODE
E-10 INPUT MATERIAL COLOR
