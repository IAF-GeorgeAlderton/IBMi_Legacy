     F* TCHK1 03/22/07 BUG FIX
     F********************************** ECQR15 **
     FECSPW50 CF  E                    WORKSTN
     FECSPL10 UF  E           K        DISK                      A
     FECSPL20 IF  E           K        DISK                      A
     FECSWL10 IF  E           K        DISK
     FECSPL05 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FAB#PPCT UF  E           K        DISK                      A
      *-----------------------------------------------------------
     E                    CMD     1   1 78
     E                    MSG     1   2 78
      *-----------------------------------------------------------
     IECSWP101
     I              E1DATE                          W1DATE
     I              E1KAT1                          W1KAT1
     I              E1KAT2                          W1KAT2
     I              E1KAT3                          W1KAT3
     I              E1KAT4                          W1KAT4
     I              E1LOC1                          W1LOC1
     I              E1LOC2                          W1LOC2
     I              E1LOC3                          W1LOC3
     I              E1LOC4                          W1LOC4
     I              E1SQTY                          W1SQTY
      *
     I            DS
     I                                        1   80D@DATE
     I                                        1   40D@YY
     I                                        5   60D@MM
     I                                        7   80D@DD
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I                                        1   60K@YYMM
     I            DS
     I                                        1   80EQYMD
     I                                        1   40EQYOYY
     I                                        5   60EQYOMM
     I                                        7   80EQYODD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------
      *  MAIN ROUTINE
      *--------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *------------------------------------------------------
      *
     C           KEY1      KLIST
     C                     KFLD           W1KAT1
     C                     KFLD           W1KAT2
     C                     KFLD           W1KAT3
     C******               KFLD           W1KAT4
     C                     KFLD           D@DATE
     C           KEY2      KLIST
     C                     KFLD           W1KAT1
     C                     KFLD           W1KAT2
     C                     KFLD           W1KAT3
     C*****                KFLD           W1KAT4
     C           K#PCT     KLIST
     C                     KFLD           K@KWD1  8
     C           K#EC1     KLIST
     C                     KFLD           W1KAT1
     C                     KFLD           W1KAT2
     C                     KFLD           W1KAT3
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#EC11    KLIST
     C                     KFLD           W1KAT1
     C                     KFLD           W1KAT2
     C                     KFLD           W1KAT3
     C           K#WEC     KLIST
     C                     KFLD           D@DATE
     C                     KFLD           E1KAT1
     C                     KFLD           E1KAT2
     C                     KFLD           E1KAT3
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
      *
     C                     MOVEL'DIEINVTY'K@KWD1
      *
     C                     MOVE '01'      W@ID    2
      *
     C           *HIVAL    SETGTECSWL10
     C                     READPECSWL10                  90
     C           *IN90     IFEQ *OFF
     C                     MOVELW1DATE    D@YYMM
     C                     Z-ADDW1DATE    D@DATE
     C                     ELSE
     C                     MOVE MSG,1     D@MSG
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SCRN1    BEGSR
      *-----------------------------------------------------
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK
     C           *IN99     IFEQ *OFF
     C           *INKX     ANDEQ*ON
     C                     EXSR #UPD
     C                     MOVE '99'      W@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #CHK      BEGSR
      *-----------------------------------------------------
     C                     SETOF                     616299
     C                     MOVE *BLANK    D@MSG
      *
     C                     Z-ADDD@YYMM    K@YYMM
     C           K#AGD     SETGTAGDPL12
     C           K#AGD     REDPEAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDF8KAYY    D@YY
     C                     Z-ADDF8KAMM    D@MM
     C                     Z-ADDF8KADD    D@DD
     C                     ENDIF
      *
     C           D@DATE    CHAINECSWL10              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     MOVE MSG,1     D@MSG
     C                     ELSE
     C           K#PCT     CHAINAB#PPCT             N90
     C           *IN90     IFEQ *OFF
     C           D@DATE    ANDEQCTNBR1
     C                     SETON                     6199
     C                     MOVE MSG,2     D@MSG
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADDD@DATE    K@YMD
      *
     C                     ENDSR
      *------------------------------------------------------
      *   UPDATE
      *------------------------------------------------------
     C           #UPD      BEGSR
      *
     C           D@DATE    SETLLECSWL10
     C           *IN90     DOUEQ*ON
     C           D@DATE    READEECSWL10                  90
     C           *IN90     IFEQ *OFF
      * IN
     C                     Z-ADD*ZERO     @IQTY   50
     C           KEY1      SETLLECSPL20              95
     C           *IN95     DOUEQ*ON
     C           KEY2      READEECSPL20                  95
     C           *IN95     IFEQ *OFF
     C           E2DATE    ANDGTD@DATE
     C           E2WHID    ANDNE'3'
     C                     ADD  E2WQTY    @IQTY
     C                     ENDIF
     C                     ENDDO
      *  OUT
     C                     Z-ADD*ZERO     @OQTY   50
     C           K#EC1     SETLLECSPL05
     C           *IN95     DOUEQ*ON
     C           K#EC11    READEECSPL05                  95
     C           *IN95     IFEQ *OFF
     C           EQYMD     ANDGTD@DATE
     C                     ADD  EQKOSU    @OQTY
     C                     ENDIF
     C                     ENDDO
      * NEW INVENTORY
     C           W1SQTY    SUB  @OQTY     @NQTY   50
     C                     ADD  @IQTY     @NQTY
      *
     C           KEY2      CHAINECSPL10              95
     C           *IN95     IFEQ *OFF
     C                     Z-ADDE1SQTY    @@QTY   50
     C                     ELSE
     C                     Z-ADD*ZERO     @@QTY
     C                     CLEARECSPP101
     C                     MOVE W1LOC1    E1LOC1
     C                     MOVE W1LOC2    E1LOC2
     C                     MOVE W1LOC3    E1LOC3
     C                     MOVE W1LOC4    E1LOC4
     C                     MOVE W1KAT1    E1KAT1
     C                     MOVE W1KAT2    E1KAT2
     C                     MOVE W1KAT3    E1KAT3
     C                     MOVE W1KAT4    E1KAT4
     C                     ENDIF
      *
     C                     Z-ADD@NQTY     E1SQTY
     C                     Z-ADD*DATE     E1KDAT
     C                     TIME           E1KTIM
     C                     MOVEL#USER     E1KOME
     C                     MOVEL#PGM      E1KPGM
     C                     Z-ADD*DATE     E1INDT
     C   95                WRITEECSPP101
     C  N95                UPDATECSPP101
      *
     C           @NQTY     SUB  @@QTY     @@BAL   50
     C           @@BAL     IFNE *ZERO
     C                     CLEARECSPP201
     C                     Z-ADD*DATE     E2KDAT
     C                     TIME           E2KTIM
     C                     MOVEL#USER     E2KOME
     C                     MOVEL#PGM      E2KPGM
     C                     Z-ADD*DATE     E2DATE
     C                     MOVE W1KAT1    E2KAT1
     C                     MOVE W1KAT2    E2KAT2
     C                     MOVE W1KAT3    E2KAT3
     C                     MOVE W1KAT4    E2KAT4
     C                     MOVE '3'       E2WHID
     C                     Z-ADD@@BAL     E2WQTY
     C                     WRITEECSPP201
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      * NO COUNT
     C           *LOVAL    SETLLECSPL10
     C           *IN90     DOUEQ*ON
     C                     READ ECSPL10                  90
     C           *IN90     IFEQ *OFF
     C           E1SQTY    ANDNE*ZERO
      *
     C           K#WEC     CHAINECSWL10              95
     C           *IN95     IFEQ *ON
      *
     C                     Z-ADDE1SQTY    @@QTY   50
     C                     Z-ADD*ZERO     E1SQTY
     C                     Z-ADD*DATE     E1KDAT
     C                     TIME           E1KTIM
     C                     MOVEL#USER     E1KOME
     C                     MOVEL#PGM      E1KPGM
     C                     Z-ADD*DATE     E1INDT
     C                     UPDATECSPP101
      *
     C                     CLEARECSPP201
     C                     Z-ADD*DATE     E2KDAT
     C                     TIME           E2KTIM
     C                     MOVEL#USER     E2KOME
     C                     MOVEL#PGM      E2KPGM
     C                     Z-ADD*DATE     E2DATE
TCHK1C*                    MOVE W1KAT1    E2KAT1
TCHK1C*                    MOVE W1KAT2    E2KAT2
TCHK1C*                    MOVE W1KAT3    E2KAT3
TCHK1C*                    MOVE W1KAT4    E2KAT4
TCHK1C                     MOVE E1KAT1    E2KAT1
TCHK1C                     MOVE E1KAT2    E2KAT2
TCHK1C                     MOVE E1KAT3    E2KAT3
TCHK1C                     MOVE E1KAT4    E2KAT4
     C                     MOVE '3'       E2WHID
     C                     Z-SUB@@QTY     E2WQTY
     C                     WRITEECSPP201
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           K#PCT     CHAINAB#PPCT              90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDD@DATE    CTNBR1
     C                     UPDATAB#PPCT1
     C                     ELSE
     C                     CLEARAB#PPCT1
     C                     MOVELK@KWD1    CTKEY1
     C                     Z-ADDD@DATE    CTNBR1
     C                     WRITEAB#PPCT1
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------
** CMD
  F1:END     F23(SHIFT + F11):UPDATE
