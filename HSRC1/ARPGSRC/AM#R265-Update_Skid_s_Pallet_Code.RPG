     H            Y.                                    1
      ***AM#R265  **************************************************************
      *  UPDATE SKID'S PALLET CODE                                             *
      *
      **************************************************************************
     FAM#PW265CF  E                    WORKSTN
     F                                              KINFDS @INFDS
     FAM#PL08 IF  E           K        DISK
     FAM#PL05 UF  E           K        DISK
     FAM#PL21 UF  E           K        DISK
     FAL#PL0C UF  E           K        DISK
      **************************************************************************
     E                    ERR     1  10 70
      **************************************************************************
     I@INFDS      DS
     I                                     *STATUS  @STTS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60WSSTM6
     I                                        1   40WSSTM4
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  140WSSDAT
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I            DS
     I                                        1  50 MFBC
     I                                        1   5 MFNAMC
     I                                       11  12 MFDOCK
     I                                       13  24 MFORD#
     I                                       37  38 MFPALT
     I                                       44  44 MFSIDE
     I                                       45  50 MFFIL2
     I            DS
     I                                        1 256 KNBC
     I                                      196 197 KNPALT
      *
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'10'      #FMT10
     C           @@ID      CASEQ'30'      #FMT30
     C           @@ID      CASEQ'40'      #FMT40
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      **************************************************************************
      *         INITIALIZE
      **************************************************************************
     C           *INZSR    BEGSR
      *
     C           KEY1      KLIST
     C                     KFLD           MFBC
      *
     C           KEY08     KLIST
     C                     KFLD           F3NONY
     C                     KFLD           F3DOCK
     C                     KFLD           F3ORD#
     C                     KFLD           F3PALT
     C                     KFLD           SKID
      *
     C           KEY0C     KLIST
     C                     KFLD           MFNAMC
     C                     KFLD           MFORD#
     C                     KFLD           ##DOCK
     C                     KFLD           MFPALT
      *
     C           KEY21     KLIST
     C                     KFLD           MFBC
      *
     C                     TIME           WSDT
      *
     C                     MOVEL*BLANK    F1MFBC
     C                     MOVEL*BLANK    MSG
      *
     C                     MOVEL'30'      @@ID    2
     C                     MOVEL'30'      @@IDSV  2
     C                     MOVEL*OFF      *IN49
      *
     C                     ENDSR
      *************************************************************************
      *     1ST SCREEN(MANIFEST BARCODE)
      **************************************************************************
     C           #FMT10    BEGSR
      *
     C                     SETOF                     4748
     C                     WRITEFMT099
     C                     EXFMTFMT010
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKE     WHEQ *ON
     C                     SETOF                     313241
     C                     SETOF                     424344
     C                     SETOF                     45
     C                     MOVE '30'      @@ID
     C                     MOVE '30'      @@IDSV
     C                     OTHER
     C                     EXSR #CHK10
     C           *IN49     IFEQ *OFF
     C                     MOVEL'40'      @@ID
     C                     ENDIF
     C           *IN49     IFEQ *ON
     C                     MOVEL'10'      @@ID
     C                     MOVEL'10'      @@IDSV
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************************
      *     1ST SCREEN CHECK
      **************************************************************************
     C           #CHK10    BEGSR
      *
     C                     SETOF                     313249
     C                     TIME           WSDT
      *
     C           F1MFBC    IFEQ *BLANK
     C                     SETON                     3149
     C                     MOVELERR,1     MSG
     C                     GOTO #EF10
     C                     ENDIF
      *
     C                     MOVELF1MFBC    MFBC
     C                     MOVEL'A'       MFSIDE
      *
     C           MFBC      CHAINAM#PL05             N98
     C           *IN98     IFEQ *ON
     C                     SETON                     3149
     C                     MOVELERR,2     MSG
     C                     GOTO #EF10
     C                     ENDIF
      *
      *
     C           #EF10     ENDSR
      *************************************************************************
      *     1ST ALTERNATE SCREEN(MANUALLY SELECT)
      **************************************************************************
     C           #FMT30    BEGSR
      *
     C                     SETOF                     4748
     C                     WRITEFMT099
     C                     EXFMTFMT030
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKE     WHEQ *ON
     C                     SETOF                     313241
     C                     SETOF                     424344
     C                     SETOF                     45
     C                     MOVE '10'      @@ID
     C                     MOVE '10'      @@IDSV
     C                     OTHER
     C                     EXSR #CHK30
     C           *IN49     IFEQ *OFF
     C                     MOVEL'40'      @@ID
     C                     ENDIF
     C           *IN49     IFEQ *ON
     C                     MOVEL'30'      @@ID
     C                     MOVEL'30'      @@IDSV
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************************
      *     1ST ALTERNATE SCREEN CHECK
      **************************************************************************
     C           #CHK30    BEGSR
      *
     C                     SETOF                     414243
     C                     SETOF                     444549
     C                     TIME           WSDT
      *
     C           F3NONY    IFEQ *ZERO
     C                     SETON                     4149
     C                     MOVELERR,4     MSG
     C                     GOTO #EF30
     C                     ENDIF
      *
     C           F3DOCK    IFEQ *BLANKS
     C                     SETON                     4249
     C                     MOVELERR,5     MSG
     C                     GOTO #EF30
     C                     ENDIF
      *
     C           F3ORD#    IFEQ *BLANKS
     C                     SETON                     4349
     C                     MOVELERR,6     MSG
     C                     GOTO #EF30
     C                     ENDIF
      *
     C           F3SKID    IFEQ *ZERO
     C                     SETON                     4549
     C                     MOVELERR,7     MSG
     C                     GOTO #EF30
     C                     ENDIF
      *
     C                     EXSR GETMF#
      *
     C                     MOVEL'A'       MFSIDE
      *
     C           MFBC      CHAINAM#PL05             N98
     C           *IN98     IFEQ *ON
     C                     SETON                     414243
     C                     SETON                     444549
     C                     MOVELERR,2     MSG
     C                     GOTO #EF30
     C                     ENDIF
      *
     C           #EF30     ENDSR
      *************************************************************************
      *     GET MANIFEST NUMBER.
      **************************************************************************
     C           GETMF#    BEGSR
      *
     C                     MOVE *BLANKS   MFBC
     C                     MOVELF3SKID    SKID    4
     C                     MOVE 'A'       SKID
      *
     C           KEY08     SETLLAM#PL08
     C           *IN98     DOUEQ*ON
     C           KEY08     READEAM#PL08                  98
      *
     C           *IN98     IFEQ *OFF
     C           R1SKJY    ANDEQ*BLANK
     C           R1HNTE    ANDEQ'OK'
     C                     MOVELR1MFBC    MFBC
     C                     MOVELR1PALT    SVPALT  2
     C                     MOVELR1MFBC    SVMFBC 50
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************************
      *     2ND SCREEN(NEW PALLET CODE)
      **************************************************************************
     C           #FMT40    BEGSR
      *
     C                     SETOF                     4748
     C                     EXFMTFMT040
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
      *
     C                     SELEC
     C           *INKL     WHEQ *ON
     C                     MOVEL@@IDSV    @@ID
     C                     OTHER
     C                     EXSR #CHK40
     C           *IN49     IFEQ *OFF
     C                     EXSR #UPDPL
     C                     MOVEL@@IDSV    @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************************
      *     2ND SCREEN CHECK -  NEW PALLET CODE
      **************************************************************************
     C           #CHK40    BEGSR
      *
     C                     SETOF                     3149
     C                     TIME           WSDT
      *
     C           F4PALT    IFEQ MFPALT
     C                     SETON                     3149
     C                     MOVELERR,7     MSG
     C                     GOTO #EF40
     C                     ENDIF
      *
     C                     MOVELF4PALT    MFPALT
      *
     C           KEY1      SETLLAM#PL05
      *
     C                     DO   *HIVAL
      *
     C           KEY1      READEAM#PL05             N    98
      *
     C   98                LEAVE
      *
     C           R1SKJY    IFEQ 'D'
     C           R1HNTE    OREQ 'NG'
     C                     ITER
     C                     ENDIF
      *
     C           *IN98     IFEQ *OFF
     C                     SETON                     3149
     C                     MOVELERR,8     MSG
     C                     GOTO #EF40
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           #EF40     ENDSR
      *************************************************************************
      *     2ND SCREEN CHECK -  NEW PALLET CODE
      *************************************************************************
      *
     C           #UPDPL    BEGSR
      *
      * update packing file...
     C                     MOVELSVMFBC    MFBC
     C           KEY1      SETLLAM#PL05
      *
     C                     DO   *HIVAL
      *
     C                     MOVELSVMFBC    MFBC
     C           KEY1      READEAM#PL05                  97
      *
     C   97                LEAVE
      *
     C           R1HNTE    IFEQ 'NG'
     C           R1SKJY    OREQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELF4PALT    R1PALT
     C                     MOVELF4PALT    R12ALT
      *
     C                     MOVELF4PALT    MFPALT
     C                     MOVELMFBC      R1MFBC
      *
     C                     MOVELR12D      KNBC
     C                     MOVELF4PALT    KNPALT
     C                     MOVELKNBC      R12D
     C                     UPDATAM#PL051
      *
     C                     ENDDO
      *
      * update load file...
     C                     MOVELSVMFBC    MFBC
     C           KEY21     SETLLAM#PL21
      *
     C                     DO   *HIVAL
      *
     C           KEY21     READEAM#PL21                  97
      *
     C   97                LEAVE
      *
     C           R2HNTE    IFEQ 'NG'
     C           R2SKJY    OREQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELF4PALT    R2PLTC
      *
     C                     MOVELF4PALT    MFPALT
     C                     MOVELMFBC      R22D
      *
     C                     UPDATAM#PP211
      *
     C                     ENDDO
      *
      * update web order file...
     C                     MOVELSVMFBC    MFBC
     C                     MOVELMFDOCK    ##DOCK  4 P
     C           KEY0C     SETLLAL#PL0C
      *
     C                     DO   *HIVAL
      *
     C           KEY0C     READEAL#PL0C                  97
      *
     C   97                LEAVE
      *
     C           CASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELF4PALT    CAPALT
      *
     C                     MOVELCAALL     KNBC
     C                     MOVELF4PALT    KNPALT
     C                     MOVELKNBC      CAALL
      *
     C                     UPDATAL#PL0C1
      *
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************************
