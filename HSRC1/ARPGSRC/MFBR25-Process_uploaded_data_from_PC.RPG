     H            Y.
     F** MFBR25 ********************************
     F*    PROCESS UPLOADED DATA
     F*        TCH  11/24/2004                 *
     F******************************** MFBR25 **
     FWREPORT IP  F     128            DISK
     FMFAPL22 IF  E           K        DISK
     FMFAPL32 IF  E           K        DISK
     FMFBWP01 O   E                    DISK                      A
      *-----------------------------------------
     E                    ARY        98  1
     E                    A10        10  1
     E                    A10X       10  1
     E                    AL1    26  26  1
     E                    AL2    26  26  1
     E                    TAB1    1   6  4   TAB2    3
      *-----------------------------------------
     IWREPORT AA  01
     I                                        1   4 SEQ
     I                                       12  15 PLNT
     I                                       17  24 DATE
     I                                       29  29 SHFT
     I                                       31 128 DATA
     I            DS
     I                                        1   80M1DATE
     I                                        1   40M1SAYY
     I                                        5   60M1SAMM
     I                                        7   80M1SADD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *---------------------------------------------------------
     C                     CLEARMFBWP011
      *
     C                     MOVEADATA      ARY
     C                     MOVE PLNT      M1KJCD
     C                     MOVE DATE      M1DATE
     C                     MOVE SHFT      M1HYKU
      * MACHINE NUMBER
     C                     Z-ADD*ZERO     X       30
     C                     MOVE *BLANK    A10
     C                     Z-ADD*ZERO     Y       30
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           ARY,X     IFEQ ','
     C                     LEAVE
     C                     ENDIF
     C           ARY,X     IFNE '"'
     C                     ADD  1         Y
     C                     MOVE ARY,X     A10,Y
     C                     Z-ADD1         M       30
     C           ARY,X     LOKUPAL1,M                    10
     C   10                MOVE AL2,M     A10,Y
     C                     ENDIF
     C                     ENDDO
      *
     C           Y         IFEQ 3
     C                     MOVEAA10       K@MCHN
     C                     EXSR #MCN
     C                     ENDIF
      *
     C           Y         IFEQ 4
     C                     MOVEAA10       @4      4
     C           A10,1     IFEQ 'U'
     C                     MOVE @4        K@MCHN
     C                     EXSR #MCN
     C                     ELSE
     C           @4        LOKUPTAB1      TAB2           10
     C           *IN10     IFEQ *ON
     C                     MOVE TAB2      K@MCHN
     C                     EXSR #MCN
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      * WORKER
     C                     ADD  1         X
     C                     MOVE *BLANK    A10
     C                     Z-ADD*ZERO     Y       30
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           ARY,X     IFEQ ','
     C                     LEAVE
     C                     ENDIF
     C           ARY,X     IFNE '"'
     C                     ADD  1         Y
     C                     MOVE ARY,X     A10,Y
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAA10       M1SAGY
     C                     MOVEAA10       M1WKCD
      * SETUP TIME
     C                     EXSR #NBR
     C           @10N      DIV  100       M1DNTI
      * ADJUST
     C                     EXSR #NBR
     C           @10N      DIV  100       M1TYTI
      * WAIT FOR CHANGEOVER
     C                     EXSR #NBR
     C           @10N      DIV  100       M1DMTI
      * WAIT FOR MATERIAL
     C                     EXSR #NBR
     C           @10N      DIV  100       M1ZMTI
      * WAIT FOR KANBAN
     C                     EXSR #NBR
     C           @10N      DIV  100       M1KNTI
      * WAIT FOR TOOLING TIME
     C                     EXSR #NBR
     C           @10N      DIV  100       M1KTTI
      * WAIT FOR REPAIR
     C                     EXSR #NBR
     C           @10N      DIV  100       M1KSTI
      * WAIT FOR OTHER
     C                     EXSR #NBR
     C           @10N      DIV  100       M1TKTI
      * ACTIAL WORKING
     C                     EXSR #NBR
     C           @10N      DIV  100       M1KADU
      * PIECES PRODUCED
     C                     EXSR #NBR
     C           @10N      DIV  100       M1MUHN
      * SETIP FREQUENCY
     C           X         ADD  1         Y
     C           ARY,Y     IFNE *BLANK
     C                     EXSR #NBR
     C           @10N      DIV  100       M1DNKI
     C                     ENDIF
      *
     C                     WRITEMFBWP011
      *---------------------------------------------------------
     C           #NBR      BEGSR
      *
     C                     MOVE *BLANK    A10
     C                     Z-ADD*ZERO     Y       30
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           ARY,X     IFEQ ','
     C           ARY,X     OREQ *BLANK
     C                     LEAVE
     C                     ENDIF
     C           ARY,X     IFNE '"'
     C           ARY,X     ANDNE'.'
     C                     ADD  1         Y
     C                     MOVE ARY,X     A10,Y
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ALL'0'   A10X
     C                     Z-ADD10        Y
     C                     Z-ADD10        Z       30
     C                     DO   10
     C           A10,Y     IFNE *BLANK
     C                     MOVE A10,Y     A10X,Z
     C                     SUB  1         Z
     C                     ENDIF
     C                     SUB  1         Y
     C           Y         IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAA10X      @10    10
     C                     MOVE @10       @10N   100
      *
     C                     ENDSR
      *---------------------------------------------------------
     C           #MCN      BEGSR
      *
     C           K#MFA     CHAINMFAPL22              90
     C           *IN90     IFEQ *OFF
     C                     MOVE K@MCHN    M1KIBN
     C                     MOVE M@KOTE    M1KTCD
     C                     MOVE M@KBN2    M1KIHS
     C                     ELSE
     C           K#MFA     CHAINMFAPL32              90
     C           *IN90     IFEQ *OFF
     C                     MOVE M@KOTE    M1KTCD
     C                     MOVE M@KBN2    M1KIHS
     C                     MOVE M@KBN1    M1KIBN
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *---------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#MFA     KLIST
     C                     KFLD           K@FACT  40
     C                     KFLD           K@MCHN  3
      *
     C                     Z-ADD0111      K@FACT
      *
     C                     ENDSR
** AL1
abcdefghijklmnopqrstuvwxyz
** AL2
ABCDEFGHIJKLMNOPQRSTUVWXYZ
** TAB1 / TAB2
SK01S01
SK02S02
SK03S03
TP01TP1
TP02TP2
TP03TP3
