     H            Y.
     F** AB#R2C1 ************************************************************
     F*  PALLET# ADD TO LABEL DATA FOR OHASHI,ETC                           *
     F*                                                                     *
     F* TCHK1 04/11/06 CREATE                                               *
     F* TCHK2 06/26/06 ADD CONTROL FOR 3545(TMI BARDSTOWN)                  *
JW1  F* JW    10/29/19 ADD FIELD (INFLDA/B/C/D)                             *
     F****************************************** AB#R2C *********************
     FAB#WP2IMIF  E           K        DISK
     FAB#PL90 IF  E           K        DISK
     FAB#WP2INO   E                    DISK
     E*****************************************************************
     I            DS
     I                                        1   5 W@PLNX
     I                                        1   1 W@PLN1
     I                                        2   2 W@PLN2
     I                                        3   3 W@PLN3
     I                                        4   4 W@PLN4
     I                                        5   5 W@PLN5
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
TCHK2I            DS
TCHK2I                                        1  55 W@NKEY
TCHK2I                                        1   4 IMDELY
TCHK2I                                        5  12 IMSHDT
TCHK2I                                       13  17 IMDUMY
TCHK2I                                       18  21 IMDOCK
TCHK2I                                       22  31 IMORDR
TCHK2I                                       32  35 IMSBAN
TCHK2I                                       36  55 IMPART
     C***********************************************************************
     C                     EXSR @INZ
     C                     EXSR @MAIN
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C***********************************************************
     C* @INZ:INITIALIZE WORK AREA
     C***********************************************************
     C           @INZ      BEGSR
     C*
     C                     Z-ADD*ZERO     W@MXPL  50
     C                     Z-ADD*ZERO     W@CCNT  50
     C                     Z-ADD1         W@PLNO  50
TCHK2C                     MOVEL*BLANK    W@OKEY 55
     C*
     C                     MOVEL*OFF      W@1ST   1
     C*
     C                     ENDSR
     C***********************************************************
     C* @MAIN
     C***********************************************************
     C           @MAIN     BEGSR
     C*
     C           *LOVAL    SETLLAB#WP2IM
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AB#WP2IM                 99
     C   99                LEAVE
     C*
     C* GET THE NUMBER OF LABEL
     C           W@1ST     IFEQ *OFF
     C           IMDELY    CHAINAB#PL90              98
     C           *IN98     IFEQ '0'
     C                     Z-ADDYAMXPL    W@MXPL
     C                     Z-ADDYA#LAB    W#LAB   50
     C           W#LAB     IFNE *ZERO
     C           W#LAB     MULT W@MXPL    W@MXPL
     C                     END
     C                     END
     C                     MOVEL*ON       W@1ST
     C                     END
TCHK2C*
TCHK2C           IMDELY    IFEQ '3545'
TCHK2C           W@OKEY    IFEQ *BLANK
TCHK2C                     MOVELW@NKEY    W@OKEY
TCHK2C                     END
TCHK2C           W@NKEY    IFNE W@OKEY
TCHK2C                     Z-ADD999       W@CCNT
TCHK2C                     MOVELW@NKEY    W@OKEY
TCHK2C                     END
TCHK2C                     END
     C*
     C                     ADD  1         W@CCNT
     C           W@CCNT    IFGT W@MXPL
     C                     Z-ADD1         W@CCNT
     C                     ADD  1         W@PLNO
     C                     END
     C                     MOVELW@PLNO    W@PLNX
     C                     DO
     C           W@PLN1    IFEQ *ZERO
     C                     MOVEL*BLANK    W@PLN1
     C                     ELSE
     C                     LEAVE
     C                     END
     C           W@PLN2    IFEQ *ZERO
     C                     MOVEL*BLANK    W@PLN2
     C                     ELSE
     C                     LEAVE
     C                     END
     C           W@PLN3    IFEQ *ZERO
     C                     MOVEL*BLANK    W@PLN3
     C                     ELSE
     C                     LEAVE
     C                     END
     C           W@PLN4    IFEQ *ZERO
     C                     MOVEL*BLANK    W@PLN4
     C                     ELSE
     C                     LEAVE
     C                     END
     C                     ENDDO
     C*
     C                     CLEARAB#WP2NR
     C                     MOVELIMPART    INPART
     C                     MOVELIMSBAN    INSBAN
     C                     MOVELIMQTY     INQTY
     C                     MOVELIMDOCK    INDOCK
     C                     MOVELIMADDR    INADDR
     C                     MOVELIMSIRE    INSIRE
     C                     MOVELIMPNAM    INPNAM
     C                     MOVELIMIPAR    INIPAR
     C                     MOVELIMSHDT    INSHDT
     C                     MOVELIMSEQ#    INSEQ#
     C                     MOVELIMORDR    INORDR
     C**JW                 MOVELW@PLNX    INDUMY
      *
JW   C           IMDELY    IFEQ '5912'
.    C           IMDELY    OREQ '5915'
.    C           IMDELY    OREQ '5917'
.    C           IMDELY    OREQ '5919'
.    C           IMDELY    OREQ '5923'
.    C                     MOVEL'EA'      INDUMY    P
.    C                     ELSE
.    C                     MOVELW@PLNX    INDUMY
JW   C                     ENDIF
      *
     C                     MOVELIMLOC1    INLOC1
     C                     MOVELIMLOC2    INLOC2
     C                     MOVELIMLOC3    INLOC3
     C                     MOVELIMLOC4    INLOC4
     C                     MOVELIMDELY    INDELY
     C                     MOVELIMFACT    INFACT
     C                     MOVELIMZETI    INZETI
     C                     MOVELIMUNIT    INUNIT
     C                     MOVELIMCNAM    INCNAM
     C                     MOVELIMWEIT    INWEIT
     C                     MOVELIMSERL    INSERL
     C                     MOVELIMSBN5    INSBN5
     C                     MOVELIMSB10    INSB10
     C                     MOVELIMRELS    INRELS
     C                     MOVELIMTTL1    INTTL1
     C                     MOVELIMFLD1    INFLD1
      *
JW1  C                     MOVELIMFLDA    INFLDA
 |   C                     MOVELIMFLDB    INFLDB
 |   C                     MOVELIMFLDC    INFLDC
JW1  C                     MOVELIMFLDD    INFLDD
      *
     C                     WRITEAB#WP2NR
     C*
     C                     ENDDO
     C*
     C                     ENDSR
