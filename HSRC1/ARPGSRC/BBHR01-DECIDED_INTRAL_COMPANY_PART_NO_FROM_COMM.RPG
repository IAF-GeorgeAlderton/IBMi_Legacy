     I                                        6  10 PSHN2
     I                                       11  12 PSHN3
     C           KEY       KLIST
     C                     KFLD           ITOKU
     C                     KFLD           INONY
     C                     KFLD           IMHN1
     C                     KFLD           IMHN2
      *
     C           KEY1      KLIST
     C                     KFLD           JTOKU
     C                     KFLD           JNONY
     C                     KFLD           JNKOJ
     C                     KFLD           JNUKE
     C                     KFLD           JMHN1
     C                     KFLD           JMHN2
     C                     KFLD           JMHN3
     C                     KFLD           JMHN4
      *
     C           *ENTRY    PLIST
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           @MHIN  15
     C                     PARM           @SHIN  12
     C                     MOVE PTOKU     @TOKU   40
     C                     MOVE PNONY     @NONY   40
     C                     MOVEL@MHIN     PMHIN
     C                     MOVEL@SHIN     PSHIN
      *
     C                     Z-ADD1         B       10
     C           1         DO   2         B
     C           B         IFEQ 1
     C                     Z-ADD@TOKU     ITOKU   40
     C                     Z-ADD@NONY     INONY   40
     C                     ELSE
     C                     Z-ADD0111      ITOKU
     C                     Z-ADD0111      INONY
     C                     END
     C                     MOVE PMHN1     IMHN1   5
     C                     MOVE PMHN2     IMHN2   5
      *
     C                     SETOF                     10
     C           KEY       CHAINFAAPL061             10
     C           *IN10     IFEQ '0'
     C                     GOTO STP1
     C                     END
     C                     END
     C                     GOTO STP2
     C           STP1      TAG
      *
     C                     Z-ADD1         B
     C           1         DO   3         B
     C                     Z-ADD@TOKU     JTOKU   40
     C                     Z-ADD@NONY     JNONY   40
     C                     MOVE PNKOJ     JNKOJ   1
     C                     MOVE PNUKE     JNUKE   4
     C                     MOVE PMHN1     JMHN1   5
     C                     MOVE PMHN2     JMHN2   5
     C                     MOVE *BLANK    JMHN3   5
     C                     MOVE *BLANK    JMHN4   5
      *
     C           B         IFEQ 1
     C                     MOVELPMHN3     JMHN3
     C                     MOVELPMHN5     JMHN4
     C                     END
     C           B         IFEQ 2
     C                     MOVELPMHN4     JMHN3
     C                     END
      *
     C                     SETOF                     10
     C           KEY1      CHAINFAAPL021             10
     C           *IN10     IFEQ '0'
     C           B7SKBN    CABNE'D'       STP3
     C           B7SKHZ    CABGT*DATE     STP3
     C                     END
      *
     C                     SETOF                     10
     C                     MOVE *BLANK    JNKOJ
     C           KEY1      CHAINFAAPL021             10
     C           *IN10     IFEQ '0'
     C           B7SKBN    CABNE'D'       STP3
     C           B7SKHZ    CABGT*DATE     STP3
     C                     END
      *
     C                     SETOF                     10
     C                     MOVE PNKOJ     JNKOJ
     C                     MOVEL*BLANK    JNUKE
     C           KEY1      CHAINFAAPL021             10
     C           *IN10     IFEQ '0'
     C           B7SKBN    CABNE'D'       STP3
     C           B7SKHZ    CABGT*DATE     STP3
     C                     END
      *
     C                     SETOF                     10
     C                     MOVE *BLANK    JNKOJ
     C           KEY1      CHAINFAAPL021             10
     C           *IN10     IFEQ '0'
     C           B7SKBN    CABNE'D'       STP3
     C           B7SKHZ    CABGT*DATE     STP3
     C                     END
      *
     C                     SETOF                     10
     C                     Z-ADD0111      JTOKU
     C                     Z-ADD0111      JNONY
     C           KEY1      CHAINFAAPL021             10
     C           *IN10     IFEQ '0'
     C           B7SKBN    CABNE'D'       STP3
     C           B7SKHZ    CABGT*DATE     STP3
     C                     END
     C                     END
      *
     C           STP2      TAG
     C                     MOVE PMHN1     PSHN1
     C                     MOVE PMHN2     PSHN2
     C                     MOVE *BLANK    PSHN3
      *
     C                     GOTO END
      *
     C           STP3      TAG
     C                     MOVE B7MHN1    PMHN1
     C                     MOVE B7MHN2    PMHN2
     C                     MOVE B7MHN3    PMHN3
     C                     MOVE B7MHN4    PMHN5
     C                     MOVELPMHIN     @MHIN
     C                     MOVE B7SHN1    PSHN1
