     H            Y.
     F** CHKR65  ***************************************************************
     F*  PROGRAM    : CHECK SBAN TABLE (AB#PP85 VS PPAW)                       *
     F*             : READ AB#PPAW                                             *
     F*  WRITTEN    : JW   2024.05.15                                          *
     F* ----------------------------------------------------                   *
     F*  IF UPD FLAG=Y --> UPDATE AB#PP85 BY AB#PPAW DATA                      *
     F**************************************************************************
     FAB#PPAW IF  E           K        DISK
     FAB#PL85AIF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     F**************************************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1  20 AWMHIN
     I                                        1   5 AWMHN1
     I                                        6  10 AWMHN2
     I                                       11  15 AWMHN3
     I                                       16  20 AWMHN4
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           *LOVAL    SETLLAB#PPAW
     C                     DO   *HIVAL
     C                     READ AB#PPAW                  98
     C   98                LEAVE
      *
     C           AWSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * SEARCH AB#PP85
     C                     MOVE 'N'       FOUND   1
     C                     MOVEL'0492'    K#NONY
     C                     MOVELAWMHN1    K#MHN1
     C                     MOVELAWMHN2    K#MHN2
     C                     MOVELAWMHN3    K#MHN3
     C                     MOVELAWMHN4    K#MHN4
     C           K#85      SETLLAB#PL85A
     C                     DO   *HIVAL
     C           K#85      READEAB#PL85A                 97
     C   97                LEAVE
      *
     C           A5SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE 'Y'       FOUND
     C                     LEAVE
     C                     ENDDO
      * NOT FOUND?
     C           FOUND     IFEQ 'N'
     C                     EXSR #PRINT
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $UPD    1
     C                     PARM           $RTN    1
      *
     C           K#85      KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#MHN1  5
     C                     KFLD           K#MHN2  5
     C                     KFLD           K#MHN3  5
     C                     KFLD           K#MHN4  5
      *
     C           $UPD      IFNE 'Y'
     C                     MOVE 'N'       $UPD
     C                     ENDIF
      *
     C                     TIME           SDATE
     C                     MOVE ' '       $RTN
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD90        LIN#    40
     C                     Z-ADD0         UPDCNT  40
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                         $UPD      12
     O                                   40 '** SBAN TABLE (AB#PP'
     O                                   60 'AW VS PP85 ERROR REP'
     O                                   80 'ORT **              '
     O                                   89 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                                  106 'P.'
     O                         PAGE  Z  110
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   10 'DELV'
     O                                   20 'USER_PART'
     O                                   39 'ADDRESS'
     O                                   52 'SBAN'
     O        E 1              @DTL
     O                         SEQ#  1 +000
     O                                 +001 '0492'
     O                         AWMHIN  +001
     O                         AWADDR  +001
     O                         AWSBAN  +001
