     H            Y.
      ** AB#R20 **************************************************
      *                                                          *
      *   LEC    PRINT QR CODES FOR TEAM MBR BADGES     2024/9/9 *
      ************************************************************
     FAB#WP200IF  E           K        DISK
     FAB#PR20 O   E                    PRINTER
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *
      *
     C           *IN50     DOWEQ*OFF
      *
     C                     Z-ADD0         CDS     20
     C                     WRITE@TOP
      *
     C                     DO   5
      *
     C                     READ AB#WP200                 50
     C           *IN50     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVELW1WKNM    WKNML
     C                     MOVELW1DPCD    DEPTL
     C                     Z-ADDW1WKCD    WKCDL
     C                     ADD  1         CDS
      *
     C                     READ AB#WP200                 50
     C           *IN50     IFEQ *ON
     C                     ADD  1         CDS
     C                     WRITE@DTL
     C                     WRITE@SPC
     C                     WRITE@SPC
     C                     CLEAR@DTL
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVELW1WKNM    WKNMR
     C                     MOVELW1DPCD    DEPTR
     C                     Z-ADDW1WKCD    WKCDR
     C                     ADD  1         CDS
      *
     C                     WRITE@DTL
     C                     WRITE@SPC
     C                     WRITE@SPC
      *
     C                     CLEAR@DTL
     C                     ENDDO
      *
     C                     ENDDO
      *
     C           CDS       IFNE 10
     C           10        SUB  CDS       REMNG   20
     C           REMNG     DIV  2         REMNG
     C                     DO   REMNG
     C                     WRITE@DTL
     C                     WRITE@SPC
     C                     WRITE@SPC
     C                     CLEAR@DTL
     C                     ENDDO
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
