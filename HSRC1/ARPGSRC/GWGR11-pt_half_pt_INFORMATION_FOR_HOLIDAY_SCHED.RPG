     H            Y/
     F***************************************************
     F*   PT/HALF PT
     F*                                                 *
     F* TCHK1  : 11/10/05 CHANGE
     F***************************************************
     FAAPTL01 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FFCEPL41 IF  E           K        DISK
     FAB#PL18 IF  E           K        DISK
     FAANPL06 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FABBPL02 IF  E           K        DISK
TCHK1FGDKPL02 IF  E           K        DISK
     FGWPTP01 O   E                    DISK
      *------------------------------------------------------------
     E                    CUST       10  4 0
      *------------------------------------------------------------
     I            DS
     I                                        1  40 CUST
     I                                        1   40CUST1
     I                                        5   80CUST2
     I                                        9  120CUST3
     I                                       13  160CUST4
     I                                       17  200CUST5
     I                                       21  240CUST6
     I                                       25  280CUST7
     I                                       29  320CUST8
     I                                       33  360CUST9
     I                                       37  400CUST10
     I            DS
     I                                        1  12 MCPRT
     I                                        1   5 MCSHN1
     I                                        6  10 MCSHN2
     I                                       11  12 MCSHN3
     I            DS
     I                                        1   80A2TYMD
     I                                        1   40A2TAYY
     I                                        5   60A2TAMM
     I                                        7   80A2TADD
     I            DS
     I                                        1   6 L7LOC
     I                                        1   1 L7TKR1
     I                                        2   3 L7TKR2
     I                                        4   5 L7TKR3
     I                                        6   6 L7TKR4
     I            DS
     I                                        1   80BADATE
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
TCHK1I*
TCHK1I            DS
TCHK1I                                        1  20 W@PT
TCHK1I                                        1   5 W@PT1
TCHK1I                                        6  10 W@PT2
TCHK1I                                       11  12 W@PT3
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C                     EXSR #OUT
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#MC      KLIST
     C                     KFLD           K@SHN1  5
     C                     KFLD           K@SHN2  5
     C                     KFLD           K@SHN3  2
     C           K#AB      KLIST
     C                     KFLD           K@SHN1
     C                     KFLD           K@SHN2
     C                     KFLD           K@SHN3
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C                     KFLD           K@DD    20
      *
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
      *
     C           K#AGDX    KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD    20
      *
     C           *MONTH    ADD  1         K@MM
     C                     Z-ADD*YEAR     K@YY
     C           K@MM      IFGT 12
     C                     ADD  1         K@YY
     C                     SUB  12        K@MM
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     W@2     20
     C                     EXSR #AGD
     C                     Z-ADD@@D       W@2
      *
     C                     ADD  1         K@MM
     C           K@MM      IFGT 12
     C                     ADD  1         K@YY
     C                     SUB  12        K@MM
     C                     ENDIF
     C                     EXSR #AGD
     C                     Z-ADD@@D       W@3     20
      *
     C                     ENDSR
      *------------------------------------------------------
      *  WORKING DAYS
      *------------------------------------------------------
     C           #AGD      BEGSR
      *
     C                     Z-ADD*ZERO     @@D     20
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C           K#AGD     READEAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     ADD  1         @@D
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR SUB FILE
      *------------------------------------------------------
     C           #OUT      BEGSR
      *
     C           *LOVAL    SETLLAAPTL01
      *
     C           *IN80     DOUEQ*ON
     C                     READ AAPTL01                  80
      *
     C           *IN80     IFEQ *OFF
     C           L5SKJY    ANDNE'D'
     C           L5STYY    ANDEQ9999
     C                     CLEARWRKR
TCHK1 *
TCHK1C                     MOVE L5SHN1    K@SHN1
TCHK1C                     MOVE L5SHN2    K@SHN2
TCHK1C                     MOVE L5SHN3    K@SHN3
TCHK1C           K#MC      CHAINFCEPL01              90
TCHK1C           *IN90     IFEQ *OFF
TCHK1C                     Z-ADDA2TYMD    START
TCHK1C                     ENDIF
TCHK1 *
     C                     MOVE L5SHN1    PART1
     C                     MOVE L5SHN2    PART2
     C                     MOVE L5SHN3    PART3
     C                     MOVE L5TKRO    LOC
TCHK1C*                    Z-ADDL5KSSU    @@QTY
TCHK1C*          @@QTY     DIV  L5SYOS    SETB      H
TCHK1C*                    MOVE L5SHN1    K@SHN1
TCHK1C*                    MOVE L5SHN2    K@SHN2
TCHK1C*                    MOVE L5SHN3    K@SHN3
      *
TCHK1C*          K#MC      CHAINFCEPL01              90
TCHK1C*          *IN90     IFEQ *OFF
TCHK1C*                    Z-ADDA2TYMD    START
TCHK1C*                    ENDIF
TCHK1 *
TCHK1C           A2GEKN    DIV  20        @@QTY     H
TCHK1C           @@QTY     DIV  L5SYOS    SETB      H
TCHK1 *
      * DAILY USAGE
     C                     Z-ADD*ZERO     @QTY2  110
      *
     C                     EXSR #RSLT
      *
     C           @QTY2     DIV  10        @@QTY  112H
     C           @@QTY     DIV  L5SYOS    DAYQ      H
      *
     C                     EXSR #FRC
     C           @QTY3     DIV  W@2       @@QTY     H
     C           @@QTY     DIV  L5SYOS    JUL       H
     C           @QTY4     DIV  W@3       @@QTY     H
     C           @@QTY     DIV  L5SYOS    AUG       H
      *
TCHK1C                     MOVEL*BLANK    W@PT
TCHK1C                     MOVELL5SHN1    W@PT1
TCHK1C                     MOVELL5SHN2    W@PT2
TCHK1C                     MOVELL5SHN3    W@PT3
TCHK1C           W@PT      SETLLGDKPL021
TCHK1C                     DO   *HIVAL
TCHK1C           W@PT      READEGDKPL021                 91
TCHK1C   91                LEAVE
TCHK1C           ISSKJY    IFEQ 'D'
TCHK1C           ISSKHZ    ANDLT*DATE
TCHK1C                     ITER
TCHK1C                     END
TCHK1C           ISENHZ    IFLT *DATE
TCHK1C                     ITER
TCHK1C                     END
TCHK1C           ISTYPE    IFEQ '0'
TCHK1C           ISTYPE    OREQ '6'
TCHK1C                     ELSE
TCHK1C                     ITER
TCHK1C                     END
TCHK1C                     LEAVE
TCHK1C                     ENDDO
TCHK1C           *IN91     IFEQ *ON
TCHK1C                     MOVEL'D'       PDLFLG
TCHK1C                     END
TCHK1 *
     C                     WRITEWRKR
     C                     ENDIF
     C                     ENDDO
      *
     C           *LOVAL    SETLLAANPL06
      *
     C           *IN80     DOUEQ*ON
     C                     READ AANPL06                  80
      *
     C           *IN80     IFEQ *OFF
     C           L7SKJY    ANDNE'D'
     C           L7STYY    ANDEQ9999
     C                     CLEARWRKR
TCHK1 *
TCHK1C                     MOVE L7SHN1    K@SHN1
TCHK1C                     MOVE L7SHN2    K@SHN2
TCHK1C                     MOVE L7SHN3    K@SHN3
TCHK1C           K#MC      CHAINFCEPL01              90
TCHK1C           *IN90     IFEQ *OFF
TCHK1C                     Z-ADDA2TYMD    START
TCHK1C                     ENDIF
TCHK1 *
     C                     MOVE L7SHN1    PART1
     C                     MOVE L7SHN2    PART2
     C                     MOVE L7SHN3    PART3
     C                     MOVE L7LOC     LOC
TCHK1C*                    Z-ADDL7KSSU    @@QTY
TCHK1C*          @@QTY     DIV  L7SYOS    SETB      H
TCHK1C*                    MOVE L7SHN1    K@SHN1
TCHK1C*                    MOVE L7SHN2    K@SHN2
TCHK1C*                    MOVE L7SHN3    K@SHN3
      *
TCHK1C*          K#MC      CHAINFCEPL01              90
TCHK1C*          *IN90     IFEQ *OFF
TCHK1C*                    Z-ADDA2TYMD    START
TCHK1C*                    ENDIF
TCHK1 *
TCHK1C           A2GEKN    DIV  20        @@QTY     H
TCHK1C           @@QTY     DIV  L7SYOS    SETB      H
TCHK1 *
      * DAILY USAGE
     C                     Z-ADD*ZERO     @QTY2  110
      *
     C           K#MC      CHAINFCEPL41              90
     C           *IN90     IFEQ *OFF
     C                     MOVE F4PRT1    K@SHN1
     C                     MOVE F4PRT2    K@SHN2
     C                     MOVE F4PRT3    K@SHN3
     C                     EXSR #RSLT
      *
     C           @QTY2     DIV  10        @@QTY  112H
     C           @@QTY     DIV  L7SYOS    DAYQ      H
      *
     C                     EXSR #FRC
     C           @QTY3     DIV  W@2       @@QTY     H
     C           @@QTY     DIV  L7SYOS    JUL       H
     C           @QTY4     DIV  W@3       @@QTY     H
     C           @@QTY     DIV  L7SYOS    AUG       H
     C                     ENDIF
      *
TCHK1C                     MOVEL*BLANK    W@PT
TCHK1C                     MOVELL7SHN1    W@PT1
TCHK1C                     MOVELL7SHN2    W@PT2
TCHK1C                     MOVELL7SHN3    W@PT3
TCHK1C           W@PT      SETLLGDKPL021
TCHK1C                     DO   *HIVAL
TCHK1C           W@PT      READEGDKPL021                 91
TCHK1C   91                LEAVE
TCHK1C           ISSKJY    IFEQ 'D'
TCHK1C           ISSKHZ    ANDLT*DATE
TCHK1C                     ITER
TCHK1C                     END
TCHK1C           ISENHZ    IFLT *DATE
TCHK1C                     ITER
TCHK1C                     END
TCHK1C           ISTYPE    IFEQ '0'
TCHK1C           ISTYPE    OREQ '6'
TCHK1C                     ELSE
TCHK1C                     ITER
TCHK1C                     END
TCHK1C                     LEAVE
TCHK1C                     ENDDO
TCHK1C           *IN91     IFEQ *ON
TCHK1C                     MOVEL'D'       PDLFLG
TCHK1C                     END
TCHK1 *
     C                     WRITEWRKR
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   RESULT
      *------------------------------------------------------
     C           #RSLT     BEGSR
      *
     C                     Z-ADD*YEAR     K@YY
     C                     Z-ADD*MONTH    K@MM
     C                     Z-ADD*DAY      K@DD
     C                     Z-ADD*ZERO     @CNT    20
     C                     Z-ADD*ZERO     Y       20
      *
     C           K#AGDX    SETGTAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     ADD  1         @CNT
     C           @CNT      IFEQ 10
     C                     Z-ADDF8KAYY    K@YY
     C                     Z-ADDF8KAMM    K@MM
     C                     Z-ADDF8KADD    K@DD
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           K#AB      SETLLAB#PL18
     C           *IN90     DOUEQ*ON
     C           K#MC      READEAB#PL18                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BADATE    IFGT *DATE
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  BASRYO    @QTY2
     C           BATOKU    LOKUPCUST                     10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         Y
     C           Y         IFLE 10
     C                     MOVE BATOKU    CUST,Y
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   FORECAST
      *------------------------------------------------------
     C           #FRC      BEGSR
      *
     C                     Z-ADD*ZERO     @QTY3  110
     C                     Z-ADD*ZERO     @QTY4  110
     C           K#MC      SETLLABBPL02
     C           *IN90     DOUEQ*ON
     C           K#MC      READEABBPL02                  90
     C           *IN90     IFEQ *OFF
     C                     ADD  Q51NNM    @QTY3
     C                     ADD  Q52NNM    @QTY4
     C           Q5TOKU    LOKUPCUST                     10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         Y
     C           Y         IFLE 10
     C                     MOVE Q5TOKU    CUST,Y
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
