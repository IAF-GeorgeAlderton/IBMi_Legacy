     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
     C*
     C           KEY1      KLIST
     C                     KFLD           A8SUPP
     C*
     C           KEY2      KLIST
     C                     KFLD           A8SUPP
     C                     KFLD           A8PAR1
     C                     KFLD           A8PAR2
     C                     KFLD           A8PAR3
     C*
     C           KEY3      KLIST
     C                     KFLD           A8SUPP
     C                     KFLD           A8PAR1
     C                     KFLD           A8PAR2
     C                     KFLD           A8PAR3
     C                     KFLD           A8ZETI
     C                     KFLD           A8TEHI
     C                     KFLD           A8PAGE
     C                     KFLD           A8DATE
     C                     KFLD           A8RENO
     C*
     C           KEY5      KLIST
     C                     KFLD           @SUPP3
     C                     KFLD           @PAR13
     C                     KFLD           @PAR23
     C                     KFLD           @PAR33
     C                     KFLD           @ZETI3
     C                     KFLD           @TEHI3
     C                     KFLD           K51
     C                     KFLD           K52
     C                     KFLD           K53
     C*
