     C   L3                SETON                     30
      * RECIEVED DATE
     C           AERCVT    IFEQ *ZERO
     C                     Z-ADD*DATE     WDAT8
     C                     ELSE
     C                     Z-ADDAERCVT    WDAT8   80
     C                     ENDIF
      *
      * CUSTOMER PART#
     C                     MOVEAAEMHIN    MH1       P
     C                     MOVE *BLANK    MH2
     C                     Z-ADD*ZERO     Y       20
     C           1         DO   30        X       20
     C           MH1,X     IFNE '-'
     C           MH1,X     ANDNE'/'
     C           MH1,X     ANDNE'.'
     C           MH1,X     ANDNE*BLANK
     C                     ADD  1         Y
     C                     MOVE MH1,X     MH2,Y
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAMH2       WMHIN     P
JWF   * SRG
 |   C           @@PRT3    IFEQ 'SRG'
 |   C                     MOVELAEMHIN    WMHIN     P
JWF  C                     ENDIF
      *
     C                     MOVE 'C'       WNOKN   1
      * DOCK
     C                     MOVELAENUKE    WNUKE   4
     C           AENUKE    IFEQ *BLANK
     C           AENUKE    OREQ '0   '
TCHKOC           WNONY     IFEQ 0701
TCHKOC                     MOVEL'T00 '    WNUKE
TCHKOC                     ELSE
     C                     MOVEL'00  '    WNUKE
TCHKOC                     END
     C                     ENDIF
      * TEXTRON
     C           AEMHIN    IFNE XXMHIN
     C           WNONY     ANDEQ5535
     C                     EXSR #RSET
     C                     ENDIF
      * USER PART
     C                     MOVELAEMHIN    XXMHIN 30
JWC   * TBA (3322)
 |   C           AENONY    IFEQ '3322'
 |   C           WTOKU     IFEQ 0
 |   C                     Z-ADD3315      WTOKU
 |   C                     ENDIF
 |   C           WNONY     IFEQ 0
 |   C                     Z-ADD3322      WNONY
 |   C                     ENDIF
 |   C                     MOVEL'0'       WNKOJ
 |   C                     MOVEL'00  '    WNUKE
JWC  C                     ENDIF
      * QTY
     C                     Z-ADDAEEQTY    WSURY   80
     C                     ADD  AEEQTY    @@QTY
      *
JWF  C                     MOVELAEPRTR    WPRTR  10
      * SCHEDULE/START DATE
     C                     MOVELAEDAT1    @DATC     P
     C           @DATS     IFEQ *BLANK
     C                     MOVE @DAT6     WDAT6   60
     C           WDAT6     ADD  20000000  WNYMD
     C                     ELSE
     C                     MOVE AEDAT1    WNYMD
     C                     ENDIF
      *
     C           AESBAN    IFEQ *BLANK
     C           K#FCC     CHAINFCCTL13              90
     C           *IN90     IFEQ *OFF
