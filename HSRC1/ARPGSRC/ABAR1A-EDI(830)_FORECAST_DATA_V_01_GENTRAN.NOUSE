     C                     ENDIF
JW2   * ADJUST HONDA CUST/DELIVERY
 |   C           AETOKU    IFEQ 'HSP '
 |   C           K#SHC     KLIST
 |   C                     KFLD           K@PLNT  3
 |   C                     KFLD           K@SHCD 10
 |   C                     MOVELXXTOKU    K@PLNT
 |   C                     MOVELAEFLR1    K@SHCD
 |   C                     MOVE *OFF      *IN95
 |   C           K#SHC     SETGTAB#PPHN
 |   C                     DO   *HIVAL
 |   C           K#SHC     REDPEAB#PPHN                  95
 |   C   95                LEAVE
 |   C           AHSKJY    IFEQ 'D'
 |   C                     ITER
 |   C                     ENDIF
 |   C                     MOVELAHTOKU    AETOKU
 |   C                     MOVELAHNONY    AENONY
JWJ  C                     MOVELAHNONY    SVNONY
JWJ  C                     MOVELAHNONY    WNONY
 |   C                     LEAVE
 |   C                     ENDDO
JW2  C                     ENDIF
      *
JW4   * GET NONY FROM WILD CHARACTER(*)
 |   C           AENONY    IFEQ '0000'
 |   C           AENONY    OREQ *BLANK
 |   C                     MOVEL'*'       K@SHCD    P
 |   C           K#SHC     CHAINAB#PPHN              95
 |   C           *IN95     IFEQ *OFF
 |   C           AHSKJY    ANDNE'D'
 |   C                     MOVELAHTOKU    AETOKU
 |   C                     MOVELAHNONY    AENONY
JWJ  C                     MOVELAHNONY    SVNONY
JWJ  C                     MOVELAHNONY    WNONY
 |   C                     ENDIF
JW4  C                     ENDIF
      *
     C**JWI                MOVELAETOKU    WTOKU   40
     C                     MOVELAETOKU    XTOKU   4
      *
JWI  C           AETOKU    IFGE '0001'
 |   C           AETOKU    ANDLE'9999'
 |   C                     MOVELAETOKU    WTOKU   40
 |   C                     ELSE
 |   C                     Z-ADD0         WTOKU
JWI  C                     ENDIF
      * TIMING OF OUTPUT
     C                     MOVE *BLANK    @@L     1
     C                     MOVELAEPRTR    K@KWD1    P
     C                     MOVEL'AB#WP10' K@KWD2    P
     C           K#KEY     CHAINAB#EP00              90
     C           *IN90     IFEQ *OFF
     C                     MOVELEPVAL1    @@L     1
     C                     ENDIF
      *
     C                     MOVELAENONY    WNONY   40
     C                     MOVELAENKOJ    WNKOJ   1
      *
     C                     ELSE
     C           @N        IFEQ 'A'
     C           AEFLR1    ANDNE@@FLR1
     C                     EXSR #NONY
     C                     MOVELAENONY    WNONY   40
     C                     SETON                     30
     C                     ENDIF
     C                     ENDIF
      *
     C           @@L       IFEQ 'A'
     C           *INL1     ANDEQ*ON
     C                     Z-ADD*ZERO     WYM
     C                     Z-ADD*ZERO     @A      30
     C                     Z-ADD*ZERO     @@QTY   81
     C                     ENDIF
      *
     C           AEUPID    CABNE*BLANK    @@JUMP
      * 0946 TOWER AUTOMOTIVE
TCHK6C           AETOKU    IFEQ '0946'
TCHK6C           AERCVT    IFNE W@RCVT
TCHK6C           AENONY    ORNE W@NONY
TCHK6C           AENKOJ    ORNE W@NKOJ
TCHK6C           AENUKE    ORNE W@NUKE
TCHK6C           AEMHIN    ORNE W@MHIN
TCHK6C                     Z-ADD*ZERO     W@QTY2
TCHK6C                     Z-ADDAERCVT    W@RCVT
TCHK6C                     MOVELAENONY    W@NONY
TCHK6C                     MOVELAENKOJ    W@NKOJ
TCHK6C                     MOVELAENUKE    W@NUKE
TCHK6C                     MOVELAEMHIN    W@MHIN
TCHK6C                     END
TCHK6C           AEEQTY    SUB  AECQTY    W@QTY1  90
TCHK6C           W@QTY1    SUB  W@QTY2    AEEQTY
TCHK6C                     Z-ADDW@QTY1    W@QTY2
TCHK6C                     END
TCHK6C*
JWT  C           WNONY     IFNE 0332
     C           AEEQTY    CABLT*ZERO     @@JUMP
JWT  C                     ENDIF
      *
     C                     MOVELXXTOKU    AETOKU
     C                     MOVELXXNONY    AENONY
     C                     MOVE '1'       AEUPID
