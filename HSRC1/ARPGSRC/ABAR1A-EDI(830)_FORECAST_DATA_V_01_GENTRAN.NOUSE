      * PROCESS OR NOT
     C                     MOVEL'AEORID'  K@KWD2    P
     C           K#KEY     CHAINAB#EP00              90
     C           *IN90     IFEQ *OFF
     C                     MOVELEPVAL1    @@1     1
     C                     MOVELEPVAL2    @@X     1
     C           @@X       IFEQ 'N'
     C           @@1       CABEQAEORID    @@JUMP
     C                     ELSE
     C           AEPRTR    IFEQ 'AMBRAKE'
     C                     MOVELAEESID    @@@1    1
     C           @@@1      CABEQ'D'       @@JUMP
     C                     ELSE
     C           @@1       CABNEAEORID    @@JUMP
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
