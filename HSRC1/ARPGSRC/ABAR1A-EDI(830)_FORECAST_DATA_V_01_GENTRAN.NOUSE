     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      * END DATE
     C           AEDAT2    IFNE *ZERO
%0003C           AEDAT2    ANDNE19910816
     C                     MOVE AEDAT2    @DATC     P
     C           @DATS     IFEQ *BLANK
     C                     MOVE @DAT6     WDAT6   60
     C           WDAT6     ADD  20000000  @@EDAT  80
     C                     ELSE
     C                     MOVE AEDAT2    @@EDAT
