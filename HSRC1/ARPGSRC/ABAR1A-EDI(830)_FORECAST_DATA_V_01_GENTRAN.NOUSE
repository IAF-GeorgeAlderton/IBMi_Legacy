 |   C           K#SHC     SETGTAB#PPHN
 |   C                     DO   *HIVAL
 |   C           K#SHC     REDPEAB#PPHN                  95
 |   C   95                LEAVE
 |   C           AHSKJY    IFEQ 'D'
 |   C                     ITER
 |   C                     ENDIF
 |   C                     MOVELAHTOKU    AETOKU
 |   C                     MOVELAHNONY    AENONY
JWJ  C                     MOVELAHNONY    SVNONY
JWJ  C                     MOVELAHNONY    WNONY
 |   C                     LEAVE
 |   C                     ENDDO
JW6  C                     ENDIF
      *
JW6   * GET NONY FROM WILD CHARACTER(*)
 |   C           AENONY    IFEQ '0000'
 |   C           AENONY    OREQ *BLANK
 |   C                     MOVEL'*'       K@SHCD    P
 |   C           K#SHC     CHAINAB#PPHN              95
 |   C           *IN95     IFEQ *OFF
 |   C           AHSKJY    ANDNE'D'
 |   C                     MOVELAHTOKU    AETOKU
 |   C                     MOVELAHNONY    AENONY
JWJ  C                     MOVELAHNONY    SVNONY
JWJ  C                     MOVELAHNONY    WNONY
 |   C                     ENDIF
JW6  C                     ENDIF
      *
      * if delivery code was not determined, write to workfile for printing
     C                     TESTN          SVNONY     41
     C           AENONY    IFEQ '0000'
     C           *IN41     ANDEQ*OFF
     C           AEFLR1    CHAINABAWP2H              61
     C           *IN61     IFEQ *ON
     C                     MOVELAEPRTR    W2PRTR
     C                     MOVELSVTOKU    W2TOKU
     C                     MOVELSVNONY    W2NONY
     C                     MOVELAEMHIN    W2MHIN
     C                     Z-ADDAEEQTY    W2EQTY
     C                     MOVELAEFLR1    W2SHCD
     C                     MOVELAESAD1    W2SAD1
     C                     MOVELAESAD2    W2SAD2
     C                     MOVELAECITY    W2CITY
     C                     MOVELAESTAT    W2STAT
     C                     MOVELAEZIPC    W2ZIPC
     C                     MOVELAECNTY    W2CNTY
     C                     MOVELAESNAM    W2SNAM
     C                     WRITEABAWP2H1
     C                     ENDIF
     C                     ENDIF
      *
     C           AEFLR2    IFNE *BLANK
     C                     MOVE AENONY    K@NONY
     C                     MOVE AETOKU    K@TOKU
     C           K#10      CHAINABAPP10              90
     C                     MOVELAEFLR2    A1RLNO
     C                     MOVE AENONY    A1NONY
     C                     MOVE AETOKU    A1CUST
     C                     Z-ADD*DATE     A1DATE
     C   90                WRITEABAPP101
     C  N90                UPDATABAPP101
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  SHIP TO
      *--------------------------------------------------------
     C           #NONYC    BEGSR
      *
     C           AEPRTR    IFEQ 'TABC'
     C                     MOVE 3423      AETOKU
     C                     ELSE
     C                     MOVE 0323      AENONY
     C                     SELEC
     C           AENKOJ    WHEQ 'A'
     C                     MOVE 0541      AETOKU
     C           AENKOJ    WHEQ 'C'
     C                     MOVE 3411      AETOKU
     C                     ENDSL
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  RESET
      *--------------------------------------------------------
     C           #RSET     BEGSR
      *
     C                     Z-ADDK@YM      @NYM
     C           KEY2      SETLLABAWP101
     C           *IN90     DOUEQ*ON
     C           KEY2X     READEABAWP101                 90
     C           *IN90     IFEQ *OFF
     C           ABDATE    IFGT K@YM
     C                     Z-ADD1         D
     C                     ELSE
     C                     Z-ADDK@DD      D
     C                     ENDIF
     C           D         DO   31        X       20
     C                     Z-ADD0         HSU,X
     C                     ENDDO
      *
     C                     XFOOTHSU       ABNNSU
      *
     C                     UPDATABAWP101
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *--------------------------------------------------------
