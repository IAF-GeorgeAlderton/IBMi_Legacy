     C                     Z-ADD0         WSRYO
     C                     END
      *
     C           ITOKU     IFEQ 0873
     C           @DUP      IFEQ '1'
     C           @@BIN     ADD  1         INOBN
     C                     ELSE
     C                     Z-ADDW@BIN     INOBN
     C                     ENDIF
