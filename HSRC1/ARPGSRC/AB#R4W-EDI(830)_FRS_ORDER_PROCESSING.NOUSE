     C           KEY3X     SETGTAB#PL17
      *
     C                     Z-ADD*ZERO     @@BIN   20
     C                     MOVE *BLANK    @DUP    1
     C                     Z-ADDINOBN     W@BIN   20
     C           KEY3X     SETLLAB#PL17
     C           *IN90     DOUEQ*ON
     C           KEY3X     READEAB#PL17                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
      * SAME ORDER#, SAME INVOICE #
     C           BAINVN    IFEQ IINVN
     C                     Z-ADDBANOBN    W@BIN   20
     C                     LEAVE
     C                     ENDIF
     C           BANOBN    IFGT @@BIN
     C                     Z-ADDBANOBN    @@BIN
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      * NO SAME ORDER NUMBER
     C           @@BIN     IFEQ *ZERO
     C                     MOVE *BLANK    @DUP
     C                     ELSE
     C                     MOVE '1'       @DUP
     C                     ENDIF
      *
     C                     ENDIF
      *------------------------------------------------
      *
     C           *INL2     IFEQ '1'
