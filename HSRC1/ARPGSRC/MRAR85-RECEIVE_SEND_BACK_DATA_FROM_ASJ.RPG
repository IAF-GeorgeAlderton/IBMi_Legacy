     H            Y.
     F** MRAR85 *********************************************
     F* RECEIVE SEND BACK DATA FROM ASJ                     *
     F*     TRANCOM-ITS            2012.10.18               *
     F*******************************************************
     FMRBPPK2 IF  E                    DISK
      *
     FMRAPPK1 O   E                    DISK
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   40WJFF
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C                     TIME           WTIME
      *----------------------------------------------------------------
      * MRBPPK1 ---> MRAPPK1
      *----------------------------------------------------------------
     C                     SETOF                     80
     C           1         SETLLMRBPPK21
     C                     READ MRBPPK21                 80
     C           *IN80     DOWEQ'0'
     C                     EXSR #SB510
     C                     READ MRBPPK21                 80
     C                     ENDDO
      *----------------------------------------------------------------
      * EXIT
      *----------------------------------------------------------------
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------------------
      * SEND BACK DATA FROM ASJ  (COMPOSITION INFORMATION)
      *----------------------------------------------------------------
     CSR         #SB510    BEGSR
     C                     CLEARMRAPPK11
     C                     MOVE EVSEQN    KSSEQN
     C                     MOVE EVSHN1    KSSHN1
     C                     MOVE EVSHN2    KSSHN2
     C                     MOVE EVSHN3    KSSHN3
     C                     MOVE EVSEHI    KSSEHI
     C                     MOVE EVKENO    KSKENO
     C                     MOVE EVKENA    KSKENA
     C                     MOVE EVKEED    KSKEED
     C                     MOVE EVTEHI    KSTEHI
     C                     MOVE EVHANN    KSHANN
     C                     MOVE EVSHN4    KSSHN4
     C                     MOVE EVSAYY    KSSAYY
     C                     MOVE EVSAMM    KSSAMM
     C                     MOVE EVSADD    KSSADD
     C                     MOVE EVSATH    KSSATH
     C                     MOVE EVSATM    KSSATM
     C                     MOVE EVSATS    KSSATS
     C                     MOVE EVKHN1    KSKHN1
     C                     MOVE EVKHN2    KSKHN2
     C                     MOVE EVKHN3    KSKHN3
     C                     MOVE EVKSEH    KSKSEH
     C                     MOVE EVKTEH    KSKTEH
     C                     MOVE EVSKSU    KSSKSU
     C                     MOVE EVKOTI    KSKOTI
     C                     MOVE EVKBMN    KSKBMN
     C                     MOVE EVUKER    KSUKER
     C                     MOVE EVGKYY    KSGKYY
     C                     MOVE EVGKMM    KSGKMM
     C                     MOVE EVGKDD    KSGKDD
     C                     MOVE EVGKJI    KSGKJI
     C                     MOVE EVGKHU    KSGKHU
     C                     MOVE EVGKNM    KSGKNM
      *              ------------------
     C                     WRITEMRAPPK11
      *              ------------------
     CSR         ESB510    ENDSR
