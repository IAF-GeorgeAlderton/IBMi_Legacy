     H            Y.
      ** AFFR65 ********************************************************
      *  CREATE CREATE INVOICE DATA AB#EP70/EP71 BY AFFWP62            *
      *  JW     2024/03/21                                             *
      ******************************************************************
     FAFFWP62 UF  E           K        DISK
     FABWEP70 IF  E           K        DISK                      A
     FABWEL71 IF  E           K        DISK                      A
     FQPRINT  O   F     132     OF     PRINTER
      *---------------------------------------------------
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   5 BAXX
     I                                        1   1 ENKOJ
     I                                        2   5 ENUKE
     I                                        1   3 EDOCK
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************
      *  MAIN
      *************************************************************
      * INITIALIZE
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ AFFWP62                  98
     C   98                LEAVE
      * IGNORE
     C           A2UFLG    IFNE ' '
     C                     ITER
     C                     ENDIF
      * SET UPDATE FLAG
     C                     MOVE '1'       A2UFLG
     C                     UPDATAFFWP621
      *
     C                     Z-ADDA2NONY    XNONY   40
     C                     Z-ADDA2NOHZ    XNOHZ   80
     C                     MOVELA2ODRN    XODRN  10
     C                     MOVELA2MHIN    XMHIN  20
     C                     MOVELA2NUKE    XDOCK   4
     C                     Z-ADDA2ARYO    XQTY    60
     C                     Z-ADDA2TANK    ETANK
     C                     Z-ADDA2SYOS    ESYOS
      * CHECK DUPLICATE INVOICE
     C                     Z-ADDXNONY     KNONY
     C                     MOVELXODRN     KODRN
     C                     MOVELXMHIN     KMHIN
     C                     MOVELXNOHZ     KNOHZ
     C           K#71A     CHAINABWEL71              97
     C           *IN97     IFEQ *OFF
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #WRT
     C                     ENDDO
      *
     C           HCNT      IFEQ 0
     C                     MOVE '0'       $RTN
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------------------
      *          CREATE INVOICE DATA
      *-----------------------------------------------------------
     C           #WRT      BEGSR
      * CREATE EP71
     C                     Z-ADDA2NONY    ENONY
     C                     Z-ADDA2NOHZ    EISDT
     C                     MOVELA2NKOJ    ENKOJ
     C                     MOVELA2NUKE    ENUKE
     C                     MOVELA2NOHZ    ENOHZ
     C                     MOVELA2INVN    EINVN
     C                     MOVELA2ODRN    EODRN
     C                     MOVELA2SBAN    ESBAN     P
     C                     Z-ADDA2ARYO    ESRYO
     C                     MOVELA2MHIN    EMHIN
     C                     MOVELA2NOBN    ENOBN
     C                     MOVEL'M390'    ECARD     P
     C                     Z-ADDA2TANK    ETANK
     C                     Z-ADDA2SYOS    ESYOS
     C                     MOVE *BLANK    EPDSC
     C                     MOVE *BLANK    ESHIN
     C                     MOVE *BLANK    EKBAN
     C                     Z-ADD0         E7PODT
     C                     MOVE *BLANK    E7SHID
      *
     C                     MOVELE7LNIT    E7LNIT
     C                     MOVELE7LPRC    E7LPRC
     C                     MOVELE7PKL#    E7PKL#
     C                     MOVELE7FLG1    E7FLG1
      *
     C           ETANK     MULT ESRYO     ETAMT
     C           ESYOS     IFEQ 0
     C                     Z-ADDESRYO     EBOX#
     C                     ELSE
     C           ESRYO     DIV  ESYOS     EBOX#
     C                     MVR            REM     50
     C           REM       IFNE 0
     C                     ADD  1         EBOX#
     C                     ENDIF
     C                     ENDIF
      *
     C                     WRITEABWEP711
     C                     ADD  1         DCNT
     C                     EXSR #PRINT
      * CHECK SAME SHIP DATE
     C                     MOVELA2NUKE    KNUKE
     C                     MOVELA2INVN    KINVN
     C           K#EP70    CHAINABWEP70              97
     C           *IN97     IFEQ *OFF
     C                     GOTO E#WRT
     C                     ENDIF
      * CREATE HEADER (EP70)
     C                     Z-ADDA2NONY    ENONY
     C                     Z-ADDA2NOHZ    EISDT
     C                     MOVEL'1731B'   ESUPL     P
     C                     Z-ADDA2TOKU    ETOKU
     C                     MOVELA2INVN    EINVN
     C                     MOVELA2ODRN    EODRN
     C                     MOVELA2NUKE    ENUKE
     C                     Z-ADD0         EDUED
     C                     MOVE *BLANK    EBCOD
     C                     Z-ADD0         E7PODT
     C                     MOVE *BLANK    E7SHID
     C                     MOVE *BLANK    E7VNNM
     C                     MOVE *BLANK    E7SUPP
     C                     MOVE *BLANK    E7VAD1
     C                     MOVE *BLANK    E7VCTY
     C                     MOVE *BLANK    E7VSTT
     C                     MOVE *BLANK    E7VZIP
     C                     MOVE *BLANK    E7VCTR
     C                     MOVE *BLANK    E7SNAM
     C                     MOVE *BLANK    E7SPCD
     C                     MOVE *BLANK    E7SAD1
     C                     MOVE *BLANK    E7SCTY
     C                     MOVE *BLANK    E7SSTT
     C                     MOVE *BLANK    E7SZIP
     C                     MOVE *BLANK    E7SCTR
     C                     MOVE *BLANK    E7BNAM
     C                     MOVE *BLANK    E7BPCD
     C                     MOVE *BLANK    E7BAD1
     C                     MOVE *BLANK    E7BCTY
     C                     MOVE *BLANK    E7BSTT
     C                     MOVE *BLANK    E7BZIP
     C                     MOVE *BLANK    E7BCTR
     C                     Z-ADD0         E7TMNT
     C                     MOVE *BLANK    E7TMDS
     C                     MOVE *BLANK    E7TRL#
     C                     MOVE *BLANK    E7SCAC
     C                     MOVE *BLANK    E7PRO
     C                     MOVE *BLANK    E7FLG0
     C                     Z-ADD0         E7FPRC
     C                     WRITEABWEP701
     C                     ADD  1         HCNT
      *
     C           E#WRT     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *          INITIALIZE
      *-----------------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C           K#71A     KLIST
     C                     KFLD           KNOHZ   80
     C                     KFLD           KNONY   40
     C                     KFLD           KODRN  10
     C                     KFLD           KMHIN  20
      *
     C           K#EP70    KLIST
     C                     KFLD           KNOHZ   80
     C                     KFLD           KNONY   40
     C                     KFLD           KNUKE   4
     C                     KFLD           KINVN  16
     C                     KFLD           KODRN  10
      *
     C                     MOVE *BLANK    $RTN
     C                     TIME           WSDT
     C                     MOVEL'01'      W@ID    2
     C                     Z-ADD0         HCNT    40
     C                     Z-ADD0         DCNT    40
     C                     Z-ADD88        LIN#    30
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** RESEND INVOICE DA'
     O                                   60 'TA REPORT **        '
     O                                   89 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                                  106 'P.'
     O                         PAGE  Z  110
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   10 'CUST'
     O                                   15 'DELV'
     O                                   32 'SHIP_DATE'
     O                                   36 'B#'
     O                                   46 'USER_PART'
     O                                   64 'ORDER#'
     O                                   77 'INVOICE#'
     O                                   98 'U/PRICE'
     O                                  108 'ORDER_QTY'
     O                                  116 'QPC'
      *
     O        E 1              @DTL
     O                         DCNT  1 +000
     O                         A2TOKU  +001
     O                         A2NONY  +001
     O                         A2NKOJ  +001
     O                         A2NUKE  +001
     O                         A2NOHZ  +001 '    /  /  '
     O                         A2NOBN  +001
     O                         A2MHIN  +001
     O                         A2ODRN  +001
     O                         A2INVN  +001
     O                         A2TANK1 +001
     O                         A2ARYO1 +001
     O                         A2SYOS1 +001
