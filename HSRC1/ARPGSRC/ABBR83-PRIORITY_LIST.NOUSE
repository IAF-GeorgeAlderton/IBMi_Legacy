     C                     ELSE
     C           A7KQTY    MULT A7LOTS    @@QTY   40
     C           @@QTY     IFEQ 0
     C                     Z-ADDA7KQTY    @@QTY
     C                     ENDIF
      *
     C                     ADD  @@QTY     @PKN,B
     C                     ENDIF
      *
     C                     SELEC
     C           A7KNID    WHEQ 'Q'
     C                     MOVEL'OQ'      W@KID   3 P
     C           A7KNID    WHEQ 'L'
     C                     MOVEL'LAN'     W@KID
     C           A7KNID    WHEQ 'R'
     C                     MOVEL'RL'      W@KID     P
