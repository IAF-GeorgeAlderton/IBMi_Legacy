     C                     MOVEL'FRL'     W@KID     P
     C                     OTHER
     C                     MOVELA7KNID    W@KID     P
     C                     ENDSL
      *
     C           '('       CAT  W@KID:0   @@KID   4
     C           @@KID     CAT  ')'       @ID,B
      *
     C                     ENDIF
