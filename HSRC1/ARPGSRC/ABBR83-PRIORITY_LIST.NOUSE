      *
     C                     MOVELNKBN,K    @KBN,B
     C           NDPT,K    IFNE 0111
     C           NDPT,K    ANDNE8990
     C           NDPT,K    ANDNE2255
     C           NDPT,K    ANDNE0
     C           NDPT,K    CHAINFGBPL01              91
