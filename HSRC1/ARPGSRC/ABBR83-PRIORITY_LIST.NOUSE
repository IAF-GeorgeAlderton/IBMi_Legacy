     C                     MOVE '1'       K@SHFT
     C           K#70      CHAINABBPL71              96
     C                     ENDIF
     C           *IN96     IFEQ *ON
     C                     MOVE '3'       K@SHFT
     C                     ENDIF
      *
     C           K#70      SETLLABBPL71
     C           *IN96     DOUEQ*ON
     C           K#70      READEABBPL71                  96
     C           *IN96     IFEQ *OFF
     C           A7KQTY    ANDNE*ZERO
      *
     C           A7KNID    IFEQ 'A'
