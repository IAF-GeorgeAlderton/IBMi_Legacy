JW1  F*  JW          2022.09.25 ADD PACKING LIST INQ BY DELEIVERY#             *
     F************************ AB#R40 ******************************************
     FAB#PWAL CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                        RRN2  KSFILE SFL02
     F                                              KINFDS @INFDS
     FAB#PL1A IF  E           K        DISK
     FAB#PL76 IF  E           K        DISK
     F****************************************************************
     E                    CMD     1   2 78
     E                    ERR     1   2 60
     E****************************************************************
     I@INFDS      DS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   80BANOHZ
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I            DS
     I                                        1   80K@NOHZ
     I                                        1   40K@NOYY
     I                                        5   60K@NOMM
     I                                        7   80K@NODD
     I            DS
     I                                        1  30 DAMANI
     I                                        1   8 WMANI2
     I                                       10  16 WMANI3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I**************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C           @@ID      CASEQ'02'      #SCRN2
     C           @@ID      CASEQ'03'      #SCRN3
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------------
     C           *INZSR    BEGSR
      *------------------------------------------------------------
     C           K#KEY1    KLIST
     C                     KFLD           K@NOHZ  80
     C                     KFLD           K@NOBN  20
     C                     KFLD           K@NONY  40
     C                     KFLD           K@NKOJ  1
     C                     KFLD           K@NUKE  4
     C           K#KEY2    KLIST
     C                     KFLD           K@NOHZ  80
     C                     KFLD           K@NOBN  20
     C                     KFLD           K@NONY  40
     C                     KFLD           K@NKOJ  1
     C                     KFLD           K@NUKE  4
     C                     KFLD           K@ODRN 10
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     RRN2    40
     C                     MOVE '01'      @@ID    2
      *
     C                     ENDSR
      *----------------------------------------------------------------
     C           #SCRN1    BEGSR
      *----------------------------------------------------------------
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
      * F1: END
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
      * F10: INQ
     C           *INKJ     WHEQ *ON
     C                     CALL 'AB#RAL2'
     C                     PARM           $SERL   9
     C           $SERL     IFNE *BLANK
     C                     MOVEL$SERL     D@PICK
     C                     ENDIF
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C           RRN1      IFGT *ZERO
     C                     MOVE '02'      @@ID
     C                     ELSE
     C                     MOVE *ON       *IN61
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *----------------------------------------------------------------
     C           #CLR      BEGSR
      *----------------------------------------------------------------
     C                     MOVE *BLANK    D@MSG
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *OFF      *IN99
      *
     C                     ENDSR
      *----------------------------------------------------------------
     C           #CHK1     BEGSR
      *----------------------------------------------------------------
     C                     EXSR #CLR
      *
     C           D@PICK    CHAINAB#PL76              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
JW1  C                     MOVELERR,1     D@MSG
     C                     ELSE
     C                     MOVE PUNONY    K@NONY
     C                     MOVE PUNUKE    K@NUKE
     C                     MOVE PUNKOJ    K@NKOJ
     C                     MOVE PUBINN    K@NOBN
     C                     Z-ADDPUNOYY    K@NOYY
     C                     Z-ADDPUNOMM    K@NOMM
     C                     Z-ADDPUNODD    K@NODD
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------------------
     C           #SET1     BEGSR
      *----------------------------------------------------------------
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1
     C           K#KEY1    SETLLAB#PL1A
     C           *IN80     DOUEQ*ON
     C           K#KEY1    READEAB#PL1A                  80
     C           *IN80     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           PUODRN    IFNE *BLANK
     C           BAODRN    ANDNEPUODRN
     C                     ITER
     C                     ENDIF
     C           PURLYY    IFNE *ZERO
     C           PURLYY    IFNE BADEYY
     C           PURLMM    ORNE BADEMM
     C           PURLDD    ORNE BADEDD
     C                     ITER
     C                     ENDIF
     C                     ENDIF
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     MOVE BATOKU    S@TOKU
     C                     MOVE BANONY    S@NONY
     C                     MOVE BANUKE    S@NUKE
     C                     Z-ADDBANOHZ    S@SHDT
     C                     Z-ADDBANOBN    S@BIN
     C                     MOVE BANKOJ    S@NKOJ
     C                     MOVE BAODRN    S@ORNO
     C                     WRITESFL01
      *
     C                     MOVE BAODRN    K@ODRN
     C           K#KEY2    SETGTAB#PL1A
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------------------
     C           #SCRN2    BEGSR
      *----------------------------------------------------------------
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      @@ID
     C                     OTHER
     C                     EXSR #CHK2
     C                     ENDSL
      *
     C                     ENDSR
      *----------------------------------------------------------------
     C           #CHK2     BEGSR
      *----------------------------------------------------------------
     C                     Z-ADD*ZERO     W@RRN   40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         W@RRN
     C           W@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           S@SLCT    ANDNE*BLANK
     C                     MOVE *BLANK    S@SLCT
     C                     UPDATSFL01
     C                     MOVE S@NONY    K@NONY
     C                     MOVE S@NUKE    K@NUKE
     C                     MOVE S@NKOJ    K@NKOJ
     C                     Z-ADDS@SHDT    K@NOHZ
     C                     Z-ADDS@BIN     K@NOBN
     C                     MOVE S@ORNO    K@ODRN
     C                     MOVE S@TOKU    D@CUST
     C                     MOVE S@NONY    D@NONY
     C                     MOVE S@NUKE    D@NUKE
     C                     MOVE S@NKOJ    D@FACT
     C                     Z-ADDS@SHDT    D@SHDT
     C                     Z-ADDS@BIN     D@BIN
     C                     MOVE S@ORNO    D@ORNO
     C                     EXSR #SET2
     C                     MOVE '03'      @@ID
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------------------
     C           #SET2     BEGSR
      *----------------------------------------------------------------
     C                     MOVE *ON       *IN54
     C                     WRITECTL02
     C                     MOVE *OFF      *IN54
     C                     Z-ADD*ZERO     RRN2
      *
     C           K#KEY2    SETLLAB#PL1A
     C           *IN85     DOUEQ*ON
     C           K#KEY2    READEAB#PL1A                  85
     C           *IN85     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           PURLYY    IFNE *ZERO
     C           PURLYY    IFNE BADEYY
     C           PURLMM    ORNE BADEMM
     C           PURLDD    ORNE BADEDD
     C                     ITER
     C                     ENDIF
     C                     ENDIF
     C                     CLEARSFL02
     C                     ADD  1         RRN2
      *
     C                     MOVE BAMHN1    S@MHN1
     C                     MOVE BAMHN2    S@MHN2
     C                     MOVE BAMHN3    S@MHN3
     C                     MOVE BAMHN4    S@MHN4
     C                     MOVE BASHN1    S@SHN1
     C                     MOVE BASHN2    S@SHN2
     C                     MOVE BASHN3    S@SHN3
     C                     Z-ADDBASRYO    S@QTY
     C                     MOVELBAINVN    S@INVN
JW1  C                     Z-ADDBASYOS    S@QPC
 .   C           BASYOS    IFEQ 0
 .   C                     Z-ADD1         S@BOX
 .   C                     ELSE
 .   C           BASRYO    DIV  BASYOS    SHO     90
 .   C                     MVR            REM     93
 .   C           REM       IFNE 0
 .   C                     ADD  1         SHO
 .   C                     ENDIF
 .   C                     Z-ADDSHO       S@BOX
JW1  C                     ENDIF
      **
     C                     WRITESFL02
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------------------
     C           #SCRN3    BEGSR
