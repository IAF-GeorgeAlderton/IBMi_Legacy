     C***********************************************************
     C* @0503:SIA,D-MAX LABEL
     C***********************************************************
     C           @0503     BEGSR
      *
     C                     CLEARAB#WP2L1
      *
     C                     ADD  1         @@CNT
     C                     MOVE 'P'       H2FLAG           LABEL FLAG
     C           WNONY     IFEQ '0437'
     C                     MOVEL'C742'    L2SIRE           SUPPLIER
     C                     MOVEL'SIA'     H2CNAM           CUSTOMER NAME
     C                     ELSE
     C                     MOVEL'D742'    L2SIRE
     C                     MOVEL'DMAX'    H2CNAM           CUSTOMER NAME
     C                     END
     C*
     C                     MOVE '01'      L2SIRK           FACTORY
     C                     MOVE D@CUST    L2SIRD           CUSTOMER
     C                     MOVE D@SHDT    L2NYMD           SHIP DATE
     C                     MOVELWMHIN     L2MHIN           PART
     C                     MOVELEKODRN    L2ODRN           ORDER NUMBER
     C*
     C                     MOVELEKODRN    K5ODRN
     C           KEY5      CHAINAB#PL2C1             90
     C  N90                MOVELBBSERI    L2SERI           SERIAL #
     C  N90                MOVELBBNAME    L2MNAM           PART NAME
     C  N90                MOVELBBWHLC    L2WHLC           WH LOCATION
     C  N90                MOVELBBFTLC    L2FTLC           FT LOCATION
     C                     MOVE D@CUST    L2TOKU           CUSTOMER COD
     C                     MOVE D@NONY    H2NONY           DELIVERY
     C                     MOVE D@NKOJ    H2NKOJ           FACTORY
     C                     MOVE D@NUKE    H2NUKE           DOCK
     C                     MOVE EKZETI    H2ZETI           ABSOLUTE #
     C                     MOVE EKLOC1    H2LOC1           NEW
     C                     MOVE EKLOC2    H2LOC2
     C                     MOVE EKLOC3    H2LOC3
     C                     MOVE EKLOC4    H2LOC4
      *
     C                     MOVE EKSYOS    H2SYOS           QTY
     C                     MOVE EKSERL    H2SERL
     C                     ADD  1         WKSEQ#
     C           G         IFEQ 100
     C                     Z-ADD1         WKSEQ#
     C                     END
     C*
     C                     MOVE WSEQ      H2SEQ#           SEQ #
     C                     MOVE H2UNIT    H2QTY            QTY
     C                     MOVE WSEQ#     H2PAGE           PAGE
     C                     Z-ADDQ         PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C*
     C                     MOVELPOQTY     H2#PAG           # OF PAGE
     C                     DO   W@LAB#
     C                     WRITEAB#WP2L1
     C                     ENDDO
     C*
     C                     ENDSR
     C***********************************************************
     C* @0590:DMAX 2D LABEL
     C***********************************************************
     C           @0590     BEGSR
      *
     C                     MOVE X'BA'     @HX1    1
     C                     MOVE X'5D'     @HX2    1
     C                     MOVE X'6E'     @HX3    1
     C                     MOVE X'1E'     @HX4    1
     C                     MOVE X'1C'     @HX5    1
     C                     MOVE X'1D'     @HX6    1
     C                     MOVE X'37'     @HX7    1
     C                     MOVE @HX1      @DX1
     C                     MOVE @HX2      @DX2
     C                     MOVE @HX3      @DX3
     C                     MOVE @HX4      @DX4
     C                     MOVE @HX6      @DX6
      *
     C                     CLEARAB#WP2F1
      *
     C                     Z-ADD*ZERO     @D      20
     C                     Z-ADD*ZERO     @TWGHT 110
     C                     MOVE *BLANK    MH@
     C                     MOVE *BLANK    TQ@
     C                     MOVE *BLANK    PA@
     C                     MOVE *BLANK    PQ@
      *
     C           WNONY     CHAINEDIPL40              90
     C           *IN90     IFEQ *OFF
     C                     MOVELE4ADD1    @ADR1  20
     C                     MOVELE4ADD2    @ADR2  20
     C                     MOVELE4ADD3    @ADR3  20
     C                     ENDIF
      *
     C                     MOVE '0111'    @4      4
     C           @4        CHAINEDIPL40              90
     C           *IN90     IFEQ *OFF
     C                     MOVELE4ADD1    @ADR11 20
     C                     MOVELE4ADD2    @ADR22 20
     C                     MOVELE4ADD3    @ADR33 20
     C                     MOVELE4ADD4    @ADR44 20
     C           'MADE IN' CAT  'USA':1   @ADR55 20
     C                     ENDIF
      *
     C                     MOVEL*BLANK    WW11   20
     C                     MOVEL*BLANK    WW13   20
     C                     MOVEL*BLANK    WW14   20
     C                     MOVEL*BLANK    WW15   20
     C                     MOVEL*BLANK    WW16   20
     C                     MOVEL*BLANK    WW17   20
     C                     MOVEL*BLANK    @CNTP  10
     C                     MOVEL'SH 00'   @DOCK  10
     C                     MOVE D@TOKU    @TOKU
     C                     MOVE D@NONY    @NONY
     C                     MOVELEKODRN    @ORNO  15 P
     C           K#2E      SETGTAB#PL2E
     C           *IN99     DOUEQ*ON
     C           K#2E      REDPEAB#PL2E                  99
     C           *IN99     IFEQ *OFF
     C                     MOVELAEPC11    WW11
     C                     MOVELAEPC13    WW13
     C                     MOVELAEPC14    WW14
     C                     MOVELAEPC15    WW15
     C                     MOVELAEPC16    WW16
     C                     MOVELAEPC17    WW17
     C                     MOVELAEPC12    @DOCK     P
     C                     MOVELAESBAN    F2SBAN
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           D@NONY    IFEQ 0590
     C                     MOVEL'W100'    F2PLNT           CUSTOMER NAME
     C                     ELSE
     C                     MOVEL@DOCK     F2PLNT
     C                     ENDIF
     C                     MOVEL@ADR1     F2TAD1
     C                     MOVEL@ADR2     F2TAD2
     C                     MOVEL@ADR3     F2TAD3
     C                     MOVEL@ADR11    F2FAD1
     C                     MOVEL@ADR22    F2FAD2
     C                     MOVEL@ADR33    F2FAD3
     C                     MOVEL@ADR44    F2FAD4
     C           D@NONY    IFEQ 0590
     C                     MOVEL'DMAX'    F2CNAM
     C                     ELSE
     C                     MOVEL'GM'      F2CNAM
     C                     ENDIF
     C                     MOVELEKODRN    F2REFR
     C                     MOVELWW11      F2MHND
     C                     MOVELWW13      F2REF1
     C                     MOVELWW14      F2REF2
     C                     MOVELWW15      F2REF3
     C                     MOVELWW16      F2REF4
     C                     MOVELWW17      F2REF5
     C                     ADD  1         @@CNT
      *
     C                     MOVE K@DD      DMXD
     C                     MOVE K@YY      DMXY
     C                     MOVE MON,K@MM  DMXM
     C                     MOVE DMDAT     F2SHDT
     C                     MOVELWMHIN     F2MHIN           PART
     C           F2SBAN    IFEQ *BLANK
     C                     MOVEL'0000'    F2SBAN
     C                     ENDIF
     C                     MOVE D@NONY    F2NONY
     C                     MOVE D@NKOJ    F2NKOJ
     C                     MOVE D@NUKE    F2NUKE
     C                     MOVE EKZETI    F2ZETI           ABSOLUTE #
     C                     MOVE EKLOC1    F2LOC1           NEW
     C                     MOVE EKLOC2    F2LOC2
     C                     MOVE EKLOC3    F2LOC3
     C                     MOVE EKLOC4    F2LOC4
     C                     MOVE EKSYOS    F2SYOS                       R
     C                     MOVE EKSYOS    WSYS    50                   R
      *
     C                     Z-ADD*ZERO     @@WHT   72
     C           KEY2      CHAINFCEPL011             91
B02  C           *IN91     IFEQ '0'
     C           A2GSKD    ANDEQ*BLANK
     C                     Z-ADDA2KASI    @@WHT   72
     C                     ENDIF
      *
     C           WSYS      MULT @@WHT     @@WHT2  92
     C           @@WHT2    DIV  1000      @@WHT3  50H
     C                     Z-ADD@@WHT3    PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C           POQTY     CAT  'KG':1    F2WEIG    P                  R
     C                     MOVELPOQTY     @@WHT4  5                    R
     C                     MOVELEKSERL    F2SERL
     C                     MOVE '1J'      @DUN1
     C                     MOVE EKSERL    @DUN3
     C                     MOVEL@DUN      F2LCPL
      *
     C                     MOVE *BLANK    @DX7
     C           'P'       CAT  WMHIN:0   @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
     C           @DX7      CAT  'Q':0     @DX7      P
     C           @DX7      CAT  F2SYOS:0  @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
     C           @DX7      CAT  F2LCPL:0  @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
     C           @DX7      CAT  '21L':0   @DX7      P
     C           @DX7      CAT  F2PLNT:0  @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
     C           @DX7      CAT  '7Q':0    @DX7      P
     C           @DX7      CAT  @@WHT4:0  @DX7      P
     C           @DX7      CAT  'GT':0    @DX7      P
     C           @DX7      CAT  @HX4:0    @DX7      P
     C           @DX7      CAT  @HX7:0    @DX7      P
     C                     MOVEL@DX       F22DBR
      *
     C                     WRITEAB#WP2F1
     C*
     C                     ENDSR
     C***********************************************************
     C* @3892:TRW KOYO LABEL
     C***********************************************************
     C           @3892     BEGSR
      *
     C                     CLEARAB#WP2H1
     C*
     C                     ADD  1         @@CNT
     C                     MOVELWMHIN     H2PART           PART
     C*
     C                     MOVELEKORDN    H2RAN#           RAN #
     C                     Z-ADD*ZERO     WKSEQ#
     C                     MOVE WSEQ      H2SEQ#           SEQ #
     C                     MOVE EKLOC1    H2LOC1           NEW
     C                     MOVE EKLOC2    H2LOC2
     C                     MOVE EKLOC3    H2LOC3
     C                     MOVE EKLOC4    H2LOC4
     C*
     C* GET PART NAME
     C           KEY2      SETLLFCEPL011
     C           #PART2    TAG
     C           KEY2      READEFCEPL011                 91
B02  C           *IN91     IFEQ '0'
     C                     MOVELA2SMEI    H2PNAM           PART NAME
E02  C                     END
      *
     C                     MOVE D@NONY    H2DELY           DELIVERY
     C                     MOVE D@NKOJ    H2FACT           FACTORY
     C                     MOVE D@NUKE    H2DOCK           DOCK
     C                     MOVE EKZETI    H2ZETI           ABSOLUTE #
     C                     MOVE EKSYOS    H2UNIT           QTY/CONTAINER
     C*
     C                     MOVE 'P'       H2FLAG           LABEL FLAG
     C                     MOVE EKSYOS    H2QTY            QTY
     C                     ADD  1         WKSEQ#
     C           G         IFEQ 100
     C                     Z-ADD1         WKSEQ#
     C                     END
     C*
     C                     MOVE WSEQ      H2SEQ#           SEQ #
     C                     MOVE WSEQ#     H2PAGE           PAGE
     C*
     C* # OF PAGE (NUM --> CHAR)
     C                     Z-ADDQ         PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C*
     C                     MOVELPOQTY     H2#PAG           # OF PAGE
     C*
     C                     MOVE EKSERL    H2SERL
      *
     C                     WRITEAB#WP2H1
     C*
     C                     ENDSR
     C***********************************************************
     C* @1431:NIFAST CANADA LABEL
     C***********************************************************
     C           @1431     BEGSR
     C*
     C  N88      KEY1      SETLLAB#PL131
     C  N88      KEY1      READEAB#PL131                 93
     C*
     C   88      KEY6      SETLLAB#PL131
     C   88      KEY6      READEAB#PL131                 93
     C           *IN93     DOWEQ'0'
     C           BASKJY    IFNE ' '
     C                     GOTO #READ2
     C                     END
     C*
     C           PORD#     IFNE *BLANK
     C           PORD#     ANDNEBAODRN
     C                     GOTO #READ2
     C                     END
     C*
     C           BIN       IFNE 0
     C           BIN       ANDNEBANOBN
     C                     GOTO #READ2
     C                     END
      *
     C           PNUKE     IFNE *BLANK
     C           BANUKE    ANDNEPNUKE
     C                     GOTO #READ2
     C                     ENDIF
     C*
     C           BAUSYS    IFEQ *ZERO
     C           BASYOS    ANDEQ*ZERO
     C                     MOVELWMHIN     M2PART           PART
     C                     MOVE *ALL'*'   M2QTY            QTY
     C                     MOVE *ALL'*'   M2SHDT           SHIP DATE
     C                     MOVE *ALL'*'   M2ORDR           ORDER #
     C*
     C                     WRITEAB#WP2M1
     C                     GOTO #READ2
     C                     END
      *
     C******************   EXSR #70DL
     C                     CLEARAB#PP701
     C                     ADD  1         @@CNT
     C* GET PART LOCATION
     C*
     C           KEY2      SETLLFCEPL011
     C           #PART3    TAG
     C           KEY2      READEFCEPL011                 91
     C           *IN91     IFEQ '0'
     C*
     C           A2GSKD    IFEQ 'D'
     C                     GOTO #PART3
     C                     END
     C*
     C           PNOHZ     IFGE A2DATE                     LOCATION
     C                     MOVE A2STRK    M2LOC1           NEW
     C                     MOVE A2STRT    M2LOC2
     C                     MOVE A2STRR    M2LOC3
     C                     MOVE A2STRD    M2LOC4
     C*
     C                     ELSE
     C                     MOVE A2KTRK    M2LOC1           OLD
     C                     MOVE A2KTRT    M2LOC2
     C                     MOVE A2KTRR    M2LOC3
     C                     MOVE A2KTRD    M2LOC4
     C                     END
     C*
     C                     ELSE
     C                     MOVE *BLANK    M2LOC1
     C                     MOVE *BLANK    M2LOC2
     C                     MOVE *BLANK    M2LOC3
     C                     MOVE *BLANK    M2LOC4
     C                     END
     C*
     C                     MOVELWMHIN     M2PART           PART
     C                     MOVE M2LOC1    EKLOC1
     C                     MOVE M2LOC2    EKLOC2
     C                     MOVE M2LOC3    EKLOC3
     C                     MOVE M2LOC4    EKLOC4
     C*
     C           BAUSYS    IFNE *ZERO                      QTY/CONT.
     C                     Z-ADDBAUSYS    WSYS    60
     C*
     C                     ELSE
     C           BASYOS    IFNE *ZERO
     C                     Z-ADDBASYOS    WSYS
     C                     ELSE
     C                     Z-ADDBASRYO    WSYS
     C                     END
     C                     END
     C*
     C                     Z-ADDWSYS      PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     M2QTY            QTY
     C                     MOVELPOQTY     M2UNIT           QTY
     C*
     C                     MOVE BAODRN    M2ORDR           ORDER #
     C                     MOVE PNOHZ     M2SHDT           SHIP DATE
     C                     MOVE PNONY     M2DELY           DELIVERY
     C                     MOVE PNKOJ     M2FACT           FACTORY
     C                     MOVE BANUKE    M2DOCK           DOCK
     C                     MOVE A2ZETI    M2ZETI           ABSOLUTE #
     C*
     C           *IN88     IFEQ '1'
     C*
     C* USER SELECTED NUMBER OF LABEL
     C           @#LAB     IFNE *ZERO
     C                     Z-ADD@#LAB     Q
      *
     C           1         DO   Q
     C                     EXSR @NMBR
     C                     MOVE N3NMBR    M2SERL
     C                     MOVELPNONY     M2SERL
      *
     C                     EXSR #PP70
     C*
     C                     DO   W#LAB
     C                     WRITEAB#WP2M1
     C                     END
     C                     END
     C                     GOTO #READ2
     C*
     C                     ELSE
     C           @FLAG     IFEQ *BLANK
     C                     GOTO #READ2
     C                     END
     C*
E2   C                     END
E1   C                     END
     C* USER ONLY MARKED
     C*
     C           BASRYO    DIV  WSYS      Q
     C                     MVR            WRST
     C           WRST      IFNE *ZERO
     C                     ADD  1         Q
     C                     END
     C*
     C           1         DO   Q
     C*
     C                     EXSR @NMBR
     C                     MOVE N3NMBR    M2SERL
     C                     MOVELPNONY     M2SERL
      *
     C                     EXSR #PP70
      *
     C                     DO   W#LAB
     C                     WRITEAB#WP2M1
     C                     END
     C*
     C                     END
      *
     C           #READ2    TAG
     C  N88      KEY1      READEAB#PL131                 93
     C   88      KEY6      READEAB#PL131                 93
     C                     END
     C*
     C                     ENDSR
     C***********************************************************
     C* @3347: TOYOTA EKANBAN
     C***********************************************************
     C           @3347     BEGSR
     C*
     C  N88      KEY1      SETLLAB#PL131
     C  N88      KEY1      READEAB#PL131                 93
     C*
     C   88      KEY6      SETLLAB#PL131
     C   88      KEY6      READEAB#PL131                 93
     C           *IN93     DOWEQ'0'
     C           BASKJY    IFNE ' '
     C                     GOTO #READ5
     C                     END
     C*
     C           PORD#     IFNE *BLANK
     C           PORD#     ANDNEBAODRN
     C                     GOTO #READ5
     C                     END
     C*
     C           BIN       IFNE 0
     C           BIN       ANDNEBANOBN
     C                     GOTO #READ5
     C                     END
      *
     C           PNUKE     IFNE *BLANK
     C           BANUKE    ANDNEPNUKE
     C                     GOTO #READ5
     C                     ENDIF
     C*
     C           BAUSYS    IFEQ *ZERO
     C           BASYOS    ANDEQ*ZERO
     C                     MOVELWMHIN     EKPART           PART
     C                     MOVE *ALL'*'   EKQTYC           QTY/CONT
     C                     MOVE *ALL'*'   EKSHDT           SHIP DATE
     C                     MOVE *ALL'*'   EKORDR           ORDER #
     C*
     C                     WRITEAB#WP2N1
     C                     GOTO #READ5
     C                     END
      *
     C           BATOKU    IFEQ 3411
     C           BANONY    IFEQ 3503
     C                     MOVE 'C'       SRVF
     C                     ELSE
     C                     MOVE 'T'       SRVF
     C                     ENDIF
     C                     ENDIF
     C*
     C******************   EXSR #70DL
     C                     CLEARAB#PP701
     C                     ADD  1         @@CNT
     C* READ EDI DATA FILE(TMMK)
     C                     MOVE BAMHN1    WAMHN1
     C                     MOVE BAMHN2    WAMHN2
     C                     MOVE BAMHN3    WAMHN3
     C                     MOVE BAMHN4    WAMHN4
     C                     MOVE BAODRN    WORDN
     C                     MOVELBAINVN    K@ORDR    P
     C* SUPPLIER NAME
     C                     MOVEANAM       EKSUNM           SUPPLIER NAME
     C                     MOVELBAINVN    EKORDR    P      ORDER #
     C           BANONY    IFEQ 3951
     C           BANONY    OREQ 3952
     C                     MOVELBAODRN    EKORDR    P      ORDER #
     C                     ENDIF
     C*
     C           KEY7      CHAINAB#PP401             97
     C           *IN97     IFEQ *ON
     C           KEY7X     SETGTAB#PL41
     C           KEY7X     REDPEAB#PL41                  97
     C                     ENDIF
      *
     C           *IN97     IFEQ '0'
     C                     MOVELDASTAD    EKSTAD           STORE ADDRESS
     C           DASUNM    IFNE *BLANK
     C                     MOVELDASUNM    EKSUNM           SUPPLIER NAME
     C                     ENDIF
     C                     MOVELDACUNM    EKCUNM           CUSTOMER NAME
     C                     MOVELDALIAD    EKLIAD           LINESIDE ADDRESS
     C                     MOVELDAPANM    EKPANM           PART DESCRIPTION
     C                     MOVELDASUB#    EKSUB#           SUB ROUTE
     C                     MOVELDAMANC    EKMAN#           MAIN ROUTE NUMBER
     C                     MOVELDAMAN#    EKMANC           MAIN ROUTE
     C                     MOVELDACUNM    EKCNAM           CUSTOMER NAME
     C******               MOVE DAORDN    EKORDR           ORDER #
     C*
     C                     ELSE
     C                     MOVE *BLANK    EKSTAD           STORE ADDRESS
     C                     MOVE *BLANK    EKSUNM           SUPPLIER NAME
     C                     MOVE *BLANK    EKCUNM           CUSTOMER NAME
     C                     MOVE *BLANK    EKMANC           MAIN ROUTE
     C                     MOVE *BLANK    EKLIAD           LINESIDE ADDRESS
     C                     MOVE *BLANK    EKPANM           PART DESCRIPTION
     C                     MOVE *BLANK    EKSUB#           SUB ROUTE
     C                     MOVE *BLANK    EKMAN#           MAIN ROUTE NUMBER
     C                     MOVE *BLANK    EKCNAM           CUSTOMER NAME
     C                     END
      *
     C                     MOVELBAINVN    @@6     6
     C                     MOVEL@@6       K@ODRN
     C           K#P42     SETLLAB#PP42
     C           *IN97     DOUEQ*ON
     C           K#P42     READEAB#PP42                  97
     C           *IN97     IFEQ *OFF
     C                     MOVELABSPNM    EKSUNM    P
     C                     MOVELABSTAD    EKSTAD
     C                     MOVELABLINE    EKLIAD           DESCRIPTION
     C                     MOVELABPDSC    EKPANM           DESCRIPTION
     C                     MOVELABN1ML    EKCNAM
     C                     MOVELABMAIN    EKMANC
     C                     MOVELABSUBR    EKSUB#
     C                     MOVELABMRNO    EKMAN#
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           K#47      CHAINAB#PP47              97
     C           *IN97     IFEQ *ON
     C           K#47X     SETGTAB#PP47
     C           K#47X     REDPEAB#PP47                  97
     C                     ENDIF
      *
     C           *IN97     IFEQ '0'
     C                     MOVELABSTAD    EKSTAD           STORE ADDRESS
     C           ABSPNM    IFNE *BLANK
     C                     MOVELABSPNM    EKSUNM           SUPPLIER NAME
     C                     ENDIF
     C                     MOVELABSDQ3    EKCUNM           CUSTOMER NAME
     C                     MOVELABLINE    EKLIAD           LINESIDE ADDRESS
     C                     MOVELABPDSC    EKPANM           PART DESCRIPTION
     C                     MOVELABSUBR    EKSUB#           SUB ROUTE
     C                     MOVELABMRNO    EKMAN#           MAIN ROUTE NUMBER
     C                     MOVELABRUNO    EKMANC           MAIN ROUTE
     C                     MOVELABN1MI    EKCNAM           CUSTOMER NAME
     C*
     C* TEMPORARY UNTIL STARTING REAL E-KANBAN
     C                     MOVELBAODRN    EKORDR    P      ORDER #
     C                     ENDIF
     C           BANONY    IFEQ 3951
     C           BANONY    OREQ 3952
     C                     MOVELBAODRN    EKORDR    P      ORDER #
     C                     ENDIF
      *
     C* READ KANBAN MASTER
     C           EKSTAD    IFEQ *BLANK
