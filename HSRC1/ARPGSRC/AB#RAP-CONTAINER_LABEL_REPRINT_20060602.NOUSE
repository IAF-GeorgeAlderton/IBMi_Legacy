     C***********************************************************
     C* @0503:SIA, LABEL
     C***********************************************************
     C           @M0503    BEGSR
      *
     C                     MOVE #USER     P@USER
     C                     Z-ADDD@BIN     PBIN
     C                     MOVE D@NONY    P@SIRE
     C                     MOVE *BLANK    PMANI
     C                     MOVE D@SHDT    P@NOHZ
     C                     CALL 'AB#R95'
     C                     PARM           P@USER 10
     C                     PARM           P@SIRE  4
     C                     PARM           P@NOHZ  8
     C                     PARM           PBIN    10
     C                     PARM           PMANI  18
      *
     C                     OPEN AB#WP2W
      *
     C           @@BB      IFEQ *ZERO
     C                     CLEARAB#WP2W1
     C                     ENDIF
     C                     ADD  1         @@BB
     C                     MOVE *DATE     WPDATE
     C                     MOVELP@SIRE    WPNONY
     C                     MOVELPMANI     WPASNO
     C                     WRITEAB#WP2W1
      *
     C                     CLOSEAB#WP2W
     C                     ENDIF
     C                     CLEARAB#WP2L1
      *
     C                     ADD  1         @@CNT
     C                     MOVE 'M'       H2FLAG           LABEL FLAG
     C           WNONY     IFEQ '0437'
     C                     MOVEL'C742'    L2SIRE           SUPPLIER
     C                     MOVEL'SIA'     H2CNAM           CUSTOMER NAME
     C                     ELSE
     C                     MOVEL'D742'    L2SIRE
     C                     MOVEL'DMAX'    H2CNAM           CUSTOMER NAME
     C                     END
     C*
     C                     MOVE '01'      L2SIRK           FACTORY
     C                     MOVE D@CUST    L2SIRD           CUSTOMER
     C                     MOVE D@SHDT    L2NYMD           SHIP DATE
     C                     MOVELWMHIN     L2MHIN           PART
     C                     MOVELEKODRN    L2ODRN           ORDER NUMBER
     C*
     C                     MOVELEKODRN    K5ODRN
     C           KEY5      CHAINAB#PL2C1             90
     C  N90                MOVELBBSERI    L2SERI           SERIAL #
     C  N90                MOVELBBNAME    L2MNAM           PART NAME
     C  N90                MOVELBBWHLC    L2WHLC           WH LOCATION
     C  N90                MOVELBBFTLC    L2FTLC           FT LOCATION
     C                     MOVE D@CUST    L2TOKU           CUSTOMER COD
     C                     MOVE D@NONY    H2NONY           DELIVERY
     C                     MOVE D@NKOJ    H2NKOJ           FACTORY
     C                     MOVE D@NUKE    H2NUKE           DOCK
     C                     MOVE EKZETI    H2ZETI           ABSOLUTE #
     C                     MOVE EKLOC1    H2LOC1           NEW
     C                     MOVE EKLOC2    H2LOC2
     C                     MOVE EKLOC3    H2LOC3
     C                     MOVE EKLOC4    H2LOC4
      *
     C                     MOVE EKSYOS    H2SYOS           QTY
     C                     MOVE EKSERL    H2SERL
     C                     DO   W@LAB#
     C                     WRITEAB#WP2L1
     C                     ENDDO
     C*
     C                     ENDSR
     C***********************************************************
     C* WRITE CONTAINER LABELS
     C***********************************************************
     C           #WRT1     BEGSR
      *
     C                     Z-ADD*ZERO     @@CNT   50
     C                     MOVE D@NONY    WNONY   4
     C* GET THE NUMBER OF LABEL
     C           WNONY     CHAINAB#PL90              96
     C           *IN96     IFEQ '0'
     C                     Z-ADDYA#LAB    W#LAB   30
     C                     ELSE
     C                     Z-ADD1         W#LAB
     C                     END
     C* SIA,D-MAX
     C                     SELEC
