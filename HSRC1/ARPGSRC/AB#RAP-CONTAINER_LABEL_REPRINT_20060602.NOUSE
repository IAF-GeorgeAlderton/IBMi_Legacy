     C                     MOVE I2SERL    I2FLD1
     C                     MOVE WWLOC1    WLOC1
     C                     MOVE WWLOC2    WLOC2
     C                     MOVE WWLOC3    WLOC3
     C                     MOVE WWLOC4    WLOC4
     C                     MOVELWLOC      I2ADDR
     C                     ENDIF
      *
     C                     EXSR #PP70
      *
     C           PNONY     IFEQ '0902'
     C           PNONY     OREQ '0905'
     C                     MOVE I2SERL    I2DUMY
     C                     ENDIF
     C           PNONY     IFEQ '5125'
     C                     MOVEL'AVRTA'   I2DUMY
     C                     MOVE I2SERL    @9      9
     C                     MOVEL@9        I2SB10    P
     C                     ENDIF
      * LITENS
     C           BATOKU    IFEQ 5253
     C                     MOVE I2SERL    @9C2    9
     C                     MOVEL'IND9'    @9C1    9 P
     C           @9C1      CAT  @9C2      I2FLD1    P
     C           '1T'      CAT  @9C2:0    I2RELS    P
     C                     ENDIF
     C           PNONY     IFEQ '0285'
     C                     MOVE I2SERL    @4      4
     C                     MOVEL@4        I2FLD1    P
     C                     ENDIF
      *
     C           BANONY    IFEQ 3423
     C                     MOVE I2SERL    @7      7
     C                     MOVEL@7        I2FLD1    P
     C                     ENDIF
      *
     C           BATOKU    IFEQ 5671
     C                     MOVE I2SERL    I2SEQ#
     C                     ENDIF
      *
     C           SRVF      IFEQ '1'
     C           *IN66     ANDEQ*OFF
     C                     Z-ADDBASRYO    PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     I2CQTY           QTY
     C           @ITM      IFGT 1
     C                     MOVEL'0'       I2PART    P
     C                     MOVE *BLANK    I2CQTY
     C                     ENDIF
     C                     MOVE I2SERL    I2CASE
     C                     MOVEL'242'     I2CASE
     C                     WRITEAB#WP2Q1
     C                     MOVE *ON       *IN66
      *
     C***********          EXSR #P66
     C                     MOVELWMHIN     I2PART    P      PART
      *
     C                     ENDIF
      *
      *
     C                     DO   W#LAB
     C           BANONY    IFNE 0285
     C                     WRITEAB#WP2I1
     C                     ELSE
     C                     WRITEAB#WP2AR
     C                     ENDIF
     C                     END
     C*
     C                     END
