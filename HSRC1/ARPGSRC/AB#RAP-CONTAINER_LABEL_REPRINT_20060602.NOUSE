      *
     C                     MOVELPOQTY     I2UNIT           QTY/CONT
     C                     MOVEL*BLANK    I2DUMY
     C                     MOVEL*BLANK    I2SBN5
      *
B1   C           *IN88     IFEQ '1'
     C*
     C* USER SELECTED NUMBER OF LABEL
B2   C           @#LAB     IFNE *ZERO
     C                     Z-ADD@#LAB     Q
B3   C           1         DO   Q
     C                     EXSR @NMBR
