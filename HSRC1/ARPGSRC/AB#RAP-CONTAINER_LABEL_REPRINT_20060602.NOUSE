     C                     ELSE
     C                     MOVE *BLANK    I2CNAM
     C                     END
     C*
     C* READ KANBAN MASTER
     C                     Z-ADDBANOYY    KEY14
     C                     Z-ADDBANOMM    KEY12
     C                     MOVE *BLANK    I2ADDR           STORE ADDRESS
     C           KEY4      SETLLFCCTL151
     C           *IN95     DOUEQ*ON
     C           KEY4      READEFCCTL151                 95
     C           *IN95     IFEQ '0'
     C           B4SBAN    IFNE BASBAN
