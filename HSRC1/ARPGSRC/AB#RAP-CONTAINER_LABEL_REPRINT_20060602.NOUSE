     C* SERIAL# SELECTED ?
     C           SER3F     IFNE *ZERO
     C           WSEQ##    IFLT SER3F
     C           WSEQ##    ORGT SER3T
     C                     GOTO #READ3
     C                     END
     C                     END
      *
     C                     EXSR @NMBR
      *
     C                     MOVE N3NMBR    I2SERL
     C                     MOVELPNONY     I2SERL
     C* TAKATA
     C           BATOKU    IFEQ 3656
