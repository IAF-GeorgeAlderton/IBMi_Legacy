     C*
     C* GET PART NAME
     C*
     C           KEY2      SETLLFCEPL011
     C           #PART7    TAG
     C           KEY2      READEFCEPL011                 91
B02  C           *IN91     IFEQ '0'
     C           PNONY     IFNE '5125'
     C                     MOVELA2SMEI    I2PNAM           PART NAME
     C                     ENDIF
     C*
     C           A2GSKD    IFEQ 'D'
