     C                     MOVE BAODRN    I2ORDR           ORDER #
     C*
     C                     MOVELWIPAR     I2IPAR           INTERNAL PART
     C                     MOVE PNOHZ     I2SHDT           SHIP DATE
      *
     C* CALUCULATE THE TOTAL WEIGHT PAR PART
     C* (QTY/CONTAINER) * (FINISHED WEIGHT) = NET WEIGHT PER BOX(G)
     C* (NET WEIGHT PER BOX) / 1000      = TOTAL WEIGHT / PART(KG)
     C           WSYS      MULT A2KASI    WKOT1   92
     C           WKOT1     DIV  1000      WKOT2   92
     C           WKOT2     MULT 2.2046    WKOT2     H
     C                     Z-ADDWKOT2     PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     I2WEIT           QTY
      *
     C                     Z-ADDWSYS      PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     I2QTY            QTY
     C                     MOVELPOQTY     @@QTY1  5        QTY
      *
     C                     MOVELPOQTY     I2UNIT           QTY/CONT
     C*
     C                     MOVEL'MASTE'   I2DUMY
     C                     MOVEL'R    '   I2SBN5
      ** WRITE A MASTER LABEL
     C           *IN99     IFEQ *OFF
B2   C           @#LAB     IFNE *ZERO
     C                     Z-ADD@#LAB     Q
     C                     ELSE
     C                     Z-ADDW#LAB     Q
     C                     ENDIF
     C                     ADD  1         WSEQ##
B3   C           1         DO   Q
     C                     MOVEL@@QTY     I2QTY
     C                     MOVE *BLANK    I2SERL
     C                     WRITEAB#WP2I1
      *
     C                     MOVE I2PART    O2PART
     C                     MOVE I2SBAN    O2SBAN
     C                     MOVE I2QTY     O2QTY
     C                     MOVE I2DOCK    O2DOCK
     C                     MOVE I2ADDR    O2ADDR
     C                     MOVE I2SIRE    O2SIRE
     C                     MOVE I2PNAM    O2PNAM
     C                     MOVE I2IPAR    O2IPAR
     C                     MOVE I2SHDT    O2SHDT
     C                     MOVELI2SEQ#    O2SEQ#
     C                     MOVE I2ORDR    O2ORDR
     C                     MOVE I2DUMY    O2DUMY
     C                     MOVE I2LOC1    O2LOC1
     C                     MOVE I2LOC2    O2LOC2
     C                     MOVE I2LOC3    O2LOC3
     C                     MOVE I2LOC4    O2LOC4
     C                     MOVE I2DELY    O2DELY
     C                     MOVE I2FACT    O2FACT
     C                     MOVE I2ZETI    O2ZETI
     C                     MOVE I2UNIT    O2UNIT
     C                     MOVE I2CNAM    O2CNAM
     C                     MOVE I2WEIT    O2WEIT
     C                     MOVE I2SERL    O2SERL
     C                     MOVE I2RELS    O2FILR
     C                     WRITEAB#WP2O1
      *
     C                     ENDDO
     C                     MOVE *ON       *IN99
     C                     ENDIF
