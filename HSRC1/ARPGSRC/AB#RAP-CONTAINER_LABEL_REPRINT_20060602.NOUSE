     C                     ENDIF
     C                     MOVELB4UTKR    I2ADDR           STORE ADDRESS
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C*          KEY4      CHAINFCCTL121             95
     C*          *IN95     IFEQ '0'
     C*                    MOVELB4UTKR    I2ADDR           STORE ADDRESS
     C*
     C*                    ELSE                                      1
     C*                    MOVE *BLANK    I2ADDR           STORE ADDRESS
     C*                    END
