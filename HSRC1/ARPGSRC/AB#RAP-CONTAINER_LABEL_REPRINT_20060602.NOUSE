     C                     MOVE BAMHN4    WAMHN4
     C                     MOVEL*BLANK    K@ORDR           ORDER #
     C           KEY7      CHAINAB#PP401             97
     C           *IN97     IFEQ *ON
     C                     MOVELBAINVN    K@ORDR    P
