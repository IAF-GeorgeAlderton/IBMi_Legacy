     C*
     C* CALUCULATE THE TOTAL WEIGHT PAR PART
     C* (QTY/CONTAINER) * (FINISHED WEIGHT) = NET WEIGHT PER BOX(G)
     C* (NET WEIGHT PER BOX) / 1000      = TOTAL WEIGHT / PART(KG)
     C           WSYS      MULT A2KASI    WKOT1   92
     C           WKOT1     DIV  1000      WKOT2   92
     C           WKOT2     MULT 2.2046    WKOT2     H
     C                     Z-ADDWKOT2     PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     I2WEIT           QTY
      *
     C                     Z-ADDWSYS      PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     I2QTY            QTY
     C*
     C                     MOVELPOQTY     I2UNIT           QTY/CONT
     C           I2SBN5    IFEQ *BLANK
     C                     MOVELBASBAN    I2SBN5
     C                     ENDIF
     C*
     C           K#43      CHAINAB#PP43              97
     C           *IN97     IFEQ *OFF
     C                     MOVELDASBAN    I2SBN5    P
     C                     MOVELDASTRA    I2ADDR
     C                     ENDIF
      *
B1   C           *IN88     IFEQ '1'
     C*
     C* USER SELECTED NUMBER OF LABEL
B2   C           @#LAB     IFNE *ZERO
     C                     Z-ADD@#LAB     Q
     C                     MOVE *OFF      *IN66
B3   C           1         DO   Q
      *
     C                     ADD  1         WSEQ##
     C                     EXSR @NMBR
      *
     C                     MOVE N3NMBR    I2SERL
     C                     MOVELPNONY     I2SERL
     C                     EXSR #PP70
     C           PNONY     IFEQ '0902'
     C           PNONY     OREQ '0905'
     C                     MOVE I2SERL    I2DUMY
     C                     ENDIF
     C           PNONY     IFEQ '5125'
     C                     MOVEL'AVRTA'   I2DUMY
     C                     MOVE I2SERL    @9      9
     C                     MOVEL@9        I2SB10    P
     C                     ENDIF
     C           PNONY     IFEQ '0285'
     C                     MOVE I2SERL    @4      4
     C                     MOVEL@4        I2FLD1    P
     C                     ENDIF
     C           BANONY    IFEQ 3423
     C                     MOVE I2SERL    @7      7
     C                     MOVEL@7        I2FLD1    P
     C                     ENDIF
     C           BATOKU    IFEQ 5671
     C                     MOVE I2SERL    I2SEQ#
     C                     ENDIF
      *
     C* TAKATA
     C           BATOKU    IFEQ 3656
     C                     MOVEL'LOT #'   I2TTL1
     C                     MOVE I2SERL    I2FLD1
     C                     MOVE WWLOC1    WLOC1
     C                     MOVE WWLOC2    WLOC2
     C                     MOVE WWLOC3    WLOC3
     C                     MOVE WWLOC4    WLOC4
     C                     MOVELWLOC      I2ADDR
     C                     ENDIF
      * LITENS
     C           BATOKU    IFEQ 5253
     C                     MOVE I2SERL    @9C2    9
     C                     MOVEL'IND9'    @9C1    9 P
     C           @9C1      CAT  @9C2      I2FLD1    P
     C           '1T'      CAT  @9C2:0    I2RELS    P
     C                     ENDIF
      *
     C           SRVF      IFEQ '1'
     C           *IN66     ANDEQ*OFF
     C                     Z-ADDBASRYO    PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     I2CQTY           QTY
     C           @ITM      IFGT 1
     C                     MOVEL'0'       I2PART    P
     C                     MOVE *BLANK    I2CQTY
     C                     ENDIF
     C                     MOVE I2SERL    I2CASE
     C                     MOVEL'242'     I2CASE
     C                     WRITEAB#WP2Q1
     C                     MOVE *ON       *IN66
      *
     C********             EXSR #P66
     C                     MOVELWMHIN     I2PART    P      PART
      *
     C                     ENDIF
      *
     C                     DO   W#LAB
     C           BANONY    IFNE 0285
     C                     WRITEAB#WP2I1
     C                     ELSE
     C                     WRITEAB#WP2AR
     C                     ENDIF
E3   C                     END
E3   C                     END
      *
     C                     GOTO #READ3
     C*
     C                     ELSE
     C           @FLAG     IFEQ *BLANK
     C                     GOTO #READ3
     C                     END
     C*
E2   C                     END
E1   C                     END
     C*
     C* USER ONLY MARKED
     C*
     C           BASRYO    DIV  WSYS      Q
     C                     MVR            WRST
     C           WRST      IFNE *ZERO
     C                     ADD  1         Q
     C                     END
