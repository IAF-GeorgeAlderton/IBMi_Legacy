     C***********************************************************
     C* 1ST SCREEN
     C***********************************************************
     C           #SCRN1    BEGSR
      *
B01  C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
     C*
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     MOVE '02'      @@ID
     C                     EXSR #SET1
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      * CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
      *
     C                     Z-ADDD@SHDT    K@YMD
B02  C           K#13      SETLLAB#PL13
     C           *IN90     DOUEQ*ON
     C           K#13      READEAB#PL13                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BANOBN    ANDEQD@BIN
     C           BANKOJ    ANDEQD@NKOJ
     C           BATOKU    ANDEQD@CUST
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     MOVE ER,1      D@MSG
     C                     MOVE *ON       *IN99
     C                     MOVEA'111111'  *IN,61
     C                     ENDIF
      *
      *
     C                     ENDSR
      *------------------------------------------------------
      * CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,61
      *
     C                     ENDSR
      *------------------------------------------------------
      * SET DATA
      *------------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
      *
B02  C           K#13      SETLLAB#PL13
     C           *IN90     DOUEQ*ON
     C           K#13      READEAB#PL13                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BANOBN    ANDEQD@BIN
     C           BANKOJ    ANDEQD@NKOJ
     C           BATOKU    ANDEQD@CUST
     C                     ADD  1         RRN1
     C                     CLEARSFL01
     C                     MOVE BAMHN1    S@MHN1
     C                     MOVE BAMHN2    S@MHN2
     C                     MOVE BAMHN3    S@MHN3
     C                     MOVE BAMHN4    S@MHN4
     C                     Z-ADDBASRYO    S@QTY
     C                     MOVELBAODRN    S@ORNO
     C                     MOVE BASHN1    H@SHN1
     C                     MOVE BASHN2    H@SHN2
     C                     MOVE BASHN3    H@SHN3
     C                     WRITESFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD1         #RCN1
      *
     C                     ENDSR
     C***********************************************************
     C* 2ND SCREEN
     C***********************************************************
     C           #SCRN2    BEGSR
      *
B01  C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCN1
     C*
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      @@ID
      *
     C                     OTHER
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET2
     C           RRN2      IFEQ 0
     C                     MOVE ER,2      D@MSG
     C                     ELSE
     C                     MOVE '03'      @@ID
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
     C*
     C                     ENDSR
     C***********************************************************
     C* CHECK
     C***********************************************************
     C           #CHK2     BEGSR
      *
     C                     EXSR #CLR
      *
     C                     Z-ADD*ZERO     WRRN    40
     C                     MOVE *ON       *IN99
      *
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           S@SLC1    IFNE *BLANK
     C                     MOVE *OFF      *IN99
     C                     MOVE H@SHN1    K@SHN1
     C                     MOVE H@SHN2    K@SHN2
     C                     MOVE H@SHN3    K@SHN3
     C                     MOVE S@MHN1    D@MHN1
     C                     MOVE S@MHN2    D@MHN2
     C                     MOVE S@MHN3    D@MHN3
     C                     MOVE S@MHN4    D@MHN4
     C                     MOVELS@ODRN    D@ORNO
     C                     MOVE *BLANK    S@SLC1
     C                     UPDATSFL01
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C***********************************************************
     C* SET DATA FOR 3RD SCREEN
     C***********************************************************
     C           #SET2     BEGSR
      *
     C                     MOVE *ON       *IN54
     C                     WRITECTL02
     C                     MOVE *OFF      *IN54
     C                     Z-ADD*ZERO     RRN2    40
     C           K#70      SETLLAB#PL70
     C           *IN90     DOUEQ*ON
     C           K#70      READEAB#PL70                  90
     C           *IN90     IFEQ *OFF
     C                     CLEARSFL02
     C                     MOVE EKSERL    S@ILBL
     C                     Z-ADDEKYMD     S@SCAN
     C                     Z-ADDEKDETM    S@TIME
      *
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD1         #RCN2
      *
     C                     ENDSR
     C***********************************************************
     C* 3RD SCREEN
     C***********************************************************
     C           #SCRN3    BEGSR
      *
B01  C                     MOVE CMD,3     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN53
     C                     EXFMTCTL02
     C                     MOVE *OFF      *IN53
      *
     C                     Z-ADD@@REC     #RCN2
     C*
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKL     WHEQ *ON
     C                     MOVE '02'      @@ID
     C           *INKI     WHEQ *ON
     C                     EXSR #ALL
      *
     C                     OTHER
     C                     EXSR #CHK3
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #WRT
     C                     MOVE '02'      @@ID
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET2
     C           RRN2      IFNE *ZERO
     C                     MOVE '03'      @@ID
     C                     ENDIF
     C                     ELSE
     C                     MOVELMSG,1     D@MSG
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
     C*
     C                     ENDSR
     C***********************************************************
     C* CHECK
     C***********************************************************
     C           #CHK3     BEGSR
      *
     C                     EXSR #CLR
      *
     C                     Z-ADD*ZERO     WRRN    40
     C                     MOVE *ON       *IN99
      *
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL02                90
     C           *IN90     IFEQ *OFF
     C           S@SLC2    ANDNE*BLANK
     C                     MOVE *OFF      *IN99
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C***********************************************************
     C* CHECK
     C***********************************************************
     C           #ALL      BEGSR
      *
     C                     Z-ADD*ZERO     WRRN    40
      *
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL02                90
     C           *IN90     IFEQ *OFF
     C                     MOVE 'X'       S@SLC2
     C                     UPDATSFL02
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C***********************************************************
     C* WRITE
     C***********************************************************
     C           #WRT      BEGSR
      * MASTER
     C                     EXSR #MAST
