      ** QTY FOR MASTER LABEL
     C           *IN99     IFEQ *OFF
     C                     Z-ADDBASRYO    PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     @@QTY   5        TOTAL WGHT
     C                     ENDIF
     C*
     C                     MOVE BANUKE    I2DOCK           DOCK CODE
     C                     MOVE *BLANK    I2DUMY           DUMMY
     C                     MOVE PNONY     I2DELY           DELIVERY
     C                     MOVE PNKOJ     I2FACT           FACTORY
     C                     MOVE A2ZETI    I2ZETI           ABSOLUTE #
     C*
     C* TOPICS CUSTOMER MASTER
     C                     MOVE BATOKU    K31
     C                     MOVE BANONY    K32
     C           KEY3      CHAINALAPL01              92
     C           *IN92     IFEQ '0'
