     F** AN#RFK ********************************************
     F*  ANDROID PACKING SLIP(GET DELIVERY CODE FOR NIRVANA)
     F*                                                    *
     F* TCHK1 07/18/06 CREATE(COPY FROM AB#RFK)            *
     F******************************************************
     C*
     C           *ENTRY    PLIST
     C                     PARM           PPLAN   4
     C                     PARM           PDOCK   4
     C                     PARM           PEND    1
     C                     PARM           PFLG    1
      *
     C           PFLG      IFEQ '1'
     C                     SELEC
     C           PPLAN     WHEQ '0000'
     C                     MOVEL'2855'    PPLAN
     C                     MOVEL'00  '    PDOCK
     C                     MOVEL' '       PEND
     C           PPLAN     WHEQ '2855'
     C                     MOVEL'2856'    PPLAN
     C                     MOVEL'00  '    PDOCK
     C                     MOVEL' '       PEND
     C           PPLAN     WHEQ '2856'
     C                     MOVEL'0000'    PPLAN
     C                     MOVEL'    '    PDOCK
     C                     MOVEL'1'       PEND
     C                     ENDSL
     C                     END
     C*
     C                     SETON                     LR
     C                     RETRN
