     H            Y.
     F** AFGR03 *********************************************
     F* CREATE EDI ORDER DATA 850 FOR OUTSOURCE             *
     F*             T.SAKAKI       2016.11.13               *
     F*******************************************************
     FAFGPW03 CF  E                    WORKSTN
     F                                        RRN2  KSFILE SFL01
     F                                              KINFDS @INFDS
     FAFGWP02 IF  E           K        DISK
     FAFGPL03 IF  E           K        DISK
     FEDIPP50 IF  E           K        DISK
     FAFDPL26 UF  E           K        DISK
     FAFGPL02 UF  E           K        DISK
      *
     E                    ERR     1  11 50
      *
     I@INFDS      DS
     I                                     *STATUS  @STTS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
      *------------------------------
     I            DS
     I                                        1  14 S1PART
     I                                        1   5 S1SHN1
     I                                        6   6 S1SF1
     I                                        7  11 S1SHN2
     I                                       12  12 S1SF2
     I                                       13  14 S1SHN3
     I            DS
     I                                        1  31 D1INBR
     I                                        1  14 D1SHN1
     I            DS
     I                                        1   9 D1UOME
     I                                        1   4 D1UOM1
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTITM
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------*
      * ENTRY LIST                                         *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1SUPP  4
     C                     PARM           P1SUPN 15
     C                     PARM           P1ODNO  60
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1CMD   2
      *----------------------------------------------------*
      * KEY LIST                                           *
      *----------------------------------------------------*
     C           KEY1      KLIST
     C                     KFLD           P1SUPP
     C                     KFLD           P1ODNO
     C                     KFLD           P1SHN1
     C                     KFLD           P1SHN2
     C                     KFLD           P1SHN3
     C**
     C           KEY2      KLIST
     C                     KFLD           P1SUPP
     C                     KFLD           K1SNRV  1
     C                     KFLD           K1DKBN  3
     C******************************************************
     C*  MAIN
     C******************************************************
     C*
     C                     EXSR @INT
     C*
     C                     EXSR @DSP01
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C******************************************************
     C*  INITIAL SET
     C******************************************************
     C           @INT      BEGSR
     C*
     C                     TIME           WTIME
     C*
     C                     MOVELP1SUPP    D1SUPP
     C                     MOVELP1SUPN    D1SUPN
     C                     MOVEL*BLANK    D1GPPO
     C                     MOVEL*BLANK    P1CMD
     C*
     C                     SETOF                     606162
     C                     SETOF                     889963
     C*
     C                     ENDSR
     C******************************************************
     C*  @DSP01
     C******************************************************
     C           @DSP01    BEGSR
     C*
     C                     EXSR @SFSET
     C                     Z-ADD1         W#RNP2  40
     C*
     C                     DO   *HIVAL
     C*
     C                     WRITEFMT09
     C                     Z-ADDW#RNP2    #RCN02
     C                     EXFMTCTL01
     C   KC                LEAVE
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP2
     C                     END
     C*
     C                     SETOF                     606199
     C                     SETOF                     6263
     C                     MOVEL*BLANK    D1ERR
     C*-------------------------------
     C* F8  CHANGE SCREEN
     C*-------------------------------
     C           *INKH     IFEQ *ON
     C                     EXSR @DSP02
     C   KC                LEAVE
     C** UPDATED
     C           P1CMD     IFEQ 'UP'
     C                     LEAVE
     C                     ENDIF
     C*
     C                     ITER
     C                     ENDIF
     C*-----------------------
     C* CHECK INPUT
     C*-----------------------
     C                     EXSR @D1CHK
     C*
     C* NO ERROR
     C           *IN99     IFEQ *OFF
     C                     SELEC
     C*-------------------------------
     C* F12 RETRIEVE FROM GPS
     C*-------------------------------
     C           *INKL     WHEQ *ON
     C                     CALL 'AFGC02'
     C                     PARM           P1SUPP  4
     C                     PARM           P1ODNO  60
     C                     PARM           D1GPPO 17
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1OKNG  2
     C*
     C           P1OKNG    IFEQ 'NG'
     C                     MOVELERR,4     D1ERR
     C                     SETON                     6099
     C                     SETOF                     88
     C                     ITER
     C                     END
     C           P1OKNG    IFEQ 'OK'
     C* CTL01 SET
     C                     EXSR @CTSET
     C                     ENDIF
     C*-------------------------------
     C* F5 UPDATE &CREATE EDI DATA
     C*-------------------------------
     C           *INKE     WHEQ *ON
     C* RETRIEVED CORRECTLY?
     C           P1OKNG    IFNE 'OK'
     C                     MOVELERR,6     D1ERR
     C                     SETON                     6099
     C                     ITER
     C                     ENDIF
     C* UPDATE
     C                     EXSR @UPDAT
     C                     LEAVE
     C*
     C                     ENDSL
     C*
     C                     Z-ADD1         W#RNP2
     C                     ITER
     C                     ENDIF
     C*
     C   KC                LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  SFL01  SET
     C******************************************************
     C           @SFSET    BEGSR
     C*
     C                     MOVEL*ON       *IN41
     C                     WRITECTL01
     C                     MOVEL*OFF      *IN41
     C                     MOVEL*OFF      *IN42
     C                     Z-ADD*ZERO     RRN2    40
     C                     Z-ADD*ZERO     WKTTQY 112
     C*
     C           KEY1      SETLLAFDPP201
     C                     DO   *HIVAL
     C           KEY1      READEAFDPP201                 80
     C   80                LEAVE
     C*  DELETED RECORD ?
     C           AFSKJY    IFEQ 'D'
     C           AFSKDT    ANDLEWTIHZ
     C                     ITER
     C                     END
     C* CREATE SUB-FILE
     C                     EXSR #SFSET
     C*
     C           RRN2      IFEQ 9999
     C                     LEAVE
     C                     ENDIF
     C*
     C                     ENDDO
     C*
     C*
     C           RRN2      IFEQ *ZERO
     C                     CLEARSFL01
     C                     Z-ADD1         RRN2
     C                     WRITESFL01
     C                     MOVEL*ON       *IN99
     C                     MOVELERR,2     D1ERR
     C                     END
     C*
     C           RRN2      IFEQ 9999
     C                     MOVEL*ON       *IN99
     C                     MOVELERR,3     D1ERR
     C                     END
     C*
     C*
     C                     ENDSR
      *----------------------------------------------------*
      * SET SUBFILE                                      *
      *----------------------------------------------------*
     CSR         #SFSET    BEGSR
      *
     C                     CLEARSFL01
      *
     C                     MOVELP1SHN1    S1SHN1
     C                     MOVEL'-'       S1SF1
     C                     MOVELP1SHN2    S1SHN2
     C                     MOVEL'-'       S1SF2
     C                     MOVELP1SHN3    S1SHN3
     C           P1SHN3    IFEQ *BLANK
     C                     MOVEL*BLANK    S1SF2
     C                     ENDIF
     C                     MOVELS1PART    P1SHN  14
      *
     C           AFHAKO    MULT AFSYOS    WKTQTY  70
     C                     Z-ADDWKTQTY    S1TQTY
     C                     ADD  WKTQTY    WKTTQY
      *
      *
     C           AFWGT1    MULT 2.2046    WKTWGT  82H      KG --> LB
     C                     Z-ADDWKTWGT    S1TWGT
      *
     C                     MOVELAFBINN    S1BINN
     C                     Z-ADDAFHAKO    S1NBOX
      *
     C                     ADD  1         RRN2
     C                     WRITESFL01
      *
     CSR         ESFSET    ENDSR
     C******************************************************
     C*  INPUT CHECK
     C******************************************************
     C           @D1CHK    BEGSR
     C*
     C           D1GPPO    IFEQ *BLANK
     C                     MOVELERR,1     D1ERR
     C                     SETON                     6099
     C                     ELSE
     C           D1GPPO    CHAINAFGPL031             85
     C           *IN85     IFEQ '0'
     C           AGSKJY    IFEQ 'D'
     C           AGSKDT    ANDLEWTIHZ
     C                     ELSE
     C                     MOVELERR,5     D1ERR
     C                     SETON                     6099
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C* F12
S1   C           *INKL     IFEQ *OFF
     C* VALUE SET
     C           *IN88     ANDEQ*ON
     C*
 S2  C           D1GPPO    IFNE W1GPPO
     C  N99                MOVELERR,6     D1ERR
     C  N99                SETON                     6099
 E2  C                     ENDIF
     C*
     C*  %0001
     C                     MOVEL*BLANK    P1SHNX 12
     C                     MOVEL*BLANK    P@IN   30
     C                     MOVELP1SHN     P@IN   30
     C                     MOVEL*BLANK    P@OUT  30
     C                     CALL 'APLR36'
     C                     PARM           P@IN   30
     C                     PARM           P@OUT  30
     C                     MOVELP@OUT     P1SHNX
      *
     C                     MOVEL*BLANK    D1SHNX 12
     C                     MOVEL*BLANK    P@IN   30
     C                     MOVELD1SHN1    P@IN   30
     C                     MOVEL*BLANK    P@OUT  30
     C                     CALL 'APLR36'
     C                     PARM           P@IN   30
     C                     PARM           P@OUT  30
     C                     MOVELP@OUT     D1SHNX
     C*
 S2  C           P1SHNX    IFNE D1SHNX
     C  N99                MOVELERR,7     D1ERR
     C  N99                SETON                     6199
 E2  C                     ENDIF
     C*
     C*
 S2  C           D1UOM1    IFEQ 'EACH'
     C           WKTTQY    ANDNED1ORDQ
     C  N99                MOVELERR,8     D1ERR
     C  N99                SETON                     6299
 E2  C                     ENDIF
     C*
     C           D1FONB    IFEQ *BLANK
     C           D1FONB    ORNE 'CC'
     C           D1FONB    ANDNE'CF'
     C           D1FONB    ANDNE'PC'
     C           D1FONB    ANDNE'PP'
     C                     MOVELERR,9     D1ERR
     C                     SETON                     6399
     C                     ENDIF
     C*
E1   C                     ENDIF
     C*
     C                     ENDSR
     C******************************************************
     C*  CTL01  SET
     C******************************************************
     C           @CTSET    BEGSR
     C*
     C* SAVE VALUES
     C                     MOVELD1GPPO    W1GPPO 17
     C                     SETON                     88
     C*
     C           KEY1      CHAINAFGWP021             81
     C           *IN81     IFEQ '0'
     C*
     C* 1ST SCREEN
     C                     MOVELAWINBR    D1INBR
     C                     MOVELAWPAYT    D1PAYT
     C                     MOVELAWCONF    D1CONF
     C                     MOVELAWSHPM    D1SHPM
     C                     MOVELAWUOME    D1UOME
     C                     MOVEL*BLANK    WKSHPM
     C                     MOVELAWSHPM    WKSHPM  2
     C* MILK RUN OR BE-  PREPAID
     C           WKSHPM    IFEQ 'MI'
     C           WKSHPM    OREQ 'BE'
     C                     MOVEL'PP'      D1FONB
     C                     ENDIF
     C* 2ND SCREEN
     C                     Z-ADDAWREQD    D1REQD
     C                     Z-ADDAWORDQ    D1ORDQ
     C                     Z-ADDAWUNTP    D1UNTP
     C                     Z-ADDAWEXTP    D1EXTP
     C                     MOVELAWITDS    D1ITDS
     C                     MOVELAWCMT1    D1CMT1
     C                     MOVELAWCMT2    D1CMT2
     C                     MOVELAWCMT3    D1CMT3
     C                     MOVELAWCMT4    D1CMT4
     C* 2ND SCREEN
     C                     MOVELP1SUPP    D1VDCD
     C                     MOVELAWVDNM    D1VDNM
     C                     MOVELAWVDA1    D1VDA1
     C                     MOVELAWVDA2    D1VDA2
     C                     MOVELAWVDCI    D1VDCI
     C                     MOVELAWVDST    D1VDST
     C                     MOVELAWVDZI    D1VDZI
     C                     MOVELAWVDPN    D1VDPN
     C                     MOVEL'0111'    D1STCD
     C                     MOVELAWSTNM    D1STNM
     C                     MOVELAWSTA1    D1STA1
     C                     MOVELAWSTA2    D1STA2
     C                     MOVELAWSTCI    D1STCI
     C                     MOVELAWSTST    D1STST
     C                     MOVELAWSTZI    D1STZI
     C                     MOVELAWSTPN    D1STPN
     C                     ENDIF
     C* EDIPP50
     C                     MOVEL'S'       K1SNRV
     C                     MOVEL'850'     K1DKBN
     C* EDIPP50
     C           KEY2      CHAINEDIPP501             84
     C           *IN84     IFEQ '0'
     C                     MOVELE5STCP    D1STCP
     C                     MOVELE5SFCP    D1VDCP
     C*
     C                     MOVELE5SELP    WKSELP  4
     C           WKSELP    IFNE *BLANK
     C           P1SUPP    ANDNEWKSELP
     C                     MOVELE5SELP    D1SECD
     C                     MOVELD1VDNM    D1SENM
     C                     ENDIF
     C                     ENDIF
     C*
     C                     WRITECTL01
     C*
     C*  %0001
     C                     MOVEL*BLANK    P1SHNX 12
     C                     MOVEL*BLANK    P@IN   30
     C                     MOVELP1SHN     P@IN   30
     C                     MOVEL*BLANK    P@OUT  30
     C                     CALL 'APLR36'
     C                     PARM           P@IN   30
     C                     PARM           P@OUT  30
     C                     MOVELP@OUT     P1SHNX
      *
     C                     MOVEL*BLANK    D1SHNX 12
     C                     MOVEL*BLANK    P@IN   30
     C                     MOVELD1SHN1    P@IN   30
     C                     MOVEL*BLANK    P@OUT  30
     C                     CALL 'APLR36'
     C                     PARM           P@IN   30
     C                     PARM           P@OUT  30
     C                     MOVELP@OUT     D1SHNX
     C*
 S2  C           P1SHNX    IFNE D1SHNX
     C  N99                MOVELERR,7     D1ERR
     C  N99                SETON                     6199
 E2  C                     ENDIF
     C*
     C           D1UOM1    IFEQ 'EACH'
     C           WKTTQY    ANDNED1ORDQ
     C  N99                MOVELERR,8     D1ERR
     C  N99                SETON                     6299
     C                     ENDIF
     C*
     C*
     C                     ENDSR
     C******************************************************
     C*  @DSP02
     C******************************************************
     C           @DSP02    BEGSR
