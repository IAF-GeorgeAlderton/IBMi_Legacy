     C*
     C                     CALL 'AFGC02'
     C                     PARM           P1SUPP  4
     C                     PARM           P1ODNO  60
     C                     PARM           D1GPPO 17
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1OKNG  2
     C*
