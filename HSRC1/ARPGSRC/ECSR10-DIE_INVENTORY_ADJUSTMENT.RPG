     H            Y.
     F** ECSR10 **********************************
     F* DIE INVENTORY ADJUSTMENT
     F* PROGRAM ID. : ECSR10
     F* CREATE DATE. : AUG.29.02                 *
     F* AUTHOR.         : TCH                    *
     F********************************** ECQR15 **
     FECSPW10 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FECSPL10 UF  E           K        DISK                      A
     FECSPP20 O   E                    DISK
     FECSPP80 O   E                    DISK
     FGCQPL11 IF  E           K        DISK
     FGCQPL12 IF  E           K        DISK
      *-----------------------------------------------------------
     E                    CMD     1   3 78
     E                    MSG     1   2 78
      *-----------------------------------------------------------
     I@INFDS      DS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------
      *  MAIN ROUTINE
      *--------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C           W@ID      CASEQ'03'      #SCRN3
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *------------------------------------------------------
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      *
     C           KEY1      KLIST
     C                     KFLD           D@KAT1
     C                     KFLD           D@KAT2
     C                     KFLD           D@KAT3
      *
     C           KEY       KLIST
     C                     KFLD           D@LOC1
     C                     KFLD           D@LOC2
     C                     KFLD           D@LOC3
     C                     KFLD           D@LOC4
     C           KEYX      KLIST
     C                     KFLD           S@KAT1
     C                     KFLD           S@KAT2
     C                     KFLD           S@KAT3
     C           KEY2      KLIST
     C                     KFLD           S@LOC1
     C                     KFLD           S@LOC2
     C                     KFLD           S@LOC3
     C                     KFLD           S@LOC4
      *
     C                     MOVE '01'      W@ID    2
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SCRN1    BEGSR
      *-----------------------------------------------------
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #CHK      BEGSR
      *-----------------------------------------------------
     C                     SETOF                     616299
     C                     MOVE *BLANK    D@MSG
      *
     C           D@KAT1    IFEQ *BLANK
     C           D@LOC1    ANDEQ*BLANK
     C                     SETON                     616299
     C                     ENDIF
      *
     C           D@KAT1    IFNE *BLANK
     C           KEY1      CHAINGCQPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     9962
     C                     MOVE MSG,2     D@MSG
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SET      BEGSR
      *-----------------------------------------------------
     C           D@KAT1    IFNE *BLANK
     C                     EXSR #SET2
     C                     MOVE '03'      W@ID
     C                     ELSE
     C                     EXSR #SET1
     C           RRN1      IFEQ *ZERO
     C                     MOVE MSG,1     D@MSG
     C                     SETON                     6199
     C                     ELSE
     C                     MOVE '02'      W@ID
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SET1     BEGSR
      *-----------------------------------------------------
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @RRN1   40
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
      *
     C           D@LOC2    CAT  '99':0    W@LOC2  2 P
     C           D@LOC3    CAT  '99':0    W@LOC3  2 P
      *
     C           KEY       SETLLGCQPL11
     C           *IN90     DOUEQ*ON
     C           D@LOC1    READEGCQPL11                  90
     C           *IN90     IFEQ *OFF
     C           T6SKJY    ANDEQ*BLANK
      *
     C           D@LOC2    IFNE *BLANK
     C           T6TKR2    ANDGTW@LOC2
     C                     LEAVE
     C                     ENDIF
      *
     C           D@LOC3    IFNE *BLANK
     C           T6TKR3    ANDGTW@LOC3
     C                     LEAVE
     C                     ENDIF
      *
     C           D@LOC4    IFNE *BLANK
     C           T6TKR4    ANDGTD@LOC4
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  1         RRN1
     C                     CLEARSFL01
     C                     MOVE T6TKR1    S@LOC1
     C                     MOVE T6TKR2    S@LOC2
     C                     MOVE T6TKR3    S@LOC3
     C                     MOVE T6TKR4    S@LOC4
     C                     MOVE T6KAT1    S@KAT1
     C                     MOVE T6KAT2    S@KAT2
     C                     MOVE T6KAT3    S@KAT3
     C           KEYX      CHAINECSPL10             N95
     C           *IN95     IFEQ *OFF
     C                     Z-ADDE1SQTY    S@QTY
     C                     Z-ADDE1SQTY    H@QTY
     C                     ENDIF
     C                     WRITESFL01
     C           KEY2      SETGTGCQPL11
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD1         #RCNO1
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVELCMD,3     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCNO1
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
     C           *INKE     WHEQ *ON
     C                     EXSR #UPD1
     C                     MOVEL'01'      W@ID
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   UPDATE
      *------------------------------------------------------
     C           #UPD1     BEGSR
      *
     C                     Z-ADD*ZERO     @RRN1
     C           *IN90     DOUEQ*ON
     C                     ADD  1         @RRN1
     C           @RRN1     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           S@QTY     ANDNEH@QTY
      *
     C           KEYX      CHAINECSPL10              95
     C           *IN95     IFEQ *ON
     C           S@QTY     ANDNE*ZERO
     C                     CLEARECSPP101
     C                     MOVE S@LOC1    E1LOC1
     C                     MOVE S@LOC2    E1LOC2
     C                     MOVE S@LOC3    E1LOC3
     C                     MOVE S@LOC4    E1LOC4
     C                     MOVE S@KAT1    E1KAT1
     C                     MOVE S@KAT2    E1KAT2
     C                     MOVE S@KAT3    E1KAT3
     C                     MOVE S@KAT4    E1KAT4
     C                     ENDIF
      *
     C                     Z-ADDS@QTY     E1SQTY
     C                     Z-ADD*DATE     E1KDAT
     C                     TIME           E1KTIM
     C                     MOVEL#USER     E1KOME
     C                     MOVEL#PGM      E1KPGM
     C                     Z-ADD*DATE     E1INDT
     C           *IN95     IFEQ *ON
     C           S@QTY     ANDNE*ZERO
     C                     WRITEECSPP101
     C                     ENDIF
      *
     C  N95                UPDATECSPP101
      *
     C                     CLEARECSPP201
     C                     Z-ADD*DATE     E2KDAT
     C                     TIME           E2KTIM
     C                     MOVEL#USER     E2KOME
     C                     MOVEL#PGM      E2KPGM
     C                     Z-ADD*DATE     E2DATE
     C                     MOVE S@KAT1    E2KAT1
     C                     MOVE S@KAT2    E2KAT2
     C                     MOVE S@KAT3    E2KAT3
     C                     MOVE S@KAT4    E2KAT4
     C                     MOVE '2'       E2WHID
     C           S@QTY     SUB  H@QTY     E2WQTY
     C                     WRITEECSPP201
     C                     CLEARECSPP801
     C                     Z-ADD0111      E8BMON            FACTORY CODE
     C                     MOVELS@KAT1    E8KAT1            DIE NO 1
     C                     MOVELS@KAT2    E8KAT2            DIE NO 2
     C                     MOVELS@KAT3    E8KAT3            DIE NO 3
     C                     MOVELS@KAT4    E8KAT4            DIE NO 4
     C                     MOVELS@LOC1    E8TKR1            FACTORY
     C                     MOVELS@LOC2    E8TKR2            PASSAGE
     C                     MOVELS@LOC3    E8TKR3            LINE
     C                     MOVELS@LOC4    E8TKR4            STAIR
     C                     MOVEL*BLANK    E8TKR5            STAIR
     C           S@QTY     SUB  H@QTY     W@CQTY  50
     C           W@CQTY    IFGE *ZERO
     C                     Z-ADDW@CQTY    E8KOSU            IN/OUT QUANTITY
     C                     MOVEL'I'       E8IOKB            IN/OUT FLG
     C                     ELSE
     C                     Z-SUBW@CQTY    E8KOSU            IN/OUT QUANTITY
     C                     MOVEL'O'       E8IOKB            IN/OUT FLG
     C                     ENDIF
     C                     MOVEL'A'       E8GSKB            GENERATION SOURCE
     C                     Z-ADDE1INDT    E8IOHZ            IN/OUT DATE
     C                     Z-ADDE1KTIM    E8IOJK            IN/OUT TIME
     C                     MOVELE1KOME    E8IOME            IN/OUT WORKER
     C                     MOVEL'OK'      E8HNTE            JUDGMENT
     C                     WRITEECSPP801
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SET2     BEGSR
      *-----------------------------------------------------
     C                     MOVE T6TKR1    D@LC01
     C                     MOVE T6TKR2    D@LC02
     C                     MOVE T6TKR3    D@LC03
     C                     MOVE T6TKR4    D@LC04
     C           KEY1      CHAINECSPL10             N95
     C           *IN95     IFEQ *OFF
     C                     Z-ADDE1SQTY    D@QTY
     C                     Z-ADDE1SQTY    W@QTY   40
     C                     ELSE
     C                     Z-ADD*ZERO     D@QTY
     C                     Z-ADD*ZERO     W@QTY
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   3RD SCREEN
      *------------------------------------------------------
     C           #SCRN3    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP02
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
     C           *INKE     WHEQ *ON
     C                     EXSR #UPD2
     C                     MOVEL'01'      W@ID
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   UPDATE
      *------------------------------------------------------
     C           #UPD2     BEGSR
      *
     C           D@QTY     IFNE W@QTY
     C           KEY1      CHAINECSPL10              95
     C           *IN95     IFEQ *ON
     C                     CLEARECSPP101
     C                     MOVE D@LC01    E1LOC1
     C                     MOVE D@LC02    E1LOC2
     C                     MOVE D@LC03    E1LOC3
     C                     MOVE D@LC04    E1LOC4
     C                     MOVE D@KAT1    E1KAT1
     C                     MOVE D@KAT2    E1KAT2
     C                     MOVE D@KAT3    E1KAT3
     C                     MOVE D@KAT4    E1KAT4
     C                     ENDIF
      *
     C                     Z-ADDD@QTY     E1SQTY
     C                     Z-ADD*DATE     E1KDAT
     C                     TIME           E1KTIM
     C                     MOVEL#USER     E1KOME
     C                     MOVEL#PGM      E1KPGM
     C                     Z-ADD*DATE     E1INDT
     C   95                WRITEECSPP101
     C  N95                UPDATECSPP101
      *
     C                     CLEARECSPP201
     C                     Z-ADD*DATE     E2KDAT
     C                     TIME           E2KTIM
     C                     MOVEL#USER     E2KOME
     C                     MOVEL#PGM      E2KPGM
     C                     Z-ADD*DATE     E2DATE
     C                     MOVE D@KAT1    E2KAT1
     C                     MOVE D@KAT2    E2KAT2
     C                     MOVE D@KAT3    E2KAT3
     C                     MOVE D@KAT4    E2KAT4
     C                     MOVE '2'       E2WHID
     C           D@QTY     SUB  W@QTY     E2WQTY
     C                     WRITEECSPP201
     C                     CLEARECSPP801
     C                     Z-ADD0111      E8BMON            FACTORY CODE
     C                     MOVELD@KAT1    E8KAT1            DIE NO 1
     C                     MOVELD@KAT2    E8KAT2            DIE NO 2
     C                     MOVELD@KAT3    E8KAT3            DIE NO 3
     C                     MOVELD@KAT4    E8KAT4            DIE NO 4
     C                     MOVELD@LC01    E8TKR1            FACTORY
     C                     MOVELD@LC02    E8TKR2            PASSAGE
     C                     MOVELD@LC03    E8TKR3            LINE
     C                     MOVELD@LC04    E8TKR4            STAIR
     C                     MOVEL*BLANK    E8TKR5            STAIR
     C           D@QTY     SUB  W@QTY     W@CQTY  50
     C           W@CQTY    IFGE *ZERO
     C                     Z-ADDW@CQTY    E8KOSU            IN/OUT QUANTITY
     C                     MOVEL'I'       E8IOKB            IN/OUT FLG
     C                     ELSE
     C                     Z-SUBW@CQTY    E8KOSU            IN/OUT QUANTITY
     C                     MOVEL'O'       E8IOKB            IN/OUT FLG
     C                     ENDIF
     C                     MOVEL'A'       E8GSKB            GENERATION SOURCE
     C                     Z-ADDE1INDT    E8IOHZ            IN/OUT DATE
     C                     Z-ADDE1KTIM    E8IOJK            IN/OUT TIME
     C                     MOVELE1KOME    E8IOME            IN/OUT WORKER
     C                     MOVEL'OK'      E8HNTE            JUDGMENT
     C                     WRITEECSPP801
     C                     ENDIF
      *
     C                     ENDSR
** CMD
  F1:END
  F1:END     F5:UPDATE     F12:GO BACK
