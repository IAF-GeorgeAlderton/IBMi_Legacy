      ***************************** GDLR10 **
     FGDLPL11 IF  E           K        DISK
     FGDLPL20 IF  E           K        DISK
     FGDLPL25 IF  E           K        DISK
     FIZAPL03 IF  E           K        DISK
     FIZBPL03 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     E                    COMT    1   2 50
     I            DS
     I                                        1   80LBSKHZ
     I                                        1   40LBSKYY
     I                                        5   60LBSKMM
     I                                        7   80LBSKDD
      *
     I            DS
     I                                        1   80LCSKHZ
     I                                        1   40LCSKYY
     I                                        5   60LCSKMM
     I                                        7   80LCSKDD
      *
     I            DS
     I                                        1   80LDSKHZ
     I                                        1   40LDSKYY
     I                                        5   60LDSKMM
     I                                        7   80LDSKDD
      *
     I            DS
     I                                        1   80ZCSKHZ
     I                                        1   40ZCSKYY
     I                                        5   60ZCSKMM
     I                                        7   80ZCSKDD
      *
     I            DS
     I                                        1   80ZDSKHZ
     I                                        1   40ZDSKYY
     I                                        5   60ZDSKMM
     I                                        7   80ZDSKDD
     I            DS
     I                                        1   80ZCUKHZ
     I                                        1   40ZCUKYY
     I                                        5   60ZCUKMM
     I                                        7   80ZCUKDD
     I            DS
