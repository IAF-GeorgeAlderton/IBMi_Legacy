     I                                        7   80ZDUKDD
     I            DS
     I                                        1   80ZDSTHZ
     I                                        1   40ZDSTYY
     I                                        5   60ZDSTMM
     I                                        7   80ZDSTDD
      *------*
      * PARM *
      *------*
     C           *ENTRY    PLIST
     C                     PARM           PUSER  10
     C                     PARM           PSIRE   4
     C                     PARM           PODR1   2
     C                     PARM           PODR2   2
     C                     PARM           PODR3   2
      *-----*
      * KEY *
      *-----*
     C           KEY1      KLIST
     C                     KFLD           ISIRE
     C                     KFLD           IODR1
     C                     KFLD           IODR2
     C                     KFLD           IODR3
      *
     C           KEY2      KLIST
     C                     KFLD           LBZAIS
     C                     KFLD           LBZAIK
     C                     KFLD           ISIRE
      *
     C           KEY3      KLIST
     C                     KFLD           LBZAIS
     C                     KFLD           LBZAIK
      *
     C                     MOVELPSIRE     ISIRE   40
     C                     MOVELPODR1     IODR1   20
     C                     MOVELPODR2     IODR2   20
     C                     MOVELPODR3     IODR3   20
      *
     C                     MOVE *BLANK    WUS     9
     C                     MOVE *BLANK    WUSME  15
     C                     CALL 'APLR00'
     C                     PARM           PUSER
     C                     PARM           WUSME
     C                     MOVELWUSME     WUS
      *
     C           KEY1      SETLLGDLPL111
      *
     C                     DO   *HIVAL
     C                     SETOF                     15
     C           KEY1      READEGDLPL11                  15
      *
     C           *IN15     IFEQ '0'
     C           LBSKJY    IFEQ 'D'
     C           LBSKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     Z-ADD0         SMAI    30
     C                     Z-ADD0         RMAI    30
      *
     C                     SETOF                     25
     C           KEY3      CHAINGDLPL201             25
      *
     C           *IN25     IFEQ '0'
     C           LCSKJY    IFEQ 'D'
     C           LCSKHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADDLCSTCK    RMAI
     C                     END
     C                     END
      *
     C                     SETOF                     25
     C           KEY3      CHAINGDLPL251             25
      *
     C           *IN25     IFEQ '0'
     C           LDSKJY    IFEQ 'D'
     C           LDSKHZ    ANDLE*DATE
     C                     ELSE
     C                     ADD  LDSTCK    RMAI
     C                     END
     C                     END
%0001 *
     C           LBPTCD    IFEQ 'W'
     C                     SETOF                     55
     C           KEY2      SETGTIZAPL03
     C                     DO   *HIVAL
     C           KEY2      REDPEIZAPL031                 55
      *
     C           *IN55     IFEQ '0'
     C           ZCSKJY    IFEQ 'D'
     C           ZCSKHZ    ANDLE*DATE
     C                     ELSE
     C           ZCUKHZ    IFLE *DATE
     C           ZCSTHZ    ANDGT*DATE
     C                     SETON                     55
      *
     C                     MOVE *BLANK    COM    50
     C                     Z-ADDZCKMMX    SMAI
     C           RMAI      IFLT SMAI
     C                     MOVELCOMT,1    COM
     C                     END
      *
     C           RMAI      IFGT SMAI
     C                     MOVELCOMT,2    COM
     C                     END
      *
     C           COM       IFNE *BLANK
     C           *IN05     IFEQ '0'
     C                     SETON                     05
     C                     TIME           WTIME   60
     C                     EXCPTHD
     C                     END
     C                     EXCPTDT
     C                     END
      *
     C                     END
     C                     END
     C                     END
     C  N55                ENDDO
     C                     END
      *
     C           LBPTCD    IFEQ 'R'
     C                     SETOF                     55
     C           KEY2      SETGTIZBPL03
     C                     DO   *HIVAL
     C           KEY2      REDPEIZBPL031                 55
      *
     C           *IN55     IFEQ '0'
     C           ZDSKJY    IFEQ 'D'
     C           ZDSKHZ    ANDLE*DATE
     C                     ELSE
     C           ZDUKHZ    IFLE *DATE
     C           ZDSTHZ    ANDGT*DATE
     C                     SETON                     55
      *
     C                     Z-ADDZDKMMX    SMAI
     C                     MOVE *BLANK    COM
     C           RMAI      IFLT SMAI
     C                     MOVELCOMT,1    COM
     C                     END
      *
     C           RMAI      IFGT SMAI
     C                     MOVELCOMT,2    COM
     C                     END
      *
     C           COM       IFNE *BLANK
     C           *IN05     IFEQ '0'
     C                     SETON                     05
     C                     EXCPTHD
     C                     END
     C                     EXCPTDT
     C                     END
      *
     C                     END
     C                     END
     C                     END
     C  N55                ENDDO
     C                     END
%0001 *
     C                     END
     C                     END
     C  N15                ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
     OQPRINT  E  102           HD
     O                                  131 '+---------+---------+'
      *
     O        E  1             HD
     O                                  131 '|         |         |'
      *
     O        E  1             HD
     O                                   12 'GDLR13-1 '
     O                                   89 'TIME'
     O                         WTIME     98 '  .  .  '
     O                                  121 '|         |'
     O                         WUS      130
     O                                  131 '|'
      *
     O        E  2             HD
     O                                   48 'MATERIAL NUMBER OF'
     O                                   60 'ROTATION KANBAN'
     O                                   78 'ABNORMAL LIST'
     O                                   89 'DATE'
     O                         UDATE Y   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O                                  131 '+---------+---------+'
      *
     O        E  2             HD
     O                                   62 'SETTING UP'
     O                                   75 'ROTATING'
      *
     O        E  2             HD
     O                                    9 'PARTS'
     O                                   17 'WIRE'
     O                                   46 'WIRE DIAMETER'
     O                                   60 'NUMBER'
     O                                   74 'NUMBER'
     O                                   86 'REMARK'
      *
     O        E  2             DT
     O                         LBPTCD     8
     O                         LBZAIS    28
     O                         LBZAIK    42 ' 0 .  '
     O                         SMAI      58 ' 0 '
     O                         RMAI      72 ' 0 '
     O                         COM      130
**
NO. OF KANBAN IS LESS THAN NO. OF SET-UP.
NO. OF KANBAN IS MORE THAN NO. OF SET-UP.
