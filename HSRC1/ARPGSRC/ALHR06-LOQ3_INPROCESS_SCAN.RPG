     C                     MOVELLOT,2     W4LOT
     C                     MOVELW4LOT1    P@LOT2    P
     C                     MOVELLOT,3     W4LOT
     C                     MOVELW4LOT1    P@LOT3    P
     C                     MOVELLOT,4     W4LOT
     C                     MOVELW4LOT1    P@LOT4    P
     C                     ENDIF
     C                     MOVELA1OQNO    P@OQNO
     C                     Z-ADDA1CHG#    P@CHG#
     C                     Z-ADDA1TSQ#    P@TSQ#
     C                     CLEARW@SHIN
     C           W2ZET1    IFEQ 'Z'
     C                     MOVELEASHN1    W@SHN1
     C           EASHN2    IFNE *BLANK
     C                     MOVEL'-'       W@SHNA
     C                     ENDIF
     C                     MOVELEASHN2    W@SHN2
     C           EASHN3    IFNE *BLANK
     C                     MOVEL'-'       W@SHNB
     C                     ENDIF
     C                     MOVELEASHN3    W@SHN3
     C                     MOVELW@SHIN    P@SHIN
     C                     MOVELEAZANM    P@ZANM
     C                     ELSE
     C                     MOVELA2BHB1    W@SHN1
     C           A2BHB2    IFNE *BLANK
     C                     MOVEL'-'       W@SHNA
     C                     ENDIF
     C                     MOVELA2BHB2    W@SHN2
     C           A2BHB3    IFNE *BLANK
     C                     MOVEL'-'       W@SHNB
     C                     ENDIF
     C                     MOVELA2BHB3    W@SHN3
     C                     MOVELW@SHIN    P@SHIN
     C                     MOVELA2ZANM    P@ZANM
     C                     ENDIF
      *
     C                     Z-ADDA1HOJI    P@HOJI
     C                     Z-ADDA1ONDO    P@ONDO
      *
     C                     MOVELW@BARC    P@BARC
     C                     MOVELW@BARC    P@BAR2
     C                     WRITEP@REC1
     C                     WRITEP@REC2
     C                     WRITEP@REC3
      *
     C                     CLOSEALHPR02
      *
      *
      * call program to print extra lot id tag for partials...
     C                     DO   4         IX      40
      *
     C           LOT,IX    IFNE *BLANKS
     C                     MOVELLOT,IX    ##LOTN  8
     C                     MOVELF1USRC    ##WKCD  6
     C                     MOVELA1ZANM    ##MATL 15
     C           W2ZET1    IFEQ 'Z'
     C                     MOVELEABHB     ##SHIN 12
     C                     ELSE
     C                     MOVELA2BHB     ##SHIN 12
     C                     ENDIF
     C                     MOVELW@BARC    ##SERL 12
      *
      * if first char of Lot# = 'R', then it's ASJ BPT so use ASJ LOT tag...
      *    else use default Lot Id Tag label name....
     C                     MOVEL##LOTN    FIRST   1
     C           FIRST     IFEQ 'R'
     C                     MOVEL'ASJLOT'  ##LBLN
     C                     ELSE
     C                     MOVELDFLBLN    ##LBLN
     C                     ENDIF
      *
     C                     CALL 'ALHR111'
     C                     PARM           ##WKCD
     C                     PARM           ##LOTN
     C                     PARM           ##MATL
     C                     PARM           ##SHIN
     C                     PARM           ##SERL
     C                     PARM           ##LBLN
     C                     PARM           ##OUTQ
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      * ADHPP01
      *----------------------------------------------------*
     CSR         #ADH01    BEGSR
      *
     C           KEYJ6     KLIST
     C                     KFLD           #KKSNK  10
     C                     KFLD           #KZETI  40
     C                     KFLD           #KATOJ  2
     C                     KFLD           #KATYP  1
     C                     KFLD           #KATOK  3
      *
     C           KEYJ6     SETGTADHPL071
     C           KEYJ6     REDPEADHPL071                 87
     C           *IN87     DOWEQ'0'
     C           J6SKJY    IFEQ 'D'
     C           J6SKHZ    ANDLEWSSDAT
     C                     ELSE
     C           J6STHZ    IFGT XDATE
     C                     MOVEL'1'       GETKAN  1
     C                     Z-ADDJ6HOJI    W@HOJI  20
     C                     Z-ADDJ6ONDO    W@ONDO  30
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C           KEYJ6     REDPEADHPL071                 87
     C                     ENDDO
      *
     CSR         EADH01    ENDSR
      *----------------------------------------------------*
      * MRHPP51
      *----------------------------------------------------*
     CSR         #MRH01    BEGSR
      *
     C           K#MRH5    KLIST
     C                     KFLD           W2THI1
     C                     KFLD           W2THI2
      *
     C           K#MRH5    SETGTMRHPL51
     C           K#MRH5    REDPEMRHPL51                  87
     C           *IN87     DOWEQ'0'
     C                     MOVEL'1'       GETKAN  1
     C                     Z-ADDSTKPTM    W@HOJI  20
     C                     Z-ADDSTTMTP    W@ONDO  30
     C                     LEAVE
     C           K#MRH5    REDPEMRHPL51                  87
     C                     ENDDO
      *
     CSR         EMRH01    ENDSR
