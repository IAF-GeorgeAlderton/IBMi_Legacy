     C                     MOVELERR,13    F2ERR
     C                     MOVELERR,13    F99ER1
     C                     MOVEL*BLANK    F99ER2
     C                     ENDIF
     C                     ENDIF
      *
      *
      * make sure this LOQ#/KANBAN hasn't already been scanned...
     C           F2OQNO    CAT  F2KAN     OQKAN  17
     C           OQKAN     LOKUPKAN                      10
     C           *IN10     IFEQ *ON
     C                     SETON                     996162
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,11    F99ER2
