     C                     CLEARFMT400
     C                     MOVEL'20'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
      *     4TH SCREEN CHECK
      **************************************************************************
     C           #CHK40    BEGSR
      *
     C                     MOVELF4LOT     W4LOT
     C                     SETOF                     9961
      *
     C                     DO
      *
     C           F4LOT     IFEQ *BLANK
     C           F4LOT1    ANDEQ*BLANK
     C           F4LOT2    ANDEQ*BLANK
     C           F4LOT3    ANDEQ*BLANK
     C                     SETON                     9961
     C                     MOVELERR,9     F4ERR
     C                     MOVELERR,9     F99ER1
     C                     MOVELERR,10    F99ER2
     C                     LEAVE
     C                     ENDIF
     C           F4LOT     IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
      * CHECK DIGIT
     C           #USER     IFNE 'TEST'
     C           #USER     ANDNE'I0777'
     C           #USER     ANDNE'I0778'
     C                     MOVELW4LOT1    PMAREA    P
     C                     MOVE '007'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C           F4ERR     IFEQ *BLANK
     C                     MOVELERR,9     F4ERR
     C                     MOVELERR,9     F99ER1
     C                     MOVELERR,6     F99ER2
     C                     ENDIF
     C                     ENDIF
     C           PMCHK     IFNE W4CHKD
     C                     SETON                     9961
     C           F4ERR     IFEQ *BLANK
     C                     MOVELERR,9     F4ERR
     C                     MOVELERR,9     F99ER1
     C                     MOVELERR,6     F99ER2
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C   99                LEAVE
      *
     C           F4LOT     IFEQ F4LOT1
     C           F4LOT     OREQ F4LOT2
     C           F4LOT     OREQ F4LOT3
     C                     SETON                     9961
     C           F4ERR     IFEQ *BLANK
     C                     MOVELERR,9     F4ERR
     C                     MOVELERR,9     F99ER1
     C                     MOVELERR,11    F99ER2
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C                     SELEC
     C           F4LOT1    WHEQ *BLANK
     C                     MOVELF4LOT     F4LOT1
     C                     MOVEL*BLANK    F4LOT
     C           F4LOT2    WHEQ *BLANK
     C                     MOVELF4LOT     F4LOT2
     C                     MOVEL*BLANK    F4LOT
     C           F4LOT3    WHEQ *BLANK
     C                     MOVELF4LOT     F4LOT3
     C                     MOVEL*BLANK    F4LOT
     C                     ENDSL
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     ENDIF
      *
     C                     ENDSR
      **************************************************************************
      *       WRITE A OK RECORD
      **************************************************************************
     C           #WRTOK    BEGSR
      *
     C                     CLEARALHPP011
     C                     CLEARALHPP111
      *
     C                     TIME           WSDT
     C                     Z-ADDWSSYYY    A1KOYY
     C                     Z-ADDWSSMMM    A1KOMM
     C                     Z-ADDWSSDDD    A1KODD
     C                     Z-ADDWSSTM6    A1KOTM
     C                     Z-ADDWSSYYY    A1SCYY
     C                     Z-ADDWSSMMM    A1SCMM
     C                     Z-ADDWSSDDD    A1SCDD
     C                     Z-ADDWSSTM6    A1SCTM
     C                     MOVEL#USER     A1USER
     C                     MOVEL#WSID     A1WSID
     C                     MOVEL#PGM      A1PGID
      *
     C                     MOVELF2OQNO    W@OQNO  2
     C                     Z-ADDF2CHG#    W@CHG#  20
      *
     C           K#PCT1    KLIST
     C                     KFLD           K@WD1   8
     C                     KFLD           K@WD2   8
     C                     MOVEL'ALHR031 'K@WD1     P
     C                     MOVEL*BLANK    K@WD2     P
     C           K#PCT1    CHAINAB#PPCT              97
     C           *IN97     IFEQ *ON
     C                     CLEARAB#PPCT1
     C                     MOVEL'ALHR031 'CTKEY1
     C                     MOVEL*BLANK    CTKEY2    P
     C                     Z-ADDWSSYM     CTNBR1
     C                     ENDIF
     C           WSSYM     IFNE CTNBR1
     C                     Z-ADDWSSYM     CTNBR1
     C                     Z-ADD*ZERO     CTNBR2
     C                     ENDIF
     C                     Z-ADDCTNBR1    W@YYMM
     C                     Z-ADDW@YYYY    A1TSQY
     C                     Z-ADDW@MMMM    A1TSQM
     C                     ADD  1         CTNBR2
     C                     Z-ADDCTNBR2    A1TSQ#
     C   97                WRITEAB#PPCT1
     C  N97                UPDATAB#PPCT1
      *
     C                     MOVELF1USRC    A1TMCD
     C                     MOVELF1SHFT    A1SHFT
      *
     C                     MOVELA2BHB1    A1SHN1
     C                     MOVELA2BHB2    A1SHN2
     C                     MOVELA2BHB3    A1SHN3
     C                     MOVELA2ZAIC    A1ZACD
      *
     C           A1ZACD    CHAINFCETL06              97
     C           *IN97     IFEQ *OFF
     C                     MOVELA2ZANM    A1ZANM
     C                     ENDIF
     C           W2ZET1    IFEQ 'Z'
     C                     MOVELEASHN1    A1SHN1
     C                     MOVELEASHN2    A1SHN2
     C                     MOVELEASHN3    A1SHN3
     C                     MOVELEAZAIC    A1ZACD
     C                     MOVELEAZANM    A1ZANM
     C                     ENDIF
      *
     C                     MOVELF2KAN     A1KAN
     C                     Z-ADDW@HOJI    A1HOJI
     C                     Z-ADDW@ONDO    A1ONDO
      *
     C                     MOVELW@KKND    A1KKND
     C                     MOVELW@OQNO    A1OQNO
     C                     Z-ADDW@CHG#    A1CHG#
      *
      * ------------------------------------------------------------
     C**         'ALHR032 'CHAINAB#PPCT              97
JW1  C           'ALHR022 'CHAINAB#PPCT              97
     C           *IN97     IFEQ *ON
     C                     CLEARAB#PPCT1
     C**                   MOVEL'ALHR032 'CTKEY1
JW1  C                     MOVEL'ALHR022 'CTKEY1
     C                     Z-ADDWSSYMD    CTNBR1
     C                     ENDIF
     C           WSSYMD    IFNE CTNBR1
     C                     Z-ADDWSSYMD    CTNBR1
