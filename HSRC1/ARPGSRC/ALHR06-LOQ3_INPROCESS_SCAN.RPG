     C                     MOVELLOT,Y     W4LOT
     C                     MOVELW4LOT1    ABLOT1
     C                     MOVELW4CHKD    ABLOT2
      *
     C                     MOVELW@BARC    ABSERL
      *
     C                     WRITEALHPP111
      *
     C                     ENDDO
      *
     C                     OPEN ALHPR02
      *
     C                     SORTALOT
     C                     DO   4
     C           LOT,1     IFEQ *BLANK
