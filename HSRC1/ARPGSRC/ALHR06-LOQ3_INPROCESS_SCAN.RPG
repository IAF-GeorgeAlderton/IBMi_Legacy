     C           #FMT20    BEGSR
      *
     C                     EXFMTFMT200
     C                     MOVEL*BLANK    F2ERR
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      @@ID
     C                     OTHER
     C                     EXSR #CHK20
     C           *IN99     IFEQ *OFF
     C                     MOVEL'40'      @@ID
     C           X         IFLT 6
     C                     ADD  1         X       10
     C                     ELSE
     C                     Z-ADD1         X
     C                     ENDIF
     C                     MOVELOQKAN     KAN,X
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
      *     2ND SCREEN CHECK
      **************************************************************************
     C           #CHK20    BEGSR
      *
     C                     MOVELF2KAN     KTYPE   3
      *
     C           KTYPE     IFEQ 'B01'
     C                     MOVELF2KAN     P1QR1 256
     C                     MOVEL*BLANKS   P1QR2 256
     C                     MOVEL*BLANKS   P9BAR  20
     C                     CALL 'UEXR13'
     C                     PARM           P1QR1
     C                     PARM           P1QR2
     C                     PARM           P9BAR
      *
     C                     MOVELP9BAR     F2KAN     P
     C                     MOVEL*BLANKS   P9BAR
     C                     ENDIF
      *
     C                     MOVELF2KAN     W2KAN
     C                     SETOF                     616263
     C                     SETOF                     99
      *
     C                     DO
      *
     C           W2KAN     IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,5     F99ER2
     C                     LEAVE
     C                     ENDIF
      * CHECK DIGIT
     C                     MOVELW2KAN     PMAREA    P
     C                     MOVE '014'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C           F2ERR     IFEQ *BLANK
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,6     F99ER2
     C                     ENDIF
     C                     ENDIF
     C           PMCHK     IFNE W2CHKD
     C                     SETON                     9961
     C           F2ERR     IFEQ *BLANK
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,6     F99ER2
     C                     ENDIF
     C                     ENDIF
     C   99                LEAVE
      *
     C           W2ZETI    CHAINFCEPL07              90
     C           *IN90     IFEQ *ON
     C           A2GSKD    ORNE *BLANK
     C           W2ZETI    CHAINMRHPL25              90
     C           *IN90     IFEQ *ON
     C           EAGSJY    ORNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,7     F99ER2
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C           *IN90     IFEQ *ON
     C           A2GSKD    ORNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,7     F99ER2
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVEL*BLANK    GETKAN  1
     C                     Z-ADD*ZERO     W@HOJI  20
     C                     Z-ADD*ZERO     W@ONDO  30
      *
     C           W2ZET1    IFEQ 'Z'
     C                     EXSR #MRH01                     POS
     C           GETKAN    IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,8     F99ER2
     C                     LEAVE
     C                     ENDIF
      *
     C                     ELSE
      * INTRA-PROC
     C           W2TYPE    IFGE '0'
