     C                     MOVELCTCHR1    DFLBLN  8
     C                     MOVELCTCHR2    ##OUTQ 10
     C                     ENDIF
      *
     C                     ENDSR
      *************************************************************************
      *     1ST SCREEN(TM-CODE ENTRY)
      **************************************************************************
     C           #FMT10    BEGSR
      *
     C                     EXFMTFMT100
     C                     MOVEL*BLANK    F1ERR
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      @@ID
     C                     OTHER
     C                     EXSR #CHK10
     C           *IN99     IFEQ *OFF
     C                     MOVEL'20'      @@ID
     C                     ENDIF
