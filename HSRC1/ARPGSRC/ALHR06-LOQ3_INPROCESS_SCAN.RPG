     C                     MOVELLOT,3     LOT,2
     C                     MOVELLOT,4     LOT,3
     C                     MOVEL*BLANK    LOT,4
     C                     ENDIF
     C           LOT,2     IFEQ *BLANK
     C                     MOVELLOT,3     LOT,2
     C                     MOVELLOT,4     LOT,3
     C                     MOVEL*BLANK    LOT,4
     C                     ENDIF
     C           LOT,3     IFEQ *BLANK
     C                     MOVELLOT,4     LOT,3
     C                     MOVEL*BLANK    LOT,4
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADDWSSMMM    P@MM
     C                     Z-ADDWSSDDD    P@DD
     C                     Z-ADDWSSYYY    P@YY
     C                     MOVELF1SHFT    P@SHFT
     C           LOT,1     IFNE *BLANK
