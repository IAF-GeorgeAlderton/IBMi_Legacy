     C                     MOVELW2ZETI    #KZETI
     C                     MOVELW2ATOJ    #KATOJ
     C                     MOVELW2ATYP    #KATYP
     C                     MOVELW2ATOK    #KATOK
      *
     C                     EXSR #ADH01                     HEAT TRT
     C           GETKAN    IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,8     F99ER2
     C                     LEAVE
     C                     ENDIF
      * A-PICS
     C                     ELSE
     C           K#AAH     KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C           K#AAH     SETGTAAHTL06
     C                     DO   *HIVAL
     C           K#AAH     REDPEAAHTL06                  90
     C           *IN90     IFEQ *ON
     C                     SETON                     9961
     C                     MOVELERR,4     F2ERR
     C                     MOVELERR,4     F99ER1
     C                     MOVELERR,8     F99ER2
     C                     LEAVE
     C                     ENDIF
     C           L6SKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
     C           WSSDAT    IFGE L6UKHZ
     C           WSSDAT    ANDLTL6STHZ
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C                     LEAVE
     C                     ENDDO
      *
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDDO
      * OQ#
     C           F2OQNO    IFEQ '31'
     C                     ELSE
     C                     SETON                     9962
     C           F2ERR     IFEQ *BLANK
     C                     MOVELERR,12    F2ERR
     C                     MOVELERR,12    F99ER1
     C                     MOVEL*BLANK    F99ER2
     C                     ENDIF
     C                     ENDIF
      * CHARGE#
     C           F2CHG#    IFEQ *ZERO
     C                     SETON                     9963
