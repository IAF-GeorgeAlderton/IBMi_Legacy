     C                     ENDIF
     C                     Z-ADDCTNBR1    W@BAR1
     C                     ADD  1         CTNBR2
     C                     Z-ADDCTNBR2    W@BAR2
     C   97                WRITEAB#PPCT1
     C  N97                UPDATAB#PPCT1
      *
      * CHECK DIGIT
     C                     MOVELW@BAR@    PMAREA    P
     C                     MOVE '011'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C                     MOVELPMCHK     W@BAR3
      *
     C                     MOVELW@BARC    A1SERL
      *
      * ------------------------------------------------------------
      *
     C                     WRITEALHPP011
      *
     C                     Z-ADD*ZERO     Y       20
     C                     DO   *HIVAL
      *
     C                     ADD  1         Y
     C           Y         IFGT 4
     C                     LEAVE
     C                     ENDIF
     C           LOT,Y     IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
      *
     C                     CLEARALHPP111
      *
     C                     Z-ADDA1KOYY    ABKOYY
