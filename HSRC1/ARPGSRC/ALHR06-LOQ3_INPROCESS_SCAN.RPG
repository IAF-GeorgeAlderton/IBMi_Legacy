      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'10'      #FMT10
     C           @@ID      CASEQ'20'      #FMT20
     C           @@ID      CASEQ'40'      #FMT40
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      **************************************************************************
      *         INITIALIZE
      **************************************************************************
     C           *INZSR    BEGSR
      * FOR KANBAN CHECK DEGIT
     C           P#BRC     PLIST
     C                     PARM           PMAREA100
     C                     PARM           PMBYTE  3
     C                     PARM           PMCHK   1
     C                     PARM           PMRTCD  1
      *
     C                     TIME           WSDT
      *
      *----------------------------*
      * GET DAY 1 YEAR AGO        *
      *----------------------------*
     C                     MOVE WSSDAT    PDATE
     C                     MOVE '-'       PPORM
     C                     MOVE '0030'    PDAYS
     C                     CALL 'DATR12'
     C                     PARM           PDATE   8
     C                     PARM           PPORM   1        + OR -
     C                     PARM           PDAYS   4
     C                     PARM           PRDAT   8
     C                     PARM           PRTN    1
     C                     MOVE PRDAT     XDATE   80
      *
     C                     CLEARFMT100
     C                     CLEARFMT200
     C                     CLEARFMT400
      *
     C                     MOVEL'10'      @@ID    2
     C                     MOVEL'P'       W@KKND  1
      * DUMMY READ
     C                     READ ALHPP01                  98
     C                     READ ALHPP11                  98
      *
      * get label name and outq name for lot id tags...
     C                     MOVEL'LOQ3'    K@WD1     P
     C                     MOVEL'LOTTAG'  K@WD2     P
     C           K#PCT1    CHAINAB#PPCT             N72
     C           *IN72     IFEQ *OFF
