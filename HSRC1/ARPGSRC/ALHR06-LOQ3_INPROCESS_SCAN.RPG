      * SHIFT CODE CHECK
     C           F1SHFT    IFEQ '1'
     C           F1SHFT    OREQ '2'
     C           F1SHFT    OREQ '3'
     C                     ELSE
     C                     SETON                     6299
     C           F1ERR     IFEQ *BLANK
     C                     MOVELERR,2     F1ERR
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *************************************************************************
      *     2ND SCREEN(APICS KANBAN)
