     H            Y.
      ** AJSR5E *******************************************************
      * INQUIRY OF DACRODIZING PLATING DISCHARGE RESULT DATA. (MACHINE NO)*
      * PROGRAM ID.  : AJSR5E  <RPG>                                  *
      * CREATE DATE. : 2015/07/07
      * AUTHOR.      : KIRI
      ******************************************************* AJSR5E **
      *  DACRODIZING PLATING DISCHARGE RESULTS FILES.  *
     FAJSPL61 IF  E           K        DISK
      *
      *  WORKER CD MASTER FILES.           *
     FAJSPLCD IF  E           K        DISK
      *
     FAJSWP5E O   F    1024            DISK
      *================================================================
     I            DS
     I                                        1  120SHIZT
     I                                        1   80SHIZ
     I                                        1   40SYY
     I                                        5   60SMM
     I                                        7   80SDD
     I                                        9  120STIM
     I                                        9  100STIMH
     I                                       11  120STIMM
     I            DS
     I                                        1  120EHIZT
     I                                        1   80EHIZ
     I                                        1   40EYY
     I                                        5   60EMM
     I                                        7   80EDD
     I                                        9  120ETIM
     I                                        9  100ETIMH
     I                                       11  120ETIMM
     I            DS
     I                                        1  14 HIN
     I                                        1   5 J6HIN1
     I                                        6   6 HINA
     I                                        7  11 J6HIN2
     I                                       12  12 HINB
     I                                       13  14 J6HIN3
     I            DS
     I                                        1   80J6SKHZ
     I                                        1   40J6SKYY
     I                                        5   60J6SKMM
     I                                        7   80J6SKDD
     I            DS
     I                                        1  120J6WKHT
     I                                        1   80J6WKHZ
     I                                        1   40J6WINY
     I                                        5   60J6WINM
     I                                        7   80J6WIND
     I                                        9  120J6WKTM
     I                                        9  100J6WINJ
     I                                       11  120J6WINF
     I            DS
     I                                        1  120J6KEHT
     I                                        1   80J6KEHZ
     I                                        1   40J6KEIY
     I                                        5   60J6KEIM
     I                                        7   80J6KEID
     I                                        9  120J6KETM
     I                                        9  100J6KEIJ
     I                                       11  120J6KEIF
      *================================================================
     C           *ENTRY    PLIST
     C                     PARM           P@MACH  2        機番
     C                     PARM           P@SHZ   80       開始日付
     C                     PARM           P@STM   40           時刻
     C                     PARM           P@EHZ   80       終了日付
     C                     PARM           P@ETM   40           時刻
     C*
     C                     EXSR #MAIN
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      *===============================================================
     C           #MAIN     BEGSR
     C                     MOVEA*ALL'0'   *IN
      *
     C                     MOVELP@MACH    MACH    2
     C                     Z-ADDP@SHZ     SHIZ
     C                     Z-ADDP@STM     STIM
     C                     Z-ADDP@EHZ     EHIZ
     C                     Z-ADDP@ETM     ETIM
      *
     C           KEY1      KLIST
     C                     KFLD           MACH
     C                     KFLD           SYY
     C                     KFLD           SMM
     C                     KFLD           SDD
     C                     KFLD           STIMH
     C                     KFLD           STIMM
      *
      *
     C           KEY1      SETLLAJSPL61
      *-------------------------
     C                     DO   *HIVAL
     C           MACH      READEAJSPL61                  90
     C   90                LEAVE
      *
     C           J6SKJY    IFEQ 'D'
     C           J6SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C*
     C           J6KEHT    IFGT EHIZT
     C                     LEAVE
     C                     ENDIF
     C*
     C                     MOVEL'-'       HINA
     C                     MOVEL'-'       HINB
     C           J6HIN3    IFEQ *BLANK
     C                     MOVEL' '       HINB
     C           J6HIN2    IFEQ *BLANK
     C                     MOVEL' '       HINA
     C                     ENDIF
     C                     ENDIF
     C*
     C                     MOVE *BLANK    #TOCM  20
     C           J6TOCD    CHAINAJSPLCD1             91
     C           JASKJY    IFEQ ' '
     C           *IN91     ANDEQ*OFF
     C                     MOVE JAWKNM    #TOCM
     C                     ENDIF
      *
     C  N10                EXCPT$HED
     C                     EXCPT$DATA
     C                     SETON                     10
     C                     ENDDO
      *-------------------------
      *
     C                     ENDSR
      *===============================================================
     OAJSWP5E E                $HED
     O                                      'MACHINE NO,'
     O                                      'DISCHARGE DATE FROM,'
     O                                      'DISCHARGE TIME FROM,'
     O                                      'DISCHARGE DATE TO,'
     O                                      'DISCHARGE TIME TO,'
      *
     O                                      'PART NO,'
     O                                      'MGT INST,'
     O                                      'ID NUMBER,'
     O                                      'SHIP ORDER NO,'
     O                                      'PAGE NO 1,2,3,4,'
     O                                      '2 PROCESSING,'
     O                                      'BESIDES OBJECT,'
     O                                      'OUTGOING EFFECTIVE,'
     O                                      'BAR CODE BOX TYPE,'
      *
     O                                      'PLATING COEFFICIENT,'
     O                                      'COLOR,'
     O                                      'ACCOM QTY,'
     O                                      'M/F BOX TYPE,'
     O                                      'COMPLETION UNIT WEIGHT,'
     O                                      'ADMIT DATE,'
     O                                      'ADMIT TIME,'
     O                                      'BEFORE ADMIT WEIGHT,'
      *
     O                                      'PLATING MCH NO,'
     O                                      'WEIGHING DATE,'
     O                                      'WEIGHING TIME,'
     O                                      'WEIGHING WEIGHT,'
     O                                      'MATERIAL BARCODE 1,'
     O                                      'MATERIAL BARCODE 2,'
     O                                      'UNLOADING WORKER CD,'
     O                                      'UNLOADING WORKER NAME'
      *************************
     O        E                $DATA
     O                         MACH
     O                                      ','
     O                         SHIZ
     O                                      ','
     O                         STIM
     O                                      ','
     O                         EHIZ
     O                                      ','
     O                         ETIM
     O                                      ','
      *
     O                         HIN
     O                                      ','
     O                         J6KANK
     O                                      ','
     O                         J6ZETI
     O                                      ','
     O                         J6THAI
     O                                      ','
     O                         J6PAG1
     O                                      ','
     O                         J6PAG2
     O                                      ','
     O                         J6PAG3
     O                                      ','
     O                         J6PAG4
     O                                      ','
     O                         J62JKA
     O                                      ','
     O                         J6TASY
     O                                      ','
     O                         J6SYKO
     O                                      ','
     O                         J6HKBR
     O                                      ','
      *
     O                         J6MKSU       '0 . '
     O                                      ','
     O                         J6IROK
     O                                      ','
     O                         J6SYUY
     O                                      ','
     O                         J6HKFA
     O                                      ','
     O                         J6TANJ
     O                                      ','
     O                         J6WKHZ
     O                                      ','
     O                         J6WKTM
     O                                      ','
     O                         J6WMJY
     O                                      ','
     O                         J6MKKB
     O                                      ','
     O                         J6KEHZ
     O                                      ','
     O                         J6KETM       '  :  '
     O                                      ','
     O                         J6WAIT       ' 0 .  '
     O                                      ','
     O                         J6ZBR1
