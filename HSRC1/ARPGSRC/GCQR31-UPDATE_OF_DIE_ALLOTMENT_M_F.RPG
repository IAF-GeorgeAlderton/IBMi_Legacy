     C*
     C*  PRESS ROLL-UP
     C*
     C           *IN,81    IFEQ '1'
     C                     MOVE *BLANK    D3OP
     C                     Z-ADD0         D3NO
     C           SEQ       IFGE 4
     C                     MOVELMSG,21    ERR
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP30
     C                     END
     C                     ADD  1         SEQ
     C           SEQ       SUB  1         SQ      50
     C                     MULT 26        SQ
     C                     ADD  1         SQ
     C           XNO,SQ    IFEQ 0
     C                     MOVELMSG,21    ERR
     C                     MOVEA'1'       *IN,99
     C                     SUB  1         SEQ
     C                     GOTO STP30
     C                     END
     C                     Z-ADD*ZERO     NO
     C                     MOVE *BLANK    KOT
     C                     Z-ADD*ZERO     KSE
     C                     MOVE *BLANK    KAT
     C                     MOVE *BLANK    NAM
     C                     MOVE *BLANK    KNM
     C                     Z-ADD*ZERO     SU
     C                     MOVE *BLANK    KUB
     C                     MOVE *BLANK    KUN
     C           SQ        ADD  25        SQ25    50
     C           SQ        DO   SQ25      I
     C           I         SUB  SQ        J
     C                     ADD  1         J
     C                     Z-ADDXNO,I     NO,J
     C                     MOVELXKOT,I    KOT,J
     C                     Z-ADDXKSE,I    KSE,J
     C                     MOVELXKAT,I    KAT,J
     C                     MOVELXNAM,I    NAM,J
     C                     MOVELXKNM,I    KNM,J
     C                     Z-ADDXSU,I     SU,J
     C                     MOVELXKUB,I    KUB,J
     C                     MOVELXKUN,I    KUN,J
     C                     END
