     C                     MOVELXKOT,I    KOT,I
     C                     Z-ADDXKSE,I    KSE,I
     C                     MOVELXKAT,I    KAT,I
     C                     MOVELXNAM,I    NAM,I
     C                     MOVELXKNM,I    KNM,I
