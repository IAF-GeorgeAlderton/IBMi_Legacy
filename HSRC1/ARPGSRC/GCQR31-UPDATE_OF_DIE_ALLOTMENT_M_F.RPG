     C                     MOVEA'1'       *IN,02
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP20
     C                     END
      *
     C                     DO   2         I
     C                     Z-ADD1         J       50
     C           D2KS,I    LOKUPDEC,J                    30
     C   30                END
     C           *IN,30    IFEQ '0'
     C                     MOVELMSG,25    ERR
     C                     MOVEA'1'       *IN,02
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP20
     C                     END
      *
     C                     MOVE *BLANK    D2KANM
     C                     MOVELD2KATA    WNEWK  15
     C           D2KATA    IFEQ *BLANK
     C                     MOVELMSG,13    ERR
     C                     MOVEA'1'       *IN,03
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP20
     C                     END
      *
     C                     MOVEA'1'       *IN,30
      *-- MSK 99.02.05 (ADD)
     C           D2KSEI    IFNE '99'
      *--
     C                     DO   7         I
     C           I         IFEQ 3
     C           D2KA,I    IFNE '-'
     C                     MOVEA'0'       *IN,30
     C                     END
     C                     ELSE
     C                     Z-ADD1         J
     C           D2KA,I    LOKUPDEC,J                    30
     C                     END
     C   30                END
     C           *IN,30    IFEQ '1'
     C           8         DO   15        I
     C           D2KA,I    IFNE *BLANK
     C                     MOVEA'0'       *IN,30
     C                     END
     C   30                END
     C                     END
      *-- MSK 99.02.05 (ADD)
     C                     END
      *--
      *
     C*
     C*  30 ON  == NEW DIE NO
     C*  30 OFF == OLD DIE NO
     C*
     C                     MOVE *BLANK    D2NEWK
      *-- MSK 99.02.05 (ADD)
     C           D2KSEI    IFNE '99'
      *--
     C           *IN,30    IFEQ '1'
      *
     C           KEYA      CHAINFCQPL311             30
     C           *IN,30    IFEQ '0'
     C           Q4SKJY    ANDEQ'D'
     C           Q4SKHZ    ANDLE*DATE
