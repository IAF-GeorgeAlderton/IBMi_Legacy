     C           D2KA01    CHAINFCQPL211             30
     C           *IN,30    IFEQ '0'
     C           O9SKJY    ANDEQ'D'
     C           O9SKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,30
     C                     END
     C           *IN,30    IFEQ '1'
     C                     MOVELMSG,15    ERR
     C                     MOVEA'1'       *IN,03
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP20
     C                     ELSE
     C                     MOVELO9KANM    D2KANM
     C                     END
      *
     C                     ELSE
      *
     C                     MOVEA'0'       *IN,60
     C           D2KATA    CHAINFCQPL321             30
     C           *IN,30    IFEQ '0'
     C           Q4SKJY    ANDEQ'D'
     C           Q4SKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,30
     C                     END
     C           *IN,30    IFEQ '1'
     C                     MOVELMSG,24    ERR
     C                     MOVEA'1'       *IN,03
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP20
     C                     END
      *
     C                     MOVELQ4KAT1    D2NEW1
     C                     MOVEL'-'       D2NEW2
     C                     MOVELQ4KAT2    D2NEW3
     C                     MOVELD2NEWK    WNEWK
     C           Q4KAT1    CHAINFCQPL211             30
     C           *IN,30    IFEQ '0'
     C           O9SKJY    ANDEQ'D'
     C           O9SKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,30
     C                     END
     C           *IN,30    IFEQ '1'
     C                     MOVELMSG,15    ERR
     C                     MOVEA'1'       *IN,03
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP20
     C                     ELSE
     C                     MOVELO9KANM    D2KANM
     C                     END
      *
     C                     END
      *-- MSK 99.02.05 (ADD)
