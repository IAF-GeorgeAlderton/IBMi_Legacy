     C           A6GSKD    ANDEQ'D'
     C           A6GSHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,30
     C                     END
     C           *IN,30    IFEQ '1'
     C                     MOVELMSG,11    ERR
     C                     MOVEA'1'       *IN,01
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP20
     C                     END
      *
     C           D2KSEI    IFEQ *BLANK
