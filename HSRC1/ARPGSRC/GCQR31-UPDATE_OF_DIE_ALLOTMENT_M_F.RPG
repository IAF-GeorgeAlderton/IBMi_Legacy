     C                     MOVELSHN2      $$SHN2
     C                     MOVELSHN3      $$SHN3
     C                     MOVELDFKOTI    $$KOTI
     C                     Z-ADDDFKSEI    $$KSEI
      *
     C                     MOVEL*BLANK    W@KSEI  1
     C                     MOVE ' '       $$KTBN
     C           $$KSEI    IFNE 99
     C                     MOVEL$$KSEI    W@KSEI  1
     C           W@KSEI    IFEQ '8'
     C           W@KSEI    OREQ '9'
     C                     MOVE '1'       $$KTBN
     C                     END
     C                     ENDIF
      *
     C                     MOVELDFKATA    $$KATA
     C                     Z-ADDDFKOSU    $$KOSU
     C                     MOVELDFKUBN    $$KUBN
     C           $$KUBN    IFEQ '0'
     C                     MOVE *BLANK    $$KUBN
