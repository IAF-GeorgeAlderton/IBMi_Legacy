     C*  EXFMT <SCREEN 3>                                            *
     C****************************************************************
     C           STP30     TAG
     C                     EXSR #WK30
     C                     EXSR #ND1
     C                     EXFMTGCQPW313
      *
     C                     MOVEA'00000'   *IN,01
     C                     MOVEA'00000'   *IN,06
     C                     MOVEA'00000'   *IN,11
     C                     MOVEA'00000'   *IN,16
     C                     MOVEA'00000'   *IN,21
     C                     MOVEA'00000'   *IN,26
     C                     MOVEA'00000'   *IN,31
     C                     MOVEA'00000'   *IN,36
     C                     MOVEA'0'       *IN,60
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    ERR
     C           *INKC     IFEQ '1'
     C           OP        CABEQ'2'       STP70
     C                     GOTO STP00
