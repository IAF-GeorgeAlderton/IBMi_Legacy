     C                     MOVELCMT,3     D2KANM
     C                     END
      *--
      *
     C           D2KOSU    IFEQ 0
     C                     Z-ADD1         D2KOSU
     C                     END
      *
     C           D2KUBN    IFNE *BLANK
     C           D2KUBN    ANDNE'0'
     C                     MOVELMSG,16    ERR
