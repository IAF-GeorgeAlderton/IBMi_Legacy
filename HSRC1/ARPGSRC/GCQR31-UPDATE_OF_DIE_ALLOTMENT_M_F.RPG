     C                     MOVELOP        $$KSKB
     C  N30                UPDATGCQPL331
     C   30                WRITEGCQPL331
     C                     MOVEA'0'       *IN,30
     C                     END
     C                     END
     C  N30                END
     C                     GOTO STPUPD
     C                     END
