     C                     Z-ADD0         I
     C           KEY1      SETLLGCQPL311
     C                     DO   *HIVAL
     C           KEY1      READEGCQPL311                 30
     C           *IN,30    IFEQ '0'
     C           DFSKJY    IFEQ 'D'
     C           DFSKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     MOVEA'0'       *IN,40
     C           DFKATA    SETLLGCQTL311
     C                     DO   *HIVAL
     C           DFKATA    READEGCQTL311                 30
     C           *IN,30    IFEQ '0'
     C           @@SKJY    IFEQ 'D'
     C           @@SKHZ    ANDLE*DATE
     C                     ELSE
     C           @@SHIN    IFNE SHN
     C                     MOVEA'1'       *IN,30
     C                     MOVEA'1'       *IN,40
     C                     END
     C                     END
     C                     END
     C  N30                END
      *
     C           *IN,40    IFEQ '0'
     C                     ADD  1         I
     C           I         IFLT 51
     C                     SETOF                     70
     C                     MOVELDFKATA    BAN$$   9
     C           BAN$$     LOKUPWBAN                     70
     C           *IN70     IFEQ '0'
     C           KEYDLT    SETLLGCQTL131
     C                     MOVE *BLANK    SW      1
     C                     MOVE *BLANK    #BAN
     C                     DO   *HIVAL
     C           KEYDLT    READEGCQTL131                 51
     C           *IN,51    IFEQ '0'
     C           T6SKJY    IFEQ 'D'
     C           T6SKHZ    ANDLE*DATE
     C                     ELSE
     C           KJ        IFEQ T6TKR1
     C                     MOVE *BLANK    #BAN
     C                     MOVEL'*'       SW
     C                     MOVEA'1'       *IN,51
     C                     MOVELT6TKR1    #BAN1
     C                     MOVELT6TKR2    #BAN2
     C                     MOVELT6TKR3    #BAN3
     C                     MOVELT6TKR4    #BAN4
     C                     MOVELT6TKR5    #BAN5
     C                     END
     C                     END
     C                     END
     C  N51                END
      *
     C*****      SW        IFEQ '*'
     C           #BAN2     IFNE *BLANK
     C                     MOVEL'-'       #BANA
     C                     END
      *
     C           #BAN3     IFNE *BLANK
     C                     MOVEL'-'       #BANB
     C                     END
      *
     C           #BAN4     IFNE *BLANK
     C                     MOVEL'-'       #BANC
     C                     END
      *
     C           #BAN5     IFNE *BLANK
     C                     MOVEL'-'       #BAND
     C                     END
      *
     C           SW        IFEQ '*'
     C                     MOVEL#BAN      @TKRO
     C                     ELSE
     C                     MOVE *BLANK    @TKRO
     C                     END
     C                     MOVELDFKATA    @KATA
     C                     MOVELDFKATA    WBAN,I
     C                     MOVE @KT       WKT,I
     C******               END
     C                     END
     C                     END
     C                     END
     C                     MOVEA'0'       *IN,30
      *
     C                     END
     C                     END
     C  N30                END
      *
     C           I         CABEQ0         STP50
     C                     SORTAWKT
     C                     Z-ADD1         I
     C                     Z-ADD0         A       20
     C           1         DO   51        I
     C                     MOVELWKT,I     @KT
     C           @KATA     IFNE *BLANK
