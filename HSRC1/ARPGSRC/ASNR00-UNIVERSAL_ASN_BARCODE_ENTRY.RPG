     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     MOVE '9'       $ERR
     C                     LEAVE
      * F12: BACK
     C           *INKL     WHEQ *ON
     C                     LEAVE
      * F5: PROCESS
     C           *INKE     WHEQ *ON
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    MSG
     C                     EXSR #SCUP
     C                     LEAVE
