      *********************************************************
      * MAIN ROUTINE
      *********************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C           W@ID      IFEQ '99'
     C                     LEAVE
     C                     ENDIF
      *
     C           W@ID      CASEQ'01'      #SCRN1           BARCODE SCAN
     C           W@ID      CASEQ'02'      #SCRN2           MANUAL ENTRY1
     C           W@ID      CASEQ'03'      #SCRN3           MANUAL ENTRY2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *---------------------------------------------------
      * BARCODE ENTRY
      *---------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C           *IN98     IFEQ *OFF
     C                     MOVE CMD,1     D@CMD
     C                     ELSE
     C                     MOVE CMD,4     D@CMD
     C                     ENDIF
      *
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
      * F1: END
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     MOVE '9'       $ERR
      * F9: MANUAL
     C           *INKI     WHEQ *ON
      * F11: CANCEL
     C**         *INKK     WHEQ *ON
     C**                   CALL 'AC#C0Q'
      * F5 OR F7 OR ENTER
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C           @@OK      ANDEQ'1'
     C           *IN98     OREQ *ON
     C           *IN99     ANDEQ*OFF
     C           *INKG     ANDEQ*ON
     C           @@OK      ANDEQ'1'
      *
     C                     EXSR #HNDCK
     C           *IN99     IFEQ *ON
     C           *IN98     ANDEQ*OFF
     C                     EXSR #SCRN6
     C           W@ID      IFEQ '99'
     C                     MOVE *ON       *INLR
     C                     RETRN
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C           *IN99     OREQ *ON
     C           *INKG     ANDEQ*ON
     C                     EXSR #UPD
      *
     C                     MOVE '99'      W@ID
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *---------------------------------------------------
      * CHECK SCREEN1
      *---------------------------------------------------
     C           #CHK1     BEGSR
     C                     SETOF                     029903
     C                     MOVE *BLANK    MSG
     C           D@BAR     IFNE *BLANK
     C           D@BAR     CHAINAB#PL76              90
     C           *IN90     IFEQ *ON
     C                     MOVE *ON       *IN02
     C                     MOVE *ON       *IN99
     C                     MOVE ERR,1     MSG
     C                     ELSE
      * CHECK CONSOLIDATED PACK SLIP
     C           PUBINN    IFEQ 99
     C           PUSKJY    OREQ 'C'
     C                     MOVE *ON       *IN02
     C                     MOVE *ON       *IN99
     C                     MOVE ERR,18    MSG
     C                     ENDIF
      * CHECK DELETED PACK SLIP
     C           PUSKJY    IFEQ 'D'
     C                     MOVE *ON       *IN02
     C                     MOVE *ON       *IN99
     C                     MOVE ERR,19    MSG
     C                     ENDIF
      *
     C                     MOVE *BLANK    SRL
     C                     Z-ADD*ZERO     Z       30
      *
     C                     Z-ADD*ZERO     W@RRN   40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         W@RRN
     C           W@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C                     ADD  1         Z
     C                     MOVE S@BARC    SRL,Z
     C           D@BAR     IFEQ S@BARC
     C                     MOVE *ON       *IN02
     C  N99                MOVE ERR,2     MSG
     C                     MOVE *ON       *IN99
     C                     ELSE
     C           PUNONY    IFNE H@NONY
     C           PUNKOJ    ORNE H@NKOJ
     C           @NOHZ     ORNE H@NOHZ
     C           PUBINN    ORNE H@NOBN
     C           S@BARC    IFNE *BLANK
     C                     MOVE *ON       *IN02
     C  N99                MOVE ERR,3     MSG
     C                     MOVE *ON       *IN99
     C           S@BARC    CHAINAB#PL76              95
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
      *
     C           STM       IFEQ *BLANK
     C                     SETON                     0399
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C                     ADD  1         @@RRN
     C                     MOVE '1'       @@OK    1
     C           @@RRN     CHAINSFL01                90
     C                     MOVE D@BAR     S@BARC
     C                     MOVE PUNONY    H@NONY
     C                     MOVE PUNKOJ    H@NKOJ
     C                     Z-ADD@NOHZ     H@NOHZ
     C                     Z-ADDPUBINN    H@NOBN
     C                     MOVE PUNONY    PSIRE
     C                     MOVE PUNKOJ    PSIRK
     C                     MOVE @NOHZ     PNOHZ
     C                     MOVE PUBINN    PNOBN
     C                     Z-ADDPUBINN    @@BIN   20
     C                     ADD  1         Z
     C                     MOVE S@BARC    SRL,Z
     C           *IN90     IFEQ *ON
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ELSE
     C                     UPDATSFL01
     C                     ENDIF
     C                     MOVE *BLANK    D@BAR
      *
     C           PUNUKE    IFEQ *BLANK
     C           KEY1      SETLLAB#PL111
     C                     ELSE
     C           KEY3      SETLLAB#PL131
     C                     ENDIF
      *
     C           *IN10     DOUEQ*ON
     C           PUNUKE    IFEQ *BLANK
     C           KEY1      READEAB#PL111                 10
     C                     ELSE
     C           KEY3      READEAB#PL131                 10
     C                     ENDIF
      *
     C           *IN10     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
      *
     C           PUODRN    IFNE *BLANK
     C           PUODRN    ANDNEBAODRN
     C                     ITER
     C                     ENDIF
      *
     C           PUBINN    IFNE *ZERO
     C           PUBINN    ANDNEBANOBN
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE BANOBN    W@BIN
     C                     MOVELBAODRN    W@ODRN
     C           K#2B      CHAINAB#PP2B              90
     C           *IN90     IFEQ *OFF
     C                     MOVELABTRLR    PTRCK  10
     C                     MOVELABSCAC    PSCAC
     C                     ELSE
     C                     MOVE ERR,17    MSG
     C                     SETON                     020399
     C                     ENDIF
      *
      *
     C           K#2AA     SETLLAB#PL2A
     C           *IN90     DOUEQ*ON
     C           K#2AA     READEAB#PL2A                  90
     C           *IN90     IFEQ *OFF
     C           ACSHTM    IFNE *ZERO
     C           ACSHTM    ANDNEBANOTM
     C           BANOTM    IFEQ *ZERO
     C                     Z-ADDACSHTM    BANOTM
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      *
     C           ACSHTM    IFEQ *ZERO
     C           ACDLTM    ANDNE*ZERO
     C           ACDLTM    ANDNEBANOTM
     C           BANOTM    IFEQ *ZERO
     C                     Z-ADDACDLTM    BANOTM
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C  N99      ERR,16    CAT  BAMHIN:1  MSG
     C                     SETON                     98
     C           K#2AA     SETGTAB#PL2A
     C           K#2AB     REDPEAB#PL2A                  90
     C                     ENDIF
     C           *IN90     IFEQ *OFF
     C           PSCAC     IFEQ *BLANK
     C                     MOVELACSCAC    PSCAC   4
     C                     ENDIF
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVE *BLANK    D@ORDR
      *
     C                     ENDSR
      *---------------------------------------------------
      * HONDA CHECK
      *---------------------------------------------------
     C           #HNDCK    BEGSR
     C                     MOVE *ON       *IN54
     C                     CLEARCTL03
     C                     MOVE *OFF      *IN54
     C                     Z-ADD*ZERO     RRN3    40
     C                     SETOF                     9998
      *
     C           PUNUKE    IFEQ *BLANK
     C           KEY1      SETLLAB#PL111
     C                     ELSE
     C           KEY3      SETLLAB#PL131
     C                     ENDIF
      *
     C           *IN10     DOUEQ*ON
     C           PUNUKE    IFEQ *BLANK
     C           KEY1      READEAB#PL111                 10
     C                     ELSE
     C           KEY3      READEAB#PL131                 10
     C                     ENDIF
      *
     C           *IN10     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
      *
     C           @@ODRN    IFNE *BLANK
     C           @@ODRN    ANDNEBAODRN
     C                     ITER
     C                     ENDIF
      *
     C           PUBINN    IFNE *ZERO
     C           PUBINN    ANDNEBANOBN
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE BANOBN    W@BIN
     C                     MOVELBAODRN    W@ODRN
      *
     C           K#2B      CHAINAB#PP2B              90
     C           *IN90     IFEQ *OFF
     C                     MOVELABTRLR    PTRCK  10
     C                     MOVELABSCAC    PSCAC
     C                     ENDIF
      *
     C           K#2AA     SETLLAB#PL2A
     C           *IN90     DOUEQ*ON
     C           K#2AA     READEAB#PL2A                  90
     C           *IN90     IFEQ *OFF
     C           ACSHTM    IFNE *ZERO
     C           ACSHTM    ANDNEBANOTM
     C           BANOTM    IFEQ *ZERO
     C                     Z-ADDACSHTM    BANOTM
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      *
     C           ACSHTM    IFEQ *ZERO
     C           ACDLTM    ANDNE*ZERO
     C           ACDLTM    ANDNEBANOTM
     C           BANOTM    IFEQ *ZERO
     C                     Z-ADDACDLTM    BANOTM
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *OFF
     C           PSCAC     ANDEQ*BLANK
     C                     MOVELACSCAC    PSCAC
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     @@QTY  110
     C                     MOVE BANONY    W@NONY
     C                     MOVE BANONY    ZNONY
      *
     C           K#70      SETLLAB#PL70
     C           *IN90     DOUEQ*ON
     C           K#70      READEAB#PL70                  90
     C           *IN90     IFEQ *OFF
     C           EKSKJY    ANDEQ*BLANK
     C           EKSYOS    ANDNE'99999'
     C           EKMHN1    ANDNE*BLANK
     C           EKHENK    ANDEQ*BLANK
      *
     C           EKNOBN    IFNE W@BIN
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE EKNOBN    @@BIN   20
     C           EKSRYO    IFNE *ZERO
     C           @@BIN     ANDEQPNOBN
     C                     MOVE EKSERL    @@SERL 18
     C                     ENDIF
     C                     ADD  EKSRYO    @@QTY
     C                     ENDIF
     C                     ENDDO
      *
     C           @@QTY     IFLT BASRYO
     C                     Z-ADD*ZERO     W@QTY  110
     C           K#70      SETGTAB#PL70
     C           *IN90     DOUEQ*ON
     C           K#70      REDPEAB#PL70                  90
     C           *IN90     IFEQ *OFF
     C           EKSKJY    ANDEQ*BLANK
     C           EKSYOS    ANDNE'99999'
     C           EKMHN1    ANDNE*BLANK
     C           EKHENK    ANDEQ*BLANK
      *
     C           EKNOBN    IFNE W@BIN
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  EKSRYO    W@QTY
     C           EKSRYO    IFEQ *ZERO
     C                     ADD  1         RRN3
     C                     MOVELBAMHN1    S@MHN1
     C                     MOVELBAMHN2    S@MHN2
     C                     MOVELBAMHN3    S@MHN3
     C                     MOVE EKSYOS    S@QNTY
     C                     MOVELEKSERL    S@SERL
     C                     WRITESFL03
     C                     ADD  S@QNTY    W@QTY
     C                     ENDIF
     C           W@QTY     IFGE BASRYO
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           RRN3      IFGT *ZERO
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     ENDSR
      *---------------------------------------------------
      * SCREEN2
      *---------------------------------------------------
     C           #SCRN2    BEGSR
     C                     WRITEDSP02
     C                     READ ASNPW00                7172
      *
     C                     SELEC
      * F1: END
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     MOVE '9'       $ERR
      * F9: MANUAL
     C           *INKI     WHEQ *ON
      * ENTR
     C                     OTHER
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C                     MOVE '03'      W@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *---------------------------------------------------
      * CHECK SCREEN2
      *---------------------------------------------------
     C           #CHK2     BEGSR
     C                     MOVEA'00000000'*IN,60
     C                     SETOF                     9998
     C                     MOVE *BLANK    MSG
      *
     C           PSIRE     IFEQ *BLANK
     C           PSIRK     OREQ *BLANK
     C                     MOVEA'11'      *IN,61
     C                     MOVE *ON       *IN99
     C                     MOVE ERR,5     MSG
     C                     ENDIF
      *
     C           PNOHZ     IFEQ *BLANK
     C                     MOVE *ON       *IN63
     C  N99                MOVE ERR,6     MSG
     C                     MOVE *ON       *IN99
     C                     ENDIF
      * CHECK FORD ADDRESS M/F
     C           PSIRE     CHAINABF9L01              90
     C           *IN90     IFEQ *OFF
     C                     MOVEA'11'      *IN,61
     C                     MOVE *ON       *IN99
     C                     MOVE ERR,14    MSG
     C                     ENDIF
      *
     C           PNOBN     IFEQ 0
     C                     MOVE *ON       *IN64
     C  N99                MOVE ERR,7     MSG
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C           PRISU     IFNE *BLANK
     C           PRISU     ANDNE'1'
     C                     MOVE *ON       *IN65
     C  N99                MOVE ERR,8     MSG
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     MOVE PSIRE     PUNONY
     C                     MOVE *BLANK    PUNUKE
     C                     MOVE PNOHZ     @NOHZ
     C           KEY1      SETLLAB#PL111
      *
     C           *IN10     DOUEQ*ON
     C           KEY1      READEAB#PL111                 10
     C           *IN10     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           D@ORDR    IFNE *BLANK
     C           D@ORDR    ANDNEBAODRN
     C                     ITER
     C                     ENDIF
     C           PNOBN     IFNE *ZERO
     C           PNOBN     ANDNEBANOBN
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE BANOBN    W@BIN
     C                     MOVELBAODRN    W@ODRN
     C           K#2B      CHAINAB#PP2B              90
     C           *IN90     IFEQ *OFF
     C                     MOVELABTRLR    PTRCK
     C                     MOVELABSCAC    PSCAC
     C                     ENDIF
      *
     C           K#2AA     SETLLAB#PL2A
     C           *IN90     DOUEQ*ON
     C           K#2AA     READEAB#PL2A                  90
     C           *IN90     IFEQ *OFF
     C           ACSHTM    IFNE *ZERO
     C           ACSHTM    ANDNEBANOTM
     C           BANOTM    IFEQ *ZERO
     C                     Z-ADDACSHTM    BANOTM
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      *
     C           ACSHTM    IFEQ *ZERO
     C           ACDLTM    ANDNE*ZERO
     C           ACDLTM    ANDNEBANOTM
     C           BANOTM    IFEQ *ZERO
     C                     Z-ADDACDLTM    BANOTM
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C  N99      ERR,16    CAT  BAMHIN:1  MSG
     C                     SETON                     98
     C           K#2AA     SETGTAB#PL2A
     C           K#2AB     REDPEAB#PL2A                  90
     C                     ENDIF
      *
     C           *IN90     IFEQ *OFF
     C           PSCAC     ANDEQ*BLANK
     C                     MOVELACSCAC    PSCAC
     C                     ENDIF
      *
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN10     IFEQ *ON
     C  N99                MOVE ERR,15    MSG
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C                     MOVE PSIRE     WNONY
     C                     MOVE PSIRE     ZNONY
     C                     MOVE PNOHZ     WNOHZ
     C           PRISU     IFEQ '1'
     C           K#P30     CHAINAB#PL30             N90
     C           *IN90     IFEQ *ON
     C                     MOVE *ON       *IN65
     C  N99                MOVE ERR,9     MSG
     C                     MOVE *ON       *IN99
     C                     ELSE
     C                     MOVE BDTRCK    PTRCK
     C                     Z-ADDBDWEGH    PWEIG
     C                     MOVE BDSCAC    PSCAC
     C                     MOVE BDSHTM    STM
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
