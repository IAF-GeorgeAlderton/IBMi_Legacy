     H            Y.                                    1
      *      CRTDUPOBJ  OBJ(INVPP40) FROMLIB(HFILE1) OBJTYPE(*FILE)
      *                   TOLIB(QTEMP) NEWOBJ(INVPP40B)
     FFCEPP01 IP  E           K        DISK
     FINVPP40 IF  E           K        DISK
     FINVPP40BO   E                    DISK                      A
     F            INVPP401                          KRENAMEINVPP40X
      *
     I            DS
     I                                        1   6 W2LOC
     I                                        1   1 W2LOC1
     I                                        2   3 W2LOC2
     I                                        4   5 W2LOC3
     I                                        6   6 W2LOC4
      *
     I            DS
     I                                        1   6 I2LOC
     I                                        1   1 I2LOC1
     I                                        2   3 I2LOC2
     I                                        4   5 I2LOC3
     I                                        6   6 I2LOC4
     I            DS
     I                                        1  12 A2BHBA
     I                                        1   5 A2BHB1
     I                                        6  10 A2BHB2
     I                                       11  12 A2BHB3
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     I            DS
     I                                        1   80A2TRDT
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
      *
     I            DS
     I                                        1   6 A2KTR
     I                                        1   1 A2KTRK
     I                                        2   3 A2KTRT
     I                                        4   5 A2KTRR
     I                                        6   6 A2KTRD
      *
     I            DS
     I                                        1   6 A2STR
     I                                        1   1 A2STRK
     I                                        2   3 A2STRT
     I                                        4   5 A2STRR
     I                                        6   6 A2STRD
     I            DS
     I                                        1   80I2DATE
     I                                        1   40I2YY
     I                                        5   60I2MM
     I                                        7   80I2DD
     I            DS
     I                                        1   60I2TIME
     I                                        1   20I2JJ
     I                                        3   40I2MN
     I                                        5   60I2SS
      *
      *
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     GOTO @END
     C                     ENDIF
      *
     C                     MOVEL*BLANK    W2LOC
     C           A2TRDT    IFLE *DATE
     C                     MOVELA2STRK    W2LOC1
     C                     MOVELA2STRT    W2LOC2
     C                     MOVELA2STRR    W2LOC3
     C                     MOVELA2STRD    W2LOC4
     C                     ELSE
     C                     MOVELA2KTRK    W2LOC1
     C                     MOVELA2KTRT    W2LOC2
     C                     MOVELA2KTRR    W2LOC3
     C                     MOVELA2KTRD    W2LOC4
     C                     ENDIF
      *
     C           W2LOC1    IFEQ '1'
     C                     GOTO @END
     C                     END
      *
     C           W2LOC     CHAININVPP40              88
     C           *IN88     IFEQ '0'
     C                     GOTO @END
     C                     END
      *
     C                     MOVELW2LOC     I2LOC
     C                     Z-ADD0         I2QTY
     C                     Z-ADD0         I2DATE
     C                     Z-ADD0         I2TIME
     C                     WRITEINVPP40X
      *
     C           @END      TAG
