     H            Y.
     F** ALCR09 ********************************************
     F*  THE NUMBER OF PROCESSED BOXES BY DATE LIST        *
     F*                                                    *
     F* TCHK1 06/04/09 CREATE(COPY FROM ALDR09)            *
     F******************************************************
     FALCWL051IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     F*************************************************************
     I* SYSTEM DATE
     I            DS
     I                                        1  120WWTIME
     I                                        1   60WTIME
     I                                        9  100WPMM
     I****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PUSR   10
     C                     PARM           PYYYY   40
     C                     PARM           PMM     20
     C*
     C           KEY1      KLIST
     C                     KFLD           WYY     40
     C                     KFLD           WMM     20
     C                     KFLD           WDD     20
     C*
     C*
     C                     EXSR @INIT
     C           *IN90     DOWEQ'0'
     C           PMM       ANDEQF8KAMM
     C*
     C                     MOVEL'0'       *IN91
     C           KEY1      SETLLALCWL051                 91
     C           *IN91     IFEQ '1'
     C                     MOVEL'0'       *IN91
     C                     MOVEL*BLANKS   FSW     1        FIRST SWITCH
     C                     MOVEL*BLANKS   WSW     1        WRITE SWITCH
     C                     MOVEL*BLANKS   SNAME  20
     C           *IN91     DOWEQ'0'
     C           KEY1      READEALCWL051                 91
     C*
     C           *IN91     IFEQ '0'
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     MOVEL'0'       *INOF
     C                     ENDIF
     C           FSW       IFEQ *BLANKS
     C                     MOVELD5NAME    SNAME
     C                     MOVEL'1'       FSW
     C                     ENDIF
     C           SNAME     IFNE D5NAME
     C           WSW       IFEQ *BLANKS
     C                     EXCPTDT1
     C                     MOVEL'1'       WSW
     C                     ELSE
     C                     EXCPTDT2
     C                     ENDIF
     C                     MOVELD5NAME    SNAME
     C                     ENDIF
     C                     ADD  D5BOX     D5BOXD  60
     C                     ADD  D5BOX     W5BOX   60
     C                     ENDIF
     C*
     C                     ENDDO
     C           WSW       IFEQ *BLANKS
     C                     EXCPTDT1
     C                     MOVEL'1'       WSW
     C                     ELSE
     C                     EXCPTDT2
     C                     ENDIF
     C*
     C                     ELSE
     C                     Z-ADD0         WKBOX   60
     C                     Z-ADDF8KAYY    D5YYYY
     C                     Z-ADDF8KAMM    D5MMMM
     C                     Z-ADDF8KADD    D5DDDD
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     MOVEL'0'       *INOF
     C                     ENDIF
     C                     EXCPTDT4
     C                     ENDIF
     C*
     C*                    Z-ADDWKBOX     W5BOX   60
     C                     ADD  W5BOX     LBOX    60
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     MOVEL'0'       *INOF
     C                     ENDIF
     C                     EXCPTDT3
     C                     Z-ADD0         WKBOX
     C                     READ AGDPL12                  90
     C                     Z-ADDF8KAYY    WYY
     C                     Z-ADDF8KAMM    WMM
     C                     Z-ADDF8KADD    WDD
     C                     ENDDO
     C*
     C                     EXCPTTL
     C                     MOVEL'1'       *INLR
     C                     RETRN
     C*
     C*
     C           @INIT     BEGSR
     C                     TIME           WWTIME
     C                     EXCPTHD
     C                     MOVEL'0'       *IN90
     C                     Z-ADDPYYYY     WYY
     C                     Z-ADDPMM       WMM
     C                     Z-ADD1         WDD
     C           KEY1      SETLLAGDPL12
     C                     READ AGDPL12                  90
     C                     ENDSR
     C*
     O*****************************************************************
     OQPRINT  E  102           HD
     O                                    8 'ALCR09'
     O                                  131 '.....................'
     O        E  1             HD
     O                                   12 'ISSUE DATE'
     O                                   14 ':'
     O                         PYYYY     19
     O                                   21 '/'
     O                         PMM       24
     O                                  128 '.         .         .'
     O        E  1             HD
     O                                   89 'TIME'
     O                         WTIME     98 '  :  :  '
     O                                  111 '.'
     O                         PUSR     121
     O                                  131 '.         .'
     O        E  2             HD
     O                                   28 'CONVEYANCE'
     O                                   48 '** THE NUMBER OF'
     O                                   64 'PROCESSED BOXES'
     O                                   84 'BY DATE (DETAIL) **'
     O                                   89 'DATE'
     O                         UDATE Y   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O                                  131 '.....................'
     O*
     O        E  0             HD
     O                                   35 '____'
     O                                   55 '___________'
     O                                   77 '__________'
     O*
     O        E  1             HD
     O                                   35 'DATE'
     O                                   55 'WORKER NAME'
     O                                   77 '# OF BOXES'
     O*
     O        E  1             DT1
     O                         F8HIRU    30
     O                         D5YYYY    35
     O                                   36 '/'
     O                         D5MMMM    38
     O                                   39 '/'
     O                         D5DDDD    41
     O                         SNAME     64
     O                         D5BOXD1B  77
     O*
     O        E  1             DT2
     O                         SNAME     64
     O                         D5BOXD1B  77
     O*
     O        E  2             DT3
     O                                   59 'SUBTOTAL'
     O                         W5BOX 1B  77
     O*
     O        E  1             DT4
     O                         F8HIRU    30
     O                         D5YYYY    35
     O                                   36 '/'
     O                         D5MMMM    38
     O                                   39 '/'
     O                         D5DDDD    41
     O                         WKBOX 1   77
     O*
     O*       E  1             DT5
     O*                        D5BOX 1   77
     O************************************************************
     O        E 2              TL
     O                                   59 'TOTAL'
     O                         LBOX  1B  77
     O************************************************************
