     H            Y.                                    1
      ***ALDR771****************************************************************
      *  SHIPPING VERIFICATION ERROR LOG LIST                                  *
      *                                                                *********
      * TCHK1 03/08/10 CREATE(COPY FROM ALDR65)
      * TCHK2 04/20/10 ADD TOYOTA KANBAN FILE
      **************************************************************************
     FALBPL30 IF  E           K        DISK
     FGADPL11 IF  E           K        DISK
     FAB#PL71 IF  E           K        DISK
TCHK2 *FAB#PP65 IF  E           K        DISK
     FALDPP76 IF  E           K        DISK
     FALDPL762IF  E           K        DISK
     F            ALDPP761                          KRENAMEALP@762
     FALDPL763IF  E           K        DISK
     F            ALDPP761                          KRENAMEALP@763
     FQPRINT  O   F     198     OF     PRINTER
      *------------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80F8KDAT
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I*
     I            DS
     I                                        1   80EKNODT
     I                                        1   40EKNOYY
     I                                        5   60EKNOMM
     I                                        7   80EKNODD
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C                     EXSR #OUT
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *
      *--------------------------------------------------------
      * INITIALIZE
      *--------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           PMSTDT  8
     C                     PARM           PMEDDT  8
     C                     MOVELPMSTDT    D@FROM  80
     C                     MOVELPMEDDT    D@TO    80
      *
     C           K#GAD     KLIST
     C                     KFLD           EKTOKU
     C                     KFLD           K@NONY  40
      *
     C                     TIME           WSDT
      *
     C                     MOVE *ALL'-'   W@LINE190
      *
     C                     ENDSR
     C*--------------------------------------------------------
     C*  OUTPUT
     C*--------------------------------------------------------
     C           #OUT      BEGSR
     C*
     C                     MOVE *OFF      *IN98
     C           D@FROM    SETLLALDPP76
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ALDPP76                  80
     C   80                LEAVE
     C           A7KODT    IFGT D@TO
     C                     LEAVE
     C                     END
     C* SELECT ERROR
     C           A7STS     IFNE 'ER'
     C                     ITER
     C                     END
     C*
     C                     Z-ADDA7KODT    @KODT   80
     C                     Z-ADDA7KOTM    @KOTM   60
     C                     MOVELA7PKL#    @PKL#   9
     C                     MOVELA7TMCD    K@OPER  60
     C           K@OPER    CHAINALBPL30              90
     C*
     C                     MOVELA7INSR    @SERL  18
     C                     MOVELA7INSR    K@SERL 18
     C                     MOVELA7DEST    K@DEST  5
     C                     MOVELA7NUKE    K@NUKE  4
     C                     MOVELA7ORNO    K@ORNO 12
     C                     MOVELA7KANO    K@KANO  4
     C                     MOVELA7BOXN    K@BOXN  4
     C                     MOVELA7MSG1    W@MSG  20
     C*
     C                     MOVEL*OFF      *IN95
     C           K@SERL    IFNE *BLANK
     C           K@SERL    SETGTALDPL762
     C           K@SERL    REDPEALDPL762                 95
     C                     ELSE
     C           K#763     KLIST
     C                     KFLD           K@DEST
     C                     KFLD           K@NUKE
     C                     KFLD           K@ORNO
     C                     KFLD           K@KANO
     C                     KFLD           K@BOXN
     C           K#763     SETGTALDPL763
     C           K#763     REDPEALDPL763                 95
     C                     END
     C*
     C           *IN95     IFEQ *ON
     C           A7STS     ORNE 'OK'
     C                     MOVEL*ON       *IN95
     C                     END
     C*
     C                     MOVEL*BLANK    W5KMEI 15
     C           K@SERL    CHAINAB#PL71              96
     C*
     C                     MOVELEKNONY    K@NONY
     C           K#GAD     CHAINGADPL11              97
     C  N97                MOVELB5KMEI    W5KMEI
     C*
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
     C  N98                MOVE *ON       *IN98
      *
     C                     EXCPT@DTL
     C*
     C                     ENDDO
     C*
     C                     ENDSR
      *-------------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                         WSSDATY  136
     O                         WSSTM6   145 '  :  :  '
     O                                  148 'P.'
     O                         PAGE  Z  152
     O        E   02           @HED
     O                                   65 'VERIFICATION'
     O                                   81 'SCAN ERROR LOG'
     O        E   04           @HED
     O                                   74 '---- CORRECTED ----'
     O        E   05           @HED
     O                                    8 'OPERATOR'
     O                                   31 'ERROR DATE'
     O                                   38 'TIME'
     O                                   53 'PICKLIST#'
     O                                   64 'DATE'
     O                                   73 'TIME'
     O                                   88 'SCAN BARCODE '
     O                                   99 'PART#'
     O                                  112 'LOC'
     O                                  122 'ORDER#'
     O                                  135 'CUSTOMER'
     O                                  162 'SHIP DATE'
     O                                  167 'BIN'
     O                                  181 'ERROR MESSAGE'
     O        E   06           @HED
     O                         W@LINE   190
     O        E 1              @DTL
     O                         ALWKNM    20
     O                         @KODT Y   31
     O                         @KOTM     40 '  :  :  '
     O                         @PKL#     53
     O                      N95A7KODT    65 '    .  .  '
     O                      N95A7KOTM    74 '  :  :  '
     O                         @SERL     93
     O                      N96EKSHN1    99
     O                      N96EKSHN2   105
     O                      N96EKSHN3   108
     O                      N96EKLOC1   110
     O                      N96EKLOC2   112
     O                      N96EKLOC3   114
     O                      N96EKLOC4   115
     O                      N96EKODRN   126
     O                      N96EKNONY   131
     O                      N96EKNUKE   136
     O                   N96N97W5KMEI   152
     O                      N96EKNODT   163 '    .  .  '
     O                      N96EKNOBN   167
     O                         W@MSG    188
