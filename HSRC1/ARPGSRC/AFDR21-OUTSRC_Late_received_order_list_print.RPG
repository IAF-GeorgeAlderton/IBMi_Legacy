      *-----------------------------------------------------
      *  MAIN ROUTINE
     C*-----------------------------------------------------
     C                     EXSR @PRNT
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
     C*-----------------------------------------------------
     C* INITIAL SET
     C*-----------------------------------------------------
     C           *INZSR    BEGSR
     C*
     C                     TIME           WSDT
     C*
     C           *ENTRY    PLIST
     C                     PARM           PMDATE  8
     C                     MOVELPMDATE    K@YYMD
     C*
     C                     ENDSR
     C******************************************************
     C*  PRINT
     C******************************************************
     C           @PRNT     BEGSR
     C*
     C                     MOVEL*BLANK    W@SPCD  5
     C                     MOVEL*BLANK    W@SPNM 15
     C*
     C           *LOVAL    SETLLAFDWL20
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AFDWL20                  97
     C   97                LEAVE
     C*
     C           AWSPCD    IFNE W@SPCD
     C           AWSPNM    ORNE W@SPNM
     C           *INOF     OREQ *ON
     C                     MOVELAWSPCD    W@SPCD
     C                     MOVELAWSPNM    W@SPNM
     C                     EXCPT@HED
     C                     MOVEL*OFF      *INOF
     C                     END
     C*
     C                     MOVEL*BLANK    P@PART
     C                     MOVELAWPAR1    P@PAR1
     C           AWPAR2    IFNE *BLANK
     C                     MOVEL'-'       P@PARA
     C                     END
     C                     MOVELAWPAR2    P@PAR2
     C           AWPAR3    IFNE *BLANK
     C                     MOVEL'-'       P@PARB
     C                     END
     C                     MOVELAWPAR3    P@PAR3
     C*
     C                     EXCPT@DTL
     C*
     C                     ENDDO
     C*
     C                     ENDSR
      *-----------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                         TBL,1     49
     O                                   57 'DATE'
