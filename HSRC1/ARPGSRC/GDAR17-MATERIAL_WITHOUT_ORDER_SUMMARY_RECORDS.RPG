     H            Y/
     F***************************************************
     F*   MATERIAL WITHOUT ORDER SUMMARY RECORDS          *
     F*        04/25/03 (TCH)                           *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FIZAPL04 IF  E           K        DISK
     FGDAPL10 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *------------------------------------------------------------
     E                    TTL     1   1 25
      *------------------------------------------------------------
     I            DS
     I                                        1  140W@TIME
     I                                        1   60W@HMS
     I                                        7  140W@YMD
     I                                        7  100W@YY
     I                                       11  120W@MM
     I                                       13  140W@DD
     I            DS
     I                                        1   60@@MDY
     I                                        1   20@@MM
     I                                        3   40@@DD
     I                                        5   60@@YY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
      * MATERIAL
     C                     EXSR #OUT
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#KEY     KLIST
     C                     KFLD           K@SUPL
     C                     KFLD           ZCZAIS
     C                     KFLD           ZCZAIK
      *
     C                     TIME           W@TIME
     C                     Z-ADDW@YY      @@YY
     C                     Z-ADDW@MM      @@MM
     C                     Z-ADDW@DD      @@DD
     C                     MOVE *ALL'-'   @@LIN1 83
      *
     C                     ENDSR
      *------------------------------------------------------
      *   MATERIAL
      *------------------------------------------------------
     C           #OUT      BEGSR
      *
     C                     MOVE *OFF      *IN98
     C                     MOVELTTL,1     HEDR   25
      *
     C                     Z-ADD2         K@SUPL  40
      *
     C           K@SUPL    SETLLIZAPL04
     C           *IN80     DOUEQ*ON
     C           K@SUPL    READEIZAPL04                  80
     C           *IN80     IFEQ *OFF
     C           ZCSKJY    ANDEQ*BLANK
     C           ZCSTYY    ANDEQ9999
      *
      * ALREADY READ?
     C           K#KEY     CHAINGDAPL10              91
     C           *IN91     IFEQ *OFF
     C                     ITER
     C                     ENDIF
      * THEN OUTPUT
     C                     EXSR #PRT1
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   OUTPUT THE LIST
      *------------------------------------------------------
     C           #PRT1     BEGSR
      *
     C  N98
     COR OF                EXCPT@HED1
     C  N98                MOVE *ON       *IN98
      *
      * DAILY USAGE X 5 = WEEKLY USAGE
     C           ZCMKJR    DIV  20        @@QTY   92
     C           @@QTY     MULT 5         @@WQY   92
     C           @@WQY     DIV  ZCTKJR    @@BOX   72
      *
     C                     EXCPT@DTL1
      *
     C                     ENDSR
      *------------------------------------------------------
     OQPRINT  E   01           @HED1
     O                         #PGM       8
     O                         @@MDY Y   59
     O                                   62 'P.'
     O                         PAGE  Z   66
     O        E   02           @HED1
     O                         HEDR      43
     O                         W@HMS     59 '  :  :  '
     O        E   04           @HED1
     O                                   58 'WEEKLY'
     O                                   68 'WEEKLY'
     O        E   05           @HED1
     O                                   45 'UNIT'
     O                                   58 'SETTING'
     O                                   68 'SETTING'
     O        E   06           @HED1
     O                                    8 'MATERIAL'
     O                                   21 'DIAMETER'
     O                                   33 'LOCATION'
     O                                   45 'KG'
     O                                   58 'KG'
     O                                   68 'COILS'
     O        E   07           @HED1
     O                         @@LIN1    83
     O        E 1              @DTL1
     O                         ZCZAIS    15
     O                         ZCZAIK4   21
     O                         ZCADR1    25
     O                                   26 '-'
     O                         ZCADR2    28
     O                                   29 '-'
     O                         ZCADR3    31
     O                                   32 '-'
     O                         ZCADR4    33
     O                         ZCTKJR1   45
     O                         @@WQY 1   58
     O                         @@BOX 1   68
** TTL
ASJ MATERIAL NOT SCANNED
