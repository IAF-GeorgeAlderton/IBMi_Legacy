     H            Y.
      *未処理の工程情報を返す
     FCA#PL08 IF  E           K        DISK
      *
     E                    KOT        10  3
     E                    BMN        10 16
     E                    KBN        10  3
     E                    HAK        10  1
     E                    NYD        10  8 0
     E                    NYB        10  2 0
     E                    KND        10  8 0
     E                    KNT        10  6 0
     E                    KNN        10 10
      *
     I            DS
     I                                        1  30 KOT
     I                                        1  30 C6KOT
     I            DS
     I                                        1 160 BMN
     I                                        1 160 C6BMN
     I            DS
     I                                        1  30 KBN
     I                                        1  30 C6KBN
     I            DS
     I                                        1  10 HAK
     I                                        1  10 C6HAK
     I            DS
     I                                        1  800NYD
     I                                        1   80C6NYD1
     I                                        9  160C6NYD2
     I                                       17  240C6NYD3
     I                                       25  320C6NYD4
     I                                       33  400C6NYD5
     I                                       41  480C6NYD6
     I                                       49  560C6NYD7
     I                                       57  640C6NYD8
     I                                       65  720C6NYD9
     I                                       73  800C6NYDA
     I            DS
     I                                        1  200NYB
     I                                        1  200C6NYB
     I            DS
     I                                        1  800KND
     I                                        1   80C6KND1
     I                                        9  160C6KND2
     I                                       17  240C6KND3
     I                                       25  320C6KND4
     I                                       33  400C6KND5
     I                                       41  480C6KND6
     I                                       49  560C6KND7
     I                                       57  640C6KND8
     I                                       65  720C6KND9
     I                                       73  800C6KNDA
     I            DS
     I                                        1  600KNT
     I                                        1   60C6KNT1
     I                                        7  120C6KNT2
     I                                       13  180C6KNT3
     I                                       19  240C6KNT4
     I                                       25  300C6KNT5
     I                                       31  360C6KNT6
     I                                       37  420C6KNT7
     I                                       43  480C6KNT8
     I                                       49  540C6KNT9
     I                                       55  600C6KNTA
     I            DS
     I                                        1 100 KNN
     I                                        1 100 C6KNN
      *
     C           *ENTRY    PLIST
     C                     PARM           P@BARC 20
     C                     PARM           P@KOT   3
     C                     PARM           P@BMN  16
     C                     PARM           P@KBN   3
     C                     PARM           P@HAK   1
     C                     PARM           P@NYD   80
     C                     PARM           P@NYB   20
     C                     PARM           P@NO    20
      *
     C                     MOVE *BLANK    P@KOT
     C                     MOVE *BLANK    P@BMN
     C                     MOVE *BLANK    P@KBN
     C                     MOVE *BLANK    P@HAK
     C                     Z-ADD0         P@NYD
     C                     Z-ADD0         P@NYB
     C                     Z-ADD0         P@NO
      *
     C                     CALL 'BARR81'
     C                     PARM           P@BARC 20
     C                     PARM           P@KRKB  1
     C                     PARM           P@ZETI  4
     C                     PARM           P@TEHI  3
     C                     PARM           P@PAGN  2
     C                     PARM           P@BCKA  1
     C                     PARM           P@BCTK  1
     C                     PARM           P@BCYK  1
     C                     PARM           P@BCHK  1
     C                     PARM           P@BCKD  1
      *
     C                     MOVE P@ZETI    K@ZETI  4
      *
     C                     MOVELP@TEHI    P#MOJI 20
     C                     MOVE '03'      P#KETA  2
     C                     MOVE *BLANK    P#RTN   1
     C                     CALL 'CHKR90'
     C                     PARM           P#MOJI 20
     C                     PARM           P#KETA  2
     C                     PARM           P#RTN   1
     C           P#RTN     IFEQ '0'
     C                     MOVELP@TEHI    K@TEHI  3
     C                     ELSE
     C                     MOVEL'999'     K@TEHI
     C                     END
      *
     C           KEY       KLIST
     C                     KFLD           K@ZETI
     C                     KFLD           K@TEHI
      *
     C           KEY       SETGTCA#PL08
      *
     C                     DO   *HIVAL
     C           KEY       REDPECA#PL08                  77
     C   77                LEAVE
      *
     C           *IN77     IFEQ '0'
     C           C6SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C                     END
      *
     C                     LEAVE
      *
     C                     ENDDO
      *
     C   77                Z-ADD91        P@NO
     C   77                GOTO @END
      *
     C                     Z-ADD1         @X      20
     C           00000000  LOKUPKND,@X                   77
     C           *IN77     IFEQ '1'
     C           KOT,@X    IFNE *BLANK
     C                     MOVE KOT,@X    P@KOT
     C                     MOVE BMN,@X    P@BMN
     C                     MOVE KBN,@X    P@KBN
     C                     MOVE HAK,@X    P@HAK
     C                     Z-ADDNYD,@X    P@NYD
     C                     Z-ADDNYB,@X    P@NYB
     C                     Z-ADD@X        P@NO
     C                     END
     C                     END
      *
     C           @END      TAG
      *
     C                     SETON                     LR
     C                     RETRN
      *
