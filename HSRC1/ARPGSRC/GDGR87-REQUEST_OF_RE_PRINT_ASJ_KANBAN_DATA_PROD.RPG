     C*===============================================================
     C           *ENTRY    PLIST
     C                     PARM           P@SYS   8
     C*===============================================================
     C*  START  PROGRAM
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#CHK1U  '#CHK1
     C           @STEP     CASEQ'#ADD    '#ADD
     C           @STEP     CASEQ'#SFSET  '#SFSET
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C           @STEP     CASEQ'#CHK2U  '#CHK2
     C           @STEP     CASEQ'#DELETE '#DEL
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     MOVE *BLANK    D1MSG            エラー
     C*
     C                     Z-ADD1         X       20
     C           P@SYS     LOKUPTBL,X                    90
     C           *IN90     IFEQ *ON
     C                     MOVE TOKU,X    @TOKU
     C                     ELSE
     C                     MOVE TOKU,4    @TOKU
     C                     ENDIF
     C*
     C                     MOVE *BLANK    D1HIN1
     C                     MOVE *BLANK    D1HIN2
     C                     MOVE *BLANK    D1HIN3
     C                     Z-ADD0         D1MAIS
     C*
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
      *===============================================================
      *  画面１　表示
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     EXFMTDSP01
     C                     SETOF                     111299
     C                     MOVE *BLANK    D1MSG
     C*
     C                     MOVE '#CHK1   '@STEP
     C*  < F1 >  END JOB
     C           *INKA     IFEQ *ON
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C*  < F3 >  END JOB
     C           *INKC     IFEQ *ON
     C                     SETON                     U3
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C*  < F5 >  INPUT OK
     C           *INKE     IFEQ *ON
     C                     MOVE '#CHK1U  '@STEP
     C                     ENDIF
     C*  < F12 >  INQUIRY
     C           *INKL     IFEQ *ON
     C                     MOVE '#SFSET  '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  画面１　チェック
      *===============================================================
     C           #CHK1     BEGSR
     C                     CLEARGDGWP871
     C*----------
     C* PART NO.
     C*----------
     C           D1HIN1    IFEQ *BLANK
     C           D1HIN2    ANDEQ*BLANK
     C           D1HIN3    ANDEQ*BLANK
     C                     SETON                     1199
     C                     MOVELMSG,1     D1MSG
     C                     ENDIF
     C*
     C           KEY01     KLIST
     C                     KFLD           D1HIN1
     C                     KFLD           D1HIN2
     C                     KFLD           D1HIN3
     C*    入力済
     C           *IN99     IFEQ *OFF
     C           KEY01     SETLLGDGWP87                  90:EQ
     C           *IN90     IFEQ *ON
     C                     SETON                     1199
     C                     MOVELMSG,2     D1MSG
     C                     ENDIF
     C                     ENDIF
     C*--------------------
     C                     Z-ADD0         G1ISYS  70       収容数
     C                     MOVE ' '       G1SKBN  1        製品区分
     C                     MOVE *BLANK    G1ZETI  4        絶対番号
      * COMPLETION HALF-FINISHED GOODS KANBAN M/F *
     C           KEY01     SETLLAAPTL01
S1   C                     DO   *HIVAL
     C           KEY01     READEAAPTL01                  90
     C   90                LEAVE
     C           L5SKJY    IFEQ 'D'                         DELETE CODE
     C           L5SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C           L5UKHZ    IFGT *DATE
     C                     ITER
     C                     ENDIF
     C           L5STHZ    IFLE *DATE
     C                     ITER
     C                     ENDIF
     C                     Z-ADDL5SYOS    G1ISYS
     C                     MOVE '0'       G1SKBN           製品区分
E1   C                     ENDDO
     C*----------
      * .. COMPONENTS KANBAN M/F   *.
S1   C           G1SKBN    IFEQ ' '                        製品区分
     C           KEY01     SETLLAKBPL04
 S2  C                     DO   *HIVAL
     C           KEY01     READEAKBPL04                  90
     C   90                LEAVE
     C           L1SKJY    IFEQ 'D'                         DELETE CODE
     C           L1SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C           L1UKHZ    IFGT *DATE
     C                     ITER
     C                     ENDIF
     C           L1STHZ    IFLE *DATE
     C                     ITER
     C                     ENDIF
     C                     Z-ADDL1SYOS    G1ISYS
     C                     MOVE '3'       G1SKBN           製品区分
     C                     Z-ADD0         G1GEKN
     C                     Z-ADD0         G1TUSZ
     C*******              MOVEL'COMPONE' G1SMEI
     C*******              MOVE 'NT PARTS'G1SMEI
     C                     MOVE *BLANK    G1SMEI
     C                     MOVE *BLANK    G1TMEI
     C                     MOVE *BLANK    G1DMEI
     C                     MOVE L1SYOT    G1IHAK
     C                     MOVE L1TKR1    G1ITK1
     C                     MOVE L1TKR2    G1ITK2
     C                     MOVE L1TKR3    G1ITK3
     C                     MOVE L1TKR4    G1ITK4
 E2  C                     ENDDO
E1   C                     ENDIF
     C*----------
      * HALF-FINISHED GOODS KANBAN M/F     *
S1   C           G1SKBN    IFEQ ' '                        製品区分
     C           KEY01     SETLLAANPL06
 S2  C                     DO   *HIVAL
     C           KEY01     READEAANPL06                  90
     C   90                LEAVE
     C           L7SKJY    IFEQ 'D'                         DELETE CODE
     C           L7SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C           L7UKHZ    IFGT *DATE
     C                     ITER
     C                     ENDIF
     C           L7STHZ    IFLE *DATE
     C                     ITER
     C                     ENDIF
      * HALF-FINISHED GOODS KANBAN M/F *
     C                     Z-ADDL7SYOS    G1ISYS
     C                     MOVE '6'       G1SKBN           製品区分
     C                     Z-ADD0         G1GEKN
     C                     Z-ADD0         G1TUSZ
     C*********            MOVEL'HALF-FI' G1SMEI
     C*********            MOVE 'NISHED  'G1SMEI
     C                     MOVE *BLANK    G1SMEI
     C                     MOVE *BLANK    G1TMEI
     C                     MOVE *BLANK    G1DMEI
     C                     MOVE L7SYOT    G1IHAK
     C                     MOVE L7TKR1    G1ITK1
     C                     MOVE L7TKR2    G1ITK2
     C                     MOVE L7TKR3    G1ITK3
     C                     MOVE L7TKR4    G1ITK4
     C                     MOVELL7ZETI    G1ZETI
 E2  C                     ENDDO
E1   C                     ENDIF
     C*
     C*
S1   C  N99      G1SKBN    IFEQ ' '                        製品区分
     C                     SETON                     1199
     C                     MOVELMSG,3     D1MSG
E1   C                     ENDIF
     C*
S1   C  N99      G1SKBN    IFNE '3'                        製品区分
     C           KEY01     CHAINFCEPL011             90
 S2  C           *IN90     IFEQ '0'
  S3 C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
  X3 C                     ELSE
  S4 C           G1SKBN    IFEQ *BLANK                     製品区分
     C                     MOVE '0'       G1SKBN           製品区分
  E4 C                     ENDIF
     C                     MOVELA2ZETI    G1ZETI
     C                     Z-ADDA2GEKN    G1GEKN
     C                     Z-ADDA2TUSZ    G1TUSZ
     C                     MOVE A2SMEI    G1SMEI
     C                     MOVE A2TMEI    G1TMEI
     C                     MOVE A2DMEI    G1DMEI
     C           A2SYHZ    IFGT *DATE
     C                     MOVE A2KSYT    G1IHAK
     C                     Z-ADDA2KSYS    G1ISYS
     C                     ELSE
     C                     MOVE A2SSYT    G1IHAK
     C                     Z-ADDA2SSYS    G1ISYS
     C                     ENDIF
     C           A2TRHZ    IFGT *DATE
     C                     MOVE A2KTRK    G1ITK1
     C                     MOVE A2KTRT    G1ITK2
     C                     MOVE A2KTRR    G1ITK3
     C                     MOVE A2KTRD    G1ITK4
     C                     ELSE
     C                     MOVE A2STRK    G1ITK1
     C                     MOVE A2STRT    G1ITK2
     C                     MOVE A2STRR    G1ITK3
     C                     MOVE A2STRD    G1ITK4
     C                     ENDIF
  E3 C                     ENDIF
 E2  C                     ENDIF
E1   C                     ENDIF
     C*
     C*上のルーチンで決めた収容数と所番地を
     C*各かんばんマスターから引きなおす！
     C                     EXSR #TYPE
     C                     MOVE WWKTRK    G1ITK1
     C                     MOVE WWKTRT    G1ITK2
     C                     MOVE WWKTRR    G1ITK3
     C                     MOVE WWKTRD    G1ITK4
     C                     MOVE WWSEIH    G1SKBN
     C                     MOVE WWZETI    G1ZETI
     C                     Z-ADDWWSYOS    G1ISYS
     C*
     C*
     C           KEY01     CHAINFCEPL11              90
S1   C           *IN90     IFEQ *OFF
     C           FCSKJY    ANDEQ'D'
     C           FCSKHZ    ANDLE*DATE
     C                     SETON                     90
E1   C                     ENDIF
S1   C           *IN90     IFEQ *OFF
     C                     Z-ADD11        D       20
 S2  C                     DO   10
     C                     SUB  1         D
  S3 C           FCKH,D    IFNE 0
     C                     MOVELFCKH,D    @@YM1   60
     C                     MOVEL*DATE     @@YM2   60
  S4 C           @@YM1     IFEQ @@YM2
     C                     Z-ADDFCGK,D    G1GEK2           月間必要数
     C                     Z-ADDFCCD,D    G1KADO           稼働日
     C                     LEAVE
  E4 C                     ENDIF
  E3 C                     ENDIF
 E2  C                     ENDDO
E1   C                     END
     C*
     C  N99      D1MAIS    IFEQ 0
     C                     SETON                     1299
     C                     MOVELMSG,4     D1MSG
     C                     ENDIF
     C*----------
     C                     Z-ADD0         WJYSU   90
     C           G1ISYS    MULT D1MAIS    WJYSU
     C  N99      WJYSU     IFGE 10000000
     C                     SETON                     1299
     C                     MOVELMSG,6     D1MSG
     C                     ENDIF
     C*----------
S1   C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK1U  '
     C                     MOVE '#ADD    '@STEP
X1   C                     ELSE
     C                     MOVE '#DSP1   '@STEP
E1   C                     ENDIF
     C*
     C                     ENDSR
     C*===============================================================
     C*===============================================================
     C*   << ADD   >>
     C*===============================================================
     C           #ADD      BEGSR
     C*
     C                     Z-ADD@@TOKU    G1TOKU
     C                     MOVE @@TKOJ    G1TKOJ
     C                     MOVE @@TUKE    G1TUKE
     C                     Z-ADD@@NONY    G1NONY
     C                     MOVE @@NKOJ    G1NKOJ
     C                     MOVE @@NUKE    G1NUKE
     C                     MOVE D1HIN1    G1HIN1
     C                     MOVE D1HIN2    G1HIN2
     C                     MOVE D1HIN3    G1HIN3
     C                     Z-ADDD1MAIS    G1MAIS
     C                     MOVE 'S'       G1HANY
     C           G1MAIS    MULT G1ISYS    G1JCHU
     C                     WRITEGDGWP871
     C*
     C                     MOVE *BLANK    D1HIN1
     C                     MOVE *BLANK    D1HIN2
     C                     MOVE *BLANK    D1HIN3
     C                     Z-ADD0         D1MAIS
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
     C*===============================================================
     C*   << SFSET >>
     C*===============================================================
     C           #SFSET    BEGSR
     C                     SETON                     73    SFLCLR
     C                     WRITESFCTL
     C                     SETOF                     73
     C                     Z-ADD0         RRN1    40
     C*
     C* DAYLY ORDER DATA BEFOR ADDING FILE
     C           *LOVAL    SETLLGDGWP87
     C*--------------------
S1   C                     DO   *HIVAL
     C                     READ GDGWP87                  90
     C   90                LEAVE
     C*
     C                     SETOF                     21
     C                     MOVE *BLANK    S1DEL            DELETE
     C                     MOVE *BLANK    S1HIN            PART NO.
     C                     MOVE G1HIN1    S1HIN1           PART NO1
     C                     MOVE G1HIN2    S1HIN2           PART NO2
     C                     MOVE G1HIN3    S1HIN3           PART NO3
     C                     MOVE '-'       S1HF1
     C                     MOVE '-'       S1HF2
     C           S1HIN3    IFEQ *BLANK                     PART NO3
     C                     MOVE ' '       S1HF2
     C           S1HIN2    IFEQ *BLANK                     PART NO2
     C                     MOVE ' '       S1HF1
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADDG1MAIS    S1MAIS           QTY
     C                     MOVE G1SKBN    S1PROD           PART CODE
     C                     ADD  1         RRN1
     C                     WRITESFREC1
E1   C                     ENDDO
     C*--------------------
     C                     Z-ADDRRN1      ENDRRN  40
     C                     Z-ADD1         RRN
     C                     MOVE '#DSP2   '@STEP
     C*
     C                     ENDSR
      *===============================================================
      *  画面２　表示
      *===============================================================
     C           #DSP2     BEGSR
     C*
     C                     WRITEDSP02
     C           ENDRRN    IFNE 0
     C                     SETON                     71
     C                     ENDIF
     C                     SETON                     72
     C                     EXFMTSFCTL
     C                     SETOF                     717299
     C                     MOVE *BLANK    D2MSG
     C                     Z-ADD$$RRN     TOPRRN  40
     C*
     C                     MOVE '#CHK2   '@STEP
     C*  < F3 >  BACK
     C           *INKC     IFEQ *ON
     C                     MOVE *BLANK    D1HIN1
     C                     MOVE *BLANK    D1HIN2
     C                     MOVE *BLANK    D1HIN3
     C                     Z-ADD0         D1MAIS
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C*  < F5 >  DELETE OK
     C           *INKE     IFEQ *ON
     C                     MOVE '#CHK2U  '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  画面２　チェック
      *===============================================================
     C           #CHK2     BEGSR
     C*
     C                     Z-ADD0         @SEL    40
     C                     Z-ADD0         ERRRRN  40
     C                     Z-ADD0         CHGRRN  40
     C*--------------------
S1   C                     DO   ENDRRN    RRN1
     C           RRN1      CHAINSFREC1               91
     C   91                LEAVE
     C                     SETOF                     21
     C*
 S2  C           S1DEL     IFNE *BLANK
     C           S1DEL     ANDNE'0'
     C                     MOVELMSG,5     D2MSG
     C                     SETON                     2199
     C                     Z-ADDRRN1      ERRRRN
 E2  C                     ENDIF
     C           S1DEL     IFEQ '0'                        DELETE
     C                     ADD  1         @SEL
     C                     ENDIF
     C*
     C                     UPDATSFREC1
E1   C  N99                ENDDO
     C*--------------------
     C*          @SEL      IFEQ 0
     C*                    MOVELMSG,5     D2MSG
     C*                    SETON                     99
     C*                    ENDIF
     C*
S1   C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK2U  '
     C                     MOVE '#DELETE '@STEP
X1   C                     ELSE
 S2  C           ERRRRN    IFNE 0
     C                     Z-ADDERRRRN    RRN
 X2  C                     ELSE
     C                     Z-ADDTOPRRN    RRN
 E2  C                     ENDIF
     C                     MOVE '#DSP2   '@STEP
E1   C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *   DELETE
      *===============================================================
     C           #DEL      BEGSR
     C*
     C           KEY02     KLIST
     C                     KFLD           S1HIN1
     C                     KFLD           S1HIN2
     C                     KFLD           S1HIN3
     C*--------------------
S1   C                     DO   ENDRRN    RRN1
     C           RRN1      CHAINSFREC1               91
     C   91                LEAVE
     C*
     C           S1DEL     IFEQ '0'                        DELETE
     C           KEY02     CHAINGDGWP87              95
     C  N95                DELETGDGWP871
     C                     ENDIF
E1   C                     ENDDO
     C*--------------------
     C                     MOVE '#SFSET  '@STEP
     C*
     C                     ENDSR
