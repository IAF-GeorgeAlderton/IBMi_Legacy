     C****************************************************************
 %002C           #TYPE     BEGSR                                     *
     C****************************************************************
     C*<KANBAN TYPE>
     C                     SETOF                     54
     C           KEY01     SETGTAAPTL011
     C                     DO   *HIVAL
     C           ##1       TAG
     C           KEY01     REDPEAAPTL011                 54
     C           *IN54     IFEQ '0'
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    IFLE *DATE
     C                     GOTO ##1
     C                     END
     C                     END
     C*
     C           L5UKHZ    IFGT *DATE
     C                     GOTO ##1
     C                     END
     C*
     C           L5STHZ    IFLE *DATE
     C                     GOTO ##1
     C                     END
     C*
     C           L5STHZ    IFNE 99999999
     C                     GOTO ##1
     C                     END
     C*
     C                     MOVE '0'       WWSEIH  1
     C                     Z-ADDL5SYOS    WWSYOS  70
     C                     MOVE L5ZETI    WWZETI  4
     C                     MOVE L5TKR1    WWKTRK  1
     C                     MOVE L5TKR2    WWKTRT  2
     C                     MOVE L5TKR3    WWKTRR  2
     C                     MOVE L5TKR4    WWKTRD  1
     C                     GOTO ETYPE
     C                     END
     C  N54                ENDDO
      *
      *
     C                     SETOF                     54
     C           KEY01     SETLLAKBPL041                 54
     C                     DO   *HIVAL
     C           ##2       TAG
     C           KEY01     READEAKBPL041                 54
     C           *IN54     IFEQ '0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    IFLE *DATE
     C                     GOTO ##2
     C                     END
     C                     END
     C           L1UKHZ    IFGT *DATE
     C                     GOTO ##2
     C                     END
     C           L1STHZ    IFLE *DATE
     C                     GOTO ##2
     C                     END
     C                     MOVE L1ZETI    WWZETI
     C                     MOVE '3'       WWSEIH
     C                     Z-ADDL1SYOS    WWSYOS
     C                     MOVE L1TKR1    WWKTRK
     C                     MOVE L1TKR2    WWKTRT
     C                     MOVE L1TKR3    WWKTRR
     C                     MOVE L1TKR4    WWKTRD
     C                     GOTO ETYPE
     C                     END
     C  N54                ENDDO
      *
      *
     C                     SETOF                     54
