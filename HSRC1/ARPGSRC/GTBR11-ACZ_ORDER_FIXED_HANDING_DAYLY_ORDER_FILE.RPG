     C                     MOVE *BLANK    WKZETI  4        製品区分
     C           KEY01     SETLLAAPTL01
B1   C                     DO   *HIVAL
     C           KEY01     READEAAPTL01                  10
     C   10                LEAVE
     C           L5SKJY    IFEQ 'D'                         DELETE CODE
     C           L5SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C           L5UKHZ    IFGT *DATE
     C                     ITER
     C                     ENDIF
     C           L5STHZ    IFLE *DATE
     C                     ITER
     C                     ENDIF
     C                     Z-ADDL5SYOS    WKSYOS
     C                     MOVE '0'       WKSEIH           製品区分
E1   C                     ENDDO
     C*----------
B1   C           WKSEIH    IFEQ ' '                        製品区分
     C           KEY01     SETLLAKBPL04
 B2  C                     DO   *HIVAL
     C           KEY01     READEAKBPL04                  10
     C   10                LEAVE
     C           L1SKJY    IFEQ 'D'                         DELETE CODE
     C           L1SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C           L1UKHZ    IFGT *DATE
     C                     ITER
     C                     ENDIF
     C           L1STHZ    IFLE *DATE
     C                     ITER
     C                     ENDIF
     C                     Z-ADDL1SYOS    WKSYOS
     C                     MOVE '3'       WKSEIH           製品区分
 E2  C                     ENDDO
E1   C                     ENDIF
     C*----------
B1   C           WKSEIH    IFEQ ' '                        製品区分
     C           KEY01     SETLLAANPL06
 B2  C                     DO   *HIVAL
     C           KEY01     READEAANPL06                  10
     C   10                LEAVE
     C           L7SKJY    IFEQ 'D'                         DELETE CODE
     C           L7SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C           L7UKHZ    IFGT *DATE
     C                     ITER
     C                     ENDIF
     C           L7STHZ    IFLE *DATE
     C                     ITER
     C                     ENDIF
     C                     Z-ADDL7SYOS    WKSYOS
     C                     MOVE '6'       WKSEIH           製品区分
 E2  C                     ENDDO
E1   C                     ENDIF
     C*
     C           WKSEIH    IFEQ ' '                        製品区分
     C           D1OPT     ANDEQ'2'
     C                     MOVEA'1'       *IN,12
     C  N99                MOVELMSG,6     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK1E
     C                     ENDIF
     C*
     C                     SETOF                     10
     C           KEY01     CHAINFCEPL011             10
     C           *IN10     IFEQ '0'
