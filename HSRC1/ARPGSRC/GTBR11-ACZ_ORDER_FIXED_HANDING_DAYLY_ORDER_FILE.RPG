     C****************************************************************
     C*           ＭＡＩＮ　ＲＯＵＴＩＮＥ                         *
     C****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C           P#00      PLIST
     C                     PARM           P@FILE 10
     C                     PARM           P@OK    2
     C                     PARM           P@ID    1
     C* CHECK & LOCK
     C                     MOVEL'GTBPP10' P@FILE
     C                     MOVEL'1'       P@ID
     C                     CALL 'GTBR0A'  P#00
      *
     C           @CLR1     TAG
     C*
     C                     MOVE *BLANK    D1OPT
     C                     MOVE *BLANK    D1HIN1
     C                     MOVE *BLANK    D1HIN2
     C                     MOVE *BLANK    D1HIN3
     C                     MOVE *BLANK    D#MSG
     C                     MOVEA'00'      *IN,11
     C                     MOVEA'0'       *IN,99
     C           P@OK      IFEQ 'NO'
     C                     MOVELMSG,7     D#MSG
     C                     MOVE *ON       *IN99
     C                     ENDIF
     C****************
     C*  第１画面  *
     C****************
     C           @DSP1     TAG
     C*
     C                     EXFMTDSP01
     C                     MOVEA'00'      *IN,11
     C*
     C           P@OK      CABEQ'NO'      @END
     C*
     C                     MOVE *BLANK    D#MSG
     C                     MOVEA'0'       *IN,99
     C* < F1=ON >
     C           *INKA     CABEQ'1'       @END
     C*
     C                     EXSR #CHK01
     C           *IN99     CABEQ'1'       @DSP1
     C*
     C                     EXSR #SET01
     C****************
     C*  第２画面  *
     C****************
     C           @DSP2     TAG
     C*
     C                     EXFMTDSP02
     C                     MOVEA'0'       *IN,21
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    D#MSG
     C* < F1=ON >
     C           *INKA     CABEQ'1'       @END
     C* < F3=ON >
     C           *INKC     CABEQ'1'       @DSP1
     C*
     C                     EXSR #CHK02
     C           *IN99     CABEQ'1'       @DSP2
     C* < F5=OFF >
     C           *INKE     CABEQ'0'       @DSP2
     C*
     C           *IN30     IFEQ '0'
     C                     SETON                     30
     C                     TIME           @@TIME
     C                     EXCPTHD
     C                     END
     C*
     C                     ADD  1         CHGALL  40
     C*
     C                     EXSR #UPD01
     C                     GOTO @CLR1
     C*
     C**************
     C* 終　　了 *
     C**************
     C           @END      TAG
     C           *IN30     IFEQ '1'
     C                     EXCPTTO
     C                     END
      * UNLOCK
     C           P@OK      IFEQ 'OK'
     C                     MOVEL'GTBPP10' P@FILE
     C                     MOVEL'2'       P@ID
     C                     CALL 'GTBR0A'  P#00
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
     C****************************************************************
     C*           ＳＵＢ　　ＲＯＵＴＩＮＥ                         *
     C****************************************************************
     C           #CHK01    BEGSR                                     *
     C****************************************************************
     C**第１画面チェック**
     C*
     C           D1OPT     IFNE '0'
     C           D1OPT     ANDNE'1'
     C           D1OPT     ANDNE'2'
     C                     MOVEA'1'       *IN,11
     C  N99                MOVELMSG,1     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK1E
     C                     END
     C*
     C           KEY01     KLIST
     C                     KFLD           D1HIN1
     C                     KFLD           D1HIN2
     C                     KFLD           D1HIN3
     C*----------
     C           KEY01     SETLLGTBPL101
     C                     DO   *HIVAL
     C           KEY01     READEGTBPL101                 10
     C   10                LEAVE
     C           IBSKJY    IFEQ 'D'                        DELETE CODE
     C           IBSKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C*:
     C                     LEAVE
     C                     ENDDO
     C*----------
     C           *IN10     IFEQ '1'
     C           D1OPT     IFEQ '0'
     C           D1OPT     OREQ '1'
     C                     MOVEA'1'       *IN,12
     C  N99                MOVELMSG,3     D#MSG
     C  N99                MOVEA'1'       *IN,99
