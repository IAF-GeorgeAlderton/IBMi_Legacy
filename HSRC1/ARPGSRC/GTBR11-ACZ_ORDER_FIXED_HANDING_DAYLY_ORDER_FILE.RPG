     C                     EXCPTNEW
     C                     EXCPTSP
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     END
     C                     MOVE ' '       IBSKJY           DELETE CODE
     C                     Z-ADD0         IBSKHZ
     C  N10                UPDATGTBPL101
     C   10                WRITEGTBPL101
      *--------------------*
      * 2004.11.08 MSK     *
      *--------------------*
     C           1         CHAINGTBPPNO1             29
     C           *IN29     IFEQ '0'
     C                     ADD  1         IASEQN
     C                     Z-ADDIASEQN    WKSEQN  50
     C                     UPDATGTBPPNO1
     C                     ELSE
     C                     Z-ADD1         IASEQN
     C                     Z-ADD1         WKSEQN  50
