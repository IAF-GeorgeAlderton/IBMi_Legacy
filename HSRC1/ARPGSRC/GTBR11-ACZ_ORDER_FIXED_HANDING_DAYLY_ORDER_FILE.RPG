     C                     Z-ADDIASEQN    WKSEQN  50
     C                     UPDATGTBPPNO1
     C                     ELSE
     C                     Z-ADD1         IASEQN
     C                     Z-ADD1         WKSEQN  50
     C                     WRITEGTBPPNO1
     C                     ENDIF
     C                     Z-ADD0         @@MAIS  50
     C           IBMAIS    MULT -1        @@MAIS
     C                     MOVEL'8'       @@NYKB  1
     C                     MOVE 'D'       @@DEL   1
     C                     EXCPTFILE
     C                     MOVEL*BLANK    @@NYKB
     C                     MOVE ' '       @@DEL   1
      *
     C                     ENDIF
     C*
     C* CHANGE MODE
     C*
     C           *IN81     IFEQ '1'
     C                     MOVE 'OLD DATA'OLDMSG
     C                     EXCPTOLD
     C                     MOVE 'CHG DATA'NEWMSG  8
     C                     EXCPTNEW
     C                     EXCPTSP
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     END
     C  N10                UPDATGTBPL101
      *--------------------*
      * 2004.11.08 MSK     *
      *--------------------*
     C           IBMAIS    SUB  WWMAIS    @@MAIS
     C           @@MAIS    IFNE 0
     C           1         CHAINGTBPPNO1             29
     C           *IN29     IFEQ '0'
     C                     ADD  1         IASEQN
     C                     Z-ADDIASEQN    WKSEQN  50
     C                     UPDATGTBPPNO1
     C                     ELSE
     C                     Z-ADD1         IASEQN
     C                     Z-ADD1         WKSEQN  50
     C                     WRITEGTBPPNO1
     C                     ENDIF
     C                     Z-ADD0         @@MAIS  50
     C           IBMAIS    SUB  WWMAIS    @@MAIS
     C                     MOVEL'8'       @@NYKB  1
     C                     MOVE '1'       @@DEL   1
     C                     EXCPTFILE
     C                     MOVEL*BLANK    @@NYKB
     C                     MOVE ' '       @@DEL   1
     C                     ENDIF
      *
     C                     ENDIF
     C*
     C* ADD MODE
     C*
     C           *IN82     IFEQ '1'
