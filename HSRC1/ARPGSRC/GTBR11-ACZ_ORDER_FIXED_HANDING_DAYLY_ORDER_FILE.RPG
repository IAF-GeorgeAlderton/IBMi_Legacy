     C                     END
     C                     ELSE
     C           D1OPT     IFEQ '2'
     C                     MOVEA'1'       *IN,12
     C  N99                MOVELMSG,2     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK1E
     C                     END
     C                     END
     C*
     C*--------------------
     C                     Z-ADD0         WKSYOS  70       収容数
