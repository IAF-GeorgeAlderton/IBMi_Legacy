     C                     ELSE
     C                     MOVELA2ZETI    WKZETI
     C                     END
     C                     END
     C*
     C           @CHK1E    ENDSR
     C****************************************************************
     C           #CHK02    BEGSR                                     *
     C****************************************************************
     C**第２画面チェック**
     C*
     C                     Z-ADDWKSYOS    D2SYOS           収容数
     C           D2MAIS    MULT D2SYOS    D2SURY
     C*
     C           D1OPT     IFNE '0'
     C           D2MAIS    IFEQ 0
     C                     MOVEA'1'       *IN,21
     C  N99                MOVELMSG,5     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK2E
     C                     END
     C                     END
     C*
     C           @CHK2E    ENDSR
     C****************************************************************
     C           #SET01    BEGSR                                     *
     C****************************************************************
     C**第２画面セット**
     C                     MOVEA'0'       *IN,21
     C                     MOVEA'0'       *IN,29
     C           D1OPT     COMP '0'                      80
     C           D1OPT     COMP '1'                      81
     C           D1OPT     COMP '2'                      82
     C           D1HIN3    COMP *BLANK                   20
     C                     Z-ADD0         D2MAIS
     C                     Z-ADD0         D2SYOS
     C   82                Z-ADDWKSYOS    D2SYOS
     C                     Z-ADD0         D2SURY
     C   80                MOVEA'1'       *IN,29
     C*----------
     C           KEY01     SETLLGTBPL101
     C                     DO   *HIVAL
     C           KEY01     READEGTBPL101            N    10
     C   10                LEAVE
     C           IBSKJY    IFEQ 'D'                        DELETE CODE
     C           IBSKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C*:
     C                     LEAVE
     C                     ENDDO
     C*----------
     C  N82      *IN,10    IFEQ '0'
     C                     Z-ADDIBMAIS    D2MAIS
     C                     Z-ADDIBSYOS    D2SYOS
     C           D2MAIS    MULT IBSYOS    D2SURY
     C                     END
     C*
     C                     ENDSR
     C****************************************************************
     C           #UPD01    BEGSR                                     *
     C****************************************************************
     C                     MOVELD1HIN1    IBHIN1
     C                     MOVELD1HIN2    IBHIN2
     C                     MOVELD1HIN3    IBHIN3
     C                     TIME           @@TIME
     C*
     C           KEY01     CHAINGTBPL101             10
     C* OLD DATA=>FIELD INPUT
     C                     MOVE IBHIN1    ODHIN1  5
     C                     MOVE IBHIN2    ODHIN2  5
     C                     MOVE IBHIN3    ODHIN3  2
     C                     Z-ADDIBSYOS    ODSYOS  70
     C                     Z-ADDIBMAIS    ODMAIS  50
     C                     Z-ADDIBSURY    ODSURY  70
     C                     Z-ADDIBMAIS    WWMAIS  50
     C*
     C                     Z-ADDD2SYOS    IBSYOS
     C                     Z-ADDD2MAIS    IBMAIS
     C                     Z-ADDD2SURY    IBSURY
     C                     MOVELWKZETI    IBZETI
     C                     MOVE WKSEIH    IBSEIH           製品区分
     C                     Z-ADD*DATE     IBKOHZ
     C                     Z-ADD@TIME     IBKOTM
     C                     MOVELPPUSER    IBKOME
     C*
     C* DELETE MODE
     C*
     C           *IN80     IFEQ '1'
     C                     MOVE 'DEL DATA'OLDMSG  8
     C                     EXCPTOLD
     C                     EXCPTSP
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     END
     C                     MOVE 'D'       IBSKJY           DELETE CODE
     C                     Z-ADD*DATE     IBSKHZ
     C  N10                UPDATGTBPL101
      *--------------------*
      * 2004.11.08 MSK     *
      *--------------------*
     C           1         CHAINGTBPPNO1             29
     C           *IN29     IFEQ '0'
