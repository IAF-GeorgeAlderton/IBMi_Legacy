     C           *ENTRY    PLIST
     C                     PARM           PUS    10
      *
     C           KEY1      KLIST
     C                     KFLD           @HIN1
     C                     KFLD           @HIN2
     C                     KFLD           @HIN3
      *
     C           KEY2      KLIST
     C                     KFLD           @HIN1
     C                     KFLD           @HIN2
     C                     KFLD           @HIN3
     C                     KFLD           WKYM
      *
     C           KEY3      KLIST
     C                     KFLD           @KYY
     C                     KFLD           @KMM
      *
     C*----------------------------------------------------*
     C*                   １画面                         *
     C*----------------------------------------------------*
      *
     C           STP1      TAG
     C                     MOVE *BLANK    @KOKU
     C                     MOVE *BLANK    @KYY
     C                     MOVE *BLANK    @KMM
     C                     MOVE *BLANK    @HIN
      *
     C           STP2      TAG
     C                     Z-ADD0         #PH
     C                     Z-ADD0         #MH
     C                     MOVE *BLANK    #ZM
     C                     MOVE *BLANK    @HOL
     C                     EXFMTCTAPW011
     C                     SETOF                     010203
     C                     SETOF                     04
     C                     SETOF                     99
      *-------*
      * CMD-1 *
      *-------*
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *------*
      *更新*
      *------*
     C           @KOKU     IFNE '0'
     C           @KOKU     ANDNE'1'
     C           @KOKU     ANDNE'2'
     C                     SETON                     0199
     C                     MOVELER,1      MSG
     C                     GOTO STP2
     C                     END
      *
     C                     SETOF                     01
     C                     Z-ADD1         A       20
     C           @KOKU     LOKUPWKJ1,A                   01
     C           *IN01     IFEQ '1'
     C                     MOVE WKJ2,A    WKSNM
     C                     SETOF                     01
     C                     END
      *------------*
      *計画予定日*
      *------------*
     C           @KYY      IFLT 1994
     C           @KMM      ORLT 1
     C           @KMM      ORGT 12
     C                     SETON                     0299
     C                     MOVELER,2      MSG
     C                     GOTO STP2
     C                     END
      *
     C                     MOVEL@KYY      WKYM    60
     C                     MOVE @KMM      WKYM
     C                     MOVEL*YEAR     WUKYM   60
     C                     MOVE UMONTH    WUKYM
      *
     C           WKYM      IFLT WUKYM
     C                     SETON                     0299
     C                     MOVELER,3      MSG
     C                     GOTO STP2
     C                     END
      *------*
      *品番*
      *------*
     C           @HIN1     IFEQ *BLANK
     C           @HIN2     ANDEQ*BLANK
     C           @HIN3     ANDEQ*BLANK
     C                     SETON                     0399
     C                     MOVELER,4      MSG
     C                     GOTO STP2
     C                     END
      *--------------------------------------*
      *平準化確定発注ファイル／品番チェック*
      *--------------------------------------*
     C                     SETOF                     03
     C           KEY1      CHAINCABPL011             03
     C           *IN03     IFEQ '0'
     C           C3SKJY    ANDEQ'D'
     C           C3SKHZ    ANDLE*DATE
     C                     SETON                     03
     C                     END
     C           @KOKU     IFEQ '2'
     C           *IN03     IFEQ '1'
     C                     SETON                     99
     C                     MOVELER,5      MSG
     C                     GOTO STP2
     C                     END
     C                     END
      *----------------------------------*
      *Ａ－ＰＩＣＳ計画発行受注ファイル*
      *----------------------------------*
     C                     SETOF                     98
     C           KEY2      CHAINCTAPL011             98
      *
     C*取消OR変更
     C           @KOKU     IFEQ '0'
     C           @KOKU     OREQ '1'
     C           *IN98     IFEQ '1'
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVELER,6      MSG
     C                     GOTO STP2
     C                     END
      *
     C           CISKJY    IFEQ 'D'
     C           CISKHZ    ANDLE*DATE
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVELER,7      MSG
     C                     GOTO STP2
     C                     END
     C                     END
      *
     C*追加
     C           @KOKU     IFEQ '2'
     C           *IN98     IFEQ '0'
     C           CISKJY    IFEQ 'D'
     C           CISKHZ    ANDLE*DATE
     C                     ELSE
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVELER,8      MSG
     C                     GOTO STP2
     C                     END
     C                     END
     C                     END
      *計画予定日
     C                     MOVE '    .  ' @KYM
     C                     MOVEL@KYY      @KYM
     C                     MOVE @KMM      @KYM
      *品番
     C                     MOVE '-'       WH1
     C                     MOVE '-'       WH2
     C           @HIN3     IFEQ *BLANK
     C                     MOVE *BLANK    WH2
     C                     END
      *収容数
     C                     Z-ADDC3SJSU    @SYUSU
      *前工程
     C                     MOVE *BLANK    @MAENM
     C                     SETOF                     04
     C           C3MBCD    CHAINFGBPL011             04
     C           *IN04     IFEQ '0'
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVE B2SMEI    @MAENM
     C                     END
     C                     END
      *フィールドクリア
     C           @KOKU     IFEQ '2'
     C                     Z-ADD0         #PH
     C                     Z-ADD0         #MH
     C                     MOVE *BLANK    #ZM
     C                     END
      *
     C                     SETOF                     03
      *
     C*青山カレンダーチェック
     C                     EXSR $HOLI
      *
     C*----------------------------------------------------*
     C*                   ２画面                         *
     C*----------------------------------------------------*
      *
     C           STP4      TAG
     C                     EXFMTCTAPW012
     C                     SETOF                     010203
     C                     SETOF                     040506
     C                     SETOF                     070809
     C                     SETOF                     101112
     C                     SETOF                     131415
     C                     SETOF                     161718
     C                     SETOF                     192021
     C                     SETOF                     222324
     C                     SETOF                     252627
     C                     SETOF                     282930
     C                     SETOF                     3199
      *
     C           *INKC     IFEQ '1'
     C                     GOTO STP1
     C                     END
      *
     C                     DO   31        A
     C           #PH,A     IFNE 0
     C           #MH,A     ANDNE0
     C                     MOVE '1'       *IN,A
     C                     MOVE '1'       *IN99
     C                     MOVE ER,09     MSG
     C                     END
     C  N97                END
      *
     C  NKE                GOTO STP4
      *
     C*----------------------------------------------------*
     C*                   データ更新                     *
     C*----------------------------------------------------*
     C                     TIME           WTIME
     C                     Z-ADD*DATE     CIKOHZ
     C                     Z-ADDJI        CIKOHH
     C                     Z-ADDFU        CIKOSS
     C                     MOVE PUS       CIKOME
      *
     C           @KOKU     IFEQ '0'
     C                     MOVE 'D'       CISKJY
     C                     Z-ADD*DATE     CISKHZ
     C                     ELSE
     C                     MOVE *BLANK    CISKJY
     C                     Z-ADD0         CISKHZ
     C                     END
      *
     C                     MOVE @HIN1     CISHN1
     C                     MOVE @HIN2     CISHN2
     C                     MOVE @HIN3     CISHN3
     C                     MOVE WKYM      CIKEYM
      *
     C           *IN98     IFEQ '0'
     C                     UPDATCTAPL011
     C                     ELSE
     C                     WRITECTAPL011
     C                     END
      *
     C*****************************************************************
     C*         青山カレンダーチェック
     C*****************************************************************
     C           $HOLI     BEGSR                                      $
      *
     C*休日'*XX*'
     C                     MOVEA'00000000'*IN,41
     C                     MOVEA'00000000'*IN,49
     C                     MOVEA'00000000'*IN,57
     C                     MOVEA'0000000' *IN,65
     C                     MOVE *BLANK    @HOL
      *
     C                     Z-ADD0         N       20
     C                     Z-ADD1         A
     C           KEY3      SETLLAGDPL121
     C           1         DO   31        A
     C                     SETOF                     80
     C           KEY3      READEAGDPL121                 80
     C           *IN80     IFEQ '0'
     C                     MOVE *BLANK    WHOL
     C                     MOVELA         WHH23
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     MOVE '*'       WHH1
     C                     MOVE '*'       WHH4
     C                     END
     C           WHH2      IFEQ '0'
     C                     MOVE *BLANK    WHH2
     C                     END
     C                     MOVE WHOL      @HOL,A
     C                     END
     C                     END
      *
     C* 今日以前は入力禁止
     C                     Z-ADD1         A
     C                     Z-ADD0         N
     C           1         DO   31        A
     C           A         ADD  40        N
      *
     C           WKYM      IFEQ WUKYM
     C           A         IFLE UDAY
     C                     MOVE '1'       *IN,N
     C                     END
     C                     END
      *
     C                     MOVE @HOL,A    WHOL
     C           WHH1      IFEQ '*'
     C                     MOVE '1'       *IN,N
     C                     END
     C           WHH23     IFEQ *BLANK
     C                     MOVE '1'       *IN,N
     C                     END
     C                     END
      *
     C           WKYM      IFLT WUKYM
     C                     Z-ADD1         A
     C                     Z-ADD0         N
     C           1         DO   31        A
     C           A         ADD  40        N
     C                     MOVE '1'       *IN,N
     C                     END
     C                     END
      *
     C                     ENDSR
