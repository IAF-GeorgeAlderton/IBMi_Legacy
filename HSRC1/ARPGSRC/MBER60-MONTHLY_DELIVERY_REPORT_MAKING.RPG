     C           *ENTRY    PLIST
     C                     PARM           PDEST  50
      *================================================================
     C*
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CRT    '#CRT             作成
     C                     ENDCS
     C                     ENDDO
     C*
     C                     MOVELD1DEST    PDEST
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      * 初期ﾈｮmb
      *===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
      *
     C                     CLEARDSP01
     C                     MOVELPDEST     D1DEST
     C                     TIME           @TIME
     C*
     C           *NAMVAR   DEFN MCEDP01   @@YMD
     C                     IN   @@YMD
     C                     Z-ADD@@YY      D1YY
     C                     Z-ADD@@MM      D1MM
     C*
     C                     MOVEL*BLANK    D1MSG
     C*
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
     C*===============================================================
      *画面１*
     C*===============================================================
     C           #DSP1     BEGSR
     C                     EXFMTDSP01
     C                     MOVEA'0'       *IN,99
      *----*
     C                     SELEC
     C* F1 *
     C           *INKA     WHEQ *ON
     C                     MOVE '#END    '@STEP
     C* F5 *
     C           *INKE     WHEQ *ON
     C                     MOVE '#CRT    '@STEP
     C******
     C                     OTHER
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSL
      *----*
     C                     ENDSR
      *===============================================================
      *  MONTHLY DELIVERY REPORT MAKING
      *===============================================================
     C           #CRT      BEGSR
      *
     C*-------------------------
     C           KEY01     KLIST
     C                     KFLD           K@SHN1  5        SPART NUMBER 1
     C                     KFLD           K@SHN2  5        SPART NUMBER 2
     C                     KFLD           K@SHN3  2        SPART NUMBER 3
      *
      * DELIVERY MONTHLY REPORT FILE
     C           *LOVAL    SETLLMBEPL02
     C                     MOVEL' '       @UMU    1
      *-------------------------
      *-------------------------
S1   C                     DO   *HIVAL
     C                     READ MBEPL02                  90
     C   90                LEAVE
     C           F2SKJY    IFEQ 'D'                        DELETE FLAG
     C                     ITER
     C                     ENDIF
     C*
     C                     MOVELF2SHN1    K@SHN1           SPART NUMBER 1
     C                     MOVELF2SHN2    K@SHN2           SPART NUMBER 2
     C                     MOVELF2SHN3    K@SHN3           SPART NUMBER 3
     C                     EXSR ##HIN                      品番編集
     C                     Z-ADD0         $$GOKE 110
     C                     Z-ADD0         T       30
     C                     Z-ADD0         @T
     C                     Z-ADD0         N       30
     C                     Z-ADD0         @N
     C*品番単位の集計
     C           KEY01     SETLLMBEPL02
     C*--------------------
     C*--------------------
 S2  C                     DO   *HIVAL
     C           KEY01     READEMBEPL02                  91
     C   91                LEAVE
     C           F2SKJY    IFEQ 'D'                        DELETE FLAG
     C                     ITER
     C                     ENDIF
     C*
     C           F2TOKU    LOKUP@T                       50CUSTOMER
     C           *IN50     IFEQ *OFF
     C                     ADD  1         T
     C                     Z-ADDF2TOKU    @T,T
     C                     ENDIF
     C           F2NONY    LOKUP@N                       50DELIVERY
     C           *IN50     IFEQ *OFF
     C                     ADD  1         N
     C                     Z-ADDF2NONY    @N,N
     C                     ENDIF
     C                     ADD  F2GOKE    $$GOKE
     C                     ENDDO
     C*--------------------
     C*--------------------
     C                     EXSR ##OUT
     C*  ::
     C           KEY01     SETGTMBEPL02
     C*  ::
     C                     ENDDO
     C*-------------------------
     C*-------------------------
     C           @UMU      IFEQ ' '
     C                     SETON                     99
     C                     MOVELER,1      D1MSG
     C                     MOVE '#DSP1   '@STEP
     C                     ELSE
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *品番編集
      *===============================================================
     C           ##HIN     BEGSR
     C           KEY01     CHAINFCEPL01              95
     C                     Z-ADD0         $$GEKN  90
     C                     Z-ADD0         $$SYS   50
     C                     MOVEL*BLANK    $$KTRK  1
     C                     MOVEL*BLANK    $$KTRT  2
     C                     MOVEL*BLANK    $$KTRR  2
     C                     MOVEL*BLANK    $$KTRD  1
S1   C           *IN95     IFEQ *OFF
     C           A2GSKD    ANDNE'D'
     C                     Z-ADDA2GEKN    $$GEKN
     C           A2SYHZ    IFGT *DATE
     C                     Z-ADDA2KSYS    $$SYS
     C                     ELSE
     C                     Z-ADDA2SSYS    $$SYS
     C                     ENDIF
     C           A2TRHZ    IFGT *DATE
     C                     MOVELA2KTRK    $$KTRK
     C                     MOVELA2KTRT    $$KTRT
     C                     MOVELA2KTRR    $$KTRR
     C                     MOVELA2KTRD    $$KTRD
     C                     ELSE
     C                     MOVELA2STRK    $$KTRK
     C                     MOVELA2STRT    $$KTRT
     C                     MOVELA2STRR    $$KTRR
     C                     MOVELA2STRD    $$KTRD
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVELF2MHN1    W1MHN1
     C                     MOVELF2MHN2    W1MHN2
     C                     MOVELF2MHN3    W1MHN3
     C                     MOVELF2MHN4    W1MHN4
     C                     MOVE '-'       W1MHF1
     C                     MOVE '-'       W1MHF2
     C                     MOVE '-'       W1MHF3
     C           W1MHN4    IFEQ *BLANK
     C                     MOVE ' '       W1MHF3
     C           W1MHN3    IFEQ *BLANK
     C                     MOVE ' '       W1MHF2
     C           W1MHN2    IFEQ *BLANK
     C                     MOVE ' '       W1MHF1
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     MOVELF2SHN1    W1SHN1
     C                     MOVELF2SHN2    W1SHN2
     C                     MOVELF2SHN3    W1SHN3
     C                     MOVE '-'       W1SHF1
     C                     MOVE '-'       W1SHF2
     C           W1SHN3    IFEQ *BLANK
     C                     MOVE ' '       W1SHF2
     C           W1SHN2    IFEQ *BLANK
     C                     MOVE ' '       W1SHF1
     C                     ENDIF
     C                     ENDIF
     C                     ENDSR
