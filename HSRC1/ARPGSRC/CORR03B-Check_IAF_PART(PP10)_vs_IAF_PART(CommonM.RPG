     H            Y/                                    1
     H** CORR03B ******************************************************
     H*  CHECK IAF PART(PP10) VS IAF PART(COMMONM) BY SHIP DATE       *
     H*  JW   2022.05.13                                              *
     F*---------------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'CORR03B'
     F*                    PARM           $SHPD   8
     F*                    PARM           $NONY   4
     F*                    PARM           $SHP    1
     F*                    PARM           $UPD    1
     F*                    PARM           $RTN    1
     F*   IN  $SHPD:  8A SHIP DATE (START FROM)
     F*       $NONY:  4A DELIVERY# (BLANK=ALL)
     F*       $SHP :  1A Y=INCLUDE SHIPPED, N=NOT SHIP YET
     F*       $UPD :  1A Y=UPDATE, N=NOT UPDATE
     F*   OUT $RTN :  1A *=THERE IS ERROR, BLANK=NO ERROR
     H*****************************************************************
     FAB#PL1A UF  E           K        DISK
     FAB#PLAE UF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *================================================================
     I            DS
     I                                        1  20 BAMHIN
     I                                        1   5 BAMHN1
     I                                        6  10 BAMHN2
     I                                       11  15 BAMHN3
     I                                       16  20 BAMHN4
     I            DS
     I                                        1  12 BASHIN
     I                                        1   5 BASHN1
     I                                        6  10 BASHN2
     I                                       11  12 BASHN3
     I            DS
     I                                        1  12 @SHIN
     I                                        1   5 @SHN1
     I                                        6  10 @SHN2
     I                                       11  12 @SHN3
     I            DS
     I                                        1   80BAURHZ
     I                                        1   40BAURYY
     I                                        5   60BAURMM
     I                                        7   80BAURDD
     I            DS
     I                                        1  140@TIME
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                     *PROGRAM #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I                                      264 269 #JBNO
      *===============================================================
      *  START  PROGRAM
      *===============================================================
     C                     EXSR #INIT
      *
     C           @SHPD     SETLLAB#PL1A
     C                     DO   *HIVAL
     C                     READ AB#PL1A                  98
     C   98                LEAVE
      *
     C           BASKJY    IFEQ 'D'
     C**         BAURYY    ORNE 0
     C                     ITER
     C                     ENDIF
      * NOT SHIP YET?
     C           $SHP      IFEQ 'N'
     C           BAURYY    ANDNE0
     C                     ITER
     C                     ENDIF
      *
     C           @NONY     IFNE 0
     C           BANONY    ANDNE@NONY
     C                     ITER
     C                     ENDIF
      * GET IAF PART
     C                     MOVELBATOKU    PTOKU
     C                     MOVELBANONY    PNONY
     C                     MOVELBANKOJ    PNKOJ
     C                     MOVELBANUKE    PNUKE
     C                     MOVELBAMHIN    @MHIN
     C                     MOVEL*BLANK    @SHIN
     C                     MOVEL*BLANK    @FLG
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           @MHIN  20
     C                     PARM           @SHIN  12
     C                     PARM           @FLG    1
      *
     C                     MOVEL@SHIN     $SHIN
     C                     MOVELTODAY     $DATE
     C                     MOVE 'Y'       $SRV
      * GET QPC FROM SERVICE PART#
     C                     CALL 'UTLR35B'
     C                     PARM           $SHIN  12
     C                     PARM           $DATE   8
     C                     PARM           $SRV    1
     C                     PARM           $SYOS   6
     C                     PARM           $RTN    1
     C                     MOVEL$SYOS     @QPC    60
      *
      * IAF PART
     C           BASHIN    IFNE @SHIN
     C**         BASHIN    ANDEQBAMHIN
     C                     MOVE '*'       $RTN
     C                     EXSR #PRINT
      * UPDATE
     C           $UPD      IFEQ 'Y'
     C                     Z-ADD@QPC      BASYOS
     C                     MOVEL@SHIN     BASHIN
     C                     UPDATAB#PL141
      * UPDATE PPA1
     C                     EXSR #UPA1
      *
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  UPDATE AB#PPA1                                    *
      *----------------------------------------------------*
     C           #UPA1     BEGSR
      *
     C                     MOVELBAMHN1    KAMHN1
     C                     MOVELBAMHN2    KAMHN2
     C                     MOVELBAMHN3    KAMHN3
     C                     MOVELBAMHN4    KAMHN4
     C                     MOVELBANONY    KANONY
     C                     MOVELBANOYY    KANOYY
     C                     MOVELBANOMM    KANOMM
     C                     MOVELBANODD    KANODD
     C                     MOVELBANOBN    KANOBN
     C                     MOVELBAODRN    KAODRN
      *
     C           K#PLAE    SETLLAB#PLAE
     C                     DO   *HIVAL
     C           K#PLAE    READEAB#PLAE                  98
     C   98                LEAVE
      *
     C           BASKJY    IFEQ 'D'
     C           BAURYY    ORNE 0
     C                     ITER
     C                     ENDIF
      * IAF PART
     C           BASHIN    IFNE @SHIN
     C                     MOVEL@SHIN     BASHIN
     C                     UPDATAB#PLAE1
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      * EDIT
     C           BASHIN    IFEQ @SHIN
     C                     MOVE ' '       SFLG
     C                     ELSE
     C                     MOVE 'X'       SFLG
     C                     ENDIF
      *
     C           BASYOS    IFEQ @QPC
     C                     MOVE ' '       QFLG
     C                     ELSE
     C                     MOVE 'X'       QFLG
     C                     ENDIF
      * DETAIL
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *===============================================================
      * INITIAL SETTINGS
      *===============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SHPD   8
     C                     PARM           $NONY   4
     C                     PARM           $SHP    4
     C                     PARM           $UPD    1
     C                     PARM           $RTN    1
      * SET KEY
     C           K#PLAE    KLIST
     C                     KFLD           KAMHN1
     C                     KFLD           KAMHN2
     C                     KFLD           KAMHN3
     C                     KFLD           KAMHN4
     C                     KFLD           KANONY
     C                     KFLD           KANOYY
     C                     KFLD           KANOMM
     C                     KFLD           KANODD
     C                     KFLD           KANOBN
     C                     KFLD           KAODRN
      *
     C           *LIKE     DEFN BAMHN1    KAMHN1
     C           *LIKE     DEFN BAMHN2    KAMHN2
     C           *LIKE     DEFN BAMHN3    KAMHN3
     C           *LIKE     DEFN BAMHN4    KAMHN4
     C           *LIKE     DEFN BANONY    KANONY
     C           *LIKE     DEFN BANOYY    KANOYY
     C           *LIKE     DEFN BANOMM    KANOMM
     C           *LIKE     DEFN BANODD    KANODD
     C           *LIKE     DEFN BANOBN    KANOBN
     C           *LIKE     DEFN BAODRN    KAODRN
      *
     C                     MOVEL$SHPD     @SHPD   80
     C                     MOVE *BLANK    $RTN
     C                     MOVE *BLANK    SFLG    1
     C                     MOVE *BLANK    QFLG    1
     C                     TIME           @TIME
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
      *
     C           $NONY     IFEQ *BLANK
     C           $NONY     OREQ '0000'
     C                     Z-ADD0         @NONY   40
     C                     ELSE
     C                     MOVEL$NONY     @NONY
     C                     ENDIF
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   14 'UPD='
     O                         $UPD      15
     O                                   50 '** IAF PART(PP10) VS'
     O                                   70 ' IAF PART(COMMON)  *'
     O                                   90 '*                   '
     O                                  101 'DATE'
     O                         TODAY    104 '    .  .  '
     O                         NOW      114 '  :  :  '
     O                                  118 'P.'
     O                         PAGE  Z  122
     O        E   02           @HDR
     O                                    1 '.'
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   12 'CUST'
     O                                   19 'DELV'
     O                                   23 'F'
     O                                   30 'DOCK'
     O                                   45 'SHP_DATE  BIN'
     O                                   58 'USER_PART#'
     O                                   78 'IAF_PART#   '
     O                                   96 'COMMON M/F   '
     O                                  104 'QPC'
     O                                  114 'QPC'
     O                                  127 'BIL_DATE'
     O        E 1              @HDR
     O                                   56 '(PP10)'
     O                                   74 '(PP10)'
     O                                   90 '(S/B)'
     O                                  106 '(PP10)'
     O                                  115 '(S/B)'
     O        E 1              @HDR
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O                                  120 '--------------------'
     O                                  132 '------------'
     O        E 1              @DTL
     O                         SEQ#    +001
     O                         BATOKU  +003
     O                         BANONY  +003
     O                         BANKOJ  +003
     O                         BANUKE  +003
     O                         BANOYY  +002
     O                                 +000 '/'
     O                         BANOMM  +000
     O                                 +000 '/'
     O                         BANODD  +000
     O                         BANOBN  +001
     O                         BAMHN1  +003
     O                         BAMHN2  +001
     O                         BAMHN3  +001
     O                         SFLG    +001
     O                         BASHN1  +001
     O                         BASHN2  +001
     O                         BASHN3  +001
     O                         @SHN1   +001
     O                         @SHN2   +001
     O                         @SHN3   +001
     O                         QFLG    +001
     O                         BASYOS1 +000
     O                         @QPC  1 +002
     O                         BAURHZ  +001 '    /  /  '
