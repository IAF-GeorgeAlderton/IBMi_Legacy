     C                     SETON                     LR
     C                     RETRN
      *
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      *    DISPLAY 1ST SCREEN
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTAB#PWAT1
     C                     MOVEL*BLANK    D1ERR
      * F12: BACK
     C           *IN12     IFEQ '1'
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      * F8: NEXT WEEK
     C*******    *IN51     IFEQ '1'
     C           *INKH     IFEQ '1'
     C           WKP       IFLT MAXP
     C                     ADD  1         WKP
     C                     EXSR #SET
     C                     ENDIF
     C                     ENDIF
      * F7: PREV WEEK
     C******     *IN52     IFEQ '1'
     C           *INKG     IFEQ '1'
     C           WKP       IFNE 1
     C                     SUB  1         WKP
     C                     EXSR #SET
     C                     ENDIF
     C                     ENDIF
JW2   * F10: MACHINE DETAIL
 .   C           *INKJ     IFEQ *ON
 .   C                     CALL 'AB#CAO'
