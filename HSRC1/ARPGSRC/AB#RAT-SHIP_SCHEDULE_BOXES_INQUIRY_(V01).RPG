 |   C           *ENTRY    PLIST
JW1  C                     PARM           @PF     1
      *----------------------------------------------------*
      *   MAIN ROUTINE
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INITIAL SETTING
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVE '01'      DSPSW   2
      * SET DATE
     C                     CLEARDT
     C                     Z-ADD0         X       30
     C           W#WSID    SETLLAB#WPAT1
     C           W#WSID    READEAB#WPAT1                 81
     C           *IN81     DOWEQ'0'
     C                     ADD  1         X
     C                     Z-ADDW#DATE    DT,X
     C           W#WSID    READEAB#WPAT1                 81
     C                     ENDDO
      *
     C                     Z-ADD0         MAXP    20
     C           X         DIV  5         MAXP
     C                     MVR            AMR     20
     C           AMR       IFNE 0
     C                     ADD  1         MAXP
     C                     ENDIF
      * SET SIZE
     C                     CLEARDSI
     C**JW3                Z-ADD0         X       30
     C**         1         SETLLABBPP7G1
     C**                   READ ABBPP7G1                 81
     C**         *IN81     DOWEQ'0'
     C**         A#SKJY    IFEQ *BLANK
     C**                   MOVELA#SIZE    A#SIZ5  5 P
     C**         A#SIZ5    LOKUPDSI                      29
     C**         *IN29     IFEQ '0'
     C**                   ADD  1         X
     C**                   MOVELA#SIZE    DSI,X
     C**                   ENDIF
     C**                   ENDIF
     C**                   READ ABBPP7G1                 81
     C**                   ENDDO
     C**         X         IFLT 9
     C**                   ADD  1         X
     C**                   MOVEL'OTHER'   DSI,X
     C**                   ENDIF
      *
     C**         X         IFLT 9
     C**                   Z-ADD9         X
     C**                   MOVEL'TOTAL'   DSI,X
     C**                   ENDIF
      *
JW3  C                     MOVEL'NUT  '   DSI,1
 .   C                     MOVEL'M8   '   DSI,2
 .   C                     MOVEL'M10  '   DSI,3
 .   C                     MOVEL'M6   '   DSI,4
 .   C                     MOVEL'H/V  '   DSI,5
 .   C                     MOVEL'TS   '   DSI,6
 .   C                     MOVEL'E/G  '   DSI,7
 .   C                     MOVEL'OTHER'   DSI,8
JW3  C                     MOVEL'TOTAL'   DSI,9
      *
     C                     Z-ADD1         WKP     30
     C                     EXSR #SET
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      *    MAIN ROUTINE
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
