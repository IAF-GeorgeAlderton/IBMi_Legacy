      *
     C           *ENTRY    PLIST
     C                     PARM           NONY
     C                     PARM           KOJO
     C                     PARM           NUKE
     C                     PARM           FLG
      *------*
      * KEYS *
      *------*
     C           KEY1      KLIST
     C                     KFLD           NONY
     C                     KFLD           KOJO
     C                     KFLD           NUKE
     C                     KFLD           SHZYY
     C                     KFLD           SHZMM
     C                     KFLD           SHZDD
     C                     KFLD           SHN1
     C                     KFLD           SHN2
     C                     KFLD           SHN3
      *
     C           KEY2      KLIST
     C                     KFLD           NONY
     C                     KFLD           KOJO
     C                     KFLD           NUKE
     C                     KFLD           SHZYY
     C                     KFLD           SHZMM
     C                     KFLD           SHZDD
      *
     C           KEY3      KLIST
     C                     KFLD           NONY
     C                     KFLD           KOJO
     C                     KFLD           NUKE
      *****************************************
      *---------------------------------------*
      *<<<<<    ALDR50   EXECUSION       >>>>>*
      *---------------------------------------*
      *****************************************
     C           STP0      TAG
     C                     MOVE *BLANK    SHN1
     C                     MOVE *BLANK    SHN2
     C                     MOVE *BLANK    SHN3
     C                     Z-ADD0         NONY
     C                     MOVE *BLANK    KOJO
     C                     MOVE *BLANK    NUKE
     C                     Z-ADD0         SHIZK
     C                     Z-ADD0         EHIZK
      **********************
      *  DISPLAY 1 SCREEN  *
      **********************
     C           STP1      TAG
     C                     EXFMTALDPW501
     C                     SETOF                     010203
     C                     SETOF                     040506
     C                     SETOF                     99
      *
     C           *INKA     IFEQ '1'
     C                     MOVE '*'       FLG     1
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
      *---------------------*
      *  CHECK OF RCV CI.   *
      *---------------------*
     C           NONY      IFEQ 0
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     ENDIF
      *---------------------*
      *  CHECK OF FACTORY   *
      *---------------------*
     C           KOJO      IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     ENDIF
      *---------------------*
      *  CHECK OF RECEIVING *
      *---------------------*
     C           NUKE      IFEQ *BLANK
     C                     SETON                     0399
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     ENDIF
      *---------------------*
      *  CHECK OF PARTS NO  *
      *---------------------*
     C           HIN       IFEQ *BLANK
     C                     SETON                     0499
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     ENDIF
      *-----------------*
      *  CHECK OF DATE  *
      *-----------------*
     C           SHIZK     IFEQ 0
     C                     SETON                     0599
     C                     MOVE ER,5      MSG
     C                     GOTO STP1
     C                     ENDIF
     C           SHZMM     IFGT 12
     C                     SETON                     0599
     C                     MOVE ER,6      MSG
     C                     GOTO STP1
     C                     ENDIF
     C           SHZDD     IFGT 31
     C                     SETON                     0599
     C                     MOVE ER,7      MSG
     C                     GOTO STP1
     C                     ENDIF
      *
     C           EHIZK     IFEQ 0
     C                     SETON                     0699
     C                     MOVE ER,8      MSG
     C                     GOTO STP1
     C                     ENDIF
     C           EHZMM     IFGT 12
     C                     SETON                     0699
     C                     MOVE ER,6      MSG
     C                     GOTO STP1
     C                     ENDIF
     C           EHZDD     IFGT 31
     C                     SETON                     0699
     C                     MOVE ER,7      MSG
     C                     GOTO STP1
     C                     ENDIF
      *
     C           SHIZK     IFGT EHIZK
     C                     SETON                     0599
     C                     MOVE ER,8      MSG
     C                     GOTO STP1
     C                     ENDIF
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP1
     C                     ENDIF
      *
      *--------------*
      *  FILE READ   *
      *--------------*
     C                     MOVE *BLANK    SW      1
     C           SHN1      IFEQ '99999'
     C           SHN2      ANDEQ'99999'
     C           SHN3      ANDEQ'99'
     C                     MOVE '*'       SW
     C                     ENDIF
      *
     C                     MOVE *BLANK    DAB     1
     C                     SETOF                     50
     C*******    KEY3      SETLLALDPL221
     C           KEY2      SETLLALDPL221
     C                     DO   *HIVAL
     C           KEY3      READEALDPL221                 50
     C           *IN50     IFEQ '1'
     C                     GOTO ESC1
     C                     ENDIF
     C*          A1SYHZ    IFLT SHIZK
     C*                    GOTO ESC1
     C*                    ENDIF
     C           A1SYHZ    IFGT EHIZK
     C                     MOVE *ON       *IN50
     C                     GOTO ESC1
     C                     ENDIF
     C           SW        IFEQ *BLANK
     C           AHIN      IFNE HIN
     C                     GOTO ESC1
     C                     ENDIF
     C                     ENDIF
     C                     EXSR OUT1
     C                     MOVE '*'       DAB
     C           ESC1      TAG
     C  N50                ENDDO
      *
     C                     SETOF                     50
     C******     KEY3      SETLLALDPL321
     C           KEY2      SETLLALDPL321
     C                     DO   *HIVAL
     C           KEY3      READEALDPL321                 50
     C           *IN50     IFEQ '1'
     C                     GOTO ESC2
     C                     ENDIF
     C*          A3SYHZ    IFLT SHIZK
     C*                    GOTO ESC2
     C*                    ENDIF
     C           A3SYHZ    IFGT EHIZK
     C                     MOVE *ON       *IN50
     C                     GOTO ESC2
     C                     ENDIF
     C           SW        IFEQ *BLANK
     C           BHIN      IFNE HIN
     C                     GOTO ESC2
     C                     ENDIF
     C                     ENDIF
     C                     EXSR OUT2
     C                     MOVE '*'       DAB
     C           ESC2      TAG
     C  N50                ENDDO
      *
     C                     SETOF                     50
     C*******    KEY3      SETLLALDPL421
     C           KEY2      SETLLALDPL421
     C                     DO   *HIVAL
     C           KEY3      READEALDPL421                 50
     C           *IN50     IFEQ '1'
     C                     GOTO ESC3
     C                     ENDIF
     C*          A5SYHZ    IFLT SHIZK
     C*                    GOTO ESC3
     C*                    ENDIF
     C           A5SYHZ    IFGT EHIZK
     C                     MOVE *ON       *IN50
     C                     GOTO ESC3
     C                     ENDIF
     C           SW        IFEQ *BLANK
     C           CHIN      IFNE HIN
     C                     GOTO ESC3
     C                     ENDIF
     C                     ENDIF
     C                     EXSR OUT3
     C                     MOVE '*'       DAB
     C           ESC3      TAG
     C  N50                ENDDO
      *
     C           DAB       IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,9      MSG
     C                     GOTO STP1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
