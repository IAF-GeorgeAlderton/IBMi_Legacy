     C           *ENTRY    PLIST
     C                     PARM           PJOBM  10        ジョブ名
     C                     PARM           PUSER  10        ユーザー
     C                     PARM           PWNBR   6        ジョブ№
     C                     PARM           PENHZ   8        終了日付
     C                     PARM           PENTI   6        終了時刻
     C                     PARM           PEDTA  10        データエリア
     C                     PARM           PELIB  10        ライブラリ
     C                     PARM           PSTHZ   8        起動日付
     C                     PARM           PSTTI   6        起動時刻
     C                     PARM           PSPGM  10        起動プログラム
     C                     PARM           PPAR1  10        パラメータ１
     C                     PARM           PPAR2  10        パラメータ２
     C                     PARM           PSJOB  10        ジョブ名
     C                     PARM           PJOBD  10        ジョブ記述
     C                     PARM           PJOBQ  10        ジョブ待ち行列
     C                     PARM           PSDTA  10        データエリア
     C                     PARM           PSLIB  10        ライブラリ
      *
     C           KEY01     KLIST
     C                     KFLD           PJOBM
     C                     KFLD           PUSER
     C                     KFLD           PWNBR
      *
     C                     SETOF                     10
     C           KEY01     CHAINENDPP011             10
     C                     EXSR #SB001
     C           *IN10     IFEQ '0'
     C                     UPDATENDPP011
     C                     ELSE
     C                     WRITEENDPP011
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------*
      *          フィールド格納処理                       *
      *-----------------------------------------------------*
     C           #SB001    BEGSR
     C                     MOVEL*BLANK    E1SKJY
     C                     Z-ADD0         E1SKHZ
     C                     Z-ADD*DATE     E1KOHZ
     C                     TIME           E1KOTI
     C                     MOVEL@USID     E1KOME
     C                     MOVEL@PGM      E1KOPG
     C                     Z-ADD*DATE     E1DTHZ
      *
     C                     MOVELPJOBM     E1JOBM
     C                     MOVELPUSER     E1USER
     C                     MOVELPWNBR     E1WNBR
     C                     MOVE PENHZ     E1ENHZ
     C                     MOVE PENTI     E1ENTI
     C                     MOVEL*BLANK    E1EFLG
     C                     MOVELPEDTA     E1EDTA
     C                     MOVELPELIB     E1ELIB
     C                     MOVE PSTHZ     E1STHZ
     C                     MOVE PSTTI     E1STTI
     C                     MOVEL*BLANK    E1SFLG
     C                     MOVELPSPGM     E1SPGM
     C                     MOVELPPAR1     E1PAR1
     C                     MOVELPPAR2     E1PAR2
     C                     MOVELPSJOB     E1SJOB
     C                     MOVELPJOBD     E1JOBD
     C                     MOVELPJOBQ     E1JOBQ
     C                     MOVELPSDTA     E1SDTA
     C                     MOVELPSLIB     E1SLIB
     C           ESB001    ENDSR
