     H            Y.                                    1
      ** AFAR96 **************************
      *  PRINT MATERIAL SUPPLY ORDER LIST*
      *  BY ORDER NO.
      *  K.KASHIWAGI 2000.12.05          *
      *  COPY FROM AFAR95                *
      ******************* AFAR96 *********
     FAFAPL93 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *
     I            DS
     I                                        1  12 A9PAR
     I                                        1   5 A9PAR1
     I                                        6  10 A9PAR2
     I                                       11  12 A9PAR3
     I            DS
     I                                        1  12 O9PAR
     I                                        1   5 O9PAR1
     I                                        6  10 O9PAR2
     I                                       11  12 O9PAR3
     I            DS
     I                                        1   60A9ODNO
     I                                        1   20A9ODN1
     I                                        3   40A9ODN2
     I                                        5   60A9ODN3
     I            DS
     I                                        1   60O9ODNO
     I                                        1   20O9ODN1
     I                                        3   40O9ODN2
     I                                        5   60O9ODN3
     I            DS
     I                                        1  100A9OD
     I                                        1   40A9ODYY
     I                                        5   60A9ODMM
     I                                        7   80A9ODDD
     I                                        9  100A9ODBB
     I            DS
     I                                        1   80@9OD
     I                                        1   40@9ODYY
     I                                        5   60@9ODMM
     I                                        7   80@9ODDD
     I            DS
     I                                        1   80A9NO
     I                                        1   40A9NOYY
     I                                        5   60A9NOMM
     I                                        7   80A9NODD
     I            DS
     I                                        1   8 O9NO
     I                                        1   4 O9NOYY
     I                                        5   6 O9NOMM
     I                                        7   8 O9NODD
     I            DS
     I                                        1   80A9NY
     I                                        1   40A9NYYY
     I                                        5   60A9NYMM
     I                                        7   80A9NYDD
      *------*
      * PARM *
      *------*
     C           *ENTRY    PLIST
     C                     PARM           #FD    100
     C                     PARM           #TD    100
     C                     PARM           #SPCD   4
     C                     PARM           US     10
      *-----*
      * KEY *
      *-----*
     C           KEY1      KLIST
     C                     KFLD           B2CODE
      *-----*
     C           KEY2      KLIST
     C                     KFLD           A9SUPP
      *-----*
      * INZ *
      *-----*
      *
     C                     MOVELUS        WUSER   9
     C           *INOF     IFEQ '1'
     C                     MOVE A9SUPP    O9SUPP  40
     C                     EXCPTHD
     C                     MOVEL'Y'       DSW     1
     C                     SETOF                     OF
     C                     END
      *
     C*--------------*
     C* MAIN ROUTINE *
     C*--------------*
     C                     MOVEL*HIVAL    S@OD#   60       ORDER# SAVEAREA
     C                     MOVEL*HIVAL    S@SPCD  4        SAVE SUPP CD
     C*
     C           #SPCD     IFEQ *BLANKS
     C           *IN90     DOWEQ'0'
     C                     READ AFAPL93                  90
     C           *IN90     IFEQ '0'
     C                     Z-ADDA9ODYY    @9ODYY
     C                     Z-ADDA9ODMM    @9ODMM
     C                     Z-ADDA9ODDD    @9ODDD
     C           A9SKJY    IFEQ 'D'
     C           @9OD      ANDLE*DATE
     C                     ELSE
     C           #TD       IFEQ 0
     C                     MOVEL*HIVAL    #TD
     C                     ENDIF
     C           A9OD      IFGE #FD
     C                     MOVEL'-'       HY1     1
     C           A9PAR3    IFEQ *BLANKS
     C                     MOVEL*BLANKS   HY2     1
     C                     ELSE
     C                     MOVEL'-'       HY2     1
     C                     ENDIF
     C           A9HAKO    MULT A9SYOS    S@QTY   80       QTY WK AREA
     C                     Z-ADDS@QTY     OQTY    80
     C                     Z-ADD0         S@QTY
     C           A9HAKO    SUB  A9NOSU    S@NCB   30       NO REC BOX
     C           A9NOSU    IFGT A9HAKO
     C                     Z-ADD0         S@NCB
     C                     ENDIF
     C                     Z-ADDS@NCB     O9NRBX  30
     C                     Z-ADD0         S@NCB
     C*
     C           A9ODNO    IFNE S@OD#
     C           A9SUPP    ANDEQS@SPCD
     C                     MOVELA9SUPP    B2CODE
     C           KEY1      CHAINFGBPL01              50
     C           *IN50     IFEQ '0'
     C                     MOVELB2SMEI    WMEI   15
     C                     ENDIF
     C                     TIME           WTIME   60
     C                     MOVE A9SUPP    O9SUPP
     C                     MOVELA9ODNO    O9ODNO
     C                     MOVELA9ODNO    S@OD#
     C                     EXCPTHD
     C                     ENDIF
     C*
     C           A9OD      IFEQ 0
     C                     MOVEL*BLANKS   SL1     1
     C                     MOVEL*BLANKS   SL2     1
     C                     ELSE
     C                     MOVEL'/'       SL1
     C                     MOVEL'/'       SL2
     C                     ENDIF
     C           A9NY      IFEQ 0
     C                     MOVEL*BLANKS   SL3     1
     C                     MOVEL*BLANKS   SL4     1
     C                     ELSE
     C                     MOVEL'/'       SL3
     C                     MOVEL'/'       SL4
     C                     ENDIF
     C           A9NO      IFEQ 0
     C                     MOVEL*BLANKS   O9NO
     C                     MOVEL*BLANKS   SL5     1
     C                     MOVEL*BLANKS   SL6     1
     C                     ELSE
     C                     MOVE A9NO      O9NO
     C                     MOVEL'/'       SL5
     C                     MOVEL'/'       SL6
     C                     ENDIF
     C*
     C           A9SUPP    IFNE S@SPCD
     C                     MOVELA9SUPP    B2CODE
     C           KEY1      CHAINFGBPL01              50
     C           *IN50     IFEQ '0'
     C                     MOVELB2SMEI    WMEI   15
     C                     ELSE
     C                     MOVEL*BLANKS   WMEI
     C                     ENDIF
     C                     TIME           WTIME   60
     C                     MOVE A9SUPP    O9SUPP
     C                     MOVELA9ODNO    O9ODNO
     C                     MOVELA9SUPP    S@SPCD
     C                     EXCPTHD
     C                     MOVEL'Y'       DSW     1
     C                     ENDIF
     C*
     C           *INOF     IFEQ '1'
     C                     MOVE A9SUPP    O9SUPP
     C                     MOVELA9ODNO    O9ODNO
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     MOVEL'Y'       DSW     1
     C                     END
     C           S@OD#     IFNE A9ODNO
     C           DSW       OREQ 'Y'
     C                     EXCPTDT1
     C                     MOVEL*BLANKS   DSW
     C                     Z-ADDA9ODNO    S@OD#
     C                     ELSE
     C                     EXCPTDT2
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C*
     C                     ELSE
     C                     MOVEL#SPCD     A9SUPP
     C           KEY2      SETLLAFAPL93
     C           *IN90     DOWEQ'0'
     C           KEY2      READEAFAPL93                  90
     C           *IN90     IFEQ '0'
     C                     Z-ADDA9ODYY    @9ODYY
     C                     Z-ADDA9ODMM    @9ODMM
     C                     Z-ADDA9ODDD    @9ODDD
     C           A9SKJY    IFEQ 'D'
     C           @9OD      ANDLE*DATE
     C                     ELSE
     C           #TD       IFEQ 0
     C                     MOVEL*HIVAL    #TD
     C                     ENDIF
     C           A9OD      IFGE #FD
     C           A9OD      ANDLE#TD
     C*****      #SPCD     ANDEQA9SUPP
     C                     MOVEL'-'       HY1     1
     C           A9PAR3    IFEQ *BLANKS
     C                     MOVEL*BLANKS   HY2     1
     C                     ELSE
     C                     MOVEL'-'       HY2
     C                     ENDIF
     C           A9HAKO    MULT A9SYOS    S@QTY   80       QTY WK AREA
     C                     Z-ADDS@QTY     OQTY
     C                     Z-ADD0         S@QTY
     C           A9HAKO    SUB  A9NOSU    S@NCB   30       NO REC BOX
     C           A9NOSU    IFGT A9HAKO
     C                     Z-ADD0         S@NCB
     C                     ENDIF
     C                     Z-ADDS@NCB     O9NRBX
     C                     Z-ADD0         S@NCB
     C*
     C           A9ODNO    IFNE S@OD#
     C                     MOVELA9SUPP    B2CODE
     C           KEY1      CHAINFGBPL01              50
     C           *IN50     IFEQ '0'
     C                     MOVELB2SMEI    WMEI   15
     C                     ENDIF
     C                     TIME           WTIME   60
     C                     MOVELA9ODNO    O9ODNO
     C                     MOVELA9ODNO    S@OD#
     C                     MOVE A9SUPP    O9SUPP
     C                     EXCPTHD
     C                     ENDIF
     C*
     C*
     C           A9OD      IFEQ 0
     C                     MOVEL*BLANKS   SL1
     C                     MOVEL*BLANKS   SL2
     C                     ELSE
     C                     MOVEL'/'       SL1
     C                     MOVEL'/'       SL2
     C                     ENDIF
     C           A9NY      IFEQ 0
     C                     MOVEL*BLANKS   SL3
     C                     MOVEL*BLANKS   SL4
     C                     ELSE
     C                     MOVEL'/'       SL3
     C                     MOVEL'/'       SL4
     C                     ENDIF
     C           A9NO      IFEQ 0
     C                     MOVEL*BLANKS   O9NO
     C                     MOVEL*BLANKS   SL5
     C                     MOVEL*BLANKS   SL6
     C                     ELSE
     C                     MOVE A9NO      O9NO
     C                     MOVEL'/'       SL5
     C                     MOVEL'/'       SL6
     C                     ENDIF
     C*
     C           *INOF     IFEQ '1'
     C                     MOVE A9SUPP    O9SUPP
     C                     MOVELA9ODNO    O9ODNO
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     MOVEL'Y'       DSW
     C                     END
     C           S@OD#     IFNE A9ODNO
     C           DSW       OREQ 'Y'
     C                     EXCPTDT1
     C                     Z-ADDA9ODNO    S@OD#
     C                     MOVEL*BLANKS   DSW
     C                     ELSE
     C                     EXCPTDT2
     C                     ENDIF
     C*
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C*
     C                     ENDIF
     C*
     C                     MOVEL'1'       *INLR
     C                     RETRN
     OQPRINT  E  103           HD
     O                                  131 '､､､､､､､､､､､､､､､､､､､､､'
      *
     O        E  1             HD
     O                                   49 '** MATERIAL SUPPLY ORDER'
     O                                   73 ' LIST <LOCAL PROCURMENT '
     O                                   83 'SYSTEM> **'
     O                                  131 '､         ､         ､'
      *
     O        E  1             HD
     O                                   13 'SUPPLIER :'
     O                         O9SUPP    18
     O                         B2SMEI    34
     O                                   89 'TIME'
     O                         WTIME     98 '  :  :  '
     O                                  111 '､'
     O                                  121 '､'
     O                         WUSER    130
     O                                  131 '､'
      *
     O        E  1             HD
     O                                   13 'ORDER NO.:'
     O                         A9ODNO    20
     O                                   89 'DATE'
     O                         UDATE     98 '  .  .  '
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O                                  131 '､､､､､､､､､､､､､､､､､､､､､'
      *
     O        E  1             HD
     O                                   20 'ORDER INFORMATION'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   75 '---------------'
     O                                   99 '------------------------'
     O                                  119 'RECIEVE INFORMATION'
     O                                  131 '------------'
      *
     O        E  1             HD
     O                                   15 'ORDER NUMBER'
     O                                   26 'ORDER DATE'
     O                                   38 'PART NO.'
     O                                   50 'IDNO.'
     O                                   58 'LOT NO.'
     O                                   63 'QTY.'
     O                                   78 'QTY./BOX'
     O                                   82 'BOX'
     O                                   99 'REC. SCHED. DATE'
     O                                  108 'REC.DATE'
     O                                  119 'REC.BOX'
     O                                  131 'NO REC. BOX'
      *
     O        E  1             HD
     O                                   15 '------------'
     O                                   29 '-------------'
     O                                   44 '--------------'
     O                                   50 '-----'
     O                                   58 '-------'
     O                                   69 '----------'
     O                                   78 '--------'
     O                                   82 '---'
     O                                   99 '----------------'
     O                                  110 '----------'
     O                                  119 '-------'
     O                                  131 '-----------'
      *
     O        E  1             DT1
     O                         A9ODN1     5
     O                                    6 '-'
     O                         A9ODN2     8
     O                                    9 '-'
     O                         A9ODN3    11
     O                         A9ODYY    20
     O                         SL1       21
     O                         A9ODMM    23
     O                         SL2       24
     O                         A9ODDD    26
     O                                   27 '-'
     O                         A9ODBB    29
     O                         A9PAR1    35
     O                         HY1       36
     O                         A9PAR2    41
     O                         HY2       42
     O                         A9PAR3    44
     O                         A9ZETI    49
     O                         A9TEHI    54
     O                         OQTY      69 '  ,   ,   '
     O                         A9SYOS    78 '  ,   '
     O                         A9HAKOZ   82
