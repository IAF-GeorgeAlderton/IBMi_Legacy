     H            Y.
     F*** APLR10 *********************************
     F*文字列から数字に変換                    *
     F*   KIRI                      2014.04.10   *
     F*------------------------------------------*
     F********************************************
     E                    @I         20  1
     E                    @O         20  1
      *================================================================
     I            DS
     I                                        1  20 @I
     I                                        1  20 W@IN
     I            DS
     I                                        1  20 @O
     I                                        1  20 W@OUT
     I                                       10  200W@S0
     I                                        9  201W@S1
     I                                        8  202W@S2
     I                                        7  203W@S3
     I                                        6  204W@S4
     I                                        5  205W@S5
     I                                        4  206W@S6
     I                                        3  207W@S7
     I                                        2  208W@S8
     I                                        1  209W@S9
      *================================================================
     C           *ENTRY    PLIST
     C                     PARM           P@IN   20        文字列
     C                     PARM           P@OUT  132       数字
     C                     PARM           P@NG    1
      *
     C                     MOVE P@IN      W@IN
     C                     MOVE *ALL'0'   W@OUT
     C                     Z-ADD0         P@OUT            数字
     C                     MOVE ' '       P@NG
      *
     C                     Z-ADD0         HG      20
     C                     Z-ADD20        Z1      20
     C                     Z-ADD20        Z2      20
     C                     Z-ADD0         Z3      20
     C                     Z-ADD0         ZTEN    20
      *-----------------------------------
     C                     DO   20
     C           @I,Z1     IFEQ '.'
     C                     Z-ADDZ3        ZTEN
     C                     ENDIF
     C*
     C           @I,Z1     IFEQ '0'
     C           @I,Z1     OREQ '1'
     C           @I,Z1     OREQ '2'
     C           @I,Z1     OREQ '3'
     C           @I,Z1     OREQ '4'
     C           @I,Z1     OREQ '5'
     C           @I,Z1     OREQ '6'
     C           @I,Z1     OREQ '7'
     C           @I,Z1     OREQ '8'
     C           @I,Z1     OREQ '9'
     C                     MOVE @I,Z1     @O,Z2
     C                     SUB  1         Z2
     C                     ADD  1         Z3
     C                     ENDIF
     C                     SUB  1         Z1
     C                     ENDDO
      *-----------------------------------
S1   C                     SELEC                           小数点以下
-1   C           ZTEN      WHEQ 1
     C                     Z-ADDW@S1      P@OUT            １桁
     C           Z2        IFLT 9
     C                     MOVE 'A'       P@NG
     C                     ENDIF
-1   C           ZTEN      WHEQ 2
     C                     Z-ADDW@S2      P@OUT            ２桁
     C           Z2        IFLT 8
     C                     MOVE 'A'       P@NG
     C                     ENDIF
-1   C           ZTEN      WHEQ 3
     C                     Z-ADDW@S3      P@OUT            ２桁
     C           Z2        IFLT 7
     C                     MOVE 'A'       P@NG
     C                     ENDIF
-1   C           ZTEN      WHEQ 4
     C                     Z-ADDW@S4      P@OUT            ２桁
     C           Z2        IFLT 6
     C                     MOVE 'A'       P@NG
     C                     ENDIF
-1   C           ZTEN      WHEQ 5
     C                     Z-ADDW@S5      P@OUT            ２桁
     C           Z2        IFLT 5
     C                     MOVE 'A'       P@NG
     C                     ENDIF
-1   C           ZTEN      WHEQ 6
     C                     Z-ADDW@S6      P@OUT            ２桁
     C           Z2        IFLT 4
     C                     MOVE 'A'       P@NG
     C                     ENDIF
-1   C           ZTEN      WHEQ 7
     C                     Z-ADDW@S7      P@OUT            ２桁
     C           Z2        IFLT 3
     C                     MOVE 'A'       P@NG
     C                     ENDIF
-1   C           ZTEN      WHEQ 8
     C                     Z-ADDW@S8      P@OUT            ２桁
     C           Z2        IFLT 2
     C                     MOVE 'A'       P@NG
     C                     ENDIF
-1   C           ZTEN      WHGE 9
     C                     Z-ADD0         P@OUT            ２桁
     C                     MOVE 'A'       P@NG
-1   C                     OTHER
     C                     Z-ADDW@S0      P@OUT            なし
     C           Z2        IFLT 10
     C                     MOVE 'A'       P@NG
     C                     ENDIF
     C                     ENDSL
      *
     C                     SETON                     LR
     C                     RETRN
      *
