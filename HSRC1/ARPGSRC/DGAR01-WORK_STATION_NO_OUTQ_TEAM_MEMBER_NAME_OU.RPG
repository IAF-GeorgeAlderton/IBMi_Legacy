     F**************************************** DGAR01 **
     FAJEPL01 IF  E           K        DISK
     FRGAPL11 IF  E           K        DISK
     I            DS
     I                                        1  10 UWS
     I                                        1   2 UKEY
     I                                        1   1 UKEY1
     C           *ENTRY    PLIST
     C                     PARM           WSID   10
     C                     PARM           PRT     7
     C                     PARM           PROF   10
     C                     PARM           NAME   10
     C                     PARM           PTIME   6
     C                     PARM           PRTID   2
     C                     MOVE WSID      UWS
      *
     C           KPARM     PLIST
     C                     PARM           PKINO   1
      *
     C           KEY1      KLIST
     C                     KFLD           PKINO
     C                     KFLD           UKEY
      *
     C                     CALL 'AJEC06'  KPARM
      *
     C                     SETOF                     01
     C           KEY1      CHAINAJEPL011             01
     C           *IN01     IFEQ '0'
     C           H4SKJY    ANDEQ'D'
     C           H4SKHZ    ANDLEUDATE
     C                     SETON                     01
     C                     END
      *
     C           *IN01     IFEQ '0'
