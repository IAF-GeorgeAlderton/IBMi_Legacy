      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#AGD     KLIST
     C                     KFLD           D@YY
     C                     KFLD           D@MM
     C           K#AB      KLIST
     C                     KFLD           K@PRT1  5
     C                     KFLD           K@PRT2  5
     C                     KFLD           K@PRT3  2
     C                     KFLD           D@YY    40
     C                     KFLD           D@MM    20
     C           K#ABX     KLIST
     C                     KFLD           K@PRT1  5
     C                     KFLD           K@PRT2  5
     C                     KFLD           K@PRT3  2
     C           K#FCE     KLIST
     C                     KFLD           K@PRT1  5
     C                     KFLD           K@PRT2  5
     C                     KFLD           K@PRT3  2
     C                     KFLD           K@PROC  3
     C                     KFLD           K@MCHN  3
     C           K#MFA     KLIST
     C                     KFLD           K@FACT  40
     C                     KFLD           K@MCHN  3
     C                     KFLD           K@PROC  3
      *
     C                     MOVEL'01'      W@ID    2
     C                     Z-ADD0111      K@FACT
      *
     C                     Z-ADD*YEAR     D@YY
     C                     Z-ADD*MONTH    D@MM
      *
     C                     Z-ADDD@YYMM    WWYYMM  60
      *
     C                     SUB  1         D@MM
     C           D@MM      IFEQ *ZERO
     C                     ADD  12        D@MM
     C                     SUB  1         D@YY
     C                     ENDIF
      *
     C                     ENDSR
      *-------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #WRT
     C                     MOVE '99'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *-------------------------------------------------------
     C           #CHK      BEGSR
      *
     C                     SETOF                     6199
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ELSE
     C           D@YYMM    IFGT WWYYMM
     C                     SETON                     6199
     C                     ENDIF
     C                     ENDIF
      *
     C           D@YYMM    MULT 100       W@YMD   80
     C                     ADD  1         W@YMD
      *
     C                     ENDSR
      *-------------------------------------------------------
     C           #WRT      BEGSR
      *
     C                     Z-ADDD@YYMM    P@YYMM  60
TCHK2C*                    CALL 'FCER59'
TCHK2C*                    PARM           P@YYMM
      *
TCHK2C*                    CALL 'FCER58'
TCHK2C*                    PARM           P@YYMM
      *
     C                     OPEN FCEPL50
      *
     C           *LOVAL    SETLLAB#PL09
     C           *IN80     DOUEQ*ON
     C                     READ AB#PL09                  80
     C           *IN80     IFEQ *OFF
     C           B1SKJY    ANDEQ*BLANK
     C                     MOVE B1SHN1    K@PRT1
     C                     MOVE B1SHN2    K@PRT2
     C                     MOVE B1SHN3    K@PRT3
     C                     CLEARFCEWP551
      *
     C           K#AB      SETLLAB#PL09
     C           *IN85     DOUEQ*ON
     C           K#AB      READEAB#PL09                  85
     C           *IN85     IFEQ *OFF
     C           B1SKJY    ANDEQ*BLANK
     C                     ADD  B1SRYO    FWSQTY
     C                     ENDIF
     C                     ENDDO
      *
     C           FWSQTY    IFGT *ZERO
     C                     EXSR #WRT1
     C                     ENDIF
      *
     C           K#ABX     SETGTAB#PL09
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-------------------------------------------------------
     C           #WRT1     BEGSR
      *
     C                     MOVE *OFF      *IN55
     C                     MOVE *BLANK    @PR
     C                     MOVELK@PRT1    @SHN1
     C                     MOVELK@PRT2    @SHN2
     C                     MOVELK@PRT3    @SHN3
     C                     Z-ADD*ZERO     FWCOST
     C           @SHN2     COMP *BLANK               1010
     C   10                MOVE '-'       @S1
     C           @SHN3     COMP *BLANK               1010
     C   10                MOVE '-'       @S2
      *
     C           K#ABX     CHAINAAMPL11              92
     C           *IN92     IFEQ *OFF
     C           1         DO   15        X       20
     C           PRC,X     IFNE *BLANK
     C           PRC,X     LOKUP@PR                      88
     C           *IN88     IFEQ *OFF
      *
     C                     MOVEL*BLANK    FWSUPP
     C           DPT,X     IFNE 0111
     C           DPT,X     CHAINFGBPL01              98
     C  N98                MOVELB2SMEI    FWSUPP
     C                     ENDIF
      *
     C                     MOVE PRC,X     FWPROC
     C                     MOVE MCN,X     FWMCNO
     C                     MOVE MCN,X     K@MCHN  3
     C                     MOVE PRC,X     K@PROC  3
     C                     MOVE *BLANK    FWCNTR
     C           K#MFA     CHAINMFAPL25              91
      *
TCHK1C                     Z-ADD*ZERO     FWCOST
     C           K#FCE     SETGTFCEPL50
     C           *IN90     DOUEQ*ON
     C           K#FCE     REDPEFCEPL50                  90
     C           *IN90     IFEQ *OFF
     C           F5VLDT    ANDLEW@YMD
     C                     Z-ADDF5COST    FWCOST
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           FWCOST    MULT FWSQTY    FWAMNT
      *
     C                     WRITEFCEWP551
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
TCHK1C                     ELSE
TCHK1C                     WRITEFCEWP551
     C                     ENDIF
      *
     C                     ENDSR
