      ******************************************************
      * MAIN ROUTINE
      ******************************************************
     C                     EXSR #INIT
      *
     C                     MOVE *ON       *IN85            SET PRINT FLG
     C                     MOVE 'Y'       FIRST
     C                     EXSR #PROC
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C******************************************************
     C* PRINT PROCESS
     C******************************************************
     C           #PROC     BEGSR
      *
     C                     MOVE *ON       *IN70            OVERFLOW FLAG
     C           *LOVAL    SETLLABWPP31
      *
     C                     DO   *HIVAL
     C                     READ ABWPP31                  98
     C   98                LEAVE
      * FIRST
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELIINV#     SVINV# 16
     C                     ENDIF
      * BREAK ?
     C           THAKO     IFGE PMXPL
     C           IINV#     ORNE SVINV#
     C                     EXSR #BRK1
     C                     ENDIF
      * DETAIL PROCESS
     C                     EXSR #DTL1
      *
     C                     ENDDO
      *
      * PRINT LAST PAGE
     C           THAKO     IFGT 0
     C                     EXSR #BRK1
     C                     ENDIF
      *
     C                     ENDSR
     C******************************************************
     C* PRINT DETAIL LINE
     C******************************************************
     C           #DTL1     BEGSR
     C                     Z-ADDFC#BOX    WHAKO
      * HEADER
     C                     EXSR #HDR
      * ADJUST
     C                     EXSR #ADJ
      * PRINT D
     C   85                WRITEAB#PR442
      *
     C                     ADD  WHAKO     THAKO
      *
     C                     ENDSR
     C******************************************************
     C* ADJUSTMENT
     C******************************************************
     C           #ADJ      BEGSR
      *
JW   C           W@INV#    IFEQ *BLANK
"    C                     MOVELIINV#     W@INV#
"    C                     ENDIF
     C           W@SBAN    IFEQ *BLANK
     C                     MOVELISBAN     W@SBAN
     C                     ENDIF
     C           W@MHN     IFEQ *BLANK
     C                     MOVELIMHN      W@MHN
     C                     ENDIF
      *
     C**         W@1ST     IFEQ *OFF
     C                     MOVELFCLOC1    W@LOC1
     C                     MOVELFCLOC2    W@LOC2
     C                     MOVELFCLOC3    W@LOC3
     C                     MOVELFCLOC4    W@LOC4
     C**                   MOVEL*ON       W@1ST
     C**                   ENDIF
      *
     C                     MOVE '-'       FLD1
     C                     MOVE '-'       FLD2
     C                     MOVE '-'       FLD3
     C                     MOVE '-'       FLD4
     C                     MOVE *BLANK    FLD5
     C                     SETOF                     11
     C                     SETOF                     60
     C                     SETOF                     12
      *
     C                     MOVE IMHN1     WMHN1
     C                     MOVE '-'       WMH1
     C                     MOVE IMHN2     WMHN2
     C                     MOVE '-'       WMH2
     C                     MOVE IMHN3     WMHN3
     C                     MOVE IMHN5     WMHN4
     C                     MOVE '-'       WMH5
     C                     MOVE IMHN6     WMHN6
     C                     MOVE IMHN7     WMHN7
     C                     MOVE '-'       WMH8
     C                     MOVE IMHN8     WMHN9
     C                     MOVE '-'       WMH10
     C                     MOVELIMHN9     WMHN11
      *
     C                     Z-ADDITOKU     KTOKU
     C                     Z-ADDINONY     KNONY            DELIVERY CODE
     C           KEY2      SETGTAB#PP85
     C           *IN90     DOUEQ*ON
     C           KEY2      REDPEAB#PP85                  90
     C           *IN90     IFEQ *OFF
     C           A5DATE    ANDLEINOHZ
     C                     MOVELA5SBAN    WSBAN     P
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C           *IN90     IFEQ *ON
     C                     MOVELISBAN     WSBAN     P
     C                     ENDIF
      *
     C                     MOVE YYYY      WNOYY
     C                     MOVE MM        WNOMM
     C                     MOVE DD        WNODD
     C                     MOVE '/'       WNO1
     C                     MOVE '/'       WNO2
      *
     C                     ENDSR
     C******************************************************
     C* BREAK
     C******************************************************
     C           #BRK1     BEGSR
      *
      * HEADER
     C                     EXSR #HDR
      * LARGE
     C                     EXSR #LARG
      *
     C   85                WRITEAB#PR443
     C                     SETON                     70
      *
     C                     MOVELIINV#     SVINV#
     C                     Z-ADD0         THAKO
      *
     C                     ENDSR
     C******************************************************
     C* EDIT PALLET
     C******************************************************
     C           #PLTED    BEGSR
     C                     MOVELD#PAGE    W@A5    5
     C                     MOVEAW@A5      T1
     C                     Z-ADD*ZERO     X       20
     C                     Z-ADD*ZERO     Y       20
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           X         IFGT 5
     C                     LEAVE
     C                     ENDIF
     C           T1,X      IFEQ *ZERO
     C                     ITER
     C                     ENDIF
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C                     MOVELT1,X      T2,Y
     C                     ADD  1         X
     C           X         IFGT 5
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C           X         IFGT 5
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C*
     C                     ADD  1         Y
     C                     MOVEL'/'       T2,Y
     C*
     C                     MOVELT#PAGE    W@A5
     C                     MOVEAW@A5      T1
     C                     Z-ADD*ZERO     X       20
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           X         IFGT 5
     C                     LEAVE
     C                     ENDIF
     C           T1,X      IFEQ *ZERO
     C                     ITER
     C                     ENDIF
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C                     MOVELT1,X      T2,Y
     C                     ADD  1         X
     C           X         IFGT 5
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C           X         IFGT 5
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C*
     C                     MOVEAT2        @#PLT
     C*
     C                     ENDSR
     C******************************************************
     C* PRINT LARDE CHARACTER
     C******************************************************
     C           #LARG     BEGSR
      *
     C                     MOVELWNOMM     WW,1
     C                     MOVE WNOMM     WW,2
     C                     MOVELWNODD     WW,3
     C                     MOVE WNODD     WW,4
     C*
     C           1         DO   4         CC      10
     C*
     C                     MOVE *BLANKS   #L1
     C                     MOVE *BLANKS   #L2
     C                     MOVE *BLANKS   #L3
     C                     MOVE *BLANKS   #L4
     C                     MOVE *BLANKS   #L5
     C                     MOVE *BLANKS   #L6
     C                     MOVE *BLANKS   #L7
     C                     MOVE *BLANKS   #L8
     C                     MOVE WW,CC     #CHR
     C                     CALL 'AB#R4P'  P#CMD
     C           CC        IFEQ 1
     C                     MOVE #L1       #11
     C                     MOVE #L2       #12
     C                     MOVE #L3       #13
     C                     MOVE #L4       #14
     C                     MOVE #L5       #15
     C                     MOVE #L6       #16
     C                     MOVE #L7       #17
     C                     MOVE #L8       #18
     C                     ENDIF
     C           CC        IFEQ 2
     C                     MOVE #L1       #21
     C                     MOVE #L2       #22
     C                     MOVE #L3       #23
     C                     MOVE #L4       #24
     C                     MOVE #L5       #25
     C                     MOVE #L6       #26
     C                     MOVE #L7       #27
     C                     MOVE #L8       #28
     C                     ENDIF
     C           CC        IFEQ 3
     C                     MOVE #L1       #31
     C                     MOVE #L2       #32
     C                     MOVE #L3       #33
     C                     MOVE #L4       #34
     C                     MOVE #L5       #35
     C                     MOVE #L6       #36
     C                     MOVE #L7       #37
     C                     MOVE #L8       #38
     C                     ENDIF
     C           CC        IFEQ 4
     C                     MOVE #L1       #41
     C                     MOVE #L2       #42
     C                     MOVE #L3       #43
     C                     MOVE #L4       #44
     C                     MOVE #L5       #45
     C                     MOVE #L6       #46
     C                     MOVE #L7       #47
     C                     MOVE #L8       #48
     C                     ENDIF
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C* PRINT HEADER
     C******************************************************
     C           #HDR      BEGSR
      *
     C           *IN70     IFEQ *ON
     C                     MOVEL*BLANKS   SPART  17        PART#
     C                     MOVEL*BLANKS   SSBAN   4        KANBAN#
     C                     Z-ADDTODAY     PHZ8
     C                     TIME           WTIME
     C                     ADD  1         D#PAGE
     C                     EXSR #PLTED
     C   85                WRITEAB#PR441
     C                     MOVE *OFF      *IN70
     C                     ENDIF
      *
     C                     ENDSR
     C******************************************************
     C* INITIAL SET
     C******************************************************
     C           #INIT     BEGSR
      *
TEMP C           *ENTRY    PLIST
"    C                     PARM           PMXPL   30
"    C**                   Z-ADD30        PMXPL   30
      *
     C                     MOVE '===='    BA1     4
     C                     MOVE '===='    BA2     4
      *
     C           P#CMD     PLIST
     C                     PARM           #CHR    1
     C                     PARM           #L1     6
     C                     PARM           #L2     6
     C                     PARM           #L3     6
     C                     PARM           #L4     6
     C                     PARM           #L5     6
     C                     PARM           #L6     6
     C                     PARM           #L7     6
     C                     PARM           #L8     6
      *
     C           KEY1      KLIST
     C                     KFLD           KTOKU   40       CUSTOMER CODE
     C                     KFLD           KNONY   40       DELIVERY CODE
      *
     C           KEY2      KLIST
     C                     KFLD           KTOKU
     C                     KFLD           KNONY
     C                     KFLD           INUKE
     C                     KFLD           IMHN1
     C                     KFLD           IMHN2
     C                     KFLD           IMHN3
     C                     KFLD           IMHN4
     C*
     C           *LIKE     DEFN IINV#     W@INV#
     C           *LIKE     DEFN ISBAN     W@SBAN
     C           *LIKE     DEFN IMHN      W@MHN
      *
     C                     TIME           @SDATE
     C                     MOVE 'Y'       FIRST   1
     C                     MOVEL*BLANK    W@INV#
     C                     MOVEL*BLANK    W@SBAN
     C                     MOVEL*BLANK    W@MHN
     C                     MOVEL*BLANK    W@LOC1  1
     C                     MOVEL*BLANK    W@LOC2  2
     C                     MOVEL*BLANK    W@LOC3  2
     C                     MOVEL*BLANK    W@LOC4  1
     C                     Z-ADD0         D#PAGE  50
     C**                   MOVEL*OFF      W@1ST   1
      * CALCULATE TOTAL PAGE
     C                     MOVE *OFF      *IN85            NOT PRINT
     C                     EXSR #PROC
     C                     Z-ADDD#PAGE    T#PAGE  50
     C                     Z-ADD0         D#PAGE
      *
     C                     ENDSR
