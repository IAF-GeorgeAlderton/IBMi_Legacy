     C           #HOLD     BEGSR
      *
     C                     SETOF                     29
     C                     Z-ADD1         X       20
      *-------------------------
S1   C                     DO   *HIVAL    X
     C                     SETOF                     25
     C           X         CHAINSFL                  25
     C   25                LEAVE
     C*
 S2  C           @SEL      IFEQ 'A'
     C           @SEL      OREQ 'B'
     C           @SEL      OREQ 'C'
     C           @SEL      OREQ 'D'
     C                     MOVE @SHN1     #KDHN1  5
     C                     MOVE @SHN2     #KDHN2  5
     C                     MOVE @SHN3     #KDHN3  2
     C                     MOVE @HKNO     #KDKNO  8
     C                     Z-ADD@HKHZ     W@DATE
     C                     MOVE W@KYY     #KDKYY  40
     C                     MOVE W@KMM     #KDKMM  20
     C                     MOVE W@KDD     #KDKDD  20
     C                     MOVEL@HKTM     #KDKJI  20
     C                     MOVE @HKTM     #KDKFN  20
     C                     SETOF                       24
     C           KEYC12    SETLLGCQWP3Z
     C*--------------------
  S3 C                     DO   *HIVAL
     C           KEYC12    READEGCQWP3Z                  24
     C   24                LEAVE
  S4 C           C1FLG1    IFEQ ' '
     C           C1FLG2    ANDNE'2'                        2=処理済
     C*
