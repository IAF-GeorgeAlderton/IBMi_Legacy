     C                     SETOF                     26
     C           Y         CHAINSFL                  26
     C   26                LEAVE
      *
     C*        * @SEL      IFEQ '1'
     C           @SEL      IFNE ' '
     C                     MOVELER,5      @ERR
     C                     SETON                     99
     C                     END
     C*
     C  N99                ADD  1         Y
     C*
     C  N99                ENDDO
      *-------------------------
     CSR         $S800E    ENDSR
      *================================================================
      *  NEXT POINTER SET                                  *
      *================================================================
     CSR         $SB900    BEGSR
      *
     C                     SETOF                       6864
     C                     SETOF                       2526
      *-------------------------
S1   C                     DO   *HIVAL
     C           KEYC11    READEGCQWP3Z                  81
     C*
     C                     MOVE '0'       GETFLG
     C                     SETOF                       67
 S2  C           *IN81     IFEQ '0'
     C           C1SKJY    ANDEQ'D'
     C           C1SKHZ    ANDLE*DATE
     C                     SETON                       67
 E2  C                     ENDIF
     C*
 S2  C           *IN81     IFEQ '0'
     C           *IN67     ANDEQ'0'
     C                     MOVE '1'       GETFLG
  S3 C           @1HKNO    IFNE *BLANK
     C           @1HKNO    ANDNEC1HKNO
     C                     MOVE '0'       GETFLG
  E3 C                     ENDIF
     C*
  S3 C           C1FLG1    IFEQ *BLANK
     C           GETFLG    ANDEQ'1'
     C                     MOVE C1SHN1    #SSHN1  5
     C                     MOVE C1SHN2    #SSHN2  5
     C                     MOVE C1SHN3    #SSHN3  2
     C                     MOVE C1HKNO    #SHKNO  8
     C                     SETON                       68
  E3 C                     ENDIF
 E2  C                     ENDIF
     C*
E1   C  N81N68             ENDDO
      *-------------------------
      *
     C           *IN68     IFEQ '1'
     C           KEYSV1    SETLLGCQWP3Z
     C                     END
      *
     CSR         $S900E    ENDSR
      *================================================================
      *         保留
