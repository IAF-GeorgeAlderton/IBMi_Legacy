     H            Y.
     F** AJSRC0 **********************************
     F* INQUIRY OF WORKER CD M/F                 *
     F* C:S.YAMAGAMI                  1997.03.31 *
     F********************************************
     FAJSPLCD IP  E           K        DISK
     FAJSWPB1 O   E                    DISK
     E                    NM         20  1
     E                    WNM        20  1
     I            DS
     I                                        1  20 NM
     I                                        1  20 JAWKNM
     I            DS
     I                                        1   80JASKHZ
     I                                        1   40JASKYY
     I                                        5   60JASKMM
     I                                        7   80JASKDD
      *
      *
     C           JASKJY    IFEQ 'D'
     C           JASKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR SUB
     C                     WRITEAJSWPB11
     C                     END
      *****************************************************************
     C           SUB       BEGSR
      *
     C                     MOVE *BLANK    WNM
     C                     Z-ADD21        A       20
     C                     Z-ADD21        B       20
     C                     SETOF                     01
      *
     C                     DO   *HIVAL
     C                     SUB  1         A
     C           A         IFEQ 0
     C                     GOTO $END
     C                     END
     C  N01      NM,A      IFEQ *BLANK
     C  N01                GOTO TOBI
     C                     END
     C                     SETON                     01
     C                     SUB  1         B
     C                     MOVE NM,A      WNM,B
     C           TOBI      TAG
     C                     ENDDO
      *
     C           $END      TAG
     C                     MOVEAWNM       NM
     C                     ENDSR
