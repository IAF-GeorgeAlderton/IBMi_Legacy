     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @@RRN   40
     C                     MOVEL'01'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *  1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C           RRN1      IFNE *ZERO
     C                     MOVE '02'      W@ID
     C                     ELSE
     C                     MOVE MSG,1     D@MSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
      *
     C           K#AAM     CHAINAAMPL11              90
TCHK1C*          *IN90     IFEQ *ON
TCHK1C           *IN90     IFEQ *OFF
TCHK1C           CKSKJY    ANDEQ*BLANK
TCHK1C                     ELSE
     C                     SETON                     6199
     C                     MOVE MSG,2     D@MSG
     C                     ENDIF
      *
     C                     Z-ADDD@DATE    K@YMD
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C  N99                MOVE MSG,3     D@MSG
     C                     SETON                     6299
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
      *
     C                     ENDSR
      *
      *------------------------------------------------------
      *  SET DATA FOR SUBFILE
      *------------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1
      *
     C           1         DO   15        X       30
     C           PRC,X     IFNE *BLANK
     C*****      LOC,X     ANDNE'------'
     C********   MCN,X     IFNE *BLANK
     C           DPT,X     ORNE 0111
     C           DPT,X     ANDNE*ZERO
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     MOVE PRC,X     S@PROC
     C                     MOVE MCN,X     S@MCN
     C           DPT,X     IFNE 0111
     C                     MOVE DPT,X     H@DEPT
     C           DPT,X     CHAINFGBPL01              95
     C  N95                MOVELB2SMEI    S@FACT
     C                     ENDIF
      *
     C           K#FCE     SETGTFCEPL50
     C           *IN95     DOUEQ*ON
     C           K#FCE     REDPEFCEPL50             N    95
     C           *IN95     IFEQ *OFF
     C           F5SKJY    ANDEQ*BLANK
     C                     Z-ADDF5VLDT    S@VALD
     C                     Z-ADDF5VLDT    H@VALD
     C                     Z-ADDF5COST    S@COST
     C                     Z-ADDS@COST    H@COST
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           K#AAM     SETLLGBFTL53
     C           *IN95     DOUEQ*ON
     C           K#AAM     READEGBFTL53                  95
     C           *IN95     IFEQ *OFF
     C           G9SKJY    ANDEQ*BLANK
     C           G9KAHZ    ANDLED@DATE
     C           G9SUHZ    ANDGTD@DATE
      *
     C           PRC,X     IFEQ 'BZ '
     C           PRC,X     OREQ 'DCF'
     C           S@COST    IFEQ *ZERO
     C           S@COST    ORGT G9GITU
     C           G9GITU    ANDNE*ZERO
     C                     Z-ADDG9GITU    S@COST
     C                     ENDIF
     C                     ELSE
     C                     Z-ADD1         Z       20
     C           PRC,X     LOKUPPR1,Z                    10
     C           *IN10     IFEQ *ON
     C           S@COST    IFEQ *ZERO
     C           S@COST    ORGT CT1,Z
     C           CT1,Z     ANDNE*ZERO
     C                     Z-ADDCT1,Z     S@COST
     C                     ENDIF
     C                     ENDIF
      *
     C           PRC,X     IFEQ 'RL '
     C                     Z-ADD1         Z       20
     C           'AK '     LOKUPPR1,Z                    10
     C           *IN10     IFEQ *ON
     C           CT1,Z     ANDNE*ZERO
     C           S@COST    IFEQ *ZERO
     C           S@COST    ORGT CT1,Z
     C           CT1,Z     ANDNE*ZERO
     C                     ADD  CT1,Z     S@COST
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
      *
     C                     WRITESFL01
     C******               ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVE *OFF      *IN50
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
      *
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
     C           *INKE     WHEQ *ON
     C                     EXSR #UPD
     C                     MOVEL'01'      W@ID
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  UPDATE
      *------------------------------------------------------
     C           #UPD      BEGSR
      *
     C                     Z-ADD*ZERO     RRN1
     C           *IN90     DOUEQ*ON
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           H@COST    ANDNES@COST
      *
     C           H@VALD    IFEQ D@DATE
     C           K#FCX     CHAINFCEPL50              95
     C           *IN95     IFEQ *OFF
     C                     Z-ADD*DATE     F5KODT
     C                     TIME           F5KOTM
     C                     MOVEL#USER     F5KOME
     C                     Z-ADDS@COST    F5COST
     C                     UPDATFCEPP501
     C                     ENDIF
      *
     C                     ELSE
     C                     CLEARFCEPP501
     C                     Z-ADD*DATE     F5KODT
     C                     TIME           F5KOTM
     C                     MOVEL#USER     F5KOME
     C                     Z-ADDS@COST    F5COST
     C                     MOVELD@PRT1    F5PRT1
     C                     MOVELD@PRT2    F5PRT2
     C                     MOVELD@PRT3    F5PRT3
     C                     MOVELS@PROC    F5PROC
     C                     MOVELS@MCN     F5MCHN
     C                     Z-ADDD@DATE    F5VLDT
     C                     Z-ADDH@DEPT    F5DEPT
     C                     WRITEFCEPP501
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
