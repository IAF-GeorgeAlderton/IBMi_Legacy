     H            Y.
     F**************************************************************************
     F*  PROGRAM    : AYBR11                                                   *
     F*  WRITTEN    : 11/9/2015                                                *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F*  FUNCTION   : CREATE SOURCE MEMBER INFORMATION                         *
     F**************************************************************************
     F** @FILE   IF  F      92            DISK
JW   F@FILE   IF  F     112            DISK
     F                                              KINFDS @INFDA
     FAYBWP10 IF  E                    DISK                      A    UC
     FAYBWP11 O   E                    DISK
     E                    ARR        30  1
     E                    TBL     1   1 80
     E                    FLD        30 20
      *
     I@FILE   AA  01
     I                                        1   60SRCSEQ
     I                                        7  120SRCDAT
     I                                       13  92 SRCDTA
     I                                       18  19 SRCID
     I                                       29  29 SRCID2
     I                                       31  36 SRCFD
     I                                       57  63 SRCFN1
     I                                       65  92 SRCFN2
      *
     IFLDX        DS
     I                                        1  20 FLD01
     I                                       21  40 FLD02
     I                                       41  60 FLD03
     I                                       61  80 FLD04
     I                                       81 100 FLD05
     I                                      101 120 FLD06
     I                                      121 140 FLD07
     I                                      141 160 FLD08
     I                                      161 180 FLD09
     I                                      181 200 FLD10
     I                                      201 220 FLD11
     I                                      221 240 FLD12
     I                                      241 260 FLD13
     I                                      261 280 FLD14
     I                                      281 300 FLD15
     I                                      301 320 FLD16
     I                                      321 340 FLD17
     I                                      341 360 FLD18
     I                                      361 380 FLD19
     I                                      381 400 FLD20
     I                                      401 420 FLD21
     I                                      421 440 FLD22
     I                                      441 460 FLD23
     I                                      461 480 FLD24
     I                                      481 500 FLD25
     I                                      501 520 FLD26
     I                                      521 540 FLD27
     I                                      541 560 FLD28
     I                                      561 580 FLD29
     I                                      581 600 FLD30
      *
     I@INFDA      DS
     I                                       83  92 #FILE
     I                                       93 102 #LIB
     I                                      129 138 #MBR
     F**************************************************************************
      * STEP1: CREATE WORK
     C                     OPEN AYBWP10
     C                     MOVELTBL,1     #CHR    1
     C           *IN90     DOWEQ*OFF
     C                     READ @FILE                    90
     C           *IN90     IFEQ *OFF
     C           SRCID     ANDEQ'A '
     C           SRCID2    ANDEQ' '
     C           SRCFN1    ANDEQ'COLHDG('
     C                     MOVEL#LIB      W1LIB
     C                     MOVEL#FILE     W1FILE
     C                     MOVEL#MBR      W1MBR
     C                     MOVELSRCFD     W1FLD
      * CLEAN FIELD NAME
     C                     Z-ADD1         XX      20
     C                     MOVEASRCFN2    ARR
     C           #CHR      LOKUPARR,XX                   99
     C           *IN99     IFEQ *ON
     C                     Z-ADDXX        YY      20
     C                     DO   2
     C                     MOVE ' '       ARR,YY
     C                     ADD  1         YY
     C                     ENDDO
     C                     ENDIF
      *
     C                     MOVEAARR       W1FLDN
     C                     WRITEAYBWP101
     C                     ENDIF
     C                     ENDDO
     C                     CLOSEAYBWP10
      * STEP2: CREATE HEADER
     C                     MOVEA*BLANK    FLD
     C                     OPEN AYBWP10
     C           1         DO   30        IX      20
     C                     READ AYBWP10                  91
     C           *IN91     IFEQ *OFF
     C                     MOVELW1FLD     FLD,IX
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     MOVEAFLD       FLDX
     C                     WRITEAYBWP111
      *
     C                     CLOSEAYBWP10
     C                     OPEN AYBWP10
     C                     MOVEA*BLANK    FLD
     C           1         DO   30        IX      20
     C                     READ AYBWP10                  91
     C           *IN91     IFEQ *OFF
     C                     MOVELW1FLDN    FLD,IX
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     MOVEAFLD       FLDX
     C                     WRITEAYBWP111
     C                     CLOSEAYBWP10
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
** (TBL)
')
