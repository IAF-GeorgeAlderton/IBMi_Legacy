     H            Y.
     F** MRHR81 **************************************
     F* 2ND SURFACE TREATMENT NAME MASTER EDIT       *
     F*        A.SHIBATA    2014.02.25               *
     F************************************************
     FMRHPW81 CF  E                    WORKSTN
     FMRHPP81 UF  E           K        DISK                      A
     E                    ER      1  19 65
      *
     I            DS
     I                                        1   80SBSKHZ
     I                                        1   40SBSKYY
     I                                        5   60SBSKMM
     I                                        7   80SBSKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
     I              '0123456789'          C         WKCKSU
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
     C           KEY1      KLIST
     C                     KFLD           #KSTID  2
      *
      *----------------------------------------------------*
      *  メインルーチン                                  *
      *----------------------------------------------------*
     C                     EXSR $SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR $SB200
     C                     ENDDO
     C                     EXSR $SB300
      *----------------------------------------------------*
      *   初期処理                                       *
      *----------------------------------------------------*
     CSR         $SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVE '01'      DSPSW   2
      *
      *
     CSR         $S100E    ENDSR
      *----------------------------------------------------*
      *   主処理                                         *
      *----------------------------------------------------*
     CSR         $SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR $SB210
     C                     ENDDO
      *
     C           DSPSW     DOWEQ'02'
     C                     EXSR $SB220
     C                     ENDDO
      *
     CSR         $S200E    ENDSR
      *----------------------------------------------------*
      *   終了処理                                       *
      *----------------------------------------------------*
     CSR         $SB300    BEGSR
      *
     C                     SETON                     LR
     C                     RETRN
      *
     CSR         $S300E    ENDSR
      *----------------------------------------------------*
      *   第一画面表示                                   *
      *----------------------------------------------------*
     CSR         $SB210    BEGSR
      *
     C                     EXFMTMRHPW811
     C                     SETOF                     313299
     C                     MOVEL*BLANK    @ERR
      * F1
     C           *IN01     IFEQ '1'
     C                     MOVE '99'      DSPSW
     C                     GOTO $S210E
     C                     ENDIF
      * F12
     C           *IN12     IFEQ '1'
     C                     CALL 'MRHR82'
     C                     GOTO $S210E
     C                     ENDIF
      *
     C           @KKBN     IFEQ *BLANK
     C                     MOVELER,1      @ERR
     C                     SETON                     3199
     C                     GOTO $S210E
     C                     ENDIF
      *
     C           @KKBN     IFEQ '0'
     C           @KKBN     OREQ '1'
     C           @KKBN     OREQ '2'
     C                     ELSE
     C                     MOVELER,2      @ERR
     C                     SETON                     3199
     C                     GOTO $S210E
     C                     ENDIF
      *オペレータ―ＩＤ
     C           @STID     IFEQ *BLANK
     C                     MOVELER,1      @ERR
     C                     SETON                     3299
     C                     GOTO $S210E
     C                     ENDIF
      *マスター
     C                     MOVEL@STID     #KSTID
     C           KEY1      CHAINMRHPP811             21
     C           *IN21     IFEQ '0'
     C           SBSKJY    ANDEQ'D'
     C           SBSKHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ELSE
     C                     MOVELSBSTNM    @STNM
     C                     ENDIF
      *
     C           *IN21     IFEQ '1'
     C           @KKBN     IFEQ '0'
     C           @KKBN     OREQ '1'
     C                     MOVELER,5      @ERR
     C                     SETON                     3299
     C                     GOTO $S210E
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN21     IFEQ '0'
     C           @KKBN     IFEQ '2'
     C                     MOVELER,6      @ERR
     C                     SETON                     3199
     C                     GOTO $S210E
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVEL@KKBN     @KBN2
     C                     MOVEL@STID     @HAN2
      *
     C                     SELEC
      *
     C           @KKBN     WHEQ '0'
     C                     MOVEL'DELETE'  @KBNM
      *
     C           @KKBN     WHEQ '1'
     C                     MOVEL'CHANGE'  @KBNM
      *
     C           @KKBN     WHEQ '2'
     C                     MOVEL'ADD'     @KBNM
     C                     MOVEL*BLANK    @STNM
      *
     C                     ENDSL
      *
     C                     MOVE '02'      DSPSW   2
      *
     CSR         $S210E    ENDSR
      *----------------------------------------------------*
      *   第二画面表示                                   *
      *----------------------------------------------------*
     CSR         $SB220    BEGSR
      *
     C                     EXFMTMRHPW812
     C                     SETOF                     3399
     C                     MOVEL*BLANK    @ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVEL*BLANK    @KKBN
     C                     MOVEL*BLANK    @STID
     C                     MOVEL*BLANK    @STNM
     C                     MOVE '01'      DSPSW
     C                     GOTO $S220E
     C                     ENDIF
      *入力チェック
      *2ND SURFACE TREATMENT NAME
     C           @STNM     IFEQ *BLANK
     C                     MOVELER,1      @ERR
     C                     SETON                     3399
     C                     GOTO $S220E
     C                     ENDIF
      *
      * F5
     C           *IN05     IFEQ '1'
     C                     SELEC
     C           @KKBN     WHEQ '0'
     C                     EXSR #DLT
     C           @KKBN     WHEQ '1'
     C                     EXSR #UPD
     C           @KKBN     WHEQ '2'
     C                     EXSR #WRT
     C                     ENDSL
      *
     C                     MOVEL*BLANK    @KKBN
     C                     MOVEL*BLANK    @STID
     C                     MOVEL@KBNM     @BKBN
     C                     MOVEL*BLANK    @KBNM
     C                     MOVEL@HAN2     @BHAN
     C                     MOVEL@STNM     @BSTM
     C                     MOVEL*BLANK    @STNM
     C                     MOVE '01'      DSPSW   2
     C                     ENDIF
      *
     CSR         $S220E    ENDSR
      *----------------------------------------------------*
      *削除                                              *
      *----------------------------------------------------*
     CSR         #DLT      BEGSR
      *
     C           *IN21     IFEQ '0'
     C                     MOVEL'D'       SBSKJY
     C                     Z-ADDWTIYY     SBSKYY
     C                     Z-ADDWTIMM     SBSKMM
     C                     Z-ADDWTIDD     SBSKDD
     C                     Z-ADDWTIYY     SBKOYY
     C                     Z-ADDWTIMM     SBKOMM
     C                     Z-ADDWTIDD     SBKODD
     C                     MOVEL@@USER    SBKOME
     C                     MOVELW$PGM     SBKOPG
     C                     UPDATMRHPP811
     C                     ENDIF
      *
     CSR         EDLT      ENDSR
      *----------------------------------------------------*
      *変更                                              *
      *----------------------------------------------------*
     CSR         #UPD      BEGSR
      *
     C           *IN21     IFEQ '0'
     C                     Z-ADDWTIYY     SBKOYY
     C                     Z-ADDWTIMM     SBKOMM
     C                     Z-ADDWTIDD     SBKODD
     C                     MOVEL@@USER    SBKOME
     C                     MOVELW$PGM     SBKOPG
     C                     MOVEL@STNM     SBSTNM
     C                     UPDATMRHPP811
     C                     ENDIF
      *
     CSR         EUPD      ENDSR
      *----------------------------------------------------*
      *追加                                              *
      *----------------------------------------------------*
     CSR         #WRT      BEGSR
      *
     C           KEY1      CHAINMRHPP811             21
      *
     C                     CLEARMRHPP811
     C                     MOVEL*BLANK    SBSKJY
     C                     Z-ADD0         SBSKYY
     C                     Z-ADD0         SBSKMM
     C                     Z-ADD0         SBSKDD
     C                     Z-ADDWTIYY     SBKOYY
     C                     Z-ADDWTIMM     SBKOMM
     C                     Z-ADDWTIDD     SBKODD
     C                     MOVEL@@USER    SBKOME
     C                     MOVELW$PGM     SBKOPG
     C                     MOVEL@STID     SBSTID
     C                     MOVEL@STNM     SBSTNM
     C           *IN21     IFEQ '0'
     C                     UPDATMRHPP811
     C                     ELSE
     C                     WRITEMRHPP811
     C                     ENDIF
      *
     CSR         EWRT      ENDSR
      *
**
ER-01 INPUT PRODUCT LOCATION CODE
ER-02 SELECT 0 OR 1 OR 2
ER-03
ER-04
ER-05 NO CORRESPONDING DATA
ER-06 IT HAS ALREADY BEEN REGISTERED
ER-07
ER-08
ER-09
