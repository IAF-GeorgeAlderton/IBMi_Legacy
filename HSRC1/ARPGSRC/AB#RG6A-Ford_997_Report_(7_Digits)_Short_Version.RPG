     H            Y.
     F** AB#RG6A ****************************************
     F*  Generate 997 Report                            *
     F*  EDI (FORD997) OK                               *
     F*  JW    2025.10.17                               *
     F***************************************************
     FAB#PL6U IF  E           K        DISK
     FJCMPL11BIF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *
     E                    TB1     1   3  1   TB2    20
     E                    TB3     1   8  1   TB4    31
     IAB#PP6U1
     I              M6PTRN                          PTRN
     I              M6AK101                         AK101
     I              M6AK102                         AK102
     I              M6AK201                         AK201
     I              M6AK202                         AK202
     I              M6AK301                         AK301
     I              M6AK302                         AK302
     I              M6AK304                         AK304
     I              M6AK401                         AK401
     I              M6AK402                         AK402
     I              M6AK403                         AK403
     I              M6AK901                         AK901
     I              M6AK902                         AK902
     I              M6AK903                         AK903
     I              M6AK904                         AK904
      *---------------------------------------------------------
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        9  140TDAY6
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *****************************************************
      * MAIN ROUTINE
      *****************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ AB#PL6U                  98
     C   98                LEAVE
      *
      * CONTROL# S/B LESS THAN 999999
     C                     MOVELAK102     NUM9    90
     C           NUM9      IFGE 999999
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #ASN
      * STATUS NAME
     C                     Z-ADD1         IX      20
     C           AK901     LOKUPTB1,IX                   97
     C  N97                MOVE *BLANK    STTNAM 20
     C   97                MOVELTB2,IX    STTNAM
      *
     C                     EXCPT@DTL
      * ADDITIONAL ERROR MSG
     C           AK901     IFNE 'A'
     C                     Z-ADD1         IY      20
     C           AK304     LOKUPTB3,IY                   97
     C  N97                MOVE *BLANK    STTERR 31
     C   97                MOVELTB4,IX    STTERR
     C                     EXCPT@DTL1
     C                     ENDIF
      *
     C                     ADD  1         DCNT    30
     C                     MOVEL'1'       PD
      *
     C           *INOF     IFEQ *ON
     C                     EXCPT@HED
     C                     ENDIF
      *
     C                     ENDDO
      *
     C**         DCNT      IFGT 0
     C                     EXCPT@TOT
     C**                   ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *===================================================================
      * GET ASN#
      *===================================================================
     C           #ASN      BEGSR
      *
     C                     Z-ADD0         ASN#
     C                     Z-ADD0         ASNDT
     C                     Z-ADD0         ASNTM
     C                     MOVE *BLANK    XNONY
     C                     Z-ADD0         XNOHZ
     C                     MOVE *BLANK    XBIN
     C                     MOVE *BLANK    XPL#
      *
     C                     MOVELAK102     NUM9    90
     C                     MOVELNUM9      LTR10  10 P
     C           LTR10     CHAINJCMPL11B             99
     C           *IN99     IFEQ *OFF
     C                     MOVE J1ASN#    ASN#
     C                     MOVELJ1DATE    ASNDT
     C                     MOVELJ1TIME    ASNTM
     C                     MOVELJ1NONY    XNONY
     C                     MOVELJ1NOHZ    XNOHZ
     C                     MOVELJ1BIN     XBIN
      * PACKING LIST#
     C                     MOVELJ1NONY    $NONY
     C                     MOVELJ1SHID    $SHID
     C                     CALL 'UTLR51F'
     C                     PARM           $NONY   4
     C                     PARM           $SHID  10
     C                     PARM           $PL#    9
     C                     MOVEL$PL#      XPL#
     C                     ENDIF
      *
     C                     ENDSR
      *===================================================================
      * INITIAL SETTINGS
      *===================================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           PD      1        PRINT FLAG
     C                     MOVE *BLANK    PD
      *
     C                     TIME           SDATE
     C                     MOVE *ALL'-'   @LINE 110
      * PRINT HEADER
     C                     EXCPT@HED                          0
      *
     C                     Z-ADD0         ASN#    70
     C                     Z-ADD0         ASNDT   80
     C                     Z-ADD0         ASNTM   40
     C                     MOVE *BLANK    STTNAM 20
     C                     MOVE *BLANK    XNONY   4
     C                     Z-ADD0         XNOHZ   80
     C                     MOVE *BLANK    XBIN    2
     C                     MOVE *BLANK    XPL#    9
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                                   17 'DATE'
     O                         UDATE Y   26
     O                         NOW       35 '  :  :  '
      *
     O        E   02           @HED
     O                                   23 'EDI(997) MESSAGE - FORD'
      *
     O        E   03           @HED
     O                                    7 'PARTNER'
     O                                   13 'EDI'
     O                                   24 'TRANS#'
     O                                   31 'ASN#'
     O                                   43 'ASN DATE'
     O                                   52 'TIME'
     O                                   63 'CONTROL#'
     O                                   75 'ACKNOWLEDGE'
     O        E   04           @HED
     O                         @LINE    110
      *
     O        E 1              @DTL
     O                         PTRN      10
     O                         AK201     17
     O                         AK202 Z   27
     O                         ASN#  Z   36
     O                         ASNDT     48 '    /  /  '
     O                         ASNTM     55 '  :  '
     O                         AK102 Z   65
     O                         STTNAM    92
      *
     O        E 1              @DTL1
     O                                   17 'SEGMENT IN ERROR:'
     O                         AK301     21
     O                                   36 'POS IN TRANS:'
     O                         AK302     45
     O                                   53 'ERROR:'
     O                         STTERR    85
     O                                   97 'POS IN SEG'
     O                         AK401    101
     O                                  113 'ERROR CODE'
     O                         AK403    109
      *
     O        E 2              @TOT
     O                                    6 'TOTAL:'
     O                         DCNT  1   10
** TB1/TB2 (STATUS)
AACCEPTED
EACCEPTED WITH ERRORS
RREJECTED
** TB3/TB4 (ERROR)
1UNRECOGNIZED SEGMENT ID
2SEGMENT HAS EXCESS DELIMITERS
3UNEXPECTED SEGMENT
4LOOP OCCURS OVER MAX TIMES
5SEGMENT EXCEEDS MAX USE
6SEGMENT NOT DEFINED IN TRAN SET
7SEGMENT IN IN PROPER SEQ
8SEGMENT HS DATA ELEMENT ERRORS
