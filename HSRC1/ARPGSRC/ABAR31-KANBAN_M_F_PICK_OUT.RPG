     C                     MOVE PHIZK     UHIZK
      *
B0   C           UHDD      IFEQ 01
     C           UHYY      SUB  1         WHYY
     C                     Z-ADD12        WHDD
     C                     ELSE
     C                     Z-ADDUHYY      WHYY
     C           UHDD      SUB  1         WHDD
E0   C                     END
      *
     C                     Z-ADDUHDD      K@MM
     C                     Z-ADD1         A       60
B0   C           1         DO   300000    A
     C                     Z-ADDA         K@REC
     C           K#F32     CHAINFCCPL32              90
B1   C           *IN90     IFEQ *OFF
     C                     MOVE *BLANK    B4RKBN
     C                     UPDATFCCPL321
     C                     ELSE
     C                     Z-ADDUHDD      B4MMRD
     C                     MOVE *BLANK    B4RKBN
     C                     Z-ADDA         B4RECD
     C                     WRITEFCCPP321
E1   C                     ENDIF
      *
E0   C                     END
      *
     C           STP1      TAG
     C                     SETOF                     01
     C                     READ FCCPP111                 01
     C   01                SETON                     LR
     C   01                RETRN
      *
B0   C           UHIZK     IFEQ B4MAHZ
     C                     SETON                     LR
     C                     RETRN
E0   C                     END
      *
B0   C           WHIZK     IFEQ B4MAHZ
      *
B1   C           B4SKBN    IFEQ 'D'
B2   C           B4SKHZ    IFLE *DATE
     C                     GOTO STP1
E2   C                     END
E1   C                     END
      *
     C                     MOVE *BLANK    B4RNBN
