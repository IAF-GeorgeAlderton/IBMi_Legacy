     H            Y.
     F**AL#R9C ***************************************
     F* COPY AL#WP9A TO AL#PW9B                      *
     F* J.WATANABE   2021.10.12                      *
     F************************************************
     FAL#WP9A IF  E           K        DISK
     FAL#WP9B O   E                    DISK
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I            DS
     I                                        1   8 WKDATE
     I                                        1   4 WKYY
     I                                        5   6 WKMM
     I                                        7   8 WKDD
      *
     I            DS
     I                                        1  10 W1DATE
     I                                        1   4 W1YY
     I                                        5   5 DS1
     I                                        6   7 W1MM
     I                                        8   8 DS2
     I                                        9  10 W1DD
      *
     I            DS
     I                                        1   6 WKTIME
     I                                        1   2 WKHH
     I                                        3   4 WKMN
     I                                        5   6 WKSS
      *
     I            DS
     I                                        1   8 W1TIME
     I                                        1   2 W1HH
     I                                        3   3 CL1
     I                                        4   5 W1MN
     I                                        6   6 CL2
     I                                        7   8 W1SS
      *
     I            DS
     I                                        1  12 A1MHN
     I                                        1   5 A1MHN1
     I                                        6  10 A1MHN2
     I                                       11  12 A1MHN3
      *
     I            DS
     I                                        1  14 WKMHN
     I                                        1   5 WKMHN1
     I                                        6   6 HF11
     I                                        7  11 WKMHN2
     I                                       12  12 HF12
     I                                       13  14 WKMHN3
      *
     I            DS
     I                                        1   9 A1TKR
     I                                        1   1 A1TKR1
     I                                        2   2 HF21
     I                                        3   4 A1TKR2
     I                                        5   5 HF22
     I                                        6   7 A1TKR3
     I                                        8   8 HF23
     I                                        9   9 A1TKR4
      ****************************************************
     C                     EXSR #INIT
      * PROGRAM START *
     C                     DO   *HIVAL
     C                     READ AL#WP9A                  98
     C   98                LEAVE
      *
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     EXSR #HDR1
     C                     ENDIF
      *
     C                     EXSR #DTL1
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *****************************************************************
      * CREATE HEADER
      *****************************************************************
     C           #HDR1     BEGSR
      *
     C                     CLEARAL#WP9B1
     C                     MOVEL'CRT_DATE'B1KADT
     C                     MOVEL'CRT_TIME'B1KATI
     C                     MOVEL'SHP_DATE'B1SHID
     C                     MOVEL'SHP_TIME'B1SHIT
     C                     MOVEL'SB_ROUTE'B1SURT
     C                     MOVEL'TRK_BIN#'B1TRKB
     C                     MOVEL'BIN#    'B1IAFB
     C                     MOVEL'CUST#   'B1TOKU
     C                     MOVEL'DELV#   'B1NONY
     C                     MOVEL'FACTORY 'B1NKOJ
     C                     MOVEL'DOCK    'B1NUKE
     C                     MOVEL'SHP_NAME'B1SMEI
     C                     MOVEL'USR_PART'B1MHN
     C                     MOVEL'EXTR#   'B1EXTR
     C                     MOVEL'PALLET# 'B1IAFP
     C                     MOVEL'PUL     'B1PPUL
     C                     MOVEL'EGBOLT  'B1EGBC
     C                     MOVEL'LOCATION'B1TKR
     C                     WRITEAL#WP9B1
      *
     C                     ENDSR
      *****************************************************************
      * CREATE DETAILS
      *****************************************************************
     C           #DTL1     BEGSR
      *
     C                     CLEARAL#WP9B1
      *
     C                     MOVELA1KADT    WKDATE
     C                     MOVELWKYY      W1YY
     C                     MOVELWKMM      W1MM
     C                     MOVELWKDD      W1DD
     C                     MOVELW1DATE    B1KADT
      *
     C                     MOVELA1KATI    WKTIME
     C                     MOVELWKHH      W1HH
     C                     MOVELWKMN      W1MN
     C                     MOVELWKSS      W1SS
     C                     MOVELW1TIME    B1KATI
      *
     C                     MOVELA1SHID    WKDATE
     C                     MOVELWKYY      W1YY
     C                     MOVELWKMM      W1MM
     C                     MOVELWKDD      W1DD
     C                     MOVELW1DATE    B1SHID
      *
     C                     MOVELA1SHIT    WKTIME
     C                     MOVELWKHH      W1HH
     C                     MOVELWKMN      W1MN
     C                     MOVELWKSS      W1SS
     C                     MOVELW1TIME    B1SHIT
      *
     C                     MOVELA1SURT    B1SURT
     C                     MOVELA1TRKB    B1TRKB
     C                     MOVELA1IAFB    B1IAFB
     C                     MOVELA1TOKU    B1TOKU
     C                     MOVELA1NONY    B1NONY
     C                     MOVELA1NKOJ    B1NKOJ
     C                     MOVELA1NUKE    B1NUKE
     C                     MOVELA1SMEI    B1SMEI
      *
     C                     MOVELA1MHN1    WKMHN1
     C                     MOVELA1MHN2    WKMHN2
     C                     MOVELA1MHN3    WKMHN3
     C                     MOVE '-'       HF11
     C                     MOVE '-'       HF12
     C           WKMHN2    IFEQ *BLANK
     C                     MOVE ' '       HF11
     C                     ENDIF
     C           WKMHN3    IFEQ *BLANK
     C                     MOVE ' '       HF12
     C                     ENDIF
     C                     MOVELWKMHN     B1MHN
      *
     C                     MOVELA1EXTR    B1EXTR
     C                     MOVELA1IAFP    B1IAFP
     C                     MOVELA1PPUL    B1PPUL
     C                     MOVELA1EGBC    B1EGBC
     C                     MOVELA1TKR     B1TKR
     C                     WRITEAL#WP9B1
      *
     C                     ENDSR
      *****************************************************************
      * INITIAL SETTING
      *****************************************************************
     C           #INIT     BEGSR
      *
     C                     MOVE 'Y'       FIRST   1
     C                     MOVE '-'       HF21
     C                     MOVE '-'       HF22
     C                     MOVE '-'       HF23
     C                     MOVE '/'       DS1
     C                     MOVE '/'       DS2
     C                     MOVE ':'       CL1
     C                     MOVE ':'       CL2
      *
     C                     ENDSR
