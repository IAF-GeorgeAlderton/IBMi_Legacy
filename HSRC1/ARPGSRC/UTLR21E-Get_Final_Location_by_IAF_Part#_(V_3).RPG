      * CHG DATE
     I            DS
     I                                        1  100WSCHG
     I                                        1   80@@CHG
      * Q/C CHG DATE
     I            DS
     I                                        1   80A2SYHZ
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
     I            DS
     I                                        1  12 @WSHN
     I                                        1   5 @WSHN1
     I                                        6  10 @WSHN2
     I                                       11  12 @WSHN3
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        1   20WSHH
     I                                        3   40WSMN
     I                                        5   60WSSS
     I                                        7  100WSYY
     I                                       11  120WSMM
     I                                       13  140WSDD
     I                                        1   40WSTM4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
     C                     EXSR @INIT
      *
     C           KEY1      CHAINFCEPL01              99
     C           *IN99     IFEQ *OFF
     C                     EXSR @FCE
     C                     EXSR @AAM
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *=============================================================
      * GET DATA FROM FCEPP11
      *=============================================================
     C           @FCE      BEGSR
      * Q/C
     C           A2SYHZ    IFGT @DATE
     C                     Z-ADDA2KSYS    $LQC
     C                     ELSE
     C                     Z-ADDA2SSYS    $LQC
     C                     ENDIF
      * ZETI
     C                     MOVELA2ZETI    $ZETI
      * MONTHLY SETTING QTY
     C                     Z-ADDA2GEKN    $MQTY
      * WEIGHT
     C                     Z-ADDA2KASI    $WGT
      *
     C                     ENDSR
      *=============================================================
      * GET DATA FROM AAMPP11
      *=============================================================
     C           @AAM      BEGSR
      *
     C           KEY1      CHAINAAMPL11              98
     C           *IN98     IFEQ *OFF
      * LAST VALUE
     C           1         DO   15        IX      20
     C                     Z-ADDCHG,IX    WSCHG
      *
     C           @@CHG     IFLE @DATE
     C           PRN,IX    IFEQ *BLANK
     C                     LEAVE
     C                     ELSE
     C                     EXSR #NEW
     C                     ENDIF
     C                     ENDIF
      *
     C           @@CHG     IFGT @DATE
     C           PRX,IX    IFEQ *BLANK
     C                     LEAVE
     C                     ELSE
     C                     EXSR #OLD
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDSR
      *=============================================================
      * GET DATA FROM NEW TABLE
      *=============================================================
     C           #NEW      BEGSR
      *
     C           LCN,IX    IFNE *BLANK
     C                     MOVELLCN,IX    $LLOC
     C                     ENDIF
      *
     C           PRN,IX    IFNE *BLANK
     C                     MOVELPRN,IX    $LPRC
     C                     ENDIF
      *
     C           DPN,IX    IFNE 0
     C                     Z-ADDDPN,IX    $LDPT
     C                     ENDIF
      *
     C           MCN,IX    IFNE *BLANK
     C                     MOVELMCN,IX    $LMCN
     C                     ENDIF
      *
     C                     ENDSR
      *=============================================================
      * GET DATA FROM OLD TABLE
      *=============================================================
     C           #OLD      BEGSR
      *
     C           LCX,IX    IFNE *BLANK
     C                     MOVELLCN,IX    $LLOC
     C                     ENDIF
      *
     C           PRX,IX    IFNE *BLANK
     C                     MOVELPRN,IX    $LPRC
     C                     ENDIF
      *
     C           DPX,IX    IFNE 0
     C                     Z-ADDDPN,IX    $LDPT
     C                     ENDIF
      *
     C           MCX,IX    IFNE *BLANK
     C                     MOVELMCX,IX    $LMCN
     C                     ENDIF
      *
     C                     ENDSR
      *=============================================================
      * INITIAL PROCESS
      *=============================================================
     C           @INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SHIN  12
ADD  C                     PARM           $DATE   8
     C                     PARM           $LLOC   6
     C                     PARM           $LQC    50
     C                     PARM           $LPRC   3
     C                     PARM           $LDPT   40
     C                     PARM           $LMCN   3
     C                     PARM           $ZETI   4
ADD  C                     PARM           $MQTY   90
     C                     PARM           $WGT    72
      *
     C           KEY1      KLIST
     C                     KFLD           @WSHN1
     C                     KFLD           @WSHN2
     C                     KFLD           @WSHN3
      * RETRIEVE SYSTEM TIME
     C                     TIME           WSDT
      *
     C           $DATE     IFEQ *BLANK
     C           $DATE     OREQ '00000000'
     C                     MOVELTODAY     $DATE
     C                     ENDIF
     C                     MOVEL$DATE     @DATE   80
      *
     C                     CLEAR$LLOC
     C                     CLEAR$LQC
     C                     CLEAR$LPRC
     C                     CLEAR$LDPT
     C                     CLEAR$LMCN
     C                     CLEAR$ZETI
     C                     CLEAR$MQTY
     C                     CLEAR$WGT
      *
     C                     MOVEL$SHIN     @WSHN
      *
     C                     ENDSR
