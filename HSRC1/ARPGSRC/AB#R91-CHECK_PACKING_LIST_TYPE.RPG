     H            Y.
      ** AB#R91 ************************************************
      *   .. CHECK OF LIST TYPE ..                             *
      *    K.YASUDA     1999.07.14                             *
      *    TCH 2000.05.18 ADD NUMBER OF PICK LIST,CUSTOM SHEET *
      *    TCH 2000.08.17 ADD TRANSPORTATION,TYPE OF CUSTOM-S  *
      ************************************************ AB#R91 **
     FAB#PL90 IF  E           K        DISK
      *
     I            DS
     I                                        1   80YASKHZ
     I                                        1   40YASKYY
     I                                        5   60YASKMM
     I                                        7   80YASKDD
      *
     C           *ENTRY    PLIST
     C                     PARM           PSIRE   4        DELIVERY
     C                     PARM           PTYPE   2        LABEL TYPE
     C                     PARM           PPICK   20       # PICK-UP LIST
     C                     PARM           PCUST   20       # CUSTOM SHEET
     C                     PARM           PTRAN  30        TRANSPORTATION
     C                     PARM           PCTYP   2        CUSTOM-S TYPE
     C                     PARM           PCNAM  10        NAME OF COUNTRY
      *
     C                     MOVEL'01'      PTYPE
     C                     Z-ADD0         PPICK
     C                     Z-ADD0         PCUST
      *
     C                     SETOF                     10
     C           PSIRE     CHAINAB#PL901             10
      *
     C           *IN10     IFEQ '0'
     C           YASKJY    IFEQ 'D'
     C           YASKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELYATYPE    PTYPE
     C                     Z-ADDYAPICK    PPICK
     C                     Z-ADDYACUST    PCUST
     C                     MOVE YATRAN    PTRAN
     C                     MOVE YACTYP    PCTYP
     C                     MOVELYACNAM    PCNAM
     C                     END
     C                     END
      *
     C                     SETOF                     LR
     C                     RETRN
