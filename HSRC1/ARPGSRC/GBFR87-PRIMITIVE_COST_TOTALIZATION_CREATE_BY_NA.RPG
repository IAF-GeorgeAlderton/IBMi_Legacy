     C******************************************************
     C* M-NO BF.6.2        PARM ﾉ cinﾒ                     *
     C******************************************************
     C           *ENTRY    PLIST
     C                     PARM           PTOKU   4
     C                     PARM           PTKOJ   1
     C                     PARM           PSRKB   1
     C           *IN01     IFEQ '0'
     C                     SETON                     01
     C                     Z-ADD*DATE     YYMD
     C                     Z-ADDSYY       DYY
     C                     Z-ADDSMD       DMD
     C                     MOVE PTOKU     UTOKU   40
     C                     TIME           UTIME   60
     C                     MOVE MD,1      HD
     C                     MOVE *BLANK    TMEIG
     C                     SETOF                     02
     C           UTOKU     CHAINFGBPL011             02
     C           *IN02     IFEQ '0'
     C                     MOVELB2SMEI    TMEIG  16
     C                     END
     C                     MOVE *BLANK    SRMEI
     C           PSRKB     IFEQ 'A'
     C                     MOVE '計画Ａ'SRMEI   8
     C                     ELSE
     C           PSRKB     IFEQ 'B'
     C                     MOVE '実績Ｂ'SRMEI
     C                     ELSE
     C           PSRKB     IFEQ 'C'
     C                     MOVE '計画Ｃ'SRMEI
     C                     ELSE
     C                     MOVE '異常　'SRMEI
     C                     END
     C                     END
     C                     END
     C******************************************************
     C* M-NO BF.6.3        ﾇcﾒｭcﾃﾞcib ﾉ ibﾅ]               *
     C******************************************************
     C           STEP01    TAG
     C                     READ GBFWP86                  11
     C           *IN11     CABEQ'1'       STEP02
     C           GTOKU     CABNEUTOKU     STEP02
     C           PSRKB     IFEQ 'A'
     C                     Z-ADDGQSRY     IBSRYO 110
     C                     ELSE
     C           PSRKB     IFEQ 'B'
     C                     Z-ADDGJIRY     IBSRYO
     C                     ELSE
     C           PSRKB     IFEQ 'C'
     C                     Z-ADDGSRYO     IBSRYO
     C                     END
     C                     END
     C                     END
     C           IBSRYO    MULT GTANK     ZSRYO  145H
     C           ZSRYO     ADD  TSRYO     TSRYO  145
     C                     GOTO STEP01
     C                     END
     C           STEP02    TAG
     C******************************************************
     C* M-NO BF.6.3.1      mﾞ-j ﾉ ﾑvﾃv                     *
     C******************************************************
     C           G9TOKU    IFNE UTOKU
     C                     SETON                     LR
     C                     GOTO END
     C                     END
     C           *INL1     IFEQ '1'
     C                     MOVE G9MSYO    MSYO    2
     C                     END
     C           *INL2     IFEQ '1'
     C                     Z-ADD1         I       20
     C           G9MSKB    LOKUPM,I                      12
     C           *IN12     IFEQ '1'
     C                     MOVE B,I       DAIM
     C                     ELSE
     C                     MOVE *BLANK    DAIM
     C                     MOVEL'ﾉj'     DAIM
     C                     END
     C                     MOVE G9MSKB    DAIB    1
     C                     END
     C           *INL3     IFEQ '1'
     C                     WRITEGBFPR871
     C                     Z-ADD0         L       20
     C                     END
     C******************************************************
     C* M-NO BF.6.3.2      mﾞ-j xbﾅb m]c                  *
     C******************************************************
     C           PSRKB     IFEQ 'A'
     C                     Z-ADDG9QSRY    IBSRYO 110
     C                     ELSE
     C           PSRKB     IFEQ 'B'
     C                     Z-ADDG9JIRY    IBSRYO
     C                     ELSE
     C           PSRKB     IFEQ 'C'
     C                     Z-ADDG9SRYO    IBSRYO
     C                     END
     C                     END
     C                     END
     C           IBSRYO    MULT G9MTAN    XKIN   112H
     C           XKIN      ADD  SRYO      SRYO   112
     C           IBSRYO    MULT G9ZAIH    WZAIH  112H
     C           WZAIH     ADD  ZRYO      ZRYO   112
     C           IBSRYO    MULT G9KOUH    WKOUH  112H
     C           WKOUH     ADD  KONU      KONU   112
     C           IBSRYO    MULT G9GITU    WGITU  112H
     C           WGITU     ADD  KAKO      KAKO   112
     C           IBSRYO    MULT G9KNRH    WKNRH  112H
     C           IBSRYO    MULT G9RIEK    WRIEK  112H
     C           WKNRH     ADD  KANR      KANR   112
     C           WRIEK     ADD  KANR      KANR   112
     C           IBSRYO    MULT G9KATA    WKATA  112H
     C           WKATA     ADD  KATA      KATA   112
     C           IBSRYO    MULT G9VAVE    WVAVE  112H
     C           WVAVE     ADD  VAVE      VAVE   112
     C           CTR       ADD  1         CTR     50
     C           END       TAG
     C******************************************************
     C* M-NO BF.6.3.2      xbﾆｭc ﾃﾞcib b]ﾅl                *
     C******************************************************
     CL1         TSRYO     IFNE 0
     CL1         SRYO      DIV  TSRYO     RSRYO  114H
     CL1                   ELSE
     CL1                   Z-ADD0         RSRYO
     CL1                   END
     CL1         RSRYO     MULT 100       RITU    52
     CL1         SRYO      ADD  BSRYO     BSRYO  112
     CL1         ZRYO      ADD  BZRYO     BZRYO  112
     CL1         KONU      ADD  BKONU     BKONU  112
     CL1         KAKO      ADD  BKAKO     BKAKO  112
     CL1         KANR      ADD  BKANR     BKANR  112
     CL1         KATA      ADD  BKATA     BKATA  112
     CL1         VAVE      ADD  BVAVE     BVAVE  112
     CL1                   WRITEGBFPR872
     CL1         L         ADD  1         L
     CL1                   Z-ADD0         SRYO   112
     CL1                   Z-ADD0         ZRYO   112
     CL1                   Z-ADD0         KONU   112
     CL1                   Z-ADD0         KAKO   112
     CL1                   Z-ADD0         KANR   112
     CL1                   Z-ADD0         KATA   112
     CL1                   Z-ADD0         VAVE   112
     CL1         *INL2     IFEQ '0'
     CL1         L         IFGE 50
     CL1                   WRITEGBFPR871
     CL1                   Z-ADD0         L
     CL1                   END
     CL1                   END
     C******************************************************
     C* M-NO BF.6.3.3      jﾞbﾎﾞ]ﾓb ﾉ ﾃﾞcib b]ﾅl           *
     C******************************************************
     CL2         TSRYO     IFNE 0
