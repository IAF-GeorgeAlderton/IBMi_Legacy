     FAABPW01 CF  E                    WORKSTN
     FAABPL01 UF  E           K        DISK                      A
     FAABNP01 O   E                    DISK
     E                    KOS     1   3  1   KON     6   ﾃcﾆ]hﾎﾞ]
     E                    ER      1   8 60
     I            DS
     I                                        1   60WTIME
     I                                        1   20A4KOHH
     I                                        3   40A4KOSS
     I            DS
     I                                        1  22 A4SETK
     I                                        2  21 WSETK
     I            DS
     I                                        1   80A4SKHZ
     I                                        1   40A4SKYY
     I                                        5   60A4SKMM
     I                                        7   80A4SKDD
     I            DS
     I                                        1   80A4KOHZ
     I                                        1   40A4KOYY
     I                                        5   60A4KOMM
     I                                        7   80A4KODD
     C           *ENTRY    PLIST
     C                     PARM           USER   10        ﾏｰﾅﾞｰ xb
     C                     Z-ADD0         A4SKHZ
     C           STP1      TAG
     C                     EXFMTAABPW011
     C                     SETOF                     010299
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C*
     C*----------------------------------------*
     C*     ...更新区分　の　チェック...     *
     C*----------------------------------------*
     C                     SETOF                     90
     C                     Z-ADD1         A       10
     C           KTYPE     LOKUPKOS,A                    90
     C           *IN90     IFEQ '0'
     C                     SETON                     0199
     C                     MOVE ER,1      ERMSG
     C                     GOTO STP1
     C                     END
     C                     MOVE KON,A     WNAME
     C*
     C*------------------------------------------*
     C*     ...設定コード　の　チェック...     *
     C*------------------------------------------*
     C                     MOVE WSETI     A4SETI
     C           WSETI     IFLT '00'
     C                     SETON                     0299
     C                     MOVE ER,2      ERMSG
     C                     GOTO STP1
     C                     END
     C*
     C*----------------------------------------*
     C*     ...マスター　の　チェック...     *
     C*----------------------------------------*
     C                     SETOF                     90
     C           A4SETI    CHAINAABPL011             90
     C           KTYPE     IFEQ '2'
     C           *IN90     IFEQ '0'
     C           A4SKJY    IFEQ 'D'
     C           A4SKHZ    ANDLE*DATE
     C                     GOTO STP3
     C                     END
     C                     SETON                     010299
     C                     MOVE ER,3      ERMSG
     C                     GOTO STP1
     C                     END
     C                     END
     C*
     C           KTYPE     IFEQ '1'
     C           *IN90     IFEQ '1'
     C                     SETON                     010299
     C                     MOVE ER,4      ERMSG
     C                     GOTO STP1
     C                     END
     C           A4SKJY    IFEQ 'D'
     C           A4SKHZ    ANDLE*DATE
     C                     SETON                     010299
     C                     MOVE ER,5      ERMSG
     C                     GOTO STP1
     C                     END
     C                     END
     C*
     C           KTYPE     IFEQ '0'
     C           *IN90     IFEQ '1'
     C                     SETON                     010299
     C                     MOVE ER,6      ERMSG
     C                     GOTO STP1
     C                     END
     C           A4SKJY    IFEQ 'D'
     C           A4SKHZ    ANDLE*DATE
     C                     SETON                     010299
     C                     MOVE ER,7      ERMSG
     C                     GOTO STP1
     C                     END
     C                     END
     C           STP3      TAG
     C*
     C           KTYPE     IFEQ '2'
     C                     MOVE *BLANK    A4SETK
     C                     MOVE *BLANK    A4SETN
     C                     END
     C*
     C*------------------------------*
     C*     ...画面　－　２...     *
     C*------------------------------*
     C           STP4      TAG
     C                     EXFMTAABPW012
     C*****                SETOF                     0499
     C                     SETOF                     99
     C           *INKC     IFEQ '1'
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C                     END
     C*
     C*--------------------------------------*
     C*     ...設定名　の　チェック...     *
     C*--------------------------------------*
     C*****      WSETK     IFEQ *BLANK
     C*****                SETON                     0499
     C*****                MOVE ER,8      ERMSG
     C*****                GOTO STP3
     C*****                END
     C*
     C           *INKE     IFEQ '0'
     C                     GOTO STP4
     C                     END
     C*
     C           KTYPE     IFEQ '0'
     C                     MOVE 'D'       A4SKJY
     C                     Z-ADD*DATE     A4SKHZ
     C                     ELSE
     C                     MOVE *BLANK    A4SKJY
     C                     Z-ADD0         A4SKHZ
     C                     END
     C                     Z-ADD*DATE     A4KOHZ
     C                     TIME           WTIME
     C           *IN90     IFEQ '0'
     C                     UPDATAABPL011
     C                     ELSE
     C                     WRITEAABPL011
     C                     END
     C*ネットワークファイル*
     C                     WRITEAABNP011
     C                     SETON                     U1
     C*
     C                     MOVE KTYPE     MTYPE
     C                     MOVE WSETI     MSETI
     C                     MOVE WNAME     MNAME
     C                     SETON                     03
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C*
     C*----------------------------------------*
     C*         ...サブルーチン...           *
     C*     ...画面－１　の　クリアー...     *
     C*----------------------------------------*
     C           SUBRTN    BEGSR
     C                     MOVE *BLANK    KTYPE
     C                     MOVE *BLANK    WSETI
     C                     ENDSR
**  KOS.KON
0CANCEL
1CHANGE
2ADD
**  ER
E-01 UPDATE INSTRUCTION IS <0 1 2>.
E-02 INPUT SETTING CODE WITH NUMBER
E-03 ADD WAS APPOINTED BUT M/F EXIST
E-04 CHANGE WAS APPOINTED BUT M/F DON'T EXIST
E-05 CHANGE WAS APPOINTED BUT M/F IS CANCELLED ALREADY
E-06 CANCEL WAS APPOINTED BUT M/F DON'T EXIST
E-07 CANCEL WAS APPOINTED BUT M/F IS CANCELLED ALREADY
E-08 INPUT SETTING NAME(KANJI)
