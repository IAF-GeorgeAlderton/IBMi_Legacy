     H            Y.
      ** AJSRB0 ************************************
      *DATA CREATE  WHICH  FA PLATING DETAILS ADMITTED LIST*
      * C:N.HAYAKAWA         94.02.24              *
      **********************************************
     FAJSPWB0 CF  E                    WORKSTN
     FAJSPL55 IF  E           K        DISK
     FAJSPL54 IF  E           K        DISK
     FAJSWPB0 O   F      70            DISK                      A
     E                    GOK        10  2               xｮg gﾌﾞ](fﾞx])
     E                    ERM     1   3 60               d[ｰxｮﾈｰﾆﾞ
     I            DS
     I                                        1  20 GOK
     I                                        1   2 @GOK01
     I                                        3   4 @GOK02
     I                                        5   6 @GOK03
     I                                        7   8 @GOK04
     I                                        9  10 @GOK05
     I                                       11  12 @GOK06
     I                                       13  14 @GOK07
     I                                       15  16 @GOK08
     I                                       17  18 @GOK09
     I                                       19  20 @GOK10
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTIMEX
     I                                        7  140WDATEX
     I                                        1   20WJI
     I                                        3   40WFN
     I                                        5   60WBY
     I                                        7  100WYEAR
     I                                       11  120WMONTH
     I                                       13  140WDAY
     I                                        1   2 XJI
     I                                        3   4 XFN
     I                                        5   6 XBY
     I                                        7  10 XYEAR
     I                                       11  12 XMONTH
     I                                       13  14 XDAY
     I            DS
     I                                        1  100EDDAY
     I                                        1   4 @EDYY
     I                                        5   6 @EDMM
     I                                        7   8 @EDDD
     I                                        9  10 @EDHH
     I            DS
     I                                        1  100J5WIN
     I                                        1   40J5WINY
     I                                        5   60J5WINM
     I                                        7   80J5WIND
     I                                        9  100J5WINJ
     C           *ENTRY    PLIST
     C                     PARM           USW1    1
     C**************************
     C*  画面出力とチェック  *
     C**************************
     C           STEP0     TAG
     C                     MOVE '99'      @GOK01
     C                     MOVE *BLANK    @GOK02
     C                     MOVE *BLANK    @GOK03
     C                     MOVE *BLANK    @GOK04
     C                     MOVE *BLANK    @GOK05
     C                     MOVE *BLANK    @GOK06
     C                     MOVE *BLANK    @GOK07
     C                     MOVE *BLANK    @GOK08
     C                     MOVE *BLANK    @GOK09
     C                     MOVE *BLANK    @GOK10
     C                     MOVE *BLANK    @STYY
     C                     MOVE *BLANK    @STMM
     C                     MOVE *BLANK    @STDD
     C                     MOVE *BLANK    @STHH
     C                     TIME           WTIMEX
     C                     Z-ADD*DATE     WDATEX
     C                     MOVE XYEAR     @EDYY
     C                     MOVE XMONTH    @EDMM
     C                     MOVE XDAY      @EDDD
     C                     MOVE XJI       @EDHH
     C*
     C           STEP1     TAG
     C                     EXFMTAJSPWB01
     C                     SETOF                     998081
     C                     SETOF                     82
     C                     MOVE *BLANK    @ERR
     C* CMD-1チェック
     C           *INKA     IFEQ '1'
     C                     MOVE '*'       USW1    1
     C                     GOTO END
     C                     END
     C*号機チェック
     C                     SETOF                     70
     C           1         DO   10        I       20
     C           GOK,I     IFNE *BLANK
     C                     SETON                     70
     C                     END
     C                     END
     C           *IN70     IFEQ '0'
     C                     SETON                     9980
     C                     MOVE ERM,1     @ERR
     C                     GOTO STEP1
     C                     END
     C*開始日付チェック
     C           @STYY     IFEQ *BLANK
     C           @STMM     OREQ *BLANK
     C           @STDD     OREQ *BLANK
     C           @STHH     OREQ *BLANK
     C                     SETON                     9981
     C                     MOVE ERM,2     @ERR
     C                     GOTO STEP1
     C                     END
     C*年*
     C           @STYY     IFGT XYEAR
     C                     SETON                     9981
     C                     MOVE ERM,2     @ERR
     C                     GOTO STEP1
     C                     END
     C*月*
     C           @STMM     IFLT '01'
     C           @STMM     ORGT '12'
     C                     SETON                     9981
     C                     MOVE ERM,2     @ERR
     C                     GOTO STEP1
     C                     END
     C*日*
     C           @STDD     IFLT '01'
     C           @STDD     ORGT '31'
     C                     SETON                     9981
     C                     MOVE ERM,2     @ERR
     C                     GOTO STEP1
     C                     END
     C*終了日付チェック
     C           @EDYY     IFEQ *BLANK
     C           @EDMM     OREQ *BLANK
     C           @EDDD     OREQ *BLANK
     C           @EDHH     OREQ *BLANK
     C                     SETON                     9982
     C                     MOVE ERM,3     @ERR
     C                     GOTO STEP1
     C                     END
     C*年*
     C           @EDYY     IFGT XYEAR
     C                     SETON                     9982
     C                     MOVE ERM,3     @ERR
     C                     GOTO STEP1
     C                     END
     C*月*
     C           @EDMM     IFLT '01'
     C           @EDMM     ORGT '12'
     C                     SETON                     9982
     C                     MOVE ERM,3     @ERR
     C                     GOTO STEP1
     C                     END
     C*日*
     C           @EDDD     IFLT '01'
     C           @EDDD     ORGT '31'
     C                     SETON                     9982
     C                     MOVE ERM,3     @ERR
     C                     GOTO STEP1
     C                     END
     C* CMD-5チェック*
     C           *INKE     IFEQ '0'
     C                     GOTO STEP1
     C                     END
     C*最初の号機が９９かチェック*
     C           @GOK01    IFEQ '99'
     C                     GOTO ALLKBN
     C                     END
     C**************************************
     C*指定号機でメッキ排出実績の抜き出し*
     C* AJSPL15 KEY=KIBAN,WINDAY           *
     C**************************************
     C           KEY1      KLIST
     C                     KFLD           KKIBAN  2
     C                     KFLD           KWINYY  40
     C                     KFLD           KWINMM  20
     C                     KFLD           KWINDD  20
     C                     KFLD           KWINJI  20
     C                     MOVE @STYY     KWINYY
     C                     MOVE @STMM     KWINMM
     C                     MOVE @STDD     KWINDD
     C                     MOVE @STHH     KWINJI
     C*画面入力が有った号機を出す
     C           1         DO   10        I       20
     C           GOK,I     IFNE *BLANK
     C******
     C                     MOVE GOK,I     KKIBAN
     C           KEY1      SETLLAJSPL551
     C           LOOP1     TAG
     C                     SETOF                     10
     C                     READ AJSPL551                 10
     C* EOF?
     C           *IN10     IFEQ '1'
     C                     GOTO EXIT1
     C                     END
     C* DEL?
     C           J5SKJY    IFEQ 'D'
     C                     GOTO LOOP1
     C                     END
     C* J5HNTE=2? (再投入) *
     C*******>>  J5HNTE    IFNE '2'
     C*******>>            GOTO LOOP1
     C*******>>            END
     C* J5SAIK=1? (再投入) *
     C           J5SAIK    IFNE '1'
     C                     GOTO LOOP1
     C                     END
     C* GOUKI?
     C           J5MKKB    IFNE KKIBAN
     C                     GOTO EXIT1
     C                     END
     C* KEY DATE?
     C           J5WIN     IFGT EDDAY
     C                     GOTO EXIT1
     C                     END
     C* WORKFILE OUT
     C                     EXCPTOUT
     C                     SETON                     11
     C* TO LOOP
     C                     GOTO LOOP1
     C******
     C                     END
     C           EXIT1     TAG
     C                     ENDDO
     C*終了へ*
     C                     GOTO END
     C****************************************
     C*全号機指定でメッキ排出実績の抜き出し*
     C*   AJSPL54 KEY=WINDAY                 *
     C****************************************
     C           ALLKBN    TAG
     C           KEY2      KLIST
     C                     KFLD           KWINYY  40
     C                     KFLD           KWINMM  20
     C                     KFLD           KWINDD  20
     C                     KFLD           KWINJI  20
     C                     MOVE @STYY     KWINYY
     C                     MOVE @STMM     KWINMM
     C                     MOVE @STDD     KWINDD
     C                     MOVE @STHH     KWINJI
     C*全号機を出す
     C           KEY2      SETLLAJSPL541
     C           LOOP2     TAG
     C                     SETOF                     10
     C                     READ AJSPL541                 10
     C* EOF?
     C           *IN10     IFEQ '1'
     C                     GOTO EXIT2
     C                     END
     C* DEL?
     C           J5SKJY    IFEQ 'D'
     C                     GOTO LOOP2
     C                     END
     C* J5HNTE=2? (再投入) *
     C*******>>  J5HNTE    IFNE '2'
     C*******>>            GOTO LOOP2
     C*******>>            END
     C* J5SAIK=1? (再投入) *
     C           J5SAIK    IFNE '1'
     C                     GOTO LOOP2
     C                     END
     C* KEY DATE?
     C           J5WIN     IFGT EDDAY
     C                     GOTO EXIT2
     C                     END
     C* WORKFILE OUT
     C                     EXCPTOUT
     C                     SETON                     11
     C* TO LOOP
     C                     GOTO LOOP2
     C           EXIT2     TAG
     C*ＰＧＭ終了*
     C           END       TAG
     C           *IN11     IFEQ '0'
     C                     MOVE '*'       USW1
     C                     END
     C                     SETON                     LR
     C                     RETRN
     OAJSWPB0 EADD             OUT
     O                         J5HIN1     5
     O                         J5HIN2    10
     O                         J5HIN3    12
     O                         J5MKTE    13
     O                         J5MKSU    16
     O                         J5IRTE    17
     O                         J5IROK    18
     O                         J5TANJ    25
     O                         J5THAI    28
     O                         J5PAG1    30
     O                         J5PAG2    32
     O                         J5PAG3    34
     O                         J5PAG4    36
     O                         J5WINY    40
     O                         J5WINM    42
     O                         J5WIND    44
     O                         J5WINJ    46
     O                         J5WINF    48
     O                         J5MKKB    50
     O                         J5KEIY    54
     O                         J5KEIM    56
     O                         J5KEID    58
     O                         J5KEIJ    60
     O                         J5KEIF    62
