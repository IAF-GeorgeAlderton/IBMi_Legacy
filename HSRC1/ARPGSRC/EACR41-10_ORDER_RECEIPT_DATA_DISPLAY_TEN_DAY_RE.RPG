     H            Y                                                       RBCR27
     F********************************************
     F*10 ORDER RECEIPT DATA  DISPLAY TEN-DAY REPORT FORM
     F* MAR.16,'87. GBC                          *
     F********************************************
     FEACPW41 CF  E                    WORKSTN
     F                                              KNUM        1
     F                                              KINFDS FEEDBK
     FAGDPL12 IF  E           K        DISK
     E                    ER      1   8 60               d[- ﾌbﾛl
     E                    YMD        10  8               ﾆﾞﾏ] ﾍﾇﾞi
     E                    DD         10  2               ﾆﾞﾏ] pk
     E                    YA         10  1               zﾇv '*'
     I            DS
     I                                        1   80F8KAHZ
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I            DS
     I                                        1   80SHIZK
     I                                        1   40UYY
     I                                        5   60UMM
     I                                        7   80UDD
     I            DS
     I                                        1  80 YMD
     I                                        1  80 YMDXX
     I            DS
     I                                        1  20 DD
     I                                        1  20 DDXX
     I            DS
     I                                        1  10 YA
     I                                        1  10 YAXX
     IFEEDBK      DS
     I                                     *STATUS  @STTS
     C****************************************************************
     C*  START PROGRAM  <EACR41>                                     *
     C****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           YMD10  80
     C                     PARM           PDD    20
     C                     PARM           PYA    10
     C                     MOVE *BLANK    YMD10
     C                     MOVE *BLANK    PDD
     C                     MOVE *BLANK    PYA
     C*
     C                     Z-ADD0         SHIZK
     C                     MOVE '2'       DKBN
     C                     MOVE *BLANK    MSG
     C                     MOVEA'00000'   *IN,01
     C                     MOVEA'0'       *IN,99
     C****************************************************************
     C*  EXFMT <fﾞx] 1>                                              *
     C****************************************************************
     C           STP01     TAG
     C                     WRITEEACPW411
     C                     READ EACPW41                0304
     C           *IN03     IFEQ '1'
     C           @STTS     ANDEQ1331
     C                     SETON                     99
     C                     MOVE ER,8      MSG
     C                     GOTO STP01
     C                     END
     C*
     C           *INKA     IFEQ '1'
     C                     SETON                     U2LR
     C                     RETRN
     C                     END
     C*
     C                     MOVE *BLANK    MSG
     C                     MOVEA'00000'   *IN,01
     C                     MOVEA'0'       *IN,99
     C*
     C*  fﾞx] ﾉ kｩｮh
     C*
     C           UYY       IFLT 1986
     C                     MOVE ER,1      MSG
     C                     SETON                     0199
     C                     GOTO STP01
     C                     END
     C           UYY       IFGT 1999
     C                     MOVELER,2      MSG
     C                     SETON                     0199
     C                     GOTO STP01
     C                     END
     C           UMM       IFGT 12
     C                     MOVELER,3      MSG
     C                     SETON                     0199
     C                     GOTO STP01
     C                     END
     C           UMM       IFLT 01
     C                     MOVELER,4      MSG
     C                     SETON                     0199
     C                     GOTO STP01
     C                     END
     C           UDD       IFGT 31
     C                     MOVELER,5      MSG
     C                     SETON                     0199
     C                     GOTO STP01
     C                     END
     C           UDD       IFLT 01
     C                     MOVELER,6      MSG
     C                     SETON                     0199
     C                     GOTO STP01
     C                     END
     C           DKBN      IFNE '1'
     C           DKBN      IFNE '2'
     C                     SETON                     0299
     C                     MOVELER,7      MSG
     C                     GOTO STP01
     C                     END
     C                     END
     C******************************************************
     C*     ﾅbﾆﾑﾉ ﾍﾇﾞif[ 10ff]ﾉ fﾛ]jﾞ- n zﾇv ﾉ kdlh        *
     C******************************************************
     C                     MOVE *BLANK    YMD
     C                     MOVE *BLANK    DD
     C                     MOVE *BLANK    YA
     C*
     C           CKEY      KLIST
     C                     KFLD           UYY
     C                     KFLD           UMM
     C                     KFLD           UDD
     C                     Z-ADD0         I       20
     C           CKEY      SETLLAGDPL121
B001 C           I         DOUGE10
     C                     READ AGDPL121                 10
B002 C           *IN,10    IFEQ '0'
B003 C           DKBN      IFEQ '1'
B004 C           F8HIRU    IFEQ '*'
     C           F8YORU    OREQ '*'
     C                     GOTO STP02
E004 C                     END
E003 C                     END
     C*
     C                     ADD  1         I
     C                     MOVELF8KAHZ    YMD,I
     C                     MOVELF8KADD    DD,I
B003 C           F8HIRU    IFEQ '*'
     C           F8YORU    OREQ '*'
     C                     MOVE '*'       YA,I
E003 C                     END
     C*
     C                     END
     C           STP02     TAG
     C  N10                END
     C*
     C                     MOVELYMDXX     YMD10
     C                     MOVELDDXX      PDD
     C                     MOVELYAXX      PYA
     C                     MOVEL'1'       *INLR
     C                     RETRN
**  ER (ERROR MESSAGE )
E-01 YEAR OF INPUT DATE IS SMALLER THAN 86.
E-02 YEAR OF INPUT DATE IS SMALLER THAN 95.
E-03 MONTH OF INPUT DATE IS SMALLER THAN 12.
E-04 MONTH OF INPUT DATE IS SMALLER THAN 01.
E-05 DAY OF INPUT DATE IS SMALLER THAN 31.
E-06 DAY OF INPUT DATE IS SMALLER THAN 01.
E-07 SELECT OF HOLIDAY OF AOYAMA ISN'T RIGHT. <1.2>
E-08 RETURN TO SCREEN OF A PASSWORD WHEN DON'T USE LONG TIME
