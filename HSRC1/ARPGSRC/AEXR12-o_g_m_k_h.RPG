     FMCENP13 IF  E           K        DISK
     FABMWP21 IF  E           K        DISK
     FABMPP81 IF  E           K        DISK
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1KHN1  5
     C                     PARM           P1KHN2  5
     C                     PARM           P1KHN3  2
     C                     PARM           P9OMIT  1
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
     C           KEYMCE    KLIST
     C                     KFLD           P1KHN1
     C                     KFLD           P1KHN2
     C                     KFLD           P1KHN3
     C                     MOVEL'1'       P9OMIT  1
     C           KEYMCE    SETLLMCENP131
     C           KEYMCE    READEMCENP131                 81
     C           *IN81     DOWEQ'0'
     C                     EXSR #SB411
     C           KEYMCE    READEMCENP131                 81
     C                     ENDDO
      *
     C           P9OMIT    IFEQ '0'
     C                     EXSR #SB422
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------------------------*
      * SALES DATA                                  *
      *---------------------------------------------*
     CSR         #SB411    BEGSR
      *
     C           KEYB11    KLIST
     C                     KFLD           MCSHN1
     C                     KFLD           MCSHN2
     C                     KFLD           MCSHN3
     C           KEYB11    SETLLABMWP211
     C           KEYB11    READEABMWP211                 82
     C           *IN82     DOWEQ'0'
