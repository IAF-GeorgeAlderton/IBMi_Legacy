     C                     MOVEL'0'       P9OMIT
     C                     ENDIF
     C           KEYB11    READEABMWP211                 82
     C                     ENDDO
      *
     CSR         ESB411    ENDSR
      *---------------------------------------------*
      * NON UPDATE M/F                              *
      *---------------------------------------------*
     CSR         #SB422    BEGSR
      *
     C           KEYMCE    CHAINABMPP811             41
     C           *IN41     IFEQ '0'
