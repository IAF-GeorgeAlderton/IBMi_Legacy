     H            Y.
      ** AB#R2L3 ************************************************************
      *  ..HONDA LABEL ---- SORT SEQUENCE                                   *
      *  LEC  09/20/19                                                      *
      ***********************************************************************
      *
     FAB#WP2U IF  E           K        DISK
     FAB#WP2V IF  E           K        DISK
     FAB#WPU  O   E                    DISK                      A
     FAB#WPV  O   E                    DISK                      A
      *
      ***********************************************************
      *
     C           *ENTRY    PLIST
     C                     PARM           PBLK    2
     C                     PARM           PBLK2   2
      *
      *  get location 1 from both workfiles...
      *      first get location 1 from A&B label workfile....
      *
     C           PBLK      IFNE *BLANKS
      *
     C           PBLK      CHAINAB#WP2U              52
      *
     C           *IN52     DOWEQ*OFF
     C                     WRITEAB#WPU1
     C           PBLK      READEAB#WP2U                  52
     C                     ENDDO
      *
      *      then get location 1 from master label workfile....
      *
     C           PBLK      CHAINAB#WP2V              52
      *
     C           *IN52     DOWEQ*OFF
     C                     WRITEAB#WPV1
     C           PBLK      READEAB#WP2V                  52
     C                     ENDDO
      *
     C                     ENDIF
      *
      *
      *  get location 2 from both workfiles...
      *      first get location 2 from A&B label workfile....
      *
     C           PBLK2     IFNE *BLANKS
      *
     C           PBLK2     CHAINAB#WP2U              52
      *
     C           *IN52     DOWEQ*OFF
     C                     WRITEAB#WPU1
     C           PBLK2     READEAB#WP2U                  52
     C                     ENDDO
      *
      *      then get location 2 from master label workfile....
      *
     C           PBLK2     CHAINAB#WP2V              52
      *
     C           *IN52     DOWEQ*OFF
     C                     WRITEAB#WPV1
     C           PBLK2     READEAB#WP2V                  52
     C                     ENDDO
      *
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ***********************************************************
