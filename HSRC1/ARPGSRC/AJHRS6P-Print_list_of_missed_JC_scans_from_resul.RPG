      ** AJHRS6P  **********************************************
      *  LIST OF MISSED JC SCANS FROM RESULTS UPLOAD.          *
      *  THESE HAD TO BE SCANNED AFTER THE FACT BY L PROGRAM.  *
      * LEC   2024/06/21                                       *
      **********************************************************
     FAJHWPS1 UF  E           K        DISK
     FALBPL30 IF  E           K        DISK
     FFCEPL07 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *
     E                    TBL     1   1 50
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
      *
      * EDITED PART NUMBER
     I            DS
     I                                        1  14 #PART#
     I                                        1   5 MHN1
     I                                        6   6 DASH1
     I                                        7  11 MHN2
     I                                       12  12 DASH2
     I                                       13  14 MHN3
      *
      * APICS BARCODE
     I            DS
     I                                        1  20 JDBARC
     I                                        2   5 #ZETI
     I                                        6   8 #LOT#
     I                                        9  10 #PAGE#
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  14 SDATE
     I                                        1   6 STIME
      *
     I            DS
     I                                        1   60JDKOTM
     I                                        1   40#KOTM
      *
     C           *ENTRY    PLIST
     C                     PARM           PRT     1
      *
     C                     MOVE *BLANK    PRT
      *
     C                     DO   *HIVAL
      *
     C                     READ AJHWPS1                  99
     C   99                LEAVE
      *
     C           JDSKJY    IFEQ 'D'
     C                     ITER
     C                     ELSE
      *
     C           W@1STP    IFEQ *ON
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     MOVEL*OFF      W@1STP
     C                     ENDIF
      *
     C                     MOVELJDWOKR    K@TMCD  60
     C           K@TMCD    CHAINALBPL30              97
     C  N97                MOVELALWKNM    #TMNAM 20
     C   97                MOVEL*BLANK    #TMNAM
      *
     C           #ZETI     CHAINFCEPL07              97
     C           *IN97     IFEQ *OFF
     C                     MOVELA2BHB1    MHN1
     C                     MOVELA2BHB2    MHN2
     C                     MOVELA2BHB3    MHN3
     C                     ENDIF
      *
     C           MHN3      IFEQ *BLANK
     C                     MOVE *BLANK    DASH2
     C                     ELSE
     C                     MOVE '-'       DASH2
     C                     ENDIF
      *
     C                     EXCPT@DTL
      *
     C                     MOVE 'D'       JDSKJY
     C                     UPDATAJHWPS11
      *
     C                     MOVE 'Y'       PRT
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
      * INITIAL SET
      *-----------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     MOVEL'-'       DASH1
     C                     TIME           WSDT
     C                     Z-ADDWSDT      WTIME
     C                     MOVEL*ON       W@1STP  1
      *
     C                     ENDSR
      *
      *-----------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM      10
     O                         TBL,1     69
     O                                  107 'Date'
     O                         WSSDATY  118
     O                                  126 'Page'
     O                         PAGE  Z  130
     O        E   02           @HED
     O                                  107 'Time'
     O                         WSSTM6   118 '  :  :  '
     O        E   03           @HED
     O                                   11 'Scan Date'
     O                                   18 'Time'
     O                                   27 'TM Name'
     O                                   54 'Part Number'
     O                                   75 'PartID   Lot#'
     O                                  101 'Page     Kanban Barcode'
     O        E 1              @DTL
     O                         JDKODTY   11
     O                         #KOTM     18 ' 0:  '
     O                         #TMNAM    40
     O                         #PART#    57
     O                         #ZETI     67
     O                         #LOT#     75
