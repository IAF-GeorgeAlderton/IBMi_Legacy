     C                     MOVEADATA      ARY
      *  B0------------------------------------------0B
      * DATE
     C           *IN99     IFEQ *OFF
     C                     Z-ADD1         X       30
      *  CHANGE
     C           '5DAYS'   SCAN DATA      X              10
     C  N10                GOTO @END
      *
     C           ','       LOKUPARY,X                    10
     C  N10                GOTO @END
      *
     C                     Z-ADD*ZERO     DT1
     C                     Z-ADD*ZERO     DT2
     C                     Z-ADD*ZERO     Z       30
     C                     MOVE *BLANK    A11
     C                     MOVE *BLANK    A12
     C                     Z-ADD*ZERO     Y       30
     C                     MOVE *OFF      *IN90
      *      B1---------------------------1B
     C                     DO   *HIVAL
     C                     ADD  1         X
      *           B2------------------2B
     C           *IN90     IFEQ *ON
     C           ARY,X     ANDEQ','
      *               B3--------3B
     C           A11,2     IFEQ *BLANK
     C                     MOVE A11,1     A11,2
     C                     MOVE '0'       A11,1
     C                     ENDIF
      *               E3--------3E
      *               B3--------3B
     C           A12,2     IFEQ *BLANK
     C                     MOVE A12,1     A12,2
     C                     MOVE '0'       A12,1
     C                     ENDIF
      *               E3--------3E
      *
     C                     MOVEAA11       MM
     C                     MOVEAA12       DD
      *               B3--------3B
     C           MM        IFGE @@MM
     C                     Z-ADD*YEAR     YEAR
     C                     ELSE
     C           *YEAR     ADD  1         YEAR
     C                     ENDIF
      *               E3--------3E
      *
     C                     ADD  1         Z
     C                     Z-ADDDATE      DT1,Z
     C                     Z-ADDZ         ZZ      30
      *
     C                     MOVE *BLANK    A11
     C                     MOVE *BLANK    A12
     C                     Z-ADD*ZERO     Y       30
     C                     MOVE *OFF      *IN90
     C                     ITER
     C                     ENDIF
      *           E2------------------2E
      *
      *           B2------------------2B
     C           ARY,X     IFEQ '/'
     C                     MOVE *ON       *IN90
     C                     Z-ADD*ZERO     Y
     C                     ITER
     C                     ENDIF
      *           E2------------------2E
      *
      *           B2------------------2B
     C           ARY,X     IFGE 'A'
     C           ARY,X     ANDLE'Z'
     C                     LEAVE
     C                     ENDIF
      *           E2------------------2E
      *
     C                     ADD  1         Y
      *           B2------------------2B
     C           *IN90     IFEQ *OFF
     C                     MOVE ARY,X     A11,Y
     C                     ELSE
     C                     MOVE ARY,X     A12,Y
     C                     ENDIF
      *           E2------------------2E
     C                     ENDDO
      *      E1---------------------------1E
      *
     C                     MOVE *ON       *IN99
      *
     C           MDATE     IFNE *BLANK
     C                     Z-ADDMINDT     DT2,1
     C                     ENDIF
      *
     C                     WRITEGWCAL1R
     C                     GOTO @END
     C                     ENDIF
      *  E0------------------------------------------0E
      *  DETAIL
      *  B0------------------------------------------0B
     C           *IN99     IFEQ *ON
     C           ARY,1     CABEQ','       @END
      * PART#
     C                     CLEARGWSCD1R
     C                     Z-ADD11        X
     C                     Z-ADDX         Z
     C           ','       LOKUPARY,X                    10
     C           X         SUB  Z         Y
     C           Y         SUBSTDATA:Z    PRT1      P
      *
     C                     ADD  1         X
     C                     Z-ADDX         Z
     C           ','       LOKUPARY,X                    10
     C           X         SUB  Z         Y
     C           Y         SUBSTDATA:Z    PRT2
      *
     C                     ADD  1         X
      *       B1----------------------------1B
     C           ARY,X     IFEQ ','
     C                     MOVE *BLANK    PRT3
     C                     ELSE
     C                     Z-ADDX         Z
     C           ','       LOKUPARY,X                    10
     C           X         SUB  Z         Y
     C           Y         SUBSTDATA:Z    PRT3      P
     C                     ENDIF
      *       E1----------------------------1E
      *
      *       B1----------------------------1B
      *  SKIP COMMANS
     C                     DO   5
     C                     ADD  1         X
     C           ','       LOKUPARY,X                    10
     C                     ENDDO
      *       E1----------------------------1E
      * QTY
     C                     Z-ADD*ZERO     Y
     C                     Z-ADD*ZERO     Z
     C                     Z-ADD*ZERO     @CNT    30
     C                     MOVE *BLANK    A31
     C                     MOVE *OFF      *IN90
      *       B1----------------------------1B
     C                     DO   *HIVAL
     C                     ADD  1         X
      *             B2-----------------2B
     C           ARY,X     IFEQ *BLANK
     C                     ADD  1         @CNT
      *                B3----------3B
     C           @CNT      IFGT 3
     C                     LEAVE
     C                     ELSE
     C                     ITER
     C                     ENDIF
      *                E3----------3E
     C                     ENDIF
      *             E2-----------------2E
      *
     C                     Z-ADD*ZERO     @CNT    30
      *             B2-----------------2B
     C           ARY,X     IFEQ ','
      *                B3----------3B
     C           *IN90     IFEQ *OFF
     C                     ADD  1         Y
     C                     Z-ADD*ZERO     ORA,Y
     C           Y         IFGE ZZ
     C                     LEAVE
     C                     ENDIF
      *
     C                     ITER
     C                     ELSE
      *
     C                     MOVE *ALL'0'   A32
     C                     Z-ADD3         W       30
     C                     Z-ADD3         Z       30
      *                   B4----4B
     C                     DO   3
      *                    B5-5B
     C           A31,W     IFNE *BLANK
     C           A31,W     ANDNE'.'
     C                     MOVE A31,W     A32,Z
     C                     SUB  1         Z
     C                     ENDIF
      *                    E5-5E
     C                     SUB  1         W
     C           W         IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *                   E4----4E
      *
     C                     MOVEAA32       @3      3
     C                     ADD  1         Y
     C                     MOVE @3        ORA,Y
      *
     C           Y         IFGE ZZ
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVE *OFF      *IN90
     C                     Z-ADD*ZERO     Z
     C                     MOVE *BLANK    A31
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      *
     C           ARY,X     IFNE '.'
     C                     ADD  1         Z
     C  N90                MOVE *ON       *IN90
     C                     MOVE ARY,X     A31,Z
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           MDATE     IFNE *BLANK
     C                     XFOOTORA       ORS,1
     C                     ENDIF
      *
     C                     WRITEGWSCD1R
     C                     ENDIF
      *
     C           @END      TAG
