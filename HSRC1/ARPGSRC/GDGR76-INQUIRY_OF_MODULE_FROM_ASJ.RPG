      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#GC      KLIST
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C                     KFLD           K@DD    20
      *
     C           K#GDL     KLIST
     C                     KFLD           LBODR1
     C                     KFLD           LBODR2
     C                     KFLD           LBODR3
      *
     C           K#GL      KLIST
     C                     KFLD           K@ZAIS 15
     C                     KFLD           K@ZAIK  52
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#GLX     KLIST
     C                     KFLD           K@ZAIS 15
     C                     KFLD           K@ZAIK  52
      *
     C           K#ORD     KLIST
     C                     KFLD           K@OR01  20
     C                     KFLD           K@OR02  20
     C                     KFLD           K@OR03  20
      *
     C                     MOVEL'01'      W@ID    2
     C                     Z-ADD*ZERO     DT4
     C                     Z-ADD*ZERO     ORD
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET
     C           RRN1      IFNE *ZERO
     C                     MOVE '02'      W@ID
     C                     ELSE
     C                     MOVE ERR,1     D@MSG
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
      *
     C           D@FRM     IFEQ *ZERO
     C           D@ORNO    ANDEQ*ZERO
     C                     MOVEA'11'      *IN,61
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C           D@OPTN    IFGE '5'
     C                     MOVE *ON       *IN62
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *OFF      *IN99
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA
      *------------------------------------------------------
     C           #SET      BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
      *
     C                     Z-ADD*ZERO     RRN1    40
      *
     C                     EXSR #CLR
     C                     Z-ADD*ZERO     TOT
     C                     Z-ADD*ZERO     ORD
      * ORDER DATE
     C           D@FRM     IFNE *ZERO
     C                     EXSR #DATE
     C                     ELSE
     C                     EXSR #ORD
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C                     SELEC
      * PRODUCT
     C           D@OPTN    WHEQ '1'
     C                     EXSR #PRD
      * WASHER
     C           D@OPTN    WHEQ '2'
     C                     EXSR #WAS
      * WIRE
     C           D@OPTN    WHEQ '3'
     C                     EXSR #MAT
      * DIE
     C           D@OPTN    WHEQ '4'
     C                     EXSR #DIE
      * ALL
     C           D@OPTN    WHEQ ' '
     C                     EXSR #PRD
     C                     EXSR #WAS
     C                     EXSR #MAT
     C                     EXSR #DIE
      *
     C                     ENDSL
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   ORDER DATE
      *------------------------------------------------------
     C           #DATE     BEGSR
      *
     C                     Z-ADD*ZERO     DT8
     C                     Z-ADDD@FRM     K@YMD
     C                     Z-ADD*ZERO     X       30
TCHK1C*          K#GC      SETGTAGDPL12
TCHK1C           K#GC      SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READ AGDPL12                  90
     C           *IN90     IFEQ *OFF
     C                     ADD  1         X
TCHK1C*          X         IFEQ 7
TCHK1C           X         IFEQ 2
     C                     Z-ADDF8YMD     DT8,1
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADDD@FRM     K@YMD
     C                     Z-ADD1         X       30
      *
     C           K#GC      SETGTAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C********** F8YOBI    ANDEQ3
     C                     ADD  1         X
     C                     Z-ADDF8YMD     DT8,X
     C           X         IFEQ 12
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD*ZERO     Y
     C           2         DO   11        X
     C                     ADD  1         Y
     C                     Z-ADDDT8,X     DT4,Y
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   ORDER NUMBER
      *------------------------------------------------------
     C           #ORD      BEGSR
      *
     C                     Z-ADD*ZERO     DT8
     C           D@ORNO    CHAINGDGPL16              90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDICODRY    K@YY
     C                     Z-ADDICODRM    K@MM
     C                     Z-ADDICODRD    K@DD
     C                     ELSE
     C           D@ORNO    CHAINGDIPL16              90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDIIODHZ    K@YMD
     C                     ELSE
     C                     MOVE *ON       *IN99
     C                     MOVE *ON       *IN63
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C                     Z-ADD*ZERO     X       30
     C                     Z-ADDK@YMD     @@YMD   80
     C           K#GC      SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READ AGDPL12                  90
     C           *IN90     IFEQ *OFF
     C                     ADD  1         X
TCH61C*          X         IFEQ 7
TCH61C           X         IFEQ 2
     C                     Z-ADDF8YMD     DT8,1
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD1         X       30
     C                     Z-ADD@@YMD     K@YMD
     C           K#GC      SETGTAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C******     F8YOBI    ANDEQ3
     C                     ADD  1         X
     C                     Z-ADDF8YMD     DT8,X
     C           X         IFEQ 12
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD*ZERO     Y
     C           2         DO   11        X
     C                     ADD  1         Y
     C                     Z-ADDDT8,X     DT4,Y
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   PRODUCT
      *------------------------------------------------------
     C           #PRD      BEGSR
      *
     C                     Z-ADD*ZERO     MDL
     C                     Z-ADD*ZERO     BOX
B0   C           1         DO   10        X
B1   C           DT8,X     IFEQ *ZERO
     C                     LEAVE
E1   C                     ENDIF
      *
     C           X         ADD  1         Y       30
     C                     Z-ADDDT8,Y     K@YMD
     C                     Z-ADD*ZERO     @@BOX   70
      *
     C           K#GC      SETLLGDGPL17
B1   C           *IN90     DOUEQ*ON
     C                     READ GDGPL17                  90
B2   C           *IN90     IFEQ *OFF
     C           ICSKJY    ANDEQ*BLANK
     C           ICSEIH    ANDEQ'0'
B3   C           ICODHZ    IFGE DT8,X
     C                     LEAVE
E3   C                     ENDIF
      *
     C                     ADD  ICMAIS    @@BOX
B3   C           ORD,X     IFEQ *ZERO
     C***        ORD,X     IFLT ICODER
     C                     Z-ADDICODER    ORD,X
E3   C                     ENDIF
E2   C                     ENDIF
E1   C                     ENDDO
      *
     C                     Z-ADD@@BOX     BOX,X
     C           @@BOX     DIV  84        MDL,X
     C                     MVR            @@MVR   50
B1   C           @@MVR     IFNE *ZERO
     C                     ADD  1         MDL,X
E1   C                     ENDIF
      *
E0   C                     ENDDO
      *
     C                     ADD  MDL       TOT
     C                     ADD  1         RRN1
     C                     MOVEL'PRODUCT 'S@TTL
     C                     WRITESFL01
      *
     C                     ENDSR
      *------------------------------------------------------
      *   WASHER
      *------------ -----------------------------------------
     C           #WAS      BEGSR
      *
     C                     Z-ADD*ZERO     MDL
     C                     Z-ADD*ZERO     BOX
     C           1         DO   10        X
     C           DT8,X     IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
      *
     C           X         ADD  1         Y       30
     C                     Z-ADDDT8,Y     K@YMD
     C                     Z-ADD*ZERO     @@BOX   70
      *
     C           K#GC      SETLLGDGPL17
     C           *IN90     DOUEQ*ON
     C                     READ GDGPL17                  90
     C           *IN90     IFEQ *OFF
     C           ICSKJY    ANDEQ*BLANK
     C           ICSEIH    ANDEQ'3'
      *
     C           ICODHZ    IFGE DT8,X
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  ICMAIS    @@BOX
     C           ORD,X     IFEQ *ZERO
     C********   ORD,X     IFLT ICODER
     C                     Z-ADDICODER    ORD,X
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD@@BOX     BOX,X
     C           @@BOX     DIV  5         MDL,X
     C                     MVR            @@MVR   50
     C           @@MVR     IFNE *ZERO
     C                     ADD  1         MDL,X
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ADD  MDL       TOT
     C                     ADD  1         RRN1
     C                     MOVEL'WASHER  'S@TTL
     C                     WRITESFL01
      *
     C                     ENDSR
      *------------------------------------------------------
      *   WIRE
      *------------------------------------------------------
     C           #MAT      BEGSR
      *
     C                     Z-ADD*ZERO     MDL
     C                     Z-ADD*ZERO     BOX
     C                     Z-ADD*ZERO     X
     C           2         DO   11        Z       30
     C           DT8,Z     IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  1         X
     C           Z         ADD  1         Y       30
     C                     Z-ADDDT8,Y     K@YMD
     C           *LOVAL    SETLLGDLPL14
     C           *IN95     DOUEQ*ON
     C                     READ GDLPL14                  95
     C           *IN95     IFEQ *OFF
     C           LBSKJY    ANDEQ*BLANK
      *
TCHK2C*TCHK1     LBSIRE    IFNE 0002
TCHK2C           LBSIRE    IFEQ 0002
TCHK2C           LBSIRE    OREQ 8990
TCHK2C                     ELSE
TCHK1C                     ITER
TCHK1C                     END
TCHK1 *
     C                     MOVE LBZAIS    K@ZAIS
     C                     Z-ADDLBZAIK    K@ZAIK
     C           K#GL      SETGTGDLPL14
     C           *IN90     DOUEQ*ON
     C           K#GLX     READEGDLPL14                  90
     C           *IN90     IFEQ *OFF
     C           LBSKJY    ANDEQ*BLANK
      *
TCHK2C*TCHK1     LBSIRE    IFNE 0002
TCHK2C           LBSIRE    IFEQ 0002
TCHK2C           LBSIRE    OREQ 8990
TCHK2C                     ELSE
TCHK1C                     ITER
TCHK1C                     END
TCHK1 *
     C           LBYMD     IFGT DT8,Z
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  LBMAIS    MDL,X
     C                     ENDIF
     C                     ENDDO
      *
     C           K#GLX     SETGTGDLPL14
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDDO
      *
     C                     ADD  MDL       TOT
     C                     ADD  1         RRN1
     C                     MOVEL'WIRE    'S@TTL
     C                     WRITESFL01
      *
     C                     ENDSR
      *------------------------------------------------------
      *   DIE
      *------------------------------------------------------
     C           #DIE      BEGSR
      *
     C                     Z-ADD*ZERO     MDL
     C                     Z-ADD*ZERO     BOX
     C           1         DO   10        X
     C           DT8,X     IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
      *
     C           X         ADD  1         Y
     C                     Z-ADDDT8,Y     K@YMD
      *
     C           K#GC      SETLLGDIPL17
     C           *IN90     DOUEQ*ON
     C                     READ GDIPL17                  90
     C           *IN90     IFEQ *OFF
     C           IISKJY    ANDEQ*BLANK
      *
     C           IIODHZ    IFGE DT8,X
     C                     LEAVE
     C                     ENDIF
      *
     C                     Z-ADD1         MDL,X
     C           ORD,X     IFEQ *ZERO
     C*****      ORD,X     IFLT IIODER
     C                     Z-ADDIIODER    ORD,X
     C                     ENDIF
      *
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDDO
      *
     C                     ADD  MDL       TOT
     C                     ADD  1         RRN1
     C                     MOVEL'DIE     'S@TTL
     C                     WRITESFL01
      *
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     WRITEDSP98
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
      *
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
