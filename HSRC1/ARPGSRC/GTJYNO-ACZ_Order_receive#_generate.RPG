     H            Y.                                    1
     F** GTJYNO ********************************************
     F*  ORDER RECEIVE# GENERATE                           *
     F*  (ORIGINAL IS JYURNO(ASJ))                         *
     F*                                                    *
     F* TCHK1 08/23/12 CREATE                              *
     F******************************************************
     FGTAPPNO UF  E           K        DISK                      A
     E                    RNO    40  40  1
     E                    @CC         5  1
     E                    WCC         5  1
      ******************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60WSSTM6
     I                                        1   40WSSTM4
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  140WSSDAT
     I                                        7  100WSSYYY
     I                                        7   80WSSYY1
     I                                        9  100WSSYY2
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I*
      * YY + GENERATE#
     I            DS
     I                                        1   7 WJNO
     I                                        1   2 WYY
     I                                        3   7 JYRENO
      *
     C           *ENTRY    PLIST
     C                     PARM           P@JNO   7
      *
     C                     TIME           WSDT
     C                     MOVELWSSYY2    WYY
      *
     C                     SETOF                     70
     C           ' '       CHAINJYUPPNO1             70
     C           *IN70     IFEQ '1'
     C                     MOVE ' '       JYSYSK           受注区分
     C                     MOVE WYY       JYYEAR
     C                     MOVE '00001'   JYRENO
     C                     EXSR #SUB2
     C                     WRITEJYUPPNO1
     C                     MOVE WJNO      P@JNO
     C                     ELSE
     C           JYYEAR    IFNE WYY
     C                     MOVE WYY       JYYEAR
     C                     MOVE '00001'   JYRENO
     C                     EXSR #SUB2
     C                     UPDATJYUPPNO1
     C                     MOVE WJNO      P@JNO
     C                     ELSE
     C                     EXSR #SUB1
     C                     MOVEAWCC       JYRENO
     C           JYRENO    IFEQ '00000'
     C                     MOVE '00001'   JYRENO
     C                     END
     C                     EXSR #SUB2
     C                     UPDATJYUPPNO1
     C                     MOVE WJNO      P@JNO
     C                     END
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------*
      * MODULUS 36                                          *
      *-----------------------------------------------------*
     C           #SUB1     BEGSR
     C*
     C                     MOVEA*BLANK    @CC
     C                     MOVEA*BLANK    WCC
     C                     MOVEAJYRENO    @CC
     C                     MOVEAJYRENO    WCC
     C                     Z-ADD5         @B      20
     C*
     C                     DO   5
     C                     Z-ADD1         @A      20
     C                     SETOF                     71
     C           @CC,@B    LOKUPRNO,@A                   71
     C           *IN71     IFEQ '1'
     C           RNO,@A    IFEQ 'Z'
     C                     Z-ADD1         @A
     C                     MOVE RNO,@A    WCC,@B
     C                     SUB  1         @B
     C                     GOTO @EDO1
     C                     ELSE
     C                     ADD  1         @A
     C                     MOVE RNO,@A    WCC,@B
     C                     GOTO ESUB1
     C                     END
     C                     END
     C           @EDO1     TAG
     C                     ENDDO
     C*
     C           ESUB1     ENDSR
     C*-----------------------------------------------------*
     C*                                                     *
     C*-----------------------------------------------------*
     C           #SUB2     BEGSR
     C*
     C                     Z-ADDWSSDAT    JYDATE
     C                     Z-ADDWSSTM6    JYTIME
     C                     MOVEL#USER     JYUSER
     C                     MOVEL#WSID     JYWSID
     C                     MOVEL#PGM      JYPGID
     C*
     C                     ENDSR
**
0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ34TM
