     C*
     C           1         SETLLAB#WP455
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AB#WP455                 90
     C           *IN90     IFEQ *ON
     C           W@1ST     IFEQ *ON
     C                     MOVELW@SAVE    O@DAT
     C                     EXCPTDT
     C                     END
     C                     LEAVE
     C                     END
     C*
     C           INONY     IFNE 7448
     C                     MOVELI@DAT     O@DAT 256
     C                     EXCPTDT
     C                     ITER
     C                     END
     C*
     C           W@1ST     IFEQ *OFF
     C                     MOVELI@DAT     W@SAVE
     C                     MOVEL*ON       W@1ST
     C                     ITER
     C                     END
      *
     C           WNONY     IFNE INONY
     C           WNKOJ     ORNE INKOJ
     C           WNUKE     ORNE INUKE
