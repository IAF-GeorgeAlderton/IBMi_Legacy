     H            Y.
     F** AB#R60 ************************
     F*  ..DAILY SALES DETAIL  LIST..  *
     F*    I-HASADA        97.08.05    *
     F************************ AB#R60 **
     FAB#PW60 CF  E                    WORKSTN
     FAB#PL06 UF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FAB#WP60 O   F     100            DISK
     E                    ER      1   4 60
     I            DS
     I                                        1   80INOHZ1
     I                                        1   40INOY1
     I                                        5   60INOM1
     I                                        7   80INOD1
     I            DS
     I                                        1   80INOHZ2
     I                                        1   40INOY2
     I                                        5   60INOM2
     I                                        7   80INOD2
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
      *
     C           KEY1      KLIST
     C                     KFLD           INOY1
     C                     KFLD           INOM1
     C                     KFLD           INOD1
      *
     C           *ENTRY    PLIST
     C                     PARM           PNONY   4
      *
     C                     Z-ADD0         INOHZ1
     C                     Z-ADD0         INOHZ2
      *
     C           STP1      TAG
     C                     EXFMTAB#PW601
     C                     SETOF                     010203
     C                     SETOF                     99
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           *INKL     IFEQ '1'
     C                     CALL 'GGBR19'
     C                     GOTO STP1
     C                     END
      *
     C           INONY     IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
     C                     MOVE INONY     WNONY   40
      *
     C                     SETOF                     10
    .C           INONY     IFNE '9999'
     C           WNONY     CHAINFGBPL011             10
     C           *IN10     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
    .C                     ENDIF
     C           *IN10     IFEQ '1'
     C                     SETON                     0199
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
      *
     C           INOHZ1    IFEQ 0
     C                     SETON                     0299
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     END
      *
     C           INOY1     IFGE 1997
     C           INOM1     ANDGE01
     C           INOM1     ANDLE12
     C           INOD1     ANDGE01
     C           INOD1     ANDLE31
     C                     ELSE
     C                     SETON                     0299
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     END
      *
     C           INOHZ2    IFEQ 0
     C                     SETON                     0399
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     END
      *
     C           INOY2     IFGE 1997
     C           INOM2     ANDGE01
     C           INOM2     ANDLE12
     C           INOD2     ANDGE01
     C           INOD2     ANDLE31
     C                     ELSE
     C                     SETON                     0399
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     END
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP1
     C                     END
      *
     C                     SETON                     U1
     C                     MOVE INONY     PNONY
      *
     C           KEY1      SETLLAB#PL061
B1   C                     DO   *HIVAL
     C                     SETOF                     30
     C                     READ AB#PL061                 30
 B2  C           *IN30     IFEQ '0'
  B3 C           B1SKJY    IFEQ 'D'
     C           B1SKHZ    ANDLE*DATE
  X3 C                     ELSE
      *
  B4 C           B1NONY    IFEQ WNONY
   4 C           WNONY     OREQ 9999                       ALL USERS
      *
  B5 C           B1NOHZ    IFGT INOHZ2
     C                     SETON                     30
  X5 C                     ELSE
      *
  B6 C           B1NOHZ    IFGE INOHZ1
     C           B1NOHZ    ANDLEINOHZ2
     C                     SETON                     U2
      *
     C                     MOVE B1TOKU    @TOKU   4
     C                     MOVE B1NONY    @NONY   4
     C                     MOVE B1NKOJ    @NKOJ   1
     C                     MOVE B1NUKE    @NUKE   4
     C                     MOVE B1MHIN    @MHIN  20
     C                     MOVE B1NOHZ    @HIZK   8
     C                     Z-ADD0         @TANK  105
     C                     MOVE *BLANK    @CHEK   1
      *
     C                     CALL 'FBCR10'
     C                     PARM           @TOKU
     C                     PARM           @NONY
     C                     PARM           @NKOJ
     C                     PARM           @NUKE
     C                     PARM           @MHIN
     C                     PARM           @HIZK
     C                     PARM           @TANK
     C                     PARM           @CHEK
      *
  B7 C           @TANK     IFEQ 0
     C                     SETON                     U3
  E7 C                     END
      *
     C                     Z-ADD@TANK     B1TANK
     C                     UPDATAB#PL061
      *
     C           B1SRYO    DIV  B1SYUY    WHAKO   30
      *
     C                     EXCPTDT
      *
  E6 C                     END
  E5 C                     END
  E4 C                     END
  E3 C                     END
 E2  C                     END
E1   C  N30                END
      *
     C                     SETON                     LR
     C                     RETRN
      *
     OAB#WP60 E                DT
     O                         B1TOKU     4
     O                         B1NONY     8
     O                         B1NKOJ     9
     O                         B1NUKE    13
     O                         B1SBAN    17
     O                         B1UHIN    37
     O                         B1ODR1    47
     O                         B1NOHZ    55
     O                         WHAKO     58
     O                         B1SYUY    63
     O                         B1SRYO    70
     O                         B1TANK    80
      *
** ER
E-01 INPUT DELIVERY
E-02 NO DATA IN SHIPMENT M/F
E-03 INPUT DELIVERY DATE
E-04 DELIVERY DATE (YYMMDD) IS NOT RIGHT
