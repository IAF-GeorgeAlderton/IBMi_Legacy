     H            Y.
     FAB#PP01 IF  E                    DISK
     FAPPWP81 O   E                    DISK
     F            AB#PP011                          KRENAMEAB#PP991
     FAPPPP81 O   E                    DISK
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        7  140WTIHZ
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
     C                     TIME           WTIME
     C                     Z-ADDWJFB      S@TIME
     C                     Z-ADDWTIHZ     S@DATE
      *
     C                     CALL 'APLC99'
     C                     PARM           W@SYS
      *
     C           *ENTRY    PLIST
     C                     PARM           P@NO    2
     C                     MOVE P@NO      K@NO    2
      *
     C                     Z-ADD2000000   @LOP    70
     C* * *                Z-ADD20        @LOP    70
     C           1         DO   @LOP
     C                     READ AB#PP011                 88
     C   88                LEAVE
     C                     ADD  1         @CNT   100
     C                     WRITEAB#PP991
     C                     ENDDO
      *
     C* * *      K@NO      CHAINAPPPP811             77
     C* * *      *IN77     IFEQ '0'
     C* * *                ADD  1         W@CNT
     C* * *                ADD  @CNT      W@KEN
     C* * *                UPDATAPPPP811
     C* * *                ELSE
     C                     MOVE P@NO      W@NO
     C                     MOVELW$WSID    W@JOB
     C                     MOVELW$USER    W@USER
     C                     MOVELW$JBNO    W@NBR
     C                     Z-ADD1         W@CNT
     C                     Z-ADD@CNT      W@KEN
     C                     TIME           WTIME
     C                     Z-ADDWJFB      W@TIME
     C                     Z-ADDWTIHZ     W@DATE
      *
     C                     MOVE *BLANK    W@BLK1
     C                     MOVE ':'       W@SEM1
     C                     MOVE ':'       W@SEM2
      *
     C                     Z-ADDS@DATE    PQDAT1  80
     C                     Z-ADDW@DATE    PQDAT2  80
     C                     Z-ADDS@TIME    PQTIM1  60
     C                     Z-ADDW@TIME    PQTIM2  60
     C                     Z-ADD0         PQDIFF 100
     C                     CALL 'YX011G'
     C                     PARM           PQDAT1  80
     C                     PARM           PQDAT2  80
     C                     PARM           PQTIM1  60
     C                     PARM           PQTIM2  60
     C                     PARM           PQDIFF 100
      *
     C                     Z-ADD0         W@HOUR
     C                     Z-ADD0         W@MIN
     C                     Z-ADD0         W@SEC
     C                     CALL 'TIMR03'
     C                     PARM           PQDIFF 100
     C                     PARM           W@HOUR  40
     C                     PARM           W@MIN   20
     C                     PARM           W@SEC   20
      *
     C                     WRITEAPPPP811
     C* * *                END
      *
     C                     SETON                     LR
     C                     RETRN
      *
