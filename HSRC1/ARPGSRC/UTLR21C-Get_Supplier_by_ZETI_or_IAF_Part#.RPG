     H            Y.
     F** UTLR21C *********************************************
     F*  PROGRAM: UTILITY- GET SUPPLIER BY ZETI OR IAF PART# *
     F*  WRITTEN: JW (SRA) 2020.09.24                        *
     F*------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR21C'
     F*                    PARM           $ZETI   4
     F*                    PARM           $SHIN  12
     F*                    PARM           $SUPP   4
     F*                    PARM           $RTN    1
     F*  IN  $ZETI :  4A  ZETI#
     F*      $SHIN : 12A  IAF PART
     F*  OUT $SUPP :  4A  SUPPLIER CODE
     F*      $RTN  :  1A  RETURN CODE (BLANK/*)
     F******************************************************
     FFCETL11 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     F******************************************************
      *
     I            DS
     I                                        1  12 #SHIN
     I                                        1   5 #SHN1
     I                                        6  10 #SHN2
     I                                       11  12 #SHN3
      * SYSTEM TIME
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
     C                     EXSR #INIT
      *
     C                     SELEC
     C           $ZETI     WHNE *BLANK
     C                     EXSR #ZETI
      *
     C           $SHIN     WHNE *BLANK
     C                     EXSR #PART
      *
     C                     ENDSL
      *
     C           $SUPP     IFEQ *BLANK
     C           $SUPP     OREQ '0000'
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *=============================================================
      * GET SUPPLIER BY ZETI
      *=============================================================
     C           #ZETI     BEGSR
      *
     C           $ZETI     CHAINFCETL11              99
     C           *IN99     IFEQ *OFF
     C                     MOVELA2SIRE    $SUPP
     C                     ENDIF
      *
     C                     ENDSR
      *=============================================================
      * GET SUPPLIER BY IAF APRT#
      *=============================================================
     C           #PART     BEGSR
      *
     C           K#SHIN    CHAINFCEPL01              99
     C           *IN99     IFEQ *OFF
     C                     MOVELA2SIRE    $SUPP
     C                     ENDIF
      *
     C                     ENDSR
      *=============================================================
      * INITIAL PROCESS
      *=============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $ZETI   4
     C                     PARM           $SHIN  12
     C                     PARM           $SUPP   4
     C                     PARM           $RTN    1
      *
     C           K#SHIN    KLIST
     C                     KFLD           #SHN1
     C                     KFLD           #SHN2
     C                     KFLD           #SHN3
      *
     C                     MOVEL$SHIN     #SHIN
     C                     MOVE '0000'    $SUPP
     C                     MOVE *BLANK    $RTN
     C                     TIME           SDATE
      *
     C                     ENDSR
