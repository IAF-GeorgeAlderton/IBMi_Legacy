     H            Y.                                    1
      ***ALDR772****************************************************************
      *  SHIPPING VERIFICATION SCAN STATUS LIST                                *
      *                                                                *********
      * TCHK1 03/15/10 CREATE
      **************************************************************************
     FALDPP76 IF  E           K        DISK
     FALBPL30 IF  E           K        DISK
     FGADPL11 IF  E           K        DISK
     FAB#PL76 IF  E           K        DISK
     FALDWP772UF  E           K        DISK                      A
     FALDWL772IF  E           K        DISK
     F            ALDWP77R                          KRENAMEALW@77R
     FALDPL761IF  E           K        DISK
     F            ALDPP761                          KRENAMEALD@76R
     FQPRINT  O   F     132     OF     PRINTER
      *------------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
     I*
     I            DS
     I                                        1   80W7NODT
     I                                        1   40W7NOYY
     I                                        5   60W7NOMM
     I                                        7   80W7NODD
     I            DS
     I                                        1  20 W@MHIN
     I                                        1   5 A7MHN1
     I                                        6  10 A7MHN2
     I                                       11  15 A7MHN3
     I                                       16  20 A7MHN4
     I            DS
     I                                        1  14 W@SHIN
     I                                        1   5 A7SHN1
     I                                        6   6 W@SHNA
     I                                        7  11 A7SHN2
     I                                       12  12 W@SHNB
     I                                       13  14 A7SHN3
     I            DS
     I                                        1   7 W@KNB@
     I                                        1   3 A7LTNO
     I                                        4   4 W@KNBA
     I                                        5   7 A7ISNO
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C                     EXSR #SELC
     C                     EXSR #LIST
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *
      *--------------------------------------------------------
      * INITIALIZE
      *--------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           PMSTDT  8
     C                     PARM           PMEDDT  8
     C                     PARM           PMLST2  1
     C                     PARM           PMLST3  1
     C                     PARM           PMLST4  1
     C                     MOVELPMSTDT    W@STDT  80
     C                     MOVELPMEDDT    W@EDDT  80
      *
     C           K#GAD     KLIST
     C                     KFLD           W7TOKU
     C                     KFLD           W7NONY
      *
     C                     TIME           WSDT
      *
     C                     ENDSR
      **************************************************************************
     C           #SELC     BEGSR
      **************************************************************************
     C           W@STDT    SETLLALDPP76
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ALDPP76                  80
     C   80                LEAVE
     C           A7KODT    IFGT W@EDDT
     C                     LEAVE
     C                     END
     C*
     C           A7INSR    IFEQ *BLANK
     C           A7SERL    ANDEQ*BLANK
     C                     ELSE
     C                     ITER
     C                     END
     C*
     C           PMLST2    IFEQ *BLANK
     C           A7STS     ANDEQ'OK'
     C                     ITER
     C                     END
     C           PMLST3    IFEQ *BLANK
     C           A7STS     ANDEQ'IM'
     C                     ITER
     C                     END
     C           PMLST4    IFEQ *BLANK
     C           A7STS     ANDEQ'DL'
     C                     ITER
     C                     END
     C*
     C           A7PKL#    CHAINALDWP772             81
     C           *IN81     IFEQ *OFF
     C           A7SEQ#    IFGT W7SEQ#
     C                     MOVELA7SKJY    W7SKJY
     C                     Z-ADDA7SKDT    W7SKDT
     C                     Z-ADDA7SKTM    W7SKTM
     C                     Z-ADDA7KODT    W7KODT
     C                     Z-ADDA7KOTM    W7KOTM
     C                     MOVELA7TMCD    W7TMCD
     C                     MOVELA7STS     W7STS
     C           A7STS     IFEQ 'OK'
     C                     MOVEL'1'       W7STSC
     C                     END
     C           A7STS     IFEQ 'IM'
     C                     MOVEL'2'       W7STSC
     C                     END
     C           A7STS     IFEQ 'DL'
     C                     MOVEL'3'       W7STSC
     C                     END
     C                     MOVELA7MSG1    W7MSG1
     C                     MOVELA7MSG2    W7MSG2
     C                     MOVELA7MSG3    W7MSG3
     C                     UPDATALDWP77R
     C                     END
     C                     ITER
     C                     END
     C*
     C           A7PKL#    CHAINAB#PL76              82
     C*
     C                     CLEARALDWP77R
     C                     MOVELA7SKJY    W7SKJY
     C                     Z-ADDA7SKDT    W7SKDT
     C                     Z-ADDA7SKTM    W7SKTM
     C                     Z-ADDA7KODT    W7KODT
     C                     Z-ADDA7KOTM    W7KOTM
     C                     MOVELA7TMCD    W7TMCD
     C                     MOVELA7PKL#    W7PKL#
     C                     Z-ADDA7SEQ#    W7SEQ#
     C                     MOVELA7STS     W7STS
     C           A7STS     IFEQ 'OK'
     C                     MOVEL'1'       W7STSC
     C                     END
     C           A7STS     IFEQ 'IM'
     C                     MOVEL'2'       W7STSC
     C                     END
     C           A7STS     IFEQ 'DL'
     C                     MOVEL'3'       W7STSC
     C                     END
     C           *IN82     IFEQ *OFF
     C                     Z-ADDPUCUST    W7TOKU
     C                     Z-ADDPUNONY    W7NONY
     C                     MOVELPUNKOJ    W7NKOJ
     C                     MOVELPUNUKE    W7NUKE
     C                     MOVELPUBINN    W7BINN
     C                     Z-ADDPUNOYY    W7NOYY
     C                     Z-ADDPUNOMM    W7NOMM
     C                     Z-ADDPUNODD    W7NODD
     C                     MOVELPUODRN    W7ODRN
     C                     END
     C                     MOVELA7MSG1    W7MSG1
     C                     MOVELA7MSG2    W7MSG2
     C                     MOVELA7MSG3    W7MSG3
     C*
     C                     WRITEALDWP77R
     C*
     C                     ENDDO
     C*
     C                     ENDSR
      **************************************************************************
     C           #LIST     BEGSR
      **************************************************************************
     C                     MOVE *OFF      *IN98
     C                     MOVEL*BLANK    W@STSC  1
     C           *LOVAL    SETLLALDWL772
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ALDWL772                 80
     C   80                LEAVE
     C*
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C           W7STSC    ORNE W@STSC
     C           W7STSC    IFEQ '1'
     C           W7STSC    OREQ '2'
     C                     MOVELW7MSG3    @CMNT  20
     C                     ELSE
     C                     MOVELW7MSG2    @CMNT
     C                     END
     C                     EXCPT@HED
     C                     MOVEL*ON       *IN98
     C                     MOVEL*OFF      *INOF
     C                     MOVELW7STSC    W@STSC
     C                     ENDIF
     C*
     C                     MOVEL*BLANK    W5KMEI 15
     C           K#GAD     CHAINGADPL11              97
     C   97                MOVEL*BLANK    W5KMEI
     C  N97                MOVELB5KMEI    W5KMEI
     C*
     C                     MOVELW7TMCD    K@OPER  60
     C           K@OPER    CHAINALBPL30              90
     C           *IN90     IFEQ *OFF
     C                     MOVELALWKNM    @TMNM  18
     C                     ELSE
     C                     MOVEL*BLANK    @TMNM
     C                     END
     C*
     C                     EXCPT@DTL
     C*
     C           W7STSC    IFEQ '2'
     C                     EXSR #LISTS
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
      **************************************************************************
     C           #LISTS    BEGSR
      **************************************************************************
     C           K#761     KLIST
     C                     KFLD           W7PKL#
     C                     KFLD           W7SEQ#
     C           K#761     SETLLALDPL761
     C*
     C                     DO   *HIVAL
     C*
     C           K#761     READEALDPL761                 83
     C   83                LEAVE
     C           A7STS     IFNE *BLANK
     C                     ITER
     C                     END
     C*
     C           *INOF     IFEQ *ON
     C                     EXCPT@HED
     C                     MOVEL*OFF      *INOF
     C                     ENDIF
     C*
     C           A7SHN2    IFNE *BLANK
     C                     MOVEL'-'       W@SHNA
     C                     ELSE
     C                     MOVEL*BLANK    W@SHNA
     C                     END
     C           A7SHN3    IFNE *BLANK
     C                     MOVEL'-'       W@SHNB
     C                     ELSE
     C                     MOVEL*BLANK    W@SHNB
     C                     END
     C                     MOVELA7SERL    W@SERL 18
     C           A7ISNO    IFNE *BLANK
     C                     MOVEL'-'       W@KNBA
     C                     ELSE
     C                     MOVEL*BLANK    W@KNBA
     C                     END
     C*
     C                     EXCPT@DTLS
     C*
     C                     ENDDO
     C*
     C                     ENDSR
      *-------------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                         WSSDATY   56
     O                         WSSTM6    65 '  :  :  '
     O                                   68 'P.'
     O                         PAGE  Z   72
     O        E   03           @HED
     O                                   28 'VERIFICATION'
     O                                   40 'SCAN STATUS'
     O                                   44 '*'
     O                         @CMNT     64
     O        E   05           @HED
     O                                   10 'PICKLIST#'
     O                                   15 'SHIP'
     O                                   20 'DOCK'
     O                                   25 'NAME'
     O                                   46 'SHIP DATE'
     O                                   50 'B#'
     O                                   60 'SCAN DATE'
     O                                   69 'TM NAME'
     O        E 1              @DTL
     O                         W7PKL#    10
     O                         W7NONY    15
     O                         W7NUKE    20
     O                      N97W5KMEI    36
     O                         W7NODT    47 '    .  .  '
     O                         W7BINN    50
     O                         W7KODT    61 '    .  .  '
     O                         @TMNM     80
     O        E 1              @DTLS
     O                                    7 'UP#:'
     O                         W@MHIN    26
     O                                   30 'IP#:'
     O                         W@SHIN    44
     O                                   51 'SERL#:'
     O                         W@SERL    69
     O                                   73 'K#:'
     O                         W@KNB@    80
