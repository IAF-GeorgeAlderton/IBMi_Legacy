     H            Y.
     F** VVVRY1 ******************************************************
     F*ソースレベルアンマッチ表示                                  *
     F*             T.SAKASHITA             2012.06.01               *
     F****************************************************** VVVR01 **
     FVVVPWY1 CF  E                    WORKSTN
      *
     I            DS
     I                                        1  13 P@SCHG
     I                                        2   7 P@SRCD
     I                                        8  13 P@SRCT
     I            DS
     I                                        1  13 P#SCHG
     I                                        2   7 P#SRCD
     I                                        8  13 P#SRCT
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P@LIBL 10
     C                     PARM           P@FILE 10
     C                     PARM           P@MBR  10
      *
     C                     MOVEL'HOBJ1 '  P#LIBL
     C           W#USER    IFEQ 'TEST'
     C                     MOVEL'TOBJ1 '  P#LIBL
     C                     END
     C                     CALL 'VVVCY3'
     C                     PARM           P#LIBL 10
     C                     PARM           P@MBR  10
     C                     PARM           P#SCHG 13
     C           P#SCHG    IFEQ *BLANK
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C                     CALL 'VVVCY1'
     C                     PARM           P@LIBL 10
     C                     PARM           P@FILE 10
     C                     PARM           P@MBR  10
     C                     PARM           P@SCHG 13
     C                     PARM           P@STYP 10
      *
     C           P@SCHG    IFEQ *BLANK
     C                     GOTO @JUMP
     C                     END
      *
     C           P@SCHG    IFNE P#SCHG
     C                     SETON                     88
     C                     EXFMTVVVPWY11
     C                     END
      *
     C           @JUMP     TAG
      *
     C                     SETON                     LR
     C                     RETRN
      *
