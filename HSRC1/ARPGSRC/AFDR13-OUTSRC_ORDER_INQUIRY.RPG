      **************************************************************************
     C           #SCRN3    BEGSR
     C*
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN53
     C                     EXFMTCTL02
     C                     MOVE *OFF      *IN53
      *
     C                     SELEC
     C           *INKC     WHEQ '1'
     C                     MOVEL'99'      @@ID    2
     C           *INKL     WHEQ '1'
     C                     MOVE '02'      @@ID
     C                     OTHER
     C                     EXSR #CHK2
     C                     ENDSL
     C*
     C                     ENDSR
