      *-----------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C           @@ID      CASEQ'02'      #SCRN2
     C           @@ID      CASEQ'03'      #SCRN3
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------
     C*
     C           *ENTRY    PLIST
     C                     PARM           SUPLY   4
     C                     PARM           SUPX    1
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
     C                     PARM           P@SDAT  8
      *
     C                     TIME           WSDT
      *
     C           K#AF10    KLIST
     C                     KFLD           SUPLY
     C                     KFLD           D@PAR1
     C                     KFLD           D@PAR2
     C                     KFLD           D@PAR3
     C                     KFLD           K@ODYY
     C                     KFLD           K@ODMM
     C                     KFLD           K@ODDD
     C*                    KFLD           S@BINN
      *
     C           K#15      KLIST
     C                     KFLD           ADKANR
     C                     KFLD           ADZETI
     C                     KFLD           ADTEHI
     C                     KFLD           ADPAGE
     C                     KFLD           ADNIJI
     C                     KFLD           ADTAIS
     C                     KFLD           ADSYUK
     C                     KFLD           ADHKOS
     C                     KFLD           ADCHKD
     C                     KFLD           ADBINN
     C                     KFLD           ADODNO
     C                     KFLD           ADSUPP
      *
     C           SUPLY     CAT  SUPX:0    SCODE   5 P
     C           SCODE     LOKUPTAB1      TAB2           90
     C           *IN90     IFEQ *ON
     C                     MOVELTAB2      D@SUPP
     C                     ENDIF
      *
     C                     MOVE SUPLY     @SUPP   40
     C                     MOVE '01'      @@ID    2
     C                     SETOF                     30
     C                     MOVE *ON       *IN43            SFLDROP
      *
     C                     ENDSR
      **************************************************************************
      *    1ST SCREEN
      **************************************************************************
     C           #SCRN1    BEGSR
      *
     C                     MOVE P@HIN1    D@PRT1
     C                     MOVE P@HIN2    D@PRT2
     C                     MOVE P@HIN3    D@PRT3
     C           P@SDAT    IFNE *BLANK
     C                     MOVE P@SDAT    D@FROM
     C                     Z-ADD999999999 D@TO
     C                     END
     C           P@HIN1    IFNE *BLANK
     C           P@SDAT    ANDNE*BLANK
     C                     SETON                     77
     C                     END
      *
     C                     MOVELCMD,1     D@CMD
      *
     C   77N88             GOTO @JUMP
      *-------------------------
      *-------------------------
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C           @JUMP     TAG
     C                     SETON                     88
      *
S1   C                     SELEC
-1   C           *INKC     WHEQ '1'
     C                     MOVEL'99'      @@ID    2
     C*
-1   C                     OTHER
     C                     EXSR #CHK1
     C*
 S2  C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
  S3 C                     SELEC
     C           RRN1      WHEQ *ZERO
     C                     MOVE ERR,1     D@MSG
     C           RRN1      WHEQ 9999
     C                     MOVE ERR,2     D@MSG
     C                     OTHER
     C                     MOVEL'02'      @@ID
  E3 C                     ENDSL
 E2  C                     ENDIF
E1   C                     ENDSL
     C*
     C                     ENDSR
      **************************************************************************
      *                    @CHK1
      **************************************************************************
     C           #CHK1     BEGSR
     C*
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,61
     C                     MOVE *BLANK    D@MSG
     C*  CHECK DATE
     C           D@TO      IFEQ *ZERO
     C                     Z-ADD99999999  D@TO
     C                     ENDIF
      *
     C           D@TO      IFLT D@FROM
     C                     MOVEA'11'      *IN,61
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     ENDSR
      **************************************************************************
      *    SET DATA FOR 2ND SCREEN
      **************************************************************************
     C           #SET1     BEGSR
      * SFLCLR
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C*
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @@RRN1  40
     C                     Z-ADDD@FROM    K@YMD
     C                     MOVE *OFF      *IN80
     C*
     C           K#AF20    KLIST
     C                     KFLD           SUPLY
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C                     KFLD           K@DD    20
     C           K#AF20    SETLLAFDPL27
      *
     C                     Z-ADD*ZERO     W@READ
     C                     Z-ADD*ZERO     WWREAD  31
     C*
     C                     EXSR #SET11
      *
     C                     ENDSR
      **************************************************************************
      *    SET DATA FOR 2ND SCREEN
      **************************************************************************
     C           #SET11    BEGSR
      *
      *
     C                     Z-ADD0         H@ORDT
     C                     MOVEL*BLANK    S@BINN
     C                     MOVEL*BLANK    S@PAR1
     C                     MOVEL*BLANK    S@PAR2
     C                     MOVEL*BLANK    S@PAR3
     C                     MOVEL*BLANK    S@ORNO
     C                     Z-ADD0         S@RCV
     C                     Z-ADD0         S@BOX
      *-------------------------
      *-------------------------
S1   C                     DO   *HIVAL
     C           SUPLY     READEAFDPL27             N    80
     C   80                LEAVE
 S2  C           AFODAT    IFGT D@TO
     C                     LEAVE
 E2  C                     ENDIF
     C*
 S2  C           AFSKJY    IFEQ 'D'
     C                     ITER
 E2  C                     ENDIF
     C*
 S2  C           SUPX      IFNE *BLANK
     C           AFAKI1    ANDNESUPX
     C                     ITER
 E2  C                     ENDIF
     C*
 S2  C           D@PRT1    IFNE *BLANK
     C           D@PRT2    ORNE *BLANK
     C           D@PRT3    ORNE *BLANK
     C           AFPAR1    IFEQ D@PRT1
     C           AFPAR2    ANDEQD@PRT2
     C           AFPAR3    ANDEQD@PRT3
     C                     ELSE
     C                     ITER
     C                     ENDIF
 E2  C                     ENDIF
     C*
     C                     MOVELAFODNO    W@ODNO  6
     C*
 S2  C           AFODAT    IFEQ H@ORDT
     C           AFBINN    ANDEQS@BINN
     C           AFPAR1    ANDEQS@PAR1
     C           AFPAR2    ANDEQS@PAR2
     C           AFPAR3    ANDEQS@PAR3
     C           W@ODNO    ANDEQS@ORNO
     C                     ADD  AFNOSU    S@RCV
     C                     ADD  AFHAKO    S@BOX
 X2  C                     ELSE
  S3 C           S@BOX     IFNE 0
     C                     ADD  1         RRN1
     C                     WRITESFL01
  E3 C                     ENDIF
     C                     CLEARSFL01
     C                     EXSR #SFSET
 E2  C                     ENDIF
      *
 S2  C           RRN1      IFEQ 9999
     C                     LEAVE
 E2  C                     ENDIF
E1   C                     ENDDO
      *-------------------------
      *-------------------------
S1   C           RRN1      IFLT 9999
     C           S@BOX     ANDNE0
     C                     ADD  1         RRN1
     C                     WRITESFL01
E1   C                     ENDIF
     C*
     C                     Z-ADD1         #RCNO1           SFLRCDNBR
     C*
     C                     ENDSR
      *---------------------------------------------------------------**********
      *---------------------------------------------------------------**********
     C           #SFSET    BEGSR
     C                     CLEARSFL01
     C                     Z-ADDAFODAT    S@ORDT
     C                     Z-ADDAFODAT    H@ORDT
     C                     MOVE AFBINN    S@BINN
     C                     MOVE AFPAR1    S@PAR1
     C                     MOVE AFPAR2    S@PAR2
     C                     MOVE AFPAR3    S@PAR3
     C                     Z-ADDAFNOSU    S@RCV
     C                     Z-ADDAFHAKO    S@BOX
     C                     MOVE AFODNO    S@ORNO
     C                     Z-ADDAFNDAT    S@RCVD
     C                     Z-ADDAFNDAT    H@RCVD
     C                     Z-ADDAFNDAT    H@RCV8
     C                     MOVELAFAKI2    S@RBIN
     C                     MOVELAFAKI2    H@RBIN
     C                     Z-ADD*ZERO     W@OUT   50
     C*
     C*
     C                     MOVEL*OFF      *IN41
     C*
     C                     Z-ADD*ZERO     WWREAD           ( L/T )
     C           K#AAML    KLIST
     C                     KFLD           AFPAR1
     C                     KFLD           AFPAR2
     C                     KFLD           AFPAR3
      * INTRA COMPANY KANBAN CHANGE M/F    LOGICAL    *.
     C           K#AAML    CHAINAAMPL11              81
     C  N81      CKSKJY    IFNE *BLANK
     C                     SETON                     81
     C                     ENDIF
     C*
S1   C           *IN81     IFEQ *OFF
     C                     Z-ADD*ZERO     I       20
     C*----------
 S2  C                     DO   *HIVAL
     C                     ADD  1         I
  S3 C           I         IFGT 15
     C                     LEAVE
  E3 C                     ENDIF
     C*
  S3 C           NKBM,I    IFEQ *ZERO
     C           NTKR,I    ANDEQ*BLANK
     C           NCKQ,I    ANDEQ*BLANK
     C                     LEAVE
  E3 C                     ENDIF
     C*
     C                     MOVELNKBM,I    W@NKBM  4
  S3 C           W@NKBM    IFNE SUPLY
     C                     ITER
  E3 C                     ENDIF
     C*
  S3 C           NTKR,I    IFEQ *BLANK
     C           NTKR,I    OREQ '------'
     C           NTKR,I    OREQ '++++++'
     C                     ITER
  E3 C                     ENDIF
     C*
  S3 C           NCKQ,I    IFEQ *BLANK
     C                     ITER
  E3 C                     ENDIF
     C*
     C           K#TKR     KLIST
     C                     KFLD           @@TK1
     C                     KFLD           @@TK2
     C                     KFLD           @@TK3
     C                     KFLD           @@TK4
     C                     MOVELNTKR,I    @@TKR
     C*****
  S3 C                     SELEC
  -3 C           NCKQ,I    WHEQ 'C'
     C           K#TKR     SETGTAAFPL03
  S4 C                     DO   *HIVAL
     C           K#TKR     REDPEAAFPL03                  83
     C   83                LEAVE
  S5 C           A3SKJY    IFNE *BLANK
     C                     ITER
  E5 C                     ENDIF
     C                     Z-ADDA3READ    WWREAD           ( L/T )
     C                     LEAVE
  E4 C                     ENDDO
     C* *
  -3 C           NCKQ,I    WHEQ 'A'
     C           K#TKR     SETGTABHPL03
  S4 C                     DO   *HIVAL
     C           K#TKR     REDPEABHPL03                  83
     C   83                LEAVE
  S5 C           M6SKJY    IFNE *BLANK
     C                     ITER
  E5 C                     ENDIF
     C                     Z-ADDM6LIT1    WWREAD           ( L/T )
     C                     ADD  M6LIT2    WWREAD           ( L/T )
     C                     ADD  M6LIT3    WWREAD           ( L/T )
     C                     ADD  M6LIT4    WWREAD           ( L/T )
     C                     LEAVE
  E4 C                     ENDDO
     C* *
  -3 C           NCKQ,I    WHEQ 'E'
     C           K#TKR     SETGTAAHPL03
  S4 C                     DO   *HIVAL
     C           K#TKR     REDPEAAHPL03                  83
     C   83                LEAVE
  S5 C           L6SKJY    IFNE *BLANK
     C                     ITER
  E5 C                     ENDIF
     C                     Z-ADDL6LTIM    WWREAD           ( L/T )
  E4 C                     ENDDO
      *
  E3 C                     ENDSL
 E2  C                     ENDDO
     C*----------
     C*----------
 S2  C           WWREAD    IFNE *ZERO                      ( L/T )
     C                     Z-ADDWWREAD    S@READ
     C                     Z-ADDWWREAD    W@READ
  S3 C           W@REA2    IFNE *ZERO                      小数点以下
     C                     ADD  1         W@REA1
     C                     Z-ADD*ZERO     W@REA2
  E3 C                     ENDIF
     C*
     C           K#AGD     KLIST
     C                     KFLD           AFODYY
     C                     KFLD           AFODMM
     C                     KFLD           AFODDD
     C                     Z-ADD*ZERO     W@CNT   30
     C           K#AGD     SETGTAGDPL12
     C*
  S3 C                     DO   *HIVAL
     C                     READ AGDPL12                  82
     C   82                LEAVE
  S4 C           F8HIRU    IFEQ *BLANK
     C                     ADD  1         W@CNT
  X4 C                     ELSE
  S5 C           F8YOBI    IFGE 6
     C                     ADD  1         W@CNT
  E5 C                     END
  E4 C                     END
  S4 C           W@CNT     IFGE W@READ
     C                     LEAVE
  E4 C                     END
  E3 C                     ENDDO
     C*
  S3 C           *IN82     IFEQ *OFF
     C           WWREAD    ANDNE*ZERO
  S4 C           AFNDAT    IFEQ *ZERO
  S5 C           F8TODT    IFLT WSSDAT
     C                     MOVEL'*'       S@LATE
  E5 C                     ENDIF
  X4 C                     ELSE
  S5 C           AFNDAT    IFGT F8TODT
     C                     MOVEL'*'       S@LATE
  E5 C                     ENDIF
  E4 C                     ENDIF
  E3 C                     ENDIF
 E2  C                     ENDIF
E1   C                     ENDIF
     C*
     C                     ENDSR
      **************************************************************************
      *   2ND SCREEN
      **************************************************************************
     C           #SCRN2    BEGSR
     C*
     C                     MOVELCMD,3     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCNO1           SFLRCDNBR
     C                     Z-ADD@@REC     TOPRRN  40       SFLRCDNBR
      *
S1   C                     SELEC
-1   C           *INKC     WHEQ '1'
     C                     MOVEL'99'      @@ID    2
     C*
-1   C           *INKL     WHEQ '1'
     C                     MOVEL'01'      @@ID    2
     C*
-1   C           *INKE     WHEQ *ON
     C                     EXSR #UPD
     C                     EXSR #SET1
     C                     Z-ADDTOPRRN    #RCNO1           SFLRCDNBR
     C*
-1   C                     OTHER
     C                     EXSR #CHK2
E2   C                     ENDSL
     C*
     C                     ENDSR
     C**************************************************************************
     C*  UPDATE
     C**************************************************************************
     C           #UPD      BEGSR
     C*
     C                     Z-ADD*ZERO     RRN1
      *-------------------------
S1   C                     DO   *HIVAL
     C*
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL01                90
     C   90                LEAVE
     C*
     C           S@RCVD    IFEQ H@RCVD
     C           S@RBIN    ANDEQH@RBIN
     C                     ITER
     C                     ENDIF
     C*
     C                     Z-ADDH@ORDT    W@ORDT
     C           K#PL20    KLIST
     C                     KFLD           SUPLY
     C                     KFLD           K@ODYY
     C                     KFLD           K@ODMM
     C                     KFLD           K@ODDD
     C                     KFLD           S@BINN
     C                     KFLD           S@PAR1
     C                     KFLD           S@PAR2
     C                     KFLD           S@PAR3
     C                     KFLD           K$ODNO
     C                     MOVELS@ORNO    K$ODNO  60
     C           K#PL20    SETLLAFDPL27
      *
 S2  C                     DO   *HIVAL
      *
     C           K#PL20    READEAFDPL27                  80
     C   80                LEAVE
     C           AFSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           SUPX      IFNE *BLANK
     C           AFAKI1    ANDNESUPX
     C                     ITER
     C                     ENDIF
      *
     C**         H@RCV8    IFEQ AFNDAT
     C**         H@RBIN    ANDEQAFAKI2
     C           20000000  ADD  S@RCVD    AFNDAT
     C                     MOVELS@RBIN    AFAKI2
     C                     Z-ADDAFHAKO    AFNOSU
     C           S@RCVD    IFEQ 0
     C           S@RBIN    ANDEQ*BLANK
     C                     Z-ADDS@RCVD    AFNDAT
     C                     Z-ADD0         AFNOSU
     C                     ENDIF
     C                     UPDATAFDPP201
     C                     EXSR #PP40
     C**                   ENDIF
      *
 E2  C                     ENDDO
      *
E1   C                     ENDDO
      *
     C                     ENDSR
