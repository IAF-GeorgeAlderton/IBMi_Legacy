      *
      **************************
     C           #PP40     BEGSR
      *
     C           K#AF14    KLIST
     C                     KFLD           SUPLY
     C                     KFLD           S@PAR1
     C                     KFLD           S@PAR2
     C                     KFLD           S@PAR3
     C                     KFLD           K@ODYY
     C                     KFLD           K@ODMM
     C                     KFLD           K@ODDD
     C                     KFLD           K$ODNO
     C           K#AF14    SETLLAFDPL14
      *-------------------------
S1   C                     DO   *HIVAL
     C           K#AF14    READEAFDPL14                  81
     C   81                LEAVE
 S2  C           ADSKJY    IFEQ 'D'
     C                     ITER
 E2  C                     ENDIF
     C*
 S2  C           SUPX      IFNE *BLANK
     C           ADFILR    ANDNESUPX
     C                     ITER
 E2  C                     ENDIF
     C*
     C                     MOVEL*BLANK    WKCLAS  1
     C                     MOVE ADTEHI    WKCLAS
     C*
     C           K#15      SETLLAFDPL40
     C           K#15      READEAFDPL40                  95
     C**
 S2  C           *IN95     IFEQ *OFF
     C           A4SKJY    ANDEQ*BLANK
     C*
  S3 C           WKCLAS    IFEQ 'A'
     C                     MOVE AFNDAT    A4SCDT  80
     C**                   MOVE A4SCTM    A4SCTM
     C                     ELSE
     C                     MOVELAFNDAT    A4SERL           SERIAL
  E3 C                     ENDIF
     C                     MOVEL#PGM      A4KOPG
     C                     TIME           A4KOTM
     C                     UPDATAFDPP401
 X2  C                     ELSE
     C                     CLEARAFDPP401
     C                     Z-ADD*DATE     A4KODT
     C                     TIME           A4KOTM
     C                     MOVEL#USER     A4KOME
     C                     MOVEL#PGM      A4KOPG
     C                     MOVELADKANR    A4KANR           CONTROL CODE
     C                     MOVELADZETI    A4ZETI           ABSOLUTE #
     C                     MOVELADTEHI    A4TEHI           TEHAI NO.
     C                     MOVELADPAGE    A4PAGE           PAGE NO.
     C                     MOVELADNIJI    A4NIJI           2ND TREATMENT TYPE
     C                     MOVELADTAIS    A4TAIS           TARGET TYPE
     C                     MOVELADSYUK    A4SYUK           SHIP EFFECTIVE TYPE
     C                     MOVELADHKOS    A4HKOS           CONTAINER TYPE
     C                     MOVELADCHKD    A4CHKD           CHECK DIGIT
     C                     MOVELADSUPP    A4SUPP           SUPPLIER
     C*                      A            A4FILR        20AFILLER
  S3 C           WKCLAS    IFEQ 'A'
     C                     MOVELAFNDAT    A4SCDT           SCAN DATE
     C*                      A            A4SCTM         6 SCAN TIME
     C                     ELSE
     C                     MOVELAFNDAT    A4SERL           SERIAL
     C                     ENDIF
     C                     Z-ADDADODYY    A4ODYY           ORDER DATE YYYY
     C                     Z-ADDADODMM    A4ODMM           MM
     C                     Z-ADDADODDD    A4ODDD           DD
     C                     Z-ADDADODNO    A4ODNO           ORDER NUMBER
     C                     MOVELADBINN    A4BINN           BIN#
     C                     WRITEAFDPP401
 E2  C                     ENDIF
     C**
E1   C                     ENDDO
      *-------------------------
     C                     ENDSR
      **************************************************************************
      *    CHECK 2ND SCREEN
      **************************************************************************
     C           #CHK2     BEGSR
     C*
     C                     MOVE '02'      @@ID
     C                     Z-ADD*ZERO     WRRN    40
      *-------------------------
S1   C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C   90                LEAVE
     C*
  S3 C           S@SLCT    IFNE *BLANK
     C                     MOVE *BLANK    S@SLCT
     C                     MOVEL*OFF      *IN41
     C                     UPDATSFL01
     C                     EXSR #SET2
     C                     MOVE '03'      @@ID
     C                     LEAVE
  E3 C                     ENDIF
     C*
     C                     MOVEL*OFF      *IN41
     C                     UPDATSFL01
E1   C                     ENDDO
      *
     C                     ENDSR
      **************************************************************************
      *    SET DATA FOR 3RD SCREEN
      **************************************************************************
     C           #SET2     BEGSR
      * SFLCLR
     C                     MOVE *ON       *IN54
     C                     WRITECTL02
     C                     MOVE *OFF      *IN54
     C                     Z-ADD*ZERO     RRN2    40
      *
     C                     MOVE S@BINN    D@BINN
     C                     MOVE S@PAR1    D@PAR1
     C                     MOVE S@PAR2    D@PAR2
     C                     MOVE S@PAR3    D@PAR3
     C                     Z-ADDS@RCV     D@OUT
     C                     Z-ADDS@BOX     D@BOX
     C                     Z-ADDS@ORDT    D@ORDT
     C                     MOVE S@ORNO    D@ORNO
     C                     Z-ADDH@ORDT    W@ORDT
      *
     C           K#AF10    SETLLAFDPL14
      *-------------------------
S1   C           *IN90     DOUEQ*ON
     C           K#AF10    READEAFDPL14                  90
 S2  C           *IN90     IFEQ *OFF
     C           ADSKJY    ANDEQ*BLANK
     C*
  S3 C           SUPX      IFNE *BLANK
     C           ADFILR    ANDNESUPX
     C                     ITER
  E3 C                     ENDIF
     C*
     C                     CLEARSFL02
     C                     MOVEL*BLANK    WKCLAS  1
     C                     ADD  1         RRN2
     C                     MOVE ADTEHI    S@TEHI
     C                     MOVE ADTEHI    WKCLAS
     C*
  S3 C           WKCLAS    IFEQ 'A'
     C                     MOVE ADTAIS    W@TICD
     C                     MOVE ADSYUK    W@YUKO
     C                     MOVE ADHKOS    W@HASY
     C                     MOVE W@LOT#    S@TEHI
  E3 C                     ENDIF
     C*
     C                     MOVE ADPAGE    S@PAGE
     C*
     C                     Z-ADD*ZERO     Z       30
  S3 C           ADLTNO    IFNE *BLANK
     C                     ADD  1         Z
     C                     MOVELADLTNO    LT,Z
  E3 C                     ENDIF
  S3 C           ADLTN2    IFNE *BLANK
     C                     ADD  1         Z
     C                     MOVELADLTN2    LT,Z
  E3 C                     ENDIF
  S3 C           ADLTN3    IFNE *BLANK
     C                     ADD  1         Z
     C                     MOVELADLTN3    LT,Z
  E3 C                     ENDIF
     C                     Z-ADDADSYOS    S@QTY
     C*
     C           K#AL3A    KLIST
     C                     KFLD           ADZETI
     C                     KFLD           ADTEHI
     C                     KFLD           ADPAGE
     C                     MOVEL' '       S@SHMK
     C           K#AL3A    SETLLALDPL30
     C*
  S3 C                     DO   *HIVAL
     C           K#AL3A    READEALDPL30                  94
     C   94                LEAVE
     C           A3SYDT    IFGT H@ORDT
     C                     MOVEL'X'       S@SHMK
     C                     LEAVE
     C                     END
  E3 C                     ENDDO
     C*
     C           K#ADA     KLIST
     C                     KFLD           K@KSKB  1
     C                     KFLD           ADZETI
     C                     KFLD           ADTEHI
      *
  S3 C           *IN94     IFEQ *ON
     C                     MOVEL'A'       K@KSKB
     C           K#ADA     SETLLADAPL01
  S4 C                     DO   *HIVAL
     C           K#ADA     READEADAPL01                  93
     C   93                LEAVE
  S5 C           A@DTKB    IFNE 'S'
     C                     ITER
  E5 C                     END
     C                     MOVELA@PGNO    W@PGNO  2
  S5 C           W@PGNO    IFNE ADPAGE
     C                     ITER
  E5 C                     END
  S5 C           A@KODT    IFGT H@ORDT
     C                     MOVEL'R'       S@SHMK
     C                     LEAVE
  E5 C                     END
  E4 C                     ENDDO
  E3 C                     END
     C*
     C*
     C                     EXSR GETNAM
     C                     MOVELALWKNM    S@TM
     C*
     C           K#15      SETLLAFDPL40
     C           K#15      READEAFDPL40                  95
  S3 C           *IN95     IFEQ *OFF
     C           A4SKJY    ANDEQ*BLANK
     C                     MOVELA4SERL    W@SR##
     C                     ADD  1         Z
     C                     MOVELW@SR#1    LT,Z      P
     C                     ADD  1         Z
     C                     MOVELW@SR#2    LT,Z      P
      *
  S4 C           WKCLAS    IFEQ 'A'
     C                     MOVE A4SCDT    W4SCDT  6
     C                     MOVEL'-'       W4SCTM  7
     C                     MOVE A4SCTM    W4SCTM
     C                     MOVELW4SCDT    LT,1      P
     C                     MOVELW4SCTM    LT,2      P
  E4 C                     ENDIF
      *
  E3 C                     END
      *
      *
     C           K#15      SETLLAFDPL15
  S3 C           *IN95     DOUEQ*ON
     C           K#15      READEAFDPL15                  95
  S4 C           *IN95     IFEQ *OFF
     C           A5SKJY    ANDEQ*BLANK
     C                     ADD  1         Z
     C                     MOVELA5LTNO    LT,Z
  E4 C                     ENDIF
  E3 C                     ENDDO
      *
     C                     WRITESFL02
 E2  C                     ENDIF
E1   C                     ENDDO
      *
      *
     C                     MOVEL*BLANK    D@SR#1
     C                     MOVEL*BLANK    D@SR#2
     C                     MOVEL'APICS'   D@KNNM
     C                     MOVEL*BLANK    D@SRNM
      *
     C           WKCLAS    IFEQ 'A'
     C                     MOVEL'INTRA'   D@KNNM
     C                     ENDIF
     C*
     C                     ENDSR
      **************************************************************************
