     H            Y.                                    1
      ***ALDR77*****************************************************************
      *  SHIPPING VERIFICATION ERROR LOG LIST CONTROL                          *
      *                                                                *********
      * TCHK1 03/08/10 CREATE(COPY FROM ALDR65)
      **************************************************************************
     FALDPW77 CF  E                    WORKSTN
     FAGDPL12 IF  E           K        DISK
      *------------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80F8KDAT
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I*
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *
      *--------------------------------------------------------
      * INITIALIZE
      *--------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
      *
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    K@YMD
      *
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     Z-ADDF8KDAT    D@FROM
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADDD@FROM    D@TO
      *
     C                     MOVEL'Y'       D@L1
     C                     MOVE '01'      W@ID    2
      *
     C                     ENDSR
      **************************************************************************
     C           #SCRN1    BEGSR
      **************************************************************************
     C                     EXFMTDSP01
     C*
     C                     SELEC
     C*
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #CALL
     C                     MOVE '99'      W@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      **************************************************************************
      *  CHECK--DATE
      **************************************************************************
     C           #CHK1     BEGSR
     C*
     C                     SETOF                     616263
     C                     SETOF                     99
     C           D@TO      IFEQ *ZERO
     C                     Z-ADDD@FROM    D@TO
     C                     ENDIF
     C*
     C                     Z-ADDD@FROM    K@YMD
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ENDIF
     C                     Z-ADDD@TO      K@YMD
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6299
     C                     ENDIF
     C*
     C           D@TO      IFLT D@FROM
     C                     SETON                     616299
     C                     ENDIF
     C*
     C           D@L1      IFEQ *BLANK
     C           D@L2      ANDEQ*BLANK
     C           D@L3      ANDEQ*BLANK
     C           D@L4      ANDEQ*BLANK
     C                     SETON                     6399
     C                     END
     C*
     C                     ENDSR
     C*--------------------------------------------------------
     C*  CALL PRINT PROGRAM
     C*--------------------------------------------------------
     C           #CALL     BEGSR
     C*
     C                     MOVELD@FROM    PMSTDT  8
     C                     MOVELD@TO      PMEDDT  8
     C                     MOVELD@L2      PMLST2  1
     C                     MOVELD@L3      PMLST3  1
     C                     MOVELD@L4      PMLST4  1
     C*
     C           D@L1      IFNE *BLANK
     C                     CALL 'ALDC771'
     C                     PARM           PMSTDT
     C                     PARM           PMEDDT
     C                     END
     C*
     C           D@L2      IFNE *BLANK
     C           D@L3      ORNE *BLANK
     C           D@L4      ORNE *BLANK
     C                     CALL 'ALDC772'
     C                     PARM           PMSTDT
     C                     PARM           PMEDDT
     C                     PARM           PMLST2
     C                     PARM           PMLST3
     C                     PARM           PMLST4
     C                     END
     C*
     C                     ENDSR
