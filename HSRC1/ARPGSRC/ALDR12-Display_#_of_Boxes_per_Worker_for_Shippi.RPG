     H            Y/
     FALDPW12 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     FALDWL04 IF  E           K        DISK
     FAM#PP31 IF  E           K        DISK
      *
     E                    CMD     1   2 78
     E*                   MSG     1   1 78
      *
     I            DS
     I                                        1   80BANOHZ
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
      *
     I            DS
     I                                        1   6 WKTI
     I                                        1   2 WKTIHH
     I                                        3   4 WKTIMM
     I                                        5   6 WKTISS
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *
     C           *ENTRY    PLIST
     C                     PARM           PYYYY   40
     C                     PARM           PMM     20
     C                     PARM           PDD     20
     C                     PARM           P1TIM1  40
     C                     PARM           P1YY2   40
     C                     PARM           P1MM2   20
     C                     PARM           P1DD2   20
     C                     PARM           P1TIM2  40
     C                     PARM           @@IDX   2
     C                     PARM           INQTYP  1
     C* ALDWL04
     C           KEY1      KLIST
     C                     KFLD           PYYYY            YY
     C                     KFLD           PMM              MM          G)
     C                     KFLD           PDD              DD          G)
      *--------------------------------------------------
     C           @@ID      DOUEQ'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C           @@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *--------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     MOVE '01'      @@ID    2
      *
     C                     ENDSR
      *--------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C*                    MOVE CMD,1     D@CMD
     C*                    WRITEDSP99
     C*                    EXFMTDSP01
      *
     C*                    SELEC
     C*          *INKA     WHEQ *ON
     C*                    MOVE '99'      @@ID
     C*                    OTHER
     C*                    EXSR #CHK1
     C*          *IN99     IFEQ *OFF
     C*                    EXSR #SET
     C*                    MOVE '02'      @@ID
     C*                    ENDIF
     C*                    ENDSL
      *
     C                     EXSR #SET
     C                     MOVE '02'      @@ID
     C                     ENDSR
      *--------------------------------------------------
     C*          #CHK1     BEGSR
      *
     C*                    SETOF                     9961
     C*                    MOVE *BLANK    D@MSG
     C*          D@DATE    CHAINAB#WPLG              90
     C*          *IN90     IFEQ *ON
     C*                    SETON                     9961
     C*                    MOVE MSG,1     D@MSG
     C*                    ENDIF
      *
     C*                    ENDSR
      *--------------------------------------------------
     C           #SET      BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     S@BOXS
     C                     Z-ADDPYYYY     C@YYYY
     C                     Z-ADDPMM       C@MM
     C                     Z-ADDPDD       C@DD
      *
     C                     MOVEL*BLANK    C@HHMM
     C                     MOVELP1TIM1    WKTI
     C           C@HHMM    CAT  WKTIHH:0  C@HHMM
     C           C@HHMM    CAT  ':':0     C@HHMM
     C           C@HHMM    CAT  WKTIMM:0  C@HHMM
     C                     Z-ADDP1YY2     C@YYY2
     C                     Z-ADDP1MM2     C@MM2
     C                     Z-ADDP1DD2     C@DD2
     C                     MOVEL*BLANK    C@HHM2
     C                     MOVELP1TIM2    WKTI
     C           C@HHM2    CAT  WKTIHH:0  C@HHM2
     C           C@HHM2    CAT  ':':0     C@HHM2
     C           C@HHM2    CAT  WKTIMM:0  C@HHM2
      *
     C           KEY1      SETLLALDWP051
     C           *IN90     DOUEQ*ON
     C           KEY1      READEALDWP051                 90
     C           *IN90     IFEQ *OFF
     C           @FIRST    IFEQ ' '
     C                     MOVE D5NAME    SVNAME 20
     C                     MOVE 'X'       @FIRST  1
     C                     ENDIF
     C           D5NAME    IFEQ SVNAME
     C                     ADD  D5BOX     SVBOXS  60
     C                     MOVE D5OPER    SVCOUT  6
     C                     ELSE
      *
     C                     MOVE SVNAME    S@NAME
     C                     MOVE SVCOUT    S@COUT
     C                     Z-ADDSVBOXS    S@BOXS
     C                     Z-ADDD5BOX     SVBOXS
     C                     MOVE D5NAME    SVNAME
     C                     MOVE D5OPER    SVCOUT
      *
      * if worker code is a team leader, don't write to subfile.
     C                     MOVELS@COUT    WKCD60  60
     C                     EXSR CHKTL
     C           TMLDR     IFEQ 'N'
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C* PROCESS LAST
     C                     MOVE SVNAME    S@NAME
     C                     MOVE SVCOUT    S@COUT
     C                     Z-ADDSVBOXS    S@BOXS
     C                     ADD  1         RRN1
     C                     WRITESFL01
      *
      *
     C                     ENDSR
      *--------------------------------------------------
     C           #SCRN2    BEGSR
      *
      * Check Inquiry Type and set indic to display appropriate heading.
     C                     SELEC
     C           INQTYP    WHEQ '2'
     C                     MOVE *ON       *IN62
     C           INQTYP    WHEQ '3'
     C                     MOVE *ON       *IN63
     C                     ENDSL
      *
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     MOVE '01'      @@IDX
     C           *INKL     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     MOVE '12'      @@IDX
     C                     OTHER
     C                     MOVE '02'      @@ID
     C                     MOVE '12'      @@IDX
     C                     ENDSL
      *
     C                     ENDSR
      *---------------------------------------------------
     C           CHKTL     BEGSR
      *
      * Check to See if Worker is a Team Leader.
      *
     C                     MOVE 'N'       TMLDR   1
     C           WKCD60    CHAINAM#PP31              55
     C           *IN55     DOWEQ*OFF
     C           R3SKJY    IFEQ ' '
     C                     MOVE 'Y'       TMLDR
     C                     LEAVE
     C                     ENDIF
     C           WKCD60    READEAM#PP31                  55
     C                     ENDDO
      *
     C                     ENDSR
      *---------------------------------------------------
** CMD
   F1:END
   F1:END     F12:GO BACK
