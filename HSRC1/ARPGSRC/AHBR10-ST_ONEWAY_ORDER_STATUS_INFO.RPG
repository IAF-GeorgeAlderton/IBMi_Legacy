     C*====================================================
     C*  ORDER DATE AND TIME  (OUTSRC)
     C*====================================================
     C           ##OUTS    BEGSR
     C*
     C                     CALL 'AFARS1'
     C                     PARM           CFCHYU
     C                     PARM           CFZENO
     C                     PARM CFTHNO    P@THAI  3        PRODUCTION ORDER
     C                     PARM CFHTHZ    P@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@OTHZ  8
     C                     PARM           P@PNHZ  8
     C                     PARM           P@RCHZ  8
     C                     PARM           P@OMAI  4
     C*
     C                     MOVE P@OTHZ    W$DATE           WORK DATE
     C                     Z-ADD*ZERO     W$TIME           WORK TIME
     C*          日付・時刻の編集
     C                     EXSR ##EDIT
     C                     MOVEL$$DAY     S1ODAY
     C                     MOVEL$$TIME    S1OTIM
     C*
     C                     MOVE P@RCHZ    W$DATE           WORK DATE
     C                     Z-ADD*ZERO     W$TIME           WORK TIME
     C*  EDIT DATE AND TIME
     C*          日付・時刻の編集
     C                     EXSR ##EDIT
     C                     MOVEL$$DAY     S1RDAY
     C                     MOVEL$$TIME    S1OTIM
     C*
     C           S1RDAY    IFEQ *BLANK
     C           P@PNHZ    ANDNE*BLANK
     C                     SETON                     94
     C                     MOVE P@PNHZ    W$DATE           WORK DATE
     C                     Z-ADD*ZERO     W$TIME           WORK TIME
     C*  EDIT DATE AND TIME
     C                     EXSR ##EDIT
     C                     MOVEL$$DAY     S1RDAY
     C                     MOVEL$$TIME    S1OTIM
     C                     ENDIF
     C*
     C                     ENDSR
     C*====================================================
     C* FAFAPL94
     C*====================================================
     C           ##GAI     BEGSR
     C*
     C           KEY94     SETGTAFAPL94
     C                     MOVEL*BLANK    S1WDAY
     C                     MOVEL*BLANK    S1KDAY
     C*
     C                     DO   *HIVAL
     C           KEY94     REDPEAFAPL94                  94
     C   94                LEAVE
     C*
     C           A9SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C*
     C           A9TEHI    IFNE S1THNO
     C                     ITER
     C                     ENDIF
     C*
     C           A9ODHZ    IFLT CFHTHZ
     C                     ITER
     C                     ENDIF
     C*
     C           A9HAKO    IFLT S1MAIS
     C                     SETON                     51
     C                     ENDIF
     C*
     C                     MOVE A9ODYY    W$04    4
     C           W$04      CAT  '.':0     S1WDAY
     C                     MOVE A9ODMM    W$02    2
     C           S1WDAY    CAT  W$02:0    S1WDAY
     C           S1WDAY    CAT  '.':0     S1WDAY
     C                     MOVE A9ODDD    W$02    2
     C           S1WDAY    CAT  W$02:0    S1WDAY
     C*
     C           A9NOYY    IFEQ *ZERO
     C                     SETON                     52
     C                     MOVE A9NYYY    W$04
     C                     MOVE A9NYMM    W$02
     C                     MOVE A9NYDD    W$02D   2
     C                     ELSE
     C                     MOVE A9NOYY    W$04
     C                     MOVE A9NOMM    W$02
     C                     MOVE A9NODD    W$02D   2
     C                     ENDIF
     C*
     C           W$04      CAT  '.':0     S1KDAY
     C           S1KDAY    CAT  W$02:0    S1KDAY
     C           S1KDAY    CAT  '.':0     S1KDAY
     C           S1KDAY    CAT  W$02D:0   S1KDAY
     C*
     C                     LEAVE
     C                     ENDDO
     C*
     C                     ENDSR
     C*====================================================
