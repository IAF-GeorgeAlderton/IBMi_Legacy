     C*
     C*====================================================
     C           #D2SET    BEGSR
     C*
     C           P$MODE    IFEQ '1'
     C                     SETON                     35
     C                     ELSE
     C                     SETOF                     35
     C                     ENDIF
     C                     TIME           @TIME
     C                     MOVELP$HIN1    D1HIN1
     C                     MOVELP$HIN2    D1HIN2
     C                     MOVELP$HIN3    D1HIN3
     C                     Z-ADDP$DATE    D1DATE
     C                     Z-ADDP$BIN     D1BIN   20
     C*
     C           KEY01     CHAINFCEPL01              91
     C*
     C           *IN91     IFEQ '1'
     C           *IN91     OREQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE@SYSHZ
     C                     Z-ADD*ZERO     A2GEKN
     C                     Z-ADD*ZERO     A2KSYS
     C                     Z-ADD*ZERO     A2SSYS
     C                     Z-ADD*ZERO     A2SYHZ
     C                     MOVEL*BLANK    A2TEHI
     C                     ENDIF
     C*
     C           KEY01     CHAINAAMPL11              92
     C*
     C           *IN92     IFEQ '1'
     C           *IN92     OREQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE@SYSHZ
     C                     MOVEL*BLANK    KKO              製造工程
     C                     Z-ADD*ZERO     KBM              製造部門
     C                     MOVEL*BLANK    KHB              工程内品番
     C                     MOVEL*BLANK    KKB              引当機番
     C                     MOVEL*BLANK    KNB              所番地
     C                     MOVEL*BLANK    KTY              かんばん種類
     C                     Z-ADD*ZERO     SSU              工程設定数
     C                     MOVEL*BLANK    KQK              Ｑ製造工程
     C                     Z-ADD*ZERO     KQB              Ｑ製造部門
     C                     MOVEL*BLANK    KQH              Ｑ工程内品番
     C                     MOVEL*BLANK    KQN              Ｑ引当機番
     C                     MOVEL*BLANK    KQT              Ｑ所番地
     C                     MOVEL*BLANK    KQS              Ｑかんばん種類
     C                     Z-ADD*ZERO     KHZ              切替日・便
     C                     ENDIF
     C*
     C*         手配名称
     C                     SELEC
     C           A2TEHI    WHEQ 'Z'
     C                     MOVEL'LIMIT '  D2TEHM           限定
     C           A2TEHI    WHEQ 'S'
     C                     MOVEL'TRIAL '  D2TEHM           試作
     C           A2TEHI    WHEQ 'G'
     C                     MOVEL'VOLUM '  D2TEHM           号口
     C                     OTHER
     C                     MOVEL*BLANK    D2TEHM
     C                     ENDSL
     C*収容数切替日
     C           A2SYHZ    IFLE @SYSHZ
     C                     Z-ADDA2SSYS    D2SYSU           新収容数
     C                     ELSE
     C                     Z-ADDA2KSYS    D2SYSU           旧収容数
     C                     ENDIF
     C*日当箱数
     C           A2GEKN    DIV  20        W$HIS   90       日当数量
     C           W$HIS     DIV  D2SYSU    HAKO      H      日当数量
     C*
     C                     MOVEL*BLANK    @KT              旧製造工程
     C                     Z-ADD*ZERO     @BM              旧製造部門
     C                     MOVEL*BLANK    @HN              旧工程内品番
     C                     MOVEL*BLANK    @KB              旧引当機番
     C                     MOVEL*BLANK    @BN              旧所番地
     C                     MOVEL*BLANK    @KS              旧かんばん種類
     C                     Z-ADD*ZERO     @HZ              切替日・便
     C*
     C           1         DO   15        A       30
     C           KHZ,A     IFNE *ZERO
     C           KHZ,A     DIV  100       $CHKDT  80
     C                     MOVELKQK,A     @KT,A            旧製造工程
