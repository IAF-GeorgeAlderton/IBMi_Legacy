     C                     ENDIF
     C* F20 *
     C           *INKU     WHEQ *ON
     C                     MOVE @SYSHZ    P#DATE
     C                     CALL 'DATR1A'
     C                     PARM           P#DATE  8
     C                     PARM '-'       P#PORM  1        + OR -
     C                     PARM '0003'    P#DAYS  4
     C                     PARM *BLANK    P#RDAT  8
     C                     PARM *BLANK    P#RTN   1
     C*
     C                     MOVE D1DATE    P#RDAT
     C                     CALL 'AJHR26'
     C                     PARM '1'       PQMODE  1
     C                     PARM D1HIN1    PQKHN1
     C                     PARM D1HIN2    PQKHN2
     C                     PARM D1HIN3    PQKHN3
     C                     PARM           P#RDAT  8
     C*
     C* F21 *
     C           *INKV     WHEQ *ON
     C                     MOVE @SYSHZ    PDATE
     C                     CALL 'DATR12'
     C                     PARM           PDATE   8
     C                     PARM '-'       PPORM   1        + OR -
     C                     PARM '0090'    PDAYS   4
     C                     PARM *BLANK    PRDAT   8
     C                     PARM *BLANK    PRTN    1
     C*
     C                     MOVE PRDAT     ##FRM
     C                     MOVE '01'      ##FRM
     C                     MOVEL'999999'  ##TO
     C                     MOVELD1HIN     P1HIN     P
     C*
     C                     CALL 'GDGC8Z'
     C                     PARM           P1HIN  15
     C                     PARM           ##FRM   6
     C                     PARM           ##TO    6
     C*
     C* F22 * WIP SATTUS INQUIRY (INV)
     C           *INKW     WHEQ *ON
     C                     MOVELD1HIN1    $HIN1
     C                     MOVELD1HIN2    $HIN2
     C                     MOVELD1HIN3    $HIN3
     C                     MOVELD1DD      $HADD
     C                     MOVELD1BIN     $HABB
     C*
     C                     Z-ADDD1YY      WYY1    40
     C                     Z-ADDD1MM      WMM1    20
     C*
     C                     SELEC
     C           HAKO      WHGE 4
     C           WMM1      SUB  0         WMM2
     C           HAKO      WHGE 0.5
     C           WMM1      SUB  2         WMM2
     C                     OTHER
     C           WMM1      SUB  11        WMM2
     C                     ENDSL
     C*
     C           WMM2      IFLE *ZERO
     C           WMM2      ADD  12        WMM2
     C           WYY1      SUB  1         WYY2    40
     C                     ELSE
     C                     Z-ADDWYY1      WYY2
     C                     ENDIF
     C                     MOVELWYY2      $HAYY   4
     C                     MOVELWMM2      $HAMM   2
     C*
     C                     CALL 'NYUR30'
     C                     PARM           $HIN1   5
     C                     PARM           $HIN2   5
     C                     PARM           $HIN3   2
     C                     PARM           $HAYY   4
     C                     PARM           $HAMM   2
     C                     PARM           $HADD   2
     C                     PARM           $HABB   2
     C* F24 * STOCK (INY)
     C           *INKY     WHEQ *ON
     C                     CALL 'STAC40'
     C                     PARM           D1HIN1
     C                     PARM           D1HIN2
     C                     PARM           D1HIN3
     C* 73 *(ROLL UP)
     C           *IN73     WHEQ *ON
     C  N90                EXSR #SFSET
     C                     MOVEL'#DSP2   '@STEP
     C* 74 *(ROLL DOWN)
     C           *IN74     WHEQ *ON
     C                     MOVEL'#DSP2   '@STEP
     C*
     C                     OTHER
     C                     MOVEL'#CHK2   '@STEP
     C                     ENDSL
     C*
     C                     ENDSR
     C*===============================================================
     C* CHECK SCREEN 2
     C*===============================================================
     C           #CHK2     BEGSR
     C*
     C                     MOVEL'#DSP2   '@STEP
     C*
     C                     DO   ENDRRN    RRN
     C*
     C           RRN       CHAINSFREC1               91
     C   91                LEAVE
     C*
     C*          S1SEL     IFEQ '1'
     C*                    CALL 'AHBR11'
     C*                    PARM           S1ZENO
     C*                    PARM           S1THNO
     C*                    PARM *BLANK    P$FLG   1        1=F1,3=F3
     C*                    ENDIF
     C*
     C*                    MOVEL*BLANK    S1SEL
     C           S1CHYU    COMP 'R'                      41
     C                     MOVELS1IN92    *IN92
     C                     MOVELS1IN93    *IN93
     C                     MOVELS1IN94    *IN94
     C                     MOVELS1IN50    *IN50
     C                     MOVELS1IN51    *IN51
     C                     MOVELS1IN52    *IN52
     C                     MOVELS1IN49    *IN49
     C*
     C                     UPDATSFREC1
     C*
     C*          P$FLG     IFEQ '1'                        1=F1,3=F3
     C*                    MOVEL'#END    '@STEP
     C*                    LEAVE
     C*                    ENDIF
     C  N99                ENDDO
     C*
     C                     ENDSR
     C*===============================================================
     C* EDIT DATE AND TIME
     C*===============================================================
     C           ##EDIT    BEGSR
     C*
     C                     MOVEL*BLANK    $$DAY   5
     C                     MOVEL*BLANK    $$TIME  5
     C*
     C           W$DATE    IFNE *ZERO
     C                     Z-ADDW$MM      $$HBMM
     C                     MOVEL'.'       $$HB1
     C                     Z-ADDW$DD      $$HBDD
     C                     MOVEL$$HB      $$DAY
     C                     Z-ADDW$JJ      $$HBMM
     C                     MOVEL':'       $$HB1
     C                     Z-ADDW$FF      $$HBDD
     C                     MOVEL$$HB      $$TIME
     C                     ENDIF
     C*
     C                     MOVEL'.'       $$HB1
     C*
     C                     ENDSR
     C*===============================================================
     C* INQUIRE PRODUCTION PROCESS INFORMATION
     C*===============================================================
     C           ##AKAR    BEGSR
     C*
     C                     MOVEL'X'       P$SNO   1
     C                     MOVEL*BLANK    P$F3    1
     C                     MOVEL*BLANK    P$ERR   1
     C*
     C                     DO   *HIVAL
     C                     MOVE P$SNO     P$NO
     C                     CALL 'AKAR27'
     C                     PARM           P$F3    1
     C                     PARM           P$ERR   1
     C                     PARM D1HIN     P$HIN  12
     C                     PARM           P$NO    1
     C*
     C           P$F3      IFEQ '1'
     C           P$ERR     ORNE *BLANK
     C                     LEAVE
     C                     ENDIF
     C*
     C                     CALL 'AKAR28'
     C                     PARM           P$F3
     C                     PARM           P$SNO   1
     C                     PARM           P$ERR   1
     C                     PARM D1HIN1    P$SHN1  5
     C                     PARM D1HIN2    P$SHN2  5
     C                     PARM D1HIN3    P$SHN3  2
     C*
     C           P$F3      IFEQ '1'
     C           P$ERR     ORNE *BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C*
     C           P$ERR     IFEQ 'E'
     C                     SETON                       99
     C                     MOVELER,8      D2ERR
     C                     ENDIF
     C*
     C           P$ERR     IFEQ '9'
     C                     SETON                       99
     C                     MOVELER,9      D2ERR
     C                     ENDIF
     C*
     C                     ENDSR
     C*====================================================
     C*
     C*====================================================
     C           #OQ       BEGSR
     C*
     C                     MOVEL*BLANK    W@OQ    3
     C*
     C                     MOVEL*BLANK    PQBAN1
     C                     MOVEL*BLANK    PQBAN2
     C                     MOVEL*BLANK    PQBAN3
     C                     MOVEL*BLANK    PQBAN4
     C                     MOVEL*BLANK    PQBMON
     C                     MOVEL'OQ '     PQKOTE
     C                     MOVEL*BLANK    PQKIBN
     C                     MOVEL*BLANK    PQKHIN
     C                     CALL 'AAMRS9'  AAMRS9
     C*
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'OQ '     W@OQ
     C*
     C                     ELSE
     C                     MOVEL'LOQ'     PQKOTE
     C                     CALL 'AAMRS9'  AAMRS9
     C*
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'LOQ'     W@OQ
     C                     ENDIF
     C                     ENDIF
     C*
     C           EOQ       ENDSR
     C*====================================================
     C*
     C*====================================================
     C           #LAN      BEGSR
     C*
     C                     MOVEL*BLANK    W@LAN   3
     C*
     C                     MOVEL*BLANK    PQBAN1
     C                     MOVEL*BLANK    PQBAN2
     C                     MOVEL*BLANK    PQBAN3
     C                     MOVEL*BLANK    PQBAN4
     C                     MOVEL*BLANK    PQBMON
     C                     MOVEL'LAN'     PQKOTE
     C                     MOVEL*BLANK    PQKIBN
     C                     MOVEL*BLANK    PQKHIN
     C                     CALL 'AAMRS9'  AAMRS9
     C*
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'LAN'     W@LAN
     C*
     C                     ELSE
     C                     MOVEL'AOQ'     PQKOTE
     C                     CALL 'AAMRS9'  AAMRS9
     C*
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'AOQ'     W@LAN
     C                     ENDIF
     C                     ENDIF
     C*
     C           ELAN      ENDSR
     C*====================================================
     C*
     C*====================================================
     C           #SB       BEGSR
     C*
     C                     MOVEL*BLANK    W@SB    3
     C*
     C                     MOVEL*BLANK    PQBAN1
     C                     MOVEL*BLANK    PQBAN2
     C                     MOVEL*BLANK    PQBAN3
     C                     MOVEL*BLANK    PQBAN4
     C                     MOVEL*BLANK    PQBMON
     C                     MOVEL'SB '     PQKOTE
     C                     MOVEL*BLANK    PQKIBN
     C                     MOVEL*BLANK    PQKHIN
     C                     CALL 'AAMRS9'  AAMRS9
     C*
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'SB '     W@SB
     C*
     C                     ELSE
     C                     MOVEL'KRO'     PQKOTE
     C                     CALL 'AAMRS9'  AAMRS9
     C*
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'KRO'     W@SB
     C                     ENDIF
     C                     ENDIF
     C*
     C           ESB       ENDSR
     C*====================================================
     C*
     C*====================================================
     C           #ST       BEGSR
     C*
     C                     MOVEL*BLANK    W@ST    3
     C*
     C                     MOVEL*BLANK    PQBAN1
     C                     MOVEL*BLANK    PQBAN2
     C                     MOVEL*BLANK    PQBAN3
     C                     MOVEL*BLANK    PQBAN4
     C                     MOVEL*BLANK    PQBMON
     C                     MOVEL*BLANK    PQKIBN
     C                     MOVEL*BLANK    PQKHIN
     C                     CALL 'AAMRS9'  AAMRS9
     C*
     C           PQKHIN    IFNE *BLANK
     C                     MOVELPQKOTE    W@ST
     C*
     C                     ELSE
     C           PQKOTE    IFEQ 'DS '
     C                     MOVEL'DSM'     PQKOTE
     C                     CALL 'AAMRS9'  AAMRS9
     C*
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'DS '     W@ST
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C*
     C           EST       ENDSR
     C*====================================================
**  ERR
ENTER IAF PART#
IAF PART# IS INVALID
DATE FROM IS INVALID
BIN IS INVALID
E-05 IAF PART# IS NOT IN KANBAN EXCHANGE MASTER
DATA NOT FOUND
STORE IS INVALID
E-08 IAF PART# IS NOT IN KANBAN EXCHANGE MASTER
E-09 IAF PART# DOES NOT HAVE DATA TO DISPLAY
E-10
