     C                     Z-ADDP@COTM    W$TIME           WORK TIME
     C                     EXSR ##EDIT
     C                     MOVEL$$DAY     S1SDAY
     C                     MOVEL$$TIME    S1STIM
     C*
     C* COLOR GREEN/RED FOR SRT/SHIPPING FIELD
     C           P@STK     IFEQ 'Y'
     C                     SETOF                     49
     C                     ELSE
     C                     SETON                     49
     C                     ENDIF
     C*
     C                     MOVEL*IN49     S1IN49
     C*
     C           ##SRTX    ENDSR
     C*===============================================================
