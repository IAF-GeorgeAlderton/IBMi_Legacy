     C*====================================================
     C* GET SORT SCAN DATE/TIME
     C*====================================================
     C           ##SRT     BEGSR
     C*
     C                     MOVEL*BLANK    S1SDAY
     C                     MOVEL*BLANK    S1STIM
     C                     MOVEL*BLANK    WDAT
     C                     MOVEL*BLANK    WTIM
     C*
     C* GET SORT SACN DATE/TIME
     C*****                MOVELS@HTHZ    P@IDAT
     C*****                CALL 'ALCRS5'
     C*****                PARM D1HIN1    P@SHN1  5
     C*****                PARM D1HIN2    P@SHN2  5
     C*****                PARM D1HIN3    P@SHN3  2
     C*****                PARM S1THNO    P@TEHI  3
     C*****                PARM           P@IDAT  8
     C*****                PARM '00000000'P@SDAT  8
     C*****                PARM '000000'  P@STIM  6
     C*****                PARM *BLANK    P@STK   1
     C*****                PARM *BLANK    P@RTN   1
     C* CHECK ISSUE DATE
     C*****      P@RTN     IFEQ *BLANK
     C*****                MOVE P@SDAT    SRT80   80
     C*****      SRT80     IFLT CFHTHZ
     C*****                GOTO ##SRTX
     C*****                ENDIF
     C*****                ENDIF
     C*****
     C*****      P@RTN     IFEQ *BLANK
     C*****                MOVE P@SDAT    LTR4    4
     C*****                MOVELLTR4      WDAT1
     C*****                MOVE LTR4      WDAT2
     C*****                MOVEL'.'       PD1
     C*****                MOVELWDAT      S1SDAY
     C* EDIT
     C*****                MOVELP@STIM    LTR4    4
     C*****                MOVELLTR4      WTIM1
     C*****                MOVE LTR4      WTIM2
     C*****                MOVEL':'       PC1
     C*****                MOVELWTIM      S1STIM
     C*****                ENDIF
     C           P@KEHZ    IFNE *ZERO
     C                     Z-ADDP@KEHZ    P@DATE           DATE OF KANBAN PUB.
     C                     Z-ADDP@KETM    P@TIME           TIME OF KANBAN PUB.
     C                     ELSE
     C                     Z-ADD99999999  P@DATE           DATE OF KANBAN PUB.
     C                     Z-ADD999999    P@TIME           TIME OF KANBAN PUB.
     C                     ENDIF
     C                     CALL 'ALDRS7'
     C*                   ( IN )
     C                     PARM CFHIN1    P@LHN1  5        PART NO1
     C                     PARM CFHIN2    P@LHN2  5        PART NO2
     C                     PARM CFHIN3    P@LHN3  2        PART NO3
