     H            Y.
     F** UEXR21 *********************************************
     F*  PROGRAM: EXSUB - MACHINE CHANGE REPORT             *
     F*  WRITTEN: JW (SRA) 2020.03.03                       *
     FUEXWP22 IF  E           K        DISK
     FUEXWP23 O   E           K        DISK
      *=====================================================*
      * SYSTEM DATE
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     MOVE 'Y'       FIRST   1
     C           *LOVAL    SETLLUEXWP22
      *
     C                     DO   *HIVAL
     C                     READ UEXWP22                  98
     C   98                LEAVE
      *
     C           U2SKJY    IFEQ 'C'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELU2EFHZ    U2EF6   60
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELU2FILE    SVFILE 10
     C                     MOVELU2EF6     SVEF6   60
     C                     ENDIF
      * BRAEK?
     C           U2FILE    IFNE SVFILE
     C           U2EF6     ORNE SVEF6
     C                     EXSR #BRK1
     C                     ENDIF
      * PROCESS
     C                     ADD  1         SEQ#    40
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * BREAK
      *======================================================
     C           #BRK1     BEGSR
      *
     C                     MOVELSVFILE    U3FILE
     C                     Z-ADDSVEF6     U3EFHZ
     C                     Z-ADDSEQ#      U3CNT
     C                     WRITEUEXWP231
      *
     C                     Z-ADD0         SEQ#
     C                     MOVELU2FILE    SVFILE
     C                     MOVELU2EF6     SVEF6
      *
     C                     ENDSR
