      *------------------------------------------------------------
      *   MAIN
      *------------------------------------------------------------
     C                     EXSR #INIT
      *
     C           *LOVAL    SETLLABAWP41A
     C                     DO   *HIVAL
     C                     READ ABAWP41A                 98
     C   98                LEAVE
      *
     C                     EXSR #EDIT
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
      * EDIT ABAWP41A
      *-----------------------------------------------------
     C           #EDIT     BEGSR
      *
     C                     CLEARABAWP412
     C                     MOVELAWSHIN    A2SHIN
      *
     C                     MOVELAWNONY    LTR1    1
     C           LTR1      IFEQ '0'
     C                     MOVE AWNONY    LTR5    5
     C                     MOVELMSG,1     LTR5
     C                     MOVELLTR5      A2NONY
     C                     ELSE
     C                     MOVELAWNONY    A2NONY
     C                     ENDIF
      *
     C                     MOVELAWNONM    A2NONM
      *
     C                     MOVELAWDOCK    LTR1
     C           LTR1      IFEQ '0'
     C                     MOVE AWDOCK    LTR5
     C                     MOVELMSG,1     LTR5
     C                     MOVELLTR5      A2DOCK
     C                     ELSE
     C                     MOVELAWDOCK    A2DOCK
     C                     ENDIF
      *
     C           1         DO   30        IX
     C           @AW,IX    IFEQ 0
     C                     MOVEL'0000'    A2W,IX    P
     C                     ELSE
     C                     Z-ADD@AW,IX    $IN
     C                     CALL 'UTLR64'
     C                     PARM           $IN    156
     C                     PARM           $TRUE  17
     C                     PARM           $RTN    1
     C                     MOVEL$TRUE     A2W,IX
     C                     ENDIF
     C                     ENDDO
      *
     C                     WRITEABAWP412
      *
     C                     ENDSR
      *-----------------------------------------------------
      * INITIALIZE
      *-----------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $STDT   8
      *
     C                     TIME           SDATE
      * CREATE HEADER
     C                     CLEARABAWP412
     C                     MOVEL'IAF PART'A2SHIN
     C                     MOVEL'DELIV#  'A2NONY
     C                     MOVEL'NAME    'A2NONM
     C                     MOVEL'DOCK    'A2DOCK
     C                     MOVEL$STDT     DT#     8
      * GET LAST MONDAY
     C                     MOVELDT#       $DT81
     C                     MOVE '1'       $DAY
     C                     CALL 'UTLR02A'
     C                     PARM           $DT81   8
     C                     PARM           $DAY    1
     C                     PARM           $DT82   8
     C                     PARM           $RTN    1
     C                     MOVEL$DT82     DT#
      * 7 DAYS BACK
     C                     MOVELDT#       $DT8
     C                     MOVE '-'       $SIGN
     C                     MOVEL'0007'    $DAYS
     C                     MOVE 'N'       $IAF
     C                     CALL 'UTLR10'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN    1
     C                     MOVEL$TGT8     DT#
      * MOVE DATE FOR HEADER
     C           1         DO   30        IX      20
     C                     MOVELDT#       $DT8
     C                     MOVE '+'       $SIGN
     C                     MOVEL'0007'    $DAYS
     C                     MOVE 'N'       $IAF
     C                     CALL 'UTLR10'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN    1
     C                     MOVEL$TGT8     A2W,IX
     C                     MOVEL$TGT8     DT#
     C                     ENDDO
      *
     C                     WRITEABAWP412
      *
     C                     ENDSR
** MSG
'
