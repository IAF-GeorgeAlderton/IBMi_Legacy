     H            Y.
     F** AL#R69  *******************************************
     F*  RETURN CUSTOMER LABEL SORT                        *
     F*      ITS.        2015.05.27                        *
     F******************************************************
     FAL#PP61 IF  E                    DISK
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1BLK   2
     C                     PARM           P9SORT  50
     C                     PARM           P9SITE  1
     C                     PARM           P9SECT  2
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
     C                     Z-ADD0         P9SORT
     C                     MOVEL*BLANK    P9SITE
     C                     MOVEL*BLANK    P9SECT
     C                     MOVEL'0'       GET     1
     C           1         SETLLAL#PP611
     C                     READ AL#PP611                 22
     C           *IN22     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           C6SKJY    IFEQ 'D'
     C           C6SKHZ    ANDLESDATE
     C                     ELSE
     C           C6BLK     IFEQ P1BLK
     C           C6BLK2    OREQ P1BLK
     C                     MOVEL'1'       GET
     C                     Z-ADDC6SORT    P9SORT
     C                     MOVELC6SITE    P9SITE
     C                     MOVELC6SECT    P9SECT
     C                     ENDIF
     C                     ENDIF
     C                     READ AL#PP611                 22
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
