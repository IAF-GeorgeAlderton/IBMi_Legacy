     H            Y.
     F** AFHR05 *********************************************
     F* CREATE EDI FORECAST 830 DETAIL                      *
     F*     T.SAKAKI                          2016.11.04    *
     F*******************************************************
     FAFHWP03 IF  E           K        DISK
      * EDI PARAMETER FILE
     FEDIPP50 IF  E           K        DISK
      * FLAT DATA
     FOUTPUT  O   F     504            DISK
      *
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
     I            DS
     I                                        1   80W3SDAT
     I                                        3   80W3SDT6
     I            DS
     I                                        1  12 W3SHN
     I                                        1   5 W3SHN1
     I                                        6  10 W3SHN2
     I                                       11  12 W3SHN3
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
      *
     I              '0123456789'          C         DIGITS
      *================================================================
      *  ENTRY LIST
      *================================================================
     C           *ENTRY    PLIST
     C                     PARM           P@SUPP  4
     C                     PARM           P@SNRV  1
     C                     PARM           P@DKBN  3
     C                     PARM           P@SERN 10
      *================================================================
      *  KEY   LIST
      *================================================================
     C           KEY1      KLIST
     C                     KFLD           P@SUPP
     C                     KFLD           P@SNRV
     C                     KFLD           P@DKBN
      *================================================================
     C* MAIN
      *================================================================
     C                     TIME           @TIME
     C                     MOVEL*BLANK    SVSHN  12
     C                     MOVE P@SERN    P@SER6  6
     C*
     C                     SETOF                     81
     C           KEY1      CHAINEDIPP501             81
     C           *IN81     IFEQ '0'
     C           E5SKJY    ANDNE'D'
     C                     MOVELE5DOCK    WKDOCK 30        IAF DOCK
     C                     MOVELE5ALF1    WKALF1 30        ASM FD LOC
     C                     MOVELE5ALF2    WKALF2 30        RESERVED
     C                     MOVELE5STCP    WKENAM 35        EXPEDITOR
     C                     MOVELE5STPH    WKEPHN 21        PHONE #
     C                     ENDIF
     C*
     C*
     C                     SETOF                     82
     C           *LOVAL    SETLLAFHWP031
     C                     DO   *HIVAL
     C                     READ AFHWP031                 82
     C   82                LEAVE
      * OUTPUT
     C                     EXCPTDTWRT
     C*
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *================================================================
      * OUTPUT
      *================================================================
     OOUTPUT  E                DTWRT
     O                                    1 'D'
     O* RECORD ID  2-7
     O                         P@SER6     7
     O* IAF PART NUMBER  8-37 (14)  21 + 16 = 37
     O                         W3SHN1    12
     O                                   13 '-'
     O                         W3SHN2    18
     O                                   19 '-'
     O                         W3SHN3    21
     O* DOCK NUMBER  38-67
     O                         WKDOCK    67
     O* ASSEMBLY LINE FEED LOCATION  68-97
     O                         WKALF1    97
     O* RESERVED ASSEMBLY LINE FEED LOCATION  98-127
     O                         WKALF2   127
     O* EXPEDITOR  128-162
     O                         WKENAM   162
     O* PHONE NUMBER  163-183
     O                         WKEPHN   183
     O* QUANTITY  184-193
     O                         W3QTY    193
     O* TIMING QUALIFIER  194-194
     O                         W3TMQL   194
     O* STARTING DATE  195-200
     O                         W3SDT6   200
