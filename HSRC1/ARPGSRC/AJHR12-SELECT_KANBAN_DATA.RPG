     H            Y.
     FINPUT   UP  F     512            DISK
     IINPUT   AA  01
     I                                        1   1 JCKANK
     I                                        1   2 JCKAN2
     C           JCKANK    IFNE 'A'
     C                     DELETINPUT
     C                     GOTO @END
     C                     END
     C           JCKAN2    IFEQ 'AA'
     C                     DELETINPUT
     C                     GOTO @END
     C                     END
     C           @END      TAG
