     H            Y.
     F** AH#RY0 ****************************************************
     F* CREATE A-PICS DATA OF NO SCAN                              *
     F*    Y.MAEDA            2017.12.01                           *
     F*                                                            *
JW1  F*    JW    2018.01.05 AVOID DIVIDING BY ZERO                 *
     F******************************** AH#R30 **********************
     FAH#TL11 IF  E           K        DISK
     FNZUPL01 IF  E           K        DISK
     FALHPL01 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FAH#WPY0 O   F    1024            DISK
      *
     I            DS
     I                                        1   80KHKHZ
     I                                        1   40KHKYY
     I                                        5   60KHKMM
     I                                        7   80KHKDD
     I            DS
     I                                        1   80CFHTHZ
     I                                        1   40CFHTYY
     I                                        5   60CFHTMM
     I                                        7   80CFHTDD
     I            DS
     I                                        1  14 CFSHIN
     I                                        1   5 CFHIN1
     I                                        6   6 HIHN1
     I                                        7  11 CFHIN2
     I                                       12  12 HIHN2
     I                                       13  14 CFHIN3
     I            DS
     I                                        1   80A1SCHZ
     I                                        1   40A1SCYY
     I                                        5   60A1SCMM
     I                                        7   80A1SCDD
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     I            DS
     I                                        1   80A2SYHZ
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
      *
     C           *ENTRY    PLIST
     C                     PARM           PISHN1  5
     C                     PARM           PISHN2  5
     C                     PARM           PISHN3  2
     C                     PARM           PITKR1  2
     C                     PARM           PITKR2  2
     C                     PARM           PISHZ   8
     C                     PARM           PIEHZ   8
      *
     C           KEY1      KLIST
     C                     KFLD           KBMON   40
     C                     KFLD           KHKYY
     C                     KFLD           KHKMM
     C                     KFLD           KHKDD
      *
     C           KEY2      KLIST
     C                     KFLD           KZETI   4
     C                     KFLD           KTHAI   3
     C*--                  KFLD           KPAGE   2
      *
     C           KEY3      KLIST
     C                     KFLD           KSHN1   5
     C                     KFLD           KSHN2   5
     C                     KFLD           KSHN3   2
     C                     KFLD           KHKYY
     C                     KFLD           KHKMM
     C                     KFLD           KHKDD
      *
     C           KEY4      KLIST
     C                     KFLD           KSHN1   5
     C                     KFLD           KSHN2   5
     C                     KFLD           KSHN3   2
      *
     C                     MOVE PISHZ     KHKHZ
     C                     MOVE '0111'    KBMON
     C                     MOVE PIEHZ     WWIEHZ  80
      *
     C                     SETOF                     71
     C           KEY1      SETLLAH#TL11
S1   C                     DO   *HIVAL
     C                     READ AH#TL11                  71
     C   71                LEAVE
     C           CFHTHZ    IFGT WWIEHZ
     C                     LEAVE
     C                     END
     C           CFSKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C           PISHN1    IFNE *BLANK
     C           PISHN2    ORNE *BLANK
     C           PISHN3    ORNE *BLANK
     C           PISHN1    IFNE CFHIN1
     C           PISHN2    ORNE CFHIN2
     C           PISHN3    ORNE CFHIN3
     C                     ITER
     C                     END
     C                     END
      *
     C                     MOVEL'-'       HIHN1
     C                     MOVEL'-'       HIHN2
     C           CFHIN3    IFEQ ' '
     C                     MOVEL' '       HIHN2
     C                     END
      *PICK UP DATE
     C                     EXSR ##PIC
      *LOAD DATE
     C                     MOVEL*BLANK    WBDATE  80
     C                     MOVEL*BLANK    WBTIME  40
     C                     EXSR ##WIN
     C           WBDATE    IFEQ 0
     C                     EXSR ##WIN2
     C                     END
     C           WBDATE    IFEQ 0
     C                     EXSR ##WIN3
     C                     END
      *STORE IN DATE
     C                     EXSR ##NZU
      *LOQ RESULT
     C                     EXSR ##LOQ
      *PART M/F
     C                     EXSR ##PAR
      *
     C                     EXCPT@HD
      *
E1   C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------------
      * PICKUP DATE
      *-----------------------------------------------------------
     C           ##PIC     BEGSR
     C                     CALL 'ALCRS1'
     C                     PARM           CFCHYU  1
     C                     PARM CFZENO    CFZENO  4
     C                     PARM CFTHNO    CFTHNO  3
     C                     PARM CFHTHZ    P@HTHZ  80       KANBAN PUBLICATION
      *                               GET ------
     C                     PARM           WPDATE  80       WORK ADMITTABLE DATE
     C                     PARM           WPTIME  60       WORK ADMITTABLE TIME
      *
     C                     ENDSR
      *-----------------------------------------------------------
      * LOAD DATA 1
      *-----------------------------------------------------------
     C           ##WIN     BEGSR
     C                     CALL 'AJSR1Z'
     C                     PARM CFHIN1    P@HIN1  5        PART NUMBER 1
     C                     PARM CFHIN2    P@HIN2  5        PART NUMBER 2
     C                     PARM CFHIN3    P@HIN3  2        PART NUMBER 3
     C                     PARM CFTHNO    P@THAI  3        PRODUCTION ORDER
     C                     PARM CFHTHZ    P@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
      *
     C                     MOVELP@WIHZ    WBDATE           WORK DATE
     C                     MOVELP@WITM    WBTIME           WORK TIME
     C*
     C                     ENDSR
      *-----------------------------------------------------------
      * LOAD DATA 2
      *-----------------------------------------------------------
     C           ##WIN2    BEGSR
     C                     CALL 'AJSR2Z'
     C                     PARM CFHIN1    P@HIN1  5        PART NUMBER 1
     C                     PARM CFHIN2    P@HIN2  5        PART NUMBER 2
     C                     PARM CFHIN3    P@HIN3  2        PART NUMBER 3
     C                     PARM CFTHNO    P@THAI  3        PRODUCTION ORDER
     C                     PARM CFHTHZ    P@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
      *
     C                     Z-ADDP@WIHZ    WBDATE           WORK DATE
     C                     Z-ADDP@WITM    WBTIME           WORK TIME
     C*
     C                     ENDSR
      *-----------------------------------------------------------
      * LOAD DATA 3
      *-----------------------------------------------------------
     C           ##WIN3    BEGSR
     C                     CALL 'ALMR0Z'
     C                     PARM CFHIN1    P@HIN1  5        PART NUMBER 1
     C                     PARM CFHIN2    P@HIN2  5        PART NUMBER 2
     C                     PARM CFHIN3    P@HIN3  2        PART NUMBER 3
     C                     PARM CFTHNO    P@THAI  3        PRODUCTION ORDER
     C                     PARM CFHTHZ    P@HTHZ  80       KANBAN PUBLICATION
     C*                               GET ------
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
      *
     C                     MOVELP@WIHZ    WBDATE           WORK DATE
     C                     MOVELP@WITM    WBTIME           WORK TIME
     C*
     C                     ENDSR
      *-----------------------------------------------------------
      * STORE IN DATE
      *-----------------------------------------------------------
     C           ##NZU     BEGSR
     C                     MOVEL*BLANK    KZETI
     C                     MOVEL*BLANK    KTHAI
     C*--                  MOVEL*BLANK    KPAGE
     C                     MOVELCFZENO    KZETI
     C                     MOVELCFTHNO    KTHAI
     C*---                 MOVE @X        KPAGE
     C                     Z-ADD0         WSDATE
     C                     Z-ADD0         WSTIME
     C                     Z-ADD0         WRDATE
     C                     Z-ADD0         WRTIME
     C                     Z-ADD0         WODATE
     C                     Z-ADD0         WOTIME
     C                     SETOF                     72
     C           KEY2      SETGTNZUPL01
     C                     DO   *HIVAL
     C           KEY2      REDPENZUPL01                  72
     C   72                LEAVE
     C*          N2NYHZ    IFLT CFHTHZ
     C*                    LEAVE
     C*                    END
     C           N2SKJY    IFEQ 'D'
     C                     Z-ADDN2KOHZ    WRDATE  80
     C                     MOVELN2KOTI    WRTIME  40
     C                     LEAVE
     C                     ELSE
     C*
     C                     MOVELN2MTK1    W0MTK1  1
     C                     MOVELN2MTK2    W0MTK2  2
     C                     MOVELN2MTK3    W0MTK3  2
     C                     MOVELN2MTK4    W0MTK4  1
     C*
     C           N2NYHZ    IFEQ 0
     C           N2DEHZ    ANDEQ0
     C                     ITER
     C                     ELSE
     C                     Z-ADDN2NYHZ    WSDATE  80
     C                     MOVELN2NYTI    WSTIME  40
     C                     Z-ADDN2DEHZ    WODATE  80
     C                     MOVELN2DETI    WOTIME  40
     C                     LEAVE
     C                     END
     C                     END
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------------
      * LOQ RESULT
      *-----------------------------------------------------------
     C           ##LOQ     BEGSR
     C                     MOVEL*BLANK    KSHN1
     C                     MOVEL*BLANK    KSHN2
     C                     MOVEL*BLANK    KSHN3
     C                     MOVELCFHIN1    KSHN1
     C                     MOVELCFHIN2    KSHN2
     C                     MOVELCFHIN3    KSHN3
     C                     Z-ADDCFHTYY    KHKYY
     C                     Z-ADDCFHTMM    KHKMM
     C                     Z-ADDCFHTDD    KHKDD
     C                     Z-ADD0         WLDATE
     C                     Z-ADD0         WLTIME
     C                     SETOF                     73
     C           KEY3      SETLLALHPL01
     C                     DO   *HIVAL
     C           KEY4      READEALHPL01                  73
     C   73                LEAVE
     C           A1SCHZ    IFGT WWIEHZ
     C                     LEAVE
     C                     END
     C           A1SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C                     Z-ADDA1SCHZ    WLDATE  80
     C                     MOVELA1SCTM    WLTIME  40
     C                     LEAVE
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------------
      * PART MASTER
      *-----------------------------------------------------------
     C           ##PAR     BEGSR
     C                     Z-ADD0         WFGEKN  90
     C                     Z-ADD0         WFSSYS  50
      *
     C           KEY4      CHAINFCEPL01              74
     C           *IN74     IFEQ *OFF
      *
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ELSE
      * SETTING #/M
     C                     Z-ADDA2GEKN    WFGEKN
      * QPC.
     C           A2SYHZ    IFGT *DATE
     C                     Z-ADDA2KSYS    WFSSYS
     C                     ELSE
     C                     Z-ADDA2SSYS    WFSSYS
     C                     ENDIF
     C           WFSSYS    IFEQ 0
     C                     Z-ADDA2SSYS    WFSSYS
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
      *
      * BOX/DAY
     C                     Z-ADD0         WFBOXP
     C                     Z-ADD0         AAA
     C                     Z-ADD0         WFBBB1
     C                     Z-ADD0         WFBBB2
JW1   * AVOID DIVIDING BY ZERO
 |   C           WFSSYS    IFEQ 0
 |   C                     Z-ADD0         AAA
 |   C                     Z-ADD0         WFBOXP
 |   C                     Z-ADD0         WFBBB1
 |   C                     Z-ADD0         WFBBB2
JW1  C                     ELSE
      *
     C           WFGEKN    DIV  WFSSYS    AAA     83
     C           AAA       DIV  20        WFBOXP  62
     C           AAA       DIV  20        WFBBB1  63
     C                     MOVE WFBBB1    WFBBB2  10
     C           WFBBB2    IFGE 5
     C                     ADD  0.01      WFBOXP
     C                     ENDIF
      *
JW1  C                     ENDIF
      * RATIO
     C                     Z-ADD0         WFRATI
     C                     Z-ADD0         WFBBB1
     C                     Z-ADD0         WFBBB2
     C           WFBOXP    IFNE 0
     C           CFMAIS    DIV  WFBOXP    WFRATI  62
     C           CFMAIS    DIV  WFBOXP    WFBBB1  63
     C                     MOVE WFBBB1    WFBBB2  10
     C           WFBBB2    IFGE 5
     C                     ADD  0.01      WFRATI
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------------
     OAH#WPY0 E                @HD
     O                         CFZENO     4
     O                         CFTHNO     7
     O*--                      KPAGE      9
     O                         CFSHIN    23
     O                         CFHTHZ    31
     O                         CFMAIS    34
      *PICK UP DATE
     O                         WPDATE    42
     O                         WPTIME    46
      *BZ DATE
     O                         WBDATE    54
     O                         WBTIME    58
      *STORE IN DATE
     O                         WSDATE    66
     O                         WSTIME    70
      *LOQ
     O                         WLDATE    78
     O                         WLTIME    82
      *STORE OUT DATA
     O                         WODATE    90
     O                         WOTIME    94
      *REISSUE
     O                         WRDATE   102
     O                         WRTIME   106
      *PART M/F
     O                         WFBOXP   112
     O                         WFRATI   118
      *PREVIOUS LOCATION
     O                         W0MTK1   119
     O                                  120 '-'
     O                         W0MTK2   122
     O                                  123 '-'
     O                         W0MTK3   125
     O                                  126 '-'
     O                         W0MTK4   127
