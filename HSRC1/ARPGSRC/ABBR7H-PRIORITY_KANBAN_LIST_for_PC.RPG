      *--------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           PDATE   8
     C                     PARM           PSHFT   1
      *--------------------------------------------------
      *
     C                     EXSR @MAIN
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *
      *-----------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------
      *
     C                     ENDSR
      *-----------------------------------------------
     C           @MAIN     BEGSR
      *-----------------------------------------------
      *
     C                     MOVELPDATE     K@DATE  80
     C           K#PL71    KLIST
     C                     KFLD           K@DATE
     C                     KFLD           PSHFT
     C           K#PL71    SETLLABBPL71
     C*
     C                     DO   *HIVAL
     C*
     C           K#PL71    READEABBPL71                  99
     C   99                LEAVE
     C           A7KNID    IFNE 'A'
     C                     ITER
     C                     END
     C*
     C           K#AAMP    CHAINABBWP7H              94
     C           *IN94     IFEQ *OFF
     C                     ADD  A7KQTY    W7KQTY
     C                     UPDATABBWP7H1
     C                     ITER
     C                     END
     C*
     C                     CLEARABBWP7H1
     C                     MOVELA7PRT1    W7PRT1
     C                     MOVELA7PRT2    W7PRT2
     C                     MOVELA7PRT3    W7PRT3
     C                     Z-ADDA7KQTY    W7KQTY
     C*
     C           K#AAMP    KLIST
     C                     KFLD           A7PRT1
     C                     KFLD           A7PRT2
     C                     KFLD           A7PRT3
     C           K#AAMP    CHAINAAMPL11              98
     C           *IN98     IFEQ *ON
     C           CKSKJY    ORNE *BLANK
     C                     WRITEABBWP7H1
     C                     ITER
     C                     END
     C*
     C                     DO   15        W       20
     C                     Z-ADDCHG,W     @CHG
     C           @CHGDT    IFGT *DATE
     C                     MOVELOTKR,W    TKR,W
     C                     MOVELOCKQ,W    CKQ,W
     C                     MOVELOPRC,W    PRC,W
     C                     MOVELOMCN,W    MCN,W
     C                     MOVELOPRT,W    PRT,W
     C                     Z-ADDODPT,W    DPT,W
     C                     ELSE
     C                     MOVELNTKR,W    TKR,W
     C                     MOVELNCKQ,W    CKQ,W
     C                     MOVELNPRC,W    PRC,W
     C                     MOVELNMCN,W    MCN,W
     C                     MOVELNPRT,W    PRT,W
     C                     Z-ADDNDPT,W    DPT,W
     C                     END
     C                     ENDDO
     C*
     C                     Z-ADD15        X       20
     C                     DO   *HIVAL
     C           TKR,X     IFEQ *BLANK
     C                     SUB  1         X
     C           X         IFLE *ZERO
     C                     LEAVE
     C                     END
     C                     ITER
     C                     END
     C                     LEAVE
     C                     ENDDO
     C           X         IFLE *ZERO
     C                     WRITEABBWP7H1
     C                     ITER
     C                     END
     C*
     C                     MOVELTKR,X     W@LOC
     C                     MOVELW@L2      @LOC1
     C                     MOVELW@L3      @LOC2
     C                     MOVEL@LOCT     W7FLOC
     C*
     C                     SUB  1         X
     C           X         IFLE *ZERO
     C                     WRITEABBWP7H1
     C                     ITER
     C                     END
     C*
     C           CKQ,X     IFEQ 'C'
     C           CKQ,X     OREQ *BLANK
     C                     DO   *HIVAL
     C                     SUB  1         X
     C           X         IFLE *ZERO
     C                     LEAVE
     C                     END
     C           CKQ,X     IFEQ 'C'
     C           CKQ,X     OREQ *BLANK
     C                     ITER
     C                     END
     C                     LEAVE
     C                     ENDDO
     C           X         IFLE *ZERO
     C                     WRITEABBWP7H1
     C                     ITER
     C                     END
     C                     END
     C*
     C                     MOVEL*BLANK    @LOC1
     C                     MOVEL*BLANK    @LOC2
     C                     MOVELTKR,X     W@LOC
     C                     MOVELPRT,X     WPART
     C           K#PRT     KLIST
     C                     KFLD           WPRT1
     C                     KFLD           WPRT2
     C                     KFLD           WPRT3
     C*
     C                     SELEC
     C           CKQ,X     WHEQ 'C'
     C           K#PRT     SETLLAAFTL06
     C           *IN95     DOUEQ*ON
     C           K#PRT     READEAAFTL06                  95
     C           *IN95     IFEQ *OFF
     C           A3SKJY    IFEQ 'D'
     C           A3STHZ    ORNE 99999999
     C                     ITER
     C                     ENDIF
     C           A3ATK2    IFNE W@L2
     C           A3ATK3    ORNE W@L3
     C                     ITER
     C                     END
     C                     MOVELA3ATK2    @LOC1
     C                     MOVELA3ATK3    @LOC2
     C                     Z-ADDA3LOTO    W7LOTO
     C                     Z-ADDA3KMAX    W7KMAX
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           CKQ,X     WHEQ 'D'
     C           K#PRT     SETLLAAGTL06
     C           *IN95     DOUEQ*ON
     C           K#PRT     READEAAGTL06                  95
     C           *IN95     IFEQ *OFF
     C           O4SKJY    IFEQ 'D'
     C           O4STHZ    ORNE 99999999
     C                     ITER
     C                     ENDIF
     C           O4BAN2    IFNE W@L2
     C           O4BAN3    ORNE W@L3
     C                     ITER
     C                     END
     C                     MOVELO4BAN2    @LOC1
     C                     MOVELO4BAN3    @LOC2
     C                     Z-ADDO4LOTO    W7LOTO
     C                     Z-ADDO4KMAX    W7KMAX
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           CKQ,X     WHEQ 'E'
     C           K#PRT     SETLLAAHTL06
     C           *IN95     DOUEQ*ON
     C           K#PRT     READEAAHTL06                  95
     C           *IN95     IFEQ *OFF
     C           L6SKJY    IFEQ 'D'
     C           L6STHZ    ORNE 99999999
     C                     ITER
     C                     ENDIF
     C           L6ATK2    IFNE W@L2
     C           L6ATK3    ORNE W@L3
     C                     ITER
     C                     END
     C                     MOVELL6ATK2    @LOC1
     C                     MOVELL6ATK3    @LOC2
     C                     Z-ADDL6LOTO    W7LOTO
     C                     Z-ADDL6KMAX    W7KMAX
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           CKQ,X     WHEQ '0'
     C           K#PRT     SETLLAAPTL01
     C           *IN95     DOUEQ*ON
     C           K#PRT     READEAAPTL01                  95
     C           *IN95     IFEQ *OFF
     C           L5SKJY    IFEQ 'D'
     C           L5STHZ    ORNE 99999999
     C                     ITER
     C                     ENDIF
     C           L5TKR2    IFNE W@L2
     C           L5TKR3    ORNE W@L3
     C                     ITER
     C                     END
     C                     MOVELL5TKR2    @LOC1
     C                     MOVELL5TKR3    @LOC2
     C                     Z-ADDL5HKSU    W7LOTO
     C                     Z-ADDL5KMAX    W7KMAX
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           CKQ,X     WHEQ 'B'
     C           K#PRT     SETLLADHTL05
     C           *IN95     DOUEQ*ON
     C           K#PRT     READEADHTL05                  95
     C           *IN95     IFEQ *OFF
     C           J6SKJY    IFEQ 'D'
     C           J6STHZ    ORNE 99999999
     C                     ITER
     C                     ENDIF
     C           J6ATK2    IFNE W@L2
     C           J6ATK3    ORNE W@L3
     C                     ITER
     C                     END
     C                     MOVELJ6ATK2    @LOC1
     C                     MOVELJ6ATK3    @LOC2
     C                     Z-ADDJ6LOTO    W7LOTO
     C                     Z-ADDJ6KMAX    W7KMAX
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           CKQ,X     WHEQ 'A'
     C           K#PRT     SETLLABHTL06
     C           *IN95     DOUEQ*ON
     C           K#PRT     READEABHTL06                  95
     C           *IN95     IFEQ *OFF
     C           M6SKJY    IFEQ 'D'
     C           M6STHZ    ORNE 99999999
     C                     ITER
     C                     ENDIF
     C           M6JBN2    IFNE W@L2
     C           M6JBN3    ORNE W@L3
     C                     ITER
     C                     END
     C                     MOVELM6JBN2    @LOC1
     C                     MOVELM6JBN3    @LOC2
     C                     Z-ADDM6LOTK    W7LOTO
     C                     Z-ADDM6KMAX    W7KMAX
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSL
     C*
     C                     MOVEL@LOCT     W7BLOC
     C                     MOVELCKQ,X     W7KNID
     C*
     C                     Z-ADD1         Y       20
     C           'HD '     LOKUPPRC,Y                    88
     C   88                MOVELMCN,Y     W7HDNF
     C           W7HDNF    IFEQ *BLANK
     C                     Z-ADD1         Y       20
     C           'BM '     LOKUPPRC,Y                    88
     C   88                MOVELMCN,Y     W7HDNF
     C                     END
     C           W7HDNF    IFEQ *BLANK
     C                     Z-ADD1         Y       20
     C           'NF '     LOKUPPRC,Y                    88
     C   88                MOVELMCN,Y     W7HDNF
     C                     END
     C                     Z-ADD1         Y       20
     C           'RL '     LOKUPPRC,Y                    88
     C   88                MOVELMCN,Y     W7RLTP
     C           W7RLTP    IFEQ *BLANK
     C                     Z-ADD1         Y       20
     C           'TP '     LOKUPPRC,Y                    88
     C   88                MOVELMCN,Y     W7RLTP
     C                     END
     C*
     C                     WRITEABBWP7H1
     C*
     C                     ENDDO
     C*
     C                     ENDSR
