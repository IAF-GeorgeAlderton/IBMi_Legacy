     C                     MOVELSKOT,X    W1KO
     C                     MOVELSTKR,X    W1NB
     C                     MOVEL*BLANK    W1KB
     C           W1NB      IFNE '------'
     C           W1NB      ANDNE'++++++'
     C                     MOVEL*BLANK    WKATOK  3
     C                     Z-ADD0         WKKMAX  50
     C                     MOVELSSHR,X    WKKCD1  1
     C                     EXSR #SB400
     C                     ENDIF
     C                     MOVELSKOT,X    W1ATOK
     C                     Z-ADDWKKMAX    W1KMAX
     C                     Z-ADDWKLOT     W1LOT
     C                     MOVELSSHR,X    W1TY
     C                     Z-ADDSU,X      W1SU
     C                     Z-ADDX         W1KSEQ
      *前工程
