     C                     READ ABMWPF01                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           KEY       KLIST
     C                     KFLD           W0SHN1
     C                     KFLD           W0SHN2
     C                     KFLD           W0SHN3
     C                     CLEARSKOT
     C                     CLEARSBMN
     C                     CLEARSTKR
     C                     CLEARSSHR
     C           KEY       CHAINAKEPL011             23
     C           *IN23     IFEQ '0'
     C           M3SKJY    ANDEQ'D'
     C           M3SKHZ    ANDLE*DATE
     C                     SETON                     23
     C                     ENDIF
     C           *IN23     IFEQ '0'
     C                     Z-ADD1         X       30
     C           X         DOWLE15
     C                     MOVEANKOT,X    SKOT,X
     C                     MOVEANBMN,X    SBMN,X
     C                     MOVEANTKR,X    STKR,X
     C                     MOVEANSHR,X    SSHR,X
     C                     MOVELKHZ,X     WDATE   80
     C           WDATE     IFGT *DATE
     C                     MOVEAOKOT,X    SKOT,X
     C                     MOVEAOBMN,X    SBMN,X
     C                     MOVEAOTKR,X    STKR,X
     C                     MOVEAOSHR,X    SSHR,X
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
     C                     ENDIF
      *
     C                     Z-ADD0         IDX1    30
     C                     Z-ADD15        X       30
     C                     MOVEL'0'       GET     1
     C           X         DOWGE1
     C                     MOVEL'1'       DT      1
     C           SKOT,X    IFEQ 'KN '
     C           SBMN,X    ANDEQ8990
     C                     MOVEL'0'       DT
     C                     ENDIF
     C           STKR,X    IFNE *BLANK
     C           DT        ANDEQ'1'
     C                     EXSR #SB211
     C                     ENDIF
     C                     SUB  1         X
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * UPDATE                                             *
      *----------------------------------------------------*
     CSR         #SB211    BEGSR
      *
     C                     Z-ADD0         WKLOT   30
     C                     CLEARABMWPF11
