     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C* 初期ﾈｮmb
     C*===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     EXCPTHD
     C*  SFLCLR
     C                     SETON                     82
     C                     WRITESFCTL1
     C                     SETOF                     82
     C                     Z-ADD0         RRN     40
     C                     Z-ADD0         ENDRRN  40
     C                     MOVE *BLANK    @@UMU   1        データ有無
     C*
     C*          1         SETLLRGAPL11
     C*-------------------------
S1   C                     DO   *HIVAL
     C                     READ RGAPL11                  90
     C   90                LEAVE
 S2  C           J8SKJY    IFEQ 'D'
     C                     ITER
 E2  C                     ENDIF
     C*
     C                     MOVELJ8PROF    @USRID
     C                     MOVELJ8NAME    @USRNM
     C                     Z-ADDJ8KOHZ    @KOHZ
     C                     Z-ADDJ8KOTM    @KOTM
      *
     C                     MOVEL*BLANK    WUSRID 10
     C                     MOVEL*BLANK    WUSRNM 15
     C                     MOVELJ8PROF    WUSRID
     C                     MOVELJ8NAME    WUSRNM
     C                     EXCPTDT
      *
     C                     ADD  1         RRN
     C                     WRITESFREC1
E1   C                     ENDDO
     C*-------------------------
     C           RRN       IFEQ 0
     C                     MOVE '#END    '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     Z-ADD1         DSPRRN
     C                     ENDIF
     C                     ENDSR
