     H            Y.
     F** AB#RF7F4 ****************************************************
     F*                                                              *
     F*  TCH              FORD ORDER ACCUMULATE UPDATE               *
%0001F*  T.SAKAKI 01/07/16 ADD LOGIC FOR BEGINNING OF A YEAR         *
JW1  F*  JW     2022/02/24 CHK YEAR FOR YTD QTY                      *
JW2  F*  JW     2023/04/17 CHK DELETED DATA                          *
JW3  F*  JW     2023/10/10 ADD DELIVERY CODE TO ABF2P01(AFPKCD)      *
     F****************************************************************
     FABFHP01 IF  E                    DISK
     FABF2L04 UF  E           K        DISK                      A
TCHK1FABF2L05 IF  E           K        DISK
TCHK1F            ABF2P011                          KRENAMEABF2L5
     FABFIP01 O   E                    DISK
TCHK1FABFJP01 O   E                    DISK
     F******************************************************
JW1  I            DS
 .   I                                        1   60AHLSDT
 .   I                                        1   20AHLSYY
 .   I                                        3   40AHLSMM
JW1  I                                        5   60AHLSDD
JW1  I            DS
 .   I                                        1   60AFLSDT
 .   I                                        1   20AFLSYY
 .   I                                        3   40AFLSMM
JW1  I                                        5   60AFLSDD
     I            DS
     I                                        1  140W#TIME
     I                                        1   60W##TIM
     I                                        7  140W##DAT
     C******************************************************
     C           *LIKE     DEFN AFPART    W#PART
     C           *LIKE     DEFN AFSTID    W#STID
     C           *LIKE     DEFN AFDOCK    W#DOCK
     C                     MOVEL*BLANK    W#PART
     C                     MOVEL*BLANK    W#STID
     C                     MOVEL*BLANK    W#DOCK
     C*
     C                     DO   *HIVAL
     C                     READ ABFHP011                 99
     C   99                LEAVE
     C*
     C           AHPART    IFNE W#PART
     C           AHSTID    ORNE W#STID
     C           AHDOCK    ORNE W#DOCK
     C*
     C           K#2PL4    KLIST
     C                     KFLD           AHPART
     C                     KFLD           AHSTID
     C           K#2PL4    SETLLABF2P011
     C*
     C                     DO   *HIVAL
     C*
     C           K#2PL4    READEABF2P011                 98
     C   98                LEAVE
      * IGNORE
JW2  C           AFTPCD    IFEQ 'FORDX'
"    C                     ITER
"    C                     ENDIF
     C*
     C           AHDOCK    IFNE AFDOCK
     C                     EXSR @DLOUT
     C                     END
     C*
     C                     ENDDO
     C*
     C                     MOVELAHPART    W#PART
     C                     MOVELAHSTID    W#STID
     C                     MOVELAHDOCK    W#DOCK
     C*
     C                     END
     C*
TCHK1C           K#2PL5    KLIST
TCHK1C                     KFLD           AHSTID
TCHK1C                     KFLD           AHDOCK
TCHK1C                     KFLD           AHPART
TCHK1C           K#2PL5    SETLLABF2L05
TCHK1C*
TCHK1C                     MOVEL*OFF      W#SERR  1
TCHK1C                     DO
TCHK1C           K#2PL5    READEABF2L05                  97
TCHK1C   97                LEAVE
      * IGNORE
JW2  C           AFTPCD    IFEQ 'FORDX'
"    C                     ITER
"    C                     ENDIF
      * CHECK DATE
TCHK1C           AHLSDT    IFLT AFLSDT
TCHK1C**JW1      AHYSQY    ORLT AFYSQY
TCHK1C                     MOVEL*ON       W#SERR
TCHK1C                     END
      * CHECK QTY
JW1  C           AHLSYY    IFEQ AFLSYY
 .   C           AHYSQY    ANDLTAFYSQY
 .   C                     MOVEL*ON       W#SERR
JW1  C                     ENDIF
      *
     C** %0001  LOGIC FOR BEGINNING OF A YEAR
     C           AHLSDT    IFEQ 0
     C           AHYSQY    OREQ 0
     C                     MOVEL*OFF      W#SERR
     C                     END
TCHK1C                     LEAVE
TCHK1C                     ENDDO
TCHK1C*
TCHK1C           W#SERR    IFEQ *OFF
     C                     EXSR @NWOUT
TCHK1C                     ELSE
TCHK1C                     EXSR @SEOUT
TCHK1C                     END
     C*
     C                     ENDDO
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
     F******************************************************
     F* DELETE FROM ABF2P01 & MAKE COPY TO ABFIP01         *
     F******************************************************
     C           @DLOUT    BEGSR
     C*
     C                     CLEARABFIP011
     C*
     C                     TIME           W#TIME
     C                     Z-ADDW##DAT    AIDLTD
     C                     Z-ADDW##TIM    AIDLTT
     C                     MOVELAFTPCD    AITPCD
     C                     MOVELAFTSID    AITSID
     C                     MOVELAFSPCD    AISPCD
     C                     MOVELAFREF#    AIREF#
     C                     MOVELAFPOR#    AIPOR#
     C                     Z-ADDAFSIDT    AISIDT
     C                     Z-ADDAFHSDT    AIHSDT
     C                     Z-ADDAFHEDT    AIHEDT
     C                     MOVELAFSTIQ    AISTIQ
     C                     MOVELAFSTID    AISTID
     C                     MOVELAFIDCD    AIIDCD
     C                     MOVELAFPART    AIPART
     C                     MOVELAFDOCK    AIDOCK
     C                     MOVELAFALFL    AIALFL
     C                     MOVELAFRALF    AIRALF
     C                     MOVELAFUBM1    AIUBM1
     C                     MOVELAFPKCD    AIPKCD
     C                     Z-ADDAFQTY1    AIQTY1
     C                     Z-ADDAFWEIT    AIWEIT
     C                     MOVELAFUBM2    AIUBM2
     C                     MOVELAFEQMT    AIEQMT
     C                     Z-ADDAFQTY2    AIQTY2
     C                     Z-ADDAFDLDT    AIDLDT
     C                     Z-ADDAFTIME    AITIME
     C                     Z-ADDAFDATE    AIDATE
     C                     MOVELAFIPAR    AIIPAR
     C                     Z-ADDAFLRDT    AILRDT
     C                     Z-ADDAFLRQY    AILRQY
     C                     Z-ADDAFLSDT    AILSDT
     C                     Z-ADDAFLSQY    AILSQY
     C                     Z-ADDAFYRDT    AIYRDT
     C                     Z-ADDAFYRQY    AIYRQY
     C                     Z-ADDAFYSDT    AIYSDT
     C                     Z-ADDAFYSQY    AIYSQY
     C                     MOVELAFEXCD    AIEXCD
     C                     MOVELAFRDCD    AIRDCD
     C*
     C                     WRITEABFIP011
     C*
     C                     DELETABF2P011
     C*
     C                     ENDSR
     F******************************************************
     F* MAKE ORDER DATA TO ABF2P01                         *
     F******************************************************
     C           @NWOUT    BEGSR
     C*
     C                     CLEARABF2P011
     C*
TCHK1C                     EXSR @EDT#1
     C*
     C                     WRITEABF2P011
     C*
     C                     ENDSR
TCHK1F******************************************************
TCHK1F* MAKE SEQ DOWN ERROR TO ABFJP01                     *
TCHK1F******************************************************
TCHK1C           @SEOUT    BEGSR
TCHK1C*
TCHK1C                     Z-ADDAFLSDT    SVLSD2  60
TCHK1C                     Z-ADDAFYSQY    SVYSQ2 100
TCHK1C*
TCHK1C                     CLEARABFJP011
TCHK1C*
TCHK1C                     EXSR @EDT#1
TCHK1C*
TCHK1C                     WRITEABFJP011
TCHK1C*
TCHK1C                     ENDSR
TCHK1F******************************************************
TCHK1F* EDIT ORDER DATA TO ABF2P01/ABFJP01                 *
TCHK1F******************************************************
TCHK1C           @EDT#1    BEGSR
TCHK1C*
TCHK1C                     MOVELAHTPCD    AFTPCD
TCHK1C                     MOVELAHTSID    AFTSID
TCHK1C                     MOVELAHSPCD    AFSPCD
TCHK1C                     MOVELAHREF#    AFREF#
TCHK1C                     MOVELAHPOR#    AFPOR#
TCHK1C                     Z-ADDAHSIDT    AFSIDT
TCHK1C                     Z-ADDAHHSDT    AFHSDT
TCHK1C                     Z-ADDAHHEDT    AFHEDT
TCHK1C                     MOVELAHSTIQ    AFSTIQ
TCHK1C                     MOVELAHSTID    AFSTID
TCHK1C                     MOVELAHIDCD    AFIDCD
TCHK1C                     MOVELAHPART    AFPART
TCHK1C                     MOVELAHDOCK    AFDOCK
TCHK1C                     MOVELAHALFL    AFALFL
TCHK1C                     MOVELAHRALF    AFRALF
TCHK1C                     MOVELAHUBM1    AFUBM1
TCHK1C**JW3                MOVELAHPKCD    AFPKCD
TCHK1C                     Z-ADDAHQTY1    AFQTY1
TCHK1C                     Z-ADDAHWEIT    AFWEIT
TCHK1C                     MOVELAHUBM2    AFUBM2
TCHK1C                     MOVELAHEQMT    AFEQMT
TCHK1C                     Z-ADDAHQTY2    AFQTY2
TCHK1C                     Z-ADDAHDLDT    AFDLDT
TCHK1C                     Z-ADDAHTIME    AFTIME
TCHK1C                     Z-ADDAHDATE    AFDATE
TCHK1C                     MOVELAHIPAR    AFIPAR
TCHK1C                     Z-ADDAHLRDT    AFLRDT
TCHK1C                     Z-ADDAHLRQY    AFLRQY
TCHK1C                     Z-ADDAHLSDT    AFLSDT
TCHK1C                     Z-ADDAHLSQY    AFLSQY
TCHK1C                     Z-ADDAHYRDT    AFYRDT
TCHK1C                     Z-ADDAHYRQY    AFYRQY
TCHK1C                     Z-ADDAHYSDT    AFYSDT
TCHK1C                     Z-ADDAHYSQY    AFYSQY
TCHK1C                     MOVELAHEXCD    AFEXCD
TCHK1C                     MOVELAHRDCD    AFRDCD
TCHK1C                     MOVELAHICCD    AFICCD
TCHK1C                     MOVELAHUSER    AFUSER
TCHK1C*
TCHK1C                     Z-ADDSVLSD2    AFLSD2
TCHK1C                     Z-ADDSVYSQ2    AFYSQ2
      * GET DELIVERY CODE
JW3  C           AHPKCD    IFEQ *BLANK
 .   C                     MOVELAHSTID    $PLNT
 .   C                     MOVELAHDOCK    $DOCK
 .   C                     CALL 'UTLR34A'
 .   C                     PARM           $PLNT   5
 .   C                     PARM           $DOCK   4
 .   C                     PARM           $NONY   4
 .   C                     PARM           $RTN    1
 .   C           $RTN      IFEQ ' '
 .   C                     MOVEL$NONY     AFPKCD    P
 .   C                     ENDIF
JW3  C                     ENDIF
      *
TCHK1C                     ENDSR
