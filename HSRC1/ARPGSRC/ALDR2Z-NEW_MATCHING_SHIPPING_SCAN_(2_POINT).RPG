      *----------------------------------------------------*
JW4   * CHECK CHARTER STEEL EXIST IN ALRPP20
 .    *----------------------------------------------------*
 .   C           #CHRTC    BEGSR
 .    * GET SUPP CODE
     C                     MOVE 'N'       OKFLG   1
     C                     MOVE 'N'       CHRFLG  1
      *
     C           BARQR     IFEQ 'B01'
     C           BARQR     OREQ 'C01'
%0003C           BARQR     OREQ 'F01'
     C                     MOVELQRZT      $ZETI
     C                     MOVE 'Q'       BRFLG   1
     C                     ELSE
     C                     MOVELIDNO7     $ZETI
     C                     MOVE 'A'       BRFLG
     C                     ENDIF
      *
     C                     MOVE *BLANK    $SHIN
     C                     CALL 'UTLR21C'
     C                     PARM           $ZETI   4
     C                     PARM           $SHIN  12
     C                     PARM           $SUPP   4
     C                     PARM           $RTNX   1
      *
     C           $SUPP     IFNE '4540'
     C                     MOVE 'N'       CHRFLG
     C                     GOTO XCHART
     C                     ENDIF
      *
      * if the supplier is charter steel,
      * check for machine S90 in process master for this part#...
      * if not S90 turn off check flag...
     C           $SUPP     IFEQ '4540'
     C                     CALL 'UTLR21X'
     C                     PARM           $ZETI
     C                     PARM           $SHIN
     C                     PARM           $RTNYN  1
     C           $RTNYN    IFEQ 'N'
     C                     MOVE 'N'       CHRFLG
     C                     GOTO XCHART
     C                     ENDIF
      *
     C                     ENDIF
      * IF CHARTER STEEL..
     C                     MOVE 'Y'       CHRFLG
      *
     C           BRFLG     IFEQ 'A'
     C                     MOVELAKAN      LTR20  20
      **JW5      LTR20     SETLLALRPL21
JW5  C           LTR20     SETLLALRPL21A
     C                     ELSE
      **JW5      @@BAR1    SETLLALRPL22
JW5  C           @@BAR1    SETLLALRPL22A
     C                     ENDIF
      *
     C                     DO   *HIVAL
      *
     C           BRFLG     IFEQ 'A'
      **JW5      LTR20     READEALRPL21             N    98
JW5  C           LTR20     READEALRPL21A            N    98
     C                     ELSE
      **JW5      @@BAR1    READEALRPL22             N    98
JW5  C           @@BAR1    READEALRPL22A            N    98
     C                     ENDIF
      *
     C   98                LEAVE
      *
     C           L2SKJY    IFEQ ' '
     C           L2OKNG    ANDEQ'OK'
     C           L2ODAT    ANDNE0
     C                     MOVE '1'       OKFLG
     C                     LEAVE
 .   C                     ENDIF
      *
     C           L2SKJY    IFEQ ' '
     C           L2OKNG    ANDEQ'OK'
     C           L2ODAT    ANDEQ0
     C                     EXSR #CHKDT
     C           #DAYS     IFLE 40
     C                     MOVE 'Y'       OKFLG
     C                     LEAVE
 .   C                     ENDIF
 .   C                     ENDIF
      *
 .   C                     ENDDO
 .    *
JW4  C           XCHART    ENDSR
      *----------------------------------------------------*
