      *----------------------------------------------------*
      * PASSWORD                                           *
      *----------------------------------------------------*
     CSR         #AM#31    BEGSR
      *
     C                     MOVE WORKER    WWWKCD  60
     C           WWWKCD    CHAINAM#PP311             49
     C           *IN49     IFEQ '0'
     C           R3SKJY    ANDEQ'D'
     C           R3SKHZ    ANDLE*DATE
     C                     SETON                     49
     C                     ENDIF
      *
     C                     MOVEL*BLANK    PASFLG  1
     C           *IN49     IFEQ '0'
     C                     MOVELR3PGM1    PASFLG
     C                     ENDIF
      *
     CSR         EAM#31    ENDSR
      *
      *----------------------------------------------------*
      * Update NZUPL01 with Shipment Date and Time         *
      *----------------------------------------------------*
      *
     C           UPDSHP    BEGSR
      *
      * update NZUPL01
      *
     C           N2KEY     KLIST
     C                     KFLD           A3ZETI
     C                     KFLD           A3TEHI
     C                     KFLD           A3PAGE
     C*
     C           N2KEY     SETGTNZUPL011
     C           N2KEY     REDPENZUPL011                 51
      *
      * if id/lot/page num is found, update record and leave.
     C           *IN51     DOWEQ*OFF
     C           N2SKJY    IFEQ *BLANK
     C           N2DEHZ    ANDEQ*ZERO
     C                     Z-ADDWSSDAT    N2KOHZ
     C                     Z-ADDWSSTM6    N2KOTI
     C                     MOVELWUSRID    N2KOME
     C                     MOVEL#PGM      N2KOPG    P
     C                     Z-ADDWSSDAT    N2DEHZ
     C                     Z-ADDWSSTM6    N2DETI
     C                     UPDATNZUPL011
     C                     LEAVE
     C                     ENDIF
     C           N2KEY     REDPENZUPL011                 51
     C                     ENDDO
      *
     C                     ENDSR
      *
      *----------------------------------------------------*
      * update NZUPL11 with passthru kanban ship info
      *----------------------------------------------------*
     C           UPDSHI    BEGSR
     C*
     C           N3KEY     KLIST
     C                     KFLD           A1ZETI
     C                     KFLD           A1ORDR
     C                     KFLD           LOTN    4
      *
     C                     MOVE A1LOTN    LOTN
     C           N3KEY     CHAINNZUPL111             51
      *
      * if id/ord#/lot# is found update record, else add record.
     C           *IN51     IFEQ *OFF
      *
     C                     MOVELWSSDAT    N3KOHZ
     C                     MOVELWSSTM6    N3KOTI
     C                     MOVELWORKER    N3KOME
     C                     MOVEL#PGM      N3KOPG    P
     C                     MOVE '0'       N3ONOF
     C                     MOVELWSSDAT    N3DEHZ
     C                     MOVELWSSTM6    N3DETI
      *
     C                     MOVELA1SHN1    N3SHN1
     C                     MOVELA1SHN2    N3SHN2
     C                     MOVELA1SHN3    N3SHN3
     C                     MOVELA1TKR1    N3JTK1
     C                     MOVELA1TKR2    N3JTK2
     C                     MOVELA1TKR3    N3JTK3
     C                     MOVELA1TKR4    N3JTK4
      *
     C                     MOVE BARKBN    N3KANR
     C                     MOVELA1ZETI    N3SZET
     C                     MOVELA1ORDR    N3SORD
     C                     MOVE A1SEHI    N3STYP
     C                     MOVELA1LOTN    N3SLOT
     C                     MOVELCHKD7     N3CHKD
      *
     C                     EXSR GETINF
      *
     C                     UPDATNZUPL111
      *
     C                     ELSE
      *
     C                     CLEARNZUPL111
     C                     MOVELA1ZETI    N3ZETI
     C                     MOVELA1ORDR    N3ORDN
     C                     MOVELLOTN      N3LOTN
      *
     C                     MOVELWSSDAT    N3KOHZ
     C                     MOVELWSSTM6    N3KOTI
     C                     MOVELWORKER    N3KOME
     C                     MOVEL#PGM      N3KOPG    P
     C                     MOVE '0'       N3ONOF
     C                     MOVELWSSDAT    N3DEHZ
     C                     MOVELWSSTM6    N3DETI
      *
     C                     MOVELA1SHN1    N3SHN1
     C                     MOVELA1SHN2    N3SHN2
     C                     MOVELA1SHN3    N3SHN3
     C                     MOVELA1TKR1    N3JTK1
     C                     MOVELA1TKR2    N3JTK2
     C                     MOVELA1TKR3    N3JTK3
     C                     MOVELA1TKR4    N3JTK4
      *
     C                     MOVE BARKBN    N3KANR
     C                     MOVELA1ZETI    N3SZET
     C                     MOVELA1ORDR    N3SORD
     C                     MOVE A1SEHI    N3STYP
     C                     MOVELA1LOTN    N3SLOT
     C                     MOVELCHKD7     N3CHKD
      *
     C                     EXSR GETINF
      *
     C                     WRITENZUPL111
     C                     ENDIF
      *
     C                     ENDSR
      *
      *----------------------------------------------------*
      * get order info from invoice management
      *----------------------------------------------------*
     C           GETINF    BEGSR
     C*
     C           GDKEY     KLIST
     C                     KFLD           A1SHN1
     C                     KFLD           A1SHN2
     C                     KFLD           A1SHN3
     C*
     C           GDKEY     SETGTGDGPP251
     C           GDKEY     REDPEGDGPP251                 51
      *
      *    read until order number is found.
     C           *IN51     DOWEQ*OFF
      *
     C                     MOVE IEODER    IEORCH  6
     C           IEORCH    IFEQ A1ORDR
     C                     Z-ADDIESYOS    N3KSYU           BOX QTY
     C                     MOVE 'C'       N3KSTI           BOX TYPE
     C                     MOVELIEYMD     N3DEJD           DEPART YMD
     C                     LEAVE
     C                     ENDIF
      *
     C           GDKEY     REDPEGDGPP251                 51
     C                     ENDDO
      *
     C                     ENDSR
      *
      **************************************************************************
      *  if first process is KN then write to ASJ order file.
      *
     C           #ASJ#2    BEGSR
      *
      * get part number process information...
     C           K#KEY1    CHAINAAMPL11              51
     C           *IN51     IFEQ *OFF
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLEWSSDAT
     C                     GOTO @ENDA2
     C                     ENDIF
      *
      * if first process is KN,  then an order entry needs to be written to ASJ
     C           *IN51     IFEQ *OFF
      *
     C           WSSDAT    IFGE CKHZ
     C           CKKO01    ANDEQ'KN'
     C           WSSDAT    ORLT CKHZ
     C           CKQK01    ANDEQ'KN'
      *
     C                     CLEARGDGPP051
     C                     TIME           WSDT
     C                     Z-ADDWSSYYY    IAKOYY
     C                     Z-ADDWSSMMM    IAKOMM
     C                     Z-ADDWSSDDD    IAKODD
     C                     MOVELWORKER    IAKOME
     C                     MOVE 'T'       IAKOME
     C                     Z-ADDWSSHHH    IAKOHH                  HOUR
     C                     Z-ADDWSSNNN    IAKOSS                  MINUTE
      *
     C                     MOVE A3ZETI    IAZETI
     C                     MOVE A3SHN1    IAHIN1
     C                     MOVE A3SHN2    IAHIN2
     C                     MOVE A3SHN3    IAHIN3
     C                     Z-ADDA3USYS    IASYOS
     C                     ADD  1         IAMAIS
     C                     Z-ADDWSSYYY    IAHAYY
     C                     Z-ADDWSSMMM    IAHAMM
     C                     Z-ADDWSSDDD    IAHADD
      *
      * get ASJ P/T order info...
%3    *
 |   C           BARQR     IFEQ 'C01'
%0003C           BARQR     OREQ 'F01'
 |   C                     MOVEL$$APBC    PTABAR
 |   C                     ELSE
 |   C                     MOVELAKAN      PTABAR
%3   C                     ENDIF
      *
     C**JW3      PTABAR    CHAINALRPP051             51
JW3   * GET LATEST KANBAN
"    C           PTABAR    SETGTALRPL05
"    C           PTABAR    REDPEALRPL05                  51
      *
      * if APICS is found, get P/T ord#, product code, lot#
     C           *IN51     IFEQ *OFF
JW3  C                     MOVE 'Y'       PTFLG   1
     C                     MOVE PTODER    IAODER
     C                     MOVE PTPRCD    IASEIH
     C                     MOVE PTLOTN    IARENB
     C                     ELSE
      *
JW3  C                     MOVE 'N'       PTFLG
     C                     MOVE *BLANKS   IAODER
     C                     MOVE '0'       IASEIH
     C                     MOVE *BLANKS   IARENB
      *
      * APICS not scanned, so write info to error log....
     C                     MOVE '30'      A5ERID
     C                     MOVE '03'      A5ERPS
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    A5KSDT
     C                     Z-ADDWSSTM6    A5KSTM
     C                     MOVELWORKER    A5OPER
     C           @D        IFEQ '1'
     C                     MOVELWWBRCD    A5SERL
     C                     MOVEL*BLANK    A52DBC
     C                     ELSE
     C                     MOVEL*BLANK    A5SERL
     C                     MOVELW2D       A52DBC
     C                     ENDIF
     C                     MOVEL@9        A5FIL1
     C                     MOVELLAR01     A5FIL2
     C                     MOVELBARKAX    A5FIL3
      *
     C                     WRITEALDPP501
      *
     C                     ENDIF
      *
     C                     WRITEGDGPP051
JW3   * OUT GDGPP06
     C                     MOVEL'2'       IAFLG1
     C                     EXSR #PP06
      *
     C                     EXSR #IICSD
      *
     C                     ENDIF
      *
     C                     ENDIF
      *
     C           @ENDA2    ENDSR
      **************************************************************************
JW3   *  OUTPUT GDGPP06
      **************************************************************************
JW3  C           #PP06     BEGSR
      *
     C                     MOVELPTFLG     IAPFLG
     C                     MOVELPTABAR    IAABAR
     C           PTFLG     IFEQ 'Y'
     C                     MOVELPTODER    IAPDER
     C                     MOVELPTLOTN    IAPOTN
     C                     MOVELPTPBAR    IAPBAR
     C                     MOVELPTTBN1    IAPBN1
     C                     MOVELPTTBN2    IAPBN2
     C                     MOVELPTTBN3    IAPBN3
     C                     MOVELPTTBN4    IAPBN4
     C                     ELSE
     C                     MOVE *BLANK    IAPDER
     C                     MOVE *BLANK    IAPOTN
     C                     MOVE *BLANK    IAABAR
     C                     MOVE *BLANK    IAPBN1
     C                     MOVE *BLANK    IAPBN2
     C                     MOVE *BLANK    IAPBN3
     C                     MOVE *BLANK    IAPBN4
     C                     ENDIF
      *
     C                     Z-ADD0         IAODDT
     C                     Z-ADD0         IAODTM
     C                     MOVE *BLANK    IAFLG2
      *
     C                     Z-ADDTODAY     IACRDT
     C                     Z-ADDNOW       IACRTM
     C                     MOVEL#USER     IACRME
     C                     MOVEL#PGM      IACRPG    P
      *
     C                     WRITEGDGPP061
      *
JW3  C                     ENDSR
      **************************************************************************
      *  get current date/time stamp of last scan.
      *
     C           GETTM     BEGSR
      *
     C                     MOVEL'*CURRENT'INPUTF
     C                     MOVEL'*YMD'    OUTPUT
      *
     C                     CALL 'QWCCVTDT'
     C                     PARM           INPUTF 10
     C                     PARM           INPUTV  1
     C                     PARM           OUTPUT 10
     C                     PARM           @@TIME 16
     C                     PARM           XERRR  15
      *
     C                     ENDSR
      **************************************************************************
TCHL5OAU#NP11 E                UP
TCHL5O                         AHZMM      2
TCHL5O                         ARECD      9
TCHL5O        EADD             WT
TCHL5O                         AHZMM      2
TCHL5O                         ARECD      9
