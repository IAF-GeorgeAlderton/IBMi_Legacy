     C                     Z-ADDHQTY      A1USYS           USER UNIT QTY
     C                     MOVE DELIVL    A1NONY           DELIVERY POINY
     C                     MOVE FACTRY    A1NKOJ                    FACTORY
     C                     MOVE DOCK      A1NUKE                    RECV
     C                     MOVE *BLANK    A1TOPX           TOPIX CODE
     C                     MOVE *BLANK    A1SALE           EFU/KANBAN
     C                     MOVE *BLANK    A1UPAG           BOTTOM KANBAN ISSU#
     C                     MOVE @@SERL    A1SERL
     C                     WRITEALDPP201
     C*
     C                     EXSR #ASJ
     C                     EXSR UPDSHI
     C*
     C                     ENDSR
     C**************************************************************************
     C* QR                 @WRT(A-PICS,KOTENAI KANBAN FILE)
     C**************************************************************************
     C           @WRT3     BEGSR
      *
     C           BARQR     IFEQ 'C01'
%0003C           BARQR     OREQ 'F01'
     C                     MOVELQRZETI    K@ZETI
     C                     ELSE
     C                     MOVELIDNO7     K@ZETI
     C                     ENDIF
     C           K#A7      CHAINFCEPL071             98
     C*
     C                     CLEARALDPP301
     C                     TIME           WSDT
     C                     Z-ADDWSSYYY    A3KSYY
     C                     Z-ADDWSSMMM    A3KSMM                  MONTH
     C                     Z-ADDWSSDDD    A3KSDD                  DAY
     C                     Z-ADDWSSHHH    A3KSJI                  HOUR
     C                     Z-ADDWSSNNN    A3KSPN                  MINUTE
TCHKGC                     MOVEL#PGM      A3UPGM    P      UPDATE PGM
     C                     MOVE WORKER    A3OPER           WORKER
     C                     MOVELWUSRID    A3OPNM           WORKER NAME
%3    *
 |   C           BARQR     IFEQ 'C01'
%0003C           BARQR     OREQ 'F01'
 |   C                     MOVELAKAN      A3APQR           QR
 |   C                     MOVEL$$APBC    A3APBC
 |   C                     ELSE
 |   C                     MOVE IAPICS    WAPICS           A-PICS KANBAN
 |   C                     MOVELW3CHKD    A3CHKD           CHECK DIGIT
 |   C                     ENDIF
%3    *
     C                     MOVE A7BHB1    A3SHN1           INTERNAL PART
     C                     MOVE A7BHB2    A3SHN2           INTERNAL PART
     C                     MOVE A7BHB3    A3SHN3           INTERNAL PART
TCHK8C*                    Z-ADDSYY       A3SYYY
TCHK8C*                    Z-ADDSMM       A3SYMM
TCHK8C*                    Z-ADDSDD       A3SYDD
TCHK8C                     Z-ADDWSSYYY    A3SYYY
TCHK8C                     Z-ADDWSSMMM    A3SYMM
TCHK8C                     Z-ADDWSSDDD    A3SYDD
     C                     Z-ADDWSSHHH    A3SYJI           BIN
     C                     Z-ADDWSSNNN    A3SYFN
     C* FINISHED STORAGE(PART MASTER LOCATION)
     C           WSDATE    IFGE W7DATE
     C                     MOVE A7STRK    A3TKR1           NEW
     C                     MOVE A7STRT    A3TKR2
     C                     MOVE A7STRR    A3TKR3
     C                     MOVE A7STRD    A3TKR4
     C*
     C                     ELSE
     C                     MOVE A7STRK    A3TKR1           OLD
     C                     MOVE A7STRT    A3TKR2
     C                     MOVE A7STRR    A3TKR3
     C                     MOVE A7STRD    A3TKR4
     C                     END
     C*
     C                     MOVE *BLANK    A3MHN1           USER PART
     C                     MOVE *BLANK    A3MHN2
     C                     MOVE *BLANK    A3MHN3
     C                     MOVE *BLANK    A3MHN4
     C                     MOVELK@MHN1    A3MHN1           USER PART
     C                     MOVELK@MHN2    A3MHN2
     C                     MOVELK@MHN3    A3MHN3
     C                     MOVELK@MHN4    A3MHN4
     C                     Z-ADDHQTY      A3SSYS           UNIT QTY
     C                     Z-ADDHQTY      A3USYS           USER UNIT QTY
     C                     MOVE DELIVL    A3NONY           DELIVERY POINY
     C                     MOVE FACTRY    A3NKOJ                    FACTORY
     C                     MOVE DOCK      A3NUKE                    RECV
     C                     MOVE *BLANK    A3TOPX           TOPIX CODE
     C                     MOVE *BLANK    A3SALE           EFU/KANBAN
     C                     MOVE @@SERL    A3SERL
     C                     WRITEALDPP301
     C*
%0001C                     MOVEL*OFF      OUTJ    1
     C*
TCHLHC           B2D       SETLLALDPP65
TCHLHC                     DO   *HIVAL
TCHLHC           B2D       READEALDPP65                  99
TCHLHC   99                LEAVE
TCHLHC           AFRDAT    IFEQ *ZERO
TCHLHC                     Z-ADDWSSDAT    AFDATE
TCHLHC                     Z-ADDWSSTM6    AFTIME
TCHLHC                     MOVELWUSRID    AFUSER
TCHLHC                     MOVEL#WSID     AFWSID
TCHLHC                     MOVEL#PGM      AFPGID    P
TCHLHC                     MOVELWORKER    AFTMCD
TCHLHC*
TCHLHC                     MOVELWAPICS    AFAKAN
TCHLHC                     MOVELA3ZETI    AFAZET
TCHLHC                     MOVELA3TEHI    AFALOT
TCHLHC                     MOVELA3PAGE    AFAPAG
TCHLHC                     Z-ADDWSSDAT    AFRDAT
TCHLHC                     Z-ADDWSSTM6    AFRTIM
TCHLHC                     MOVELWORKER    AFRTMC
     C*
TCHLHC                     UPDATALDPP651
%0001C                     MOVEL*ON       OUTJ
     C*
TCHLHC                     ENDIF
TCHLHC                     LEAVE
TCHLHC                     ENDDO
     C*
     C* NO OUTSTANDING (NO SHORTAGE)
%0001C           OUTJ      IFEQ *OFF
     C                     MOVEL'1'       W@SETF
     C* A-PICS2
     C           A3YUKO    IFEQ '2'
%0003C                     EXSR @CA#11
     C*
     C                     ELSE
     C* A-PICS1
TCHL5C                     EXSR @AU#11
     C                     ENDIF
      *
TCHLHC                     ENDIF
      * WRITE PT ORDER
     C                     EXSR #ASJ#2
      * UPDATE NZUPP01
     C                     EXSR UPDSHP
%0003C* UPDATE A-PICS2 STATUS
     C           A3YUKO    IFEQ '2'
     C                     EXSR @CA#01
     C                     ENDIF
      *
     C                     ENDSR
      **************************************************************************
      *  Check to see if Last Process is not at IAF, if not write to Out-
      *       going file.
      *
     C           @CHKLP    BEGSR
      *
      * key list
     C           K@AAMP    KLIST
     C                     KFLD           EKSHN1
     C                     KFLD           EKSHN2
     C                     KFLD           EKSHN3
      *
      * get process codes for part number...
     C           K@AAMP    CHAINAAMPL11              51
     C           *IN51     IFEQ *OFF
      *
     C                     Z-ADD*ZERO     LASTPR  40
     C                     Z-ADD*ZERO     BX      40
      *
      * find last process code for part number...
     C                     DO   15        BX
      *
     C           BMN,BX    IFNE *ZERO
     C                     Z-ADDBMN,BX    LASTPR
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
      * if last process is not done at IAF, then write to retrieval outgoing fil
     C           LASTPR    IFNE *ZERO
     C           LASTPR    ANDNE111
     C                     EXSR @WRTRV
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDSR
      **************************************************************************
      *   Write to Retrieval Out Going File.
      *
     C           @WRTRV    BEGSR
      *
     C                     CLEARALDPP791
      *
     C                     Z-ADDWSSDAT    ARKODT           update date
     C                     Z-ADDWSSTM6    ARKOTM           update time
     C                     MOVELWORKER    ARWKCD           worker code
     C                     MOVELWUSRID    ARWKNM           worker name
     C                     MOVEL#PGM      ARPGID    P      pgm id
     C                     Z-ADDWSSDAT    ARCODT           scan date
     C                     Z-ADDWSSTM6    ARCOTM           scan time
      *
     C                     MOVE EKSHN1    ARSHN1           internal part1
     C                     MOVE EKSHN2    ARSHN2           internal part2
     C                     MOVE EKSHN3    ARSHN3           internal part3
      *
     C                     MOVE EKMHN1    ARMHN1           user part 1
     C                     MOVE EKMHN2    ARMHN2           user part 2
     C                     MOVE EKMHN3    ARMHN3           user part 3
     C                     MOVE EKMHN4    ARMHN4           user part 4
      *
     C                     MOVE EKLOC1    ARTBN1           final loc 1
     C                     MOVE EKLOC2    ARTBN2           final loc 2
     C                     MOVE EKLOC3    ARTBN3           final loc 3
     C                     MOVE EKLOC4    ARTBN4           final loc 4
      *
     C                     Z-ADDLASTPR    ARCKBM           last process code
      *
     C                     Z-ADDEKTOKU    ARTOKU           customer code
     C                     MOVE EKNONY    ARNONY           delivery code
     C                     MOVE EKNKOJ    ARNKOJ           factory code
     C                     MOVE EKNUKE    ARNUKE           dock code
      *
     C                     Z-ADDEKSRYO    ARSRYO           quantity
     C                     MOVE EKODRN    ARORDN           order number
      *
     C                     WRITEALDPP791
      *
     C                     ENDSR
     C**************************************************************************
     C*      WRITE RECORDS IN ORDER FILE TO ASJ
     C**************************************************************************
     C           #ASJ      BEGSR
      *
     C                     CLEARGDGPP051
TCHK8C                     TIME           WSDT
TCHK8C                     Z-ADDWSSYYY    IAKOYY
TCHK8C                     Z-ADDWSSMMM    IAKOMM
TCHK8C                     Z-ADDWSSDDD    IAKODD
     C                     MOVELWORKER    IAKOME
     C                     Z-ADDWSSHHH    IAKOHH                  HOUR
     C                     Z-ADDWSSNNN    IAKOSS                  MINUTE
     C                     MOVE A1ORDR    IAODER
     C                     MOVE A1ZETI    IAZETI
     C                     MOVE A1SEHI    IASEIH
     C                     MOVE A1LOTN    IARENB
     C                     MOVE A1SHN1    IAHIN1
     C                     MOVE A1SHN2    IAHIN2
     C                     MOVE A1SHN3    IAHIN3
     C                     Z-ADDA1SSYS    IASYOS
     C                     ADD  1         IAMAIS
TCHK8C                     Z-ADDWSSYYY    IAHAYY
TCHK8C                     Z-ADDWSSMMM    IAHAMM
TCHK8C                     Z-ADDWSSDDD    IAHADD
     C                     WRITEGDGPP051
JW3   * OUT GDGPP06
     C                     MOVEL'1'       IAFLG1
     C                     EXSR #PP06
      *
TCHK C                     EXSR #IICSD
TCHK  *
     C                     ENDSR
