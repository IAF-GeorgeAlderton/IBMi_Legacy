|    C                     Z-ADDEKNOYY    KQNOYY
|    C                     Z-ADDEKNOMM    KQNOMM
|    C                     Z-ADDEKNODD    KQNODD
|    C                     MOVELEKNOBN    KQNOBB
|    C*
     C*    2D
1    C                     ELSE
|    C                     Z-ADDBATOKU    KQTOKU
|2   C           BATOKU    IFEQ K@NONY
||   C                     MOVELBANKOJ    KQTKOJ
||   C                     MOVELBANUKE    KQTUKE
|2   C                     ENDIF
|    C                     MOVELBANONY    KQNONY
|    C                     MOVELBANKOJ    KQNKOJ
|    C                     MOVELBANUKE    KQNUKE
|    C                     MOVELBASHN1    KQSHN1
|    C                     MOVELBASHN2    KQSHN2
|    C                     MOVELBASHN3    KQSHN3
|2   C           W@SETF    IFEQ '1'
||   C                     MOVELA7BHB1    KQSHN1
||   C                     MOVELA7BHB2    KQSHN2
||   C                     MOVELA7BHB3    KQSHN3
|2   C                     ENDIF
|    C                     MOVELBAMHN1    KQMHN1
|    C                     MOVELBAMHN2    KQMHN2
|    C                     MOVELBAMHN3    KQMHN3
|    C                     MOVE BANOBN    KQKANR
|    C                     MOVELBAODRN    KQNOCR
|    C                     Z-ADDBASYOS    KQSRYO
|    C                     Z-ADDBASYOS    KQSYUY
|    C                     MOVEL'C'       KQTANI
|    C                     MOVEL'C'       KQNSYK
|    C                     Z-ADDBANOYY    KQNOYY
|    C                     Z-ADDBANOMM    KQNOMM
|    C                     Z-ADDBANODD    KQNODD
|    C                     MOVELBANOBN    KQNOBB
|    C                     MOVELBASBAN    KQSEBN
1    C                     ENDIF
     C*
     C                     Z-ADDWSSYYY    KQTHYY
     C                     Z-ADDWSSMMM    KQTHMM
     C                     Z-ADDWSSDDD    KQTHDD
     C*
     C           NKEY      KLIST
     C                     KFLD           KQTOKU
     C                     KFLD           K@NONY
     C                     KFLD           KQNKOJ
     C                     KFLD           KQNUKE
     C           NKEY      CHAINGADPL111             96
1    C           *IN96     IFEQ '0'
|    C           B5SKJY    ANDEQ'D'
|    C           B5SKHZ    ANDLEWSSDAT
|    C                     SETON                     96
1    C                     ENDIF
     C*
1    C           *IN96     IFEQ '1'
|    C                     Z-ADD1         KQCIC1
|    C                     Z-ADD1         KQCIC2
|    C                     Z-ADD1         KQCIC3
|    C                     Z-ADDWSSHHH    KQTHJI
|    C                     Z-ADDWSSNNN    KQTHPN
|    C                     Z-ADDWSSHHH    KQURJI
|    C                     Z-ADDWSSNNN    KQURPN
1    C                     ELSE
|    C                     Z-ADDB5HIZK    KQCIC1
|    C                     Z-ADDB5KAIS    KQCIC2
|    C                     Z-ADDB5NBIN    KQCIC3
|    C                     Z-ADDB51SJI    KQTHJI
|    C                     Z-ADDB51SFN    KQTHPN
|    C                     Z-ADDB51UJI    KQURJI
|    C                     Z-ADDB51UFN    KQURPN
1    C                     END
1    C           KQTHJI    IFEQ 0
|    C                     Z-ADDWSSHHH    KQTHJI
1    C                     ENDIF
1    C           KQTHPN    IFEQ 0
|    C                     Z-ADDWSSNNN    KQTHPN
1    C                     ENDIF
1    C           KQURJI    IFEQ 0
|    C                     Z-ADDWSSHHH    KQURJI
1    C                     ENDIF
1    C           KQURPN    IFEQ 0
|    C                     Z-ADDWSSNNN    KQURPN
1    C                     ENDIF
     C*
     C           BKEY      KLIST
     C                     KFLD           KQSHN1
     C                     KFLD           KQSHN2
     C                     KFLD           KQSHN3
     C           BKEY      CHAINFCEPL011             96
1    C           *IN96     IFEQ '0'
|    C           A2GSKD    ANDEQ'D'
|    C           A2GSHZ    ANDLEWSSDAT
|    C                     SETON                     96
1    C                     ENDIF
1    C           *IN96     IFEQ '1'
|    C                     MOVE 'S'       KQTHAI
1    C                     ELSE
|    C                     MOVE A2TEHI    KQTHAI
|2   C           K@NYMD    IFLT WLDATE
||   C                     MOVE A2KTRK    KQSBKJ
||   C                     MOVE A2KTRT    KQSBRO
||   C                     MOVE A2KTRR    KQSBRT
||   C                     MOVE A2KTRD    KQSBDN
|2   C                     ELSE
||   C                     MOVE A2STRK    KQSBKJ
||   C                     MOVE A2STRT    KQSBRO
||   C                     MOVE A2STRR    KQSBRT
||   C                     MOVE A2STRD    KQSBDN
|2   C                     ENDIF
1    C                     ENDIF
     C*
     C                     MOVEL'K'       KQSKKB
     C                     Z-ADD1         KQHAKO
     C                     Z-ADDWSSYYY    KQURYY
     C                     Z-ADDWSSMMM    KQURMM
     C                     Z-ADDWSSDDD    KQURDD
     C*
     C                     MOVEL'S'       KQDTSY
     C                     MOVEL'4'       KQDTSO
     C                     MOVEL'05'      KQGYOM
      *
     C                     SETOF                     96
     C           1         CHAINAU#NP11              96
1    C           *IN96     IFEQ '0'
|2   C           AHZMM     IFNE UMONTH
||   C                     Z-ADDUMONTH    AHZMM
||   C                     Z-ADD7000001   ARECD
|2   C                     ELSE
||   C                     ADD  1         ARECD
|2   C                     ENDIF
|    C                     EXCPTUP
1    C                     ELSE
|    C                     Z-ADDUMONTH    AHZMM
|    C                     Z-ADD7000001   ARECD
|    C                     EXCPTWT
1    C                     ENDIF
     C*
     C                     Z-ADDARECD     KQJTNO
     C*
     C                     Z-ADDWSSDAT    KQSSHZ
     C                     Z-ADDWSSTM6    KQSSTI
     C                     Z-ADD0         KQNKHZ
     C                     Z-ADD0         KQNKTI
     C                     Z-ADD0         KQAPHZ
     C                     Z-ADD0         KQAPBN
     C                     WRITEKU#PP111
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C**************************************************************************
%0003C* CA#PP11 WRITE       A-PIC2 ORDER FILE
     C**************************************************************************
     C           @CA#11    BEGSR
     C*
     C                     CLEARCA#PP111
     C                     Z-ADDWSSYYY    C7KOYY
     C                     Z-ADDWSSMMM    C7KOMM
     C                     Z-ADDWSSDDD    C7KODD
     C                     Z-ADDWSSHHH    C7KOHH
     C                     Z-ADDWSSNNN    C7KOSS
     C                     MOVELWORKER    C7KOME
     C                     MOVEL#PGM      C7KOPG    P
     C*  SHORTAGE SCAN
     C                     MOVELEKSHN1    C7SHN1
     C                     MOVELEKSHN2    C7SHN2
     C                     MOVELEKSHN3    C7SHN3
     C                     MOVEL*BLANK    C7THNO
     C*  NOT SHORTAGE SCAN
     C           W@SETF    IFEQ '1'
     C                     MOVELA7BHB1    C7SHN1
     C                     MOVELA7BHB2    C7SHN2
     C                     MOVELA7BHB3    C7SHN3
     C                     MOVELA3TEHI    C7THNO
     C                     ENDIF
     C                     MOVEL'F'       C7KDAI
     C                     MOVELEKZETI    C7ZETI
     C                     Z-ADD0111      C7MBMN
     C                     MOVELW@LOC1    C7TKR1
     C                     MOVELW@LOC2    C7TKR2
     C                     MOVELW@LOC3    C7TKR3
     C                     MOVELW@LOC4    C7TKR4
     C                     Z-ADD1         C7HKSU
     C                     MOVE EKSYOS    C7SYOS
     C                     Z-ADDWSSYYY    C7KEYY
     C                     Z-ADDWSSMMM    C7KEMM
     C                     Z-ADDWSSDDD    C7KEDD
     C                     Z-ADDWSSHHH    C7KEJI
     C                     Z-ADDWSSNNN    C7KEPN
     C                     MOVEL'05'      C7GYOM
     C                     Z-ADD0         C7DTYY
     C                     Z-ADD0         C7DTMM
     C                     Z-ADD0         C7DTDD
     C                     Z-ADD0         C7DTHH
     C                     Z-ADD0         C7DTSS
     C                     WRITECA#PP111
     C*
     C           ECA#11    ENDSR
     C**************************************************************************
%0003C* UPDATE CA#PP01        A-PICS2 STATUS FILE
     C**************************************************************************
     C           @CA#01    BEGSR
      *
     C                     MOVELA3TEHI    K@THNO
      *
     C           K#CA      SETGTCA#PL021
     C                     DO   *HIVAL
     C           K#CA      REDPECA#PL021                 30
     C   30                LEAVE
     C           C6SKJY    IFEQ 'D'
     C           C6SKDT    ANDLETODAY
     C                     ITER
     C                     ENDIF
     C* NON CONFORMANCE, ALREADY SHIPPED
     C           C6FRHZ    IFNE 0
     C           C6SFLG    ORNE *BLANK
     C                     ITER
     C                     ENDIF
     C*
     C                     ADD  1         C6SPBX
     C           C6SPBX    IFGE C6MAIS
     C                     MOVEL'1'       C6SFLG
     C                     ENDIF
     C*
     C                     Z-ADDWSSDAT    C6SPDT
     C                     Z-ADDWSSTM6    C6SPTM
     C*
     C                     UPDATCA#PL021
     C                     LEAVE
     C                     ENDDO
     C*
     C           ECA#01    ENDSR
