     C                     MOVE IIAF      WIAF             IAF KANBAN
     C* FINISHED STORAGE(PART MASTER LOCATION)
     C           WSDATE    IFGE W7DATE
     C                     MOVE A7STRK    A1TKR1           NEW
     C                     MOVE A7STRT    A1TKR2
     C                     MOVE A7STRR    A1TKR3
     C                     MOVE A7STRD    A1TKR4
     C*
     C                     ELSE
     C                     MOVE A7STRK    A1TKR1           OLD
     C                     MOVE A7STRT    A1TKR2
     C                     MOVE A7STRR    A1TKR3
     C                     MOVE A7STRD    A1TKR4
     C                     END
     C*
     C                     MOVE WORKER    A1OPER           WORKER
     C                     MOVE *BLANK    A1MHN1           USER PART
     C                     MOVE *BLANK    A1MHN2
     C                     MOVE *BLANK    A1MHN3
     C                     MOVE *BLANK    A1MHN4
