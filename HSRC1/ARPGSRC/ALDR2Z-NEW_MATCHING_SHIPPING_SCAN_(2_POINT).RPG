     C           @CHK13    BEGSR
      *----------------------------------------------
      *
      * take dock from 2D barcode and get cust, delv codes
     C                     MOVELDCCOD     ADDOCK    P
     C                     MOVE *BLANKS   WKPNO
     C           ADDOCK    CHAINAB#PPDC              91
     C           *IN91     IFEQ *OFF
      *
      * take user part id and get internal part id and location.
     C                     MOVELADTOKU    PTOKU
     C                     MOVELADNONY    PNONY
     C                     MOVEL' '       PNKOJ
     C                     MOVEL'    '    PNUKE
     C                     MOVELPART      PMHIN
     C                     CALL 'BBHR50'  P1
      *
     C                     MOVE PSHIN     WKPNO
      *
      * get invoice number from 2D barcode Order Number.
      *    for these toyota export labels the first 3 chars are ignored and the
      *    next 5 chars are the invoice number.
     C           5         SUBSTORNO:4    @@INVN    P
      *
     C                     MOVELADNONY    @@NONY
     C                     MOVE SHDT      K@NYMD
     C                     MOVELDCCOD     K@NUKE
     C                     MOVEL*BLANK    K@MHIN
     C                     MOVELPART      K@MHIN    P
      *
     C                     ENDIF
      *
      *    find the invoice number in the order file...to get the correct
      *     order number and bin number.
     C           K#13      SETLLAB#PL13
     C           *IN92     DOUEQ*ON
     C           K#13      READEAB#PL13                  92
     C           *IN92     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           5         SUBSTBAINVN:1  @INV13  5
     C           @INV13    IFEQ @@INVN
     C                     Z-ADDBANOBN    @@NBN   20
     C                     MOVELBAODRN    ORNO      P
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
      *     if order not found, check for full order# (for AIR exports)
     C           *IN92     IFEQ *ON
     C                     MOVE *OFF      *IN92
     C           K#13      SETLLAB#PL13
     C           *IN92     DOUEQ*ON
     C           K#13      READEAB#PL13                  92
     C           *IN92     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           ORNO      IFEQ BAINVN
     C                     Z-ADDBANOBN    @@NBN   20
     C                     MOVELBAODRN    ORNO      P
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C           *IN92     IFEQ *ON
     C                     MOVELERR,13    MSG
JW1  C                     MOVE '01'      MSG
      *
     C                     MOVE '13'      A5ERID
     C                     SETON                     3330
     C                     GOTO #CHK13
     C                     ENDIF
      *
