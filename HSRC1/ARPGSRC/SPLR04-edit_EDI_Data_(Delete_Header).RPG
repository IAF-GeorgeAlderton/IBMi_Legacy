     H            Y.
     F* SPLR04 ***************************************
     F* EDIT EDI DATA                                *
     F* J.WATANABE     2021.09.1                     *
     F************************************************
     F**TXT200  IF  E                    DISK
     FTXT200  IF  F     200            DISK
     FTXTP200 O   E                    DISK
      ************************************************
     E                    TBL       200  1
     ITXT200  AA  01
     I                                        1 200 FLD200
     I                                        1   5 FLD1
     I                                        4   9 FLD2
     I**          DS
     I**                                      1 200 FLD200
     I**                                      1   5 FLD1
      *
     I              X'00'                 C         @NUL
      ************************************************
      * READ
     C                     DO   *HIVAL
     C                     READ TXT200                   98
     C   98                LEAVE
      *
     C           FLD1      IFEQ 'EBDI0'
     C           FLD1      OREQ 'COMM '
     C           FLD2      OREQ '5770WD'
     C           FLD2      OREQ 'SOURCE'
     C           FLD2      OREQ 'MEMBER'
     C           FLD2      OREQ 'SEQNBR'
     C                     ITER
     C                     ENDIF
      * REMOVE BLANK
     C                     EXSR #BLNK
      *
     C                     WRITETXTP200R
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      ************************************************
      * REMOVE BLANK                                 *
      ************************************************
     C           #BLNK     BEGSR
      *
     C                     MOVEAFLD200    TBL
     C                     Z-ADD201       IX      30
      *
     C           1         DO   200
     C                     SUB  1         IX
     C           IX        IFLT 1
     C           TBL,IX    ORNE *BLANK
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVE @NUL      TBL,IX
      *
     C                     ENDDO
      *
     C                     MOVEATBL       FLD200
      *
     C                     ENDSR
