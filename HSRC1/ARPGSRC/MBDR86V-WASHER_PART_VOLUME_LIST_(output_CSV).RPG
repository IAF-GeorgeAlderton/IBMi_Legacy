     H            Y/
     F** MBDR83 *****************************************
     F*  WASHER PART VOLUME LIST (CREATE WF: MBDWP86)   *
     F*  J.WATANABE   2021.01.21                        *
     F***************************************************
     FMBDWP86 IF  E           K        DISK
     FMBDWP86VO   E           K        DISK
      *------------------------------------------------------------
     E                    TXT     1  16 25
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C                     EXSR #INIT
      *
     C           *LOVAL    SETLLMBDWP86
     C                     DO   *HIVAL
     C                     READ MBDWP86                  98
     C   98                LEAVE
      * OUT HEADER
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     EXSR #HEAD
     C                     ENDIF
      * OUT DETAIL
     C                     EXSR #DTL
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      * CREATE HEADER
      *------------------------------------------------------
     C           #HEAD     BEGSR
      * FIRST HEADER
     C                     CLEARMBDW86V1
     C                     MOVELTXT,15    MVWHIN
      * DATE FROM
     C                     MOVELTXT,13    LTR17  17
     C                     MOVE M6FROM    LTR17
     C                     MOVELLTR17     MVYSLS
      * DATE TO
     C                     MOVELTXT,14    LTR15  15
     C                     MOVE M6TO      LTR15
     C                     MOVELLTR15     MVMSLS
     C                     WRITEMBDW86V1
      * SECOND HEADER
     C                     CLEARMBDW86V1
     C                     MOVELTXT,1     MVWHIN
     C                     MOVELTXT,2     MVYSLS
     C                     MOVELTXT,3     MVMSLS
     C                     MOVELTXT,4     MVSUPN
     C                     MOVELTXT,5     MVSHIN
     C                     MOVELTXT,6     MVMHIN
     C                     MOVELTXT,7     MVFSLS
     C                     MOVELTXT,8     MVTOKU
     C                     MOVELTXT,9     MVNONY
      **                   MOVELTXT,10    MVDSLS
     C                     MOVELTXT,11    MVGRPN
     C                     MOVELTXT,12    MVSMEI
     C                     MOVELTXT,16    MVBMON
     C                     WRITEMBDW86V1
      *
     C                     ENDSR
      *------------------------------------------------------
      *  OUT DETAIL
      *------------------------------------------------------
     C           #DTL      BEGSR
      *
     C                     CLEARMBDW86V1
     C                     MOVELM6WHIN    MVWHIN
     C                     MOVELM6YSLS    MVYSLS
     C                     MOVELM6MSLS    MVMSLS
     C                     MOVELM6SUPN    MVSUPN
     C                     MOVELM6SHIN    MVSHIN
     C                     MOVELM6MHIN    MVMHIN
     C                     MOVELM6DSLS    MVFSLS
     C                     MOVELM6TOKU    MVTOKU
     C                     MOVELM6NONY    MVNONY
      **                   MOVELM6DSLS    MVDSLS
     C                     MOVELM6GRPN    MVGRPN
     C                     MOVELM6SMEI    MVSMEI
     C                     MOVELM6SUP     MVBMON
     C                     WRITEMBDW86V1
      *
     C                     ENDSR
      *------------------------------------------------------
      *  INITIAL SETTINGS
      *------------------------------------------------------
     C           #INIT     BEGSR
      *
     C                     MOVE 'Y'       FIRST   1
      *
     C                     ENDSR
**  TXT (25A) .....2....>
IAF WASHER PART            1
ANNUAL VOLUME              2
MONTHLY VOLUME             3
SUPPLIER                   4
IAF FINAL PART             5
CUSTOMER PART              6
FINAL PART ANNL VOL        7
CUSTOMER#                  8
DELIVERY#                  9
VOL BY DELIV#             10
GROUP                     11
CUSTOMER NAME             12
FROM: DATE                13
TO DATE:                  14
 ** WASHER VOLUME LIST ** 15
SUPP.CODE                 16
