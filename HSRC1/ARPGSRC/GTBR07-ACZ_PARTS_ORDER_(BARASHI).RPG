     C           #PUBL     BEGSR
     C*
     C           K#GT5A    KLIST
     C                     KFLD           IBHIN1
     C                     KFLD           IBHIN2
     C                     KFLD           IBHIN3
     C                     KFLD           K@YM
     C           K#GT5A    CHAINGTCPL05              89
     C           *IN89     IFEQ *ON
     C           GTSKJY    ORNE *BLANK
     C                     CLEARGTCPL051
     C                     MOVELIBHIN1    GTSHN1
     C                     MOVELIBHIN2    GTSHN2
     C                     MOVELIBHIN3    GTSHN3
     C                     MOVELK@YM      GTKEYM
     C                     END
     C*
     C                     Z-ADDW@NXMS    W@N003  50
     C                     Z-ADDK@DD      X       20
     C*
     C                     DO   *HIVAL
     C*
     C           W@N003    IFEQ *ZERO
     C           HTP,X     ORGE 999
     C                     Z-ADDWSSYYY    GTKOYY
     C                     Z-ADDWSSMMM    GTKOMM
     C                     Z-ADDWSSDDD    GTKODD
     C                     Z-ADDWSSHHH    GTKOHH
     C                     Z-ADDWSSNNN    GTKOSS
     C                     MOVEL#USER     GTKOME
     C  N89                UPDATGTCPL051
     C   89                WRITEGTCPL051
     C                     LEAVE
     C                     END
     C*
     C                     ADD  1         HTP,X
     C                     SUB  1         W@N003
     C*
     C                     ENDDO
     C*
     C           W@N003    IFNE *ZERO
     C                     Z-ADDK@YMD     N@YMD
     C                     DO   *HIVAL
     C                     EXSR #PUBLS
     C           W@N003    IFEQ *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     END
     C*
     C                     ENDSR
      *-----------------------------------------------------------
