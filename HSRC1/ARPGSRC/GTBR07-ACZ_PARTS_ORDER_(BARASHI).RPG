     C*
     C           *LOVAL    SETLLGTBPL10
     C*
     C                     DO   *HIVAL
     C*
     C                     READ GTBPL10                  99
     C   99                LEAVE
     C*
     C           IBSKJY    IFEQ 'D'
     C           IBSKHZ    ANDLE*DATE
     C                     ITER
     C                     END
     C*
     C                     MOVE *BLANK    @LOC1   1
     C                     MOVE *BLANK    @LOC2   2
     C                     MOVE *BLANK    @LOC3   2
     C                     MOVE *BLANK    @LOC4   1
     C                     Z-ADD*ZERO     W@LOT#  30
     C                     Z-ADD*ZERO     @DBOX   50
     C                     Z-ADD*ZERO     @DBOX@  50
     C                     Z-ADD*ZERO     @DBOX# 147
     C*
     C                     SELEC
     C*
     C           IBSEIH    WHEQ '0'
     C           K#KEY     SETLLAAPTL01
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAAPTL01                  90
     C           *IN90     IFEQ *OFF
     C           L5SKJY    ANDEQ*BLANK
     C           L5UKHZ    IFGT WSSDAT
     C                     ITER
     C                     END
     C           L5STHZ    IFLE WSSDAT
     C                     ITER
     C                     END
     C                     MOVE L5TKR1    @LOC1   1
     C                     MOVE L5TKR2    @LOC2   2
     C                     MOVE L5TKR3    @LOC3   2
     C                     MOVE L5TKR4    @LOC4   1
     C                     EXSR #SETT
     C           W@SYS     IFNE *ZERO
     C           W@W#01    DIV  W@SYS     @DBOX@  50H
     C           W@W#01    DIV  W@SYS     @DBOX# 147
     C                     ELSE
     C           L5SYOS    IFNE *ZERO
     C           L5KSSU    DIV  L5SYOS    @DBOX@  50H
     C           L5KSSU    DIV  L5SYOS    @DBOX# 147
     C                     END
     C                     END
     C                     Z-ADDL5HKSU    W@LOT#  30
     C                     LEAVE
     C                     END
     C                     ENDDO
      *
     C           IBSEIH    WHEQ '3'
     C           K#KEY     SETLLAKBPL04
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAKBPL04                  90
     C           *IN90     IFEQ *OFF
     C           L1SKJY    ANDEQ*BLANK
     C           L1UKHZ    IFGT WSSDAT
     C                     ITER
     C                     END
     C           L1STHZ    IFLE WSSDAT
     C                     ITER
     C                     END
     C                     MOVE L1TKR1    @LOC1   1
     C                     MOVE L1TKR2    @LOC2   2
     C                     MOVE L1TKR3    @LOC3   2
     C                     MOVE L1TKR4    @LOC4   1
     C           L1SYOS    IFNE *ZERO
     C           L1KTSU    DIV  L1SYOS    @DBOX@  50H
     C           L1KTSU    DIV  L1SYOS    @DBOX# 147
     C                     ENDIF
     C                     Z-ADD1         W@LOT#  30
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           IBSEIH    WHEQ '6'
     C           K#KEY     SETLLAANPL06
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAANPL06                  90
     C           *IN90     IFEQ *OFF
     C           L7SKJY    ANDEQ*BLANK
     C           L7UKHZ    IFGT WSSDAT
     C                     ITER
     C                     END
     C           L7STHZ    IFLE WSSDAT
     C                     ITER
     C                     END
     C                     MOVE L7TKR1    @LOC1   1
     C                     MOVE L7TKR2    @LOC2   2
     C                     MOVE L7TKR3    @LOC3   2
     C                     MOVE L7TKR4    @LOC4   1
     C                     EXSR #SETT
     C           W@SYS     IFNE *ZERO
     C           W@W#01    DIV  W@SYS     @DBOX@  50H
     C           W@W#01    DIV  W@SYS     @DBOX# 147
     C                     ELSE
     C           L7SYOS    IFNE *ZERO
     C           L7KSSU    DIV  L7SYOS    @DBOX@  50H
     C           L7KSSU    DIV  L7SYOS    @DBOX# 147
     C                     END
     C                     END
     C                     Z-ADD1         W@LOT#  30
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSL
      *
     C                     Z-ADD*ZERO     W@RATE  52
     C                     MOVEL*OFF      W@PP06  1
     C                     EXSR #RATE
     C                     Z-ADDW@RATE    WWRATE  52
     C           @DBOX#    MULT W@RATE    W@MS#
     C                     Z-ADD@DBOX#    @DBOX
     C           W@MS#6    IFNE *ZERO
     C           W@MS#     ADD  1         W@MS@D  50
     C                     ELSE
     C                     Z-ADDW@MS#     W@MS@D
     C                     END
     C           W@MS@D    IFEQ *ZERO
     C                     Z-ADD1         W@MS@D
     C                     END
     C*
     C                     Z-ADDIBMAIS    W@BFMS  50
     C*
     C           W@LOT#    IFEQ *ZERO
     C                     Z-ADD1         W@LOT#
     C                     END
     C           W@LOT#    IFGT 1
     C           W@MS@D    DIV  W@LOT#    W@N001  50
     C                     MVR            W@N002  50
     C           W@N002    IFNE *ZERO
     C                     ADD  1         W@N001
     C                     END
     C           W@LOT#    MULT W@N001    W@MS@D
     C                     END
     C*
     C           IBMAIS    IFGT W@MS@D
     C           IBMAIS    SUB  W@MS@D    W@NXMS  50
     C                     Z-ADDW@MS@D    IBMAIS
     C                     ELSE
     C                     Z-ADD*ZERO     W@NXMS
     C                     END
     C*
     C           IBMAIS    MULT IBSYOS    IBSURY
     C*
     C                     UPDATGTBPL101
     C*
     C           W@NXMS    IFNE *ZERO
     C                     EXSR #PUBL
     C                     END
     C*
     C                     Z-ADD*ZERO     W@PUMS  50
     C                     EXSR #PULS
     C*
     C                     Z-ADD*ZERO     W@NTMS  50
     C                     EXSR #PUBN
     C*
     C           @DBOX@    IFEQ *ZERO
     C           IBMAIS    DIV  1         PERCEN    H
     C                     ELSE
     C           IBMAIS    DIV  @DBOX@    PERCEN    H
     C                     END
     C*
     C           @DBOX#    IFNE *ZERO
     C           W@NTMS    DIV  @DBOX#    W@N052  52
     C           W@N052    ADD  0.09      W@DAYS
     C                     ELSE
     C                     Z-ADD*ZERO     W@DAYS
     C                     END
     C*
     C           W@PP06    IFEQ *ON
     C                     MOVEL'*'       @AST
     C                     ELSE
     C                     MOVEL*BLANK    @AST
     C                     END
     C*
     C                     WRITEGTBWP071
     C*
     C                     ENDDO
     C*
     C* ----------------------------------------------------
     C*
     C                     Z-ADD*ZERO     ORGALL  70
     C                     Z-ADD*ZERO     ORDALL  70
     C                     Z-ADD*ZERO     PUBALL  70
     C                     Z-ADD*ZERO     PULALL  70
     C                     Z-ADD*ZERO     NTTALL  70
     C           *HIVAL    SETLLGTBWP07
     C*
     C                     DO   *HIVAL
     C*
     C                     READ GTBWP07                  98
     C   98                LEAVE
     C*
     C           *IN10     IFEQ '0'
     C                     SETON                     10
     C                     TIME           @@TIME
     C                     TIME           WSDT
     C                     EXCPTHY
     C                     END
     C*
     C           *INOV     IFEQ '1'
     C                     EXCPTHY
     C                     SETOF                     OV
     C                     END
     C*
     C                     EXCPTMY
     C*
     C                     ADD  W@BFMS    ORGALL
     C                     ADD  IBMAIS    ORDALL
     C                     ADD  W@NXMS    PUBALL
     C                     ADD  W@PUMS    PULALL
     C                     ADD  W@NTMS    NTTALL
     C*
     C                     ENDDO
     C*
     C                     EXCPTTY
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
      *-----------------------------------------------------------
      *  GET SETTING
      *-----------------------------------------------------------
     C           #SETT     BEGSR
     C*
     C                     Z-ADD*ZERO     W@SYS   50
     C                     Z-ADD*ZERO     W@W#01 112
     C                     Z-ADD*ZERO     W@GEKN  90
     C*
     C                     DO
     C*
     C           K#FCEP    KLIST
     C                     KFLD           IBHIN1
     C                     KFLD           IBHIN2
     C                     KFLD           IBHIN3
     C           K#FCEP    CHAINFCEPL01              91
     C           *IN91     IFEQ *ON
     C                     LEAVE
     C                     END
     C*
     C           A2SYHZ    IFGT *DATE
     C                     Z-ADDA2KSYS    W@SYS   50
     C                     ELSE
     C                     Z-ADDA2SSYS    W@SYS
     C                     END
     C*
     C                     Z-ADDA2GEKN    W@GEKN  90
     C           K#FCEP    CHAINFCEPL11              94
     C           *IN94     IFEQ *OFF
     C           FCSKJY    ANDEQ*BLANK
     C                     Z-ADD*ZERO     Z       20
     C                     DO   *HIVAL
     C                     ADD  1         Z
     C           Z         IFGT 10
     C                     LEAVE
     C                     END
     C           WSSDAT    IFGE CGH,Z
     C                     LEAVE
     C                     END
     C                     ENDDO
     C           Z         IFLE 10
     C           CCD,Z     IFNE *ZERO
     C           CGK,Z     DIV  CCD,Z     @@QTY   90
     C           @@QTY     MULT 20        W@GEKN
     C                     END
     C                     END
     C                     END
     C*
     C           W@GEKN    DIV  20        W@W#01 112
     C*
     C                     ENDDO
     C*
     C                     ENDSR
      *-----------------------------------------------------------
      *  GET RATE(W@RATE)
      *-----------------------------------------------------------
     C           #RATE     BEGSR
     C*
     C                     DO
     C*
     C           K#KEY     CHAINGTDPP06              88
     C           *IN88     IFEQ *OFF
     C           AISKJY    ANDEQ*BLANK
     C                     Z-ADDAIKISU    W@RATE
     C                     MOVEL*ON       W@PP06
     C                     LEAVE
     C                     END
     C*
     C                     Z-ADD*ZERO     I
     C                     DO   *HIVAL
     C*
     C                     ADD  1         I
     C           I         IFGT W@MAXI
     C                     LEAVE
     C                     END
     C* <
     C           @FUG,I    IFEQ '1'
     C           @DBOX#    ANDLT@HTS,I
     C                     Z-ADD@KIS,I    W@RATE
     C                     LEAVE
     C                     END
     C* >
     C           @FUG,I    IFEQ '2'
     C           @DBOX#    ANDGT@HTS,I
     C                     Z-ADD@KIS,I    W@RATE
     C                     LEAVE
     C                     END
     C* =
     C           @FUG,I    IFEQ '3'
     C           @DBOX#    ANDEQ@HTS,I
     C                     Z-ADD@KIS,I    W@RATE
     C                     LEAVE
     C                     END
     C* <=
     C           @FUG,I    IFEQ '4'
     C           @DBOX#    ANDLE@HTS,I
     C                     Z-ADD@KIS,I    W@RATE
     C                     LEAVE
     C                     END
      * >=
     C           @FUG,I    IFEQ '5'
     C           @DBOX#    ANDGE@HTS,I
     C                     Z-ADD@KIS,I    W@RATE
     C                     LEAVE
     C                     END
      * <>
     C           @FUG,I    IFEQ '6'
     C           @DBOX#    ANDNE@HTS,I
     C                     Z-ADD@KIS,I    W@RATE
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C           W@RATE    MULT WNRATE    W@RATE
     C*
     C                     ENDSR
      *-----------------------------------------------------------
      *  UPDATE PUBLICATION
