     FABVPW0G CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS WSINF
     F*
      * EKANBAN SERIAL NUMBER FILE                    *
     FAB#PL7B IF  E           K        DISK
      * PRIORITY KANBAN PRINT ORDER
     FABVPL77 IF  E           K        DISK
      *------------------------------------------------------------
     E*                   MSG     1   2 70
     E                    HSER    1   2 13
      *------------------------------------------------------------
     IWSINF       DS
     I                                    B 378 3790$$RRN
     I* DELIVERY CODE(FROM DISPLAY)
     I            DS
     I                                        1   4 WNONY
     I                                        1   40KNONY
     I            DS
     I                                        1   8 WREHZ
     I                                        1   40KREYY
     I                                        5   60KREMM
     I                                        7   80KREDD
     I            DS
     I                                        1   8 WNOHZ
     I                                        1   80KNOHZ
     I                                        1   40KNOYY
     I                                        5   60KNOMM
     I                                        7   80KNODD
     I            DS
     I                                        1  12 FCIPAR
     I                                        1   5 @PRT1
     I                                        6  10 @PRT2
     I                                       11  12 @PRT3
     I            DS
     I                                        1  12 KIPAR
     I                                        1   5 BASHN1
     I                                        6  10 BASHN2
     I                                       11  12 BASHN3
     I            DS
     I                                        1   80EKSHDT
     I                                        1   40EKDEYY
     I                                        5   60EKDEMM
     I                                        7   80EKDEDD
     I            DS
     I                                        1   60@TIME
     I                                        1   20@H
     I                                        3   40@M
     I            DS
     I                                        1   8 P$NOHZ
     I                                        1   40P@NOYY
     I                                        5   60P@NOMM
     I                                        7   80P@NODD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *================================================================
     C           *ENTRY    PLIST
     C                     PARM           P@NONY  4        DELIVERY CODE
     C                     PARM           P@NKOJ  1        FACTORY
     C                     PARM           P@NUKE  4        DOCK
     C                     PARM           P@NOHZ  8
     C*                    PARM           P@NOYY  40
     C*                    PARM           P@NOMM  20
     C*                    PARM           P@NODD  20
     C                     PARM           P@NOBN  2        BIN
     C                     PARM           P@ODRN 10        ORDER NO
     C                     PARM           P@FLG   1
      *================================================================
      *   MAIN
      *================================================================
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #DSP01
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *================================================================
     C           *INZSR    BEGSR
      *-----------------------------------------------------
     C*
     C           KEY1      KLIST
     C                     KFLD           P@NONY  4        DELIVERY CODE
     C                     KFLD           P@NKOJ  1        FACTORY
     C                     KFLD           P@NUKE  4        DOCK
     C                     KFLD           P@NOYY  40
     C                     KFLD           P@NOMM  20
     C                     KFLD           P@NODD  20
     C                     KFLD           P@NOBN  2        BIN
     C                     KFLD           P@ODRN 10        ORDER NO
     C*
     C           KEY2      KLIST
     C                     KFLD           P@NOYY
     C                     KFLD           P@NOMM
     C                     KFLD           P@NODD
     C                     KFLD           P@NOBN           BIN
     C                     KFLD           EKMHN1           CUST PART#1
     C                     KFLD           EKMHN2           CUST PART#2
     C                     KFLD           EKMHN3           CUST PART#3
     C                     KFLD           EKMHN4           CUST PART#4
     C                     KFLD           EKSHN1           IAF PART#1
     C                     KFLD           EKSHN2           2
     C                     KFLD           EKSHN3           3
     C                     KFLD           P@ODRN 10        ORDER NO
     C                     KFLD           K$CON2  9
     C*
     C                     MOVE P@NOHZ    P$NOHZ
     C*
     C                     EXSR #CHK
      *
     C           RRN1      IFEQ *ZERO
     C                     MOVE '99'      @@ID    2
     C                     MOVE *BLANK    P@FLG
     C                     ELSE
     C                     Z-ADD1         RRN#
     C                     MOVE '01'      @@ID
     C                     MOVE '1'       P@FLG
     C                     ENDIF
      *
     C                     ENDSR
      *================================================================
     C           #CHK      BEGSR
      *-----------------------------------------------------
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
      *
     C           KEY1      SETLLAB#PL7B
      *-------------------------
     C                     DO   *HIVAL
     C           KEY1      READEAB#PL7B                  90
     C   90                LEAVE
     C*
     C           EKSKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
     C           EKSRYO    IFEQ 0
     C                     ITER
     C                     ENDIF
     C*
     C                     MOVE EKSERL    K$CON2  9
     C           KEY2      SETLLABVPL77
     C                     DO   *HIVAL
     C           KEY2      READEABVPL77                  91
     C   91                LEAVE
     C           A7SKJY    IFNE ' '
     C                     ITER
     C                     ENDIF
     C                     MOVE A7MST1    S@MST1
     C                     LEAVE
     C                     ENDDO
     C*
     C           *IN91     IFEQ *ON
     C                     ADD  1         RRN1
     C                     MOVE EKSERL    S@SERL
     C                     MOVELHSER,1    S@SERL
     C                     MOVE EKSHN1    S@SHN1
     C                     MOVE EKSHN2    S@SHN2
     C                     MOVE EKSHN3    S@SHN3
     C                     Z-ADDEKSRYO    S@SRYO
     C                     WRITESFL01
     C                     ENDIF
     C*
     C                     ENDDO
      *-------------------------
      *
     C                     ENDSR
      *================================================================
     C           #DSP01    BEGSR
      *-----------------------------------------------------
      *
     C                     MOVE *ON       *IN51
     C                     WRITEDSP99
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
     C                     Z-ADD$$RRN     RRN#
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKE     WHEQ *ON
     C                     EXSR #UPD
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK2
      *
     C                     ENDSL
      *
     C                     ENDSR
      *================================================================
     C           #UPD      BEGSR
      *-----------------------------------------------------
     C                     Z-ADD*ZERO     @@RRN   40
     C                     MOVE *BLANK    P@FLG
     C*-------------------------
     C           *IN90     DOUEQ*ON
     C                     ADD  1         @@RRN
     C           @@RRN     CHAINSFL01                90
     C*
     C           *IN90     IFEQ *OFF
     C                     MOVE '1'       P@FLG
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *================================================================
     C           #CHK2     BEGSR
      *-----------------------------------------------------
     C                     Z-ADD*ZERO     @@RRN   40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         @@RRN
     C           @@RRN     CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
