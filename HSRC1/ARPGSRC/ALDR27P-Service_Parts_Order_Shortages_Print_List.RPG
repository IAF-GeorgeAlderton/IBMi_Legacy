     H            Y.
      ** ALDR27P  ******************************************
      *  SERVICE PARTS - ORDER SHORTAGES - PRINT LIST      *
      *                                                    *
      * LEC   21/05/25 CREATE                              *
      ******************************************************
     FALDWP27 UF  E           K        DISK
     FALBPL30 IF  E           K        DISK
     FQPRINT  O   F     150     OF     PRINTER
      *
     E                    TBL     1   1 50
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
      *
      * PART NUMBER
     I            DS
     I                                        1  12 W1SHN
     I                                        1   5 W1SHN1
     I                                        6  10 W1SHN2
      * EDITED PART NUMBER
     I            DS
     I                                        1  12 PART#
     I                                        1   5 SHN1
     I                                        6   6 DASH
     I                                        7  11 SHN2
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  14 SDATE
     I                                        1   6 STIME
      *
     C           *ENTRY    PLIST
     C                     PARM           PRT     1
      *
     C                     MOVE *BLANK    PRT
      *
     C                     DO   *HIVAL
      *
     C                     READ ALDWP27                  99
     C   99                LEAVE
      *
     C           W1FLDA    IFEQ 'PRINTED'
     C                     ITER
     C                     ELSE
      *
     C           W@1STP    IFEQ *ON
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     MOVEL*OFF      W@1STP
     C                     ENDIF
      *
     C                     MOVELW1SHID    SHIPDT  80
     C                     MOVELW1SHIT    SHIPTM  40
      *
     C                     MOVELW1SHN1    SHN1
     C                     MOVELW1SHN2    SHN2
      *
     C                     MOVELW1KOME    K@TMCD  60
     C           K@TMCD    CHAINALBPL30              97
     C  N97                MOVELALWKNM    P@WKNM 15
     C   97                MOVEL*BLANK    P@WKNM
      *
     C                     EXCPT@DTL
      *
     C                     MOVEL'PRINTED' W1FLDA
     C           SDATE     CAT  STIME:1   W1FLDB
     C                     UPDATALDWP271
     C                     MOVE 'Y'       PRT
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
      * INITIAL SET
      *-----------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     MOVEL'-'       DASH
     C                     TIME           WSDT
     C                     Z-ADDWSDT      WTIME
     C                     MOVEL*ON       W@1STP  1
      *
     C                     ENDSR
      *
      *-----------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM      10
     O                         TBL,1     72
     O                                   87 'DATE'
     O                         WSSDATY   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O        E   02           @HED
     O                                   87 'TIME'
     O                         WSSTM6    98 '  :  :  '
     O        E   03           @HED
     O                                   11 'SHIP DATE'
     O                                   18 'BIN#'
     O                                   29 'DELV CD'
     O                                   35 'DOCK'
     O                                   44 'ORDER #'
     O                                   67 'PART NUMBER'
     O                                   75 'QPC'
     O                                   85 'ORD QTY'
     O                                  105 'SERIAL NUMBER'
     O                                  129 'TEAM MEMBER'
     O        E 1              @DTL
     O                         SHIPDTY   11
     O                         W1NOBN    17
     O                         W1NONY    28
     O                         W1HPOS    34
     O                         W1ORD#    49
     O                         PART#     68
     O                         W1QPC Z   75
     O                         W1ODERZ   83
     O                         W1SERL   107
     O                         P@WKNM   133
** TBL
        << SERVICE PARTS ORDER SHORTAGE LIST >>
