     C                     TIME           WTIME
     C                     READ BTCWP021                 80
     C           *IN80     DOWEQ'0'
     C                     EXSR #SB500
     C                     READ BTCWP021                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYBT     KLIST
     C                     KFLD           KKSHN1  5
     C                     KFLD           KKSHN2  5
     C                     KFLD           KKSHN3  2
     C                     KFLD           KKKEYM  60
     C                     MOVELW2SHN1    KKSHN1
     C                     MOVELW2SHN2    KKSHN2
     C                     MOVELW2SHN3    KKSHN3
     C                     Z-ADDW2KEYM    KKKEYM
     C                     Z-ADDW2KEDD    X       20
      *
     C           KEYBT     CHAINBTAPL051             20
     C           *IN20     IFEQ '0'
     C                     MOVE *BLANK    BTSKJY
     C                     Z-ADD0         BTSKYY
     C                     Z-ADD0         BTSKMM
     C                     Z-ADD0         BTSKDD
     C                     Z-ADDSDATEY    BTKOYY
     C                     Z-ADDSDATEM    BTKOMM
     C                     Z-ADDSDATED    BTKODD
     C                     Z-ADDSTIMEH    BTKOHH
     C                     Z-ADDSTIMEM    BTKOSS
     C                     MOVELW#USER    BTKOME
     C                     ADD  W2PH      #PH,X
     C                     ADD  W2MH      #MH,X
     C                     UPDATBTAPL051
     C                     ELSE
     C                     CLEARBTAPL051
     C                     Z-ADDSDATEY    BTKOYY
     C                     Z-ADDSDATEM    BTKOMM
     C                     Z-ADDSDATED    BTKODD
     C                     Z-ADDSTIMEH    BTKOHH
     C                     Z-ADDSTIMEM    BTKOSS
     C                     MOVELW#USER    BTKOME
     C                     MOVELW2SHN1    BTSHN1
     C                     MOVELW2SHN2    BTSHN2
     C                     MOVELW2SHN3    BTSHN3
     C                     Z-ADDW2KEYM    BTKEYM
     C                     Z-ADDW2PH      #PH,X
     C                     Z-ADDW2MH      #MH,X
     C                     WRITEBTAPL051
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
