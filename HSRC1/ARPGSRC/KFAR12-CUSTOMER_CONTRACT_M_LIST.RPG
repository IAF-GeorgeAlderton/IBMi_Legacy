     H            Y.                                                      FEAR03
      ** KFAR12 ********************************************
      * CUSTOMER CONTRACT M/LIST                           *                *
      *            S.YAMAGAMI.              MAR/1997/20    *
      ******************************************************
     FKFAPL11 IP  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
     E                    #N         15  1
     E                    $N         15  1
     E                    WN         17  1
     E                    #Z          9  1
     E                    WZ         11  1
      *
     I            DS
     I                                        1  15 #N
     I                                        1  15 D1TELN
     I            DS
     I                                        1  15 $N
     I                                        1  15 D1FAXN
      *
     I            DS
     I                                        1   9 #Z
     I                                        1   9 D1ZIPC
      *
     C           *ENTRY    PLIST
     C                     PARM           PUSER  10
      *
     C           *IN55     IFEQ '0'
     C                     SETON                     55OF
     C                     MOVE *ALL'-'   WLIN  190
     C                     MOVE PUSER     WUSME  10
     C                     TIME           WTIME   60
     C                     END
      *
     C   OF                EXCPTMDS
     C   OF                SETOF                     OF
      *
     C                     EXSR ZIP
     C                     EXSR TEL
     C                     EXSR FAX
     C                     EXCPTDT
      ***************************************************
      ***************************************************
     C           ZIP       BEGSR
     C*
     C                     SETOF                     12
     C                     MOVE *BLANK    WZIP   10
     C                     SETOF                     11
     C                     Z-ADD1         A       20
     C                     Z-ADD0         B       20
     C                     MOVE *BLANK    WZ
     C*
     C                     DO   9         A
     C           #Z,A      IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE #Z,A      WZ,B
     C           A         IFEQ D1ZPH1
     C                     ADD  1         B
     C                     MOVE '-'       WZ,B
     C                     SETON                     12
     C                     END
     C                     ELSE
     C                     SETON                     11
     C                     END
     C  N11                ENDDO
     C*
     C                     MOVEAWZ        WZIP
     C                     ENDSR
      ***************************************************
      ***************************************************
     C           TEL       BEGSR
     C*
     C                     SETOF                     12
     C                     MOVE *BLANK    WTEL   17
     C                     SETOF                     11
     C                     Z-ADD1         A       20
     C                     Z-ADD0         B       20
     C                     MOVE *BLANK    WN
     C*
     C                     DO   15        A
     C           #N,A      IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE #N,A      WN,B
     C           *IN12     IFEQ '0'
     C           A         IFEQ D1TLH1
     C                     ADD  1         B
     C                     MOVE '-'       WN,B
     C           D1TLH1    ADD  D1TLH2    C
     C                     SETON                     12
     C                     END
     C                     ELSE
     C           A         IFEQ C
     C                     ADD  1         B
     C                     MOVE '-'       WN,B
     C                     END
     C                     END
     C                     ELSE
     C                     SETON                     11
     C                     END
     C  N11                ENDDO
     C*
     C                     MOVEAWN        WTEL
     C                     ENDSR
      ***************************************************
      ***************************************************
     C           FAX       BEGSR
     C*
     C                     SETOF                     12
     C                     MOVE *BLANK    WFAX   17
     C                     SETOF                     11
     C                     Z-ADD1         A       20
     C                     Z-ADD0         B       20
     C                     MOVE *BLANK    WN
     C*
     C                     DO   15        A
     C           $N,A      IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE $N,A      WN,B
     C           *IN12     IFEQ '0'
     C           A         IFEQ D1FXH1
     C                     ADD  1         B
     C                     MOVE '-'       WN,B
     C           D1FXH1    ADD  D1FXH2    C       20
     C                     SETON                     12
     C                     END
     C                     ELSE
     C           A         IFEQ C
     C                     ADD  1         B
     C                     MOVE '-'       WN,B
     C                     END
     C                     END
     C                     ELSE
     C                     SETON                     11
     C                     END
     C  N11                ENDDO
     C*
     C                     MOVEAWN        WFAX
     C                     ENDSR
      ***************************************************
      *
     OQPRINT  E  102           MDS
