     C           HTP,U     IFNE 0
     C                     SETON                     52
     C                     ADD  HTP,U     WWMAIS
     C                     ADD  HTP,U     WPSU
     C                     MOVE '*'       HTZ,U
     C                     END
     C                     END
     C                     END
      *
     C                     Z-ADD1         U       20
     C                     Z-ADD0         WMSU    50
     C                     Z-ADD0         WMSU1   50
     C           1         DO   31        U
     C           HTZ,U     IFEQ *BLANK
     C           HTM,U     IFNE 0
     C                     Z-ADDHTM,U     WMSU2   50
     C                     Z-SUBHTM,U     WMSU3   50
     C           WWMAIS    IFGE WMSU2
     C                     SETON                     52
     C                     ADD  WMSU3     WWMAIS
     C                     ADD  HTM,U     WMSU1
     C                     Z-SUBWMSU1     WMSU
     C                     MOVE '*'       HTZ,U
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C           *IN52     IFEQ '1'
