     C                     EXSR #SUB1
     C                     END
      *
     C                     END
      *
     C           $WYM      IFEQ GTKEYM
      *
     C                     Z-ADD1         U
     C                     Z-ADD0         WPSU
     C           1         DO   $WDD      U
     C           HTZ,U     IFEQ *BLANK
     C           HTP,U     IFNE 0
     C                     SETON                     52
     C                     ADD  HTP,U     WWMAIS
     C                     ADD  HTP,U     WPSU
     C                     MOVE '*'       HTZ,U
     C                     END
     C                     END
     C                     END
      *
     C                     Z-ADD1         U
     C                     Z-ADD0         WMSU
     C                     Z-ADD0         WMSU1
     C           1         DO   $WDD      U
     C           HTZ,U     IFEQ *BLANK
     C           HTM,U     IFNE 0
     C                     Z-ADDHTM,U     WMSU2
     C                     Z-SUBHTM,U     WMSU3
     C           WWMAIS    IFGE WMSU2
     C                     SETON                     52
     C                     ADD  WMSU3     WWMAIS
     C                     ADD  HTM,U     WMSU1
     C                     Z-SUBWMSU1     WMSU
     C                     MOVE '*'       HTZ,U
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C           *IN52     IFEQ '1'
