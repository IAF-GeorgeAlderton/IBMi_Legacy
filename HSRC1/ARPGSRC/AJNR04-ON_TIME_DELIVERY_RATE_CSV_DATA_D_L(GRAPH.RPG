     H            Y.
     F** AJNR04 **********************************
     F* ON-TIME DELIVERY RATE CSV DATA D/L(GRAPH)*
     F*     SAKAKI.        2019.10.07            *
     F********************************************
     FAJNWP03 IF  E           K        DISK
     FAJNWP04 O   F     256            DISK                      A
      *
     I            DS
     I                                        1  12 W1SHIN
     I                                        1   5 W1HIN1
     I                                        6  10 W1HIN2
     I                                       11  12 W1HIN3
      *
     C                     EXCPTOHED1
     C                     READ AJNWP03                  80
     C           *IN80     DOWEQ'0'
     C           W3DATA    IFNE SVTYPE
     C                     EXCPTOHED2
     C                     MOVELW3DATA    SVTYPE  1
     C                     ENDIF
     C                     EXSR #SB500
     C                     EXCPTODAT
     C                     EXCPTODAT2
     C                     READ AJNWP03                  80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-------------------------------*
      *
      *-------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     Z-ADD0         W@RAT1  52
     C                     Z-ADD0         W@RAT2  52
     C                     Z-ADD0         W@RAT3  52
     C                     Z-ADD0         W@RAT4  52
     C                     Z-ADD0         W@RAT5  52
     C                     Z-ADD0         W@RAT7  52
     C                     Z-ADD0         W@OKT   52
      *
     C           W3ALL     IFNE 0
      *
     C                     Z-ADD0         W@RAT   94
     C           W3OK1     DIV  W3ALL     W@RAT     H
     C           W@RAT     MULT 100       W@RAT1
     C                     ADD  W@RAT1    W@OKT
      *
     C                     Z-ADD0         W@RAT   94
     C           W3OK2     DIV  W3ALL     W@RAT     H
     C           W@RAT     MULT 100       W@RAT2
     C                     ADD  W@RAT2    W@OKT
      *
     C                     Z-ADD0         W@RAT   94
     C           W3OK3     DIV  W3ALL     W@RAT     H
     C           W@RAT     MULT 100       W@RAT3
     C                     ADD  W@RAT3    W@OKT
      *
     C                     Z-ADD0         W@RAT   94
     C           W3OK4     DIV  W3ALL     W@RAT     H
     C           W@RAT     MULT 100       W@RAT4
     C                     ADD  W@RAT4    W@OKT
      *
     C                     Z-ADD0         W@RAT   94
     C           W3OK5     DIV  W3ALL     W@RAT     H
     C           W@RAT     MULT 100       W@RAT5
     C                     ADD  W@RAT5    W@OKT
      *
     C                     Z-ADD0         W@RAT7
     C           100       SUB  W@OKT     W@RAT7
      *
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
      ******************************************************
     OAJNWP04 EADD             OHED1
     O                                      'TYPE,'
     O                                      'ISSUE DATE,'
     O                                      'RANGE1,'
     O                                      'RANGE2,'
     O                                      'RANGE3,'
     O                                      'RANGE4,'
     O                                      'RANGE5,'
     O                                      'OTHER,'
     O        EADD             OHED2
     O                         W3DATA
     O                                      '-'
     O                                      'RANGE,'
     O                                      ','
     O                         W3RGE1
     O                                      ','
     O                         W3RGE2
     O                                      ','
     O                         W3RGE3
     O                                      ','
     O                         W3RGE4
     O                                      ','
     O                         W3RGE5
     O                                      ','
     O                                      'OTHER,'
      *
     O        EADD             ODAT
      *
     O                                      '  RATE'
     O                                      ','
     O                         W3HTHZ
     O                                      ','
     O                         W@RAT1       ' 0 .  '
     O                                      ','
     O                         W@RAT2       ' 0 .  '
     O                                      ','
     O                         W@RAT3       ' 0 .  '
     O                                      ','
     O                         W@RAT4       ' 0 .  '
     O                                      ','
     O                         W@RAT5       ' 0 .  '
     O                                      ','
     O                         W@RAT7       ' 0 .  '
     O                                      ','
     O        EADD             ODAT2
      *
     O                                      '  # OF BOX'
     O                                      ','
     O                         W3HTHZ
     O                                      ','
     O                         W3OK1H       '     0 '
     O                                      ','
     O                         W3OK2H       '     0 '
     O                                      ','
     O                         W3OK3H       '     0 '
     O                                      ','
     O                         W3OK4H       '     0 '
     O                                      ','
     O                         W3OK5H       '     0 '
     O                                      ','
     O                         W3OK7H       '     0 '
     O                                      ','
