     H            Y.
      ** MYCR80 ******************************************
      *  DELETED PART MASTER DOWNLOAD (FCEPP01)
      *  JW      2024.01.09
      ****************************************************
     FMBDPL01 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FMYCWP80 O   E                    DISK
      ****************************************************
     E                    MSG     1   5 25
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     I            DS
     I                                        1  14 F3SHIN
     I                                        1   5 F3SHN1
     I                                        6   6 @1
     I                                        7  11 F3SHN2
     I                                       12  12 @2
     I                                       13  14 F3SHN3
     I            DS
     I                                        1  23 F3MHIN
     I                                        1   5 F3MHN1
     I                                        6   6 @3
     I                                        7  11 F3MHN2
     I                                       12  12 @4
     I                                       13  17 F3MHN3
     I                                       18  18 @5
     I                                       19  23 F3MHN4
      ****************************************************
      *  MAIN ROUTINE
      ****************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ MBDPL01                  98
     C   98                LEAVE
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELF3SHN1    SVSHN1  5
     C                     MOVELF3SHN2    SVSHN2  5
     C                     MOVELF3SHN3    SVSHN3  2
     C                     MOVELF3NONY    SVNONY  40
     C                     ENDIF
      * BREAK?
     C           F3SHN1    IFNE SVSHN1
     C           F3SHN2    ORNE SVSHN2
     C           F3SHN3    ORNE SVSHN3
     C           F3NONY    ORNE SVNONY
     C                     EXSR #BRK
     C                     ENDIF
      * LAST BREAK
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ****************************************************
      *  BREAK
      ****************************************************
     C           #BRK      BEGSR
      * CHECK FCEPP01
     C                     MOVELSVSHN1    K3SHN1
     C                     MOVELSVSHN2    K3SHN2
     C                     MOVELSVSHN3    K3SHN3
      *
     C           K#01      CHAINFCEPL01              99
     C           *IN99     IFEQ *OFF
     C           A2GSKD    ANDEQ'D'
     C                     EXSR #OUT
     C                     ENDIF
      * RESET
     C                     MOVELF3SHN1    SVSHN1
     C                     MOVELF3SHN2    SVSHN2
     C                     MOVELF3SHN3    SVSHN3
     C                     MOVELF3NONY    SVNONY
      *
     C                     ENDSR
      ****************************************************
      *  OUTPUT MTCWP80
      ****************************************************
     C           #OUT      BEGSR
      *
     C           COUNT     IFEQ 0
     C                     EXSR #HEAD
     C                     ENDIF
      *
     C                     ADD  1         COUNT
     C                     EXSR #DTL
      *
     C                     ENDSR
      ****************************************************
      *  HEADER
      ****************************************************
     C           #HEAD     BEGSR
      * 1ST LINE
     C                     CLEARMYCWP801
     C                     MOVELMSG,1     M2FL01           TITLE
     C                     WRITEMYCWP801
      * 2ND LINE
     C                     CLEARMYCWP801
     C                     MOVELMSG,2     M2FL01           PM DLT FLG
     C                     MOVELMSG,2     M2FL02           PM DLT DATE
     C                     MOVEL'CUST#   'M2FL03           CUST#
     C                     MOVEL'DELV#   'M2FL04           DELIV#
     C                     MOVELMSG,3     M2FL05           USER PART
     C                     MOVELMSG,4     M2FL06           IAF PART
     C                     MOVEL'NAME1   'M2FL07           PART NAME1
     C                     MOVEL'NAME2   'M2FL08           PART NAME2
     C                     MOVEL'MATERIAL'M2FL09           PART NAME3
     C                     MOVEL'SURFACE 'M2FL10           PART NAME4
     C                     WRITEMYCWP801
      * 3RD LINE
     C                     CLEARMYCWP801
     C                     MOVEL'DLT_FLG 'M2FL01           PM DLT FLG
     C                     MOVEL'DLT_DATE'M2FL02           PM DLT DATE
     C                     MOVEL'        'M2FL03           CUST#
     C                     MOVEL'        'M2FL04           DELIV#
     C                     MOVEL'        'M2FL05           USER PART
     C                     MOVEL'        'M2FL06           IAF PART
     C                     MOVEL'        'M2FL07           PART NAME1
     C                     MOVEL'        'M2FL08           PART NAME2
     C                     MOVEL'        'M2FL09           PART NAME3
     C                     MOVEL'        'M2FL10           PART NAME4
     C                     WRITEMYCWP801
      *
     C                     ENDSR
      ****************************************************
      *  DETAIL TA
      ****************************************************
     C           #DTL      BEGSR
      *
     C                     CLEARMYCWP801
     C                     MOVELA2GSKD    M2FL01    P      PM DLT FLG
      *
     C                     MOVELA2GSHZ    $SRC      P
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C                     MOVEL$TRUE2    M2FL02    P      PM DLT DATE
      *
     C                     MOVELF3TOKU    M2FL03    P      CUST#
     C                     MOVELF3NONY    M2FL04    P      DELIV#
      *
     C                     MOVELF3MHIN    M2FL05    P      USER PART
      *
     C                     MOVELF3SHIN    M2FL06    P      IAF PART
      *
     C                     MOVELA2DMEI    M2FL07    P      PART NAME1
     C                     MOVELA2SMEI    M2FL08    P      PART NAME2
     C                     MOVELA2ZANM    M2FL09    P      PART NAME3
     C                     MOVELA2MMEI    M2FL10    P      PART NAME4
     C                     WRITEMYCWP801
      *
     C                     ENDSR
      ****************************************************
      *  INITIAL SETTINGS
      ****************************************************
     C           #INIT     BEGSR
      *
     C           K#01      KLIST
     C                     KFLD           K3SHN1  5
     C                     KFLD           K3SHN2  5
     C                     KFLD           K3SHN3  2
      *
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         COUNT   60
     C                     MOVE ' '       @1
     C                     MOVE ' '       @2
     C                     MOVE ' '       @3
     C                     MOVE ' '       @4
     C                     MOVE ' '       @5
      *
     C                     ENDSR
** MSG (25) .......2....>
 ** DELETED PART LIST **  01
PART_MASTER               02
USER_PART#                03
IAF_PART#                 04
                          05
