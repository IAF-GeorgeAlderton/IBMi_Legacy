     C                     EXSR #HDR
      *
     C                     DO   *HIVAL
     C                     READ AAMPL11                  98
     C   98                LEAVE
      *
     C           CKSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVEA*BLANK    DTL
      *
     C           1         DO   15        IX      20
     C           PRC,IX    IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
      *
     C                     Z-ADD1         IY      20
     C           PRC,IX    LOKUPHDR,IY                   85
     C           *IN85     IFEQ *ON
     C           MCN,IX    IFEQ *BLANK
     C                     MOVEL'*'       DTL,IY
     C                     ELSE
     C                     MOVELMCN,IX    DTL,IY
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      * EDIT PART
     C           CKHIN2    IFEQ *BLANK
     C                     MOVE *BLANK    FL1
     C                     ELSE
     C                     MOVE '-'       FL1
     C                     ENDIF
     C           CKHIN3    IFEQ *BLANK
     C                     MOVE *BLANK    FL2
     C                     ELSE
     C                     MOVE '-'       FL2
     C                     ENDIF
      *
     C                     MOVELCKHIN     FBPART
     C                     WRITEMBDWPTB1
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *****************************************************************
      * SET HEADER
      *****************************************************************
     C           #HDR      BEGSR
      *
     C           1         DO   60        IX      20
     C                     READ MBDWLTA                  97
     C   97                LEAVE
      *
     C                     MOVELFAPROC    HDR,IX
     C                     ENDDO
      *
     C                     MOVE *BLANK    FBPART
     C                     MOVEAHDR       DTL
     C                     WRITEMBDWPTB1
      *
     C                     ENDSR
