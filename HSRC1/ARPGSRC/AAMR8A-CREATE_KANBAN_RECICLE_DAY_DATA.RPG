     C                     Z-ADDW0SLOT    W1SLOT
     C                     Z-ADDW0SJNK    W1SJNK
     C                     Z-ADDW0SMAX    W1SMAX
      *
     C                     MOVE W0KKEY    W1KKEY
      *
     C                     SELEC
     C           POUT      WHEQ '1'
     C                     MOVELW0BMON    W1K001
     C                     MOVELW0KOTE    W1K002
     C                     MOVELW0TKR1    W1K003
     C                     MOVELW0TKR2    W1K004
     C                     MOVELW0TKR3    W1K005
     C                     MOVELW0TKR4    W1K006
