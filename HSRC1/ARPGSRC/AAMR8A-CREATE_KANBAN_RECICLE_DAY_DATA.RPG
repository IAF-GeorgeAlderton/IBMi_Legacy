     C                     MOVELW0KCD2    W1KCD2
      *
     C                     MOVELW0KSN1    W1KSN1
     C                     MOVELW0KSN3    W1KSN3
     C                     MOVELW0KSN2    W1KSN2
     C                     Z-ADDW0HITO    W1HITO
     C                     Z-ADDW0TYLT    W1TYLT
     C                     Z-ADDW0LTIM    W1LTIM
     C                     Z-ADDW0KEIS    W1KEIS
