     H            Y/                                    1
     H** CORR02 *******************************************************
     H*  CHANGE ORDER DATA FOR ALL CUSTOMER                           *
     H*  JW   2020.10.12                                              *
     H*****************************************************************
     FCORPW02 CF  E                    WORKSTN      KINFDS INFDS
     FAB#PL2N UF  E           K        DISK
     FAB#PL2J UF  E           K        DISK
     F            AB#PP2A1                          KRENAMEAB#PP2AX
     FAB#PL1N UF  E           K        DISK
     FAB#PL7B UF  E           K        DISK
     FAB#PP2F UF  E           K        DISK
     FAB#PL0M UF  E           K        DISK
     FAB#PLAN UF  E           K        DISK
     FAB#PP2B UF  E           K        DISK
     FAB#PL75 UF  E           K        DISK
     FAB#PL78 UF  E           K        DISK
     FAB#PPH6 O   E                    DISK
      *================================================================
     E                    MSG     1  30 70
      *================================================================
     IINFDS       DS
     I                                    B 378 3790\\RRN
      *
     I            DS
     I                                        1   80XSHDT
     I                                        1   40XNOYY
     I                                        5   60XNOMM
     I                                        7   80XNODD
      *
     I            DS
     I                                        1  140@TIME
     I                                        1   60@NOW
     I                                        1   20@SYSHH
     I                                        3   40@SYSMN
     I                                        5   60@SYSSS
     I                                        7  140@TODAY
     I                                        7  100@SYSYY
     I                                       11  120@SYSMM
     I                                       13  140@SYSDD
      *
     I           SDS
     I                                     *PROGRAM #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I                                      264 269 #JBNO
      *===============================================================
      *  START  PROGRAM
      *===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
      * INDEX SCREEN ----------------------------
     C           @STEP     CASEQ'#DSP0   '#DSP0
     C           @STEP     CASEQ'#CHK0   '#CHK0
      * CHANGE BIN# -----------------------------
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#CHK1 F5'#CHK1
     C           @STEP     CASEQ'#UPD1   '#UPD1
      * CHANGE PLANT CODE -----------------------
     C**         @STEP     CASEQ'#DSP1   '#DSP1
     C**         @STEP     CASEQ'#CHK1   '#CHK1
     C**         @STEP     CASEQ'#CHK1 F5'#CHK1
     C**         @STEP     CASEQ'#UPD1   '#UPD1
      * CHANGE SHIP TO --------------------------
     C**         @STEP     CASEQ'#DSP2   '#DSP2
     C**         @STEP     CASEQ'#CHK2   '#CHK2
     C**         @STEP     CASEQ'#CHK2 F5'#CHK2
     C**         @STEP     CASEQ'#UPD2   '#UPD2
      * CHANGE PO# ------------------------------
     C**         @STEP     CASEQ'#DSP3   '#DSP3
     C**         @STEP     CASEQ'#CHK3   '#CHK3
     C**         @STEP     CASEQ'#CHK3 F5'#CHK3
     C**         @STEP     CASEQ'#UPD3   '#UPD3
      * CHANGE SCAC -----------------------------
     C**         @STEP     CASEQ'#DSP4   '#DSP4
     C**         @STEP     CASEQ'#CHK4   '#CHK4
     C**         @STEP     CASEQ'#CHK4 F5'#CHK4
     C**         @STEP     CASEQ'#UPD4   '#UPD4
      * CHANGE SHIP DATE ------------------------
     C**         @STEP     CASEQ'#DSP6   '#DSP6
     C**         @STEP     CASEQ'#CHK6   '#CHK6
     C**         @STEP     CASEQ'#CHK6 F5'#CHK6
     C**         @STEP     CASEQ'#UPD6   '#UPD6
      * -----------------------------------------
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      *  DISPLAY FIRST SCREEN
      *===============================================================
     C           #DSP0     BEGSR
     C*
     C                     EXFMTDSP00
     C                     MOVE *OFF      *IN21
     C                     MOVE *OFF      *IN85
     C                     MOVE *BLANK    XMSG
     C*
     C                     MOVE '#CHK0   '@STEP
     C*  < F1 >  END JOB
     C           *INKA     IFEQ *ON
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      * CHECK SCREEN1 DATA
      *===============================================================
     C           #CHK0     BEGSR
     C* CLEAR
     C                     CLEARDSP01
     C                     CLEARDSP02
     C                     CLEARDSP03
     C                     CLEARDSP04
     C                     CLEARDSP05
     C*--------------------
     C* XSEL
     C*--------------------
     C           XSEL      IFEQ 0
     C                     SETON                     2185
     C                     MOVELMSG,20    XMSG
     C                     MOVE '#DSP0   '@STEP
     C                     GOTO @CHK0Z
     C                     ENDIF
     C*
     C           XSEL      IFNE 01
     C           XSEL      ANDNE02
     C           XSEL      ANDNE03
     C           XSEL      ANDNE04
     C           XSEL      ANDNE05
     C           XSEL      ANDNE06
     C**         XSEL      ANDNE07
     C**         XSEL      ANDNE08
     C**         XSEL      ANDNE09
     C**         XSEL      ANDNE10
     C**         XSEL      ANDNE11
     C                     SETON                     2185
     C                     MOVELMSG,1     XMSG
     C                     MOVE '#DSP0   '@STEP
     C                     GOTO @CHK0Z
     C                     ENDIF
     C*
     C                     SELEC
     C           XSEL      WHEQ 01
     C                     MOVE '#DSP1   '@STEP            BIN#
     C**         XSEL      WHEQ 01                         PLANT CODE
     C**                   MOVE '#DSP1   '@STEP
     C**         XSEL      WHEQ 02                         SHIP TO CODE
     C**                   MOVE '#DSP2   '@STEP
     C**         XSEL      WHEQ 03                         ORDER#
     C**                   MOVE '#DSP3   '@STEP
     C**         XSEL      WHEQ 04                         SCAC
     C**                   MOVE '#DSP4   '@STEP
     C**         XSEL      WHEQ 06
     C**                   MOVE '#DSP6   '@STEP            SHIP DATE
     C                     ENDSL
     C*
     C           @CHK0Z    ENDSR
      *===============================================================
      *  DISPLAY 2ND SCREEN - CHANE SHIP TO
      *===============================================================
     C           #DSP2     BEGSR
     C*
     C                     TIME           @TIME
     C                     EXFMTDSP02
     C                     EXSR #CLR
     C*
     C                     MOVE '#CHK2   '@STEP
     C*  < F3 >  BACK
     C           *INKC     IFEQ *ON
     C                     MOVE *BLANK    XMSG
     C                     MOVE '#DSP0   '@STEP
     C                     ENDIF
     C*  < F5 >  UPDAT
     C           *INKE     IFEQ *ON
     C                     MOVE '#CHK2 F5'@STEP
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      * CHECK SCREEN2 DATA
      *===============================================================
     C           #CHK2     BEGSR
     C*--------------------
     C           XTOKU     IFEQ 0
     C                     SETON                     85  47
     C                     MOVELMSG,2     XMSG
     C                     GOTO @CHK2Z
     C                     ENDIF
     C*
     C           XNONY     IFEQ 0
     C                     SETON                     85  41
     C                     MOVELMSG,3     XMSG
     C                     GOTO @CHK2Z
     C                     ENDIF
     C*
     C           XSHDT     IFEQ 0
     C                     SETON                     85  42
     C                     MOVELMSG,4     XMSG
     C                     GOTO @CHK2Z
     C                     ENDIF
     C*
     C           XBIN      IFEQ 0
     C                     SETON                     85  43
     C                     MOVELMSG,5     XMSG
     C                     GOTO @CHK2Z
     C                     ENDIF
     C*
     C           XPO       IFEQ *BLANK
     C                     SETON                     85  44
     C                     MOVELMSG,6     XMSG
     C                     GOTO @CHK2Z
     C                     ENDIF
     C*
     C           XSTOLD    IFEQ *BLANK
     C                     SETON                     85  45
     C                     MOVELMSG,7     XMSG
     C                     GOTO @CHK2Z
     C                     ENDIF
     C*
     C           XSTNEW    IFEQ *BLANK
     C                     SETON                     85  46
     C                     MOVELMSG,8     XMSG
     C                     GOTO @CHK2Z
     C                     ENDIF
     C* CHECK ORDER PP10
     C                     MOVE *OFF      *IN95
     C                     Z-ADD0         PP10R   30
     C           K@PP10    SETLLAB#PL1N
     C           *IN95     DOWEQ*OFF
     C           K@PP10    READEAB#PL1N                  95
     C           *IN95     IFEQ *OFF
     C           BASKJY    ANDNE'D'
     C                     ADD  1         PP10R
     C                     ENDIF
     C                     ENDDO
     C*
     C           PP10R     IFEQ 0
     C                     SETON                     85
     C                     MOVELMSG,9     XMSG
     C                     MOVEL'MSG092'  XMSG
     C                     GOTO @CHK2Z
     C                     ENDIF
     C* CHECK ORDER PP2A WITH PLSH
     C                     MOVE *OFF      *IN95
     C                     Z-ADD0         PP2AR   30
     C                     MOVELXPO       XPO20
     C           K@PP2A    SETLLAB#PL2N
     C           *IN95     DOWEQ*OFF
     C           K@PP2A    READEAB#PL2N                  95
     C           *IN95     IFEQ *OFF
     C           ACUPID    ANDNE'D'
     C           ACSHCD    ANDEQXSTOLD
     C                     ADD  1         PP2AR
     C                     ENDIF
     C                     ENDDO
      *
     C           PP2AR     IFNE 0
     C                     MOVEL'PLSH'    TYP2A
     C                     ENDIF
      *
     C* CHECK ORDER PP2A WITH ASDT
     C           PP2AR     IFEQ 0
     C                     MOVE *OFF      *IN95
     C                     Z-ADD0         PP2AR   30
     C                     MOVELXPO       XPO20
     C           K@PP2A    SETLLAB#PL2J
     C           *IN95     DOWEQ*OFF
     C           K@PP2A    READEAB#PL2J                  95
     C           *IN95     IFEQ *OFF
     C           ACUPID    ANDNE'D'
     C           ACSHCD    ANDEQXSTOLD
     C                     ADD  1         PP2AR
     C                     ENDIF
     C                     ENDDO
      *
     C           PP2AR     IFNE 0
     C                     MOVEL'ASDT'    TYP2A
     C                     ENDIF
     C                     ENDIF
     C*
     C           PP2AR     IFEQ 0
     C                     SETON                     85
     C                     MOVELMSG,24    XMSG
     C                     GOTO @CHK2Z
     C                     ENDIF
      * RETRIEVE PACKING #
     C                     MOVELXSHDT     \NOHZ
     C                     MOVELXTOKU     \CUST
     C                     MOVELXNONY     \NONY
     C                     MOVELXBIN      \BINN
     C                     MOVEL'00000000'\RLHZ
     C                     MOVE *BLANK    \ODRN
     C                     CALL 'UTLR51'
     C                     PARM           \NOHZ   8
     C                     PARM           \CUST   4
     C                     PARM           \NONY   4
     C                     PARM           XNKOJ
     C                     PARM           XNUKE
     C                     PARM           \BINN   2
     C                     PARM           \RLHZ   8
     C                     PARM           \ODRN  10
     C                     PARM           \PICK#  9
     C                     PARM           \RTN    1
     C                     MOVELMSG,18    XPL#
     C           \PICK#    IFEQ *BLANK
     C                     MOVE '????????'XPL#
     C                     ELSE
     C                     MOVE \PICK#    XPL#
     C                     ENDIF
     C*-------------------------
     C           @CHK2Z    TAG
     C*-------------------------
     C           *IN85     IFEQ *OFF
     C           @STEP     IFEQ '#CHK2 F5'
     C                     MOVEL'#UPD2   '@STEP
     C                     ELSE
     C                     MOVELMSG,10    XMSG
     C                     MOVE PP10R     XMSG
     C                     MOVEL'#DSP2   '@STEP
     C                     ENDIF
     C                     ELSE
     C                     MOVEL'#DSP2   '@STEP
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *  UPDATE 2
      *===============================================================
     C           #UPD2     BEGSR
      *
     C* UPDATE AB#PP2A -----------------------------------
     C                     MOVE *OFF      *IN95
     C                     Z-ADD0         PP2AU   30
      *
     C           TYP2A     IFEQ 'PLSH'
     C           K@PP2A    SETLLAB#PL2N
     C                     ELSE
     C           K@PP2A    SETLLAB#PL2J
     C                     ENDIF
      *
     C           *IN95     DOWEQ*OFF
      *
     C           TYP2A     IFEQ 'PLSH'
     C           K@PP2A    READEAB#PL2N                  95
     C                     ELSE
     C           K@PP2A    READEAB#PL2J                  95
     C                     ENDIF
      *
     C           *IN95     IFEQ *OFF
     C           ACUPID    ANDNE'D'
     C           ACSHCD    ANDEQXSTOLD
     C                     ADD  1         PP2AU
     C                     MOVELXSTNEW    ACSHCD
      *
     C           TYP2A     IFEQ 'PLSH'
     C                     UPDATAB#PP2A1
     C                     ELSE
     C                     UPDATAB#PP2AX
     C                     ENDIF
      *
     C                     Z-ADD@TODAY    ACKYMD
     C                     Z-ADD@NOW      ACKTIM
     C                     MOVEL#PGM      ACKPGM
     C                     MOVEL#USER     ACKUSR
     C                     MOVELXSTOLD    ACSHNM    P
     C                     MOVELMSG,11    ACPLNM
     C                     WRITEAB#PPH61
      *
     C                     ENDIF
     C                     ENDDO
      *----------------------------------------------------
      * LAST MSG
     C                     MOVELMSG,11    XMSG
     C                     MOVE PP2AU     XMSG
     C                     MOVEL'#DSP2   '@STEP
      * RESULT
     C                     MOVEL'AB#PP2A' XRSLT1
     C                     MOVE PP2AU     XRSLT1
      *
     C                     ENDSR
      *===============================================================
      *  DISPLAY 3RD SCREEN - CHANE ORDER#
      *===============================================================
     C           #DSP3     BEGSR
     C*
     C                     TIME           @TIME
     C                     EXFMTDSP03
     C                     EXSR #CLR
     C*
     C                     MOVE '#CHK3   '@STEP
     C*  < F3 >  BACK
     C           *INKC     IFEQ *ON
     C                     MOVE *BLANK    XMSG
     C                     MOVE '#DSP0   '@STEP
     C                     ENDIF
     C*  < F5 >  UPDAT
     C           *INKE     IFEQ *ON
     C                     MOVE '#CHK3 F5'@STEP
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      * CHECK SCREEN3 DATA
      *===============================================================
     C           #CHK3     BEGSR
     C*--------------------
     C           XTOKU     IFEQ 0
     C                     SETON                     85  47
     C                     MOVELMSG,2     XMSG
     C                     GOTO @CHK3Z
     C                     ENDIF
     C*
     C           XNONY     IFEQ 0
     C                     SETON                     85  41
     C                     MOVELMSG,3     XMSG
     C                     GOTO @CHK3Z
     C                     ENDIF
     C*
     C           XSHDT     IFEQ 0
     C                     SETON                     85  42
     C                     MOVELMSG,4     XMSG
     C                     GOTO @CHK3Z
     C                     ENDIF
     C*
     C           XBIN      IFEQ 0
     C                     SETON                     85  43
     C                     MOVELMSG,5     XMSG
     C                     GOTO @CHK3Z
     C                     ENDIF
     C*
     C           XPOOLD    IFEQ *BLANK
     C                     SETON                     85  44
     C                     MOVELMSG,12    XMSG
     C                     GOTO @CHK3Z
     C                     ENDIF
     C*
     C           XPONEW    IFEQ *BLANK
     C                     SETON                     85  45
     C                     MOVELMSG,13    XMSG
     C                     GOTO @CHK3Z
     C                     ENDIF
     C* CHECK ORDER
     C                     MOVE *OFF      *IN95
     C                     Z-ADD0         PP10R   30
     C                     MOVELXPOOLD    XPO
     C           K@PP10    SETLLAB#PL1N
     C           *IN95     DOWEQ*OFF
     C           K@PP10    READEAB#PL1N                  95
     C           *IN95     IFEQ *OFF
     C           BASKJY    ANDNE'D'
     C                     ADD  1         PP10R
     C                     ENDIF
     C                     ENDDO
     C*
     C           PP10R     IFEQ 0
     C                     SETON                     85
     C                     MOVELMSG,9     XMSG
     C                     MOVEL'MSG093'  XMSG
     C                     GOTO @CHK3Z
     C                     ENDIF
      * RETRIEVE PACKING #
     C                     MOVELXSHDT     \NOHZ
     C                     MOVELXTOKU     \CUST
     C                     MOVELXNONY     \NONY
     C                     MOVELXBIN      \BINN
     C                     MOVEL'00000000'\RLHZ
     C                     MOVE *BLANK    \ODRN
     C                     CALL 'UTLR51'
     C                     PARM           \NOHZ   8
     C                     PARM           \CUST   4
     C                     PARM           \NONY   4
     C                     PARM           XNKOJ
     C                     PARM           XNUKE
     C                     PARM           \BINN   2
     C                     PARM           \RLHZ   8
     C                     PARM           \ODRN  10
     C                     PARM           \PICK#  9
     C                     PARM           \RTN    1
     C                     MOVELMSG,18    XPL#
     C           \PICK#    IFEQ *BLANK
     C                     MOVE '????????'XPL#
     C                     ELSE
     C                     MOVE \PICK#    XPL#
     C                     ENDIF
      *
     C*-------------------------
     C           @CHK3Z    TAG
     C*-------------------------
     C           *IN85     IFEQ *OFF
     C           @STEP     IFEQ '#CHK3 F5'
     C                     MOVEL'#UPD3   '@STEP
     C                     ELSE
     C                     MOVELMSG,10    XMSG
     C                     MOVE PP10R     XMSG
     C                     MOVEL'#DSP3   '@STEP
     C                     ENDIF
     C                     ELSE
     C                     MOVEL'#DSP3   '@STEP
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      *  UPDATE 3
      *===============================================================
     C           #UPD3     BEGSR
      *
     C                     MOVELXPOOLD    XPO
     C                     MOVELXPOOLD    XPO20
     C* UPDATE AB#PP2A BY PLSH ---------------------------
     C                     MOVE *OFF      *IN95
     C                     Z-ADD0         PP2AU   30
      *
     C           K@PP2A    SETLLAB#PL2N
     C           *IN95     DOWEQ*OFF
     C           K@PP2A    READEAB#PL2N                  95
     C           *IN95     IFEQ *OFF
     C           ACUPID    ANDNE'D'
     C                     ADD  1         PP2AU
     C                     MOVE *BLANK    ACODRN
     C                     MOVELXPONEW    ACODRN
     C                     MOVE XPONEW    LST1    1
     C           LST1      IFEQ *BLANK
     C                     MOVEL'862'     ACEDID
     C                     ELSE
     C                     MOVEL'850'     ACEDID
     C                     ENDIF
      *
     C                     UPDATAB#PP2A1
      *
     C                     Z-ADD@TODAY    ACKYMD
     C                     Z-ADD@NOW      ACKTIM
     C                     MOVEL#PGM      ACKPGM
     C                     MOVEL#USER     ACKUSR
     C                     MOVELXPOOLD    ACSHNM    P
     C                     MOVELMSG,16    ACPLNM
     C                     WRITEAB#PPH61
      *
     C                     ENDIF
     C                     ENDDO
      *
     C* UPDATE AB#PP2A BY ASDT ---------------------------
     C           PP2AU     IFEQ 0
     C                     MOVE *OFF      *IN95
     C                     Z-ADD0         PP2AU   30
      *
     C           K@PP2A    SETLLAB#PL2J
     C           *IN95     DOWEQ*OFF
     C           K@PP2A    READEAB#PL2J                  95
     C           *IN95     IFEQ *OFF
     C           ACUPID    ANDNE'D'
     C                     ADD  1         PP2AU
     C                     MOVE *BLANK    ACODRN
     C                     MOVELXPONEW    ACODRN
     C                     MOVE XPONEW    LST1    1
     C           LST1      IFEQ *BLANK
     C                     MOVEL'862'     ACEDID
     C                     ELSE
     C                     MOVEL'850'     ACEDID
     C                     ENDIF
      *
     C                     UPDATAB#PP2AX
      *
     C                     Z-ADD@TODAY    ACKYMD
     C                     Z-ADD@NOW      ACKTIM
     C                     MOVEL#PGM      ACKPGM
     C                     MOVEL#USER     ACKUSR
     C                     MOVELXPOOLD    ACSHNM    P
     C                     MOVELMSG,16    ACPLNM
     C                     WRITEAB#PPH61
      *
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C* UPDATE AB#PP10 -----------------------------------
     C                     MOVE *OFF      *IN95
     C                     Z-ADD0         PP10U   30
     C           K@PP10    SETLLAB#PL1N
     C           *IN95     DOWEQ*OFF
     C           K@PP10    READEAB#PL1N                  95
     C           *IN95     IFEQ *OFF
     C           BASKJY    ANDNE'D'
     C                     ADD  1         PP10U
     C                     MOVE *BLANK    BAODRN
     C                     MOVELXPONEW    BAODRN
     C                     UPDATAB#PL1N1
     C                     MOVELBAINVN    ASN#5   5
     C                     MOVE '00000000'ASN#8   8
     C                     MOVE ASN#5     ASN#8
     C                     ENDIF
     C                     ENDDO
     C* UPDATE AB#PP70 -----------------------------------
     C                     MOVE *OFF      *IN95
     C                     Z-ADD0         PP70U   30
     C                     MOVELXNONY     XNONYX  4
     C                     MOVELXBIN      XBINX   2
     C           K@PP70    SETLLAB#PL7B
     C           *IN95     DOWEQ*OFF
     C           K@PP70    READEAB#PL7B                  95
     C           *IN95     IFEQ *OFF
     C           EKSKJY    ANDNE'D'
      *
     C           EKODRN    IFEQ *BLANK
     C                     ADD  1         PP70U
     C                     MOVE *BLANK    EKODRN
     C                     MOVELXPONEW    EKODRN
     C                     UPDATAB#PP701
     C                     ELSE
     C           EKODRN    IFEQ XPOOLD
     C                     ADD  1         PP70U
     C                     MOVE *BLANK    EKODRN
     C                     MOVELXPONEW    EKODRN
     C                     UPDATAB#PP701
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
     C* UPDATE AB#PP2F -----------------------------------
     C                     MOVE *OFF      *IN95
     C                     Z-ADD0         PP2FU   30
     C                     MOVELASN#5     XASN#X  8
     C           K@PP2F    SETLLAB#PP2F
     C           *IN95     DOWEQ*OFF
     C           K@PP2F    READEAB#PP2F                  95
     C           *IN95     IFEQ *OFF
     C                     ADD  1         PP2FU
     C                     MOVE *BLANK    AFODRN
     C                     MOVELXPONEW    AFODRN
     C                     UPDATAB#PP2F1
     C                     ENDIF
     C                     ENDDO
     C* UPDATE AB#PP01 -----------------------------------
     C                     MOVE *OFF      *IN95
     C                     Z-ADD0         PP01U   30
     C           K@PP01    SETLLAB#PL0M
     C           *IN95     DOWEQ*OFF
     C           K@PP01    READEAB#PL0M                  95
     C           *IN95     IFEQ *OFF
     C           B1SKJY    ANDNE'D'
     C           B1ODR1    ANDEQXPOOLD
     C                     ADD  1         PP01U
     C                     MOVE *BLANK    B1ODR1
     C                     MOVELXPONEW    B1ODR1
     C                     UPDATAB#PL0M1
     C                     ENDIF
     C                     ENDDO
     C* UPDATE AB#PPA1 -----------------------------------
     C                     MOVE *OFF      *IN95
     C                     Z-ADD0         PPA1U   30
     C           K@PP10    SETLLAB#PLAN
     C           *IN95     DOWEQ*OFF
     C           K@PP10    READEAB#PLAN                  95
     C           *IN95     IFEQ *OFF
     C           BASKJY    ANDNE'D'
     C                     ADD  1         PPA1U
     C                     MOVE *BLANK    BAODRN
     C                     MOVELXPONEW    BAODRN
     C                     Z-ADD@SYSYY    BAKOYY
     C                     Z-ADD@SYSMM    BAKOMM
     C                     Z-ADD@SYSDD    BAKODD
     C                     MOVEL#USER     BAKOME
     C                     MOVEL'AB#RH6'  BANOPG
     C                     Z-ADD@SYSHH    BAKOHH
     C                     Z-ADD@SYSMN    BAKOSS
     C                     UPDATAB#PLAN1
     C                     ENDIF
     C                     ENDDO
     C* UPDATE AB#PP2B -----------------------------------
     C                     MOVE *OFF      *IN95
     C                     Z-ADD0         PP2BU   30
     C           K@PP2B    SETLLAB#PP2B
     C           *IN95     DOWEQ*OFF
