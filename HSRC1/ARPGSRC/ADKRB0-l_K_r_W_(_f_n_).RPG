      *----------------------------------------------------*
      * 1ST.                                               *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTADKPWB01
     C                     SETOF                     313233
     C                     SETOF                     343536
     C                     SETOF                     9930
     C                     MOVEL*BLANK    D1ERR
      * F1
     C           *IN01     IFEQ '1'
     C                     MOVEL'01'      PCMD
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1DATA    IFEQ '1'
     C           D1DATA    OREQ '2'
     C                     ELSE
     C                     MOVELER,2      D1ERR
     C                     SETON                     3599
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1DATA    IFEQ '1'
     C           D1CR1     IFEQ 0
     C                     MOVELER,1      D1ERR
     C                     SETON                     3199
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADDD1C1      A1C1
     C                     Z-ADDD1C2      A1C2
     C           D1CR2     IFEQ 0
     C                     Z-ADD99999999  A1CR2
     C                     ENDIF
     C           D1CB2     IFEQ 0
     C                     Z-ADD99        A1CB2
     C                     ENDIF
     C           A1C2      IFNE 0
     C           A1C1      IFGT A1C2
     C                     MOVELER,3      D1ERR
     C                     SETON                     313233
     C                     SETON                     3499
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
     C           KEYSHN    KLIST
     C                     KFLD           D1SHN1
     C                     KFLD           D1SHN2
     C                     KFLD           D1SHN3
     C           D1SHN     IFNE *BLANK
     C           KEYSHN    CHAINFCEPL011             22
     C           *IN22     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     22
     C                     ENDIF
     C           *IN22     IFEQ '1'
     C                     MOVELER,5      D1ERR
     C                     SETON                     3099
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
     C           D1SORT    IFEQ '1'
     C           D1SORT    OREQ '2'
     C           D1SORT    OREQ '3'
     C           D1SORT    OREQ '4'
     C                     ELSE
     C                     MOVELER,2      D1ERR
     C                     SETON                     3699
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     MOVELD1CR1     P1CR1
