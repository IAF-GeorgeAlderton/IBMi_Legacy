      *******************************************************
     C           #CHKP     BEGSR
      *
     C                     MOVE 'N'       PFLG    1
     C                     MOVELA2BHB1    P#SHN1
     C                     MOVELA2BHB2    P#SHN2
     C                     MOVELA2BHB3    P#SHN3
     C           P#PL01    CHAINFCEPL01B             99
      *
     C           *IN99     IFEQ *ON
     C                     MOVE 'Y'       PFLG
     C           1         DO   60        IX      20
     C           PRT,IX    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELA2SHIN    PRT,IX
     C                     LEAVE
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDSR
      *******************************************************
