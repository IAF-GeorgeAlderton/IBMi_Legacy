     C*
     C           KEY1      KLIST
     C                     KFLD           KDOC1   5
     C*
GA   C           KEY2      KLIST
GA   C                     KFLD           #PAR1
GA   C                     KFLD           #PAR2
GA   C                     KFLD           #PAR3
     C*
     C           KEY3      KLIST
     C                     KFLD           KSTID   5        PLANT
     C                     KFLD           KDOCK   4        DOCK
     C                     KFLD           KIPAR  20        INTRL PART#
     C                     KFLD           KSIDT   80       SHIP ISS DAT
     C                     KFLD           KPOR#   6        RELEASE#
     C*
     C           *ENTRY    PLIST
     C                     PARM           PUSER  10        USER ID
     C*
     C                     MOVELPUSER     USER    5
     C                     TIME           WTIME   60
     C                     Z-ADD*ZERO     WNNET   70
     C                     Z-ADD*ZERO     QTYPC   50
     C                     Z-ADD1         I       20
     C                     Z-ADD*ZERO     X       20
     C                     MOVE *ZERO     NET
     C                     MOVE *ZERO     DAT
     C                     MOVE *ZERO     QPC
     C*
     C                     SETON                     OF
     C   OF                EXCPT#HED1
     C   OF                SETOF                     OF
     C*
     C*------------------- SETON                     98
     C           *LOVAL    SETLLABFAP01R
     C                     READ ABFAP01R                 90
     C*
   B1C           *IN90     DOWEQ'0'
     C*
     C                     SETON                     91
     C* MOVE VALUE FOR KEY3
     C                     MOVELCFDOCK    KSTID
     C                     MOVE 'A'       KSTID
     C                     MOVELCFDOC2    KDOCK
     C                     MOVELCFPART    KIPAR
     C                     MOVE CFSIDT    KSIDT
     C                     MOVE CFPOR#    KPOR#
     C*
     C                     SETOF                       95
     C           KEY3      SETLLABF2P011
     C           KEY3      READEABF2P011                 95
     C*
     C                     Z-ADD0         Y       20       14 TIMES
     C           *IN95     DOWEQ'0'
      * IGNORE
     C           AFTPCD    IFEQ 'FORDX'
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         Y
     C           *IN95     IFEQ '1'
     C           Y         ORGT 14
     C                     LEAVE
     C                     ENDIF
     C*
     C                     SETON                       80  RECORD IS FOUND
     C* MOVE VALUE FOR KEY1
     C                     MOVELAFDOCK    WDOCK   4
     C                     MOVELAFSTID    KDOC1
     C                     MOVE 'A'       KDOC1
     C           KEY1      CHAINABF9P01              92
   B3C           *IN92     IFEQ '0'
     C                     MOVELF9DOCK    WTOKU   4        TOKUISAKI
     C                     MOVELF9DELY    WNONY   4        NONYUSAKI
   E3C                     END
     C*
     C                     MOVEL'5149'    PTOKU   4
     C                     MOVELF9DELY    PNONY   4
     C                     MOVEL'0'       PNKOJ   1
     C                     MOVELAFDOCK    PNUKE   4
     C                     MOVELCFPART    @MHIN  20        USER PART#
     C                     MOVEL*BLANK    @SHIN  12        INTERNAL
     C                     MOVEL*BLANK    @FLG    1
     C*
     C*  CALL PART# CONVERSION PGM
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU
     C                     PARM           PNONY
     C                     PARM           PNKOJ
     C                     PARM           PNUKE
     C                     PARM           @MHIN
     C                     PARM           @SHIN
     C                     PARM           @FLG
     C                     MOVEL@MHIN     WPART  12
     C*
     C*  PART# IS IN KEY2
     C           KEY2      CHAINFCEPL011             93
     C           *IN93     IFEQ '0'
     C                     MOVE A2SYYY    CDAT1
     C                     MOVE A2SYMM    CDAT2
     C                     MOVE A2SYDD    CDAT3
     C                     MOVE A2TRYY    TDAT1
     C                     MOVE A2TRMM    TDAT2
     C                     MOVE A2TRDD    TDAT3
     C*
     C                     ELSE
     C                     MOVE *BLANK    CDAT1
     C                     MOVE *BLANK    CDAT2
     C                     MOVE *BLANK    CDAT3
     C                     END
     C*
     C* 1ST. RECORD ?
     C           *IN91     IFEQ '1'
     C                     SETOF                     913031
     C                     SETOF                     32
     C*
     C                     MOVEAWWDLDT    DAT,I
     C           AFQTY2    SUB  AFYSQY    WNNET
     C*
     C                     EXSR @SYOS
     C                     EXSR @SUBR1
     C                     Z-ADDQTYPC     WTYPC   50
     C*
     C                     ELSE
     C*
     C           *IN93     IFEQ '1'
     C                     MOVE *ZERO     QTYPC
     C*
     C                     ELSE
     C           CDATE     IFGE WFHSDT
     C           CDATE     ANDLEWFHEDT
     C                     SETON                     31
     C                     MOVE A2SSYS    QTYPC
     C*
     C                     ELSE
     C                     MOVE WSYOS     QTYPC
     C                     END
     C           TDATE     IFGE WFHSDT
     C           TDATE     ANDLEWFHEDT
     C                     SETON                     32
     C                     END
     C                     END
     C*
     C                     ADD  1         I
     C                     MOVEAWWDLDT    DAT,I
     C           AFQTY2    SUB  AFYSQY    WNNET
     C*
     C                     EXSR @SYOS
     C                     EXSR @SUBR1
     C*
     C                     END
     C                     Z-ADDAFHSDT    WFHSDT  80
     C                     Z-ADDAFHEDT    WFHEDT  80
     C*
     C           KEY3      READEABF2P011                 95
     C                     END
     C*
     C* WHEN THERE IS ANY RECORD TO BE WRITTEN
     C* *IN80 = '1'
     C           *IN80     IFEQ '1'
     C   OF                EXCPT#HED1
     C   OF                SETOF                     OF
     C*
      * if any of the 14 qtys is greater than zero, output detail.
     C                     MOVE ' '       PRINT   1
      *
     C                     DO   14        QX      20
     C           QPC,QX    IFGT *ZERO
     C                     MOVE 'Y'       PRINT
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           PRINT     IFEQ 'Y'
     C                     EXCPT#DTL
     C                     ENDIF
      *
     C                     EXSR @CLR
     C                     SETOF                     80
     C                     ENDIF
      *
     C                     READ ABFAP01R                 90
     C                     END
     C*
     C*
     C                     SETON                     LR
     C                     RETRN
     C*****************************************************************
     C*     @CLR : CLEAR WORK-AREA,TBL
     C*****************************************************************
     C           @CLR      BEGSR
     C*
     C                     Z-ADD*ZERO     QTYPC   50
     C                     Z-ADD*ZERO     CDAT
     C                     Z-ADD*ZERO     QTYPC1  50
     C                     MOVE *BLANK    WSTR
     C                     MOVE *BLANK    WKTR
     C                     SETOF                     303132
     C                     Z-ADD1         I
     C                     MOVE *ZERO     DAT
     C                     MOVE *ZERO     NET
     C                     MOVE *ZERO     QPC
     C           AFQTY2    SUB  AFYSQY    WNNET
     C                     MOVEAWWDLDT    DAT,I
     C*
     C                     ENDSR
     C*****************************************************************
     C*     @SYOS:CALCULATION WITH REMAINDER
     C*****************************************************************
     C           @SYOS     BEGSR
     C*
     C* SAVE UNIT QTY.
     C* CALUCULATE THE NUMBER OF CONTAINER
     C           *IN93     IFEQ '1'
     C                     MOVE *ZERO     WSYOS
     C                     MOVE *ZERO     QTYPC1
     C                     MOVE *ZERO     QTYPC
     C*
     C                     ELSE
     C           AFDLDT    IFLT CDATE
     C                     MOVE A2KSYS    WSYOS   50
     C                     ELSE
     C                     MOVE A2SSYS    WSYOS
     C                     END
     C*
     C                     MOVE A2KSYS    QTYPC1
     C                     MOVE A2SSYS    QTYPC
     C                     MOVE A2STR     WSTR
     C                     MOVE A2KTR     WKTR
     C                     END
     C*
     C           WSYOS     IFNE *ZERO
     C           WNNET     DIV  WSYOS     QPCN    60
     C                     MVR            P1      30
     C*                    EXSR @SUBR1
     C*
     C                     ELSE
     C                     Z-ADD*ZERO     QPCN
     C                     SETON                     30
     C                     END
     C*
     C                     ENDSR
     C*****************************************************************
     C*     @SUBR1:CALCULATION WITH REMAINDER
     C*****************************************************************
     C           @SUBR1    BEGSR
     C*
     C           P1        IFGT 0
     C           QPCN      ANDGE0
     C                     ADD  1         QPCN
     C                     END
     C           P1        IFLT 0
     C           QPCN      ANDLE0
     C                     SUB  1         QPCN
     C                     END
     C*
     C                     Z-ADDQPCN      SQPC,I  60       SAVE BOX CNT
     C*
     C           I         IFEQ 1
     C                     Z-ADDQPCN      QPC,I
     C                     ENDIF
     C*
     C           I         IFGT 1
     C           I         SUB  1         X
     C           SQPC,I    SUB  SQPC,X    QPC,I
     C           QPC,I     IFLT 0
     C                     Z-ADD0         QPC,I
     C                     ENDIF
     C                     ENDIF
     C*
     C                     ENDSR
     C**************************************************************************
