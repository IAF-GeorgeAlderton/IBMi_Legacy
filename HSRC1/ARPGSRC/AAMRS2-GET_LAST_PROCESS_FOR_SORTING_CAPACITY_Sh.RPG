     F*----------------------------------------------------*
      *  ENTRY LIST
     F*----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
     C                     PARM           P@BAN1  1
     C                     PARM           P@BAN2  2
     C                     PARM           P@BAN3  2
     C                     PARM           P@BAN4  1
     C                     PARM           P@BMON  4
     C                     PARM           P@KOTE  3
     C                     PARM           P@KIBN  3
     C                     PARM           P@KHIN 12
     C                     PARM           P@FLG   1
     F*----------------------------------------------------*
      *  MAIN
     F*----------------------------------------------------*
     C                     MOVE P@HIN1    K@HIN1
     C                     MOVE P@HIN2    K@HIN2
     C                     MOVE P@HIN3    K@HIN3
      *
     C                     MOVE *BLANK    P@KIBN
     C                     MOVE *BLANK    P@KHIN
     C                     MOVE *BLANK    P@FLG
      *
     C           HINKEY    KLIST
     C                     KFLD           K@HIN1  5
     C                     KFLD           K@HIN2  5
     C                     KFLD           K@HIN3  2
      *
     C           HINKEY    CHAINAAMPL11              88
     C           *IN88     IFEQ '0'
     C           CKSKJY    IFEQ 'D'
     C                     SETON                     88
     C                     END
     C                     END
      *
     C   88                GOTO @END
      *
     C                     SETOF                     77
      *
     C           1         DO   15        @X      20
      *
     C           16        SUB  @X        @Z      20
      *
      * SKIP BLANK PROCESS
     C           NKOT,@Z   IFEQ *BLANK
     C                     ITER
     C                     ENDIF
      *
      * SKIP SPECIFIC PROCESSES - VNL,HT,SL
     C           NKOT,@Z   LOKUPTB1                      90
     C           *IN90     IFEQ *ON
     C                     ITER
     C                     ENDIF
      *
      * SKIP BLANK KANBAN KIND
     C***        NSHR,@Z   IFNE *BLANK
     C                     MOVE NBMN,@Z   P@BMON
     C                     MOVE NKOT,@Z   P@KOTE
     C                     MOVE NKBN,@Z   P@KIBN
     C                     MOVE NHBN,@Z   P@KHIN
     C                     MOVE '*'       P@FLG
     C                     LEAVE
     C***                  END
      *
     C                     ENDDO
      *
     C           @END      TAG
      *
     C                     SETON                     LR
     C                     RETRN
      *
** TB1
