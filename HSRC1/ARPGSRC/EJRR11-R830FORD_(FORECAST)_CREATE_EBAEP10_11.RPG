     H            Y.
     F** EJRR11 *******************************************************
     F* R830FORD (FORECAST) CREATE EBAEP10,11                         *
     F* T.SAKAKI                    2017.01.06                        *
     F*****************************************************************
     FEJRWP11 IF  F     511            DISK
      *
     FEBAEP10 O   E                    DISK
     FEBAEP11 O   E                    DISK
      *
     E                    TB1        10  1
     E                    TB2        10  1
      *
     IEJRWP11 AA  01
     I                                        1 511 A#DATA
     I**  HEADER
     I                                        1   1 @KUBN
     I                                        2   7 H#RCID
     I                                        8  19 H#PTID
     I                                       34  63 H#REL#
     I                                       67  72 H#HSDT
     I                                       73  78 H#HEDT
     I                                       79  84 H#SIDT
     I                                      121 125 H#DOCK
     I                                      130 134 H#SIRE
     I                                      139 143 H#STFC
     I**  MESSAGE LEVEL
     I                                        1   3 @KBN3
     I                                        4   6 M#MKBN
     I                                        7   9 M#NRCD
     I                                       10  69 M#NOTE
     I**  DETAIL
     I                                        2   7 D#RCID
     I                                       10  39 D#PART
     I                                       42  71 D#ORD#
     I                                      158 161 D#SHDK
     I                                      252 253 D#CFCD
     I                                      254 288 D#CFNM
     I                                      291 311 D#PHN#
     I                                      315 324 D#QTY1
     I                                      326 326 D#QTCD
     I                                      327 332 D#CSDT
     I                                      333 338 D#CEDT
     I                                      348 353 D#FIED
     I                                      354 363 D#FIQT
     I                                      364 369 D#FISD
     I                                      372 377 D#MTED
     I                                      378 387 D#MTQT
     I                                      388 393 D#MTSD
     I                                      455 464 D#SHQT
     I                                      468 473 D#SHSD
     I                                      474 479 D#SHLD
     I**
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *================================================================
      *   KEY LIST
      *================================================================
      *================================================================
      *  MAIN
      *================================================================
     C                     TIME           WTIME
     C*-------------------------
     C           1         SETLLEJRWP11
     C*-------------------------
     C                     DO   *HIVAL
     C                     READ EJRWP11                  90
     C   90                LEAVE
     C*
     C                     SELEC
     C* HEADER
     C           @KUBN     WHEQ 'H'
     C                     EXSR #HDSET
     C* DETAIL
     C           @KUBN     WHEQ 'D'
     C                     EXSR #DTSET
     C* SET MESSAGE
     C           @KBN3     WHEQ 'MSG'
     C           M#MKBN    IFEQ 'SDP'
     C                     EXSR #MSWRT
     C                     ENDIF
     C*
     C                     ENDSL
     C*
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *================================================================
      *  GET HEADER
      *================================================================
     CSR         #HDSET    BEGSR
     C*
     C                     MOVELH#PTID    ABPRTR
     C                     MOVEL'5149'    ABCUST
     C                     MOVEL'0'       ABFACT
     C                     MOVELH#REL#    ABREL#
     C*
     C                     MOVELH#HSDT    WKDTA6  6
     C                     EXSR #DATE8
     C                     MOVE WKDTA8    ABHSDT
     C*
     C                     MOVELH#HEDT    WKDTA6
     C                     EXSR #DATE8
     C                     MOVE WKDTA8    ABHEDT
     C*
     C                     MOVELH#SIDT    WKDTA6
     C                     EXSR #DATE8
     C                     MOVE WKDTA8    ABSIDT
     C*
     C                     MOVELH#DOCK    ABDOCK
     C                     MOVELH#SIRE    ABSIRE
     C                     MOVELH#STFC    ABSTFC
     C*
     CSR         EHDSET    ENDSR
      *================================================================
      *  GET DETAIL
      *================================================================
     CSR         #DTSET    BEGSR
      *
     C                     Z-ADDWTIHZ     ABCRDT
     C                     Z-ADDWJFB      ABCRTM
      *
     C                     MOVELD#PART    ABPART
     C                     MOVELD#ORD#    ABORD#
     C                     MOVELD#SHDK    ABSHDK
      *
     C                     MOVEL*BLANK    ABEXCD
     C                     MOVEL*BLANK    ABEX#
     C                     MOVEL*BLANK    ABRDCD
     C                     MOVEL*BLANK    ABRD#
      *
     C           D#CFCD    IFEQ 'EX'
     C                     MOVELD#CFNM    ABEXCD
     C                     MOVELD#PHN#    ABEX#
     C                     ELSE
     C                     MOVELD#CFNM    ABRDCD
     C                     MOVELD#PHN#    ABRD#
     C                     ENDIF
      * QTY
     C                     MOVEAD#QTY1    TB1
     C                     EXSR #CONV
     C                     Z-ADD@NUM      ABQTY1
      *
     C                     MOVELD#QTCD    ABQTCD
     C*
     C                     MOVELD#CSDT    WKDTA6
     C                     EXSR #DATE8
     C                     MOVE WKDTA8    ABCSDT
      *
     C                     MOVELD#CEDT    WKDTA6
     C                     EXSR #DATE8
     C                     MOVE WKDTA8    ABCEDT
      *
     C                     MOVELD#FIED    WKDTA6
     C                     EXSR #DATE8
     C                     MOVE WKDTA8    ABFIED
      *
     C                     MOVELD#FISD    WKDTA6
     C                     EXSR #DATE8
     C                     MOVE WKDTA8    ABFISD
      *
     C                     MOVEAD#FIQT    TB1
     C                     EXSR #CONV
     C                     Z-ADD@NUM      ABFIQT
      *
     C                     MOVELD#MTED    WKDTA6
     C                     EXSR #DATE8
     C                     MOVE WKDTA8    ABMTED
      *
     C                     MOVELD#MTSD    WKDTA6
     C                     EXSR #DATE8
     C                     MOVE WKDTA8    ABMTSD
      *
     C                     MOVEAD#MTQT    TB1
     C                     EXSR #CONV
     C                     Z-ADD@NUM      ABMTQT
      *
     C                     MOVEAD#SHQT    TB1
     C                     EXSR #CONV
     C                     Z-ADD@NUM      ABSHQT
      *
     C                     MOVELD#SHSD    WKDTA6
     C                     EXSR #DATE8
     C                     MOVE WKDTA8    ABSHSD
      *
     C                     MOVELD#SHLD    WKDTA6
     C                     EXSR #DATE8
     C                     MOVE WKDTA8    ABSHLD
      *
     C* WRITE
     C                     WRITEEBAEP101
      *
     CSR         EDTSET    ENDSR
      *================================================================
      *  WRITE MESSAGE
      *================================================================
     CSR         #MSWRT    BEGSR
      *
     C                     CLEAREBAEP111
     C                     MOVELM#NOTE    AENOTE
     C                     MOVELABPRTR    AEPRTR
     C                     Z-ADDABSIDT    AESIDT
     C                     MOVELABDOCK    AEDOCK
     C                     MOVELABPART    AEPART
     C                     Z-ADDWTIHZ     AECRDT
     C                     Z-ADDWJFB      AECRTM
     C* WRITE
     C                     WRITEEBAEP111
      *
     CSR         EMSWRT    ENDSR
      *================================================================
      *  DATE 6 TO 8 DIGITS
      *================================================================
     CSR         #DATE8    BEGSR
      *
     C                     MOVEL*BLANK    WKDTA8  8
      *
     C           WKDTA6    IFEQ *BLANK
     C                     ELSE
     C                     CALL 'DATR00'
     C                     PARM           WKDTA6
     C                     PARM           WKDTA8
     C                     ENDIF
      *
     CSR         EDATE8    ENDSR
      *================================================================
      *  NUMERIC
      *================================================================
     CSR         #CONV     BEGSR
      *
     C                     Z-ADD0         @NUM   100
     C                     Z-ADD0         IX      20
     C                     SETOF                     60
     C                     MOVEA*ALL'0'   TB2
      *
     C           1         DO   10        IX
     C                     MOVE TB1,IX    TB2,IX
     C                     SELEC
     C           TB1,IX    WHEQ *BLANK
     C           TB1,IX    OREQ '+'
     C                     MOVE '0'       TB2,IX
     C           TB1,IX    WHEQ '-'
     C                     MOVE '0'       TB2,IX
     C                     SETON                     60
     C                     ENDSL
     C*
     C                     ENDDO
     C*
     C                     MOVEATB2       LTR10  10
     C                     MOVELLTR10     @NUM
     C* NEGATIVE
     C           *IN60     IFEQ *ON
     C           0         SUB  @NUM      @NUM
     C                     ENDIF
     C*
     CSR         ECONV     ENDSR
