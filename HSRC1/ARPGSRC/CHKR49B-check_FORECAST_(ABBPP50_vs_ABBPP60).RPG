     H            Y.
     F** CHKR49B ***************************************************************
     F*  PROGRAM    : CHECK FORECAST (ABBPP50 VS ABBPP60)                      *
     F*  WRITTEN    : JW    2023.06.27                                         *
     F* ----------------------------------------------------                   *
     F**************************************************************************
     FABBPL50 IF  E           K        DISK
     FABBPL60 IF  E           K        DISK
     FCHKWP49 UF  E           K        DISK                      A
     F**************************************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        7  100@YEAR
     I            DS
     I                                        1  20 ABMHIN
     I                                        1   5 ABMHN1
     I                                        6  10 ABMHN2
     I                                       11  15 ABMHN3
     I                                       16  20 ABMHN4
     I            DS
     I                                        1  20 BBMHIN
     I                                        1   5 BBMHN1
     I                                        6  10 BBMHN2
     I                                       11  15 BBMHN3
     I                                       16  20 BBMHN4
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      * PP50
     C           @SDAT8    SETLLABBPL50
     C                     DO   *HIVAL
     C                     READ ABBPL50                  98
     C   98                LEAVE
      *
     C           BBFLG1    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           BBTOKU    IFNE SVTOKU
     C           BBNONY    ORNE SVNONY
     C           BBMHIN    ORNE SVMHIN
     C                     EXSR #PP50
     C                     Z-ADDBBTOKU    SVTOKU
     C                     Z-ADDBBNONY    SVNONY
     C                     MOVELBBMHIN    SVMHIN
     C                     ENDIF
     C                     ENDDO
      * PP60
     C                     Z-ADD0         SVTOKU
     C                     Z-ADD0         SVNONY
     C                     MOVE *BLANK    SVMHIN
     C           @SDAT6    SETLLABBPL60
     C                     DO   *HIVAL
     C                     READ ABBPL60                  97
     C   97                LEAVE
      *
     C           ABSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           ABTOKU    IFNE SVTOKU
     C           ABNONY    ORNE SVNONY
     C           ABMHIN    ORNE SVMHIN
     C                     EXSR #PP60
     C                     Z-ADDABTOKU    SVTOKU
     C                     Z-ADDABNONY    SVNONY
     C                     MOVELABMHIN    SVMHIN
     C                     ENDIF
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * PP50                                               *
      *----------------------------------------------------*
     C           #PP50     BEGSR
      *
     C                     CLEARCHKWP491
     C                     Z-ADDBBTOKU    C4TOKU
     C                     Z-ADDBBNONY    C4NONY
     C                     MOVELBBMHIN    C4MHIN
     C                     MOVE 'Y'       C4PP50
     C                     MOVE ' '       C4PP60
     C                     WRITECHKWP491
      *
     C                     ENDSR
      *----------------------------------------------------*
      * PP60                                               *
      *----------------------------------------------------*
     C           #PP60     BEGSR
      *
     C                     Z-ADDABTOKU    K4TOKU
     C                     Z-ADDABNONY    K4NONY
     C                     MOVELABMHIN    K4MHIN
     C           K#49      CHAINCHKWP49              99
      *
     C           *IN99     IFEQ *OFF
     C                     MOVE 'Y'       C4PP60
     C                     UPDATCHKWP491
     C                     ELSE
     C                     CLEARCHKWP491
     C                     Z-ADDABTOKU    C4TOKU
     C                     Z-ADDABNONY    C4NONY
     C                     MOVELABMHIN    C4MHIN
     C                     MOVE ' '       C4PP50
     C                     MOVE 'Y'       C4PP60
     C                     WRITECHKWP491
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      * INITIAL SETTINGS                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           K#49      KLIST
     C                     KFLD           K4TOKU  40
     C                     KFLD           K4NONY  40
     C                     KFLD           K4MHIN 20
      *
     C                     TIME           SDATE
     C                     Z-ADD0101      @SDAT8  80
     C                     MOVEL@YEAR     @SDAT8
     C                     Z-ADD01        @SDAT6  60
     C                     MOVEL@YEAR     @SDAT6
     C                     Z-ADD0         SVTOKU  40
     C                     Z-ADD0         SVNONY  40
     C                     MOVE *BLANK    SVMHIN 20
      * DELETE CHKWP49
     C           *LOVAL    SETLLCHKWP49
     C                     DO   *HIVAL
     C                     READ CHKWP49                  99
     C   99                LEAVE
     C                     DELETCHKWP491
     C                     ENDDO
      *
     C                     ENDSR
