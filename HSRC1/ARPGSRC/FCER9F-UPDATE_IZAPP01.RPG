     C           KEY02     SETLLIZAPL01
      *-------------------------
S1   C                     DO   *HIVAL
     C           KEY02     READEIZAPL01                  92
     C   92                LEAVE
 S2  C           ZCSKJY    IFEQ 'D'
     C           ZCSKHZ    ANDLE*DATE
     C                     ITER
 E2  C                     ENDIF
     C***
 S2  C           *DATE     IFGE ZCUKHZ
     C           *DATE     ANDLEZCSTHZ
     C                     MOVE '*'       WFLG
     C                     LEAVE
 E2  C                     ENDIF
     C***
E1   C                     ENDDO
