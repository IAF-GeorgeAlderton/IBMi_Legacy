S1   C           WFLG      IFEQ *BLANK
     C                     MOVE *BLANK    ZCSKJY
     C                     Z-ADD0         ZCSKHZ
     C                     Z-ADD*DATE     ZCKOHZ
     C                     TIME           ZCKOTM
     C                     MOVEL@@USER    ZCKOME
     C                     MOVE 'Z'       ZCKOME
     C                     Z-ADDK@KOJE    ZCKOJE
     C                     MOVELK@ZAIS    ZCZAIS
     C                     Z-ADDK@ZAIK    ZCZAIK
     C                     Z-ADDK@KAKE    ZCKAKE
     C                     MOVE 'W'       ZCKNO2
     C                     Z-ADDWBMSJR    ZCMSJR
     C                     Z-ADDK@BZIK    ZCBZIK
     C                     Z-ADD*DATE     ZCUKHZ
     C                     Z-ADD01        ZCUBIN
     C                     Z-ADD99999999  ZCSTHZ
     C                     Z-ADD99        ZCSBIN
     C                     MOVE '2'       ZCDTKO
     C                     MOVE *BLANK    ZCDTHE
     C                     MOVE '0'       ZCKOSN
     C                     Z-ADD0         ZCSRMS
     C                     Z-ADD0         ZCALHK
     C                     Z-ADD0         ZCMXHK
     C                     MOVE *BLANK    ZCKSHK
     C                     MOVE *BLANK    ZCKOUT
     C                     MOVE *BLANK    ZCDOUT
      *
     C                     SETOF                     11
     C           1         CHAINIZAPPNO              11
 S2  C           *IN11     IFEQ '0'
     C                     MOVE @BRECD    #BRECD  40
     C                     ADD  1         #BRECD
     C                     MOVE #BRECD    @BRECD
     C                     EXCPTUPZA
 X2  C                     ELSE
      *
     C                     MOVE '0001'    @BRECD
     C                     EXCPTWTZA
 E2  C                     ENDIF
      *
     C                     MOVE @BRECD    ZCKNO3
      *
     C                     MOVE *BLANK    ZCKOJK
     C                     MOVE *BLANK    ZCKAKK
     C                     MOVE *BLANK    ZCKNO1
     C                     MOVE *BLANK    ZCKNOE
     C                     Z-ADD0         ZCTKJR
     C                     Z-ADD0         ZCNISG
     C                     EXSR #SB110
     C                     MOVE WZIRO     ZCZIRO
     C                     Z-ADD0         ZCMKJR
     C                     MOVE *BLANK    ZCADR1
     C                     MOVE *BLANK    ZCADR2
     C                     MOVE *BLANK    ZCADR3
     C                     MOVE *BLANK    ZCADR4
     C                     MOVE *BLANK    ZCUKIR
     C                     Z-ADD0         ZCLOTO
     C                     Z-ADD0         ZCMSSU
     C                     Z-ADD0         ZCSLTM
     C                     Z-ADD0         ZCKEIS
     C                     Z-ADD0         ZCSETI
     C                     Z-ADD0         ZCKMAL
     C                     Z-ADD0         ZCKMMN
     C                     Z-ADD0         ZCKMMX
     C                     Z-ADD0         ZCCHOS
     C                     MOVE *BLANK    ZCYOSI
     C                     MOVE *BLANK    ZCBAD1
     C                     MOVE *BLANK    ZCBAD2
     C                     MOVE *BLANK    ZCBAD3
     C                     MOVE *BLANK    ZCBAD4
     C                     MOVE *BLANK    ZCKIBN
     C                     MOVE *BLANK    ZCSNJ1
     C                     MOVE *BLANK    ZCSNJ2
     C                     MOVE *BLANK    ZCSNJ3
     C                     MOVE *BLANK    ZCSNJ4
     C                     MOVE *BLANK    ZCKHKO
     C                     MOVE *BLANK    ZCDHKO
     C                     Z-ADD0         ZCBZJR
     C                     WRITEIZAPL011
E1   C                     ENDIF
