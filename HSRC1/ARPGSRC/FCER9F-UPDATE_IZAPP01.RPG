      *================================================================
      *           完成材かんばんマスター更新              *
      *================================================================
     C                     MOVE *BLANK    WFLG    1
      *
     C                     Z-ADD*DATE     WKHZ
     C                     Z-ADD01        WKBI
     C                     Z-ADD0         WZYMD
     C           KEY1      KLIST
     C                     KFLD           WKYY
     C                     KFLD           WKMM
     C                     KFLD           WKDD
     C           KEY1      SETLLAGDPL121
     C                     SETOF                     10
     C                     READPAGDPL121                 10
     C           *IN10     IFEQ '0'
     C                     Z-ADDF8KAYY    WZYY
     C                     Z-ADDF8KAMM    WZMM
     C                     Z-ADDF8KADD    WZDD
     C                     END
      *
     C           *LOVAL    SETLLIZAPL01
      *-------------------------
S1   C                     DO   *HIVAL
     C                     READ IZAPL01                  90
     C   90                LEAVE
      *
 S2  C           ZCSKJY    IFEQ 'D'
     C           ZCSKHZ    ANDLE*DATE
     C                     ITER
 E2  C                     ENDIF
     C***
     C                     EXSR #PP10
     C***
 S2  C           *DATE     IFGE ZCUKHZ
     C           *DATE     ANDLEZCSTHZ
     C*<<      >>
     C*****PP10無
  S3 C           CFLG      IFEQ *BLANK                     失効
     C                     Z-ADD*DATE     ZCKOHZ
     C                     TIME           ZCKOTM
     C                     MOVEL@@USER    ZCKOME
     C                     MOVE 'Z'       ZCKOME
     C                     Z-ADDWZYMD     ZCSTHZ
     C                     Z-ADD01        ZCSBIN
     C                     UPDATIZAPL011
  X3 C                     ELSE
     C*****PP10あり
  S4 C           ZCMSJR    IFNE WBMSJR
     C                     MOVE *BLANK    ZCSKJY
     C                     Z-ADD0         ZCSKHZ
     C                     Z-ADD*DATE     ZCKOHZ
     C                     TIME           ZCKOTM
     C                     MOVEL@@USER    ZCKOME
     C                     MOVE 'Z'       ZCKOME
     C                     Z-ADDWBMSJR    ZCMSJR
  S5 C           ZCDTKO    IFNE '2'
     C                     MOVE '3'       ZCDTKO
  E5 C                     END
     C                     MOVE *BLANK    ZCDTHE
     C                     UPDATIZAPL011
  E4 C                     ENDIF
  E3 C                     ENDIF
     C*****
 X2  C                     ELSE
     C*<<      >>
  S3 C           ZCUKHZ    IFEQ *DATE
  E3 C                     END
     C***
 E2  C                     ENDIF
      *
E1   C                     ENDDO
      *-------------------------
      *-------------------------
     C           KEY02     KLIST
     C                     KFLD           K@ZAIS 15        MATERIAL
     C                     KFLD           K@ZAIK  52       DTAMETER
     C                     KFLD           K@KOJE  40       PLANT COAD
     C                     KFLD           K@KAKE  40       SUPPLIER
     C           *LOVAL    SETLLIZAPL10
      *-------------------------
S1   C                     DO   *HIVAL
     C                     READ IZAPL10                  90
     C   90                LEAVE
 S2  C           ZBSKJY    IFEQ 'D'
     C           ZBSKHZ    ANDLE*DATE
     C                     ITER
 E2  C                     ENDIF
     C*
     C                     MOVELZBZAIS    K@ZAIS 15        MATERIAL
     C                     Z-ADDZBZAIK    K@ZAIK  52       DTAMETER
     C                     Z-ADDZBKOJE    K@KOJE  40       PLANT COAD
     C                     Z-ADDZBKAKE    K@KAKE  40       SUPPLIER
     C                     Z-ADDZBBZIK    K@BZIK  52       DIAMETER OF ROD
     C                     MOVE *BLANK    CFLG    1
     C                     Z-ADD0         WBMSJR  80
     C*
     C           KEY02     SETLLIZAPL10
 S2  C                     DO   *HIVAL
     C           KEY02     READEIZAPL10                  91
     C   91                LEAVE
  S3 C           ZBSKJY    IFEQ 'D'
     C           ZBSKHZ    ANDLE*DATE
     C                     ITER
  E3 C                     ENDIF
     C                     ADD  ZBMSJR    WBMSJR
     C                     MOVE '*'       CFLG
 E2  C                     ENDDO
     C*
     C           CFLG      IFEQ '*'
     C                     EXSR #PP01
     C                     ENDIF
     C*
     C           KEY02     SETGTIZAPL10
E1   C                     ENDDO
      *-------------------------
      *
     C                     SETON                     LR
     C                     RETRN
      *================================================================
      * FINISHED MATERIAL KANBAN MASTER FILE *
      *================================================================
     C           #PP10     BEGSR
      *
     C           KEY01     KLIST
     C                     KFLD           ZCZAIS
     C                     KFLD           ZCZAIK
     C                     KFLD           ZCKOJE
     C                     KFLD           ZCKAKE
      *
     C                     Z-ADD0         WBMSJR  80
     C                     MOVE *BLANK    CFLG    1
     C           KEY01     SETLLIZAPL101
      *-------------------------
S1   C                     DO   *HIVAL
     C           KEY01     READEIZAPL101                 91
     C   91                LEAVE
 S2  C           ZBSKJY    IFEQ 'D'
     C           ZBSKHZ    ANDLE*DATE
 X2  C                     ELSE
     C                     MOVE '*'       CFLG
     C                     ADD  ZBMSJR    WBMSJR
 E2  C                     ENDIF
E1   C                     ENDDO
      *-------------------------
