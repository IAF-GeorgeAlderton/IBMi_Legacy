      * --------------------------------------
     C* CHECK(PICK-UP LIST TYPE)
      * --------------------------------------
      * IF CANCEL MODE, SKIP TO STP4
     C           @COD      IFEQ '0'
     C                     GOTO STP4
     C                     ENDIF
      * CHECK LIST TYPE
     C           YATYPE    IFEQ *BLANK
     C  N99                MOVELER,6      MSG              ENTER LIST TYPE
     C                     SETON                     01  99
     C                     GOTO STP3
     C                     ENDIF
      *
     C           YATYPE    IFNE '01'
     C           YATYPE    ANDNE'02'
     C           YATYPE    ANDNE'03'
     C           YATYPE    ANDNE'04'
     C           YATYPE    ANDNE'05'
     C           YATYPE    ANDNE'06'
     C           YATYPE    ANDNE'07'
     C           YATYPE    ANDNE'08'
     C           YATYPE    ANDNE'09'
     C           YATYPE    ANDNE'10'
     C  N99                MOVELER,7      MSG              ENTER LIST TYPE 01 TO 10
     C                     SETON                     01  99
     C                     GOTO STP3
     C                     END
     C*
     C           DMXPL     IFEQ 0
     C           DMXPL     ORGT 999
     C  N99                MOVELER,16     MSG              INVALID MAX. BOXES OF PALLET
     C                     SETON                     02  99
     C                     GOTO STP3
     C                     ENDIF
     C*
     C* CHECK(NUMBER OF PICK-UP LIST)
     C           DPICK     IFEQ 0
     C  N99                MOVELER,10     MSG              ENTER # OF PACKING LIS
     C                     SETON                     03  99
     C                     GOTO STP3
     C                     END
     C*
     C* CHECK(MIX PALLET LIST)
     C           DMIX      IFEQ 0
     C                     ENDIF
     C*
     C* CHECK(NUMBER OF LABEL)
     C           D#LAB     IFEQ 0
     C  N99                MOVELER,11     MSG              ENTER # OF LABEL
     C                     SETON                     05  99
     C                     GOTO STP3
     C                     ENDIF
     C*
     C* CHECK(TRANSPORTATION)
     C           DCUST     IFEQ 0
     C           DTRAN     IFNE *BLANK
     C  N99                MOVELER,12     MSG              TRANSPORTATION USED FOR CUSTOM SHEET
     C                     SETON                     06  99
     C                     GOTO STP3
     C                     ENDIF
     C*
     C                     ELSE
     C           DTRAN     IFEQ *BLANK
     C  N99                MOVELER,12     MSG              TRANSPORTATION USED FOR CUSTOM SHEET
     C                     SETON                     06  99
     C                     GOTO STP3
     C                     ENDIF
     C                     ENDIF
     C*
     C* CHECK(CUSTOM SHEET TYPE)
     C           DCUST     IFEQ 0
     C           DCTYP     ANDNE*BLANKS
     C  N99                MOVELER,17     MSG              CUSTOM SHEET TYPE SHOULD BE BLANK
     C                     SETON                     07  99
     C                     GOTO STP3
     C                     ENDIF
      *
     C* TYPE 03 FOR MEXICO IS NOT USED ANY MORE
     C           DCUST     IFNE 0
     C           DCTYP     IFNE '01'
     C           DCTYP     ANDNE'02'
     C  N99                MOVELER,13     MSG              ENTER 01 OR 02 FOR CUSTOM SHEET TYPE
     C                     SETON                     07  99
     C                     GOTO STP3
     C                     ENDIF
     C                     ENDIF
     C* CHECK COUNTRY
     C           DCUST     IFEQ 0
     C           DCNAM     IFNE *BLANK
     C  N99                MOVELER,14     MSG              COUNTRY SHOULD BE BLANK WHEN CUST = BLANK
     C                     SETON                     08  99
     C                     GOTO STP3
     C                     ENDIF
     C                     ELSE
     C           DCNAM     IFEQ *BLANK
     C  N99                MOVELER,15     MSG              ENTER COUNTRY
     C                     SETON                     08  99
     C                     GOTO STP3
     C                     ENDIF
     C                     ENDIF
      *
