     C                     ENDIF
      * 4.
     C           @KK       IFEQ 'E'
     C           KEY1      SETLLAAHTL061
     C           *IN91     DOUEQ*ON
     C           KEY1      READEAAHTL061                 91
     C           *IN91     IFEQ '0'
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
PATCHC*          *DATE     IFGE L6UKHZ
PATCHC*          *DATE     ANDLEL6STHZ
PATCHC           W@DATE    IFGE L6UKHZ
PATCHC           W@DATE    ANDLEL6STHZ
     C           L6ATOB    IFNE @SUPP
     C                     SETON                     30
     C                     MOVE ER,10     MSG
     C                     GOTO #ECHK1
     C                     END
     C                     Z-ADDL6SYOS    @@QTY
JW4  C                     MOVEL'L6SYOS  'ADFIL2
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C           #ECHK0    TAG
     C                     MOVE A2BHB1    WWBHB1           INTERNAL PART
     C                     MOVE A2BHB2    WWBHB2
     C                     MOVE A2BHB3    WWBHB3
      * 5.
     C**JW2      @@QTY     IFEQ 0
     C**                   Z-ADDA2SSYS    @@QTY   50       QTY/CONT.
     C**                   ENDIF
      *
     C           #ECHK1    TAG
      *
     C           *IN99     IFEQ *ON
     C           *IN30     ANDEQ*OFF
     C                     ADD  1         @@RRN
     C           SUPLY     IFEQ '2888'
     C           SUPLY     ORNE '2888'
     C           KCLAS     ANDEQ'A'
     C                     EXSR #LOT
     C                     ADD  @@LOT     @C
     C                     ELSE
     C                     ADD  1         @C
     C                     ENDIF
     C                     MOVE BARCD     BR,@C
      * WRITE A RECORD TO WORK FILE
     C                     ADD  1         @B
     C                     Z-ADD@A        AWSEQ
     C                     MOVE *BLANK    AWUPD
     C                     WRITEAFDWP011
      *
     C           @@RRN     CHAINSFL01                90
     C                     MOVE BARCD     S@BAR
     C                     Z-ADD@@RRN     S@NBR
     C           *IN90     IFEQ *OFF
     C                     UPDATSFL01
     C                     ELSE
     C                     Z-ADD@@RRN     RRN1
     C                     WRITESFL01
     C                     ENDIF
     C                     Z-ADDRRN1      #RCNO
      *
     C                     MOVE *BLANK    BARCD
     C                     ENDIF
      *
     C           @CNT      IFEQ 1
     C                     MOVE *ON       *IN88
     C                     ELSE
     C                     MOVE *OFF      *IN88
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*   LOT
     C**************************************************************************
     C           #LOT      BEGSR
      *
     C                     Z-ADD*ZERO     @@LOT   50
      *
     C           K#KEY     SETLLABHPL02
     C           *IN95     DOUEQ*ON
     C           K#KEY     READEABHPL02                  95
     C           *IN95     IFEQ *OFF
      * %0002
     C                     MOVEL*BLANK    WAKT    3
     C           M6AKT1    IFNE *BLANK
     C                     MOVELM6AKT1    WAKT
     C                     ENDIF
     C           M6AKT2    IFNE *BLANK
     C                     MOVELM6AKT2    WAKT
     C                     ENDIF
     C           M6AKT3    IFNE *BLANK
     C                     MOVELM6AKT3    WAKT
     C                     ENDIF
     C           M6AKT4    IFNE *BLANK
     C                     MOVELM6AKT4    WAKT
     C                     ENDIF
      *
     C           BPROC     IFNE WAKT
     C                     ITER
     C                     ENDIF
      *
     C           M6SKJY    IFEQ *BLANK
     C           M6STHZ    ANDEQ99999999
     C                     Z-ADDM6LOTK    @@LOT
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           @@LOT     IFEQ *ZERO
     C**JW3                ADD  1         @@LOT
JW3  C                     ADD  16        @@LOT
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*   2ND SCREEN
     C**************************************************************************
     C           #DSP02    BEGSR
     C*
     C                     MOVELCMD,3     D@KEY
     C                     WRITEDSP99
     C                     MOVE *ON       *IN53
     C                     EXFMTCTL02
     C                     MOVE *OFF      *IN53
      *
TCHKBC                     DO
TCHKBC*
B02  C           *INKC     IFEQ '1'
     C           BARC2     IFEQ *BLANK
     C           @B        ANDGT*ZERO
     C           SUPLY     ANDEQ'2888'
     C                     EXSR @WRT
     C                     EXFMTDSPOK
     C                     EXSR @RSET
     C                     ENDIF
     C                     MOVEL'99'      @@ID    2
     C*
     C                     ELSE
     C                     EXSR @CHK2
     C*
B04  C           *IN99     IFEQ '0'
TCHKBC           SUPLY     IFEQ '4444'
TCHKBC           @L        ANDEQ4
TCHKBC                     MOVE '03'      @@ID
TCHKBC                     LEAVE
TCHKBC                     END
B04  C           *IN30     IFEQ '0'
     C           @C        IFLT 32
     C                     EXSR #SET
     C                     MOVE '01'      @@ID
     C                     ELSE
     C           SUPLY     IFNE '2888'
     C                     MOVE '03'      @@ID
     C                     ELSE
     C                     EXSR #SET
     C                     MOVE '01'      @@ID
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     ELSE
     C                     EXFMTERR99
     C                     SETOF                     30
     C                     MOVE *BLANK    MSG
     C                     END
     C                     END
     C*
TCHKBC                     ENDDO
TCHKBC*
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK2
     C**************************************************************************
     C           @CHK2     BEGSR
     C*
     C                     MOVE *OFF      *IN30
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    MSG
      *
     C           BARC2     IFEQ *BLANK
     C           @@RRN2    ANDEQ*ZERO
     C                     MOVE *ON       *IN99
     C                     MOVE ER,5      MSG
     C                     ENDIF
      *
     C           BARC2     IFNE *BLANK
     C           W@LL      ANDNE*BLANK
     C                     MOVELBARC2     @@1     1
     C           @@1       IFNE W@LL
     C                     MOVE *ON       *IN99
     C                     MOVE ER,13     MSG
     C                     ENDIF
     C                     ENDIF
      *
     C           BARC2     IFNE *BLANK
     C           BARC2     LOKUPLT                       90
     C           *IN90     IFEQ *ON
     C                     MOVE *ON       *IN99
     C                     MOVE ER,9      MSG
     C                     ELSE
     C           @@RRN2    IFEQ *ZERO
     C           @@HN      ANDEQ*BLANK
     C           @@RRN2    ORLT 8
     C           @@HN      ANDNE*BLANK
     C                     MOVE *ON       *IN30
     C                     ENDIF
     C*                    ELSE
     C*                    MOVE BARC2     LT2,@B
     C**                   ENDIF
     C                     ENDIF
      *
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C           BARC2     ANDNE*BLANK
     C                     MOVELBARC2     W@LL
      *
     C                     ADD  1         @@RRN2
     C           @@RRN2    CHAINSFL02                90
     C                     MOVE BARC2     S@LOT
     C                     ADD  1         @L
     C                     MOVE BARC2     LT,@L
      * WRITE A RECORD TO WORK FILE
     C                     Z-ADD@A        A2SEQ
     C                     MOVE *BLANK    A2UPD
     C                     WRITEAFDWP021
      *
     C           *IN90     IFEQ *OFF
     C                     UPDATSFL02
     C                     ELSE
     C                     Z-ADD@@RRN2    RRN2
     C                     WRITESFL02
     C                     ENDIF
      *
     C                     MOVE *BLANK    BARC2
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*   3RD SCREEN
     C**************************************************************************
     C           #DSP03    BEGSR
     C*
     C                     MOVELCMD,2     D@KEY
     C                     WRITEDSP99
     C                     EXFMTDSP03
      *
B02  C           *INKC     IFEQ '1'
     C                     MOVEL'99'      @@ID    2
     C*
     C                     ELSE
     C                     EXSR @CHK3
     C*
B04  C           *IN30     IFEQ '0'
      ***
     C                     MOVE *BLANK    VERIFY  1
     C           VERIFY    DOUEQ'Y'
     C           *INKJ     OREQ *ON
     C                     EXSR #DSP05
     C           *INKJ     IFEQ *ON
     C                     GOTO ##END3
     C                     ELSE
     C                     MOVE 'Y'       VERIFY
     C                     ENDIF
     C                     ENDDO
      ***
     C                     EXSR @WRT
      *
     C                     EXFMTDSPOK
     C                     EXSR @RSET
      *
     C                     EXSR #SET
     C                     MOVE '01'      @@ID
     C                     ELSE
     C                     EXFMTERR99
     C                     SETOF                     30
     C                     MOVE *BLANK    MSG
     C                     END
     C                     END
     C*
     C           ##END3    ENDSR
     C**************************************************************************
     C*   4TH SCREEN
     C**************************************************************************
     C           #DSP04    BEGSR
      *
     C                     Z-ADD@C        NEW@C
      *
      * get maximum qty for number of kanbans scanned
     C           RRN1      MULT @@LOT     MAXQTY  50
      *
      * get minimum qty for number of kanbans scanned
     C           RRN1      SUB  1         MINKBN  40
     C           MINKBN    MULT @@LOT     MINQTY  50
     C                     ADD  1         MINQTY
      *
     C                     DO   *HIVAL
      *
     C                     EXFMTDSP04
     C                     MOVE *BLANKS   MSG
      *
     C           *INKJ     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C           NEW@C     IFGT MAXQTY
     C                     MOVELER,15     MSG
     C                     EXFMTERR99
     C                     ITER
     C                     ENDIF
      *
     C           NEW@C     IFLT MINQTY
     C                     MOVELER,16     MSG
     C                     MOVE MINQTY    MSG
     C                     EXFMTERR99
     C                     ITER
     C                     ELSE
     C                     Z-ADDNEW@C     @C
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
     C**************************************************************************
     C*   5TH SCREEN  -   VERIFY BIN # IS CORRECT
     C**************************************************************************
     C           #DSP05    BEGSR
      *
     C                     MOVE BARC3     BINCHR  3
     C                     MOVEABINCHR    WW
      *
     C           1         DO   3         CC      10
     C                     MOVE *BLANKS   #L1
     C                     MOVE *BLANKS   #L2
     C                     MOVE *BLANKS   #L3
     C                     MOVE *BLANKS   #L4
     C                     MOVE *BLANKS   #L5
     C                     MOVE *BLANKS   #L6
     C                     MOVE *BLANKS   #L7
     C                     MOVE *BLANKS   #L8
     C                     MOVE WW,CC     #CHR
      *
     C                     SELEC
     C           #CHR      WHGE '0'
     C           #CHR      ANDLE'9'
     C                     CALL 'AB#R4P'  P#CMD
     C           #CHR      WHGE 'A'
     C           #CHR      ANDLE'Z'
     C                     CALL 'AB#R4O'  P#CMD
     C                     ENDSL
      *
     C           CC        IFEQ 1
     C                     MOVE #L1       DGT11
     C                     MOVE #L2       DGT12
     C                     MOVE #L3       DGT13
     C                     MOVE #L4       DGT14
     C                     MOVE #L5       DGT15
     C                     MOVE #L6       DGT16
     C                     MOVE #L7       DGT17
     C                     MOVE #L8       DGT18
     C                     ENDIF
     C           CC        IFEQ 2
     C                     MOVE #L1       DGT21
     C                     MOVE #L2       DGT22
     C                     MOVE #L3       DGT23
     C                     MOVE #L4       DGT24
     C                     MOVE #L5       DGT25
     C                     MOVE #L6       DGT26
     C                     MOVE #L7       DGT27
     C                     MOVE #L8       DGT28
     C                     ENDIF
     C           CC        IFEQ 3
     C                     MOVE #L1       DGT31
     C                     MOVE #L2       DGT32
     C                     MOVE #L3       DGT33
     C                     MOVE #L4       DGT34
     C                     MOVE #L5       DGT35
     C                     MOVE #L6       DGT36
     C                     MOVE #L7       DGT37
     C                     MOVE #L8       DGT38
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     EXFMTDSP05
      *
     C                     ENDSR
     C**************************************************************************
     C*           RESET
     C**************************************************************************
     C           @RSET     BEGSR
      *
     C                     Z-ADD*ZERO     @A      20
     C                     Z-ADD*ZERO     @C
     C                     Z-ADD*ZERO     @B      20
     C                     Z-ADD*ZERO     @L      20
     C                     MOVE *BLANK    W@LL    1
     C                     MOVE *BLANK    BR
     C                     MOVE *BLANK    LT
     C                     MOVE *BLANK    WWBHB1           INTERNAL PART
     C                     MOVE *BLANK    WWBHB2
     C                     MOVE *BLANK    WWBHB3
      *
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK3
     C**************************************************************************
     C           @CHK3     BEGSR
     C*
     C                     MOVE *OFF      *IN30
     C                     MOVE *BLANK    MSG
      *
     C           BARC3     IFEQ *BLANKS
     C                     MOVE *ON       *IN30
     C                     MOVE ER,6      MSG
     C                     ELSE
     C                     MOVE BARC3     K@BIN
     C           K#AFD     CHAINAFDPL10              90
     C           *IN90     IFEQ *OFF
     C           ADSKJY    ANDEQ*BLANK
     C                     MOVE *ON       *IN30
     C                     MOVE ER,11     MSG
     C                     ENDIF
     C                     ENDIF
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @WRT
     C**************************************************************************
     C           @WRT      BEGSR
     C*
     C                     CLEARAFDPP101
     C                     CLEARAFDPP151
TCHK1C                     CLEARAFDPP301
     C*
     C                     Z-ADD@C        QTYREM  50       QTY REMAINING
      *
     C                     MOVE *BLANK    K@UPD
     C           K@UPD     SETLLAFDWP01
     C           *IN80     DOUEQ*ON
     C           K@UPD     READEAFDWP01                  80
     C           *IN80     IFEQ *OFF
      *
     C                     ADD  1         #TIMES  60
     C                     EXSR @WRT1
     C                     ENDIF
     C                     ENDDO
     C*
     C                     ENDSR
      *---------------------------------------------------------
     C           @WRT1     BEGSR
      *
TCHK1C*                    Z-ADD*DATE     ADKODT
TCHK1C*                    TIME           ADKOTM
TCHK1C                     TIME           WSDT
TCHK1C                     Z-ADDWSSDAT    ADKODT
TCHK1C                     Z-ADDWSSTM6    ADKOTM
     C                     MOVE PUSR      ADKOME                  USER
     C                     MOVEL#PGM      ADKOPG                  PGM-ID
     C                     MOVE PWKCD     ADWORK                  WORKER CD
     C                     MOVE BCOCD     ADKANR           CONTROL CODE
     C                     MOVE BZETI     ADZETI           ABSOLUTE
     C                     MOVE WTEHI     ADTEHI           TEHAI #
     C                     MOVE BPAGE     ADPAGE           PAGE #
     C                     MOVE BNIJI     ADNIJI           2ND TREATMENT
     C                     MOVE BTICD     ADTAIS           TARGET TYPE
     C                     MOVE BYUKO     ADSYUK           SHIP EFECTIVE
     C                     MOVE BHASY     ADHKOS           CONTAINER TYPE
     C                     MOVE BCKDT     ADCHKD           CHECK DIGIT
     C                     MOVE WWBHB1    ADPAR1           INTERNAL PART
     C                     MOVE WWBHB2    ADPAR2
     C                     MOVE WWBHB3    ADPAR3
     C                     Z-ADD@@QTY     ADSYOS           QTY/CONT.
     C                     MOVE SUPLY     ADSUPP
     C                     MOVELBARC3     ADBINN
     C           SUPLY     IFEQ '2888'
     C                     MOVE ADAD      ADBINN
     C                     ENDIF
      *
     C           K#FCE     CHAINFCEPL01              95
     C           *IN95     IFEQ *OFF
     C                     Z-ADDA2KASI    ADWGHT
      *
JW2  C           @@QTY     IFEQ 0
 |   C                     Z-ADDA2SSYS    ADSYOS           QTY/CONT
JW4  C                     MOVEL'A2SSYS  'ADFIL2
 |   C                     ENDIF
JW2   *
     C                     ENDIF
      *
     C                     MOVELPID       ADFILR
      *
      ***  if kanban is a plastic kanban, assign qty by lot size to kanbans
      ***     until remaining qty is zero.
     C           BCOCD     IFEQ '0'
     C           BCOCD     OREQ '2'
     C           BCOCD     OREQ '9'
      *
     C           QTYREM    IFGT @@LOT
     C                     Z-ADD@@LOT     ADCQTY           # CONTAINERS
     C                     SUB  @@LOT     QTYREM           QTY REMAINING
     C                     ELSE
     C                     Z-ADDQTYREM    ADCQTY
     C                     Z-ADD*ZERO     QTYREM
     C                     ENDIF
      *
     C                     ELSE
     C                     Z-ADD*ZERO     ADCQTY
     C                     SUB  @@LOT     QTYREM           QTY REMAINING
     C                     ENDIF
      *
     C                     WRITEAFDPP101
      *
      * call pgm to update/remove from outsource store in file
     C                     MOVEL#PGM      P#PGM     P
     C                     MOVELBARCD     PBARCD 20 P
      *
     C                     CALL 'AFDR9U'
     C                     PARM           PWKCD
     C                     PARM           P#PGM
     C                     PARM           PBARCD
      *
TCHK1C                     WRITEAFDPP301
JW3   * CREATE AFDPP12
 |   C                     TIME           SDATE
 |   C                     Z-ADDTODAY     ADCRDT
 |   C                     Z-ADDNOW       ADCRTM
 |   C                     MOVEL#USER     ADCRME
 |   C                     MOVEL#WSID     ADCRWS
 |   C                     MOVEL#PGM      ADCRPG
 |   C                     MOVELBARCD     ADBAR
JW3  C                     WRITEAFDPP121
      *
     C                     MOVE '1'       AWUPD
     C                     UPDATAFDWP011
      *
     C                     Z-ADDAWSEQ     K@SEQ
     C           K#W2      SETLLAFDWP02
     C           *IN81     DOUEQ*ON
     C           K#W2      READEAFDWP02                  81
     C           *IN81     IFEQ *OFF
     C                     Z-ADDADKODT    A5KODT
     C                     Z-ADDADKOTM    A5KOTM
     C                     MOVE ADKOME    A5KOME                  USER
     C                     MOVEL#PGM      A5KOPG                  PGM-ID
     C                     MOVE ADWORK    A5WORK                  WORKER CD
     C                     MOVE ADKANR    A5KANR           CONTROL CODE
     C                     MOVE ADZETI    A5ZETI           ABSOLUTE
     C                     MOVE ADTEHI    A5TEHI           TEHAI #
     C                     MOVE ADPAGE    A5PAGE           PAGE #
     C                     MOVE ADNIJI    A5NIJI           2ND TREATMENT
     C                     MOVE ADTAIS    A5TAIS           TARGET TYPE
     C                     MOVE ADSYUK    A5SYUK           SHIP EFECTIVE
     C                     MOVE ADHKOS    A5HKOS           CONTAINER TYPE
     C                     MOVE ADCHKD    A5CHKD           CHECK DIGIT
     C                     MOVE ADSUPP    A5SUPP
     C                     MOVELADFILR    A5FILR
     C                     MOVE BARC2     A5LTNO
     C                     Z-ADDADKODT    A5SCDT
     C                     Z-ADDADKOTM    A5SCTM
     C                     MOVELBARC3     A5BINN
     C                     WRITEAFDPP151
      *
     C                     MOVE '1'       A2UPD
     C                     UPDATAFDWP021
      *
     C                     MOVEL#PGM      P#PGM  10 P
     C                     CALL 'AFDROSU'
     C                     PARM           PWKCD
     C                     PARM           P#PGM
     C                     PARM           A5ZETI
     C                     PARM           A5LTNO
     C                     PARM           A5BINN
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *
** CMD
F3:END F4:BN F6:LT F9:QTY
F3:END
F3:END ENTR:NEXT
F3:END F6:LT
** ERROR MESSAGE (ER,)
BARCODE BLANK          01
CONTROL CODE           02
ABSOLUTE NO.           03
ALREADY SCANNED        04
LOT NUMBER             05
BIN# ERROR             06
COMPLET. WEIGHT        07
PARTS ERROR            08
DUPLICATE ERROR        09
NOT THIS SUPPLY        10
ALREADY SCANNED        11
NOT IAF PRODUCT        12
CONTACT T/L            13
KANBAN ERROR           14
ONLY LOWER QTY         15
MIN QTY =              16
** TAB1 / TAB2
2222 ** TO CURTIS **
2111 ** TO FOREST **
2333 **  TO J&M   **
2444 **  TO ELM   **
2666 **  TO MMC   **
2555 **  TO MAC   **
2777 **  TO MPI   **
28881* TO T&S(RC) **
28882* TO T&S(HN) **
2999 **  TO EMT   **
2424 **  TO PTC   **
2929 ** TO DEPOR  **
2828 **  TO SWD   **
4444 * TO ROCKFORD *
2112 **  TO FCO   **
** KBN
APICS KANBAN:
RETRIEVAL KAN
INTRA KANBAN:
