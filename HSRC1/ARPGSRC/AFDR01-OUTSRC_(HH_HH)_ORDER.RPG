JW4  C                     MOVEL'Z-ADD 0 'ADFIL2
      *
      ***  if kanban scanned is an in process kanban, set flag @@HN = ON.
      ***     this will allow more than 2 Lot ID tags to be scanned.
     C           BARCD     IFNE *BLANK
     C           HNHN      IFEQ 'AHN'
     C           HNHN      OREQ 'ABZ'
TCHK7C           HNHN      OREQ 'AGF'
TCHKBC           HNHN      OREQ 'ACU'
     C           HNHN      OREQ 'ASD'
     C           HNHN      OREQ 'ATC'
     C           HNHN      OREQ 'AJC'
     C           HNHN      OREQ 'ADS'
     C           HNHN      OREQ 'ANP'
