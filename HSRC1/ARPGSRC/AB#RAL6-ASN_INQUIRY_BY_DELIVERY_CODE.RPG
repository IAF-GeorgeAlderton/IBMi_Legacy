      ********************************************************
     FAB#PL78BIF  E           K        DISK
      ********************************************************
     I            DS
     I                                        1   80P8NOHZ
     I                                        1   40P8NOYY
     I                                        5   60P8NOMM
     I                                        7   80P8NODD
      *
     I            DS
     I                                        1   80K#NOHZ
     I                                        1   40K#NOYY
     I                                        5   60K#NOMM
     I                                        7   80K#NODD
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *-----------------------------------------------------------*
      *     M  A  I  N  L  I  N  E      SFL1                      *
      *-----------------------------------------------------------*
      *
     C                     EXSR #INIT
      *
      *
     C                     SETON                     LR
     C                     RETRN
      ************************************************************
      *  SET DATA FOR SFL01
      ************************************************************
     C           #SET1     BEGSR
      *
     C                     EXSR #CLRS1
      *
     C                     Z-ADD@NONY     K#NONY
     C                     Z-ADD@ASNFR    K#NOHZ
     C           K#78B     SETLLAB#PL78B
     C                     DO   *HIVAL
     C           @NONY     READEAB#PL78B                 97
     C   97                LEAVE
      * IGNORE
     C           P8SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * END?
     C           P8NOHZ    IFGT @ASNTO
     C                     LEAVE
     C                     ENDIF
      *
     C                     CLEARSFL01
     C                     Z-ADDP8NOHZ    S1NOHZ
     C                     MOVELP8BINN    S1BIN
     C                     MOVELP8SERL    S1SERL
     C**                   MOVELP8NKOJ    S1NKOJ
     C                     MOVELP8NUKE    S1NUKE
     C                     MOVELP8ODRN    S1ODRN
     C                     Z-ADDP8PLDT    S1PLHZ
     C                     Z-ADDP8PLTM    S1PLTM
     C                     MOVELP8PLNM    S1PLUS
     C                     ADD  1         RRN1
     C                     WRITESFL01
      *
     C                     ENDDO
      *
     C                     Z-ADDRRN1      RCNT
      *
     C                     ENDSR
      ************************************************************
      *  DSPLAY 2ND SCREEN
      ************************************************************
     C           #SFL1     BEGSR
      *
     C                     EXSR #SET1
      *
     C                     WRITEDSP99
     C                     MOVEL'1'       *IN70
     C                     EXFMTCTL01
     C                     MOVEL*BLANKS   XMSG
     C                     MOVEL'0'       *IN85
     C                     MOVEL'0'       *IN70
      *
     C                     SELEC
      * F3: EXIT
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * F12: BACK
     C           *INKL     WHEQ *ON
     C                     EXSR #SEL
     C           S1SELX    IFEQ 'P'
     C                     MOVEL'99'      W@ID
     C                     ELSE
     C                     MOVE '01'      W@ID
     C                     MOVE *BLANK    $SERL
     C                     ENDIF
      * ENTER
     C                     OTHER
     C                     EXSR #SEL
     C           S1SELX    IFEQ 'P'
     C                     MOVEL'99'      W@ID
     C                     ELSE
     C           S1SELX    IFNE *BLANK
     C                     CALL 'AB#R985'                  PL INQ
     C                     PARM           $SERL
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************
      * CLEAR SUB FILE 01
      *************************************************************
     C           #CLRS1    BEGSR
      *
     C                     SETON                     71
     C                     WRITECTL01
     C                     SETOF                     71
     C                     Z-ADD0         RRN1
      *
     C                     ENDSR
      *************************************************************
      * CHECK SELECTION
      *************************************************************
     C           #SEL      BEGSR
      *
     C                     MOVE *BLANK    S1SELX  1
     C           1         DO   RCNT      RRN1
      *
     C           RRN1      CHAINSFL01                50
     C           *IN50     IFEQ *OFF
     C           S1SEL     ANDNE' '
     C                     MOVELS1SERL    $SERL
     C                     MOVELS1SEL     S1SELX
     C                     MOVE *BLANK    S1SEL
     C                     UPDATSFL01
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************
      * INITIAL SETTING
      *************************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4        IN
     C                     PARM           $ASFR   8        IN
     C                     PARM           $ASTO   8        IN
     C                     PARM           $SHFR   8        IN
     C                     PARM           $SHTO   8        IN
      *
     C           K#78B     KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#NOYY  40
     C                     KFLD           K#NOMM  20
     C                     KFLD           K#NODD  20
      *
     C                     TIME           SDATE
     C                     MOVEL$NONY     @NONY   40
     C                     MOVEL$ASFR     @ASFR   80
     C                     MOVEL$ASTO     @ASTO   80
     C                     MOVEL$SHFR     @SHFR   80
     C                     MOVEL$SHTO     @SHTO   80
      *
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         RCNT    40
      *
     C                     ENDSR
