     H            Y.
     F*** FCER60 *****************************
     F* SERVICE PARTS M/F MAINTENANCE      *
     F*                                      *
     F***************************** FCER60 ***
     FFCEWRK1 IP  F      92            DISK
     FFCEPP30 O   E                    DISK                      A
     FFCEPL01 IF  E           K        DISK
     IFCEWRK1 AA  01
     I                                       45  49 PRT1
     I                                       53  57 PRT2
     I                                       61  62 PRT3
     I                                       69  69 LOC1
     I                                       77  78 LOC2
     I                                       85  86 LOC3
     I            DS
     I                                        1   80A2SYMD
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
     I            DS
     I                                        1   80A2TYMD
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *****************************************************
      *  MAIN ROUTINE
      *****************************************************
     C           K#KEY     KLIST
     C                     KFLD           PRT1
     C                     KFLD           PRT2
     C                     KFLD           PRT3
      *
     C           PRT1      IFNE *BLANK
     C                     CLEARFCEPP301
     C                     Z-ADD*DATE     F3GKDT
     C                     TIME           F3GTIM
     C                     MOVEL#USER     F3GKNM
     C                     MOVELPRT1      F3BHB1
     C                     MOVELPRT2      F3BHB2
     C                     MOVELPRT3      F3BHB3
     C                     MOVE LOC1      F3STRK
     C                     MOVE LOC2      F3STRT
     C                     MOVE LOC3      F3STRR
     C                     MOVE '0'       F3STRD
     C                     MOVE 'G'       F3TEHI
     C           K#KEY     CHAINFCEPL01              90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDA2TYMD    F3TYMD
     C                     Z-ADDA2KASI    F3KASI
     C                     MOVELA2DMEI    F3DMEI
     C                     MOVELA2SMEI    F3SMEI
     C                     MOVELA2ZETI    F3ZETI
     C                     Z-ADDA2SSYS    F3SSYS
     C                     MOVELA2STRK    F3PTRK
     C                     MOVELA2STRT    F3PTRT
     C                     MOVELA2STRR    F3PTRR
     C                     MOVELA2STRD    F3PTRD
     C                     Z-ADDA2SYMD    F3SYMD
     C                     ENDIF
      *
     C                     WRITEFCEPP301
     C                     ENDIF
      *
