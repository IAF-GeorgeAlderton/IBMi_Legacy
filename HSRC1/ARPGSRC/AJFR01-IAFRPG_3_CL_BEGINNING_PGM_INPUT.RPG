     FAJFPW01 CF  E                    WORKSTN
     FAJFPW05 CF  E                    WORKSTN
     E                    TB0     1  22  1               ﾆ] ﾎﾟﾜhﾞ[w-1
     E                    TB1     1  18  1               ﾎﾟﾜhﾞ[w-1
     E                    TB2     1   5  1   TB3     7   ﾎﾟﾜhﾞ[w-4
     E                    TB9     1   5  1   TB10    5   ﾎﾟﾜhﾞ[wjbﾎﾟ
     E                    TBA     1   9  1   TBB    10   ﾆ] ｰﾇﾎｦbﾓ
     E                    TBC     1   9  1   TBD    10   ﾆ] ﾎﾟﾜhﾞ[wjbﾎﾟ
     E                    ER      1   3 60               d[ｰxｮﾈｰﾆﾞ
     I            DS
     I                                        1   6 APGM
     I                                        1   1 WA1
     I                                        4   4 WA4
     I                                        6   6 WA6
     I            DS
     I                                        1   8 WSRC
     I                                        1   1 WSRC1
     I                                        2   8 WSRC2
      *
     C           *ENTRY    PLIST
     C                     PARM           PLIB    8
     C                     PARM           PSRC    8
     C                     PARM           PPGM    6
     C                     PARM           PTYP    5
     C                     PARM           PUSR   10
      *
     C                     MOVELPUSR      WUSR    5
     C           WUSR      IFEQ 'TEST '
     C                     SETON                     88
     C                     END
      *
     C           STP1      TAG
     C                     EXFMTAJFPW011
     C                     SETOF                     0199
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C*------------*
     C*  ..HELP..  *
     C*------------*
     C           *IN50     IFEQ '1'
     C                     EXFMTAJFPW051
     C                     GOTO STP1
     C                     END
      *
     C*---------------*
     C*  ..ﾎﾟﾜhﾞ[w..  *
     C*---------------*
     C           APGM      IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
      *
     C*----------------------*
     C* 新旧プログラム判断 *
     C*----------------------*
     C                     MOVEL'N'       WKUBN   1
     C           WA4       LOKUPTB2                      77
     C           *IN77     IFEQ '1'
     C                     MOVEL'O'       WKUBN   1
     C                     END
      *
     C*--------------------------*
     C*  ..プログラム頭１桁..  *
     C*--------------------------*
     C                     SETOF                     10
     C                     Z-ADD1         A       20
      *
     C           WKUBN     IFEQ 'N'
     C           WA1       LOKUPTB0                      10
     C                     ELSE
     C           WA1       LOKUPTB1                      10
     C                     ENDIF
      *
     C           *IN10     IFEQ '0'
     C                     SETON                     0199
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
      *
     C*---------------*
     C*  ..ｰﾇﾎｦbﾓ..  *
     C*---------------*
     C                     MOVE *BLANK    PSRC
     C                     MOVE *BLANK    WSRC
     C                     MOVE WA1       WSRC1
      *
     C*--------------------------*
     C*  ..プログラム頭４桁..  *
     C*--------------------------*
     C                     SETOF                     10
     C                     Z-ADD1         A       20
      *
S1   C           WKUBN     IFEQ 'N'
      *
     C           WA6       LOKUPTBA,A                    10
     C           *IN10     IFEQ '0'
     C                     SETON                     0199
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     END
     C                     MOVELTBB,A     PSRC
      *
X1   C                     ELSE
      *
     C           WA4       LOKUPTB2,A                    10
     C           *IN10     IFEQ '0'
     C                     SETON                     0199
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     END
      *
     C                     MOVE TB3,A     WSRC2
      *
     C           WSRC2     IFEQ 'FMTSRC '
     C                     MOVELWSRC2     PSRC
     C                     ELSE
     C                     MOVELWSRC      PSRC
     C                     END
      *
E1   C                     END
      *
     C                     MOVE APGM      PPGM
      *
     C*---------------*
     C*  ..[bﾎﾞ[ﾒｰ..  *
     C*---------------*
     C                     MOVEL'HSRC1   'PLIB
      *
     C*--------------------*
     C*  ..ﾎﾟﾜhﾞ[w jbﾎﾟ..  *
     C*--------------------*
     C                     SETOF                     10
     C                     MOVE *BLANK    PTYP
     C                     Z-ADD1         A
      *
     C           WKUBN     IFEQ 'N'
      *
     C           WA6       LOKUPTBC,A                    10
     C           *IN10     IFEQ '1'
     C                     MOVELTBD,A     PTYP    5
     C                     END
      *
     C                     ELSE
      *
     C           WA4       LOKUPTB9,A                    10
     C           *IN10     IFEQ '1'
     C                     MOVE TB10,A    PTYP
     C                     END
      *
     C                     END
      *
     C           *INKH     IFEQ '1'
     C                     MOVELPLIB      P@LIB  10
     C                     MOVELPSRC      P@SRC  10
     C                     MOVELPPGM      P@PGM  10
     C                     CALL 'VVVC90'
     C                     PARM           P@LIB
     C                     PARM           P@SRC
     C                     PARM           P@PGM
     C                     GOTO STP1
     C                     ENDIF
      *
     C                     SETON                     U1LR
     C                     RETRN
      *
