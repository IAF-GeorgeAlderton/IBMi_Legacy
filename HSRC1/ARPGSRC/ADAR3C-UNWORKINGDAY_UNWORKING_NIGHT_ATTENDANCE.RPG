     C*************************
     C*   １画面目の入力    *
     C*************************
     C           STEP1     TAG
     C                     SETOF                     010203
     C                     SETOF                     040506
     C                     SETOF                     070809
     C                     SETOF                     101151
     C                     SETOF                     525354
     C                     SETOF                     555657
     C                     SETOF                     585960
     C                     SETOF                     6199
     C                     MOVE *BLANK    MSG
     C                     MOVE *BLANK    WNO
     C                     Z-ADD0         WYM
     C                     Z-ADD0         WBN
      *
     C                     SETOF                     95
     C                     MOVE ' '       FLG     1
     C           *HIVAL    SETGTADAPL301
     C                     Z-ADD1         I       20
      *
     C                     DO   12        I
     C           STEP2     TAG
     C                     READPADAPL301                 80
     C           I         IFGT 11
     C                     SETON                     80
     C                     GOTO EXIT
     C                     END
     C           *IN80     IFEQ '1'
     C                     Z-ADDWWSAHZ    WYM,I
     C                     Z-ADDWWSARD    WBN,I
     C                     GOTO EXIT
     C                     END
     C           *IN80     IFEQ '0'
     C           DBSKJY    IFEQ 'D'
     C           DBSKHZ    ANDLE*DATE
     C                     GOTO STEP2
     C                     END
     C                     END
      *
     C           *IN95     IFEQ '0'
     C                     Z-ADDDBSAHZ    WWSAHZ  80
     C                     Z-ADDDBSARD    WWSARD  20
     C                     MOVE '*'       FLG
     C                     SETON                     95
     C                     END
      *
     C           DBSAHZ    IFEQ WWSAHZ
     C           DBSARD    ANDEQWWSARD
     C                     GOTO STEP2
     C                     END
      *
     C                     Z-ADDWWSAHZ    WYM,I
     C                     Z-ADDWWSARD    WBN,I
     C                     Z-ADDDBSAHZ    WWSAHZ
     C                     Z-ADDDBSARD    WWSARD
      *
     C           EXIT      TAG
     C  N80                ENDDO
      *
     C                     Z-ADDI         KEN     20
     C           I         IFGE 11
     C                     GOTO SKIP
     C                     END
      *
     C                     EXSR CHKRTN
      *
     C           SKIP      TAG
     C                     EXFMTADAPW3C1
     C                     SETOF                     010203
     C                     SETOF                     040506
     C                     SETOF                     070809
     C                     SETOF                     101125
     C                     SETOF                     99
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      ***  pﾆﾞｬc ﾉ kｩｮh  ***
     C                     Z-ADD1         A       20
     C                     MOVE ' '       DOB     1
     C                     MOVE '0'       SW      1
      *
     C                     DO   11        A
     C           WNO,A     IFNE *BLANK
     C           DOB       IFEQ '*'
     C                     SETON                     99
     C                     MOVELERR,1     MSG
     C                     MOVE '1'       SW      1
     C                     GOTO JUMP
     C                     END
     C                     MOVE '*'       DOB
     C                     Z-ADDA         IX      20
     C                     END
     C           JUMP      TAG
     C                     ENDDO
      *
     C           SW        IFEQ '1'
     C                     EXSR ERRTN
     C                     GOTO SKIP
     C                     END
      *
      ***  'M' bfﾞb ﾉ kｩｮh  ***
     C           APNO      IFEQ 0
     C           IX        IFNE 0
     C           WNO,IX    IFNE 'M'
     C                     EXSR ERRTN
     C                     MOVELERR,2     MSG
     C                     SETON                     99
     C                     GOTO SKIP
     C                     END
     C                     END
     C                     END
      *
      ***  xbﾅb n A-PICS NO fﾞ ﾈbjh ﾅﾛjf?  ***
     C                     MOVE ' '       BLFLG   1
     C                     Z-ADD1         X       20
     C                     DO   11        X
     C           WNO,X     IFNE *BLANK
     C                     MOVE '*'       BLFLG
     C                     END
     C                     ENDDO
      *
     C           BLFLG     IFEQ '*'
     C           APNO      IFNE 0
     C                     EXSR ERRTN
     C                     MOVELERR,3     MSG
     C                     SETON                     99
     C                     GOTO SKIP
     C                     END
     C                     END
      *
      ***  op y pｬcﾒｭh ﾅﾛﾇﾞp ADVANCE OR CMD-5 ･ eﾆj  ***
     C           APNO      IFEQ 0
     C           BLFLG     IFEQ ' '
     C                     SETON                     0199
     C                     MOVELERR,6     MSG
     C                     GOTO SKIP
     C                     END
     C                     END
      *
      ***  A-PICS NO fﾞ ﾍｭcﾆﾞ i]ﾇc ﾑﾒ eebf ?  ***
     C           APNO      IFNE 0
     C           APNO      IFGT KEN
     C                     SETON                     2599
     C                     MOVELERR,7     MSG
     C                     GOTO SKIP
     C                     END
     C                     END
      *
      ***  A-PICS NO fﾞ ﾈbjh ﾅﾛj[ ﾌﾟ[xｰj ･ ﾝjﾆm STOP RUN ﾇﾓ  ***
     C           BLFLG     IFEQ ' '
     C           APNO      IFNE 0
     C           *INKE     IFEQ '1'
     C                     Z-ADDAPNO      P       20
     C                     MOVE WYM,P     PYM     8
     C                     MOVE WBN,P     PBN     2
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C                     GOTO SKIP
     C                     END
     C                     END
