     C                     MOVE '#DSP1   '@STEP
     C           *IN76     WHEQ *ON
     C                     MOVE '#DSP1   '@STEP
     C* < F3 > 終了
     C           *INKC     WHEQ *ON
     C                     MOVE '#END    '@STEP
     C* <    >
     C                     OTHER
     C           RTNRRN    IFNE 0
     C           RTNRRN    CHAINSFREC1               94
     C           *IN94     IFEQ *OFF
     C                     MOVELS1KOTE    P@KOTE
