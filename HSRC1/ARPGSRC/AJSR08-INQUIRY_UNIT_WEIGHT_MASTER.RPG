     FAJSPP09 IF  E           K        DISK
      *
      *.. PROCESS NAME M/F ...
     FFCETL03 IF  E           K        DISK
      *================================================================
      *================================================================
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
      *(FCETL03).. PROCESS NAME M/F ...
     I* DELETE DUE DATE
     I            DS
     I                                        1   80A6GSHZ
     I                                        1   40A6GSYY
     I                                        5   60A6GSMM
     I                                        7   80A6SSDD
      *
      * PART NO.
     I            DS
     I                                        1  14 S1HIN
     I                                        1   5 S1HIN1
     I                                        6   6 S1HF1
     I                                        7  11 S1HIN2
     I                                       12  12 S1HF2
     I                                       13  14 S1HIN3
      *
      *
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *     <<
      *
     I           SDS
     I                                     *PROGRAM W@PGM
     I                                      244 253 W@WSID
     I                                      254 263 W@USER
     I                                      264 269 W@JBNO
     C*===============================================================
     C           *ENTRY    PLIST
     C                     PARM           P@KOTE  3
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
     C*===============================================================
     C*  START  PROGRAM
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
     C                     TIME           @TIME
     C                     MOVEA*ALL'0'   *IN
     C                     WRITEW1
      *
     C* SFLCLR
     C                     SETON                     72
     C                     WRITESFCTL1
     C                     SETOF                     72
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         ENDRRN  40
      *
     C                     MOVELP@KOTE    K@KOTE
     C                     MOVELP@HIN1    K@HIN1
     C                     MOVELP@HIN2    K@HIN2
     C                     MOVELP@HIN3    K@HIN3
     C                     MOVEL*BLANK    P@KOTE
     C                     MOVEL*BLANK    P@HIN1
     C                     MOVEL*BLANK    P@HIN2
     C                     MOVEL*BLANK    P@HIN3
      *
     C           KEY01     KLIST
     C                     KFLD           K@KOTE  3
     C                     KFLD           K@HIN1  5
     C                     KFLD           K@HIN2  5
     C                     KFLD           K@HIN3  2
      *
     C           KEY01     SETLLAJSPP09
     C                     Z-ADD0         ENDRRN  40
      *
     C                     EXSR ##UP
      *
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
      *===============================================================
      *===============================================================
     C           ##UP      BEGSR
     C                     Z-ADDENDRRN    RRN1    40
     C                     Z-ADD0         @CTR    40
      *-----------------------------------
     C                     DO   *HIVAL
     C                     READ AJSPP09                  90
     C   90                LEAVE
     C*
     C           J@SKJY    IFEQ 'D'                        DELETE CODE
     C           J@SKDT    ANDLE@SYSHZ                     DELETE DATE
     C                     ITER
     C                     ENDIF
     C*
     C                     MOVELJ@KOTE    S1KOTE
     C                     MOVELJ@HIN1    S1HIN1
     C                     MOVELJ@HIN2    S1HIN2
     C                     MOVELJ@HIN3    S1HIN3
     C                     MOVEL'-'       S1HF1
     C                     MOVEL'-'       S1HF2
     C           S1HIN3    IFEQ *BLANK
     C                     MOVEL*BLANK    S1HF2
     C           S1HIN2    IFEQ *BLANK
     C                     MOVEL*BLANK    S1HF1
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADDJ@TANJ    S1TANJ
     C                     EXSR ##KTNM
     C                     ADD  1         RRN1
     C                     ADD  1         @CTR    40
     C                     WRITESFREC1
     C           @CTR      IFGE 18
     C                     LEAVE
     C                     ENDIF
     C*
     C                     ENDDO
      *-----------------------------------
     C                     Z-ADDRRN1      ENDRRN
     C                     ENDSR
      *------------------------------------------------------------------
      *(FCETL03).. PROCESS NAME M/F ...
      *------------------------------------------------------------------
     C           ##KTNM    BEGSR
     C*
     C           S1KOTE    CHAINFCETL03              91
     C  N91      A6GSKD    IFEQ 'D'
     C           A6GSHZ    ANDLE@SYSHZ
     C                     SETON                     91
     C                     ENDIF
     C  N91                MOVELA6KTNM    S1KTNM
     C                     ENDSR
      *===============================================================
      *  画面１　表示
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     SETON                     70
     C           ENDRRN    IFNE 0
     C                     SETON                     71
     C                     ENDIF
     C                     WRITEDSP01
     C                     EXFMTSFCTL1
     C                     SETOF                     707199
     C                     Z-ADD$$RRN     RRN1
     C*----------
     C*----------
     C                     SELEC
     C* < PAGE UP/DOWN >
     C           *IN75     WHEQ *ON
