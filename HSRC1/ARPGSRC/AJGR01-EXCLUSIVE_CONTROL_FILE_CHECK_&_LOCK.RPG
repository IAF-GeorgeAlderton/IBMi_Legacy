     H            Y.
      ** AJGR01 **************************************
      * EXCLUSIVE CONTROL FILE - CHECK & LOCK
      *        MSK.         2007.11.02               *
      ************************************************
     FAJGPP01 UF  E           K        DISK                      A
     FRGAPL11 IF  E           K        DISK
      *
     I            DS
     I                                        1   80A1SKHZ
     I                                        1   40A1SKYY
     I                                        5   60A1SKMM
     I                                        7   80A1SKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------*
      * PARAMETER
      *   IN                                               *
      *      PIPGMN : CL NAME                              *
      *   OUT                                              *
      *      POUSID : USING USER ID                        *
      *      POKONA : USING USER NAME                      *
      *      POSTTS : '1' NOT USING                        *
      *               '2' USING                            *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           PIPGMN 10
     C                     PARM           POUSID 10
     C                     PARM           POKONA 15
     C                     PARM           POSTTS  1
      *
     C                     TIME           WTIME
      * CHECK CONTROL FIE
     C                     MOVEL*BLANK    POUSID
     C                     MOVEL*BLANK    POKONA
     C                     MOVEL*BLANK    POSTTS
     C           PIPGMN    CHAINAJGPP011             21
     C           *IN21     IFEQ '0'
     C           A1SKJY    ANDEQ'D'
     C           A1SKHZ    ANDLEWTIHZ
     C                     SETON                     21
     C                     ENDIF
      *
     C           *IN21     IFEQ '0'
     C                     MOVELA1USID    POUSID
     C                     MOVELA1KONA    POKONA
     C                     MOVEL'2'       POSTTS           USING
     C                     ELSE
     C                     MOVEL'1'       POSTTS           NOT USING
     C                     EXSR #WRT
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *----------------------------------------------------*
      * CREATE CONTROL FILE                                *
      *----------------------------------------------------*
     CSR         #WRT      BEGSR
      *
     C           PIPGMN    CHAINAJGPP011             21
     C                     CLEARAJGPP011
      *
     C                     MOVEL*BLANK    A1SKJY
     C                     Z-ADD0         A1SKYY
     C                     Z-ADD0         A1SKMM
     C                     Z-ADD0         A1SKDD
     C                     Z-ADDWTIYY     A1KOYY
     C                     Z-ADDWTIMM     A1KOMM
     C                     Z-ADDWTIDD     A1KODD
     C                     Z-ADDTIMHH     A1KOTH
     C                     Z-ADDTIMMM     A1KOTM
     C                     Z-ADDTIMSS     A1KOTS
      *
     C                     MOVELW$WSID    A1WSID
     C                     MOVEL@@USER    A1USID
     C           @@USER    CHAINRGAPL111             22
     C           *IN22     IFEQ '0'
     C                     MOVELJ8NAME    A1KONA
     C                     ENDIF
      *
     C                     MOVELPIPGMN    A1PGMN
     C                     Z-ADDWTIYY     A1STYY
     C                     Z-ADDWTIMM     A1STMM
     C                     Z-ADDWTIDD     A1STDD
     C                     Z-ADDTIMHH     A1STTH
     C                     Z-ADDTIMMM     A1STTM
     C                     Z-ADDTIMSS     A1STTS
      *
     C           *IN21     IFEQ '0'
     C                     UPDATAJGPP011
     C                     ELSE
     C                     WRITEAJGPP011
     C                     ENDIF
      *
     CSR         EWRT      ENDSR
      *
