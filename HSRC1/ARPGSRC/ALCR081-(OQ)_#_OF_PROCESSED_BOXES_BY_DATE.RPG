     H            Y.
     F** ALCR081 *******************************************
     F*  THE NUMBER OF PROCESSED BOXES BY DATE LIST        *
     F*                                                    *
     F* TCHK1 06/04/09 CREATE(COPY FROM ALDR08)            *
     F******************************************************
     FALCWL05 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     F*************************************************************
     I* SYSTEM DATE
     I            DS
     I                                        1  120WWTIME
     I                                        1   60WTIME
     I                                        9  100WPMM
     I****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PUSR   10
     C                     PARM           PYYYY   40
     C                     PARM           PMM     20
     C*
     C           KEY1      KLIST
     C                     KFLD           WYY     40
     C                     KFLD           WMM     20
     C                     KFLD           WDD     20
     C*
     C*
     C                     EXSR @INIT
     C           *IN90     DOWEQ'0'
     C           PMM       ANDEQF8KAMM
     C*
     C                     MOVEL'0'       *IN91
     C           KEY1      SETLLALCWL05                  91
     C           *IN91     IFEQ '1'
     C                     MOVEL'0'       *IN91
     C           *IN91     DOWEQ'0'
     C           KEY1      READEALCWL05                  91
     C*
     C           *IN91     IFEQ '0'
     C                     ADD  D5BOX     WKBOX   60
     C                     ENDIF
     C*
     C                     ENDDO
     C                     ELSE
     C                     Z-ADD0         WKBOX
     C                     Z-ADDF8KAYY    D5YYYY
     C                     Z-ADDF8KAMM    D5MMMM
     C                     Z-ADDF8KADD    D5DDDD
     C                     ENDIF
     C*
     C                     Z-ADDWKBOX     W5BOX   60
     C                     ADD  WKBOX     LBOX    60
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     MOVEL'0'       *INOF
     C                     ENDIF
     C                     EXCPTDT
     C                     Z-ADD0         WKBOX
     C                     READ AGDPL12                  90
     C                     Z-ADDF8KAYY    WYY
     C                     Z-ADDF8KAMM    WMM
     C                     Z-ADDF8KADD    WDD
     C                     ENDDO
     C*
     C                     EXCPTTL
     C                     MOVEL'1'       *INLR
     C                     RETRN
     C*
     C*
     C           @INIT     BEGSR
     C                     TIME           WWTIME
     C                     EXCPTHD
     C                     MOVEL'0'       *IN90
     C                     Z-ADDPYYYY     WYY
     C                     Z-ADDPMM       WMM
     C                     Z-ADD1         WDD
     C           KEY1      SETLLAGDPL12
     C                     READ AGDPL12                  90
     C                     ENDSR
     C*
     O*****************************************************************
     OQPRINT  E  102           HD
     O                                    9 'ALCR081'
     O                                  131 '.....................'
     O        E  1             HD
     O                                   12 'ISSUE DATE'
     O                                   14 ':'
     O                         PYYYY     19
     O                                   21 '/'
     O                         PMM       24
     O                                  128 '.         .         .'
     O        E  1             HD
     O                                   89 'TIME'
     O                         WTIME     98 '  :  :  '
     O                                  111 '.'
     O                         PUSR     121
     O                                  131 '.         .'
     O        E  2             HD
     O                                   28 'OQ        '
     O                                   47 '** THE NUMBER OF'
     O                                   63 'PROCESSED BOXES'
     O                                   76 'BY DATE **'
     O                                   89 'DATE'
     O                         UDATE Y   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O                                  131 '.....................'
     O        E  1             HD
     O                                   58 'DATE'
     O                                   77 '# OF BOXES'
     O*
     O        E  1             DT
     O                         F8HIRU    53
     O                         D5YYYY    58
     O                                   59 '/'
     O                         D5MMMM    61
     O                                   62 '/'
     O                         D5DDDD    64
     O                         W5BOX 1B  77
     O************************************************************
     O        E 2              TL
     O                                   59 'TOTAL'
     O                         LBOX  1B  77
     O************************************************************
