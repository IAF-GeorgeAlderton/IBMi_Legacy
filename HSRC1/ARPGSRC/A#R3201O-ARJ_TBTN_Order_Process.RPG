     H            Y.
     F** A#R3201O ******************************************
     F*  ARJ ORDER PROCESSING                              *
     F*                                                    *
     F* TCHK 11/01/13 CREATE(COPY FROM A#R0465O)           *
     F******************************************************
     FARJ     IP  F     600            DISK
     FAB#WARJ O   E                    DISK
      *--------------------------------------------------------
     E                    AY        600  1
     E                    DT2         2  1
     E**                  OD         10  1
JW   E                    OD         15  1
     E                    A9          9  1
     E                    A9X         9  1
     E                    MHN        15  1
      *--------------------------------------------------------
     IARJ     AA  01
     I                                        1  12 SEQ
     I                                       13 268 DAT1
     I                                      269 524 DAT2
     I                                      525 600 DAT3
     I            DS
     I                                        1   8 YMD
     I                                        1   4 YY
     I                                        5   6 MM
     I                                        7   8 DD
     I            DS
     I                                        1  15 AWMHNX
     I                                        1   5 AWMHN1
     I                                        6  10 AWMHN2
     I                                       11  15 AWMHN3
     I            DS
     I                                        1  140W@TIME
     I                                        1   20W@TH
     I                                        3   40W@TM
     I                                        5   60W@TS
     I                                        7  100W@DY
     I                                       11  120W@DM
     I                                       13  140W@DD
      *
     C           *ENTRY    PLIST
     C                     PARM           PID     1
      *
     C**                   Z-ADD3201      AWTOKU
JW   C                     Z-ADD3315      AWTOKU
     C                     Z-ADD3201      AWNONY
     C                     MOVE '0'       AWNKOJ
     C                     MOVE '00  '    AWNUKE
     C                     MOVE '000000'  AWSBAN
     C                     MOVE '1'       AWBIN#
      *
     C                     MOVEADAT1      AY,1
      *
      * ------------------------------
      * SHIP DATE & 'QTY/BOX' POSITION
      * ------------------------------
     C           *IN99     IFEQ *OFF
      *
     C                     Z-ADD1         X       30
     C           'PART#'   SCAN DAT1      X              10
     C  N10      'Part#'   SCAN DAT1      X              10
     C  N10                GOTO @END
     c*
     C                     MOVEL*ON       *IN99
     C                     GOTO @END
      *
     C                     END
      *
     C                     Z-ADD*ZERO     J       30
     C                     Z-ADD*ZERO     L       30
      *
      *
      * ------
      * DETAIL
      * ------
      *
      * PART#
      *
     C                     Z-ADD1         X       30
     C           'PP'      SCAN DAT1      X              10
     C  N10                GOTO @END
      *
     C                     MOVEL*BLANK    MHN
     C                     Z-ADD*ZERO     J
     C                     Z-ADD*ZERO     L
      *
     C                     DO   *HIVAL
     C                     ADD  1         J
     C           AY,J      IFEQ ','
     C                     LEAVE
     C                     END
     C           AY,J      IFEQ '-'
     C           AY,J      OREQ *BLANK
     C                     ITER
     C                     END
     C                     ADD  1         L
     C                     MOVELAY,J      MHN,L
     C                     ENDDO
      *
     C                     MOVEAMHN       AWMHNX
      *
      *
      * ORDER NUMBER
      *
     C                     ADD  1         J
     C           ','       LOKUPAY,J                     10
     C  N10                GOTO @END
     C*
     C                     ADD  1         J
     C           AY,J      IFEQ ','
     C           AY,J      OREQ ' '
     C                     GOTO @END
     C                     END
     C*
     C                     MOVEL*BLANK    OD
     C                     Z-ADD*ZERO     L
     C                     DO   *HIVAL
     C           AY,J      IFEQ ','
     C           AY,J      OREQ ' '
     C                     LEAVE
     C                     END
     C                     ADD  1         L
     C                     MOVELAY,J      OD,L
     C                     ADD  1         J
     C                     ENDDO
     C*
     C                     MOVEAOD        W#A10  10
     C                     MOVELW#A10     AWORDN
     C*
     C*
     C* SHIPPING DATE
     C*
     C* MM
     C                     ADD  1         J
     C                     MOVEAAY,J      DT2
     C           DT2,2     IFGE '0'
     C           DT2,2     ANDLE'9'
     C                     MOVEADT2       MM
     C                     ELSE
     C                     MOVE '00'      MM
     C                     MOVE DT2,1     MM
     C                     END
      * DD
     C           '/'       LOKUPAY,J                     10
     C  N10                GOTO @END
     C                     ADD  1         J
     C                     MOVEAAY,J      DT2
     C           DT2,2     IFGE '0'
     C           DT2,2     ANDLE'9'
     C                     MOVEADT2       DD
     C                     ELSE
     C                     MOVE '00'      DD
     C                     MOVE DT2,1     DD
     C                     END
      * YY
     C                     MOVELMM        MM##N   20
     C           MM##N     IFLT W@DM
     C           W@DY      ADD  1         YY##N   40
     C                     ELSE
     C                     Z-ADDW@DY      YY##N
     C                     END
     C                     MOVELYY##N     YY
     C                     MOVELYMD       AWSHDT
      *
      *
      * QTY
     C           ','       LOKUPAY,J                     10
     C  N10                GOTO @END
     C                     ADD  1         J
     C           ','       LOKUPAY,J                     10
     C  N10                GOTO @END
      *
     C                     Z-ADD*ZERO     L
     C                     MOVE *BLANK    A9
     C                     DO   *HIVAL
     C                     ADD  1         J
     C           AY,J      IFEQ ','
     C           AY,J      OREQ ' '
     C                     LEAVE
     C                     END
     C                     ADD  1         L
     C                     MOVE AY,J      A9,L
     C                     ENDDO
      *
     C                     MOVEL*ZERO     A9X
     C                     Z-ADD9         M       30
     C                     Z-ADD9         L
     C                     DO   9
     C           A9,M      IFNE *BLANK
     C                     MOVELA9,M      A9X,L
     C                     SUB  1         L
     C                     END
     C                     SUB  1         M
     C           M         IFEQ *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVE @9C       @9      90
     C                     Z-ADD@9        AWSRYO
      *
      *
      *
      * QTY/BOX
      *
     C                     ADD  1         J
     C           ','       LOKUPAY,J                     10
     C  N10                GOTO @END
      *
     C                     MOVEL*BLANK    A9
     C                     Z-ADD*ZERO     L
     C                     DO   *HIVAL
     C                     ADD  1         J
     C           AY,J      IFEQ ','
     C           AY,J      OREQ ' '
     C                     LEAVE
     C                     END
     C                     ADD  1         L
     C                     MOVELAY,J      A9,L
     C                     ENDDO
      *
     C                     MOVEL*ZERO     A9X
     C                     Z-ADD9         L
     C                     Z-ADD9         M
     C                     DO   9
     C           A9,L      IFNE *BLANK
     C                     MOVELA9,L      A9X,M
     C                     SUB  1         M
     C                     END
     C                     SUB  1         L
     C           L         IFEQ *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVEL@9C       @9      90
     C                     Z-ADD@9        AWSYOS
      *
      *
      * WRITE
     C           AWSRYO    IFNE *ZERO
     C                     WRITEAB#WARJ1
     C                     MOVE '1'       PID
     C                     END
      *
      *
     C           @END      TAG
      ******************************************************
     C           *INZSR    BEGSR
      ******************************************************
      *
     C                     TIME           W@TIME
     C                     Z-ADD*ZERO     W#PQB   20
      *
     C                     ENDSR
