     I                                       29  300A2GSMM
     I                                       31  320A2GSDD
     C                     SETOF                     01
     C                     Z-ADD0         RECD    20
     C   02                GOTO STP2
     C                     SETON                     02
     C           *ENTRY    PLIST
     C                     PARM           PHIZK   8
     C                     PARM FLIST     PLIST   1
     C                     MOVE PHIZK     UHIZK
     C           STP2      TAG
     C           A2GSKD    CABNE'D'       STP3
     C           A2GSHZ    CABGT*DATE     STP3
     C                     GOTO END
     C           STP3      TAG
     C           A2TRHZ    CABNEUHIZK     STP1
     C                     SETON                     01U1U2
     C                     MOVE '*'       FLIST   1
     C           STP5      TAG
     C                     ADD  1         RECD
     C           RECD      CABEQ2         END
     C                     EXCPTMEISAI
     C                     GOTO STP5
     C           STP1      TAG
     C           A2SYHZ    CABNEUHIZK     END
     C                     SETON                     U1U3
     C           STP4      TAG
     C                     ADD  1         RECD
     C           RECD      CABEQ2         END
     C                     EXCPTMEISAI
     C                     GOTO STP4
     C           END       TAG
     OFCEWP20 E                MEISAI
