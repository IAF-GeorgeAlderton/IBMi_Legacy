     H            Y.
     F** AL#RF1  *******************************************
     F*LIST OF COMPLETE PALLETS                            *
     F*      ITS.        2015.06.15                        *
     F******************************************************
     FAL#PL01 IF  E           K        DISK
     FAL#WPF0 O   E                    DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1DATE  80
     C                     PARM           P9CMD   2
      *
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      *
     C           KEYC1     KLIST
     C                     KFLD           KKKADT  8
      *
     C                     MOVE P1DATE    KKKADT
     C                     MOVEL*BLANK    WKSURT  9
     C           KEYC1     SETLLAL#PL011
     C           KEYC1     READEAL#PL011                 81
     C           *IN81     DOWEQ'0'
     C           CASKJY    IFEQ 'D'
     C           CASKHZ    ANDLESDATE
     C                     ELSE
     C           CASURT    IFNE WKSURT
     C                     EXSR #SB500
     C                     MOVELCASURT    WKSURT  9
     C                     ENDIF
     C                     ENDIF
     C           KEYC1     READEAL#PL011                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AL#WPF0
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C                     CLEARAL#WPF01
     C                     MOVEL*BLANK    W0SEL
     C                     MOVELCATRKB    W0TRKB
     C                     MOVELCASURT    W0SURT
     C                     WRITEAL#WPF01
      *
     CSR         ESB500    ENDSR
