     H            Y.
     F** A#R0647O ******************************************
     F*  TAKUMI CANADA ORDER PROCESS                       *
     F*                                                    *
     F* TCHK1 05/28/10 CREATE                              *
     F******************************************************
     FTAKUMICNIP  F    3000            DISK
     FAB#WTAC O   E                    DISK
      *--------------------------------------------------------
     E                    AY        800  1
     E                    DAT         2  8 0
     E                    A2          2  1
     E                    A6          6  1
     E                    A6X         6  1
     E                    A8          8  1
     E                    A9          9  1
     E                    A9X         9  1
     E                    A15        15  1
     E                    OD#         2 15
      *--------------------------------------------------------
     ITAKUMICNAA  01
     I                                        1   4 SEQN
     I                                        1  12 SEQ
     I                                       13 268 DAT1
     I                                      269 524 DAT2
     I                                      525 780 DAT3
     I            DS
     I                                        1   80YMD
     I                                        1   40YEAR
     I                                        5   60MONTH
     I                                        7   80DAY
     I            DS
     I                                        1  15 ATMHIN
     I                                        1   5 ATMHN1
     I                                        6  10 ATMHN2
     I                                       11  15 ATMHN3
     C*
     C                     Z-ADD1         X
     C                     MOVEADAT1      AY,X
     C                     ADD  256       X       50
     C                     MOVEADAT2      AY,X
     C                     ADD  256       X       50
     C                     MOVEADAT3      AY,X
     C*
     C                     Z-ADD*ZERO     Z       50
     C                     Z-ADD*ZERO     Y       50
     C                     Z-ADD*ZERO     I       50
     C*
     C* HEADER
     C*
     C* PO#
     C           *IN99     IFEQ *OFF
     C*
     C                     Z-ADD*ZERO     I
     C                     MOVEL*BLANK    OD#
     C                     MOVEL*BLANK    A15
     C                     Z-ADD*ZERO     Y       50
     C*
     C                     DO   *HIVAL
     C                     ADD  1         Z
     C           AY,Z      IFEQ ','
     C           AY,Z      OREQ ' '
     C                     LEAVE
     C                     END
     C                     ADD  1         Y
     C                     MOVELAY,Z      A15,Y
     C                     ENDDO
     C                     MOVEAA15       W@A15  15
     C                     ADD  1         I
     C                     MOVELW@A15     OD#,I
     C*
     C                     MOVE *ON       *IN99
     C                     GOTO @END
     C*
     C                     END
     C*
     C* PICKUP DATE
     C           *IN98     IFEQ *OFF
     C*
     C                     Z-ADD*ZERO     I
     C                     Z-ADD*ZERO     DAT
      *
     C                     MOVEL*ZERO     YMD
     C* MM
     C                     ADD  1         Z
     C           '/'       LOKUPAY,Z                     10
     C  N10                GOTO @END
     C           Z         SUB  2         Y
     C                     MOVEAAY,Y      A2
     C           A2,2      IFGE '0'
     C           A2,2      ANDLE'9'
     C                     MOVE A2,2      MONTH
     C           A2,1      IFGE '0'
     C           A2,1      ANDLE'9'
     C                     MOVELA2,1      MONTH
     C                     END
     C                     ELSE
     C           A2,1      IFGE '0'
     C           A2,1      ANDLE'9'
     C                     MOVE A2,1      MONTH
     C                     END
     C                     END
     C* DD
     C                     ADD  1         Z
     C           '/'       LOKUPAY,Z                     10
     C  N10                GOTO @END
     C           Z         SUB  2         Y
     C                     MOVEAAY,Y      A2
     C           A2,2      IFGE '0'
     C           A2,2      ANDLE'9'
     C                     MOVE A2,2      DAY
     C           A2,1      IFGE '0'
     C           A2,1      ANDLE'9'
     C                     MOVELA2,1      DAY
     C                     END
     C                     ELSE
     C           A2,1      IFGE '0'
     C           A2,1      ANDLE'9'
     C                     MOVE A2,1      DAY
     C                     END
     C                     END
     C* YY
     C           Z         ADD  1         Y
     C                     MOVEAAY,Y      W@A4    4
     C                     MOVELW@A4      YEAR
      *
     C                     ADD  1         I
     C                     Z-ADDYMD       DAT,I
     C  N98                MOVE *ON       *IN98
      *
     C                     GOTO @END
      *
     C                     END
     C*
     C* DETAIL
     C                     Z-ADD*ZERO     W       50
     C*
      * QTY/BOX
     C                     Z-ADD*ZERO     X
     C                     MOVE *BLANK    A6
     C                     Z-ADD*ZERO     Y
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C                     LEAVE
     C                     END
     C           AY,X      IFLT '0'
     C           AY,X      ORGT '9'
     C                     ITER
     C                     END
     C                     ADD  1         Y
     C                     MOVE AY,X      A6,Y
     C                     ENDDO
      *
     C                     Z-ADD6         A       30
     C                     Z-ADD6         B       30
     C                     MOVEL*ALL'0'   A6X
     C                     DO   6
     C           A6,A      IFNE *BLANK
     C                     MOVE A6,A      A6X,B
     C                     SUB  1         B
     C                     END
     C                     SUB  1         A
     C           A         IFEQ *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     MOVEAA6X       @6N     6
     C                     MOVE @6N       ATSYOS
     C*
     C* QTY
     C                     Z-ADD1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
     C*
     C                     Z-ADD*ZERO     Y
     C                     Z-ADD*ZERO     I
     C                     Z-ADD*ZERO     W
     C                     MOVE *BLANK    A9
      *
     C                     Z-ADDX         Z
     C                     Z-ADD*ZERO     W
     C                     Z-ADD*ZERO     Y
     C                     MOVEL*BLANK    A9
      *
     C                     DO   *HIVAL
     C                     ADD  1         Z
     C           AY,Z      IFEQ ','
     C           AY,Z      OREQ ' '
     C                     LEAVE
     C                     END
     C           AY,Z      IFLT '0'
     C           AY,Z      ORGT '9'
     C                     ITER
     C                     END
     C                     ADD  1         Y
     C                     MOVELAY,Z      A9,Y
     C                     ENDDO
      *
     C                     MOVEL*ALL'0'   A9X
     C                     Z-ADD9         W
     C                     Z-ADD9         V       30
     C                     DO   9
     C           A9,W      IFNE *BLANK
     C                     MOVE A9,W      A9X,V
     C                     SUB  1         V
     C                     END
     C                     SUB  1         W
     C           W         IFEQ *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVE @9C       @9      90
     C                     Z-ADD@9        ATSRYO
     C*
     C* PART NUMBER
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
      *
     C                     MOVE *BLANK    A15
     C                     Z-ADD*ZERO     Y
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C           AY,X      OREQ ' '
     C                     LEAVE
     C                     END
     C           AY,X      IFEQ '-'
     C                     ITER
     C                     END
     C                     ADD  1         Y
     C                     MOVE AY,X      A15,Y
     C                     ENDDO
      *
     C                     MOVEAA15       ATMHIN    P
     C           ATMHIN    IFEQ *BLANK
     C                     GOTO @END
     C                     END
     C*
     C           ATSRYO    IFEQ *ZERO
     C                     GOTO @END
     C                     END
      *
     C                     Z-ADD0647      ATTOKU
     C                     Z-ADD0647      ATNONY
     C                     MOVEL'0'       ATNKOJ
     C                     MOVEL'00'      ATNUKE
     C                     MOVEL'0000'    ATSBAN
      *
     C                     Z-ADD1         I
     C           DAT,I     IFGE *DATE
     C                     Z-ADDDAT,I     ATSHDT
     C                     MOVELOD#,I     ATORDN
     C                     WRITEAB#WTAC1
     C                     MOVE '1'       PID
     C                     ENDIF
     C*
     C           @END      TAG
     C******************************************************
     C*  INITIAL                                           *
     C******************************************************
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           PID     1
      *
     C                     ENDSR
