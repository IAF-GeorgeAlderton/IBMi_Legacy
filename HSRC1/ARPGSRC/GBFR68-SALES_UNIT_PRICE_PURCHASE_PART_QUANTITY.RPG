     C           *ENTRY    PLIST
     C                     PARM           PTOKU   4
     C                     PARM           PLKBN   1
     C                     PARM           PTKOJ   1
     C           *IN01     IFEQ '0'
     C                     SETON                     01
     C                     Z-ADD*DATE     YYMD
     C                     Z-ADDSYY       DYY
     C                     Z-ADDSMD       DMD
     C                     MOVE PTOKU     UTOKU   40
     C                     MOVE MD,1      HD
     C                     MOVE *BLANK    TMEIG
     C                     MOVE '-'       F1
     C                     MOVE '-'       F2
     C                     SETOF                     02
     C           UTOKU     CHAINFGBPL011             02
     C           *IN02     IFEQ '0'
     C                     MOVELB2SMEI    TMEIG
     C                     END
     C                     END
     C           IATOKU    IFNE UTOKU
     C                     SETON                     LR
     C                     GOTO END
     C                     END
     C           *INL4     IFEQ '1'
     C                     MOVE IAKKEY    KKEY    1
     C                     Z-ADDIASAIZ    SAIZ    20
     C                     MOVE IAKHN1    HIN1
     C                     MOVE IAKHN2    HIN2
     C                     MOVE IAKHN3    HIN3
     C                     MOVE IATKOJ    TKOJ    1
     C                     WRITEGBFPR681
