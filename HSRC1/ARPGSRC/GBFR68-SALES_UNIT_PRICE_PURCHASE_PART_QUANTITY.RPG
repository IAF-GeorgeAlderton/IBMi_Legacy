     C                     MOVE IAKHN2    HIN2
     C                     MOVE IAKHN3    HIN3
     C                     MOVE IATKOJ    TKOJ    1
     C                     ELSE
     C           *INL1     IFEQ '1'
     C                     MOVE IATKOJ    TKOJ    1
     C                     END
     C                     END
     C                     END
     C                     END
     C           IADKBN    IFEQ 'N'
     C           IAKOSU    MULT IASRYO    PSRYO  100
     C           SRYO      ADD  PSRYO     SRYO   100
     C           NTAN      IFEQ 0
     C                     Z-ADDIAKTAN    NTAN    75
     C                     END
     C                     END
     C           IADKBN    IFEQ 'O'
     C           QTAN      IFEQ 0
     C                     Z-ADDIAKTAN    QTAN    75
     C                     END
     C                     END
     C           END       TAG
     CL1         SRYO      MULT NTAN      NKIN   112H
     CL1         SRYO      MULT QTAN      QKIN   112H
     CL1         QKIN      SUB  NKIN      SKIN   102
     CL1         SSRYO     ADD  SRYO      SSRYO  110
     CL1         SQKIN     ADD  QKIN      SQKIN  112
