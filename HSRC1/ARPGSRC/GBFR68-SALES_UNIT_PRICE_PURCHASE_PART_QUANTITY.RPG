     C                     MOVE IAKHN1    HIN1
     C                     MOVE IAKHN2    HIN2
     C                     MOVE IAKHN3    HIN3
     C                     MOVE IATKOJ    TKOJ    1
     C                     ELSE
     C           *INL2     IFEQ '1'
