     F********************************* AB#R7C **
     FAB#WP65 IP  F     128            DISK
     FFCEPL01 IF  E           K        DISK
     IAB#WP65 AA  01
     I                                        1   40ITOKU
     I                                        5   80INONY
     I                                        9   9 INKOJ
     I                                       10  13 INUKE
     I                                       14  210INOHZ L3
     I                                       14  170INOYY
     I                                       18  190INOMM
     I                                       20  210INODD
     I                                       22  250INOTM
     I                                       26  41 IINVN
     I                                       42  51 IODRN L2
     I                                       52  55 ISBAN
     I                                       56  610ISYOS
     I                                       62  710ISURY
     I                                       72  91 IMHIN L1
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     I            DS
     I                                        1  12 @SHIN
     I                                        1   5 @SHN1
     I                                        6  10 @SHN2
     I                                       11  12 @SHN3
      *------*
      * PARM *
      *------*
     C           *ENTRY    PLIST
     C                     PARM           PPALT   7
     C                     PARM           PCONW   52
     C                     PARM           PGROS  100
      *
     C           KEY1      KLIST
     C                     KFLD           @SHN1
     C                     KFLD           @SHN2
     C                     KFLD           @SHN3
      *-----*
      * INZ *
      *-----*
     C                     Z-ADDPCONW     ICONW   52
     C                     Z-ADD0         IHAK    60
     C                     Z-ADD0         IHAS    60
     C                     Z-ADD0         WHAS    60
     C                     Z-ADD0         WCONW   52
      *--------*
      * L1 = 1 *
      *--------*
     C           *INL1     IFEQ '1'
     C                     EXSR SUB1
     C                     END
      *
     C                     Z-ADD0         WWEIG  100
     C                     Z-ADD0         IWEIG  100
     C           ISURY     DIV  ISYOS     IHAK
     C                     MVR            IHAS
     C           ISURY     MULT WEIGHT    IWEIG
      *
     C           IHAS      IFNE 0
     C           ISYOS     SUB  IHAS      WHAS
     C                     ADD  1         IHAK
     C                     END
      *
     C           ICONW     MULT IHAK      WCONW
     C           IWEIG     ADD  WCONW     WWEIG
      *
     CL1                   ADD  WWEIG     GWEIG  100
     CLR                   Z-ADD0         IPALT   70
     CLR         IHAK      DIV  120       IPALT
     CLR                   MVR            IHAS
      *
     CLR         IHAS      IFNE 0
     CLR                   ADD  1         IPALT
     CLR                   END
     CLR                   MOVE IPALT     PPALT
     CLR                   Z-ADDGWEIG     PGROS
      *
     C           SUB1      BEGSR
     C                     Z-ADD0         WEIGHT  72
     C                     MOVE *BLANK    PTOKU   4
     C                     MOVE *BLANK    PNONY   4
     C                     MOVE *BLANK    PNKOJ   1
     C                     MOVE *BLANK    PNUKE   4
     C                     MOVE *BLANK    PMHIN  20
     C                     MOVELITOKU     PTOKU
     C                     MOVELINONY     PNONY
     C                     MOVELINKOJ     PNKOJ
     C                     MOVELINUKE     PNUKE
     C                     MOVELIMHIN     PMHIN
      *
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU
     C                     PARM           PNONY
     C                     PARM           PNKOJ
     C                     PARM           PNUKE
     C                     PARM           PMHIN
     C                     PARM           @SHIN  12
     C                     PARM           @FLG    1
      *
     C                     SETOF                     15
     C           KEY1      CHAINFCEPL011             15
      *
     C           *IN15     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADDA2KASI    WEIGHT
     C                     END
     C                     END
     C                     ENDSR
