     H            Y.
     F***SETR02  ***************************************************************
     F*  PROGRAM    : SET EDI PARTNER TABLE BY AB#EP40S                        *
     F*  WRITTEN    : JW (SRA)  2025.05.02                                     *
     F**************************************************************************
     FAB#EP40SIF  E           K        DISK
     FAB#EP01 IF  E           K        DISK                      A
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     MOVE *BLANK    SVPRTN 30
      * LOOP
     C           *LOVAL    SETLLAB#EP40S
     C                     DO   *HIVAL
     C                     READ AB#EP40S                 98
     C   98                LEAVE
      * IGNORE
     C           ESRYO     IFEQ 0
     C           ENONY     OREQ *BLANK
     C                     ITER
     C                     ENDIF
      * IGNORE
     C           EPRTNR    IFEQ SVPRTN
     C                     ITER
     C                     ENDIF
      * CHECK
     C                     MOVELENONY     @@NONY  40
     C           @@NONY    CHAINAB#EP01              98
     C           *IN98     IFEQ *ON
     C                     TIME           SDATE
     C                     MOVELEPRTNR    EP1PRT
     C                     Z-ADD@@NONY    EP1NON
     C                     Z-ADDTODAY     EP1CDT
     C                     Z-ADDNOW       EP1CTM
     C                     MOVEL#USER     EP1CUS
     C                     MOVEL#PGM      EP1CPG
     C                     WRITEAB#EP011
     C                     MOVELEPRTNR    SVPRTN
     C                     ENDIF
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
