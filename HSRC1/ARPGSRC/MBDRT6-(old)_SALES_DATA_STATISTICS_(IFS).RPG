      *****************************************************************
      *                    MAIN ROUTINE
      *****************************************************************
      * INIT
     C                     EXSR #INIT
      * SETLL
     C           @TOKU     IFEQ 9999
     C           *LOVAL    SETLLMBDPL11
     C                     ELSE
     C           @TOKU     SETLLMBDPL11
     C                     ENDIF
      * LOOP -----------------------------------
     C           *IN90     DOWEQ*OFF
      * READ
     C                     READ MBDPL11                  90
     C   90                LEAVE
      * IGNORE DELETED RECORD
     C           F4SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C* END?
     C           @TOKU     IFNE 9999
     C           @TOKU     ANDNEF4TOKU
     C                     MOVE *ON       *IN90
     C                     LEAVE
     C                     ENDIF
      * SELECT DELIVERY#
     C           @NONY     IFNE 0
     C           @TOKU     ANDNE9999
     C           @NONY     ANDNEF4NONY
     C                     ITER
     C                     ENDIF
     C* SELECT FACTORY
     C           @NKOJ     IFNE *BLANK
     C           @NKOJ     ANDNEF4NKOJ
     C                     ITER
     C                     ENDIF
     C* SELECT DOCK
     C           @NUKE     IFNE *BLANK
     C           @NUKE     ANDNEF4NUKE
     C                     ITER
     C                     ENDIF
     C* SELECT YEAR
     C           F4TNEN    LOKUP#H1                      75
     C           *IN75     IFEQ *OFF
     C                     ITER
     C                     ENDIF
     C* ADJUST PART
     C           F4MHN2    IFEQ *BLANK
     C                     MOVE *BLANK    F4M1
     C                     ELSE
     C                     MOVE '-'       F4M1
     C                     ENDIF
     C           F4MHN3    IFEQ *BLANK
     C                     MOVE *BLANK    F4M2
     C                     ELSE
     C                     MOVE '-'       F4M2
     C                     ENDIF
     C           F4MHN4    IFEQ *BLANK
     C                     MOVE *BLANK    F4M3
     C                     ELSE
     C                     MOVE '-'       F4M3
     C                     ENDIF
     C           F4SHN2    IFEQ *BLANK
     C                     MOVE *BLANK    F4S1
     C                     ELSE
     C                     MOVE '-'       F4S1
     C                     ENDIF
     C           F4SHN3    IFEQ *BLANK
     C                     MOVE *BLANK    F4S2
     C                     ELSE
     C                     MOVE '-'       F4S2
     C                     ENDIF
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     Z-ADDF4TOKU    SVTOKU  40
     C                     Z-ADDF4NONY    SVNONY  40
     C                     MOVELF4NKOJ    SVNKOJ  1
     C                     MOVELF4NUKE    SVNUKE  4
     C                     MOVELF4MHN     SVMHN  23
     C                     MOVELF4MHN1    SVMHN1
     C                     MOVELF4MHN2    SVMHN2
     C                     MOVELF4MHN3    SVMHN3
     C                     MOVELF4MHN4    SVMHN4
     C                     MOVELF4SHN     SVSHN  14
     C                     MOVELF4SHN1    SVSHN1  5
     C                     MOVELF4SHN2    SVSHN2  5
     C                     MOVELF4SHN3    SVSHN3  2
     C                     ENDIF
      * BREAK?
     C           F4TOKU    IFNE SVTOKU
     C           F4NONY    ORNE SVNONY
     C           F4NKOJ    ORNE SVNKOJ
     C           F4NUKE    ORNE SVNUKE
     C           F4MHN     ORNE SVMHN
     C           F4SHN     ORNE SVSHN
     C                     EXSR #BRK1
     C                     ENDIF
      * PROCESS
     C                     EXSR #PROC
      *
     C                     ENDDO
      * LAST BREAK
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK1
     C                     ENDIF
      * SET RETURN FLAG
     C           RCNT      IFEQ 0
     C                     MOVE '*'       P@STS
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *****************************************************************
      *                    BREAK PROCESS
      *****************************************************************
     C           #BRK1     BEGSR
      * ADJUST PRICE
     C           P@TYPE    IFEQ '2'
     C                     EXSR #UPRC
     C                     ENDIF
      * OUTPUT AB#WPT3
     C                     XFOOTF3Q       F3QT99
     C                     XFOOTF3A       F3AM99
      * GET FCEPP INFO.
     C                     EXSR #FCEP
     C                     WRITEMBDWPT31
     C                     ADD  1         RCNT    60
      * SAVE KEY
     C                     Z-ADDF4TOKU    SVTOKU
     C                     Z-ADDF4NONY    SVNONY
     C                     MOVELF4NKOJ    SVNKOJ
     C                     MOVELF4NUKE    SVNUKE
     C                     MOVELF4MHN     SVMHN
     C                     MOVELF4MHN1    SVMHN1
     C                     MOVELF4MHN2    SVMHN2
     C                     MOVELF4MHN3    SVMHN3
     C                     MOVELF4MHN4    SVMHN4
     C                     MOVELF4SHN     SVSHN
     C                     MOVELF4SHN1    SVSHN1
     C                     MOVELF4SHN2    SVSHN2
     C                     MOVELF4SHN3    SVSHN3
      * RESET FIELDS (MBDWPT3)
     C                     CLEARMBDWPT31
      *
     C                     ENDSR
      *----------------------------------------------------*
      *          GET PRODUCTION INFORMATION
      *----------------------------------------------------*
     C           #FCEP     BEGSR
     C                     SETOF                     53
     C                     MOVE SVSHN1    K@SHN1
     C                     MOVE SVSHN2    K@SHN2
     C                     MOVE SVSHN3    K@SHN3
     C           FCEKEY    CHAINFCEPL011             53
     C           *IN53     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSH8    ANDLE*DATE
     C                     SETON                     53
     C                     ENDIF
     C                     ENDIF
     C           FCEKEY    CHAINAAMPL111             53
     C           *IN53     IFEQ '0'
     C           CKSKJY    IFEQ 'D'
     C           CKGSH8    ANDLE*DATE
     C                     SETON                     53
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN53     IFEQ '0'
     C                     Z-ADDA2TUSZ    F3MSIZ
     C                     Z-ADDA2KUBI    F3SHNK
     C                     Z-ADDA2SSYS    F3QPC
     C                     MOVELA2MEK     F3MEKI
     C                     MOVE A2ZANM    F3MATE
      *
     C                     MOVE CKKO01    F3PC01
     C                     Z-ADDCKBM01    F3CD01
     C                     MOVE CKKO02    F3PC02
     C                     Z-ADDCKBM02    F3CD02
     C                     MOVE CKKO03    F3PC03
     C                     Z-ADDCKBM03    F3CD03
     C                     MOVE CKKO04    F3PC04
     C                     Z-ADDCKBM04    F3CD04
     C                     MOVE CKKO05    F3PC05
     C                     Z-ADDCKBM05    F3CD05
     C                     MOVE CKKO06    F3PC06
     C                     Z-ADDCKBM06    F3CD06
     C                     MOVE CKKO07    F3PC07
     C                     Z-ADDCKBM07    F3CD07
     C                     MOVE CKKO08    F3PC08
     C                     Z-ADDCKBM08    F3CD08
     C                     MOVE CKKO09    F3PC09
     C                     Z-ADDCKBM09    F3CD09
     C                     MOVE CKKO10    F3PC10
     C                     Z-ADDCKBM10    F3CD10
     C                     MOVE CKKO11    F3PC11
     C                     Z-ADDCKBM11    F3CD11
     C                     MOVE CKKO12    F3PC12
     C                     Z-ADDCKBM12    F3CD12
     C                     MOVE CKKO13    F3PC13
     C                     Z-ADDCKBM13    F3CD13
     C                     MOVE CKKO14    F3PC14
     C                     Z-ADDCKBM14    F3CD14
     C                     MOVE CKKO15    F3PC15
     C                     Z-ADDCKBM15    F3CD15
JW2   *MATERIAL WGT
 |   C                     Z-ADDA2SOZI    F3MWGT
 |    *FINISH   WGT
JW2  C                     Z-ADDA2KASI    F3FWGT
      *MONTHLY SET
JW3  C                     Z-ADDA2GEKN    F3MSET
      *
     C                     ENDIF
      *
     C                     ENDSR
      *****************************************************************
      *          PROCESS (SUMMARIZE BY PART, YEAR)
      *****************************************************************
     C           #PROC     BEGSR
      *
     C                     MOVELF4TOKU    F3TOKU
     C                     MOVELF4NONY    F3NONY
     C                     MOVE *BLANK    F3TONM
      * GET CUST NAME
     C           F4NONY    SETLLGADPL15
     C                     MOVE *OFF      *IN98
     C           *IN98     DOWEQ*OFF
     C           F4NONY    READEGADPL15                  98
     C           *IN98     IFEQ *OFF
     C                     MOVELB5KMEI    F3TONM
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVELF4NKOJ    F3NKOJ
     C                     MOVELF4NUKE    F3NUKE
     C                     MOVELF4MHN     F3MHIN
     C                     MOVELF4SHN     F3SHIN
      *
     C                     Z-ADD*ZERO     @M
     C                     DO   @SIZI
     C                     ADD  1         @M
      *
     C           #H1,@M    IFNE F4TNEN
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADD#H2,@M    @N      20
     C                     Z-ADD#TS,@N    F3Q,@M
     C                     Z-ADD#TN,@N    F3P,@M
      *
     C                     Z-ADD0         W@KING 150
     C           F3Q,@M    MULT F3P,@M    W@KING    H
     C                     ADD  W@KING    F3A,@M
      *
     C                     ENDDO
      *
     C                     ENDSR
      *****************************************************************
      *          ADJUST UNIT PRICE (IF P@TYPE='2')
      *****************************************************************
     C           #UPRC     BEGSR
      *
     C                     Z-ADD*ZERO     @M
     C                     DO   @SIZI
     C                     ADD  1         @M
      *
     C           #H1,@M    IFEQ 0
     C                     GOTO $UPRCX
     C                     ENDIF
      *
     C                     Z-ADD#H1,@M    TGT@YY
     C                     Z-ADD#H2,@M    TGT@MM
      *
     C                     MOVELTGT@DT    $DATE
     C                     MOVELSVTOKU    $TOKU
     C                     MOVELSVNONY    $NONY
     C                     MOVELSCPART    $CPART
     C                     CALL 'UTLR03'
     C                     PARM           $DATE   6
     C                     PARM           $TOKU   4
     C                     PARM           $NONY   4
     C                     PARM           $CPART 20
     C                     PARM           $UP     9
     C                     PARM           $RTN    1
      * CHANGE U/P AND AMOUNT
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$UP       @UP     95
     C                     Z-ADD@UP       F3P,@M
     C           F3Q,@M    MULT F3P,@M    F3A,@M    H
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           $UPRCX    TAG
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIALIZATION
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@TOKU  4
     C                     PARM           P@NONY  4
     C                     PARM           P@NKOJ  1
     C                     PARM           P@NUKE  4
     C                     PARM           P@YYYY  4
     C                     PARM           P@MM    2
     C                     PARM           P@SIZI  1
     C                     PARM           P@TYPE  1
     C                     PARM           P@STS   1
      *
     C           FCEKEY    KLIST
     C                     KFLD           K@SHN1  5
     C                     KFLD           K@SHN2  5
     C                     KFLD           K@SHN3  2
      *
     C                     MOVE *BLANK    P@STS
     C                     MOVELP@TOKU    @TOKU   40
     C                     MOVELP@NONY    @NONY   40
     C                     MOVELP@NKOJ    @NKOJ   1
     C                     MOVELP@NUKE    @NUKE   4
     C                     MOVELP@YYYY    @YYYY   40
     C                     MOVELP@MM      @MM     20
     C                     CLEARMBDWPT31
     C                     MOVEL'Y'       FIRST   1
     C                     MOVELP@TYPE    @T      10
     C                     Z-ADD0         @M      20
     C                     Z-ADD*DATE     @DATE   80
      *
      ** SET MONTHLY INDICATOR
     C                     SELEC
     C           P@SIZI    WHEQ '1'
     C                     Z-ADD6         @SIZI   20
     C           P@SIZI    WHEQ '2'
     C                     Z-ADD12        @SIZI
     C           P@SIZI    WHEQ '3'
     C                     Z-ADD24        @SIZI
     C                     ENDSL
     C                     Z-ADD*ZERO     #H1
     C                     Z-ADD*ZERO     #H2
     C                     EXSR #MON
      * OUTPUT HEADER
     C                     EXSR #HDR
     C                     CLEARMBDWPT31
      *
     C                     ENDSR
      *----------------------------------------------------*
      * SET MONTHLY INDICATOR
      *----------------------------------------------------*
     C           #MON      BEGSR
      *
     C                     Z-ADD*ZERO     @A      20
     C                     Z-ADD@YYYY     W@YY    40
     C                     Z-ADD@MM       W@MM    20
      *
     C                     DO   @SIZI
     C                     ADD  1         @A
      **
     C           @A        IFGT @SIZI
     C                     GOTO E#MON
     C                     ENDIF
      *
     C                     Z-ADDW@YY      #H1,@A
     C                     Z-ADDW@MM      #H2,@A
      *
     C           W@MM      IFLT 12
     C                     ADD  1         W@MM
     C                     ELSE
     C                     ADD  1         W@YY
     C                     Z-ADD1         W@MM
     C                     ENDIF
      **
     C                     ENDDO
      *
     C           E#MON     ENDSR
      *----------------------------------------------------*
      * OUTPUT HEADER
      *----------------------------------------------------*
     C           #HDR      BEGSR
      *
     C                     CLEARMBDWPT31
      *
     C                     MOVEL'****'    F3TOKU
     C                     MOVEL'****'    F3NONY
     C                     MOVEL'HDR2'    F3NUKE
     C                     MOVEL'AS OF'   LTR14  14
     C                     MOVE @DATE     LTR14
     C                     MOVELLTR14     F3MHIN
     C                     MOVE *ALL'*'   F3SHIN
     C                     MOVE *ALL'*'   F3MATE
     C                     MOVE *ALL'*'   F3MEKI
     C                     MOVE *ALL'*'   F3PC01
     C                     MOVE *ALL'*'   F3PC02
     C                     MOVE *ALL'*'   F3PC03
     C                     MOVE *ALL'*'   F3PC04
     C                     MOVE *ALL'*'   F3PC05
     C                     MOVE *ALL'*'   F3PC06
     C                     MOVE *ALL'*'   F3PC07
     C                     MOVE *ALL'*'   F3PC08
     C                     MOVE *ALL'*'   F3PC09
     C                     MOVE *ALL'*'   F3PC10
     C                     MOVE *ALL'*'   F3PC11
     C                     MOVE *ALL'*'   F3PC12
     C                     MOVE *ALL'*'   F3PC13
     C                     MOVE *ALL'*'   F3PC14
     C                     MOVE *ALL'*'   F3PC15
      *
     C                     Z-ADD0         @A      20
     C                     DO   @SIZI
     C                     ADD  1         @A
     C           #H1,@A    MULT 100       NUM6    60
     C                     ADD  #H2,@A    NUM6
     C                     Z-ADDNUM6      F3Q,@A
     C                     Z-ADDNUM6      F3A,@A
     C                     Z-ADDNUM6      F3P,@A
     C                     ENDDO
      *
     C                     WRITEMBDWPT31
      *
     C                     ENDSR
