     F*  N.HYOTO       01.02.27 ADD INVOICE #,RECORD LENGTH            *
     F****************** AB#R67 ****************************************
 GA  F*B#PL11 IF  E           K        DISK
 GA  FAB#PL17 IF  E           K        DISK
     FAB#WP671O   F     256            DISK
     FAB#WP672O   F     256            DISK
     FAB#WP673O   F     256            DISK
     I            DS
     I                                        1   80@NOHZ
     I                                        1   40@NOYY
     I                                        5   60@NOMM
     I                                        7   80@NODD
     I            DS
     I                                        1  20 $MHIN
     I                                        1   5 $MHN1
     I                                        6  10 $MHN2
     I                                       11  15 $MHN3
     I                                       16  20 $MHN4
      *
     C           KEY1      KLIST
     C                     KFLD           WNONY   40
     C*                    KFLD           PSIRE
     C*                    KFLD           PSIRK
     C                     KFLD           @NOYY
     C                     KFLD           @NOMM
     C                     KFLD           @NODD
     C                     KFLD           PODRN
      *
     C           *ENTRY    PLIST
     C                     PARM           PSIRE   4
     C                     PARM           PSIRK   1
     C                     PARM           PNOHZ   8
     C                     PARM           PODRN  10
     C                     PARM           PFLG    1
     C                     MOVE PNOHZ     @NOHZ
     C                     MOVELPSIRE     WNONY
      *
     C           KEY1      SETLLAB#PL171
      *
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY1      READEAB#PL171                 10
     C           *IN10     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           BASKJY    IFEQ 'D'
     C**         BASKHZ    ANDLE*DATE
     C                     ELSE
      *
     C           PODRN     IFEQ BAODRN
     C                     SETON                     U1
      *
     C                     Z-ADDBATANK    WTANK  134
     C                     Z-ADDBATANK    @@TANK 114
      *
     C           WTANK     IFEQ 0
      *
     C                     MOVELBATOKU    $TOKU   4
     C                     MOVELBANONY    $NONY   4
     C                     MOVELBANKOJ    $NKOJ   1
     C                     MOVELBANUKE    $NUKE   4
     C                     MOVELBAMHIN    $MHIN  20
     C                     MOVEL*BLANK    $SHIN  12
     C                     MOVEL*BLANK    $FLG    1
      *
     C                     CALL 'BBHR50'
     C                     PARM           $TOKU
     C                     PARM           $NONY
     C                     PARM           $NKOJ
     C                     PARM           $NUKE
     C                     PARM           $MHIN
     C                     PARM           $SHIN
     C                     PARM           $FLG
      *
     C           $FLG      IFEQ '*'
     C                     MOVE *BLANK    $MHN3
     C                     MOVE *BLANK    $MHN4
     C                     END
      *
     C                     MOVE BATOKU    @TOKU   4
     C                     MOVE BANONY    @NONY   4
     C                     MOVE BANKOJ    @NKOJ   1
     C                     MOVE BANUKE    @NUKE   4
     C                     MOVEL$MHIN     @MHIN  20
     C                     MOVE BANOHZ    @HIZK   8
     C                     Z-ADD0         @TANK  105
     C                     MOVE *BLANK    @CHEK   1
      *
     C                     CALL 'FBCR10'
     C                     PARM           @TOKU
     C                     PARM           @NONY
     C                     PARM           @NKOJ
     C                     PARM           @NUKE
     C                     PARM           @MHIN
     C                     PARM           @HIZK
     C                     PARM           @TANK
     C                     PARM           @CHEK
      *
     C                     Z-ADD@TANK     WTANK
     C                     Z-ADD@TANK     @@TANK
      *
     C                     END
      *
     C           WTANK     IFEQ 0
     C                     MOVE '*'       PFLG
     C                     END
      *
     C                     Z-ADDBANOHZ    WNOHZ   60
     C                     MOVELBANUKE    WNUKE   2
     C                     Z-ADDBASRYO    WSRYO  100
     C                     MOVELBAMHIN    WMHIN  30
      *
     C           BAUSYS    IFNE *ZERO
     C                     Z-ADDBAUSYS    WSYOS   60
     C                     ELSE
     C           BASYOS    IFNE *ZERO
     C                     Z-ADDBASYOS    WSYOS
     C                     ELSE
     C                     Z-ADD1         WSYOS
     C                     END
     C                     END
      *
     C                     EXCPTDT
      *
     C                     END
     C                     END
     C  N10                END
      *
     OAB#WP671E                DT
