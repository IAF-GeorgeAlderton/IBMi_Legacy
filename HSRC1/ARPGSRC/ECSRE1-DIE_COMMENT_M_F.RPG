     H            Y.
     F** ECSRE1 *********************************************
     F* DIE COMMENT M/F
     F*   MAEDA.          2019.03.19                        *
     F*******************************************************
     FECSPWE1 CF  E                    WORKSTN
     FECSPPE1 UF  E           K        DISK                      A
     FGCQPL14 IF  E           K        DISK
     E                    ER      1  11 65
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  14 SDATE
     I                                        1   6 STIME
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTECSPWE11
     C                     MOVEL*BLANK    D1ERR
     C                     SETOF                     313233
     C                     SETOF                     349930
      *
     C                     TIME           WTIME
     C           *IN01     IFEQ '1'
     C                     MOVEL'99'      DSPSW   2
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           *IN08     IFEQ '1'
     C                     CALL 'ECSRE2'
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1UPD     IFEQ '0'
     C           D1UPD     OREQ '1'
     C           D1UPD     OREQ '2'
     C                     ELSE
     C                     SETON                     3099
     C                     MOVELER,1      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1KAT1    IFEQ *BLANK
     C           D1KAT2    OREQ *BLANK
     C                     SETON                     3199
     C                     MOVELER,2      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           KEYCN     KLIST
     C                     KFLD           D1KAT1
     C                     KFLD           D1KAT2
     C                     KFLD           K1KAT3  1
     C                     MOVEL*BLANK    K1KAT3
      *
     C                     MOVEL'0'       GETGCQ  1
     C           KEYCN     SETLLGCQPL141
     C           KEYCN     READEGCQPL141                 20
     C           *IN20     DOWEQ'0'
     C           T6SKJY    IFEQ 'D'
     C           T6SKHZ    ANDLE*DATE
     C                     ELSE
     C           T6KIHZ    IFLE *DATE
     C                     MOVEL'1'       GETGCQ
     C                     ENDIF
     C                     ENDIF
     C           KEYCN     READEGCQPL141                 20
     C                     ENDDO
      *
     C           D1UPD     IFEQ '2'
     C           GETGCQ    IFEQ '0'
     C                     SETON                     3199
     C                     MOVELER,5      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
     C           KEYCN     CHAINECSPPE11             20
     C           *IN20     IFEQ '0'
     C           CNSKJY    ANDEQ'D'
     C           CNSKHZ    ANDLE*DATE
     C                     SETON                     20
     C                     ENDIF
      *
     C                     SETOF                     29
     C                     MOVEL*BLANK    D1TXT1
     C                     MOVEL*BLANK    D1TXT2
     C                     MOVEL*BLANK    D1TXT3
     C                     MOVEL*BLANK    D1TXT4
     C                     SELEC
     C           D1UPD     WHEQ '0'
     C           D1UPD     OREQ '1'
     C           *IN20     IFEQ '1'
     C                     SETON                     303199
     C                     MOVELER,3      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
     C                     MOVELCNTXT1    D1TXT1
     C                     MOVELCNTXT2    D1TXT2
     C                     MOVELCNTXT3    D1TXT3
     C                     MOVELCNTXT4    D1TXT4
     C           D1UPD     WHEQ '2'
     C           *IN20     IFEQ '0'
     C                     SETON                     303199
     C                     MOVELER,4      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDSL
      *
     C           D1UPD     IFEQ '0'
     C                     SETON                     29
     C                     ENDIF
     C                     MOVEL'02'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C                     EXFMTECSPWE12
     C                     MOVEL*BLANK    D1ERR
     C                     SETOF                     313233
     C                     SETOF                     349930
      *
     C           *IN03     IFEQ '1'
     C                     MOVEL'01'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           *IN05     IFEQ '1'
     C                     EXSR #SB500
     C                     MOVELD1UPD     Z1UPD
     C                     MOVELD1KAT1    Z1KAT1
     C                     MOVELD1KAT2    Z1KAT2
     C                     MOVEL*BLANK    D1UPD
     C                     MOVEL*BLANK    D1KAT1
     C                     MOVEL*BLANK    D1KAT2
     C                     MOVEL*BLANK    D1TXT1
     C                     MOVEL*BLANK    D1TXT2
     C                     MOVEL*BLANK    D1TXT3
     C                     MOVEL*BLANK    D1TXT4
     C                     MOVEL'01'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * UPDATE                                             *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYCN     CHAINECSPPE11             20
      *
     C                     SELEC
      *
     C           D1UPD     WHEQ '0'
     C                     MOVEL'D'       CNSKJY
     C                     Z-ADD0         CNSKHZ
     C           *IN20     IFEQ '0'
     C                     UPDATECSPPE11
     C                     ENDIF
      *
     C           D1UPD     WHEQ '1'
     C           *IN20     IFEQ '0'
     C                     Z-ADD*DATE     CNKOHZ
     C                     TIME           CNKOTI
     C                     MOVELW#USER    CNKOME
     C                     MOVELD1TXT1    CNTXT1
     C                     MOVELD1TXT2    CNTXT2
     C                     MOVELD1TXT3    CNTXT3
     C                     MOVELD1TXT4    CNTXT4
     C                     UPDATECSPPE11
     C                     ENDIF
      *
     C           D1UPD     WHEQ '2'
     C                     CLEARECSPPE11
     C                     Z-ADD*DATE     CNKOHZ
     C                     TIME           CNKOTI
     C                     MOVELW#USER    CNKOME
     C                     MOVELD1KAT1    CNKAT1
     C                     MOVELD1KAT2    CNKAT2
     C                     MOVEL*BLANK    CNKAT3
     C                     MOVEL*BLANK    CNKAT4
     C                     MOVELD1TXT1    CNTXT1
     C                     MOVELD1TXT2    CNTXT2
     C                     MOVELD1TXT3    CNTXT3
     C                     MOVELD1TXT4    CNTXT4
     C           *IN20     IFEQ '0'
     C                     UPDATECSPPE11
     C                     ELSE
     C                     WRITEECSPPE11
     C                     ENDIF
      *
     C                     ENDSL
      *
     CSR         ESB500    ENDSR
**
ER-1 INPUT 0,1,2.
ER-2 INPUT DIE #.
ER-3 NO DATA.
ER-4 ALREADY EXIST.
ER-5 NO DIE KANBAN M/F.
