     H            Y.
     F** AB#R3@ ********************************************
     F*  PICK-UP LIST GET SUB-ROUTE FOR TOYOTA             *
     F*                                                    *
     F* TCHK1 01/15/09 CREATE                              *
     F******************************************************
     FAB#PP40 IF  E           K        DISK
      *--------------------------------------------------
     I           SDS
     I                                        1   8 @PGMID
     I                                        1   6 PGMID
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I            DS
     I                                        1  140WSSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
     I*
     C* ----------------------------------------------------
     C                     TIME           WSSDT
     C*
     C           *ENTRY    PLIST
     C                     PARM           PMNONY  4
     C                     PARM           PMNKOJ  1
     C                     PARM           PMNUKE  4
     C                     PARM           PMNOYY  4
     C                     PARM           PMNOMM  2
     C                     PARM           PMNODD  2
     C                     PARM           PMNOBN  2
     C                     PARM           PMINVN 16
     C                     PARM           PMSUB#  7
     C*
     C                     MOVEL*BLANK    PMSUB#
     C*
     C                     DO
     C*
     C           PMNONY    IFEQ '0541'                     NUMMI
     C           PMNONY    OREQ '0542'                     NUMMI S
     C           PMNONY    OREQ '3764'                     TMMAL
     C           PMNONY    OREQ '3765'                     TMMAL S
     C           PMNONY    OREQ '3481'                     TMMBC
     C           PMNONY    OREQ '3482'                     TMMBC S
     C           PMNONY    OREQ '3503'                     TMMC
     C           PMNONY    OREQ '3504'                     TMMC S
     C           PMNONY    OREQ '3804'                     TMMI
     C           PMNONY    OREQ '3805'                     TMMI S
     C           PMNONY    OREQ '3347'                     TMMK
     C           PMNONY    OREQ '3348'                     TMMK S
     C           PMNONY    OREQ '3220'                     TMMNK
     C           PMNONY    OREQ '3421'                     TMMNK S
     C           PMNONY    OREQ '3851'                     TMMTX
JW   C           PMNONY    OREQ '3226'                     TMMGT
"    C           PMNONY    OREQ '3227'                     TMMGT S
"    C           PMNONY    OREQ '3770'                     MTMUS
"    C           PMNONY    OREQ '3941'                     TBMNC
     C           PMNONY    OREQ '3852'                     TMMTX S
     C           PMNONY    OREQ '3931'                     TMMWV
     C           PMNONY    OREQ '3932'                     TMMWV S
     C                     ELSE
     C                     LEAVE
     C                     END
     C*
     C                     MOVELPMNONY    W@NONY  40
     C                     MOVELPMNUKE    W@NUKE  4
     C                     MOVELPMNOYY    W@NOYY  40
     C                     MOVELPMNOMM    W@NOMM  20
     C                     MOVELPMNODD    W@NODD  20
     C                     MOVELPMNOBN    W@NOBN  20
     C                     MOVELPMINVN    W@INVN 15
     C*
     C           K#PP40    KLIST
     C                     KFLD           W@NONY
     C                     KFLD           W@NOYY
     C                     KFLD           W@NOMM
     C                     KFLD           W@NODD
     C                     KFLD           W@NUKE
     C*
     C           K#PP40    SETLLAB#PP40
     C*
     C                     DO   *HIVAL
     C*
     C           K#PP40    READEAB#PP40                  99
     C   99                LEAVE
     C           DASKJY    IFNE *BLANK
     C                     ITER
     C                     END
      *
     C           DANOBN    IFEQ W@NOBN
     C           DAORDN    ANDEQW@INVN
     C                     MOVELDASUB#    PMSUB#
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
