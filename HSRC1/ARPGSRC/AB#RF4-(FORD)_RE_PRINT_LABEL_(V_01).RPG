     C**************************************************************************
     C*                    MAIN ROUTINE                                        *
     C**************************************************************************
     C                     EXSR #INIT
      * DO LOOP *
     C                     DO   *HIVAL
     C                     EXFMTFMT01
     C                     SETOF                     3031
     C                     MOVE *BLANK    XMSG
     C                     MOVE WKBLK     *IN,32
      *
     C                     EXSR #CHK
      *
     C                     SELEC
      * F1: END
     C           *INKA     WHEQ *ON
     C           *INKC     OREQ *ON
     C                     LEAVE
      * F5: RUN
     C           *INKE     WHEQ *ON
     C           *IN30     IFEQ *OFF
     C                     EXSR #F5
     C                     ENDIF
     C* F12: INQ
     C           *INKL     WHEQ *ON
     C                     CALL 'ABFR44'
     C* ENTER
     C                     OTHER
     C           *IN30     IFEQ *OFF
     C                     EXSR #SET
     C                     MOVELMES,8     XMSG
     C                     ENDIF
     C                     ENDSL
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C**************************************************************************
     C*  #CHK : CHECK INPUT FIELD
     C**************************************************************************
     C           #CHK      BEGSR
     C*
     C           #SEQFR    IFEQ 0
     C           #SEQTO    ANDEQ0
     C           #SEQ1     ANDEQ0
     C                     SETON                     3031
     C                     MOVEAMES,1     XMSG
     C                     GOTO XCHK
     C                     ENDIF
     C*
     C           #SEQFR    IFNE 0
     C           #SEQTO    ANDEQ0
     C                     Z-ADD#SEQFR    #SEQTO
     C                     ENDIF
     C*
     C           #SEQFR    IFNE 0
     C           #SEQTO    ANDNE0
     C           #SEQFR    ANDGT#SEQTO
     C                     SETON                     3031
     C                     MOVEAMES,7     XMSG
     C                     GOTO XCHK
     C                     ENDIF
      * CHECK EACH SEQ#
     C           1         DO   15        LX      20
     C           SEQ,LX    IFNE *ZERO
     C                     MOVE SEQ,LX    KSEQ
     C           KEY1      CHAINABF6L01             N90
     C*
     C           *IN90     IFEQ '1'
     C                     SETON                     30
     C           LX        ADD  31        MX
     C                     MOVEA'1'       *IN,MX
     C**                   MOVEAMES,1     XMSG
JW4  C                     MOVEAMES,6     XMSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C*
     C           XCHK      ENDSR
     C**************************************************************************
     C*  #SET : SET FIELD OF DISPLAY
     C**************************************************************************
     C           #SET      BEGSR
JW2  C                     MOVE WKBLK     *IN,32
     C                     MOVE *BLANK    DEL
     C                     MOVE *ZERO     SHD
     C                     MOVE *BLANK    PAR
     C                     MOVE *BLANK    STS
     C*
     C           1         DO   15        JX      20
     C           SEQ,JX    IFNE 0
TCHK2C                     MOVE SEQ,JX    KSEQ
TCHK2C           KEY1      CHAINABF6L01             N90
TCHK2C           *IN90     IFEQ *OFF
     C**                   MOVEAWCDELY    DEL,JX           DELIVERY
     C**                   MOVEAWCSHDT    SHD,JX           SHIPPING DATE
     C**                   MOVEAWCIPAR    PAR,JX           PART
JW2  C                     MOVELFCDELY    DEL,JX           DELIVERY
     C                     MOVELFCSHDT    SHD,JX           SHIPPING DATE
     C                     MOVELFCIPAR    PAR,JX    P      PART
      * STATUS
JW2  C                     SELEC
 .   C           FCPRNT    WHEQ ' '
 .   C                     MOVELMES,2     STS,JX
 .   C           FCPRNT    WHEQ 'C'
 .   C                     MOVELMES,3     STS,JX
 .   C           FCPRNT    WHEQ 'P'
 .   C                     MOVELMES,4     STS,JX
 .   C           FCPRNT    WHEQ 'A'
 .   C                     MOVELMES,5     STS,JX
 .   C                     OTHER
 .   C                     MOVE *BLANK    STS,JX
 .   C                     ENDSL
 .    * NOT FOUND
 .   C                     ELSE
JW2  C                     MOVELMES,6     STS,JX
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
     C*
     C                     ENDSR
     C**************************************************************************
     C*  #F5 : RE-CREATE LABEL DATE
     C**************************************************************************
     C           #F5       BEGSR
     C*
     C* FROM - TO  ================================
     C           #SEQFR    IFNE *ZERO
     C                     Z-ADD#SEQFR    KSEQ
     C           KEY1      SETLLABF6L01
     C                     READ ABF6L01                  90
     C           *IN90     DOUEQ'1'
     C           FCSEQ#    ORGT #SEQTO
     C*
     C           FCSKJY    IFNE 'D'
     C           FCPRNT    ANDNE'C'
     C                     EXSR #ADR
     C                     EXSR #NMBR1
     C           FCPRNT    IFEQ *BLANK
     C**TEMP               MOVE 'P'       FCPRNT
     C                     ENDIF
      *
     C                     UPDATABF6P011
      *=================
      * CONTAINER LABEL
      *=================
     C           FCPBCD    IFEQ 'S'
TCHK C                     WRITEABF7P011
     C                     WRITEABF7P011
      *
JW3  C                     Z-ADD11        SER3F
     C                     MOVEL'ABF7P01' IXWRKF
 .   C                     EXSR #XP01                      =>AB#XP01 #1-1
      *
     C                     ENDIF
      *==============
      * MASTER LABEL
      *==============
     C           FCPBCD    IFEQ 'M'
     C                     MOVE FC#PLT    F7PLT#
     C                     WRITEABF7P021
JW4  C                     WRITEABF7P021
      *
JW3  C                     Z-ADD21        SER3F
     C                     MOVEL'ABF7P02' IXWRKF
 .   C                     EXSR #XP01                      =>AB#XP01 #2-1
      *
     C                     ENDIF
      *===========
      * MIX LABEL
      *===========
     C****       FCDELY    IFNE @@DLY
     C**         FCDELY    IFNE 5156
     C**         FCDELY    ANDNE5148
     C**         FCDELY    ANDNE5151
     C**         FCDELY    ANDNE5172
     C**         FCDELY    ANDNE5191
     C**         FCDELY    ANDNE5196
     C**         FCDELY    ANDNE5197
     C                     EXSR #MIX
     C**                   ENDIF
      *
     C                     ENDIF
     C*
     C                     READ ABF6L01                  90
     C                     ENDDO
     C                     ENDIF
      *===============================================
      *===============================================
     C* INDIVISUAL
     C           #SEQFR    IFEQ 0
     C           1         DO   15        LX
     C*
     C           SEQ,LX    IFNE *ZERO
     C                     MOVE SEQ,LX    KSEQ
     C           KEY1      SETLLABF6L01
     C           KEY1      READEABF6L01                  90
     C*
     C           *IN90     DOWEQ'0'
     C*
     C           FCSKJY    IFNE 'D'
     C           FCPRNT    ANDNE'C'
     C                     EXSR #ADR
     C                     EXSR #NMBR1
      *=================
      * CONTAINER LABEL
      *=================
     C           FCPBCD    IFEQ 'S'
TCHK C                     WRITEABF7P011
     C                     WRITEABF7P011
      *
JW3  C                     Z-ADD12        SER3F
     C                     MOVEL'ABF7P01' IXWRKF
 .   C                     EXSR #XP01                      =>AB#XP01 #1-2
      *
     C                     ENDIF
      *
      *===============
      * MASTER LABEL
      *===============
     C           FCPBCD    IFEQ 'M'
     C                     MOVE FC#PLT    F7PLT#
     C                     WRITEABF7P021
JW4  C                     WRITEABF7P021
      *
JW3  C                     Z-ADD22        SER3F
     C                     MOVEL'ABF7P02' IXWRKF
 .   C                     EXSR #XP01                      =>AB#XP01 #2-2
      *
     C                     ENDIF
      *============
      * MIX LABEL
      *============
     C**         FCDELY    IFNE @@DLY
     C**         FCDELY    IFNE 5156
     C**         FCDELY    ANDNE5148
     C**         FCDELY    ANDNE5151
     C**         FCDELY    ANDNE5172
     C**         FCDELY    ANDNE5191
     C**         FCDELY    ANDNE5196
     C**         FCDELY    ANDNE5197
     C                     EXSR #MIX
     C**                   ENDIF
      *
     C                     ENDIF
      *
     C           KEY1      READEABF6L01                  90
     C                     ENDDO
     C*
     C                     ENDIF
     C*
     C                     ENDDO
     C                     ENDIF
     C*
     C                     MOVE *ZERO     #SEQFR
     C                     MOVE *ZERO     #SEQTO
     C                     MOVE *ALL'0'   SEQ
     C                     MOVE *BLANK    DEL
     C                     MOVE *ZERO     SHD
     C                     MOVE *BLANK    PAR
JW2  C                     MOVE *BLANK    STS
     C*
     C                     ENDSR
      *-------------------------------------------------
      * RETRIEVE ADDRESSES
      *-------------------------------------------------
     C           #ADR      BEGSR
      *
     C           FCDELY    CHAINGADPL13              95
TCHK2C           *IN95     IFEQ *OFF
     C                     MOVELB5KMEI    F7NAME    P
     C           'FORD'    SCAN B5KMEI                   10
     C           *IN10     IFEQ *OFF
     C           'FORD'    CAT  B5KMEI:1  F7NAME    P
     C                     ENDIF
TCHK2C                     END
      * ADDED BY JW
JW1  C           KEY9      CHAINGADPL13              95
JW1  C           *IN95     IFEQ *OFF
JW1  C                     MOVELB5KMEI    F7NAME    P
JW1  C           'FORD'    SCAN B5KMEI                   10
JW1  C           *IN10     IFEQ *OFF
JW1  C           'FORD'    CAT  B5KMEI:1  F7NAME    P
JW1  C                     ENDIF
JW1  C                     ENDIF
      *
     C                     MOVE FCDELY    WDELY
     C           KEY3      CHAINABF9P011             95
   B1C           *IN95     IFEQ '0'
     C                     MOVELF9ADD1    F7ADD1
     C                     MOVELF9ADD2    F7ADD2
     C                     MOVELF9DOCK    F7CUST
   E1C                     END
      *
      *** get container type to include in 2D barcode.
     C           F7CUST    IFNE *BLANK
     C                     CALL 'AB#RYZ'
     C                     PARM           F7CUST
     C                     PARM           F7CONT
     C                     ENDIF
      *
      *** check european label flag in EDI address file to determine
      *   foreign or domestic.  domestic=blank, foreign='Y'
     C                     MOVELFCDELY    DLVCD   4
     C           DLVCD     CHAINEDIPP42              95
     C           *IN95     IFEQ *OFF
     C           E4SKJY    ANDEQ*BLANK
     C           E4FLG2    IFEQ 'Y'                        EUROPEAN LABL FLAG
     C                     MOVE 'F'       FORD    1          FOREIGN
     C                     ELSE
     C                     MOVE 'D'       FORD               DOMESTIC
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*  #NMBR1 SUBROUTINE: MOVE DATA FROM DBFILES TO FILE ABF8P01
     C**************************************************************************
     C           #NMBR1    BEGSR
     C*
     C                     MOVE FCDELY    F7NONY
%0001C                     MOVEL*BLANK    F7LNFD
%0001C                     MOVEL'0'       WNKOJ   1
%0001C                     MOVE FCSHTM    WSHTM   20
     C                     MOVELFCSEQ#    F7SEQ#
     C                     MOVE FCSHYY    F7XY
     C                     MOVE FCSHDD    F7XD
     C                     Z-ADDFCSHMM    PX
     C                     MOVE MON,PX    F7XM
     C                     MOVE *BLANK    WDELY   4
     C                     MOVE FCDOCK    F7DOCK           DOCK CODE
      *
%0001C           KEY8      SETLLAB#PL141
     C           *IN20     DOUEQ*ON
%0001C           KEY8      READEAB#PL141                 20
%0001C           *IN20     IFEQ '0'
%0001C           BASKJY    ANDEQ*BLANK
%0001C                     MOVELBAALFL    F7LNFD
     C                     MOVELBASHIN    F7IPAR
     C                     MOVELBARESE    F7STAD
TCHK2C                     EXSR #MOVS1
     C                     MOVE BANONY    EKNONY
     C                     MOVE BANKOJ    EKNKOJ
     C                     MOVE BANUKE    EKNUKE
     C                     MOVE BASYOS    EKSYOS
     C                     MOVE BAODRN    EKODRN
      ** RECORD NUMBER
     C                     Z-ADDBATOKU    EKTOKU
     C                     MOVELBAMHN1    EKMHN1
     C                     MOVELBAMHN2    EKMHN2
     C                     MOVELBAMHN3    EKMHN3
     C                     MOVELBAMHN4    EKMHN4
     C                     MOVE BANOBN    EKNOBN
     C                     Z-ADDBADEYY    EKRLYY
     C                     Z-ADDBADEMM    EKRLMM
     C                     Z-ADDBADEDD    EKRLDD
     C                     LEAVE
%0001C                     ENDIF
%0001C                     ENDDO
      *
     C                     MOVE *BLANK    F7LOC
     C           KEY4      CHAINFCEPL011             15
   B1C           *IN15     IFEQ '0'
   B2C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADDA2KASI    @@WGHT  72
     C                     MOVELA2SMEI    F7DESC
     C                     MOVE A2ZETI    EKZETI
%0001C                     Z-ADDA2SSYS    P11
%0001C                     MOVE *BLANK    P12
%0001C                     CALL 'AB#R2K'  P1
%0001C                     MOVELP12       F7SPQY
      *
TCHK3C*          A2TRHZ    IFLE *DATE
TCHK3C           A2TRHZ    IFLE BANOHZ
     C                     MOVELA2STKR    F7LOC
     C                     ELSE
     C                     MOVELA2KTKR    F7LOC
   E3C                     END
 | E2C                     END
 TTE1C                     END
      *
     C                     MOVE FCSERL    F7SERL
     C           FCPBCD    IFEQ 'S'
     C           FCSERL    ANDEQ*BLANK
      ** SERIAL NUMBER
     C                     EXSR #NMBR
     C                     MOVE N3NMBR    F7SERL
     C                     MOVE N3NMBR    FCSERL
      *
     C                     EXSR #PP70
     C                     ENDIF
      *
     C                     MOVELFCCPAR    F7PBAR
     C                     MOVEAFCCPAR    PNO
     C                     MOVE *BLANK    NOB
     C           1         DO   20        MX      20
     C           PNO,MX    IFEQ *BLANK
     C           MX        ADD  1         PX
     C           PNO,PX    IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
     C                     MOVE '-'       NOB,MX
     C                     ELSE
     C                     MOVE PNO,MX    NOB,MX
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEANOB       F7PART
     C*
     C* FIND THE FIRST BLANK BEFORE THE SUFIX PART NUMBER
     C                     Z-ADD20        MX      20
     C                     MOVEAFCCPAR    PNO
     C           PNO,MX    DOUNE*BLANK
     C                     SUB  1         MX
     C                     END
     C*
     C           PNO,MX    DOUEQ*BLANK
     C                     SUB  1         MX
     C                     END
     C*
     C                     Z-ADD*ZERO     WX      20
     C                     MOVE *BLANK    NOB
     C           MX        SUB  1         PX      20
     C           1         DO   PX        WX
     C                     MOVE PNO,WX    NOB,WX
     C                     END
     C                     MOVEANOB       F7BASE
     C*
     C                     Z-ADD*ZERO     WX      20
     C                     Z-ADD1         TX      20
     C                     MOVE *BLANK    NOA
     C           MX        ADD  1         PX      20
     C           PX        DO   20        WX
     C                     MOVE PNO,WX    NOA,TX
     C           TX        IFEQ 4
     C           TX        ADD  1         TT      20
     C           PNO,TT    IFNE *BLANK
     C                     ADD  1         TX
     C                     ENDIF
     C                     ENDIF
     C                     ADD  1         TX
     C                     END
     C                     MOVEANOA       F7SUFX
     C*
%0001C                     Z-ADDFCRQTY    P11
%0001C                     MOVE *BLANK    P12
%0001C                     CALL 'AB#R2K'  P1
%0001C                     MOVELP12       WWRQTY 15
%0001C                     Z-ADDFCUQTY    P11
%0001C                     MOVE *BLANK    P12
%0001C                     CALL 'AB#R2K'  P1
%0001C                     MOVELP12       WWUQTY 15
     C*
     C                     SELEC
   B1C           FCPBCD    WHEQ 'M'
%0001C                     MOVELWWRQTY    F7QTY
%0001C                     MOVELLBL,1     F7LABL
   B1C           FCPBCD    WHEQ 'S'
%0001C                     MOVELWWUQTY    F7QTY
%0001C                     MOVEL*BLANK    F7LABL
   E1C                     ENDSL
      *
      *
     C                     SELEC
   B1C           FCPBCD    WHEQ 'M'
     C           FCRQTY    MULT @@WGHT    @TWGHT 112
   B1C           FCPBCD    WHEQ 'S'
     C           FCUQTY    MULT @@WGHT    @TWGHT 112
     C                     ENDSL
      *
     C           @TWGHT    DIV  1000      @TWGHT
IH   C           @TWGHT    MULT 2.2046    @@LIB  112H
     C                     SELEC
   B1C           FCPBCD    WHEQ 'M'
     C           FCRQTY    DIV  A2SSYS    PX
     C           0.7       MULT PX        @BOX   112
     C           @@LIB     ADD  @BOX      @@LIB
   B1C           FCPBCD    WHEQ 'S'
     C                     ADD  0.7       @@LIB
     C                     ENDSL
      *
     C           @@LIB     MULT 1         @LWGHT  90H
%0001C                     Z-ADD@LWGHT    P11
%0001C                     MOVE *BLANK    P12
%0001C                     CALL 'AB#R2K'  P1
%0001C                     MOVELP12       F7GWEH
      *
      *
     C           K#4P      CHAINABF4P01              95
     C           *IN95     IFEQ *OFF
     C                     Z-ADDYBPS#     @@ASN   60
     C                     ELSE
     C                     Z-ADD*ZERO     @@ASN
     C                     ENDIF
      *
     C                     MOVEL'AVRTA'   F7SUPL
      * 2D
     C                     MOVE *BLANK    @DX7
     C           'P'       CAT  F7PBAR:0  @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
     C           @DX7      CAT  'Q':0     @DX7      P
     C           @DX7      CAT  F7QTY:0   @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
     C           @DX7      CAT  'V':0     @DX7      P
     C           @DX7      CAT  F7SUPL:0  @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
      *
     C           @DX7      CAT  'Z':0     @DX7      P      DATA IDENTIFIER
     C           @DX7      CAT  F7GWEH:0  @DX7      P       GROSS WEIGHT
     C           @DX7      CAT  @HX6:0    @DX7      P      GROUP SEPARATOR
      *
     C           @DX7      CAT  'D':0     @DX7      P
     C                     MOVE FCSHDT    @6      6
     C           @DX7      CAT  @6:0      @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
   B1C           FCPBCD    IFEQ 'M'
     C           @DX7      CAT  'M':0     @DX7      P
     C                     ELSE
     C           @DX7      CAT  'S':0     @DX7      P
     C                     ENDIF
     C           @DX7      CAT  F7SEQ#:0  @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
      *
     C           F7CONT    IFNE *BLANKS
     C           @DX7      CAT  'B':0     @DX7      P      DATA IDENTIFIER
     C           @DX7      CAT  F7CONT:0  @DX7      P       CONTAINER TYPE
     C           @DX7      CAT  @HX6:0    @DX7      P      GROUP SEPARATOR
     C                     ENDIF
      *
     C           F7STAD    IFNE *BLANK
     C           @DX7      CAT  'L':0     @DX7      P
     C           @DX7      CAT  F7STAD:0  @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
     C                     ENDIF
     C           FORD      IFEQ 'D'                        DOMESTIC cust label
     C           @DX7      CAT  '20L':0   @DX7      P
     C           @DX7      CAT  F7LNFD:0  @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
     C                     ELSE
     C           FORD      IFEQ 'F'                        FOREIGN cust label
     C           @@ASN     ANDNE*ZERO
     C                     MOVEL@@ASN     F7LNFD           ... for 2D barcode
     C           @DX7      CAT  'N':0     @DX7      P      DATA IDENTIFIER
     C           @DX7      CAT  F7LNFD:0  @DX7      P       ASN NUMBER
     C           @DX7      CAT  @HX6:0    @DX7      P      GROUP SEPARATOR
     C           'ASN'     CAT  F7LNFD:0  F7LNFD    P      ...for field itself
     C                     ENDIF
     C                     ENDIF
      *
     C           F7CUST    IFNE *BLANKS
     C           @DX7      CAT  '8V':0    @DX7      P      DATA IDENTIFIER
     C           @DX7      CAT  F7CUST:0  @DX7      P       CUST PLANT CODE
     C           @DX7      CAT  @HX6:0    @DX7      P      GROUP SEPARATOR
     C                     ENDIF
      *
     C           @DX7      CAT  '1L':0    @DX7      P
     C           @DX7      CAT  F7DOCK:0  @DX7      P
     C           @DX7      CAT  @HX4:0    @DX7      P
     C           @DX7      CAT  @HX7:0    @DX7      P
     C                     MOVEL@DX       F72DBD    P
      *
     C                     ENDSR
TCHK2C*-------------------------------------------------------------------------
TCHK2C           #MOVS1    BEGSR
TCHK2C*
