     FEDIPW55 CF  E                    WORKSTN
     F                                              KINFDS WSDS
     FFGBPL01 IF  E           K        DISK
     FEDIPP50 UF  E           K        DISK                      A
     **==============================================================**
     E                    @SL     1   3  6                SELECT
     E                    @MS     1  17 53                ERR MSG
     **==============================================================**
     I            DS
     I                                        1  140S@TIME
     I                                        1   60S@HMS
     I                                        1   20S@TMHH
     I                                        3   40S@TMMM
     I                                        5   60S@TMSS
     I                                        7  140S@YYMD
     I                                        7  100S@DYYY
     I                                       11  120S@DYMM
     I                                       13  140S@DYDD
     IWSDS        DS
     I                                    B 370 3710S@CUR
     I                                      370 370 S@LIN
     I                                      371 371 S@COL
     I                                    B 378 3790S@POS
     I            DS
     I                                        1   8 W@SEL
     I                                        1   1 W@SEL1
     I                                        2   2 W@HF
     I                                        3   8 W@SEL2
     I           SDS
     I                                     *PROGRAM S@PGID
     I                                      244 253 S@WSID
     I                                      254 263 S@USID
     I                                      264 269 S@JBID
     **==============================================================**
     **   ENTRY                                                      **
     **==============================================================**
     C           *ENTRY    PLIST
     C                     PARM           P1SUPP  4
     **==============================================================**
     **                    MAIN ROUTINE                              **
     **==============================================================**
      *
     C                     EXSR #INIT
      *
     C           W@NEXT    DOUEQ'END  '
      * SCREEN1
     C           W@NEXT    CASEQ'SET10'   #SET10
     C           W@NEXT    CASEQ'PNL10'   #PNL10
     C           W@NEXT    CASEQ'CHK10'   #CHK10
      * SCREEN2
     C           W@NEXT    CASEQ'SET20'   #SET20
     C           W@NEXT    CASEQ'PNL20'   #PNL20
     C           W@NEXT    CASEQ'CHK20'   #CHK20
     C**         W@NEXT    CASEQ'WIN20'   #WIN20
      *
     C           W@NEXT    CASEQ'DBOUT'   #DBOUT
     C                     END
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-------------------------------------------------------------------------
      * SET INITIAL VALUE FOR SCREEN1
      *-------------------------------------------------------------------------
     C           #SET10    BEGSR
      *
     C                     SETOF                     909192
     C                     SETOF                     414243
     C                     SETOF                     44
JW1  C                     SETOF                     6162
     C                     SETOF                     99
      *
     C                     MOVEL*BLANK    D1SEL
     C                     MOVELP1SUPP    D1NONY
     C                     MOVEL*BLANK    D1SNRV
     C                     MOVEL*BLANK    D1DKBN
     C                     MOVEL*BLANK    D1NAME
     C                     MOVEL*BLANK    D1MSG
      *
      * NEXT-CONTROL
     C                     MOVEL'PNL10'   W@NEXT           G1-PNL
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      * SCREEN1 PROCESS
      *-------------------------------------------------------------------------
     C           #PNL10    BEGSR
      *
     C                     MOVE *BLANK    D1NAME
      * CHECK DETAIL CODE
     C           D1NONY    IFNE *BLANK
     C                     MOVELD1NONY    NUM4
     C           NUM4      CHAINFGBPL01              95
     C           *IN95     IFEQ *OFF
     C                     MOVELB2SMEI    D1NAME
     C                     ENDIF
     C                     ENDIF
      *
     C                     EXFMTDSP01
      *
     C                     SETOF                     909192
     C                     SETOF                     414243
     C                     SETOF                     44
JW1  C                     SETOF                     6162
     C                     SETOF                     99
     C                     MOVEL*BLANK    D1MSG            * ERR MSG
      *
      * F03: END
     C           *INKA     IFEQ *ON
     C                     MOVEL'END  '   W@NEXT
     C                     GOTO XPNL10
     C                     ENDIF
      * F12: INQ
     C           *INKL     IFEQ *ON
     C                     CALL 'EDIR56'
     C                     PARM           D1NONY
     C                     PARM           D1SNRV
     C                     PARM           D1DKBN
     C                     MOVEL'PNL10'   W@NEXT
     C                     GOTO XPNL10
     C                     ENDIF
      * ENTER
     C                     MOVEL'CHK10'   W@NEXT
      *
     C           XPNL10    ENDSR
      *-------------------------------------------------------------------------
      *  CHECK FIELDS OF SCREEN1
      *-------------------------------------------------------------------------
     C           #CHK10    BEGSR
      *
     C           D1SEL     IFNE '0'
     C           D1SEL     ANDNE'1'
     C           D1SEL     ANDNE'2'
     C  N99                MOVEL@MS,01    D1MSG     P
     C  N99                SETON                     4199
     C                     GOTO XCHK10
     C                     ENDIF
      *
     C                     SELEC
     C           D1SEL     WHEQ '0'
     C                     SETON                     90
     C           D1SEL     WHEQ '1'
     C                     SETON                     91
     C           D1SEL     WHEQ '2'
     C                     SETON                     92
     C                     ENDSL
      * CHECK DETAIL CODE
     C                     MOVELD1NONY    NUM4    40
     C           NUM4      CHAINFGBPL01              95
     C           *IN95     IFEQ *ON
     C  N99                MOVEL@MS,08    D1MSG     P
     C  N99                SETON                     42
     C  N99                SETON                     99
     C                     GOTO XCHK10
     C                     ENDIF
     C                     MOVELB2SMEI    D1NAME
      *
     C           D1NONY    IFEQ *BLANK
     C           D1SNRV    ANDEQ*BLANK
     C           D1DKBN    ANDEQ*BLANK
     C  N99                MOVEL@MS,02    D1MSG     P
     C  N99                SETON                     424344
     C  N99                SETON                     99
     C                     GOTO XCHK10
     C                     ENDIF
     C                     MOVELB2SMEI    D1NAME
      * CHECK R/S
     C           D1SNRV    IFNE 'S'
     C           D1SNRV    ANDNE'R'
     C  N99                MOVEL@MS,06    D1MSG     P
     C  N99                SETON                     43
     C  N99                SETON                     99
     C                     GOTO XCHK10
     C                     ENDIF
      *
     C           *IN99     IFEQ '0'
     C                     MOVELD1NONY    K@NONY
     C                     MOVELD1SNRV    K@SNRV
     C                     MOVELD1DKBN    K@DKBN
     C           K@EDI     CHAINEDIPP50             N80
     C           *IN80     IFEQ '0'
      * ADD
     C           D1SEL     IFEQ '2'
     C           E5SKJY    IFEQ 'D'
     C                     ELSE
     C  N99                MOVEL@MS,05    D1MSG     P
     C  N99                SETON                     424344
     C  N99                SETON                     99
     C                     GOTO XCHK10
     C                     ENDIF
     C                     ENDIF
      * CHANGE/DELETE
     C           D1SEL     IFEQ '0'
     C           D1SEL     OREQ '1'
     C           E5SKJY    IFEQ 'D'
     C  N99                MOVEL@MS,04    D1MSG     P
     C  N99                SETON                     424344
     C  N99                SETON                     99
     C                     ENDIF
     C                     ENDIF
      *
     C                     ELSE
      * CHANGE/DELETE
     C           D1SEL     IFEQ '0'
     C           D1SEL     OREQ '1'
     C  N99                MOVEL@MS,03    D1MSG     P
     C  N99                SETON                     424344
     C  N99                SETON                     99
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
JW1   * SET 830(*IN61) 850(*IN62) FLAG
 |   C                     MOVE *OFF      *IN61
 |   C                     MOVE *OFF      *IN62
 |   C           D1DKBN    IFEQ '830'
 |   C                     MOVE *ON       *IN61
 |   C                     ENDIF
 |   C           D1DKBN    IFEQ '850'
 |   C                     MOVE *ON       *IN62
JW1  C                     ENDIF
      * NEXT-CONTROL
     C           XCHK10    TAG
     C           *IN99     IFEQ *ON
     C                     MOVEL'PNL10'   W@NEXT
     C                     ELSE
     C                     MOVEL'SET20'   W@NEXT
     C                     ENDIF
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      * SET INITIAL VALUE OF SCREEN2
      *-------------------------------------------------------------------------
     C           #SET20    BEGSR
      *
     C                     SETOF                     515253
     C                     SETOF                     99
      *
     C                     MOVEL'0111'    D2SHPT
     C                     MOVELD1NONY    D2SHPF
     C                     MOVEL*BLANK    D2NAM1
     C                     MOVEL*BLANK    D2NAM2
     C                     MOVEL*BLANK    D2SELP
     C                     MOVEL*BLANK    D2DOCK
     C                     MOVEL*BLANK    D2SLF1
     C                     MOVEL*BLANK    D2ALF2
     C                     MOVEL*BLANK    D2STCP
     C                     MOVEL*BLANK    D2STPH
     C                     MOVEL*BLANK    D2SFCP
JW1  C*                    MOVEL*BLANK    D2SFPH
     C                     MOVEL*BLANK    D2FRF1
     C                     MOVEL*BLANK    D2FRF2
     C                     MOVEL*BLANK    D2FRF3
     C                     MOVEL*BLANK    D2FRF4
     C                     MOVEL*BLANK    D2MSG
      * SET UPD TITLE
     C                     MOVELD1SEL     W@SEL1
     C                     MOVEL'-'       W@HF
     C                     SELEC
     C           D1SEL     WHEQ '0'
     C                     MOVEL@SL,01    W@SEL2
     C           D1SEL     WHEQ '1'
     C                     MOVEL@SL,02    W@SEL2
     C           D1SEL     WHEQ '2'
     C                     MOVEL@SL,03    W@SEL2
     C                     ENDSL
     C                     MOVELW@SEL     D2SEL
      * IF UPD=CHANGE/DELETE
     C           D1SEL     IFEQ '0'
     C           D1SEL     OREQ '1'
     C                     MOVELE5SHPT    D2SHPT
     C                     MOVELE5SHPF    D2SHPF
     C                     MOVELE5SELP    D2SELP
     C                     MOVELE5DOCK    D2DOCK
     C                     MOVELE5ALF1    D2SLF1
     C                     MOVELE5ALF2    D2ALF2
     C                     MOVELE5STCP    D2STCP
     C                     MOVELE5STPH    D2STPH
     C                     MOVELE5SFCP    D2SFCP
JW1  C*                    MOVELE5SFPH    D2SFPH
     C                     MOVELE5FRF1    D2FRF1
     C                     MOVELE5FRF2    D2FRF2
     C                     MOVELE5FRF3    D2FRF3
     C                     MOVELE5FRF4    D2FRF4
JW1   * GET NAME1
     C                     MOVE *BLANK    D2NAM1
     C           D2SHPT    IFNE *BLANK
     C                     MOVELD2SHPT    NUM4
     C           NUM4      CHAINFGBPL01              99
     C           *IN99     IFEQ *OFF
     C                     MOVELB2SMEI    D2NAM1
     C                     ENDIF
     C                     ENDIF
JW1   * GET NAME2
     C                     MOVE *BLANK    D2NAM2
     C           D2SHPF    IFNE *BLANK
     C                     MOVELD2SHPF    NUM4
     C           NUM4      CHAINFGBPL01              99
     C           *IN99     IFEQ *OFF
     C                     MOVELB2SMEI    D2NAM2
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
      *
      * NEXT-CONTROL
     C                     MOVEL'PNL20'   W@NEXT
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *  SCREEN2 PROCESS
      *-------------------------------------------------------------------------
     C           #PNL20    BEGSR
      *
     C                     EXFMTDSP02
      *
     C                     SETOF                     515253
     C                     SETOF                     99
     C                     MOVEL*BLANK    D2MSG            * ERR MSG
      *
      * NEXT-CONTROL
     C                     MOVEL'CHK20'   W@NEXT
      * IF F3
     C           *INKC     IFEQ *ON
     C           *INKL     OREQ *ON
     C                     MOVEL'PNL10'   W@NEXT
     C                     ENDIF
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *  CHECK FILEDS OF SCREEN2
      *-------------------------------------------------------------------------
     C           #CHK20    BEGSR
      * IF RECEIVE ----------------
      *    CHECK SHIP TO
JW1  C           *IN61     IFEQ *ON
     C           D2SHPT    IFEQ *BLANK
     C  N99                MOVEL@MS,09    D2MSG     P
     C  N99                SETON                     51  99
     C                     GOTO SKIP2
     C                     ELSE
     C                     MOVELD2SHPT    NUM4    40
     C           NUM4      CHAINFGBPL01              95
     C           *IN95     IFEQ *ON
     C  N99                MOVEL@MS,11    D2MSG     P
     C  N99                SETON                     51
     C  N99                SETON                     99
     C                     GOTO SKIP2
     C                     ENDIF
     C                     ENDIF
JW1  C                     ENDIF
JW1  C                     MOVELB2SMEI    D2NAM1
      *    CHECK SHIP FROM
JW1  C           *IN61     IFEQ *ON
     C           D2SHPF    IFEQ *BLANK
     C  N99                MOVEL@MS,10    D2MSG     P
     C  N99                SETON                     52  99
     C                     GOTO SKIP2
     C                     ELSE
     C                     MOVELD2SHPF    NUM4
     C           NUM4      CHAINFGBPL01              95
     C           *IN95     IFEQ *ON
     C  N99                MOVEL@MS,12    D2MSG     P
     C  N99                SETON                     52
     C  N99                SETON                     99
     C                     GOTO SKIP2
     C                     ENDIF
     C                     ENDIF
JW1  C                     ENDIF
JW1  C                     MOVELB2SMEI    D2NAM2
      * CHECK SHIP TO & FROM
     C           D2SHPT    IFNE *BLANK
     C           D2SHPF    ANDNE*BLANK
     C           D2SHPT    IFEQ D2SHPF
     C  N99                MOVEL@MS,14    D2MSG     P
     C  N99                SETON                     5152
     C  N99                SETON                     99
     C                     GOTO SKIP2
     C                     ENDIF
     C                     ENDIF
      *
      *    CHECK SELLING PARTY
     C           D2SELP    IFNE *BLANK
     C                     MOVELD2SELP    NUM4
     C           NUM4      CHAINFGBPL01              95
     C           *IN95     IFEQ *ON
     C  N99                MOVEL@MS,13    D2MSG     P
     C  N99                SETON                     53
     C  N99                SETON                     99
     C                     GOTO SKIP2
     C                     ENDIF
     C                     ENDIF
      * NEXT-CONTROL
     C           SKIP2     TAG
     C                     MOVEL'PNL20'   W@NEXT
      * IF F5
     C           *IN05     IFEQ '1'
     C           *IN99     ANDEQ'0'
     C                     MOVEL'DBOUT'   W@NEXT
     C                     ENDIF
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *  UPDATE RECORD
      *-------------------------------------------------------------------------
     C           #DBOUT    BEGSR
      *
     C                     TIME           S@TIME
      *
     C                     MOVELD1NONY    K@NONY
     C                     MOVELD1SNRV    K@SNRV
     C                     MOVELD1DKBN    K@DKBN
     C           K@EDI     CHAINEDIPP50              80
      *
      * DELETE
     C           D1SEL     IFEQ '0'
     C           *IN80     IFEQ '0'
     C                     EXSR #DEL10
     C                     ENDIF
     C                     ELSE
      * ADD / CHANGE
     C           *IN80     IFEQ '0'
      * ADD(UPDAT)
     C           D1SEL     IFEQ '2'
     C                     EXSR #WRT11
     C                     ENDIF
      * CHANGE
     C           D1SEL     IFEQ '1'
     C                     EXSR #UPD10
     C                     ENDIF
     C                     ELSE
      * ADD(WRITE)
     C                     EXSR #WRT10
     C                     ENDIF
     C                     ENDIF
      *
      * NEXT-CONTROL
     C                     MOVEL'SET10'   W@NEXT
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      * WRITE RECORD
      *-------------------------------------------------------------------------
     C           #WRT10    BEGSR
      *
     C                     CLEAREDIPP501
      *
     C                     Z-ADDS@YYMD    E5KOHZ
     C                     Z-ADDS@HMS     E5KOTM
     C                     MOVELS@PGID    E5KOPG
     C                     MOVELS@USID    E5KOME
     C                     MOVELD1NONY    E5NONY
     C                     MOVELD1SNRV    E5SNRV
     C                     MOVELD1DKBN    E5DKBN
     C                     MOVELD2SHPT    E5SHPT
     C                     MOVELD2SHPF    E5SHPF
     C                     MOVELD2SELP    E5SELP
     C                     MOVELD2DOCK    E5DOCK
     C                     MOVELD2SLF1    E5ALF1
     C                     MOVELD2ALF2    E5ALF2
     C                     MOVELD2STCP    E5STCP
     C                     MOVELD2STPH    E5STPH
     C                     MOVELD2SFCP    E5SFCP
JW1  C*                    MOVELD2SFPH    E5SFPH
     C                     MOVELD2FRF1    E5FRF1
     C                     MOVELD2FRF2    E5FRF2
     C                     MOVELD2FRF3    E5FRF3
      *
     C                     WRITEEDIPP501
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *  WRITE(UPDATE) RECORD
      *-------------------------------------------------------------------------
     C           #WRT11    BEGSR
      *
     C                     MOVEL*BLANK    E5SKJY
     C                     Z-ADD*ZERO     E5SKHZ
     C                     Z-ADDS@YYMD    E5KOHZ
     C                     Z-ADDS@HMS     E5KOTM
     C                     MOVELS@PGID    E5KOPG
     C                     MOVELS@USID    E5KOME
     C                     MOVELD2SHPT    E5SHPT
     C                     MOVELD2SHPF    E5SHPF
     C                     MOVELD2SELP    E5SELP
     C                     MOVELD2DOCK    E5DOCK
     C                     MOVELD2SLF1    E5ALF1
     C                     MOVELD2ALF2    E5ALF2
     C                     MOVELD2STCP    E5STCP
     C                     MOVELD2STPH    E5STPH
     C                     MOVELD2SFCP    E5SFCP
JW1  C*                    MOVELD2SFPH    E5SFPH
     C                     MOVELD2FRF1    E5FRF1
     C                     MOVELD2FRF2    E5FRF2
     C                     MOVELD2FRF3    E5FRF3
     C                     MOVELD2FRF4    E5FRF4
      *
     C                     UPDATEDIPP501
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      * UPDATE RECORD
      *-------------------------------------------------------------------------
     C           #UPD10    BEGSR
      *
     C                     MOVEL*BLANK    E5SKJY
     C                     Z-ADD*ZERO     E5SKHZ
     C                     Z-ADDS@YYMD    E5KOHZ
     C                     Z-ADDS@HMS     E5KOTM
     C                     MOVELS@PGID    E5KOPG
     C                     MOVELS@USID    E5KOME
     C                     MOVELD2SHPT    E5SHPT
     C                     MOVELD2SHPF    E5SHPF
     C                     MOVELD2SELP    E5SELP
     C                     MOVELD2DOCK    E5DOCK
     C                     MOVELD2SLF1    E5ALF1
     C                     MOVELD2ALF2    E5ALF2
     C                     MOVELD2STCP    E5STCP
     C                     MOVELD2STPH    E5STPH
     C                     MOVELD2SFCP    E5SFCP
JW1  C*                    MOVELD2SFPH    E5SFPH
     C                     MOVELD2FRF1    E5FRF1
     C                     MOVELD2FRF2    E5FRF2
     C                     MOVELD2FRF3    E5FRF3
     C                     MOVELD2FRF4    E5FRF4
      *
     C                     UPDATEDIPP501
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      * DELETE(UPDATE) RECORD
      *-------------------------------------------------------------------------
     C           #DEL10    BEGSR
      *
     C                     MOVEL'D'       E5SKJY           * DELETE CODE D
     C                     Z-ADDS@YYMD    E5SKHZ           * DELETE DATE
     C                     Z-ADDS@YYMD    E5KOHZ           * UPDATE DATE
     C                     Z-ADDS@HMS     E5KOTM           * UPDATE TIME
     C                     MOVELS@PGID    E5KOPG           * UPDATE PROGRAM
     C                     MOVELS@USID    E5KOME           * UPDATE PERSON
      *
     C                     UPDATEDIPP501
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *  INITIAL PROCESS
      *-------------------------------------------------------------------------
     C           #INIT     BEGSR
      *
     C           K@EDI     KLIST
     C                     KFLD           K@NONY  4
     C                     KFLD           K@SNRV  1
     C                     KFLD           K@DKBN  3
      * NEXT-CONTROL
     C                     MOVEL'SET10'   W@NEXT  5
      *
     C                     ENDSR
      *----------------------------------------------------------------
**  @SL  ( SELECT )
DELETE
CHANGE
ADD
**  @MS  ( ERR MSG )
ER01 SELECT 0, 1 OR 2!
ER02 ENTER KEYS!
ER03 NOT EXSIST IN B2B PARAMETER MASTER(EDIPP50)!
ER04 KEYS ALREADY DELETED!
ER05 KEYS EXIST IN B2B PARAMETER MASTER(EDIPP50)!
ER06 R/S SHOULD BE R OR S!
ER07
ER08 DETAIL CODE IS NOT IN M/F(FGBPL01)!
ER09 ENTER SHIP TO!
ER10 ENTER SHIP FROM!
ER11 SHIP TO IS NOT IN M/F(FGBPL01)!
ER12 SHIP FROM IS NOT IN M/F(FGBPL01)!
ER13 SELLING PARTY IS NOT IN M/F(FGBPL01)!
ER14 SHIP_TO AND SHIP_FROM SHOULD NOT BE SAME!
ER15
ER16
ER17
