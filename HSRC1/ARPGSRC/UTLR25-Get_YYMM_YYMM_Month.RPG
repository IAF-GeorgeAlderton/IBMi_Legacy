     H            Y.
     F** UTLR25 ********************************************
     F*  PROGRAM: *DATE* TARGET = YYMM + MONTHS            *
     F*  WRITTEN: JW (SRA)                                 *
     F*           08/10/2018                               *
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR25'
     F*                    PARM           $DT6    6
     F*                    PARM           $SIGN   1
     F*                    PARM           $MON    2
     F*                    PARM           $TGT6   6
     F*                    PARM           $RTN    1
     F*   IN  $DT6  :  6A DATE (YYYYMM)
     F*       $SIGN :  1A + OR -
     F*       $MON  :  2A MONTH
     F*   OUT $TGT6 :  6A TARGET YYYYMM
     F*       $RTN  :  1A RETURN FLAG (BLANK=OK, *=ERROR)
     F******************************************************
     I            DS
     I                                        1   60@YYMM
     I                                        1   40@YY
     I                                        5   60@MM
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
      *
     C                     EXSR #INIT
      * DAY=0
     C           $MON      IFEQ '00'
     C           @MON      OREQ 0
     C                     MOVEL$DT6      $TGT6
     C                     GOTO @END
     C                     ENDIF
      *
     C                     MOVEL$DT6      @YYMM
      *
     C           $SIGN     IFEQ '+'
     C                     EXSR #ADD
     C                     ELSE
     C           $SIGN     IFEQ '-'
     C                     EXSR #SUB
     C                     ELSE
     C                     MOVE '*'       $RTN
     C                     GOTO @END
     C                     ENDIF
     C                     ENDIF
      * SET PARAMETER
     C                     MOVEL@YYMM     $TGT6
      *
     C           @END      TAG
     C                     SETON                     LR
     C                     RETRN
      *=============================================================
      *                    ADD DAYS
      *=============================================================
     C           #ADD      BEGSR
      *
     C                     Z-ADD@MON      IX      20
     C                     DO   IX
     C                     ADD  1         @MM
     C           @MM       IFGT 12
     C                     Z-ADD1         @MM
     C                     ADD  1         @YY
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *=============================================================
      *                    SUBTRACT DAYS
      *=============================================================
     C           #SUB      BEGSR
      *
     C                     Z-ADD@MON      IX
     C                     DO   IX
     C                     SUB  1         @MM
     C           @MM       IFLT 1
     C                     Z-ADD12        @MM
     C                     SUB  1         @YY
     C                     ENDIF
     C                     ENDDO
      *
     C           @YY       IFLT 1
     C                     Z-ADD0         @YY
     C                     Z-ADD0         @MM
     C                     ENDIF
      *
     C                     ENDSR
      *=============================================================
      *                    INITIAL PROCESS
      *=============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $DT6    6
     C                     PARM           $SIGN   1
     C                     PARM           $MON    2
     C                     PARM           $TGT6   6
     C                     PARM           $RTN    1
      *
     C                     MOVEL'000000'  $TGT6
     C                     MOVEL' '       $RTN
     C                     MOVEL$DT6      @DT6    60
     C                     Z-ADD0         @TGT6   60
     C                     MOVEL$MON      @MON    20
      *
     C                     ENDSR
