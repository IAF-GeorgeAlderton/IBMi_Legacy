     H            Y.
     F***CHKR74*****************************************************************
     F*  PROGRAM    : PRINT SUBARU QUICK SHIP EDI ORDER REPORT                 *
     F*             : ADD JOB TO AB#C0A                                        *
     F*  WRITTEN    : 7/24/2019                                                *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#WP452IF  F     256            DISK
     FQPRINT  O   F     132     OF     PRINTER
      **************************************************************************
     IAB#WP452AA  01
     I                                        1   4 ISIRE
     I                                        5   5 ISIRK
     I                                        6   90ITOKU
     I                                       10  130INONY
     I                                       14  14 INKOJ
     I                                       15  18 INUKE
     I                                       19  22 ISBAN
     I                                       23  42 IMHIN
     I                                       23  27 IMHN1
     I                                       28  32 IMHN2
     I                                       33  37 IMHN3
     I                                       38  42 IMHN4
     I                                       43  500INOHZ
     I                                       43  460INOYY
     I                                       47  480INOMM
     I                                       49  500INODD
     I                                       51  60 IODRN
     I                                       61  670ISRYO
     I                                       68  730ISYOS
     I                                       74  770INOTM
     I                                       78  89 ISHIN
     I                                       78  82 ISHN1
     I                                       83  87 ISHN2
     I                                       88  89 ISHN3
     I                                       90  93 ICARD
     I                                       94  97 IALFL
     I                                       98  990INOBN
     I                                      100 1050IUSYS
     I                                      106 121 IINVN
     I                                      122 125 IRESE
     I                                      126 1330IDEHZ
     I                                      126 1290IDEYY
     I                                      130 1310IDEMM
     I                                      132 1330IDEDD
     I                                      134 145 IPGID
     I                                      146 165 IMHIN2
     I                                      256 256 @@H
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ AB#WP452                 98
     C   98                LEAVE
      * SELECT SUBARU
     C           INONY     IFNE 3611
     C                     ITER
     C                     ENDIF
      * SHIP DATE
     C           INOHZ     IFGE TODAY
     C           INOHZ     ANDLE@NEXT
     C                     EXSR #PRINT
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           SEQ#      IFGE 1
     C                     MOVE '*'       $RTN
     C                     ELSE
     C                     MOVE ' '       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      * PRINT HEADER
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD4         LIN#
     C                     ENDIF
      * PRINT DETAIL
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C                     TIME           @SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
      * GET NEST BUSINESS DATE
     C                     MOVELTODAY     $DT8
     C                     MOVEL'+'       $SIGN
     C                     MOVEL'0001'    $DAYS
     C                     MOVE 'Y'       $IAF
     C                     CALL 'UTLR10'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN    1
     C                     MOVEL$TGT8     @NEXT   80
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** SUBARU QUICK SHIP'
     O                                   60 ' EDI ORDER REPORT **'
     O                                   99 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                         PAGE  Z  109
     O                                  106 'P.'
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   11 'CUST'
     O                                   17 'DELV'
     O                                   27 'SHP_DATE'
     O                                   33 'BIN'
     O                                   44 'USER_PART'
     O                                   58 'ORDER#'
     O                                   72 'QTY'
     O                                   90 'RCV_DATE'
     O                                   98 'TIME'
     O        E   04           @HDR
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O                                  120 '--------------------'
     O                                  130 '----------'
     O        E 1              @DTL
     O                         SEQ#  Z +001
     O                         ITOKU   +002
     O                         INONY   +002
     O                         INOHZ   +002 '    /  /  '
     O                         INOBN   +002
     O                         IMHN1   +002
     O                         IMHN2   +001
     O                         IMHN3   +001
     O                         IODRN   +000
     O                         ISRYO 1 +001
     O**                       BAEDIK  +003
     O                         TODAY   +010 '    /  /  '
     O                         NOW     +002 '0 :  :  '
