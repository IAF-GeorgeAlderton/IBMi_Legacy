     O                                      '"'
     O                                      ','
     O                         W@GEKN
     O                                      ','
     O                         A2SSYS
     O                                      ','
     O                         W@DBOX       '   0 . '
     O                                      ','
     O* * *                    P@JOK1
     O* * *                                 ','
     O* * *                    P@JOK2
     O* * *                                 ','
     O* * *                    P@JOK3
     O* * *                                 ','
     O* * *                    P@JOK4
     O* * *                                 ','
