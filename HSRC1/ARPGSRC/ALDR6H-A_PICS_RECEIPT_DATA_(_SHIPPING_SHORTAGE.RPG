     H            Y.
      ** ALDR6H *******************************************************
      * A-PICS RECEIPT DATA ( SHIPPING SHORTAGE DATA )
      *
      *  KIRI                                            2020.06.16
      *****************************************************************
     FALDWP69 IF  E                    DISK
      *
      * .. PART INFORMATION M/F   *.
     FFCEPL01 IF  E           K        DISK
      * .. SHIPMENT M/F
     FGADPL11 IF  E           K        DISK
      *
      * .. SHIPPING SHORTAGE FILE                         *
     FALDPL6A UF  E           K        DISK
      *
      *
     FAU#NP11 UF  F       9            DISK                      A
      * .. A-PICS RECEIPT DATA ACCUMULATION FILE
     FAU#PP11 O   E                    DISK                      A
      *
      *
     FALDPP69 O   E                    DISK
      *===============================================================
      *===============================================================
     IAU#NP11 AA  70
     I                                        1   20AHZMM
     I                                        3   90ARECD
     I****************************
      *プログラム状況データ構造*
     I****************************
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *          *
     I            DS
     I                                        1   80BANOHZ
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
      *
     I            DS
     I                                        1   80CQKOHZ
     I                                        1   40CQKOYY
     I                                        5   60CQKOMM
     I                                        7   80CQKODD
      *
     I            DS
     I                                        1   60CQKOTM
     I                                        1   20CQKOHH
     I                                        3   40CQKOSS
      *
     I            DS
     I                                        1   80CQTHHZ
     I                                        1   40CQTHYY
     I                                        5   60CQTHMM
     I                                        7   80CQTHDD
      *
     I            DS
     I                                        1   60CQTHTM
     I                                        1   20CQTHJI
     I                                        3   40CQTHPN
      *
     I            DS
     I                                        1   80CQURHZ
     I                                        1   40CQURYY
     I                                        5   60CQURMM
     I                                        7   80CQURDD
      *
     I            DS
     I                                        1   60CQURTM
     I                                        1   20CQURJI
     I                                        3   40CQURPN
      ******************
     I            DS
     I                                        1   80A2TRHZ
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
     C*===============================================================
     C           *ENTRY    PLIST
     C                     PARM           P@UBAR250
      *===============================================================
      *  START  PROGRAM
      *===============================================================
     C                     TIME           @TIME
      *-------------------------
     C                     DO   *HIVAL
     C                     READ ALDWP69                  90
     C   90                LEAVE
     C*
     C                     EXSR #ALD
     C*
     C           $APICS    IFNE 0
     C           $HAKO     ANDNE0
     C                     EXSR #AU#
     C                     ENDIF
     C*
     C                     ENDDO
      *-------------------------
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      * .. SHIPPING SHORTAGE FILE                         *
      *===============================================================
     C           #ALD      BEGSR
     C           KEY01     KLIST
     C                     KFLD           P@UBAR
      *
      * .. SHIPPING SHORTAGE FILE                         *
      *
     C           KEY01     SETLLALDPL6A
     C                     Z-ADDBAMINS    $SUU   100
     C                     Z-ADD0         $APICS 100
     C                     Z-ADD0         $HAKO  100
      *-------------------------
     C                     DO   *HIVAL
     C           KEY01     READEALDPL6A                  91
     C   91                LEAVE
     C*
     C           AFSKJC    IFEQ 'D'
     C           AFRDAT    ORNE 0
     C                     ITER
     C                     ENDIF
     C*
     C                     SUB  BASYOS    $SUU
     C*
     C           $SUU      IFGE 0
     C                     Z-ADD99999999  AFRDAT            RCVR DATE
     C                     Z-ADD999999    AFRTIM            RCVR TIME
     C                     MOVELW$PGM     AFPGID            UPDATE PGM
     C                     MOVELW$USER    AFRTMC            INPUT TM
     C                     UPDATALDPP651
     C                     ADD  BASYOS    $APICS
     C                     ADD  1         $HAKO
     C                     ELSE
     C                     WRITEALDPP691
     C                     ENDIF
     C                     ENDDO
      *-------------------------
     C                     ENDSR
      *===============================================================
      * .. A-PICS RECEIPT DATA ACCUMULATION FILE
      *===============================================================
     C           #AU#      BEGSR
     C*
     C                     CLEARAU#PP111
     C                     Z-ADD@SYSHZ    CQKOHZ
     C                     Z-ADD@SYSTM    CQKOTM
     C                     MOVELW$USER    CQKOME
     C                     Z-ADDBATOKU    CQTOKU            CUSTOMER CODE
     C                     MOVELBANKOJ    CQTKOJ            CUSTOMER FACTORY
     C                     MOVELBANUKE    CQTUKE            CUSTOMER RECEIVING
     C                     Z-ADDBANONY    CQNONY            DELIVERY CODE
     C                     MOVELBANKOJ    CQNKOJ            DELIVERY FACTORY
     C                     MOVELBANUKE    CQNUKE            DELIVERY RECEIVING
     C                     MOVELBASHN1    CQSHN1            INTRAL COMPANY PART
     C                     MOVELBASHN2    CQSHN2            INTRAL COMPANY PART
     C                     MOVELBASHN3    CQSHN3            INTRAL COMPANY PART
     C                     MOVELBAMHN1    CQMHN1            USER PART NUMBER
     C                     MOVELBAMHN2    CQMHN2            USER PART NUMBER
     C                     MOVELBAMHN3    CQMHN3            USER PART NUMBER
     C                     MOVELBANOBN    CQKOBI
     C                     MOVELBASBAN    CQSEBN            IDENTIFICATION NUMBE
     C                     MOVELBANOBN    CQKANR           'MANAGEMENT NUMBER
     C                     Z-ADD0         CQTANK           UNIT PRICE
     C                     MOVEL*BLANK    CQTKUB
     C                     MOVEL*BLANK    CQTKTI
     C                     MOVELBAODRN    CQNOCR           DELIVERY NUMBER
     C                     Z-SUB$APICS    CQSRYO            AMOUNT
     C                     MOVEL'C'       CQTANI
     C                     MOVEL'C'       CQNSYK
     C                     Z-ADD@SYSHZ    CQTHHZ
     C                     Z-ADD@SYSTM    CQTHTM
     C                     MOVEL'S'       CQTHAI
     C** KLIST
     C           KEY2      KLIST
     C                     KFLD           BASHN1
     C                     KFLD           BASHN2
     C                     KFLD           BASHN3
      *
     C           KEY2      CHAINFCEPL01              92
     C           *IN92     IFEQ *OFF
     C           A2GSKD    ANDEQ*BLANK
     C                     MOVELA2TEHI    CQTHAI
     C           A2TRHZ    IFGE @SYSHZ
     C                     MOVE A2KTRK    CQSBKJ
     C                     MOVE A2KTRT    CQSBRO
     C                     MOVE A2KTRR    CQSBRT
     C                     MOVE A2KTRD    CQSBDN
     C                     ELSE
     C                     MOVE A2STRK    CQSBKJ
     C                     MOVE A2STRT    CQSBRO
     C                     MOVE A2STRR    CQSBRT
     C                     MOVE A2STRD    CQSBDN
     C                     ENDIF
     C                     ENDIF
     C*
     C           NKEY      KLIST
     C                     KFLD           BATOKU
     C                     KFLD           BANONY
     C                     KFLD           BANKOJ
     C                     KFLD           BANUKE
     C           NKEY      CHAINGADPL111             93
     C           *IN93     IFEQ *OFF
     C           B5SKJY    ANDEQ'D'
     C           B5SKHZ    ANDLE@SYSHZ
     C                     SETON                     93
     C                     ENDIF
     C*
     C           *IN93     IFEQ *ON
     C                     Z-ADD1         CQCIC1
     C                     Z-ADD1         CQCIC2
     C                     Z-ADD1         CQCIC3
     C                     ELSE
     C                     Z-ADDB5HIZK    CQCIC1
     C                     Z-ADDB5KAIS    CQCIC2
     C                     Z-ADDB5NBIN    CQCIC3
     C                     ENDIF
     C                     Z-ADDBANOYY    CQNOYY            MAKER DELIVERY DATE
     C                     Z-ADDBANOMM    CQNOMM
     C                     Z-ADDBANODD    CQNODD
     C                     Z-ADDBANOBN    CQNOBB
     C                     MOVEL*BLANK    CQKJYN           SHIPMENT STANDARD
     C                     MOVEL'K'       CQSKKB
     C                     Z-SUB$HAKO     CQHAKO           NUMBER OF BOXES
     C                     Z-ADDBASYOS    CQSYUY
     C                     MOVEL*BLANK    CQSTAN
     C                     MOVEL*BLANK    CQKIBN
     C                     MOVEL*BLANK    CQHBSB
     C                     MOVEL*BLANK    CQROTN
     C                     Z-ADD0         CQPAGN
     C                     Z-ADD0         CQOCRD
     C                     MOVEL'S'       CQDTSY
     C                     MOVEL'4'       CQDTSO
     C                     MOVEL'15'      CQGYOM
     C                     Z-ADD@SYSHZ    CQURHZ           SALES ADDING UP
     C                     Z-ADD@SYSTM    CQURTM           SALES ADDING UP
      *
     C                     SETOF                     94
     C           1         CHAINAU#NP11              94
     C           *IN94     IFEQ *OFF
     C           AHZMM     IFNE UMONTH
     C                     Z-ADDUMONTH    AHZMM
     C                     Z-ADD7000001   ARECD
     C                     ELSE
     C                     ADD  1         ARECD
     C                     ENDIF
     C                     EXCPT$UP
     C                     ELSE
     C                     Z-ADDUMONTH    AHZMM
     C                     Z-ADD7000001   ARECD
     C                     EXCPT$WT
     C                     ENDIF
     C*
     C                     Z-ADDARECD     CQJTNO
     C                     MOVEL*BLANK    CQBNKA
      *
     C                     WRITEAU#PP111
      *
     C                     ENDSR
      *===============================================================
      *===============================================================
      *                                                                *********
      *===============================================================
     OAU#NP11 E                $UP
     O                         AHZMM      2
     O                         ARECD      9
     O        EADD             $WT
     O                         AHZMM      2
     O                         ARECD      9
