     C                     Z-ADD0         W@GSRY 100
     C                     Z-ADD0         W@USM1  90
     C                     Z-ADD0         W@USM2  90
     C                     Z-ADD0         W@USM3  90
     C           KEYB12    SETLLAB#PL071
     C           KEYB12    READEAB#PL071                 82
     C           *IN82     DOWEQ'0'
     C           B1NOYM    ANDLEW@M1YM
     C           B1SKJY    IFEQ 'D'
     C           B1SKHZ    ANDLE*DATE
     C                     ELSE
