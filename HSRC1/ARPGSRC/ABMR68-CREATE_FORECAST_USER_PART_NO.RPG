     C           W@P1DY    IFNE 0
     C           W@FSM1    DIV  W@P1DY    W1FSD1
     C                     ENDIF
     C           W@P2DY    IFNE 0
     C           W@FSM2    DIV  W@P2DY    W1FSD2
     C                     ENDIF
     C           W@1WDY    IFNE 0
     C           W@USM1    DIV  W@1WDY    W1USD1
     C                     ENDIF
     C           W@M2DY    IFNE 0
     C           W@USM2    DIV  W@M2DY    W1USD2
     C                     ENDIF
     C           W@M3DY    IFNE 0
     C           W@USM3    DIV  W@M3DY    W1USD3
     C                     ENDIF
      *
     C           W@NKBN    IFEQ 'N'
     C           W@NWDY    IFNE 0
     C           W@FSRY    DIV  W@NWDY    W1NSRD
     C                     ENDIF
     C                     ELSE
     C           W@NSRY    DIV  20        W1NSRD
     C                     ENDIF
      * PASS THROUGH
     C                     CALL 'ABMR1A'
     C                     PARM           W1SHN1
     C                     PARM           W1SHN2
     C                     PARM           W1SHN3
     C                     PARM           P@PAS   1
     C                     MOVELP@PAS     W1PAS
     C                     Z-ADDA2GEKN    W1GEKN
     C           W1OMIT    IFEQ '0'
     C           W@GEKN    IFEQ 20
     C                     MOVEL'4'       W1OMIT
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADDW@SSYS    W1SSYS
     C                     Z-ADDW@HIKN    W1HIKN
     C                     Z-ADDW@STDY    W1STDY
      *
     C                     WRITEABMWP111
      *
     CSR         ESB500    ENDSR
