      *
     C           KEY81     KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
      *
     C                     CLEARABMWP111
     C                     Z-ADD*DATE     W1CRDT
     C                     Z-ADDQ6TOKU    W1TOKU
     C                     Z-ADDQ6NONY    W1NONY
     C                     MOVELQ6NKOJ    W1NKOJ
     C                     MOVELQ6NUKE    W1NUKE
     C                     MOVELQ6MHN1    W1MHN1
     C                     MOVELQ6MHN2    W1MHN2
     C                     MOVELQ6MHN3    W1MHN3
     C                     MOVELQ6MHN4    W1MHN4
     C                     MOVELMCKHN1    W1SHN1
     C                     MOVELMCKHN2    W1SHN2
     C                     MOVELMCKHN3    W1SHN3
     C                     MOVELA2BHB1    W1OHN1
     C                     MOVELA2BHB2    W1OHN2
     C                     MOVELA2BHB3    W1OHN3
     C                     Z-ADD1         A       30
     C                     Z-ADD0         W@KOSU  10
     C           MCKHN     LOKUPKSH,A                    29
     C           *IN29     IFEQ '1'
     C                     Z-ADDKOS,A     W@KOSU
     C                     ELSE
     C                     Z-ADD1         W@KOSU
     C                     ENDIF
     C           W@NSRY    MULT W@KOSU    W1NSRY
     C                     Z-ADDW@NTYM    W1NTYM
     C                     Z-ADDW@M1YM    W1URY1
     C                     Z-ADDW@M2YM    W1URY2
     C                     Z-ADDW@M3YM    W1URY3
     C                     MOVELW@NKBN    W1NKBN
     C                     MOVEL'0'       W1OMIT
     C           KEY81     CHAINABMPP811             41
     C           *IN41     IFEQ '0'
     C           CNSKJY    ANDEQ'D'
     C           CNSKHZ    ANDLE*DATE
     C                     SETON                     41
     C                     ENDIF
     C           *IN41     IFEQ '0'
     C                     MOVEL'1'       W1OMIT
     C                     ENDIF
      *立上６ヶ月は自動処理しない
     C           W1OMIT    IFEQ '0'
     C           A2TAHZ    IFGT W6DATE
     C                     MOVEL'2'       W1OMIT
     C                     ENDIF
     C                     ENDIF
      *３ヶ月以内の手動更新ありは自動処理しない
     C           W1OMIT    IFEQ '0'
     C           W@KOS3    IFEQ '1'
