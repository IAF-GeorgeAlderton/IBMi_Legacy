      *
     C                     Z-ADD*DATE     W@DATE
     C                     Z-ADDW@DTYM    W@NTYM  60
      * N+1
     C                     Z-ADDW@DTYM    W@P1YM
     C           W@DTMM    IFEQ 12
     C                     ADD  1         W@P1YY
     C                     Z-ADD1         W@P1MM
     C                     ELSE
     C                     ADD  1         W@P1MM
     C                     ENDIF
      * N+2
     C                     Z-ADDW@P1YM    W@P2YM
     C           W@P2MM    IFEQ 12
     C                     ADD  1         W@P2YY
     C                     Z-ADD1         W@P2MM
     C                     ELSE
     C                     ADD  1         W@P2MM
     C                     ENDIF
      * N-1
     C           W@DTMM    IFEQ 1
     C                     SUB  1         W@DTYY
     C                     Z-ADD12        W@DTMM
     C                     ELSE
     C                     SUB  1         W@DTMM
     C                     ENDIF
     C                     Z-ADDW@DTYM    W@M1YM
      * N-2
     C                     Z-ADDW@M1YM    W@M2YM
     C           W@M1MM    IFEQ 1
     C                     SUB  1         W@M2YY
     C                     Z-ADD12        W@M2MM
     C                     ELSE
     C                     SUB  1         W@M2MM
     C                     ENDIF
      * N-3
     C                     Z-ADDW@M2YM    W@M3YM
     C           W@M2MM    IFEQ 1
     C                     SUB  1         W@M3YY
     C                     Z-ADD12        W@M3MM
     C                     ELSE
     C                     SUB  1         W@M3MM
     C                     ENDIF
      * N WORK DAY
     C                     MOVELP@DTYM    K#DTYY
     C                     MOVE P@DTYM    K#DTMM
     C                     Z-ADD0         W@NWDY  31
     C                     EXSR #SB010
     C                     Z-ADDW@KAD     W@NWDY  31
      * N+1 WORK DAY
     C                     Z-ADDW@P1YY    K#DTYY
     C                     Z-ADDW@P1MM    K#DTMM
     C                     Z-ADD0         W@P1DY  31
     C                     EXSR #SB010
     C                     Z-ADDW@KAD     W@P1DY  31
      * N+2 WORK DAY
     C                     Z-ADDW@P2YY    K#DTYY
     C                     Z-ADDW@P2MM    K#DTMM
     C                     Z-ADD0         W@P2DY  31
     C                     EXSR #SB010
     C                     Z-ADDW@KAD     W@P2DY  31
      * N-1 WORK DAY
     C                     Z-ADDW@DTYY    K#DTYY
     C                     Z-ADDW@DTMM    K#DTMM
     C                     Z-ADD0         W@1WDY  31
     C                     EXSR #SB010
     C                     Z-ADDW@KAD     W@1WDY  31
      * N-2 WORK DAY
     C                     Z-ADDW@M2YY    K#DTYY
     C                     Z-ADDW@M2MM    K#DTMM
     C                     Z-ADD0         W@M2DY  31
     C                     EXSR #SB010
     C                     Z-ADDW@KAD     W@M2DY  31
      * N-3 WORK DAY
     C                     Z-ADDW@M3YY    K#DTYY
     C                     Z-ADDW@M3MM    K#DTMM
     C                     Z-ADD0         W@M3DY  31
     C                     EXSR #SB010
     C                     Z-ADDW@KAD     W@M3DY  31
      *６ヶ月前
     C                     Z-ADD*DATE     W6DATE
     C           W6DTMM    IFGE 7
     C                     SUB  6         W6DTMM
     C                     ELSE
     C                     SUB  1         W6DTYY
     C                     ADD  6         W6DTMM
     C                     ENDIF
