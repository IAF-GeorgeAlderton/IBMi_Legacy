     C                     Z-ADD0         W@FSM2  90
     C                     Z-ADD0         W@FSRY  90
     C                     Z-ADD0         W@NSRY  90
     C                     Z-ADD0         W@USM1  90
     C                     Z-ADD0         W@USM2  90
     C                     Z-ADD0         W@USM3  90
     C           KEYQ6     SETLLABMWP601
     C           KEYQ6     READEABMWP601                 81
     C           *IN81     DOWEQ'0'
     C                     MOVEL'1'       W@ABB   1
     C                     Z-ADDQ6NNNM    W@FSMN  90
     C                     Z-ADDQ61NNM    W@FSM1  90
     C                     Z-ADDQ62NNM    W@FSM2  90
     C                     Z-ADDQ6NNNM    W@FSRY  90
     C***        Q6NNNM    IFGE Q61NNM
