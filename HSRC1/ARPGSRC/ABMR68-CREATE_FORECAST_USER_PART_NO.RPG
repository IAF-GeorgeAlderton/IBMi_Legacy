     C***                  ELSE
     C***                  Z-ADDQ61NNM    W@NSRY  90
     C***                  ENDIF
     C                     ENDIF
     C                     EXSR #SB500
     C           KEYQ6     READEABMWP601                 81
     C                     ENDDO
