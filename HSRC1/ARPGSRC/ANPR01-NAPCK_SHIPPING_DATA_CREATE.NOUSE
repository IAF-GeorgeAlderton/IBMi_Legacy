     H            Y.
     F** ANPR01 *******************************************************
     F*  NAPCK SHIPPING DATA CREATE
     F*
     F* KIRI  15.07.01
     F*****************************************************************
     FANPPW01 CF  E                    WORKSTN
     F                                              KINFDS INFDS
      *  ..EDI FIXED ORDER DATA..  *
     FAB#PL1C IF  E           K        DISK
      * SERIAL NUMBER FILE FOR PICK UP LIST           *
     FAB#PL75 IF  E           K        DISK
      * EKANBAN SERIAL NUMBER FILE                    *
     FAB#PL70 UF  E           K        DISK
      * TMS MASTSER LABEL                           *
     FAB#PL66 UF  E           K        DISK
      *================================================================
     E                    ER      1  10 60               d[ｰxｮﾈｰﾆﾞ
      *================================================================
      *================================================================
     IINFDS       DS
     I                                    B 378 3790$$RRN
     I****************************
     I*プログラム状況データ構造*
     I****************************
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W$JBNO
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
     I                                        1   20@SYSHH
     I                                        3   40@SYSMN
     I                                        7  100@SYSYY
     I                                       11  120@SYSMM
     I                                       13  140@SYSDD
      *---------------------------------------------
     I            DS
     I                                        1   80BASKHZ
     I                                        1   40BASKYY
     I                                        5   60BASKMM
     I                                        7   80BASKDD
     I            DS
     I                                        1   80BANOHZ
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I            DS
     I                                        1   80EKSKHZ
     I                                        1   40EKSKYY
     I                                        5   60EKSKMM
     I                                        7   80EKSKDD
      *---------------------------------------------
     I              'VOLKSWAGEN          'C         $$VW
      *================================================================
     C*
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#CHK1 F5'#CHK1
     C           @STEP     CASEQ'#UPDT   '#UPDT
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      * 初期ﾈｮmb
      *===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
      *
     C                     CLEARDSP01
     C                     TIME           @TIME
     C                     MOVEL*BLANK    D1ODRN           ORDER NO
     C                     MOVEL*BLANK    D1SERL           SERIAL#
     C                     MOVEL*BLANK    D$ODRN           ORDER NO
     C                     MOVEL*BLANK    D$SERL           SERIAL#
     C                     MOVEL*BLANK    D1ERR
     C*
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
     C*===============================================================
      *画面１*
     C*===============================================================
     C           #DSP1     BEGSR
     C                     EXFMTDSP01
     C                     MOVEA'000'     *IN,31
     C                     MOVEA'0'       *IN,99
      *----*
     C                     SELEC
     C* F1 *
     C           *INKA     WHEQ *ON
     C                     MOVE '#END    '@STEP
     C* F5 *
     C           *INKE     WHEQ *ON
     C                     MOVE '#CHK1 F5'@STEP
     C******
     C                     OTHER
     C                     MOVE '#CHK1   '@STEP
     C                     ENDSL
      *----*
     C                     ENDSR
     C*===============================================================
      *画面１チェック
     C*===============================================================
     C           #CHK1     BEGSR
     C                     MOVEL*BLANK    D1SERL           SERIAL#
      **
      ** ORDER NO (31)
      **
     C           D1ODRN    IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVELER,1      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
     C*
     C                     MOVELD1ODRN    D1OD2   2
     C           D1OD2     IFNE 'TC'
     C                     SETON                     3199
     C                     MOVELER,2      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
      *
      *  ..EDI FIXED ORDER DATA..  *
     C           KEY01     KLIST
     C                     KFLD           D1ODRN           ORDER NO
     C                     KFLD           K$NONY  40       DELIVERY CODE
     C                     KFLD           K$NUKE  4        DELIVERY RECEIVING
     C                     KFLD           K$NKOJ  1        DELIVERY FACTORY
     C*
     C                     Z-ADD3411      K$CUST  40       CUSTOMER
     C                     Z-ADD0323      K$NONY           DELIVERY CODE
     C                     MOVEL'C'       K$NKOJ           DELIVERY FACTORY
     C                     MOVEL'00  '    K$NUKE           DELIVERY RECEIVING
     C                     Z-ADD0         K$NOYY  40       INVOICE YY
     C                     Z-ADD0         K$NOMM  20       INVOICE MM
     C                     Z-ADD0         K$NODD  20       INVOICE DD
     C                     Z-ADD0         K$NOBN  20       INVOICE BIN
     C                     MOVE ' '       @@UMU1  1        有無
     C                     MOVE ' '       @@UMU7  1        有無
     C                     MOVE ' '       @@SUMI  1        処理済
     C           KEY01     SETLLAB#PL1C
     C*-------------------------
     C                     DO   *HIVAL
     C           KEY01     READEAB#PL1C                  91
     C   91                LEAVE
     C           BASKJY    IFEQ 'D'                        DELETE CODE
     C**JW       BASKHZ    ANDLE@SYSHZ
     C                     ITER
     C                     ENDIF
     C*
     C* EKANBAN SERIAL NUMBER FILE
     C*
     C                     MOVE '*'       @@UMU1  1        有無
     C                     EXSR #AB70A
     C           @@UMU7    IFEQ '*'                        有無
     C                     Z-ADDBANOYY    K$NOYY           INVOICE YY
     C                     Z-ADDBANOMM    K$NOMM           INVOICE MM
     C                     Z-ADDBANODD    K$NODD           INVOICE DD
     C                     Z-ADDBANOBN    K$NOBN           INVOICE BIN
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C*-------------------------
     C           @@UMU1    IFEQ ' '                        有無
     C                     SETON                     3199
     C                     MOVELER,3      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
     C*
     C           @@UMU7    IFEQ ' '                        有無
     C                     SETON                     3199
     C           @@SUMI    IFEQ '*'                        処理済
     C                     MOVELER,5      D1ERR
     C                     ELSE
     C                     MOVELER,6      D1ERR
     C                     ENDIF
     C                     GOTO @CHK1
     C                     ENDIF
      *
      * SERIAL NUMBER FILE FOR PICK UP LIST           *
      *
     C           KEY02     KLIST
     C                     KFLD           K$NOYY           DELIVERY YY
     C                     KFLD           K$NOMM           MM
     C                     KFLD           K$NODD           DD
     C                     KFLD           K$CUST           CUSTOMER
     C                     KFLD           K$NONY           DELIVERY CODE
     C                     KFLD           K$NKOJ           DELIVERY FACTORY
     C                     KFLD           K$NUKE           DELIVERY RECEIVING
     C           KEY02     SETLLAB#PL75
     C*-------------------------
     C                     DO   *HIVAL
     C           KEY02     READEAB#PL75                  92
     C   92                LEAVE
     C           PUSKJY    IFEQ 'D'                        DELETE FLAG
     C           PUSKDT    ANDLE@SYSHZ                     DELETE DATE
     C                     ITER
     C                     ENDIF
     C           PUODRN    IFEQ D1ODRN                     ORDER#
     C                     MOVELPUSERL    D1SERL           SERIAL#
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C*-------------------------
     C           *IN92     IFEQ *ON
     C                     SETON                     3199
     C                     MOVELER,4      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
     C*-------------------------
      *-------------------------
     C           @CHK1     TAG
      *-------------------------
     C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK1 F5'
     C                     MOVE '#UPDT   '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      * EKANBAN SERIAL NUMBER FILE CHECK
      *===============================================================
     C           #AB70A    BEGSR
      *
     C           KEY03     KLIST
     C                     KFLD           K$CUST           CUSTOMER
     C                     KFLD           K@NONY           DELIVERY CODE
     C                     KFLD           K$NKOJ           DELIVERY FACTORY
     C                     KFLD           K$NUKE           DELIVERY RECEIVING
     C                     KFLD           BAMHN1           CUST PART#1
     C                     KFLD           BAMHN2           CUST PART#2
     C                     KFLD           BAMHN3           CUST PART#3
     C                     KFLD           BAMHN4           CUST PART#4
     C                     KFLD           D1ODRN           ORDER NO
      *
     C                     MOVEL'0323'    K@NONY  4        DELIVERY CODE
     C           KEY03     SETLLAB#PL70
     C*--------------------
     C                     DO   *HIVAL
     C           KEY03     READEAB#PL70                  93
     C   93                LEAVE
     C           EKSKJY    IFEQ 'D'                        DELETE FLAG
     C           EKSKHZ    ANDLE@SYSHZ
     C                     ITER
     C                     ENDIF
     C           EKLTNO    IFEQ *BLANK                     LOT#
     C                     MOVE '*'       @@UMU7           有無
     C                     LEAVE
     C                     ENDIF
     C                     MOVE '*'       @@SUMI           処理済
     C                     ENDDO
     C*--------------------
     C                     ENDSR
      *===============================================================
      * EKANBAN SERIAL NUMBER FILE(AB#PP70) UPDAT
      *===============================================================
     C           #UPDT     BEGSR
      *
     C           KEY01     SETLLAB#PL1C
     C*-------------------------
S1   C                     DO   *HIVAL
     C           KEY01     READEAB#PL1C                  91
     C   91                LEAVE
     C           BASKJY    IFEQ 'D'                        DELETE CODE
     C**JW       BASKHZ    ANDLE@SYSHZ
     C                     ITER
     C                     ENDIF
     C*
     C           BANOYY    IFEQ K$NOYY                     INVOICE YY
     C           BANOMM    ANDEQK$NOMM                     INVOICE MM
     C           BANODD    ANDEQK$NODD                     INVOICE DD
     C           BANOBN    ANDEQK$NOBN                     INVOICE BIN
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C*
     C                     MOVEL'00'      WKNOBN  2        INVOICE BIN
     C                     MOVE K$NOBN    WKNOBN           INVOICE BIN
     C*
     C* EKANBAN SERIAL NUMBER FILE(AB#PP70) UPDAT
     C           KEY03     SETLLAB#PL70
     C*--------------------
 S2  C                     DO   *HIVAL
     C           KEY03     READEAB#PL70                  93
     C   93                LEAVE
     C           EKSKJY    IFEQ 'D'                        DELETE FLAG
     C           EKSKHZ    ANDLE@SYSHZ
     C                     ITER
     C                     ENDIF
     C           EKLTNO    IFNE *BLANK                     LOT#
     C                     ITER
     C                     ENDIF
     C           EKNOBN    IFNE WKNOBN                     BIN
     C                     ITER
     C                     ENDIF
     C                     Z-ADD@SYSYY    EKKOYY           UPDATE YEAR
     C                     Z-ADD@SYSMM    EKKOMM           UPDATE MONTH
     C                     Z-ADD@SYSDD    EKKODD           UPDATE DATE
     C                     Z-ADD@SYSHH    EKKOHH           UPDATE HOUR
     C                     Z-ADD@SYSMN    EKKOMN           UPDATE MINUTE
     C                     Z-ADD@SYSYY    EKDEYY           SHIP YY
     C                     Z-ADD@SYSMM    EKDEMM           MM
     C                     Z-ADD@SYSDD    EKDEDD           DD
     C                     Z-ADD@SYSTM    EKDETM           DELIVERY TIME
     C                     MOVELEKSYOS    $$SRYO  50       QTY/BOX
     C                     Z-ADD$$SRYO    EKSRYO           DELIVERY QUANTITY
     C                     MOVE '999'     EKLTNO           LOT#
     C                     MOVEL'99 '     EKISNO           ISSUE#
     C                     UPDATAB#PP701
 E2  C                     ENDDO
     C*--------------------
E1   C                     ENDDO
     C*-------------------------
     C*-------------------------
      ** AB#PL66
      *  TMS MASTSER LABEL                           *
      *
     C           KEY04     KLIST
     C                     KFLD           K$CUST           CUSTOMER
     C                     KFLD           K$NONY           DELIVERY CODE
     C                     KFLD           K$NKOJ           DELIVERY FACTORY
     C                     KFLD           K$NUKE           DELIVERY RECEIVING
     C                     KFLD           BANOHZ           DELIVERY DATE
     C           KEY04     SETLLAB#PL66
     C*-------------------------
     C                     DO   *HIVAL
     C           KEY04     READEAB#PL66                  95
     C   95                LEAVE
     C           A6ORDN    IFNE D1ODRN                     ORDER#
     C                     ITER
     C                     ENDIF
     C           A6NBIN    IFNE K$NOBN                     BIN
     C                     ITER
     C                     ENDIF
     C           A6SHN1    IFEQ *BLANK                     IAF PART#1
     C           A6SHN2    ANDEQ*BLANK                     IAF PART#2
     C           A6SHN3    ANDEQ*BLANK                     IAF PART#3
     C           A6MHN1    ANDEQ*BLANK                     CUST PART#1
     C           A6MHN2    ANDEQ*BLANK                     CUST PART#2
     C           A6MHN3    ANDEQ*BLANK                     CUST PART#3
     C           A6MHN4    ANDEQ*BLANK                     CUST PART#4
     C                     MOVELBASHN1    A6SHN1           IAF PART#1
     C                     MOVELBASHN2    A6SHN2           IAF PART#2
     C                     MOVELBASHN3    A6SHN3           IAF PART#3
     C                     MOVELBAMHN1    A6MHN1           CUST PART#1
     C                     MOVELBAMHN2    A6MHN2           CUST PART#2
     C                     MOVELBAMHN3    A6MHN3           CUST PART#3
     C                     MOVELBAMHN4    A6MHN4           CUST PART#4
     C                     Z-ADDBASRYO    A6SRYO           QUANTITY
     C                     MOVE EKSYOS    A6QTYB           QTY/BOX
     C                     UPDATAB#PP661
     C                     ENDIF
     C                     ENDDO
     C*-------------------------
     C*-------------------------
     C                     CALL 'ANPR02'
     C                     PARM           D1SERL
     C                     PARM           P@ERR   1
     C*-------------------------
