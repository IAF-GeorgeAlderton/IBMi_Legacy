     H            Y.
      ** UEXR56 ****************************************************
      *  GET NEXT SEQUENCE NUMBER                                  *
      *  JW     2024.12.13                                         *
      **************************************************************
      *  CALLING SEQ.
      *                    CALL 'UEXR56 '
      *                    PARM           $KEY1   8
      *                    PARM           $KEY2   8
      *                    PARM           $SEQ1  110
      *                    PARM           $SEQ2  11
      *   IN  $KEY1   8A  KEYWORD1 IN AB#PPCT
      *   IN  $KEY2   8A  KEYWORD2 IN AB#PPCT
      *   OUT $SEQ1  11,0 SEQUENCE# IN NUMERIC
      *   OUT $SEQ2  11   SEQUENCE# 0 SUPLESSED TEXT
      *--------------------------------------
      *   EX. $KEY1=HONDA, $KEY2=ASN# --> $SEQ1 = 0000123456 (NEXT ASN#)
      *                               --> $SEQ2 = '123456   '(NEXT ASN#)
      ***********************************************************
     FAB#PPCT UF  E           K        DISK                      A
      ***********************************************************
     C           *ENTRY    PLIST
     C                     PARM           $KEY1   8
     C                     PARM           $KEY2   8
     C                     PARM           $SEQ1  110
     C                     PARM           $SEQ2  11
      *
     C                     Z-ADD0         $SEQ1
     C                     MOVE *BLANK    $SEQ2
     C           K#PPCT    KLIST
     C                     KFLD           $KEY1
     C                     KFLD           $KEY2
      *
     C           K#PPCT    CHAINAB#PPCT              98
      *
     C           *IN98     IFEQ *OFF
     C                     ADD  1         CTNBR1
     C                     UPDATAB#PPCT1
     C                     Z-ADDCTNBR1    $SEQ1
     C                     ELSE
     C                     CLEARAB#PPCT1
     C                     MOVELCTKEY1    CTKEY1
     C                     MOVELCTKEY2    CTKEY2
     C                     Z-ADD1         CTNBR1
     C                     WRITEAB#PPCT1
     C                     Z-ADD1         $SEQ1
     C                     ENDIF
      * EDIT $SEQ1
     C                     Z-ADD$SEQ1     PIN
     C                     CALL 'EDTR04'
     C                     PARM           PIN    300
     C                     PARM           POUT   30
     C                     MOVELPOUT      $SEQ2
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
