      * --------------------------------------------------
      * GET DATA FROM PPHN
     C           $NONY     IFEQ '0000'
     C                     MOVEL$PLNT     K@PLNT
     C                     MOVEL$SHCD     K@SHCD
     C                     MOVE *OFF      *IN95
     C           K#SHC     SETLLAB#PPHN
     C                     DO   *HIVAL
     C           K#SHC     READEAB#PPHN                  95
     C   95                LEAVE
     C           AHSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C                     MOVELAHTOKU    $TOKU
     C                     MOVELAHNONY    $NONY
     C                     LEAVE
     C                     ENDDO
     C                     ENDIF
      * ---------------------------------------------------
      * GET NONY FROM WILD CHARACTER(*)
     C           $NONY     IFEQ '0000'
     C           $NONY     OREQ *BLANK
     C                     MOVEL'*'       K@SHCD    P
     C           K#SHC     CHAINAB#PPHN              96
     C           *IN96     IFEQ *OFF
     C           AHSKJY    ANDNE'D'
     C                     MOVELAHTOKU    $TOKU
     C                     MOVELAHNONY    $NONY
     C                     ENDIF
     C                     ENDIF
      * ---------------------------------------------------
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
