     H            Y.
     F** AB#R4T1 *******************************************
     F*  PRINT TIER1 ORDER CREATION ERRORS LIST -- EMAIL   *
     F*  (COPIED FROM AB#RT1E)                             *
     F*  LEC     2021.12.06                                *
     F******************************************************
     FRDBWP20 IF  E                    DISK
     FRDBWP21 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *
     E                    TBL     1   1 50
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           PRT     1
      *
     C           R21KEY    KLIST
     C                     KFLD           K@TIER 10
     C                     KFLD           K@ORGC 10
     C                     KFLD           K@ORD# 15
     C                     KFLD           K@DOCK  4
      *
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     READ RDBWP20                  50
     C           *IN50     DOWEQ*OFF
     C                     EXSR #SB400
     C                     READ RDBWP20                  50
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  RDBWP21
      *-----------------------------------------------------
     CSR         #SB400    BEGSR
      *
     C           10        SUBSTTHINDX:1  K@TIER
     C           10        SUBSTTHINDX:11 K@ORGC
     C           15        SUBSTTHINDX:21 K@ORD#
     C                     MOVELTHNUKE    K@DOCK
      *
     C                     MOVELK@TIER    @TIER  10
     C                     MOVELK@ORGC    @ORGCD 10
     C                     MOVELK@ORD#    @ORD#  15
     C                     MOVELK@DOCK    @DOCK   2
      *
     C                     MOVELTHMSG     @ERROR 35
      *
     C                     EXSR #SB500
      *
     C           R21KEY    SETLLRDBWP21
     C           R21KEY    READERDBWP21                  51
      *
     C           *IN51     DOWEQ*OFF
      *
     C           TDMSG     IFNE *BLANKS
     C                     MOVELTDKSER    @SERL   5
     C                     MOVELTDMSG     @ERROR 35
     C                     MOVELTDMHN     @MHIN  15
     C                     Z-ADDTDQPC     @CQPC   50
     C                     Z-ADDTDSYOS    @IQPC   50
     C                     EXSR #SB500
     C                     ENDIF
      *
     C           R21KEY    READERDBWP21                  51
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *-----------------------------------------------------
      *  WRITE DETAIL
      *-----------------------------------------------------
     C           #SB500    BEGSR
      *
     C           W@1STP    IFEQ *ON
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     MOVEL*OFF      W@1STP
     C                     ENDIF
      *
     C                     EXCPT@DTL
      *
     C                     MOVE *BLANKS   @TIER
     C                     MOVE *BLANKS   @ORGCD
     C                     MOVE *BLANKS   @ORD#
     C                     MOVE *BLANKS   @DOCK
     C                     MOVE *BLANKS   @SERL
     C                     MOVE *BLANKS   @ERROR
     C                     MOVE *BLANKS   @MHIN
     C                     Z-ADD*ZERO     @CQPC
     C                     Z-ADD*ZERO     @IQPC
      *
     C                     MOVE 'Y'       PRT
      *
     C                     ENDSR
      *-----------------------------------------------------
      * INITIAL SET
      *-----------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL*ON       W@1STP  1
      *
     C                     ENDSR
      *
      *-----------------------------------------------------
     OQPRINT  E   01           @HED
     O                         W#PGM     10
     O                         TBL,1     72
     O                                   87 'DATE'
     O                         SDATE Y   98
     O                                  121 'PAGE'
     O                         PAGE  Z  125
     O        E   02           @HED
     O                                   87 'TIME'
     O                         STIME     98 '  :  :  '
     O        E   03           @HED
     O                                   11 'TIER1 NAME'
     O                                   21 'ORG CODE'
     O                                   31 'ORDER#'
     O                                   46 'DOCK'
     O                                   54 'SERIAL'
     O                                   61 'ERROR'
     O                                  104 'CUST PART#'
     O                                  119 'QPC'
     O                                  128 'IAF'
     O        E 1              @DTL
     O                         @TIER     11
     O                         @ORGCD    23
     O                         @ORD#     40
     O                         @DOCK     45
     O                         @SERL     54
     O                         @ERROR    91
     O                         @MHIN    109
     O                         @CQPC Z  119
     O                         @IQPC Z  128
** TBL
        << TIER 1 WEBSITE ORDER UPLOAD ERRORS >>
