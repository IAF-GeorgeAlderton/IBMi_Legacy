JW2  F*  JW   2024.05.23 STOP CHECKING LAST SHIP DATE          *
     F**********************************************************
     FABFJP01 IF  E                    DISK
JW1  FABFDP01 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *
      * SYSTEM TIME & DATE
     I            DS
     I                                        1  140WTMDT
     I                                        1   60WTIME
     I                                        1   20WTIHH
     I                                        3   40WTIMM
     I                                        5   60WTISS
     I                                        7  140WDATE
     I                                        9  140WDAT6
     I                                        7  100WDAY4
     I                                        9  100WDAYY
     I                                       11  120WDAMM
     I                                       13  140WDADD
      *
     C           *ENTRY    PLIST
     C                     PARM           PD      1
      ***********************************************************
      *   M  A  I  N  L  I  N  E
      ***********************************************************
     C                     EXSR @INZ
     C                     EXSR @MAIN
     C                     EXSR @END
      ***********************************************************
      * INITIALIZE WORK AREA
      ***********************************************************
     C           @INZ      BEGSR
      *
     C                     TIME           WTMDT
     C                     SETON                     OF
     C                     ENDSR
      ***********************************************************
      * MAIN PROCESSING SUBROUTINE
      ***********************************************************
     C           @MAIN     BEGSR
      *
     C                     READ ABFJP01                  90
      *
     C           *IN90     DOWEQ'0'
      *
     C   OF                EXCPT#HED1
     C   OF                EXCPT#HED2
     C   OF                SETOF                     OF
      *
JW1   * GET DELIVERY CODE
 .   C           K#DP01    KLIST
 .   C                     KFLD           KAPLAN  5
 .   C                     KFLD           KADOCK  4
     C                     MOVELAFSTID    KAPLAN
     C                     MOVELAFDOCK    KADOCK
      *
     C           K#DP01    CHAINABFDP01              99
     C           *IN99     IFEQ *OFF
 .   C                     MOVELQANONY    XNONY   4
 .   C                     ELSE
 .   C                     MOVEL'0000'    XNONY
JW1  C                     ENDIF
      *
     C                     EXCPT#DTL1
     C                     MOVE '1'       PD
      *
     C                     READ ABFJP01                  90
     C                     ENDDO
      *
     C                     ENDSR
      ***********************************************************
      * END
      ***********************************************************
     C           @END      BEGSR
      *
     C                     SETON                     LR
     C                     RETRN
      *
     C                     ENDSR
      ***********************************************************
     OQPRINT  E    2           #HED1
     O       OR        OF
