      *  229-229   つるべ区分 ﾎﾞ[]h :Ａ－ＰＩＣＳ
      *                           1   :つるべ    AFAR43でセット
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I              '0123456789'          C         WKCKSU
      *-----------------------------------------------------*
      *                                                     *
      *-----------------------------------------------------*
     C                     TIME           WTIME
     C                     READ AFAWP44                  80
     C           *IN80     DOWEQ'0'
     C                     EXSR #SB400
     C                     EXSR #SB500
     C                     READ AFAWP44                  80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------*
      * SET A SORT KEY                                      *
      *-----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEL*BLANK    WKKY01 20
     C                     MOVEL*BLANK    WKKY02 20
     C                     MOVEL*BLANK    WKKY03 20
     C                     MOVEL*BLANK    WKKY04 20
     C                     MOVEL*BLANK    WKKY05 20
     C                     MOVEL*BLANK    WKKY06 20
     C                     MOVEL*BLANK    WKKY07 20
     C                     MOVEL*BLANK    WKKY08 20
     C                     MOVEL*BLANK    WKKY09 20
     C                     MOVEL*BLANK    WKKY10 20
      * 00
     C                     MOVEL'00000'   WKKY01
     C                     Z-ADD0         ##BMON  40
     C           CFKDAI    IFEQ 'E'
     C                     MOVELIATOB     ##BMON
     C                     ELSE
     C                     MOVELCFMBMN    ##BMON
     C                     ENDIF
      * 01
     C                     Z-ADD0111      ##TBMN
     C           ##TBMN    IFEQ 0111
     C           CFKDAI    IFNE '0'
     C           ##BMON    IFEQ 0111
     C                     MOVEL'00100'   WKKY01
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      * 02
     C           ##TBMN    IFEQ 0111
     C           CFKDAI    IFEQ '0'
     C                     MOVEL'00200'   WKKY01
     C                     ENDIF
     C                     ENDIF
      * 03
     C           ##TBMN    IFEQ 0111
     C           CFKDAI    IFNE '0'
     C           ##BMON    IFNE 0111
     C                     MOVEL'00300'   WKKY01
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     EXSR #P01
      *
     CSR         ESB400    ENDSR
      *-----------------------------------------------------*
      *出力                                               *
      *-----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAGJWP111
     C                     MOVELIDATA     QQDATA
     C                     MOVELWKKY01    QQKY01
     C                     MOVELWKKY02    QQKY02
     C                     MOVELWKKY03    QQKY03
     C                     MOVELWKKY04    QQKY04
     C                     MOVELWKKY05    QQKY05
     C                     MOVELWKKY06    QQKY06
     C                     MOVELWKKY07    QQKY07
     C                     MOVELWKKY08    QQKY08
     C                     MOVELWKKY09    QQKY09
     C                     MOVELWKKY10    QQKY10
     C                     WRITEAGJWP111
      *
     CSR         ESB500    ENDSR
      *-----------------------------------------------------*
      * SET A SORT KEY                                      *
      *-----------------------------------------------------*
     CSR         #P01      BEGSR
      *
     C                     MOVELCFBLK1    WKKY02
     C                     MOVELCFBLK2    WKKY03
     C                     MOVELCFZSEQ    WKKY04
     C                     MOVEL*BLANK    WKKY05
     C                     MOVEL*BLANK    WKKY06
     C                     MOVEL*BLANK    WKKY07
     C                     MOVEL*BLANK    WKKY08
     C                     MOVEL*BLANK    WKKY09
     C                     MOVEL*BLANK    WKKY10
      *
     CSR         EP01      ENDSR
      *-----------------------------------------------------*
      * TBMN                                                *
      *-----------------------------------------------------*
     CSR         #SB800    BEGSR
      *
     C           KEY1      KLIST
     C                     KFLD           CFBMON
     C                     KFLD           CFKDAI
      *
     C           KEY5      KLIST
     C                     KFLD           CFBMON
     C                     KFLD           CFKDAI
     C                     KFLD           CFHIN1
     C                     KFLD           CFHIN2
     C                     KFLD           CFHIN3
      *
     C                     Z-ADD0         ##TBMN  40
     C                     MOVE *BLANK    WKCD1   1
     C                     MOVE *BLANK    WSW1    1
      *
     C           CFKDAI    IFEQ '0'
     C           CFBMON    OREQ 8907
     C                     Z-ADD8907      ##TBMN
     C                     ELSE
      *
     C           KEY1      SETLLACAPL111
      *
     C                     DO   *HIVAL
     C                     SETOF                     13
     C           KEY1      READEACAPL111                 13
     C           *IN13     IFEQ '0'
     C           I1SKJY    IFEQ 'D'
     C           I1SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     SETON                     13
     C                     MOVE '*'       WSW1
     C                     Z-ADDI1BMON    ##TBMN
     C                     MOVE I1KCD1    WKCD1
      *
     C                     END
     C                     END
     C  N13                END
      *
     C           WSW1      IFEQ *BLANK
     C                     Z-ADD0111      ##TBMN
     C                     ELSE
      *
     C                     SETOF                     14
     C           KEY5      CHAINACAPL111             14
     C           *IN14     IFEQ '0'
     C           I1SKJY    ANDEQ'D'
     C           I1SKHZ    ANDLE*DATE
     C                     SETON                     14
     C                     END
     C           *IN14     IFEQ '0'
     C                     Z-ADDI1BMON    ##TBMN
     C                     ELSE
      *
     C           ##TBMN    IFEQ 8907
     C           WKCD1     IFNE '0'
     C                     Z-ADD8990      ##TBMN
     C                     END
     C                     END
     C                     END
     C                     END
     C                     END
      *
     CSR         ESB800    ENDSR
