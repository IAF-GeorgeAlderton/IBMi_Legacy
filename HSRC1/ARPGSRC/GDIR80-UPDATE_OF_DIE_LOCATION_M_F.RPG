     FGDIPW80 CF  E                    WORKSTN
     FGDIPL30 UF  E           K        DISK                      A
     E                    MSG     1   7 59               d[ｰ xｮﾈｰﾆﾞ
     I****************************************************************
     I            DS
     I                                        1   8 D1DIE
     I                                        1   2 D1DIE1
     I                                        3   6 D1DIE2
     I                                        7   7 D1DIE3
     I                                        8   8 D1DIE4
     I            DS
     I                                        1   60@@TIME
     I                                        1   40@TIME
     I            DS
     I                                        1   40ILKOTM
     I                                        1   20ILKOHH
     I                                        3   40ILKOSS
     I            DS
     I                                        1   80ILSKHZ
     I                                        1   40ILSKYY
     I                                        5   60ILSKMM
     I                                        7   80ILSKDD
     I            DS
     I                                        1   80ILKOHZ
     I                                        1   40ILKOYY
     I                                        5   60ILKOMM
     I                                        7   80ILKODD
     C****************************************************************
     C*           ＭＡＩＮ　ＲＯＵＴＩＮＥ                         *
     C****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C*
     C           @CLR1     TAG
     C*
     C                     MOVE *BLANK    D1OPT
     C                     MOVE *BLANK    D1DIE
     C                     MOVE *BLANK    D#MSG
     C                     MOVEA'00'      *IN,11
     C                     MOVEA'0'       *IN,99
     C****************
     C*  第１画面  *
     C****************
     C           @DSP1     TAG
     C*
     C                     EXFMTDSP01
     C                     MOVEA'00'      *IN,11
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    D#MSG
     C* < F1=ON >
     C           *INKA     CABEQ'1'       @END
     C*
     C                     EXSR #CHK01
     C           *IN99     CABEQ'1'       @DSP1
     C*
     C                     EXSR #SET01
     C****************
     C*  第２画面  *
     C****************
     C           @DSP2     TAG
     C*
     C                     EXFMTDSP02
     C                     MOVEA'00'      *IN,21
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    D#MSG
     C* < F1=ON >
     C           *INKA     CABEQ'1'       @END
     C* < F3=ON >
     C           *INKC     CABEQ'1'       @DSP1
     C*
     C                     EXSR #CHK02
     C           *IN99     CABEQ'1'       @DSP2
     C* < F5=OFF >
     C           *INKE     CABEQ'0'       @DSP2
     C*
     C                     EXSR #UPD01
     C                     GOTO @CLR1
     C*
     C**************
     C* 終　　了 *
     C**************
     C           @END      TAG
     C                     SETON                     LR
     C                     RETRN
     C****************************************************************
     C*           ＳＵＢ　　ＲＯＵＴＩＮＥ                         *
     C****************************************************************
     C           #CHK01    BEGSR                                     *
     C****************************************************************
     C**第１画面チェック**
     C*
     C           D1OPT     IFNE '0'
     C           D1OPT     ANDNE'1'
     C           D1OPT     ANDNE'2'
     C                     MOVEA'1'       *IN,11
     C  N99                MOVELMSG,1     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK1E
     C                     END
     C*
     C*----------
     C           D1DIE1    IFEQ *BLANK
     C           D1DIE2    OREQ *BLANK
     C                     MOVEA'1'       *IN,12
     C  N99                MOVELMSG,7     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK1E
     C                     END
     C*
     C           D1DIE     SETLLGDIPL301
     C                     DO   *HIVAL
     C           D1DIE     READEGDIPL301            N    10
     C   10                LEAVE
     C           ILSKJY    IFEQ 'D'                        DELETE CODE
     C           ILSKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C*:
     C                     LEAVE
     C                     ENDDO
     C*----------
     C           *IN10     IFEQ '1'
     C           D1OPT     IFEQ '0'
     C           D1OPT     OREQ '1'
     C                     MOVEA'1'       *IN,12
     C  N99                MOVELMSG,3     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK1E
     C                     END
     C                     ELSE
     C           D1OPT     IFEQ '2'
     C                     MOVEA'1'       *IN,12
     C  N99                MOVELMSG,2     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK1E
     C                     END
     C                     END
     C*
     C*
     C           @CHK1E    ENDSR
     C****************************************************************
     C           #CHK02    BEGSR                                     *
     C****************************************************************
     C**第２画面チェック**
     C*
     C*
     C           D1OPT     IFNE '0'
     C           D2SYOS    IFEQ 0
     C                     MOVEA'1'       *IN,21
     C  N99                MOVELMSG,5     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK2E
     C                     END
     C           D2TKR1    IFNE '6'
     C                     MOVEA'1'       *IN,22
     C  N99                MOVELMSG,6     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK2E
     C                     END
     C           D2TKR2    IFEQ *BLANK
     C                     MOVEA'1'       *IN,22
     C  N99                MOVELMSG,6     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK2E
     C                     END
     C           D2TKR3    IFEQ *BLANK
     C                     MOVEA'1'       *IN,22
     C  N99                MOVELMSG,6     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK2E
     C                     END
     C           D2TKR4    IFEQ *BLANK
     C                     MOVEA'1'       *IN,22
     C  N99                MOVELMSG,6     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK2E
     C                     END
     C                     END
     C*
     C           @CHK2E    ENDSR
     C****************************************************************
     C           #SET01    BEGSR                                     *
     C****************************************************************
     C**第２画面セット**
     C                     MOVEA'00'      *IN,21
     C                     MOVEA'0'       *IN,29
     C           D1OPT     COMP '0'                      80
     C           D1OPT     COMP '1'                      81
     C           D1OPT     COMP '2'                      82
     C                     Z-ADD0         D2SYOS
     C                     MOVE *BLANK    D2TKR1
     C                     MOVE *BLANK    D2TKR2
     C                     MOVE *BLANK    D2TKR3
     C                     MOVE *BLANK    D2TKR4
     C  N82                Z-ADDILSYOS    D2SYOS
     C  N82                MOVELILTKR1    D2TKR1
     C  N82                MOVELILTKR2    D2TKR2
     C  N82                MOVELILTKR3    D2TKR3
     C  N82                MOVELILTKR4    D2TKR4
     C   80                MOVEA'1'       *IN,29
     C*----------
     C*
     C                     ENDSR
     C****************************************************************
     C           #UPD01    BEGSR                                     *
     C****************************************************************
     C**型・所番地マスターの更新**
     C*
     C                     TIME           @@TIME
     C*
     C           D1DIE     CHAINGDIPL301             10
     C*
     C                     MOVELD1DIE     ILDIE
     C                     Z-ADDD2SYOS    ILSYOS
     C                     MOVELD2TKR1    ILTKR1
     C                     MOVELD2TKR2    ILTKR2
     C                     MOVELD2TKR3    ILTKR3
     C                     MOVELD2TKR4    ILTKR4
     C                     Z-ADD*DATE     ILKOHZ
     C                     Z-ADD@TIME     ILKOTM
     C                     MOVELPPUSER    ILKOME
     C*
     C           *IN80     IFEQ '1'
     C                     MOVE 'D'       ILSKJY           DELETE CODE
     C                     Z-ADD*DATE     ILSKHZ
     C  N10                UPDATGDIPL301
     C                     ENDIF
     C           *IN81     IFEQ '1'
     C  N10                UPDATGDIPL301
     C                     ENDIF
     C           *IN82     IFEQ '1'
     C                     MOVE ' '       ILSKJY           DELETE CODE
     C                     Z-ADD0         ILSKHZ
     C  N10                UPDATGDIPL301
     C   10                WRITEGDIPL301
     C                     ENDIF
     C*
     C                     ENDSR
     C****************************************************************
**  MSG
 INCORRECT TREATMENT CLASIFICATION.
 THE DIE NUMBER INPUT ALREADY EXIST.
 THERE IS NO CONRRESPONDING DIE NUMBER EXIST.
 THERE IS NO DIE NUMBER IN THE LOCATION MASTER.
 INPUT THE ACCOMODATED QUANTITY.
 INCORRECT LOCATION.
 INCORRECT DIE NUMBER.
