     H            Y/                                    1
      **** GDIR70 ****************************************************
      *  INQUILY OF DAILY ORDERING DATA
      *        G.B.C                            97/04/09
      ****************************************************************
      ****************************************************************
     FGDIPW70 CF  E                    WORKSTN
     F                                        RRN   KSFILE S1
     FGDIPL17 IF  E           K        DISK
     FGDIPL25 IF  E           K        DISK
      ****************************************************************
     E                    MSG     1   2 60               d[ｰ xｮﾈｰﾆﾞ
      ****************************************************************
     I            DS
     I                                        1   60G1JSYM
     I                                        1   40G1JSYY
     I                                        5   60G1JSMM
     I            DS
     I                                        1   8 G1KATA
     I                                        1   2 G1KAT1
     I                                        3   6 G1KAT2
     I                                        7   7 G1KAT3
     I                                        8   8 G1KAT4
     I            DS
     I                                        1  11 S1KATA
     I                                        1   2 S1KAT1
     I                                        3   3 S1HF1
     I                                        4   7 S1KAT2
     I                                        8   8 S1HF2
     I                                        9   9 S1KAT3
     I                                       10  10 S1HF3
     I                                       11  11 S1KAT4
     I            DS
     I                                        1   40S1ODMD
     I                                        1   20S1ODMM
     I                                        3   40S1ODDD
     I            DS
     I                                        1   40S1NYMD
     I                                        1   20S1NYMM
     I                                        3   40S1NYDD
     I            DS
     I                                        1   8 IIKATA
     I                                        1   2 IIKAT1
     I                                        3   6 IIKAT2
     I                                        7   7 IIKAT3
     I                                        8   8 IIKAT4
      ****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
      ****************************************************************
     C           IIKEY1    KLIST
     C                     KFLD           G1JSYY
     C                     KFLD           G1JSMM
     C           IIKEY2    KLIST
     C                     KFLD           G1JSYY
     C                     KFLD           G1JSMM
     C           IKKEY1    KLIST
     C                     KFLD           IKITEM
      ****************************************************************
      *          M  A  I  N    R  O  U  T  I  N  E
      ****************************************************************
     C                     MOVEL'SET10'   W@NEXT  5
      *
     C           W@NEXT    DOWNE'END  '
      *
     C           W@NEXT    CASEQ'SET10'   @SET10
     C           W@NEXT    CASEQ'PNL10'   @PNL10
     C           W@NEXT    CASEQ'CHK10'   @CHK10
     C           W@NEXT    CASEQ'INZ20'   @INZ20
     C           W@NEXT    CASEQ'SET20'   @SET20
     C           W@NEXT    CASEQ'PNL20'   @PNL20
     C                     ENDCS
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      ****************************************************************
      *          S  U  B    R  O  U  T  I  N  E
      ****************************************************************
      *          @SET10    INIT
      ****************************************************************
     C           @SET10    BEGSR
      *ﾎｧｰﾓnﾞ hﾒa
     C                     Z-ADD*ZERO     G1JSYM
     C                     MOVEL*BLANK    G1KAT1
     C                     MOVEL*BLANK    G1KAT2
     C                     MOVEL*BLANK    G1KAT3
     C                     MOVEL*BLANK    G1KAT4
     C                     SETOF                     61
     C                     SETOF                     99
      * NEXT-ROUTINE
     C                     MOVEL'PNL10'   W@NEXT
      *
     C                     ENDSR
      ****************************************************************
      *          @PNL10
      ****************************************************************
     C           @PNL10    BEGSR
      *
     C                     WRITEC1
     C                     EXFMTG1
      *
     C                     SETOF                     61
     C                     SETOF                     99
     C                     MOVEL*BLANK    C1MSG
      * NEXT-ROUTINE
     C                     MOVEL'CHK10'   W@NEXT
      * END
     C           *IN01     IFEQ '1'
     C                     MOVEL'END  '   W@NEXT
     C                     END
      *
     C                     ENDSR
      ****************************************************************
      *          @CHK10
      ****************************************************************
     C           @CHK10    BEGSR
      * ORDER DATE
     C           G1JSYM    IFEQ *ZERO
     C                     SETON                     61
     C                     SETON                     99
     C                     MOVELMSG,1     C1MSG
     C                     END
      * MONTH
     C           *IN99     IFEQ '0'
     C           G1JSMM    IFLE *ZERO
     C           G1JSMM    ORGT 12
     C                     SETON                     61
     C                     SETON                     99
     C                     MOVELMSG,2     C1MSG            * d[ｰ xｮﾈｰﾆﾞ
     C                     END
     C                     END
      * NEXT-ROUTINE
     C                     MOVEL'INZ20'   W@NEXT
      * ERROR YES
     C           *IN99     IFEQ '1'
     C                     MOVEL'PNL10'   W@NEXT
     C                     END
      *
     C                     ENDSR
      ****************************************************************
      *          @INZ20
      ****************************************************************
     C           @INZ20    BEGSR
      *
     C                     SETON                     32    * SFLCLR
     C                     WRITES1C
     C                     SETOF                     32    * SFLCLR
      *
     C                     Z-ADD*ZERO     RRN
     C                     Z-ADD*ZERO     W1RRN   40
      *
     C                     MOVEL*BLANK    S1KATA
     C                     MOVEL*BLANK    S1ODER
     C                     MOVEL*BLANK    S1ITEM
     C                     Z-ADD*ZERO     S1ODMD
     C                     Z-ADD*ZERO     S1SURY
     C                     MOVEL*BLANK    S1INVO
     C                     Z-ADD*ZERO     S1NYMD
     C                     Z-ADD*ZERO     S1SUR2
     C                     MOVEL*BLANK    S1NYUK
      *
     C           G1KATA    IFEQ *BLANK
      *(GDIPL17)
     C                     MOVELG1KATA    IIKATA
     C           IIKEY1    SETLLGDIPL171
     C           IIKEY1    READEGDIPL171                 80
     C                     ELSE
      *(GDIPL17)
     C                     MOVELG1KATA    IIKATA
     C           IIKEY1    SETLLGDIPL171
     C                     SETOF                     81
     C           *IN81     DOWEQ'0'
     C           IIKEY1    READEGDIPL171                 80
     C   80                SETON                     81
     C           *IN80     IFEQ '0'
     C           G1KATA    IFEQ IIKATA
     C                     SETON                     81
     C                     END
     C                     END
     C                     END
     C*
     C                     END
      * NEXT-ROUTINE
     C                     MOVEL'SET20'   W@NEXT
      *
     C                     ENDSR
      ****************************************************************
      *          @SET20
      ****************************************************************
     C           @SET20    BEGSR
      *
     C                     Z-ADDW1RRN     RRN
     C                     Z-ADD*ZERO     JJ      40
      *
     C           *IN80     DOWEQ'0'
     C           JJ        ANDLE11
      *
     C           IISKJY    IFNE 'D'
     C           IISKHZ    ORGT *DATE
      *
     C                     MOVELIIKAT1    S1KAT1
     C                     MOVELIIKAT2    S1KAT2
     C                     MOVELIIKAT3    S1KAT3
     C                     MOVELIIKAT4    S1KAT4
      *
     C           IIKAT2    IFEQ *BLANK
     C                     MOVEL*BLANK    S1HF1            * ﾌbﾎ]
     C                     ELSE
     C                     MOVEL'-'       S1HF1            * ﾌbﾎ]
     C                     END
      *
     C           IIKAT3    IFEQ *BLANK
     C                     MOVEL*BLANK    S1HF2            * ﾌbﾎ]
     C                     ELSE
     C                     MOVEL'-'       S1HF2            * ﾌbﾎ]
     C                     END
      *
     C           IIKAT4    IFEQ *BLANK
     C                     MOVEL*BLANK    S1HF3            * ﾌbﾎ]
     C                     ELSE
     C                     MOVEL'-'       S1HF3            * ﾌbﾎ]
     C                     END
     C                     MOVELIIODER    S1ODER
     C                     MOVELIIITEM    S1ITEM
     C                     Z-ADDIIODRM    S1ODMM
     C                     Z-ADDIIODRD    S1ODDD
     C                     Z-ADDIISURY    S1SURY
     C                     MOVE IIIFMK    S1NYUK
     C                     MOVE IIIFMK    S1IFMK  1
     C                     EXSR @SET21
     C                     END
      *
     C           ##10      TAG
     C           G1KATA    IFEQ *BLANK
     C           IIKEY1    READEGDIPL171                 80
     C                     ELSE
     C           IIKEY1    READEGDIPL171                 80
     C  N80      G1KATA    CABNEIIKATA    ##10
     C                     END
      *
     C                     ENDDO
      *
     C           RRN       IFEQ *ZERO
     C                     MOVEL*BLANK    S1KATA
     C                     MOVEL'NONE'    S1KAT2
     C                     Z-ADD*ZERO     S1SURY
      *
     C                     ADD  1         RRN
     C                     WRITES1
     C                     END
      *
     C                     Z-ADDRRN       W1RRN
      *
     C           *IN80     IFEQ '1'
     C                     Z-ADDW1RRN     RRN
     C                     END
      * NEXT-ROUTINE
     C                     MOVEL'PNL20'   W@NEXT
      *
     C                     ENDSR
      ****************************************************************
      *          @SET21
      ****************************************************************
     C           @SET21    BEGSR
      *
     C                     Z-ADD*ZERO     II      40
     C                     MOVELIIITEM    IKITEM
     C           IKKEY1    SETLLGDIPL251
     C           IKKEY1    READEGDIPL251                 80
      *
     C           *IN80     DOWEQ'0'
     C           JJ        ANDLE11
     C                     MOVELIKINVO    S1INVO
     C                     Z-ADDIKNYUM    S1NYMM
     C                     Z-ADDIKNYUD    S1NYDD
     C                     Z-ADDIKSURY    S1SUR2
     C***                  MOVELIKNYUK    S1NYUK
      *
     C                     ADD  1         RRN
     C                     ADD  1         JJ
     C                     ADD  1         II
     C                     WRITES1
      *
     C           IKKEY1    READEGDIPL251                 80
     C                     MOVE *BLANK    S1KATA
     C                     MOVE *BLANK    S1ODER
     C                     MOVE *BLANK    S1ITEM
     C                     Z-ADD0         S1ODMD
     C                     Z-ADD0         S1SURY
     C                     MOVEL*BLANK    S1NYUK
      *
     C                     ENDDO
      *
     C           II        IFEQ *ZERO
     C                     MOVEL*BLANK    S1INVO
     C*                    MOVEL'NONE'    S1INVO
     C                     Z-ADD*ZERO     S1NYMD
     C                     Z-ADD*ZERO     S1SUR2
     C                     MOVELS1IFMK    S1NYUK
      *
     C                     ADD  1         RRN
     C                     ADD  1         JJ
     C                     WRITES1
     C                     END
      *
     C                     ENDSR
      ****************************************************************
      *          @PNL20
      ****************************************************************
     C           @PNL20    BEGSR
      *
     C                     WRITEC2
     C                     SETON                     31    * SFLDSP
     C                     EXFMTS1C
     C                     SETOF                     31    * SFLDSP
      * NEXT-ROUTINE
     C                     MOVEL'PNL20'   W@NEXT
     C           *IN01     IFEQ '1'
     C                     MOVEL'END  '   W@NEXT
     C                     END
     C           *IN03     IFEQ '1'
     C                     MOVEL'PNL10'   W@NEXT
     C                     END
      * ROLL-UP
     C           *IN25     IFEQ '1'
     C                     MOVEL'SET20'   W@NEXT
     C                     END
      *
     C                     ENDSR
      ****************************************************************
**  MSG (mｰﾎﾞﾓ ﾃx]n)
INPUT THE ORDER DATE.
WRONG THE ORDER DATE.
