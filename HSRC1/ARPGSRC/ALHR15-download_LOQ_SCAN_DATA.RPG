     H            Y.
     F** ALHR15 ************************************
     A*  DOWNLOAD LOQ SCAN DATA                    *
     F*  JW       2025.11.07                       *
     F**********************************************
     FALHPW15 CF  E                    WORKSTN
     FALHPP01 IF  E           K        DISK
     FALHWP15 O   E                    DISK
      *---------------------------------------------------------------
     E                    MSG     1   8 60
     E                    TTL     1  18 20
      *---------------------------------------------------------------
     I            DS
     I                                        1   80@FROM
     I                                        1   40XFRYY
     I                                        5   60XFRMM
     I                                        7   80XFRDD
     I            DS
     I                                        1   80@TO
     I                                        1   40XTOYY
     I                                        5   60XTOMM
     I                                        7   80XTODD
     I            DS
     I                                        1   80A1SCHZ
     I                                        1   40A1SCYY
     I                                        5   60A1SCMM
     I                                        7   80A1SCDD
     I            DS
     I                                        1  100A1TRT#
     I                                        1   40A1TSQY
     I                                        5   60A1TSQM
     I                                        7  100A1TSQ#
     I            DS
     I                                        1  12 A1SHIN
     I                                        1   5 A1SHN1
     I                                        6  10 A1SHN2
     I                                       11  12 A1SHN3
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *----------------------------------------------------*
      *   MAIN                                             *
      *----------------------------------------------------*
     C                     EXSR #INIT
      *
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------------*
      *   1ST SCREEN                                       *
      *----------------------------------------------------*
     C           #SCRN1    BEGSR
      * DEFAULT
     C           XFROM     IFEQ 0
     C                     Z-ADDTODAY     XFROM
     C                     ENDIF
      *
     C                     EXFMTDSP01
     C                     MOVE *OFF      *IN85
     C                     SETOF                     414243
     C                     MOVE *BLANK    XMSG
      *
     C                     SELEC
      * F1: EXIT
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN85     IFEQ *OFF
      * F5: RUN
     C           *INKE     IFEQ *ON
     C                     EXSR #OUT
     C                     MOVE '99'      @@ID
     C                     ELSE
     C                     MOVELMSG,6     XMSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  CHECK
      *----------------------------------------------------*
     C           #CHK1     BEGSR
      * DATE FROM
     C           XFROM     IFEQ 0
     C                     MOVE *ON       *IN85
     C                     MOVE *ON       *IN41
     C                     MOVELMSG,1     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     MOVELXFROM     $SRC      P
     C                     CALL 'UTLR01'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE   8
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$TRUE     XFROM
     C                     ELSE
     C                     MOVE *ON       *IN85
     C                     MOVE *ON       *IN41
     C                     MOVELMSG,2     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      * DATE TO
     C           XTO       IFEQ 0
     C                     Z-ADDXFROM     XTO
     C                     ENDIF
      *
     C           XTO       IFEQ 0
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,3     XMSG
     C                     MOVE *ON       *IN42
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     MOVELXTO       $SRC      P
     C                     CALL 'UTLR01'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE   8
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$TRUE     XTO
     C                     ELSE
     C                     MOVE *ON       *IN85
     C                     MOVE *ON       *IN42
     C                     MOVELMSG,4     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           XFROM     IFGT XTO
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,5     XMSG
     C                     MOVE *ON       *IN41
     C                     GOTO XCHK1
     C                     ENDIF
      * IF NO EROR ...
     C                     MOVELXFROM     @FROM
     C                     MOVELXTO       @TO
      *
     C           XCHK1     ENDSR
      *---------------------------------------------------
      *  OUTPUT DATA
      *---------------------------------------------------
     C           #OUT      BEGSR
      *
     C                     MOVELXFRYY     K#FYY
     C                     MOVELXFRMM     K#FMM
     C                     MOVELXFRDD     K#FDD
     C           K#FYMD    SETLLALHPP01
     C                     DO   *HIVAL
     C                     READ ALHPP01                  98
     C   98                LEAVE
      *
     C           A1SCHZ    IFGT @TO
     C                     LEAVE
     C                     ENDIF
      *
     C           A1SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * SCAN DATE
     C                     CLEARALHWP151
     C                     MOVELA1SCHZ    $DATE1
     C                     MOVELA1SCTM    $TIME1
     C                     CALL 'EDTR01 '
     C                     PARM           $DATE1  8
     C                     PARM           $TIME1  6
     C                     PARM           $YMD    3
     C                     PARM           $DATE2 10
     C                     PARM           $TIME2  8
     C                     MOVEL$DATE2    WASCHZ
     C                     MOVEL$TIME2    WASCTM
      *
     C                     MOVELA1SERL    WASERL
     C                     MOVELA1USER    WAUSER
     C                     MOVELA1PGID    WAPGM
     C                     MOVELA1OQNO    WALOQ#
     C                     MOVELA1CHG#    WACHG#
      * PART
     C                     MOVELA1SHIN    $SHIN
     C                     CALL 'EDTR02'
     C                     PARM           $SHIN  12
     C                     PARM           $SHIN2 14
     C                     MOVEL$SHIN2    WAPART
      *
     C                     MOVELA1TRT#    WATRT#
     C                     MOVELA1KAN     WABARC
     C                     MOVELA1TMCD    WAWKER
     C                     MOVELA1WSID    WAWSID
     C                     MOVELA1SHFT    WASHIF
     C                     MOVELA1ZACD    WAMTR
     C                     MOVELA1ZANM    WANAME
     C                     MOVELA1HOJI    WATIME
     C                     MOVELA1ONDO    WATEMP
     C                     MOVELA1KKND    WATYPE
      *
     C                     WRITEALHWP151
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      * INITIALIZE                                         *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           K#FYMD    KLIST
     C                     KFLD           K#FYY   40
     C                     KFLD           K#FMM   20
     C                     KFLD           K#FDD   20
      *
     C                     TIME           @SDATE
     C                     MOVE '01'      @@ID    2
     C                     MOVE *ALL'-'   @@LIN 132
     C                     Z-ADD0         @FROM
     C                     Z-ADD0         @TO
      * HEADER
     C                     CLEARALHWP151
     C                     MOVELTTL,01    WASCHZ
     C                     MOVELTTL,02    WASCTM
     C                     MOVELTTL,03    WASERL
     C                     MOVELTTL,04    WAUSER
     C                     MOVELTTL,05    WAPGM
     C                     MOVELTTL,06    WALOQ#
     C                     MOVELTTL,07    WACHG#
     C                     MOVELTTL,08    WAPART
     C                     MOVELTTL,09    WATRT#
     C                     MOVELTTL,10    WABARC
     C                     MOVELTTL,11    WAWKER
     C                     MOVELTTL,12    WAWSID
     C                     MOVELTTL,13    WASHIF
     C                     MOVELTTL,14    WAMTR
     C                     MOVELTTL,15    WANAME
     C                     MOVELTTL,16    WATIME
     C                     MOVELTTL,17    WATEMP
     C                     MOVELTTL,18    WATYPE
     C                     WRITEALHWP151
      *
     C                     ENDSR
** MSG(60A) .......2.........3.........4.........5.........6
ENTER DATE FROM!                                              1
DATE FROM IS INVALID!                                         2
ENTER DATE TO!.                                               3
DATE TO IS INVALID!                                           4
FROM IS GREATER THAN TO!                                      5
PRESS F5 TO RUN...                                            6
                                                              7
                                                              8
** TTL(20A) .......2
SCAN_DATE             1
SCAN_TIME             2
SERIAL#               3
USERT                 4
PGM#                  5
LOQ#                  6
CHG#                  7
IAF_PART#             8
TRT#                  9
BARCODE              10
WORKER#              11
WSID                 12
SHIFT                13
MATERIAL             14
NAME                 15
TIME                 16
TEMPERATURE          17
TYPE                 18
