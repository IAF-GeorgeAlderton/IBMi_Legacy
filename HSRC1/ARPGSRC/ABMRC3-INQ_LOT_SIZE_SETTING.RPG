     H            Y.
     F** ABMRC3 *********************************************
     F* INQ LOT SIZE SETTING
     F*    HOTTA.               2018.10.26                  *
     F*******************************************************
     FABMPWC3 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL
     FABMPPC5 IF  E           K        DISK
      *
     E                    ER      1  11 65
      *
     I            DS
     I                                        1   80BHSKHZ
     I                                        1   40BHSKYY
     I                                        5   60BHSKMM
     I                                        7   80BHSKDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
     C           *ENTRY    PLIST
     C                     PARM           PHBMON  4
     C                     PARM           PHKOTE  3
      *
     C           KEYBH     KLIST
     C                     KFLD           KHBMON  4
     C                     KFLD           KHKOTE  3
      *----------------------------------------------------*
      *  メインルーチン                                  *
      *----------------------------------------------------*
     C                     EXSR $SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR $SB200
     C                     END
     C                     EXSR $SB300
      *----------------------------------------------------*
      *   初期処理                                       *
      *----------------------------------------------------*
     CSR         $SB100    BEGSR
     C                     MOVEL'01'      DSPSW   2
      *
     C                     EXSR #CLR
     C                     MOVELPHBMON    KHBMON
     C                     MOVELPHKOTE    KHKOTE
      *
     CSR         $S100E    ENDSR
      *----------------------------------------------------*
      *   主処理                                         *
      *----------------------------------------------------*
     CSR         $SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR $SB210
     C                     END
     C           DSPSW     DOWEQ'02'
     C                     EXSR $SB220
     C                     END
     CSR         $S200E    ENDSR
      *----------------------------------------------------*
      *   処理区分                                       *
      *----------------------------------------------------*
     CSR         $SB210    BEGSR
      *
      *-------------------------*
      *対象データ存在チェック *
      *-------------------------*
      *
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     C                     SETOF                     8166
     C           KEYBH     SETLLABMPPC51
     C           KEYBH     READEABMPPC51                 81
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C           KEYBH     READEABMPPC51                 81
     C                     END
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     MOVE '02'      DSPSW
      *
     CSR         $S210E    ENDSR
      *----------------------------------------------------*
      *   第二画面処理(SFL.ABMPW029)                     *
      *----------------------------------------------------*
     CSR         $SB220    BEGSR
     C           CTRX      IFEQ 0
     C                     SETON                     72
     C                     SETON                     99
     C                     MOVELER,1      @ERR
     C                     ELSE
     C                     SETON                     7072
     C                     ENDIF
      *
     C                     WRITEABMPWC39
     C                     EXFMTSFLCTL
     C                     SETOF                     7072
     C                     SETOF                     99
     C                     MOVEL*BLANK    @ERR
      * CMD-3
     C           *IN03     IFEQ '1'
     C                     EXSR #CLR
     C                     SETOF                       03
     C                     MOVE '99'      DSPSW
     C                     GOTO $S220E
     C                     END
     C           CTRX      IFEQ 0
     C                     GOTO $S220E
     C                     END
      *-----------------*
      * ROLLDOWN/PAGEUP *
      *-----------------*
     C           *IN52     IFEQ '1'
     C*                    ADD  1         CTRX
      * 1ST. PAGE
     C           WKPAGE    IFEQ 1
     C                     GOTO $S220E
     C                     END
      *-----------------*
     C           *IN81     IFEQ '1'
     C                     SETOF                     81
     C           KEYBH     SETGTABMPPC51
     C           KEYBH     REDPEABMPPC51                 81
     C                     SUB  1         CTRX
     C                     END
      *
     C                     ADD  15        CTRX
      *                         L--表示行数
     C                     SETOF                     6627
      *
     C           *IN81     DOWEQ'0'
     C           *IN27     ANDEQ'0'
     C                     EXSR #READP
     C           KEYBH     REDPEABMPPC51                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXTP
     C                     ENDDO
      *
     C                     Z-ADD0         CTRX    40
      *
     C           *IN81     IFEQ '1'
     C           KEYBH     SETLLABMPPC51
     C           KEYBH     READEABMPPC51                 81
     C                     END
      *
     C                     EXSR #CLR
     C                     SETOF                     8166
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C           KEYBH     READEABMPPC51                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     SUB  1         WKPAGE
     C                     GOTO $S220E
     C                     ENDIF
      *--------------------*
      * ROLL-UP            *
      *--------------------*
     C           *IN51     IFEQ '1'
     C           *IN81     ANDEQ'0'
      *
     C                     EXSR #CLR
      *
     C                     SETOF                     6681
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C           KEYBH     READEABMPPC51                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     ADD  1         WKPAGE
     C                     GOTO $S220E
     C                     ENDIF
      *
     CSR         $S220E    ENDSR
      *----------------------------------------------------*
      *   終了処理                                       *
      *----------------------------------------------------*
     CSR         $SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         $S300E    ENDSR
      *----------------------------------------------------*
      *   照会データ検索                                 *
      *----------------------------------------------------*
     CSR         #READ     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREAD
     C                     ENDIF
      *
     C                     EXSR #EDIT
     C                     ADD  1         RRN
     C                     ADD  1         @RRN
     C                     ADD  1         CTRX
     C                     WRITESFL
      *
     C           CTRX      IFEQ 15
      *                         L表示行数
     C                     SETON                       66
     C                     END
      *
     CSR         EREAD     ENDSR
      *----------------------------------------------------*
      *   検索ファイル逆読み                             *
      *----------------------------------------------------*
     CSR         #READP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREADP
     C                     ENDIF
      *
     C                     SUB  1         CTRX           27
      *
     CSR         EREADP    ENDSR
      *----------------------------------------------------*
      *   検索条件判定                                   *
      *----------------------------------------------------*
     CSR         #SELEC    BEGSR
      *
     C           BHSKJY    IFEQ 'D'
     C           BHSKHZ    ANDLE*DATE
     C                     GOTO ESELEC
     C                     ENDIF
      *
     C                     MOVEL'1'       WKGET
      *
     CSR         ESELEC    ENDSR
      *----------------------------------------------------*
      *   表示項目＆サブファイルクリアー                 *
      *----------------------------------------------------*
     CSR         #CLR      BEGSR
      *
     C                     SETON                     71
     C                     WRITESFLCTL
     C                     SETOF                     7166
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN    40
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         @SFRC1
      *
     CSR         ECLR      ENDSR
      *----------------------------------------------------*
      *   編集処理                                       *
      *----------------------------------------------------*
     CSR         #EDIT     BEGSR
      *
     C                     MOVELBHPTAN    @PTAN
     C                     Z-ADDBHHTSU    @HTSU
     C                     SELEC
     C           BHFUGO    WHEQ '1'
     C                     MOVEL'< '      @FUGO
     C           BHFUGO    WHEQ '2'
     C                     MOVEL'> '      @FUGO
     C           BHFUGO    WHEQ '3'
     C                     MOVEL'= '      @FUGO
     C           BHFUGO    WHEQ '4'
     C                     MOVEL'<='      @FUGO
     C           BHFUGO    WHEQ '5'
     C                     MOVEL'>='      @FUGO
     C           BHFUGO    WHEQ '6'
     C                     MOVEL'<>'      @FUGO
     C                     ENDSL
     C                     Z-ADDBHLOT     @LOT
      *
     CSR         EEDIT     ENDSR
      *----------------------------------------------------*
      *   次データ                                       *
      *----------------------------------------------------*
     CSR         #NEXT     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXT
     C                     ENDIF
      *
     C                     READ ABMPPC51                 81
      *
     CSR         ENEXT     ENDSR
      *----------------------------------------------------*
      *   前データ                                       *
      *----------------------------------------------------*
     CSR         #NEXTP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXTP
     C                     ENDIF
      *
     C                     READPABMPPC51                 81
      *
     CSR         ENEXTP    ENDSR
     C*----------------------------------------------------------------
**
ER-1 NO DATAS.
ER-2
