     H            Y.
     F** UTLR75B **********************************************************
     F*  UTILITY- GET ORIGINAL USER PART# BY USER PART (5-5-5-5)
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR75B'
     F*                    PARM           $MHIN  20
     F*                    PARM           $NONY   4
     F*                    PARM           $UPART 20
     F*                    PARM           $RTN    1
     F*   IN  $MHIN  20A   USER PART (IN)
     F*       $NONY   4A   DELIVERY CODE
     F*   OUT $UPART 20A   USER PART (ORIGINAL)
     F*       $RTN    1A   RETURN (BLANK: OK, *: ERROR)
     F******************************************************************
     FEDIPP45 IF  E           K        DISK
     F******************************************************************
     I            DS
     I                                        1  20 ##MHIN
     I                                        1   5 ##MHN1
     I                                        6  10 ##MHN2
     I                                       11  15 ##MHN3
     I                                       16  20 ##MHN4
      *----------------------------------------------------
      * MAIN ROUTINE
      *----------------------------------------------------
     C                     EXSR #INIT
      *
      * GET PART FROM EDIPP45
     C                     EXSR #PP45
     C           *IN85     IFEQ *OFF
     C                     MOVEL#UPART    $UPART
     C                     MOVE *BLANK    $RTN
     C                     GOTO ENDP
     C                     ENDIF
      *
     C                     MOVE '*'       $RTN
      *
     C           ENDP      TAG
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------
      * GET PART FROM EDIPP45
      *----------------------------------------------------
     C           #PP45     BEGSR
      *
     C                     MOVE *OFF      *IN85
     C                     MOVE *BLANK    #UPART
     C                     MOVEL$NONY     K#NONY  40
     C                     MOVEL$MHIN     ##MHIN
     C                     MOVEL##MHN1    K#MHN1
     C                     MOVEL##MHN2    K#MHN2
     C                     MOVEL##MHN3    K#MHN3
     C                     MOVEL##MHN4    K#MHN4
     C           K#PP45    CHAINEDIPP45              85
     C   85                GOTO XPP45
      *
     C           E5SKJY    IFEQ 'D'
     C                     MOVE *ON       *IN85
     C                     GOTO XPP45
     C                     ENDIF
      *
     C                     MOVELE5UPRT    #UPART
      *
     C           XPP45     ENDSR
      *----------------------------------------------------
      * INITIAL SET
      *----------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $MHIN  20
     C                     PARM           $NONY   4
     C                     PARM           $UPART 20
     C                     PARM           $RTN    1
      *
     C           K#PP45    KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#MHN1  5
     C                     KFLD           K#MHN2  5
     C                     KFLD           K#MHN3  5
     C                     KFLD           K#MHN4  5
      *
     C                     MOVEL$MHIN     $UPART    P
     C                     MOVE *BLANK    $RTN
     C                     MOVE *BLANK    #UPART 20
      *
     C                     ENDSR
