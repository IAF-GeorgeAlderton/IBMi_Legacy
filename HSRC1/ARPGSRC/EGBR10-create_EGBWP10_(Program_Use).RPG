     H            Y.
     F** EGBR10 ********************************************
     F*  CREATE EGBWP10 (PROGRAM USE)                    *
     F*  J.WATALIB    2019.12.20                           *
     F******************************************************
     FEGBPL11 IF  E           K        DISK
     FRGAPP12 IF  E           K        DISK
     FVVVPP40 IF  E           K        DISK
     FEGBWP10 IF  E           K        DISK                      A
      ******************************************************
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   6 ODCDAT
     I                                        1   2 ODCDMM
     I                                        3   4 ODCDDD
     I                                        5   6 ODCDYY
     I            DS
     I                                        1   80@CRHZ
     I                                        1   40@CRHZY
     I                                        5   60@CRHZM
     I                                        7   80@CRHZD
     I           SDS
     I                                     *PROGRAM #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ******************************************************
      * MAIN ROUTINE
      ******************************************************
     C                     EXSR #INIT
     C*
     C                     DO   *HIVAL
     C                     READ EGBPL11                  98
     C   98                LEAVE
      *
     C           M1SKJY    IFEQ 'D'
     C           M1PGMN    OREQ *BLANK
     C                     ITER
     C                     ENDIF
      * CHECK DEPART
     C           M1USRC    CHAINRGAPP12              97
     C           *IN97     IFEQ *OFF
      * CHECK EGBWP10
     C                     MOVELM1PGMN    X1PGMN
     C           K#WP10    CHAINEGBWP10              96
     C           *IN96     IFEQ *ON
     C                     CLEAREGBWP101
     C                     MOVELJ9DPT     G1DPT
     C                     MOVELM1USRC    G1PROF
     C           M1MNNO    MULT 10        G1OPT
     C                     ADD  M1MNDN    G1OPT
     C                     MOVELM1PGMN    G1PGM
     C                     MOVELM1TEXT    G1TEXT
     C                     MOVELM1PGMN    LTR10  10 P
     C           LTR10     CHAINVVVPP40              99
     C           *IN99     IFEQ *OFF
     C                     Z-ADDV1LSHZ    G1LUHZ
     C                     Z-ADDV1CRHZ    G1CRHZ
     C                     MOVELODOBAT    G1ATTR
     C                     ENDIF
      *
     C                     WRITEEGBWP101
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C* INITIAL SETTING
     C*===============================================================
     C           #INIT     BEGSR
     C*
     C           K#WP10    KLIST
     C                     KFLD           M1USRC
     C                     KFLD           X1PGMN 10
     C*
     C                     TIME           @SDATE
     C*
     C                     ENDSR
