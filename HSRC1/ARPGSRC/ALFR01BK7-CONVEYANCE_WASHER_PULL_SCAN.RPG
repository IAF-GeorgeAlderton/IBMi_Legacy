     C**************************************************************************
     C           #FMT40    BEGSR
      *
     C                     EXFMTFMT400
     C                     MOVEL*BLANK    F4ERR
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKG     WHEQ *ON
     C                     EXSR #CLRS
     C                     MOVE '10'      @@ID
     C                     OTHER
     C                     EXSR #CHK40
     C           *IN99     IFEQ *OFF
     C           WALC#2    IFEQ 'R1'
     C           WALC#2    OREQ 'R2'
TCHK1C           WALC#2    OREQ 'RK'
TCHK1C           WALC#2    OREQ 'RH'
TCHK1C           WALC#2    OREQ 'RJ'
TCHK1C           WALC#2    OREQ 'RL'
TCHK1C           WALC#2    OREQ 'RM'
TCHK1C           WALC#2    OREQ 'RN'
     C                     MOVE '50'      @@ID
     C                     ELSE
     C                     EXSR #WRTOK
     C                     EXSR #CLRS
     C                     MOVEL'10'      @@ID
     C                     EXFMTFMT900
     C                     END
     C                     ELSE
     C                     EXSR #WRTER
     C                     END
     C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
