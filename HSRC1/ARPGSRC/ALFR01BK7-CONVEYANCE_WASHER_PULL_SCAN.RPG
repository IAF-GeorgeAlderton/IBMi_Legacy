     C**************************************************************************
     C*       WRITE A OK RECORD
     C**************************************************************************
     C           #WRTOK    BEGSR
     C*
     C                     CLEARALFPP011
     C*
     C                     TIME           WSDT
     C                     Z-ADDWSSDAT    A8DATE
     C                     Z-ADDWSSTM6    A8TIME
     C                     MOVEL#USER     A8USER
     C                     MOVEL#WSID     A8WSID
     C                     MOVEL#PGM      A8PGID
     C*
     C                     MOVELPOPR      A8TMCD
     C*
     C                     MOVELW@ERR     A8ERR
     C           W1BMON    IFEQ 8990
     C                     MOVEL'A'       A8DKND
     C                     END
     C           W1BMON    IFEQ 2323
     C                     MOVEL'F'       A8DKND
     C                     END
     C           W1BMON    IFEQ 2525
     C                     MOVEL'R'       A8DKND
     C                     END
JW2  C           W1BMON    IFEQ 3111
 "   C                     MOVEL'S'       A8DKND           SEKIDO
 "   C                     END
      * art metals
     C           W1BMON    IFEQ 2626
     C                     MOVEL'T'       A8DKND
     C                     END
     C*
     C                     MOVELW1SHN1    A8PRT1
     C                     MOVELW1SHN2    A8PRT2
     C                     MOVELW1SHN3    A8PRT3
     C*
     C                     MOVELWALOC     A8BRC1
     C                     MOVELWAZETI    A8B1LZ
     C                     MOVELWALC#1    A8B1L1
     C                     MOVELWALC#2    A8B1L2
     C                     MOVELWALC#3    A8B1L3
     C                     MOVELWALC#4    A8B1L4
     C*
     C           F2BARC    IFNE *BLANK
     C                     MOVELWBKNBN    A8BRC2
     C                     MOVELWBZETI    A8ZTI2
     C                     MOVELWBORDR    A8ODR2
     C                     MOVELWBITEM    A8ITM2
     C                     END
     C*
     C           F3BARC    IFNE *BLANK
     C                     MOVELWCKNBN    A8BRC3
     C                     MOVELWCZETI    A8ZTI3
     C                     END
     C*
     C           F4BARC    IFNE *BLANK
     C                     MOVELWDKNBN    A8BRC4
     C                     END
     C*
     C           F5BARC    IFNE *BLANK
     C                     MOVELWEKNBN    A8BRC5
     C                     END
     C*
     C           W@ERR     IFNE *BLANK
     C                     MOVELF99ER1    A8EM01
     C                     MOVELF99ER2    A8EM02
     C                     END
      *
     C                     WRITEALFPP011
     C*
      *
      * check/remove PT barcode in CV overflow file...
     C           A8BRC2    IFNE *BLANK
     C           W@ERR     ANDEQ*BLANK
      *
     C                     MOVEL#PGM      P#PGM  10 P
     C                     MOVELA8BRC2    P#BRC2 17 P
     C                     CALL 'ALCR9U'
     C                     PARM           POPR
     C                     PARM           P#PGM
     C                     PARM           P#BRC2
      *
      * UPDATE WASHER INVENTORY FILE - CANS (ORDER)...
     C           A8DKND    IFEQ 'A'
     C                     MOVELA8BRC2    ORDKAN 20
     C                     MOVELA8BRC5    RTVKAN 20
     C                     CALL 'IWAR70U3'
     C                     PARM           ORDKAN
     C                     PARM           RTVKAN
     C                     PARM           WALOC#
     C                     PARM           POPR
     C                     PARM           P#PGM
     C                     PARM '3'       #STEP   1
     C                     PARM           #RTNC   1
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*       WRITE A ERROR RECORD
     C**************************************************************************
     C           #WRTER    BEGSR
     C*
     C                     MOVEL'E'       W@ERR
     C*
     C                     EXSR #WRTOK
     C*
     C                     MOVEL*BLANK    W@ERR
     C*
     C                     ENDSR
     C**************************************************************************
** ERR
USER CODE ERROR                  #01 O
LOCATION ERROR                   #02 O
BLANK                            #03 O
M/F NOT FOUND                    #04 O
CHECK TAG                        #05 O
KANBAN ERROR                     #06 O
ONLY ASJ KANBAN                  #07 O
KANBAN KIND ERROR                #08 O
UNMATCH                          #09 O
PART NUMBER                      #10 O
FREEWAY KANBAN                   #11 O
                                 #12
                                 #13
                                 #14
                                 #15
                                 #16
                                 #17
                                 #19
                                 #20
                                 #09
