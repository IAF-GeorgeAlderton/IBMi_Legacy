     C                     MOVE '99'      @@ID
     C           *INKG     WHEQ *ON
     C                     EXSR #CLRS
     C                     MOVE '10'      @@ID
     C                     OTHER
     C                     EXSR #CHK30
     C           *IN99     IFEQ *OFF
     C                     MOVE '40'      @@ID
     C                     ELSE
     C                     EXSR #WRTER
     C                     END
     C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
     C*     FREEWAY/RK-METAL KANBAN SCREEN CHECK
     C**************************************************************************
     C           #CHK30    BEGSR
     C*
     C                     MOVEL*BLANK    W3SHIN
     C                     MOVELF3BARC    WCKNBN
     C                     SETOF                     9961
     C*
     C                     DO
     C*
     C           WCKNBN    IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,6     F3ERR
     C                     MOVELERR,6     F99ER1
     C                     MOVELERR,3     F99ER2
     C                     LEAVE
     C                     END
     C*
     C           WCSUPP    IFNE '2323'
TCHK2C           WCSUPP    ANDNE'2525'
JW2  C           WCSUPP    ANDNE'3111'
     C           WCSUPP    ANDNE'2626'
     C                     SETON                     9961
     C                     MOVELERR,6     F3ERR
     C                     MOVELERR,6     F99ER1
     C                     MOVELERR,11    F99ER2
     C                     LEAVE
     C                     END
     C*
     C           WCZETI    IFNE WAZETI
     C                     SETON                     9961
