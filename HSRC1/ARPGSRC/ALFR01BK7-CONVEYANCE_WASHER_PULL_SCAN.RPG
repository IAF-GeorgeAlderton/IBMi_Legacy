     C                     END
      *
     C                     ENDSR
     C*************************************************************************
     C*     LOCATION SCREEN
     C**************************************************************************
     C           #FMT10    BEGSR
     C*
     C                     EXFMTFMT100
     C                     MOVEL*BLANK    F1ERR
     C*
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKG     WHEQ *ON
     C                     EXSR #CLRS
     C                     MOVE '10'      @@ID
     C                     OTHER
     C                     Z-ADD*ZERO     W1BMON  40
     C                     EXSR #CHK10
     C           *IN99     IFEQ *OFF
     C           W1BMON    IFEQ 8990
     C                     MOVEL'20'      @@ID
     C                     ELSE
 JW1 C                     MOVE '40'      @@ID
     C                     END
     C                     ELSE
     C           F1LOC     IFNE *BLANK
     C                     EXSR #WRTER
     C                     END
     C                     END
     C                     ENDSL
     C*
     C                     ENDSR
     C**************************************************************************
     C*     LOCATION SCREEN CHECK
     C**************************************************************************
     C           #CHK10    BEGSR
     C*
     C                     MOVEL*BLANK    W1SHIN
     C                     MOVELF1LOC     WALOC
     C                     SETOF                     9961
     C*
     C                     DO
     C*
     C           WALOC     IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,2     F2ERR
     C                     MOVELERR,2     F99ER1
     C                     MOVELERR,3     F99ER2
     C                     LEAVE
     C                     END
     C*
     C           K#AKB     KLIST
     C                     KFLD           WALC#1
     C                     KFLD           WALC#2
     C                     KFLD           WALC#3
     C                     KFLD           WALC#4
     C           K#AKB     SETGTAKBPL01
     C*
     C                     DO   *HIVAL
     C*
     C           K#AKB     REDPEAKBPL01                  90
     C   90                LEAVE
     C           L1SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           L1STYY    IFNE 9999
     C                     ITER
     C                     END
      * LEC
      * CHECK PART ID, IF NOT SAME IGNORE
     C           L1ZETI    IFNE WAZETI
     C                     ITER
     C                     ENDIF
     C*
     C                     LEAVE
     C*
     C                     ENDDO
     C*
     C           *IN90     IFEQ *ON
     C                     SETON                     9961
     C                     MOVELERR,2     F2ERR
     C                     MOVELERR,2     F99ER1
     C                     MOVELERR,4     F99ER2
     C                     LEAVE
     C                     END
     C*
     C           L1ZETI    IFNE WAZETI
     C                     SETON                     9961
     C                     MOVELERR,2     F2ERR
     C                     MOVELERR,2     F99ER1
     C                     MOVELERR,5     F99ER2
     C                     LEAVE
     C                     END
     C*
     C                     MOVELL1SHN1    W1SHN1
     C                     MOVELL1SHN2    W1SHN2
     C                     MOVELL1SHN3    W1SHN3
     C                     Z-ADDL1BMON    W1BMON
     C*
     C                     ENDDO
     C*
     C           *IN99     IFEQ *ON
     C                     EXFMTFMT999
     C                     END
     C*
     C                     ENDSR
     C*----------------------------------------------------------------*********
     C*     FIELD CLEAR SUB
     C*----------------------------------------------------------------*********
     C           #CLRS     BEGSR
     C*
     C                     CLEARFMT100
