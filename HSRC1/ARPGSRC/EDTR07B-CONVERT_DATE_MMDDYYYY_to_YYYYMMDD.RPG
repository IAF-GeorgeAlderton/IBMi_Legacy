     H            Y.
     F** EDTR07B ***************************************
     F*  CONVERT DATE MMDDYYYY TO YYYYMMDD             *
     F*  J.WATANABE    2024.05.09                      *
     F*------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'EDTR07B'
     F*                    PARM           $MDY    8
     F*                    PARM           $YMD1   8
     F*                    PARM           $YMD2   6
     F*  IN  $MDY    8A DATE MMDDYYYY  (EX. 12312024) BLANK=TODAY
     F*  OUT $YMD1   8A DATE YYYYMMDD  (EX. 20241231)
     F*  OUT $YMD2   6A DATE YYMMDD    (EX. 241231)
     F**************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        7  100TOYY
     I                                       11  120TOMM
     I                                       13  140TODD
     I            DS
     I                                        1   8 @MDY
     I                                        1   2 @MM
     I                                        3   4 @DD
     I                                        5   8 @YYYY
     I                                        7   8 @YY
     I            DS
     I                                        1   8 XYMD1
     I                                        1   4 XYYYY1
     I                                        5   6 XMM1
     I                                        7   8 XDD1
     I            DS
     I                                        1   6 XYMD2
     I                                        1   2 XYY2
     I                                        3   4 XMM2
     I                                        5   6 XDD2
      *=========================
      * MAIN ROUTINE
      *=========================
     C           *ENTRY    PLIST
     C                     PARM           $MDY    8
     C                     PARM           $YMD1   8
     C                     PARM           $YMD2   6
      *
     C           $MDY      IFEQ *BLANK
     C           $MDY      OREQ *ZEROS
     C                     TIME           SDATE
     C                     MOVELTOYY      @YYYY
     C                     MOVELTOMM      @MM
     C                     MOVELTODD      @DD
     C                     ELSE
     C                     MOVEL$MDY      @MDY
     C                     ENDIF
      * $MDY1
     C                     MOVEL@MM       XMM1
     C                     MOVEL@DD       XDD1
     C                     MOVEL@YYYY     XYYYY1
     C                     MOVELXYMD1     $YMD1
      * $MDY2
     C                     MOVEL@MM       XMM2
     C                     MOVEL@DD       XDD2
     C                     MOVEL@YY       XYY2
     C                     MOVELXYMD2     $YMD2
      *
     C                     SETON                     LR
     C                     RETRN
