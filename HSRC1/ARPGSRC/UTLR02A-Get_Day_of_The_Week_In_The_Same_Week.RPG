     H            Y.
     F** UTLR02A *******************************************
     F*  PROGRAM: GET DAY OF THE WEEK IN THE SAME WEEK     *
     F*  WRITTEN: JW (SRA)  2019.09.09                     *
     F*  (SAME FUNCTION WITH UTLR36)                       *
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR02A'
     F*                    PARM           $DT81   8
     F*                    PARM           $DAY    1
     F*                    PARM           $DT82   8
     F*                    PARM           $RTN    1
     F*  IN   $DT81 :  8A DATE1 (YYYYMMDD)
     F*       $DAY  :  1A DESIGNATED DAY (1:MON, 2:TUE,,, 6:SAT, 7=SUN)
     F*  OUT  $DT82 :  8A DATE2 (YYYYMMDD)
     F*       $RTN  :  1A RETURN FLAG (BLANK=OK, 1=DATE ERROR, 2=DAY ERROR)
     F*********************************************************************
     FAGDPL12 IF  E           K        DISK
      *--------------------------------------------------------
     I            DS
     I                                        1   80K@DT
     I                                        1   40K@DTYY
     I                                        5   60K@DTMM
     I                                        7   80K@DTDD
     I            DS
     I                                        1   80F8KA
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
      *
     C                     EXSR #INIT
      * CHECK DATE1
     C                     EXSR #CHK
      *
     C           *IN85     IFEQ *OFF
     C                     EXSR #CALC
     C                     ELSE
     C                     GOTO ENDP
     C                     ENDIF
      *
     C           ENDP      TAG
     C                     SETON                     LR
     C                     RETRN
      *=============================================================
      *          CHECK PARAMETERS
      *=============================================================
     C           #CHK      BEGSR
     C                     MOVE *OFF      *IN85
     C                     Z-ADD0         @DT81   80
     C                     Z-ADD0         @YOBI   10
      * CHECK DATE
     C                     MOVEL$DT81     K@DT
     C           K@PL12    CHAINAGDPL12              99
     C           *IN99     IFEQ *ON
     C                     MOVE '1'       $RTN
     C                     SETON                     85
     C                     GOTO XCHK
     C                     ELSE
     C                     MOVEL$DT81     @DT81
     C                     MOVELF8YOBI    @YOBI
     C                     ENDIF
      * CHECK DAY
     C           $DAY      IFNE '1'
     C           $DAY      ANDNE'2'
     C           $DAY      ANDNE'3'
     C           $DAY      ANDNE'4'
     C           $DAY      ANDNE'5'
     C           $DAY      ANDNE'6'
     C           $DAY      ANDNE'7'
     C                     MOVE '2'       $RTN
     C                     SETON                     85
     C                     GOTO XCHK
     C                     ELSE
     C                     MOVEL$DAY      @DAY    10
     C                     ENDIF
      *
     C           XCHK      TAG
     C                     ENDSR
      *=============================================================
      *          GET DATE2 FROM YOBI
      *=============================================================
     C           #CALC     BEGSR
      *
     C           @DAY      IFEQ @YOBI
     C                     MOVEL$DT81     $DT82
     C                     GOTO XCALC
     C                     ENDIF
      * GET DIFFERENCE
     C           @DAY      SUB  @YOBI     @DIF    40
     C           @DIF      IFGE 0
     C                     MOVE '+'       $SIGN
     C                     ELSE
     C                     MOVE '-'       $SIGN
     C                     MULT -1        @DIF
     C                     ENDIF
      *
     C                     MOVEL$DT81     $DT8
     C                     MOVEL@DIF      $DAYS
     C                     MOVE 'N'       $IAF    1
     C                     CALL 'UTLR10'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN    1
     C                     MOVEL$TGT8     $DT82
      *
     C           XCALC     ENDSR
      *=============================================================
      *                    INITIAL PROCESS
      *=============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $DT81   8        IN
     C                     PARM           $DAY    1        "
     C                     PARM           $DT82   8        OUT
     C                     PARM           $RTN    1        "
      *
     C           K@PL12    KLIST
     C                     KFLD           K@DTYY  40
     C                     KFLD           K@DTMM  20
     C                     KFLD           K@DTDD  20
      *
     C                     TIME           SDATE
     C                     MOVE *BLANK    $RTN
     C                     MOVEL'00000000'$DT82
      *
     C           $DT81     IFEQ *BLANK
     C           $DT81     OREQ '00000000'
     C                     MOVELTODAY     $DT81
     C                     ENDIF
      *
     C                     ENDSR
