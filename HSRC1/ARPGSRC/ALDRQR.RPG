     H            Y.
     FALDPL28 IF  E           K        DISK
     FALDWPQR O   F     256            DISK
      *
     C                     Z-ADD20230227  K@DATE  80
      *
     C           K@DATE    SETLLALDPL28
     C                     DO   *HIVAL
     C                     READ ALDPL28                  77
     C   77                LEAVE
      *
     C           A9CODT    IFNE K@DATE
     C                     LEAVE
     C                     END
      *
     C                     CALL 'AAMRSJ'
     C                     PARM A9ABAR    P@BARC 20
     C                     PARM 'JC '     P@KOTE  3
     C                     PARM '0111'    P@BMON  4
     C                     PARM *BLANK    P@KIBN  3
     C                     PARM *BLANK    P@RTN   1
      *
     C                     MOVE *BLANK    P#RTN   1
     C                     Z-ADD0         P#WINY  40
     C                     Z-ADD0         P#WINM  20
     C                     Z-ADD0         P#WIND  20
     C                     Z-ADD0         P#WINJ  20
     C                     Z-ADD0         P#WINF  20
     C                     Z-ADD0         P#WMJY  20
     C                     MOVE *BLANK    P#MKKB  2
     C           P@RTN     IFEQ '*'
     C                     CALL 'AJHRS1'
     C                     PARM A9ABAR    P#BARC 20
     C                     PARM *BLANK    P#RTN   1
     C                     PARM 0         P#WINY  40
     C                     PARM 0         P#WINM  20
     C                     PARM 0         P#WIND  20
     C                     PARM 0         P#WINJ  20
     C                     PARM 0         P#WINF  20
     C                     PARM 0         P#WMJY  20
     C                     PARM *BLANK    P#MKKB  2
     C                     END
      *
     C                     CALL 'TIMR90'
     C                     PARM           A9COTM  60
     C                     PARM           O@COTM  8
      *
     C  N99                EXCPTOHED
     C                     SETON                     99
     C                     EXCPTODAT
      *
     C                     ADD  1         SAKA    40
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
     OALDWPQR E                OHED
     O                                      'PART NO.,'
     O                                      'STORE IN DATE,'
     O                                      'STORE IN TIME,'
     O                                      'BARCODE,'
     O                                      'JC CHECK,'
     O                                      'JC CHECK RESULT,'
     O                                      'STORE IN RESULT,'
     O                                      'STORE IN NG CODE,'
     O        E                ODAT
     O                                      '="'
     O                         A9AHN1
     O                         A9AHN2
     O                         A9AHN3
     O                                      '"'
     O                                      ','
     O                         A9CODT       '    /  /  '
     O                                      ','
     O                         O@COTM
     O                                      ','
     O                         A9ABAR
     O                                      ','
     O                         P@RTN
     O                                      ','
     O                         P#RTN
     O                                      ','
     O                         A9OKNG
     O                                      ','
     O                         A9ERCD
