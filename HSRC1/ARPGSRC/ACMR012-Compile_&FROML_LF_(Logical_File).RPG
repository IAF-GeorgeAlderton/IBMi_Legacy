     H            Y.
      ** ACMR012  ******************************************
      *  COMPILE OBJLIB/LF (LOGICAL FILE)                  *
      *  JW      2022.10.11                                *
      ******************************************************
     FVVVPLA1 IF  E           K        DISK
     FACMWP10 O   E                    DISK
      ******************************************************
JWL  I            DS
"    I                                        1  140SDATE
"    I                                        1   60NOW
"    I                                        7  140TODAY
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ******************************************************
     C                     EXSR #INIT
      *
     C           PF        SETLLVVVPLA1
     C                     DO   *HIVAL
     C           PF        READEVVVPLA1                  51
     C   51                LEAVE
      * COMPILE L/F
     C                     MOVELVVREFI    LF        P
     C                     CALL 'ACMC012'
     C                     PARM           LF     10
     C                     PARM           OBJLIB
     C                     PARM           DDSF
     C                     PARM           SRCLIB
     C                     PARM           #STS    1
      *
     C                     EXSR #LOG
      *
     C                     ENDDO
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
      *****************************************
      * OUTPUT ACNPW10
      *****************************************
     C           #LOG      BEGSR
      *
     C                     TIME           SDATE
     C                     CLEARACMWP101
     C                     MOVELVVRFI     A1PF
     C                     MOVELVVREFI    A1LF
     C                     MOVELSRCLIB    A1SLIB
     C                     MOVELDDSF      A1SFIL
     C                     MOVEL'PF      'A1STYP
     C           #STS      IFEQ ' '
     C                     MOVEL'GOOD'    A1STAT
     C                     ELSE
     C                     MOVEL'FAIL'    A1STAT
     C                     ENDIF
      *
     C                     Z-ADDTODAY     A1CRHZ
     C                     Z-ADDNOW       A1CRTM
     C                     MOVEL#USER     A1CRUS
     C                     MOVEL#WSID     A1CRWS
     C                     WRITEACMWP101
      *
     C                     ENDSR
      *****************************************
      * INITIAL SETTING
      *****************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           PF     10
     C                     PARM           OBJLIB 10
     C                     PARM           DDSF   10
     C                     PARM           SRCLIB 10
      *
     C                     TIME           SDATE
      *
     C                     ENDSR
