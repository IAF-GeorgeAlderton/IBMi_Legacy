     H*           Y
     H** AB#RFQ  PRINT WEEKLY ORDER SHEET **************************************
     H*                                                                        *
     H*  TCH 02.19.00                                                          *
     H*  TCH 08.07.01                                                          *
TCH47H*  TCH 03.08.05                                                          *
TCHK1H*  TCH 12.24.05 CHG PRINTER CONTROL                                      *
TCHK2H*  TCH 02.06.13 CHG CFDOCK LENGTH(4 --> 5)                               *
     H**************************************************************************
     H*
     H* *IN03 = (CF03) EXIT
     H* *IN05 = (CF03):PRINT
     H* *IN89 = 0(FIRST PRINT DATA)
     H* *IN90 = 1(NOT READ AGDPL12:CALENDER FILE)
     H* *IN91 = 1(NOT READ AFAPP30:FORECAST KEY FILE(FORD)
     H* *IN92 = 1(NOT READ ABFDP01:ROUTE CODE MASTER(NIRVANA)
     H* *IN93 = 1(NOT READ ABFPL10:FORECAST DATA
     H* *IN94 = 1(NOT READ FCEPL01:PART MASTER
     H* *IN95 = 1(NOT READ ABFAL01:EDI862 KEY FILE)
     H* *IN96 = 1(NOT READ ABF9P01:FORD ADDRESS MASTER)
     H* *IN98 = 1(DISPLAY MSG)
     H* *IN99 = INPUT ERROR
     H*
     H**************************************************************************
     FAB#PWFQ CF  E                    WORKSTN
     FAGDPL12 IF  E           K        DISK
     FABFPP30 IF  E           K        DISK
     FABFDP01 IF  E           K        DISK
     FABFPL10 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FABFAL01 IF  E           K        DISK
     FABF9P01 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER                        UC
     F**************************************************************************
     E                    MES     1   2 78
     E                    CMD     1   1 80
     E                    ARY        80  1
     I**************************************************************************
     I* SCHEDULE ISSUE DATE ABFPP30
     I            DS
     I                                        3   80WGSIDT
     I                                        1   80CGSIDT
     I* INPUT DATE(DISPLAY)
     I            DS
     I                                        3   80W@DATE
     I                                        1   40@YY
     I                                        5   60@MM
     I                                        7   80@DD
     I* PART(KEY FILE)
     I            DS
     I                                        1  12 CGPART
     I                                        1   5 WPART1
     I                                        6  10 WPART2
     I                                       11  12 WPART3
     I            DS
     I                                        1   80QASKHZ
     I                                        1   40QASKYY
     I                                        5   60QASKMM
     I                                        7   80QASKDD
     I            DS
     I                                        1   80QAEFHZ
     I                                        1   40QAEFYY
     I                                        5   60QAEFMM
     I                                        7   80QAEFDD
     C**************************************************************************
     C           *ENTRY    PLIST
     C                     PARM           USER   10
TCH47C           P#CMD     PLIST
     C                     PARM           P@CMD 256
TCH47C                     PARM           P@LEN  155
     C**************************************************************************
     C*
     C* AGDPL12 CALENDER
     C           KEY1      KLIST
     C                     KFLD           @YY
     C                     KFLD           @MM
     C                     KFLD           @DD
     C*
     C* AGFPP10 FORD FORECAST DATA
     C           KEY2      KLIST
     C                     KFLD           CGDOCK
     C                     KFLD           CGPART
     C                     KFLD           W@DATE
     C                     KFLD           WGSIDT
     C*
     C* FCEPL01 PART MASTER
     C           KEY3      KLIST
     C                     KFLD           WPART1
     C                     KFLD           WPART2
     C                     KFLD           WPART3
     C*
     C* ABFAL01 FORD 862 KEY FILE
     C           KEY4      KLIST
     C                     KFLD           WKDOCK
     C                     KFLD           CGPART
     C**************************************************************************
     C*                   MAIN LOGIC
     C**************************************************************************
     C*
     C*
     C                     TIME           WTIME   60
     C                     MOVELUSER      WUSER   7
     C                     EXSR @INIT
     C           *INKC     DOWEQ'0'
     C                     EXFMTAB#PWFQ1
     C                     MOVE *BLANK    MSG
     C                     SETOF                     9998
     C*
     C           *INKE     IFEQ '1'
     C                     EXSR @CHK
     C           *IN99     IFEQ '0'
     C                     EXSR @PRNT
     C                     END
     C*
     C                     ELSE
     C                     EXSR @CHK
     C                     END
     C*
     C                     END
     C*
     C                     EXSR @END
     C**************************************************************************
     C*  @END SUBROUTINE: END OF JOB PROCESS
     C**************************************************************************
     C           @END      BEGSR
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C                     ENDSR
     C**************************************************************************
     C*  @CHK  SUBROUTINE: CHECK DATE
     C**************************************************************************
     C           @CHK      BEGSR
     C*
     C           KEY1      CHAINAGDPL12              90
     C           *IN90     IFEQ '1'
     C                     SETON                     990198
     C                     MOVEAMES,1     MSG
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*  @INIT SUBROUTINE: CLEAR FILDS
     C**************************************************************************
     C           @INIT     BEGSR
     C*
TCH47C                     MOVE '1'       P@PRT
     C                     MOVE *BLANKS   MSG
     C                     MOVE *BLANKS   WGSIDT
TCHK2C*                    MOVE *BLANKS   WKDOCK  4
TCHK2C                     MOVE *BLANKS   WKDOCK  5
     C                     MOVE *BLANK    WKDELY  4
     C                     MOVE *BLANK    WK862   3
     C                     Z-ADD*ZERO     W@DATE
     C                     Z-ADD*ZERO     WKAMT   60       ORDER QTY.
     C                     Z-ADD*ZERO     WKCAMT  90       IAF CUM.
     C                     Z-ADD*ZERO     WKUNIT  50       QTY/CONT.
     C                     SETOF                     89
     C*
     C                     ENDSR
     C**************************************************************************
     C*  @PRNT SUBROUTINE: PRINT WEEKLY OPRDER SHEET
     C**************************************************************************
     C           @PRNT     BEGSR
TCH47C*
   | C           P@PRT     IFEQ '1'
     C                     MOVEL'LANPRT02'@PRT    8
     C                     ENDIF
     C           P@PRT     IFEQ '2'
     C                     MOVEL'LANPRT07'@PRT
     C                     ENDIF
     C           P@PRT     IFEQ '3'
     C                     MOVEL'LANPRT08'@PRT
     C                     ENDIF
     C           P@PRT     IFEQ '4'
     C                     MOVEL'LANPRT03'@PRT
     C                     ENDIF
     C           P@PRT     IFEQ '5'
     C                     MOVEL'QPRINTA '@PRT
     C                     ENDIF
     C           P@PRT     IFEQ '6'
     C                     MOVEL'LANPRT09'@PRT
     C                     ENDIF
TCHK1C           P@PRT     IFEQ '7'
TCHK1C                     MOVEL'LANPRT10'@PRT
TCHK1C                     ENDIF
TCHK1C           P@PRT     IFEQ '8'
TCHK1C                     MOVEL'LANPRT05'@PRT
TCHK1C                     ENDIF
TCHK1C           P@PRT     IFEQ '9'
TCHK1C                     MOVEL'QDKT    '@PRT
TCHK1C                     ENDIF
     C                     MOVEACMD,1     ARY
     C                     MOVEA@PRT      ARY,27
     C                     MOVEAARY       P@CMD
   | C                     Z-ADD80        P@LEN
TCH47C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN QPRINT
     C*
     C           *LOVAL    SETLLABFPP301
     C                     READ ABFPP301                 91
      *  ----------------------------------------------- *
B0   C           *IN91     DOWEQ'0'
     C           CGDLCD    CABNE*BLANK    #READ
      *
     C           CGDOCK    SETLLABFDP01R
B1   C           *IN92     DOUEQ*ON
     C           CGDOCK    READEABFDP01R                 92
B2   C           *IN92     IFEQ *OFF
B3   C           QASKJY    IFEQ 'D'
     C           QASKHZ    ANDLE*DATE
     C                     ITER                            DOCK CODE
E3   C                     ENDIF
B3   C           QAEFHZ    IFGT *DATE
     C                     ITER                            DOCK CODE
E3   C                     ENDIF
      *
     C                     LEAVE
E2   C                     ENDIF
E1   C                     ENDDO
      *
B1   C           *IN92     IFEQ '0'
     C                     GOTO #READ
E1   C                     END
     C*
     C           KEY2      CHAINABFPP101             93
B1   C           *IN93     IFEQ '0'
     C  N89                EXCPTHEADS
     C  N89                SETON                     89
     C   89 OF             EXCPTHEADS
     C   89 OF             SETOF                     OF
     C*
     C* FORD 862 KEY FILE
     C                     MOVELCGDOCK    WKDOCK
     C           KEY4      CHAINABFAL01              95
B2   C           *IN95     IFEQ '0'
     C                     Z-ADDCFCAMT    WKCAMT
B3   C           CFPOR#    IFEQ *BLANK
     C                     MOVE 'YES'     WK862
     C*
     C                     ELSE
     C                     MOVE 'NO '     WK862
E3   C                     END
     C*
     C                     ELSE
     C                     Z-ADD*ZERO     WKCAMT
     C                     MOVE 'NO '     WK862
E2   C                     END
     C*
     C* FORD ADDRESS MASTER
     C           CGDOCK    CHAINABF9P011             96
B2   C           *IN96     IFEQ '0'
     C                     MOVE F9DELY    WKDELY
     C*
     C                     ELSE
     C                     MOVE *BLANK    WKDELY
E2   C                     END
     C           FBQTY1    SUB  WKCAMT    WKAMT
     C*
     C*
     C           KEY3      CHAINFCEPL01              94
B2   C           *IN94     IFEQ '0'
     C                     Z-ADDA2SSYS    WKUNIT           QTY./CONT.
E2   C                     END
     C                     EXCPTDETAIL
E1   C                     END
     C*
     C           #READ     TAG
     C                     READ ABFPP301                 91
E0   C                     END
      *  ----------------------------------------------- *
     C*
TCH47C                     CLOSEQPRINT
     C                     SETON                     98
     C                     MOVEAMES,2     MSG
     C*
     C                     ENDSR
     C**************************************************************************
     OQPRINT  E    2           HEADS
     O                                  131 '.....................'
     O        E 1              HEADS
     O                                  131 '.         .         .'
     O        E 1              HEADS
     O                                    8 'AB#RFQ'
     O                                   89 'TIME'
     O                         WTIME     98 '  :  :  '
     O                                  131 '.         .         .'
     O                         WUSER    119
     O        E 1              HEADS
     O                                   16 'SELECTED DATE:'
     O                         W@DATE    28 '    /  /  '
     O                                   61 'WEEKLY ORDER SHEET'
     O                                   89 'DATE'
     O                         UDATE Y   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O                                  131 '.....................'
     O*
     O        E 2              HEADS
     O                                    7 'PLANT'
     O                                   19 'PART'
     O                                   50 'FORD REQUESTED CUM.'
     O                                   68 'IAF SHIPPED CUM.'
     O                                   80 'ORDER QTY.'
     O                                   92 'QTY./CONT.'
     O*                                 100 'R-CODE'
     O*                                 111 'LINE FEED'
     O                                  122 'LAST SHIP'
     O                                  131 'EDI862'
     O*
     O        E 1              DETAIL
     O                         CGDOCK     7
     O                         WKDELY    13
     O                         WPART1    20
     O                         WPART2    26
     O                         WPART3    29
     O                         FBQTY1    49 ' ,   ,   ,   '
     O                         WKCAMT    67 '   ,   ,   '
     O                         WKAMT N   79
     O                         WKUNIT    91 '  ,   '
     O                         FBSHLD   121 '    /  /  '
     O                         WK862    128
     C**************************************************************************
** MES
DATE DOESN'T EXIST
COMPLETED SUCESSFULLY PRINT WEEKLY ORDER LIST
**
OVRPRTF FILE(QPRINT) OUTQ(LANPRT03)
