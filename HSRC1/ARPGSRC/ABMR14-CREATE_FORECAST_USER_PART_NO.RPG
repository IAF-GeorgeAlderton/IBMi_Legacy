     C                     Z-ADD1         S4NSRD
     C                     Z-ADD0.1       S4NBXD
     C                     ENDIF
      *
     C                     Z-ADDW2YMD3    S4YMD3
     C                     WRITEABMPP211
      *
     CSR         ESB500    ENDSR
      *---------------------------------------------*
      * BPT                                         *
      *---------------------------------------------*
     CSR         #SB700    BEGSR
      *
     C           KEYF40    KLIST
     C                     KFLD           W2SHN1
     C                     KFLD           W2SHN2
     C                     KFLD           W2SHN3
     C                     Z-ADD0         W@NSRY  90
     C                     Z-ADD0         W@NSRD  90
     C                     Z-ADD0         CNT     30
     C           KEYF40    SETLLFCEPL41
     C           KEYF40    READEFCEPL41                  80
     C           *IN80     DOWEQ'0'
     C           F4GSKD    IFEQ 'D'
     C           F4GSDT    ANDLE*DATE
     C                     ELSE
     C                     ADD  1         CNT
     C                     MOVELF4PRT1    K@PRT1
     C                     MOVELF4PRT2    K@PRT2
     C                     MOVELF4PRT3    K@PRT3
     C*****      S4PAS     IFEQ '1'
     C*****                MOVEL'2'       S4PAS
     C*****                ENDIF
     C                     EXSR #SB710
     C                     ENDIF
     C           KEYF40    READEFCEPL41                  80
     C                     ENDDO
      *
     C           CNT       IFNE 0
     C           W@NSRD    MULT 20        S4NSRY
     C                     Z-ADDW@NSRD    S4NSRD
     C                     Z-ADD0         W4NBXD
     C           W2SSYS    IFNE 0
     C           S4NSRD    DIV  W2SSYS    W4NBXD  72
     C                     ENDIF
     C           W4NBXD    ADD  0.09      S4NBXD
     C           S4NBXD    IFEQ 0
