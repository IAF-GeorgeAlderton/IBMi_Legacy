     H            Y.
     F** ABAR02 ************************************************
     F*  ADJUST ABAEP20 BEFORE PROCESSING                      *
     F*  JW1    2023.12.01 ADD PURGE FUNCTION TO ABAR02        *
     F**********************************************************
     FABAEP20 UF  E                    DISK
     FABAEP20GO   E                    DISK
      **********************************************************
     E                    ERR     1  10 20
     I            DS
     I                                        1  10 AEPRTR
     I                                        1   3 @@PRT3
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *****************************************
      *          MAIN ROUTINE                 *
      *****************************************
     C                     TIME           SDATE
      *
     C                     DO   *HIVAL
     C                     READ ABAEP20                  98
     C   98                LEAVE
      *
JW1   * CHECK PURGE?
 .   C                     EXSR #PRG
 .   C           PRGFLG    IFEQ 'Y'
 .   C                     ITER
JW1  C                     ENDIF
      *
     C                     MOVE 'N'       UPDFLG  1
     C                     SELEC
      * ARVIN SANGO
     C           AEPRTR    WHEQ 'ASI  '
     C                     EXSR #ASI
      * OTHERS
     C                     OTHER
     C                     EXSR #OTHER
      *
     C                     ENDSL
      *
     C           UPDFLG    IFEQ 'Y'
     C                     UPDATABAEP201
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *************************************************
      * ADJUST FOR ARVIN SANGO (SET NONY & NUKE)
      *************************************************
     C           #ASI      BEGSR
      *
     C                     SELEC
      *
     C           AEPRTR    WHEQ 'ASI  '                    SANGO, KY
     C           AEFLR1    ANDEQ'MERCED'                   SANGO, MER/CANADA
     C                     MOVEL'0870'    AENONY
     C                     MOVEL'C1  '    AENUKE
     C                     MOVE 'Y'       UPDFLG
      *
     C           AEPRTR    WHEQ 'ASI  '                    SANGO, KY
     C           AEFLR1    ANDEQ'6 '
     C                     MOVEL'0871'    AENONY
     C                     MOVEL'M1  '    AENUKE
     C                     MOVE 'Y'       UPDFLG
      *
     C           AEPRTR    WHEQ 'ASI  '                    SANGO MADISON, IN
     C           AEFLR1    ANDEQ'1 '
     C                     MOVEL'0873'    AENONY
     C                     MOVEL'N2  '    AENUKE
     C                     MOVE 'Y'       UPDFLG
      *
     C           AEPRTR    WHEQ 'ASI  '                    SANGO MADISON, IN
     C           AEFLR1    ANDEQ'11'
     C                     MOVEL'0873'    AENONY
     C                     MOVEL'W1  '    AENUKE
     C                     MOVE 'Y'       UPDFLG
      *                                                    SANGO SERVICE, IN
     C           AEPRTR    WHEQ 'ASI  '
     C           AEFLR1    ANDEQ'15'
     C                     MOVEL'0876'    AENONY
     C                     MOVEL'SP1 '    AENUKE
     C                     MOVE 'Y'       UPDFLG
      *
     C           AEPRTR    WHEQ 'ASI  '                    SANGO LOND/CANADA
     C           AEFLR1    ANDEQ'50'
     C                     MOVEL'0878'    AENONY
     C                     MOVEL'N1  '    AENUKE
     C                     MOVE 'Y'       UPDFLG
      *
     C           AEPRTR    WHEQ 'ASI  '                    SANGO TEXAS
     C           AEFLR1    ANDEQ'18'
     C                     MOVEL'0879'    AENONY
     C                     MOVEL'TX  '    AENUKE
     C                     MOVE 'Y'       UPDFLG
      *
     C           AEPRTR    WHEQ 'ASI  '                    SANGO HENDERSON, TN
     C           AEFLR1    ANDEQ'14'
     C                     MOVEL'0880'    AENONY
     C                     MOVEL'1   '    AENUKE
     C                     MOVE 'Y'       UPDFLG
      *
     C           AEPRTR    WHEQ 'ASI  '                    SANGO, MX
     C           AEFLR1    ANDEQ'20'
     C                     MOVEL'0881'    AENONY
     C                     MOVEL'M1  '    AENUKE
     C                     MOVE 'Y'       UPDFLG
      *                                                    DMAX
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************
      * ADJUST OTHER CUSTOMER
      *************************************************
     C           #OTHER    BEGSR
      *
     C                     SELEC
     C           AEFLR1    WHEQ 'DMAX'                     DMAX
     C                     MOVEL'0590'    AENONY
     C                     MOVE 'Y'       UPDFLG
      *
     C           AEFLR1    WHEQ 'SIA'                      SUBARU
     C                     MOVEL'0437'    AENONY
     C                     MOVE 'Y'       UPDFLG
      *
JW   C           AETOKU    WHEQ '3953'                     HINO
     C                     MOVE *BLANK    AESBAN
     C                     MOVE 'Y'       UPDFLG
      *
JW   C           AETOKU    WHEQ '0479'                     AISIN-TP1
     C                     MOVEL'AT  '    AENUKE
     C                     MOVE 'Y'       UPDFLG
      *
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************
      * PURGE INVALID DATA
      *************************************************
     C           #PRG      BEGSR
      *
     C                     MOVE 'N'       PRGFLG  1
      *
      * UPDATE FLAG
     C           AEUPID    IFNE ' '
     C                     MOVELERR,6     AEPGRS           AEUPID<>' ' UPDATED!
     C                     EXSR #PURGE
     C                     GOTO XPRG
     C                     ENDIF
      *
      * PURGE INVALID EDI CUSTOMER
     C           AENONY    IFEQ '0465'                     ADVICS
     C           AETOKU    OREQ 'PMC '                     HONDA PMC
     C           AEPRTR    OREQ 'TMIBT'
     C           AEPRTR    OREQ 'TMIEL'
     C           AEPRTR    OREQ 'TMIHB'
     C           AEPRTR    OREQ 'TMIMO'
     C           AEPRTR    OREQ 'TMINV'
     C           AEPRTR    OREQ 'TMITX'
     C           AEPRTR    OREQ 'ATS  '
     C           AEPRTR    OREQ 'TABCTEST'
     C           AEPRTR    OREQ 'TBATISA'
     C                     MOVELERR,3     AEPGRS           NOT ALLOW EDI
     C                     EXSR #PURGE
     C                     GOTO XPRG
     C                     ENDIF
      *
      * PURGE TOYOTETSU
     C           AENONY    IFEQ '3511'                     TTTX
     C           AENONY    OREQ '3512'                     TTCA
     C           AENONY    OREQ '3550'                     TTMA
     C           AENONY    OREQ '3556'                     TTAI
     C           AENONY    OREQ '4022'                     YKTA
     C           AEESID    IFEQ 'C'
     C                     MOVELERR,4     AEPGRS           AEESID=C (FC ID)
     C                     EXSR #PURGE
     C                     GOTO XPRG
     C                     ENDIF
     C                     ENDIF
      *
      * PURGE TBA
     C           AEPRTR    IFEQ 'TBA '
     C           AEORID    ANDNE'D'
     C                     MOVELERR,5     AEPGRS           AEORID<>"D"
     C                     EXSR #PURGE
     C                     GOTO XPRG
     C                     ENDIF
      *
      * SRG
     C           @@PRT3    IFEQ 'SRG'
     C           AEORID    ANDNE'D'
     C                     MOVELERR,5     AEPGRS           AEORID<>"D"
     C                     EXSR #PURGE
     C                     GOTO XPRG
     C                     ENDIF
      *
      * PURGE IF RCV_DATE >= SHP_DATE
     C           AERCVT    IFGE AEDAT1
     C           AEEQTY    ANDEQ0
     C                     MOVELERR,1     AEPGRS           RCV_DATE >= SHP_DATE
     C                     EXSR #PURGE
     C                     GOTO XPRG
     C                     ENDIF
      *
      * PURGE QTY=0
     C           AEEQTY    IFEQ 0
     C                     MOVELERR,2     AEPGRS           QTY=0
     C                     EXSR #PURGE
     C                     GOTO XPRG
     C                     ENDIF
      * SHIP DATE
     C**         WNYMD     IFEQ 0
     C**                   MOVELERR,7     AEPGRS           SHIP DATE = 0
     C**                   EXSR #PURGE
     C**                   GOTO XPRG
     C**                   ENDIF
      *
     C           XPRG      ENDSR
      *************************************************
      * PURGE FORECAST DATA
      *************************************************
     C           #PURGE    BEGSR
      *
     C                     Z-ADDTODAY     AEPGDT
     C                     Z-ADDNOW       AEPGTM
     C                     MOVEL#PGM      AEPGPG
     C                     MOVEL#USER     AEPGUS
     C                     WRITEABAE20G1
      *
     C                     DELETABAEP201
      *
     C                     MOVE 'Y'       PRGFLG
      *
     C                     ENDSR
      *************************************************
** ERR (20A) ......>
RCV_DATE >= SHP_DATE 01
QTY=0                02
NOT ALLOW EDI        03
AEESID=C (FC ID)     04
AEORID<>"D"          05
AEUPID<>' ' UPDATED! 06
SHIP DATE = 0        07
                     08
                     09
                     10
