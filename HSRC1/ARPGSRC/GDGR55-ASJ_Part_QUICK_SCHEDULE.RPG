     H            Y/
     F***************************************************
     F*   ASJ PART - QUICK SCHEDULE                     *
     F*                                                 *
     F*                                                 *
     F*   MODIFICAITON:                                 *
     F*      JAN/22/02 CHANGE OUTPUT FIELDS -> INPUT    *
     F*      SAVE RCV INFORMATION TO A FILE             *
     F*      JUN/26/02 SET FROM TOMORROW                *
     F*      AUG/27/02 ADD MANUAL ENTRY COLUMN FOR ORDER*
     F***************************************************
     FGDGPW55 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FFCEPL01 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FGDGPL27 IF  E           K        DISK
     FAB#PL18 IF  E           K        DISK
     FGDGPP60 UF  E           K        DISK                      A
     FQPRINT  O   F     132     OF     PRINTER
      *------------------------------------------------------------
     E                    CMD     1   2 78
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1  140W@TIME
     I                                        1   60W@HMS
     I                                        7  140W@YMD
     I                                        7  100W@YY
     I                                       11  120W@MM
     I                                       13  140W@DD
     I            DS
     I                                        1   60@@MDY
     I                                        1   20@@MM
     I                                        3   40@@DD
     I                                        5   60@@YY
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C           W@ID      CASEQ'02'      #DSP02
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#FCEP    KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C           K#ADGP    KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#ADGX    KLIST
     C                     KFLD           W@YY
     C                     KFLD           W@MM
     C           K#GDGP    KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C           K#GDGX    KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#GDGZ    KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C                     KFLD           K@IVNO
     C           K#GD60    KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C                     KFLD           K@YMD
      *
     C           *LIKE     DEFN IEINVO    K@IVNO
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @@RRN   40
     C                     MOVEL'01'      W@ID    2
     C                     TIME           W@TIME
     C                     Z-ADDW@YY      @@YY
     C                     Z-ADDW@MM      @@MM
     C                     Z-ADDW@DD      @@DD
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     MOVEL'02'      W@ID
     C                     EXSR #SET1
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C           K#FCEP    SETLLFCEPL01
     C           *IN90     DOUEQ*ON
     C           K#FCEP    READEFCEPL01                  90
     C           *IN90     IFEQ *OFF
     C           A2GSKD    IFEQ 'D'
     C                     ITER
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     MOVE *ON       *IN61
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR 2ND SCREEN
      *------------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     MOVE *ON       *IN51
     C                     WRITECTL01
     C                     MOVE *OFF      *IN51
     C                     Z-ADD*ZERO     RRN1
     C                     Z-ADD*ZERO     @@RRN
     C                     MOVE *OFF      *IN80
     C                     MOVE *OFF      *IN05
      *  HEADER INFORMATION
     C                     MOVELA2STRK    D@LOC1
     C                     MOVELA2STRT    D@LOC2
     C                     MOVELA2STRR    D@LOC3
     C                     MOVELA2STRD    D@LOC4
     C                     Z-ADDA2SSYS    D@PPBX
      * NUMBER OF WORKING DAYS
     C                     Z-ADD*ZERO     W@DAYS  20
     C                     Z-ADDW@YY      K@YY
     C                     Z-ADDW@MM      K@MM
     C                     Z-ADDW@DD      K@DD
     C           K#ADGX    SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C           K#ADGX    READEAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDNE'*'
     C                     ADD  1         W@DAYS
     C                     ENDIF
     C                     ENDDO
      * # OF INVENTORY/DAY
     C           W@DAYS    IFNE *ZERO
     C           A2GEKN    DIV  W@DAYS    W@QTY   91
     C                     MVR            W@MVR  115
     C           W@MVR     IFNE *ZERO
     C                     ADD  0.1       W@QTY
     C                     ENDIF
     C                     ELSE
     C                     Z-ADD*ZERO     W@QTY
     C                     ENDIF
      *
     C                     Z-ADDW@QTY     D@IVDY
      * # OF BOX/DAY
     C           A2SSYS    IFNE *ZERO
     C           D@IVDY    DIV  A2SSYS    D@BXDY
     C                     MVR            W@MVR
     C           W@MVR     IFNE *ZERO
     C                     ADD  1         D@BXDY
     C                     ENDIF
     C                     ELSE
     C                     Z-ADD*ZERO     D@BXDY
     C                     ENDIF
      *
     C                     Z-ADDD@STCK    @@STCK  70
     C**                   MOVE *BLANK    @@MORE
     C           K#ADGP    SETGTAGDPL12
     C                     EXSR #SET2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR SUB FILE
      *------------------------------------------------------
     C           #SET2     BEGSR
      *
     C                     Z-ADD@@RRN     RRN1
     C                     CLEARSFL01
      *
     C                     Z-ADD*ZERO     X       30
     C                     DO   *HIVAL
     C                     READ AGDPL12                  80
     C           *IN80     IFEQ *ON
     C                     LEAVE
     C                     ELSE
      *
     C                     CLEARSFL01
      *
     C           F8KAMM    MULT 100       S@DATE
     C                     ADD  F8KADD    S@DATE
     C                     MOVELF8HIRU    S@HLDY
      * INVOICE INF.
     C                     MOVE *BLANK    @@FRST  1
     C                     Z-ADDF8KAYY    K@YY
     C                     Z-ADDF8KAMM    K@MM
     C                     Z-ADDF8KADD    K@DD
      *
     C                     Z-ADDK@YMD     H@DATE
      *
     C           RRN1      IFEQ *ZERO
     C           K#GDGP    SETLLGDGPL27
     C                     ELSE
     C           K#GDGZ    SETLLGDGPL27
     C                     MOVE '*'       @@FRST
     C                     ENDIF
      *
     C                     MOVE *OFF      *IN92
     C           *IN91     DOUEQ*ON
     C           RRN1      IFEQ *ZERO
     C           K#GDGP    READEGDGPL27                  91
     C                     ELSE
     C           K#GDGX    READEGDGPL27                  91
     C                     ENDIF
      *
     C           *IN91     IFEQ *OFF
     C           RRN1      IFEQ *ZERO
     C           IETOYY    IFGT F8KAYY
     C           IETOYM    ORGT F8KAMM
     C           IETOYD    ORGT F8KADD
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVE *ON       *IN92
     C                     MOVELIEINVO    S@IVNO
     C                     MOVELIEINVO    H@IVNO
     C           IEHANY    IFEQ 'S'
     C                     ADD  IESBOX    S@SEA
     C                     ELSE
     C                     ADD  IESBOX    S@AIR
     C                     ENDIF
      * ORDER INF
     C*********  @@FRST    IFEQ *BLANK
     C*********            MOVE '*'       @@FRST  1
     C********             ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
      *** FROM SAVED FILE
     C           K#GD60    CHAINGDGPP60             N91
     C           *IN91     IFEQ *OFF
     C           G6SKJY    ANDEQ*BLANK
     C                     MOVELG6IVNO    H@IVNO
     C                     MOVELG6IVNO    S@IVNO
     C                     Z-ADDG6SEAB    S@SEA
     C                     Z-ADDG6AIRB    S@AIR
     C                     Z-ADDG6SARB    S@SAIR
     C                     MOVELG6RMRK    S@SRMK
     C                     Z-ADDG6AJBX    S@CHBX
     C                     Z-ADDG6AJBX    H@CHBX
     C                     ENDIF
      *
     C*******    *IN05     IFEQ *OFF
     C                     EXSR #ORD
     C*********            ELSE
     C           S@HLDY    IFEQ *BLANK
     C           *IN05     ANDEQ*ON
     C           S@ORD     ANDEQ*ZERO
     C           S@CHBX    ANDEQ*ZERO
     C                     ADD  D@BXDY    S@ORD
     C                     ENDIF
     C*********            ENDIF
      *
     C                     Z-ADD@@STCK    S@STK1
     C           S@STK1    ADD  S@AIR     S@STK2
     C                     ADD  S@SEA     S@STK2
     C                     ADD  S@SAIR    S@STK2
     C                     SUB  S@ORD     S@STK2
     C                     SUB  S@CHBX    S@STK2
     C                     Z-ADDS@STK2    @@STCK
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ADD  1         X
     C           X         IFEQ 15
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADDRRN1      #RCNO1
     C                     Z-ADDRRN1      @@RRN
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET ORDER INFORMATION
      *------------------------------------------------------
     C           #ORD      BEGSR
      *
     C                     Z-ADD*ZERO     @@QTY  110
     C           K#GDGX    SETLLAB#PL18
     C           *IN93     DOUEQ*ON
     C           K#GDGX    READEAB#PL18                  93
     C           *IN93     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C                     ADD  BASRYO    @@QTY
     C                     ENDIF
     C                     ENDDO
      *
     C           A2SSYS    IFNE *ZERO
     C           @@QTY     DIV  A2SSYS    S@ORD
     C                     MVR            W@MVR
     C           W@MVR     IFNE *ZERO
     C                     ADD  1         S@ORD
     C                     ENDIF
     C                     ELSE
     C                     Z-ADD@@QTY     S@ORD
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #DSP02    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN52
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN52
      *
     C                     Z-ADD@@REC     #RCNO1
     C                     SELEC
      * F3
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * F12
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
      * F5
     C           *INKE     WHEQ *ON
     C                     EXSR #SIM
      * F11
     C           *INKK     WHEQ *ON
     C                     EXSR #CHK2
     C                     EXSR #PRT
     C                     MOVEL'01'      W@ID
      * ROLL UP
     C           *IN38     WHEQ *ON
     C           *IN80     ANDEQ*OFF
     C                     EXSR #CHK2
     C                     EXSR #SET2
     C                     OTHER
     C                     EXSR #CHK2
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  SIMULATION
      *------------------------------------------------------
     C           #SIM      BEGSR
      *
     C                     Z-ADD*ZERO     WRRN    40
     C                     Z-ADDD@STCK    WWSTK   70
     C*******              MOVE *OFF      *IN05
     C                     DO   *HIVAL
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVEA'00000000'*IN,60
      *
     C           S@AIR     IFNE *ZERO
     C           S@SAIR    ORNE *ZERO
     C           S@SEA     ORNE *ZERO
     C           S@IVNO    IFEQ *BLANK
     C                     MOVE *ON       *IN62
     C                     ENDIF
     C                     ENDIF
      *
     C           S@IVNO    IFNE *BLANK
     C           S@AIR     ANDEQ*ZERO
     C           S@SAIR    ANDEQ*ZERO
     C           S@SEA     ANDEQ*ZERO
     C                     MOVE *ON       *IN63
     C                     ENDIF
      *
     C                     Z-ADDH@DATE    K@YMD
     C           H@IVNO    IFNE *BLANK
     C           S@IVNO    ORNE *BLANK
     C           S@CHBX    ORNE *ZERO
     C           H@CHBX    ORNE *ZERO
     C           K#GD60    CHAINGDGPP60              91
     C           *IN91     IFEQ *ON
     C                     CLEARGDGPP601
     C                     ENDIF
      * DELETE
     C*****      H@IVNO    IFNE *BLANK
     C****       S@IVNO    ANDEQ*BLANK
     C**                   MOVE 'D'       G6SKJY
     C**                   Z-ADD*DATE     G6SKDT
     C**                   ELSE
      * UPDATE/WRITE
     C                     MOVE S@IVNO    G6IVNO
     C                     MOVE D@PRT1    G6HIN1
     C                     MOVE D@PRT2    G6HIN2
     C                     MOVE D@PRT3    G6HIN3
     C                     Z-ADDH@DATE    G6RCDT
      *
     C           S@SAIR    IFNE *ZERO
     C                     MOVE 'P'       G6CARR
     C                     Z-ADDS@SAIR    G6SARB
     C                     ENDIF
     C           S@AIR     IFNE *ZERO
     C                     MOVE 'A'       G6CARR
     C                     Z-ADDS@AIR     G6AIRB
     C                     ENDIF
     C           S@SEA     IFNE *ZERO
     C                     MOVE 'S'       G6CARR
     C                     Z-ADDS@SEA     G6SEAB
     C                     ENDIF
      *
     C           S@AIR     ADD  S@SAIR    G6RCBX
     C                     ADD  S@SEA     G6RCBX
     C           G6RCBX    MULT A2SSYS    G6RCQT
     C           S@SAIR    MULT A2SSYS    G6SARQ
     C           S@AIR     MULT A2SSYS    G6AIRQ
     C           S@SEA     MULT A2SSYS    G6SEAQ
      *
     C                     MOVELS@SRMK    G6RMRK
     C**********           ENDIF
      *
     C                     Z-ADDS@CHBX    G6AJBX
      *
     C                     Z-ADD*DATE     G6KODT
     C                     TIME           G6KOTM
     C                     MOVEL#USER     G6KOME
     C  N91                UPDATGDGPP601
     C   91                WRITEGDGPP601
     C                     ENDIF
      *
     C           S@SIML    IFNE *BLANK
     C                     MOVE *ON       *IN05
     C                     MOVE *BLANK    S@SIML
     C                     ENDIF
      *
     C           *IN05     IFEQ *OFF
     C                     Z-ADDS@STK2    WWSTK
     C                     UPDATSFL01
     C                     ITER
     C                     ENDIF
      *
     C           S@HLDY    IFEQ *BLANK
     C           S@ORD     ANDEQ*ZERO
     C           S@CHBX    ANDEQ*ZERO
     C                     Z-ADDD@BXDY    S@ORD
     C                     ENDIF
     C                     Z-ADDWWSTK     S@STK1
     C           S@STK1    ADD  S@AIR     S@STK2
     C                     ADD  S@SEA     S@STK2
     C                     ADD  S@SAIR    S@STK2
     C                     SUB  S@ORD     S@STK2
     C                     SUB  S@CHBX    S@STK2
     C                     Z-ADDS@STK2    WWSTK
     C                     UPDATSFL01
      *
     C                     ENDDO
      *
     C                     Z-ADDWWSTK     @@STCK
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     Z-ADD*ZERO     WRRN    40
     C                     Z-ADDD@STCK    WWSTK   70
     C*********            MOVE *OFF      *IN05
     C                     DO   *HIVAL
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
     C                     MOVEA'00000000'*IN,60
      *
     C           S@AIR     IFNE *ZERO
     C           S@SAIR    ORNE *ZERO
     C           S@SEA     ORNE *ZERO
     C           S@IVNO    IFEQ *BLANK
     C                     MOVE *ON       *IN62
     C                     ENDIF
     C                     ENDIF
      *
     C           S@IVNO    IFNE *BLANK
     C           S@AIR     ANDEQ*ZERO
     C           S@SAIR    ANDEQ*ZERO
     C           S@SEA     ANDEQ*ZERO
     C                     MOVE *ON       *IN63
     C                     ENDIF
      *
     C                     Z-ADDWWSTK     S@STK1
     C           S@STK1    ADD  S@AIR     S@STK2
     C                     ADD  S@SEA     S@STK2
     C                     ADD  S@SAIR    S@STK2
     C                     SUB  S@ORD     S@STK2
     C                     SUB  S@CHBX    S@STK2
     C                     Z-ADDS@STK2    WWSTK
     C                     UPDATSFL01
      *
     C                     ENDDO
      *
     C                     Z-ADDWWSTK     @@STCK
      *
     C                     ENDSR
      *------------------------------------------------------
      *  OUTPUT
      *------------------------------------------------------
     C           #PRT      BEGSR
      *
     C                     MOVE *ALL'-'   @@LINE 66
     C                     Z-ADD*ZERO     WRRN    40
     C                     EXCPT@HED
      *
     C                     DO   *HIVAL
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C           *INOF     IFEQ *ON
     C                     EXCPT@HED
     C                     ENDIF
      *
     C                     EXCPT@DTL
      *
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                         @@MDY Y   59
     O                                   62 'P.'
     O                         PAGE  Z   66
     O        E   02           @HED
     O                                   40 'ASJ PART SCHEDULE'
     O                         W@HMS     59 '  :  :  '
     O        E   04           @HED
     O                                    6 'PART#:'
     O                         D@PRT1    12
     O                         D@PRT2    18
     O                         D@PRT3    21
     O                                   35 'PCS/BOX:'
     O                         D@PPBX4   42
     O                                   55 'LOCATION:'
     O                         D@LOC1    57
     O                         D@LOC2    60
     O                         D@LOC3    63
     O                         D@LOC4    65
     O        E   05           @HED
     O                                   10 'BOXES/DAY:'
     O                         D@BXDY1   19
     O                                   40 'INVENTORY/DAY:'
     O                         D@IVDY1   51
     O        E   06           @HED
     O                                   35 'SPECIAL'
     O                                   48 'USUAL'
     O        E   07           @HED
     O                                    4 'DATE'
     O                                   16 'INVOICE#'
     O                                   22 'STOCK'
     O                                   30 'AIR'
     O                                   37 'RMRK'
     O                                   44 'AIR'
     O                                   51 'SEA'
     O                                   58 'ORDER'
     O                                   66 'CHANGED'
     O                                   74 'BALANCE'
     O        E   08           @HED
     O                         @@LINE    66
     O        E 1              @DTL
     O                         S@DATEY    5
     O                         S@HLDY     7
     O                         S@IVNO    15
     O                         S@STK1J   23
     O                         S@SAIR1   30
     O                         S@SRMK    37
     O                         S@AIR 1   44
     O                         S@SEA 1   51
     O                         S@ORD 1   58
     O                         S@CHBX1   66
     O                         S@STK2J   75
**  CMD
F3: EXIT
F3: EXIT   F5: SIMULATION/SAVE RCV INF.   F11: PRINT  F12: PREV
