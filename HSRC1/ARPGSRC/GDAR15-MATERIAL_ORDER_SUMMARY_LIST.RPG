      *** GDAR15 *****************************************************
      *    PRINT OF ORDER TOTAL LIST (MATERIAL)
      *                  TCH              FEB/06/03
      *
      *
      ****************************************************************
     H            Y/                                    1
     FGDAPL10 IP  E           K        DISK
     FIZAPL01 IF  E           K        DISK
     FIZBPL01 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     I****************************************************************
     I            DS
     I                                        1   60@@TIME
     I                                        1   40@TIME
     I            DS
     I                                        1   80ZCSKHZ
     I                                        1   40ZCSKYY
     I                                        5   60ZCSKMM
     I                                        7   80ZCSKDD
     I            DS
     I                                        1   80ZDSKHZ
     I                                        1   40ZDSKYY
     I                                        5   60ZDSKMM
     I                                        7   80ZDSKDD
     I            DS
     I                                        1   80ZCUKHZ
     I                                        1   40ZCUKYY
     I                                        5   60ZCUKMM
     I                                        7   80ZCUKDD
     I            DS
     I                                        1   80ZCSTHZ
     I                                        1   40ZCSTYY
     I                                        5   60ZCSTMM
     I                                        7   80ZCSTDD
     I            DS
     I                                        1   80ZDUKHZ
     I                                        1   40ZDUKYY
     I                                        5   60ZDUKMM
     I                                        7   80ZDUKDD
     I            DS
     I                                        1   80ZDSTHZ
     I                                        1   40ZDSTYY
     I                                        5   60ZDSTMM
     I                                        7   80ZDSTDD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-------------------------------------------------------
     C           K#KEY     KLIST
     C                     KFLD           IBZAIS
     C                     KFLD           IBZAIK
      *-------------------------------------------------------
     C           *IN10     IFEQ '0'
     C                     SETON                     10
     C                     TIME           @@TIME
     C                     EXCPTHD
     C                     END
     C*
     C           IBSKJY    IFEQ *BLANK
     C*
     C                     MOVE *BLANK    @LOC1   1
     C                     MOVE *BLANK    @LOC2   2
     C                     MOVE *BLANK    @LOC3   2
     C                     MOVE *BLANK    @LOC4   1
     C*
     C                     SELEC
     C           IBPTCD    WHEQ 'W'
     C           K#KEY     SETGTIZAPL01
     C           *IN90     DOUEQ*ON
     C                     SETOF                     90
     C           K#KEY     REDPEIZAPL011                 90
      *
     C           *IN90     IFEQ '0'
     C           ZCSKJY    ANDEQ*BLANK
     C           ZCUKHZ    ANDLE*DATE
     C           ZCSTHZ    ANDGT*DATE
     C                     MOVELZCADR1    @LOC1
     C                     MOVELZCADR2    @LOC2
     C                     MOVELZCADR3    @LOC3
     C                     MOVELZCADR4    @LOC4
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *------------*
      * ROD KANBAN *
      *------------*
     C           IBPTCD    WHEQ 'R'
     C           K#KEY     SETGTIZBPL01
     C           *IN90     DOUEQ*ON
     C           K#KEY     REDPEIZBPL011                 90
      *
     C           *IN90     IFEQ '0'
     C           ZDSKJY    ANDEQ*BLANK
     C           ZDUKHZ    ANDLE*DATE
     C           ZDSTHZ    ANDGT*DATE
     C                     MOVELZDADR1    @LOC1
     C                     MOVELZDADR2    @LOC2
     C                     MOVELZDADR3    @LOC3
     C                     MOVELZDADR4    @LOC4
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSL
      *
     C* TOTAL LIST PRINTING
     C                     ADD  IBMAIS    BOXALL  70
     C                     EXCPTME
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     END
     C*
     C                     ENDIF
     C*
     CLR                   EXCPTTO
     OQPRINT  E  102           HD
     O                                  131 '+-------------------+'
     O        E  1             HD
     O                                  131 '|         |         |'
     O        E  1             HD
     O                                   89 'TIME'
     O                         @@TIME    98 '  .  .  '
     O                                  131 '|         |         |'
     O        E  2             HD
     O                         #PGM       8
     O                                   54 '**  KANBAN INPUT DATA'
     O                                   68 'TOTAL LIST **'
     O                                   80 '(MATERIAL)'
     O                                   89 'DATE'
     O                         UDATE Y   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O                                  131 '+-------------------+'
     O        E  2             HD
     O                                    8 'LOCATION'
     O                                   26 'MATERIAL#'
     O                                   55 '# OF KANBANS'
     O        E  1             ME
     O                      N90@LOC1      1
     O                      N90           2 '-'
     O                      N90@LOC2      4
     O                      N90           5 '-'
     O                      N90@LOC3      7
     O                      N90           8 '-'
     O                      N90@LOC4      9
     O                         IBPTCD    17
     O                         IBZAIS    34
     O                         IBZAIK1   41
     O                         IBMAISJ   53
     O        E 11             TO
     O                                   40 '*** TOTAL'
     O                         BOXALLJ   53
