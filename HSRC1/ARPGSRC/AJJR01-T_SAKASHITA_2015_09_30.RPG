     FAAFPP01 IP  E                    DISK
     FAJJWP01 O   F     512            DISK
      ********
     I            DS
     I                                        1   80A3STDT
     I                                        1   40A3STYY
     I                                        5   60A3STMM
     I                                        7   80A3STDD
     I            DS
     I                                        1   80A3UKDT
     I                                        1   40A3UKYY
     I                                        5   60A3UKMM
     I                                        7   80A3UKDD
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20WTIJJ
     I                                        3   40WTIHH
     I                                        5   60WTIBB
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     C           A3SKJY    IFEQ 'D'
     C                     GOTO @END
     C                     END
     C           A3ATOB    IFEQ 0111
     C                     GOTO @END
     C                     END
      *失効日の拡大
     C           A3STYY    IFEQ 2031
     C                     Z-ADD2013      A3STYY
     C                     END
     C                     MOVE A3STDT    PRDAT
     C           A3STMM    IFNE 99
     C                     MOVE A3STDT    PDATE   8
     C                     MOVE '+'       PPORM   1        + OR -
     C                     MOVE '0005'    PDAYS   4
     C                     MOVE *BLANK    PRDAT   8
     C                     MOVE *BLANK    PRTN    1
     C                     CALL 'DATR1A'
     C                     PARM           PDATE   8
     C                     PARM           PPORM   1        + OR -
     C                     PARM           PDAYS   4
     C                     PARM           PRDAT   8
     C                     PARM           PRTN    1
     C                     END
     C                     MOVE PRDAT     W@STDT  80
      *有効日の拡大
     C           A3UKYY    IFEQ 2031
     C                     Z-ADD2013      A3UKYY
     C                     END
     C                     MOVE A3UKDT    PDATE   8
     C                     MOVE '-'       PPORM   1        + OR -
     C                     MOVE '0005'    PDAYS   4
     C                     MOVE *BLANK    PRDAT   8
     C                     MOVE *BLANK    PRTN    1
     C                     CALL 'DATR1A'
     C                     PARM           PDATE   8
     C                     PARM           PPORM   1        + OR -
     C                     PARM           PDAYS   4
     C                     PARM           PRDAT   8
     C                     PARM           PRTN    1
     C                     MOVE PRDAT     W@UKDT  80
      *
     C                     TIME           WTIME
      *
     C           WTIHZ     IFGE W@UKDT
     C           WTIHZ     ANDLEW@STDT
     C                     ELSE
     C                     GOTO @END
     C                     END
      *
     C                     Z-ADD0         J1TANJ  73
     C                     CALL 'AJUR19'
     C                     PARM           A31HB5
     C                     PARM           A32HB5
     C                     PARM           A33HB2
     C                     PARM           J1TANJ
      *
     C                     EXCPTODAT
      *
     C           @END      TAG
      *
     OAJJWP01 E                ODAT
     O*                        D@KBN      1
     O                                    1 'C'
     O                         A3ZETI     5
     O                         A31HB5    10
     O                         A32HB5    15
     O                         A33HB2    17
     O                         A3SSYS    22
     O                         A3SSYT    23
      *
     O                         A3UKYY    33
     O                         A3UKMM    35
     O                         A3UKDD    37
      *
     O                         J1TANJ    44
      *
     O                         A3ATK1   112
     O                         A3ATK2   114
     O                         A3ATK3   116
     O                         A3ATK4   117
