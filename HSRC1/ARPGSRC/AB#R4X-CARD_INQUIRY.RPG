     FAB#PW4X CF  E                    WORKSTN
     F                                        RRN1  KSFILE WSFL1
      *----------------------------------------------------
     E                    DAT     1   3 20
      *----------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           P@CODE  4
      *
     C                     MOVE *ON       *IN56
     C                     WRITEWCTL1
     C                     MOVE *OFF      *IN56
     C                     Z-ADD*ZERO     RRN1    40
     C                     CLEARWSFL1
     C           1         DO   3         X       30
     C                     MOVELDAT,X     S@CRD
     C                     MOVE DAT,X     S@CRNM
     C                     ADD  1         RRN1
     C                     WRITEWSFL1
     C                     ENDDO
      *
     C           *INKL     DOWEQ*OFF
     C                     WRITEW01
     C                     WRITEW999
     C                     MOVE *ON       *IN55
     C                     EXFMTWCTL1
     C                     MOVE *OFF      *IN55
      *
     C           *INKL     IFEQ *ON
     C                     LEAVE
     C                     ELSE
     C                     EXSR #CHK
     C           *IN99     IFEQ *OFF
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *--------------------------------------------
     C           #CHK      BEGSR
      *
     C                     MOVE *ON       *IN99
     C           1         DO   4         X
     C           X         CHAINWSFL1                90
     C           *IN90     IFEQ *OFF
     C           S@OPTN    IFNE *BLANK
     C                     MOVELS@CRD     P@CODE
     C                     MOVE *OFF      *IN99
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
