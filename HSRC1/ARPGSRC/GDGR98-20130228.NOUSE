     H            Y/                                    1
     FGDKPP01 UP  E           K        DISK
     FAAPTL01 IF  E           K        DISK
     FAKBPL05 IF  E           K        DISK
     FAANPL06 IF  E           K        DISK
     I            DS
     I                                        1   80L7SKHZ
     I                                        1   40L7SKYY
     I                                        5   60L7SKMM
     I                                        7   80L7SKDD
     I            DS
     I                                        1   80L7UKHZ
     I                                        1   40L7UKYY
     I                                        5   60L7UKMM
     I                                        7   80L7UKDD
     I            DS
     I                                        1   80L7STHZ
     I                                        1   40L7STYY
     I                                        5   60L7STMM
     I                                        7   80L7STDD
     I            DS
     I                                        1  20 ISHIN
     I                                        1   5 ISHIN1
     I                                        6  10 ISHIN2
     I                                       11  12 ISHIN3
     C                     MOVEL*BLANK    WSEIH   1
     C                     EXSR #TYPE
     C                     MOVELWSEIH     ISTYPE
      *
     C                     UPDATGDKPP011
     C****************************************************************
     C           #TYPE     BEGSR                                     *
     C****************************************************************
     C*<KANBAN TYPE>
     C           KEY4      KLIST
     C                     KFLD           ISHIN1
     C                     KFLD           ISHIN2
     C                     KFLD           ISHIN3
      *
     C                     SETOF                     10
     C           KEY4      SETLLAAPTL011
     C                     DO   *HIVAL
     C           ##1       TAG
     C           KEY4      READEAAPTL011                 10
     C           *IN10     IFEQ '0'
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    IFLE *DATE
     C                     GOTO ##1
     C                     END
     C                     END
     C           L5UKHZ    IFGT *DATE
     C                     GOTO ##1
     C                     END
     C           L5STHZ    IFLT *DATE
     C                     GOTO ##1
     C                     END
     C                     MOVE '0'       WSEIH
     C                     GOTO ETYPE
     C                     END
     C  N10                ENDDO
      *
      *
     C                     SETOF                     10
     C           KEY4      SETLLAKBPL051                 10
     C                     DO   *HIVAL
     C           ##2       TAG
     C           KEY4      READEAKBPL051                 10
     C           *IN10     IFEQ '0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    IFLE *DATE
     C                     GOTO ##2
     C                     END
     C                     END
     C           L1UKHZ    IFGT *DATE
     C                     GOTO ##2
     C                     END
     C           L1STHZ    IFLT *DATE
     C                     GOTO ##2
     C                     END
     C                     MOVE '3'       WSEIH
     C                     GOTO ETYPE
     C                     END
     C  N10                ENDDO
      *
      *
     C                     SETOF                     10
     C           KEY4      SETLLAANPL061                 10
     C                     DO   *HIVAL
     C           ##3       TAG
     C           KEY4      READEAANPL061                 10
     C           *IN10     IFEQ '0'
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    IFLE *DATE
     C                     GOTO ##3
     C                     END
     C                     END
     C           L7UKHZ    IFGT *DATE
     C                     GOTO ##3
     C                     END
     C           L7STHZ    IFLT *DATE
     C                     GOTO ##3
     C                     END
     C                     MOVE '6'       WSEIH
     C                     GOTO ETYPE
     C                     END
     C  N10                ENDDO
     C*
     C           ETYPE     ENDSR
