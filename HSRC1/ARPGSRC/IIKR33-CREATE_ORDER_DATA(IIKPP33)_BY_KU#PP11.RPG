     C                     KFLD           BAMHN3
     C                     MOVELBAODRN    KAODRN
     C                     MOVEL*BLANK    BAKU#
     C                     Z-ADD0         BAKU#C
     C                     Z-ADD0         BAKU#S
     C           KEYSHN    SETLLKU#PL131
     C           KEYSHN    READEKU#PL131                 22
     C           *IN22     DOWEQ'0'
     C           KQSKJY    IFEQ 'D'
     C           KQSKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'1'       BAKU#
     C                     ADD  1         BAKU#C
