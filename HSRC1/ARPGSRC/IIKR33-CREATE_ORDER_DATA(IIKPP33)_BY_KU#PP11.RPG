     C           *ENTRY    PLIST
     C                     PARM           P1NOH1  8
     C                     PARM           P1NOH2  8
     C                     MOVE P1NOH1    D1NOH1
     C                     MOVE P1NOH2    D1NOH2
      *
     C           D1NOH2    IFEQ 0
     C                     Z-ADD*HIVAL    D1NOH2
     C                     ENDIF
     C                     Z-ADDD1NOY1    KKNOYY  40
     C                     Z-ADDD1NOM1    KKNOMM  20
     C                     Z-ADDD1NOD1    KKNODD  20
     C           KEYME     KLIST
     C                     KFLD           KKNOYY  40
     C                     KFLD           KKNOMM  20
     C                     KFLD           KKNODD  20
     C           KEYME     SETLLAB#PL1N1
     C                     READ AB#PL1N1                 80
     C           *IN80     DOWEQ'0'
     C           BANOHZ    ANDLED1NOH2
     C           BASKJY    IFEQ 'D'
     C**         BASKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #SB100
     C                     ENDIF
     C                     READ AB#PL1N1                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------*
      *                                   *
      *-----------------------------------*
     CSR         #SB100    BEGSR
      *
     C           KEYSHN    KLIST
     C                     KFLD           BANOYY
     C                     KFLD           BANOMM
