      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#KEY1    KLIST
     C                     KFLD           K@HIN1  5
     C                     KFLD           K@HIN2  5
     C                     KFLD           K@HIN3  2
     C                     KFLD           W@YY
     C                     KFLD           W@MM
     C                     KFLD           W@DD
     C           K#KEY2    KLIST
     C                     KFLD           K@HIN1  5
     C                     KFLD           K@HIN2  5
     C                     KFLD           K@HIN3  2
      *
     C           K#BZ      KLIST
     C                     KFLD           K@MKKB  2
     C                     KFLD           K@HIN1  5
     C                     KFLD           K@HIN2  5
     C                     KFLD           K@HIN3  2
     C                     KFLD           W@YY
     C                     KFLD           W@MM
     C                     KFLD           W@DD
     C           K#BZ1     KLIST
     C                     KFLD           K@MKKB  2
     C                     KFLD           K@HIN1  5
     C                     KFLD           K@HIN2  5
     C                     KFLD           K@HIN3  2
      *
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      *
     C                     MOVEL'01'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVELKEY,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
     C                     SELEC
      * F1
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * F5
     C                     OTHER
     C                     EXSR #CHK
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #WRT
     C                     MOVEL'99'      W@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK      BEGSR
      *
     C                     MOVEA'000000'  *IN,60
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    D@MSG
     C           D@TO      IFLT D@FRM
     C                     SETON                     6199
     C                     ENDIF
      *
     C           D@TO      IFEQ *ZERO
     C                     SETON                     6199
     C                     ENDIF
      *
     C           D@OPTN    IFLT '1'
     C           D@OPTN    ORGT '3'
     C                     SETON                     6299
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   WRITE
      *------------------------------------------------------
     C           #WRT      BEGSR
      *
     C                     MOVELCMD,1     P@CMD
     C                     Z-ADD70        P@LEN
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN AJSWP27
      * HEADER
     C                     Z-ADDD@FRM     W@YMD
     C                     Z-ADDW@YY      @@YY
     C                     Z-ADDW@MM      @@MM
     C                     Z-ADDW@DD      @@DD
     C                     MOVEL@@DAT     @DAT1  12
      *
     C                     Z-ADDD@TO      W@YMD
     C                     Z-ADDW@YY      @@YY
     C                     Z-ADDW@MM      @@MM
     C                     Z-ADDW@DD      @@DD
     C                     MOVEL@@DAT     @DAT2  12
      *
     C                     CLEARAJSWP271
     C           @DAT1     CAT  '-':1     JWTERM    P
     C           JWTERM    CAT  @DAT2:1   JWTERM    P
      *
     C                     SELEC
     C           D@OPTN    WHEQ '1'
     C                     EXSR #DCR
     C           D@OPTN    WHEQ '2'
     C                     EXSR #BZ
     C           D@OPTN    WHEQ '3'
     C                     EXSR #DCR
     C                     EXSR #BZ
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   DACRO
      *------------------------------------------------------
     C           #DCR      BEGSR
      *
     C           *LOVAL    SETLLAJSPL64
     C           *IN90     DOUEQ*ON
     C                     READ AJSPL64                  90
     C           *IN90     IFEQ *OFF
     C           J6SKJY    ANDEQ*BLANK
     C                     MOVE J6HIN1    K@HIN1
     C                     MOVE J6HIN2    K@HIN2
     C                     MOVE J6HIN3    K@HIN3
     C                     Z-ADDD@FRM     W@YMD
     C                     Z-ADD*ZERO     QTY
     C                     MOVE *BLANK    MCN
      * PLATING MACHINE
     C           K#KEY2    CHAINAAMPL11              91
     C           *IN91     IFEQ *OFF
     C           CKSKJY    ANDEQ*BLANK
     C           1         DO   15        A       20
     C           KO,A      IFEQ 'BZ '
     C           KO,A      OREQ 'DCF'
     C                     Z-ADDCHG,A     DAT10
     C                     MOVE KB,A      MCN,1
     C                     ENDIF
      *
     C           ORC,A     IFEQ 'DCF'
     C           ORC,A     OREQ 'BZ '
     C                     MOVE OCN,A     MCN,2
     C                     ENDIF
      *
     C                     ENDDO
     C                     ENDIF
      *
     C           MCN,2     IFNE *BLANK
     C           MCN,2     ANDNEMCN,1
     C                     MOVE '1'       @@CHG   1
     C                     ELSE
     C                     MOVE *BLANK    @@CHG
     C                     ENDIF
      *
     C           K#KEY1    SETLLAJSPL64
     C           *IN95     DOUEQ*ON
     C           K#KEY2    READEAJSPL64                  95
     C           *IN95     IFEQ *OFF
     C           J6SKJY    ANDEQ*BLANK
     C           J6YMD     IFGT D@TO
     C                     LEAVE
     C                     ENDIF
      *
     C           @@CHG     IFEQ *BLANK
     C                     ADD  4         QTY,1
     C                     ELSE
     C           J6YMD     IFLT DAT8
     C                     ADD  4         QTY,2
     C                     ELSE
     C                     ADD  4         QTY,1
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           QTY,1     IFGT *ZERO
     C           QTY,2     ORGT *ZERO
     C                     EXSR #WRT1
     C                     ENDIF
      *
     C           K#KEY2    SETGTAJSPL64
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   WRT1
      *------------------------------------------------------
     C           #WRT1     BEGSR
      *
     C           K#KEY2    CHAINFCEPL01              91
     C                     MOVE K@HIN1    JWPRT1
     C                     MOVE K@HIN2    JWPRT2
     C                     MOVE K@HIN3    JWPRT3
     C                     MOVELMCN,1     JWMCN     P
     C                     Z-ADDQTY,1     JWBOX
     C                     Z-ADDA2SSYS    JWQTYB
     C           JWQTYB    MULT QTY,1     JWQTY
     C                     WRITEAJSWP271
      *
     C           @@CHG     IFEQ '1'
     C           QTY,2     ANDNE*ZERO
     C                     MOVELMCN,2     JWMCN     P
     C                     Z-ADDQTY,2     JWBOX
     C           JWQTYB    MULT QTY,2     JWQTY
     C                     WRITEAJSWP271
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   BZ
      *------------------------------------------------------
     C           #BZ       BEGSR
      *
     C           *LOVAL    SETLLAJSPL27
     C           *IN90     DOUEQ*ON
     C                     READ AJSPL27                  90
     C           *IN90     IFEQ *OFF
     C           J2SKJY    ANDEQ*BLANK
     C                     MOVE J2HIN1    K@HIN1
     C                     MOVE J2HIN2    K@HIN2
     C                     MOVE J2HIN3    K@HIN3
     C                     MOVE J2MKKB    K@MKKB
     C                     Z-ADDD@FRM     W@YMD
     C                     Z-ADD*ZERO     JWBOX
      *
     C           K#BZ      SETLLAJSPL27
     C           *IN95     DOUEQ*ON
     C           K#BZ1     READEAJSPL27                  95
     C           *IN95     IFEQ *OFF
     C           J2SKJY    ANDEQ*BLANK
      *
     C           J2YMD     IFGT D@TO
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  4         JWBOX
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           JWBOX     IFGT *ZERO
     C                     EXSR #WRT2
     C                     ENDIF
      *
     C           K#BZ1     SETGTAJSPL27
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   WRT2
      *------------------------------------------------------
     C           #WRT2     BEGSR
      *
     C           K#KEY2    CHAINFCEPL01              91
     C                     MOVE K@HIN1    JWPRT1
     C                     MOVE K@HIN2    JWPRT2
     C                     MOVE K@HIN3    JWPRT3
     C                     MOVELK@MKKB    JWMCN     P
     C                     Z-ADDA2SSYS    JWQTYB
     C           JWQTYB    MULT JWBOX     JWQTY
     C                     WRITEAJSWP271
      *
     C                     ENDSR
      *
**  KEY
 F1:END      F5:CREATE
**  CMD
CLRPFM AJSWP27
