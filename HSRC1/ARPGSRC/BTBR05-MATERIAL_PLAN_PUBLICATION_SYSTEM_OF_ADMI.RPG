     C                     DO   *HIVAL
     C           KEY1      REDPEIZAPL011                 50
      *
     C           *IN50     IFEQ '0'
     C           ZCSKJY    IFEQ 'D'
TCHK2C*          ZCSKHZ    ANDLE*DATE
TCHK2C           ZCSKHZ    ANDLEWSSDAT
     C                     ELSE
TCHK2C*          ZCUKHZ    IFLE *DATE
TCHK2C*          ZCSTHZ    ANDGT*DATE
TCHK2C           ZCUKHZ    IFLE WSSDAT
TCHK2C           ZCSTHZ    ANDGTWSSDAT
     C                     MOVEL'*'       @DATA
     C                     END
     C                     END
     C                     END
     C  N50                ENDDO
      *
     C           @DATA     IFEQ *BLANK
