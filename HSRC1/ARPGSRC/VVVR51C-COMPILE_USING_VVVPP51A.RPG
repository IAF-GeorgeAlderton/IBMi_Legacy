     H            Y.
     F** VVVR51C***********************************************************
     F*  COMPILE USING VVVPP51A                                           *
     F*  J.WATANABE   2026.02.13                                          *
     F*********************************************************************
     FVVVPP51AUF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *********************************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ********************************************************************
      * MAIN ROUTINE                                                     *
      ********************************************************************
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    50
     C                     MOVE 'N'       @PASS   1
      *
     C           *LOVAL    SETLLVVVPP51A                 98
     C                     DO   *HIVAL
     C                     READ VVVPP51A                 98
     C   98                LEAVE
      *
     C           A3CHGD    IFEQ 0
     C           A1FLG1    OREQ ' '
     C           A1FLG1    OREQ '='
     C           A1FLD1    OREQ 'X'
     C                     ITER
     C                     ENDIF
      *
     C           A1FLD1    IFNE 'COMPILED'
     C                     ITER
     C                     ENDIF
      *
     C           A1SEU     IFNE 'RPG '
     C                     ITER
     C                     ENDIF
      *
     C**         A1NAME    IFEQ 'ADAR50'
     C**                   MOVE 'Y'       @PASS
     C**                   ENDIF
      *
     C**         @PASS     IFNE 'Y'
     C**                   ITER
     C**                   ENDIF
      *
     C                     MOVELA1SEU     $SEU
     C                     MOVELA1NAME    $PGM
     C                     CALL 'VVVC51C1'
     C                     PARM           $SEU    4
     C                     PARM           $PGM   10
     C                     PARM           $STT    1
      *
      * PRINT
     C           $STT      IFEQ 'X'
     C                     EXCPT@DTL
     C                     MOVEL'X'       A1FLD1    P
     C                     ELSE
     C                     MOVEL'COMPILED'A1FLD1    P
     C                     ENDIF
      *
     C                     UPDATVVVP51A1
      * PRINT
     C           $STT      IFEQ 'X'
     C           SEQ#      IFEQ 1
     C                     EXCPT@HDR
     C                     ENDIF
     C                     EXCPT@DTL
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      ***********************************************************
     OQPRINT  E   03           @HDR
     O                                   19 '** COMPILE ERROR **'
     O        E 1              @DTL
     O                         A1NAME  +001
     O                         A1SEU   +001
