     H            Y.
     F** AM#R84  *******************************************
     F* PLAN START END                                     *
     F*      ITS.        2015.06.24                        *
     F******************************************************
     FAM#WP83 UF  E           K        DISK
     FAM#WP51 IF  E           K        DISK
     FAM#PP00 IF  E           K        DISK
     FAM#WP84 O   E                    DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1FIXD  80
     C                     PARM           P1FIXT  60
     C                     PARM           P1BINS  30
     C                     PARM           P1KENS  40
      *
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      * PULLING CYCLE
     C                     Z-ADD0         D1PULC  30
     C                     MOVEL'PULCYC'  KEY    10
     C           KEY       CHAINAM#PP001             20
     C           *IN20     IFEQ '0'
     C                     Z-ADDD0VALU    D1PULC
     C                     ENDIF
      * PACKING CYCLE
     C                     Z-ADD0         D1PACC  30
     C                     MOVEL'PACCYC'  KEY    10
     C           KEY       CHAINAM#PP001             20
     C           *IN20     IFEQ '0'
     C                     Z-ADDD0VALU    D1PACC
     C                     ENDIF
      *
     C           P1KENS    DIV  P1BINS    WKMIN   30
     C           WKMIN     IFGT D1PULC
     C                     Z-ADDD1PULC    WKMIN
     C                     ENDIF
      *
     C           KEY51     KLIST
     C                     KFLD           K1FIXD  80
     C                     KFLD           K1FIXT  60
     C                     Z-ADDP1FIXD    K1FIXD
     C                     Z-ADDP1FIXT    K1FIXT
     C           KEY51     SETLLAM#WP511
     C           KEY51     READEAM#WP511                 83
      *
     C                     Z-ADDWKMIN     W       30
     C                     READ AM#WP831                 80
     C           *IN80     DOWEQ'0'
     C           W         IFEQ WKMIN
     C                     Z-ADD0         W
     C                     EXSR #SB400
     C                     ENDIF
     C           W3USE     IFEQ '00'
     C                     EXSR #SB500
     C                     ADD  1         W
     C           GET       IFEQ '1'
     C                     MOVEL'##'      W3USE
     C                     MOVELWKTRKB    W3TRKB
     C                     MOVELWKIAFB    W3IAFB
     C                     Z-ADDWKEXTR    W3EXTR
     C                     UPDATAM#WP831
     C                     ENDIF
     C                     ENDIF
     C                     READ AM#WP831                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEL'0'       GET     1
     C                     MOVEL*BLANK    WKTRKB  2
     C                     MOVEL*BLANK    WKIAFB  3
     C                     Z-ADD0         WKEXTR  30
     C                     MOVEL*BLANK    WKSHID  8
     C           *IN83     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           W1IAFB    IFNE *BLANK
     C                     MOVEL'1'       GET     1
     C                     MOVELW1TRKB    WKTRKB
     C                     MOVELW1IAFB    WKIAFB
     C                     Z-ADDW1EXTR    WKEXTR
     C                     MOVELW1SHD1    WKSHID
     C                     ENDIF
     C           KEY51     READEAM#WP511                 83
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAM#WP841
     C                     Z-ADDP1FIXD    W4FIXD
     C                     Z-ADDP1FIXT    W4FIXT
     C                     MOVELWKSHID    W4SHID
     C                     Z-ADDW3DATE    W4DATE
     C                     Z-ADDW3TIME    W4TIME
     C                     MOVELW3USE     W4USE
     C                     MOVELW3YOBI    W4YOBI
     C                     MOVELWKTRKB    W4TRKB
     C                     MOVELWKIAFB    W4IAFB
     C                     Z-ADDWKEXTR    W4EXTR
     C                     WRITEAM#WP841
      *
     CSR         ESB500    ENDSR
