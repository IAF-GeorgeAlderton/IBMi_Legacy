     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * READ                                               *
      *----------------------------------------------------*
     CSR         #READ     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREAD
     C                     ENDIF
      *
     C                     EXSR #EDIT
     C                     ADD  1         RRN
     C                     ADD  1         @RRN
     C                     ADD  1         CTRX
     C                     WRITESFL
      *
     C           CTRX      IFEQ 15
     C                     SETON                       66
     C                     ENDIF
      *
     CSR         EREAD     ENDSR
      *----------------------------------------------------*
      * READP                                              *
      *----------------------------------------------------*
     CSR         #READP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREADP
     C                     ENDIF
      *
     C                     SUB  1         CTRX           27
      *
     CSR         EREADP    ENDSR
      *----------------------------------------------------*
      * SELECT                                             *
      *----------------------------------------------------*
     CSR         #SELEC    BEGSR
      *
     C           S2SKJY    IFEQ 'D'
     C           S2SKHZ    ANDLE*DATE
     C                     GOTO ESELEC
     C                     ENDIF
      *
     C           S2ERCD    IFNE *BLANK
     C                     GOTO ESELEC
     C                     ENDIF
      *
     C                     SELEC
     C           S2SYOR    WHEQ '1'
     C***        S2PRO1    IFNE P1PROC
     C***                  GOTO ESELEC
     C***                  ENDIF
     C           P1BARC    IFNE *BLANK
     C           S2BAR1    IFNE P1BARC
     C                     GOTO ESELEC
     C                     ENDIF
     C                     ENDIF
     C           S2SYOR    WHEQ '2'
     C***        S2PRO2    IFNE P1PROC
     C***                  GOTO ESELEC
     C***                  ENDIF
     C           P1BARC    IFNE *BLANK
     C           S2BAR2    IFNE P1BARC
     C                     GOTO ESELEC
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     MOVEL'1'       WKGET
      *
     CSR         ESELEC    ENDSR
      *----------------------------------------------------*
      * CLEAR                                              *
      *----------------------------------------------------*
     CSR         #CLR      BEGSR
      *
     C                     SETON                     71
     C                     WRITESFLCTL
     C                     SETOF                     7166
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN    40
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         @SFRC1
      *
     CSR         ECLR      ENDSR
      *----------------------------------------------------*
      * EDIT                                               *
      *----------------------------------------------------*
     CSR         #EDIT     BEGSR
      *
     C                     Z-ADDS2CRHZ    S3CRHZ
     C                     MOVEL*BLANK    S3CRTI
     C                     MOVELS2CRTH    S3CRTI
     C           S3CRTI    CAT  ':':0     S3CRTI
     C           S3CRTI    CAT  S2CRTM:0  S3CRTI
     C                     Z-ADDS2HKSU    S3TUHK
     C                     MOVEL*BLANK    S3INOU
     C*
     C                     MOVEL*BLANK    S3PAGE  7
     C*
     C                     SELEC
     C           S2SYOR    WHEQ '1'
     C                     MOVEL'IN '     S3INOU
     C* INTRA
     C                     MOVELS2PAG1    S3PAGE
     C* PLASTIC
     C           S2KBN1    IFEQ 'A'
     C           S2KBN1    OREQ 'R'
     C           S2VLO1    CAT  '-':0     S3PAGE
     C           S3PAGE    CAT  S2VPA1:0  S3PAGE
     C                     ENDIF
     C* PT/BPT
     C           S2KBN1    IFEQ 'I'
     C                     MOVELS2LOT1    S3PAGE
     C                     ENDIF
     C           S2SYOR    WHEQ '2'
     C                     MOVEL'OUT'     S3INOU
     C* INTRA
     C                     MOVELS2PAG2    S3PAGE
     C* PLASTIC
     C           S2KBN2    IFEQ 'A'
     C           S2KBN2    OREQ 'R'
     C           S2VLO2    CAT  '-':0     S3PAGE
     C           S3PAGE    CAT  S2VPA2:0  S3PAGE
     C                     ENDIF
     C*
     C           S2KBN2    IFEQ 'I'
     C                     MOVELS2LOT2    S3PAGE
     C                     ENDIF
     C                     ENDSL
     C*
      *
     CSR         EEDIT     ENDSR
