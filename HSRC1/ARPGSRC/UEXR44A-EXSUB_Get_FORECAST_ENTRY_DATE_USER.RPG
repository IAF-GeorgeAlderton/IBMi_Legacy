     H            Y.
      ** UEXR44A ***************************************************
      *  GET FORECAST ENTRY DATE/USER                              *
      *  JW     2023.01.24                                         *
      **************************************************************
      *  CALLING SEQ.                                              *
     C*                    CALL 'UEXR44A'
     C*                    PARM           $NONY   4
     C*                    PARM           $NKOJ   1
     C*                    PARM           $NUKE   4
     C*                    PARM           $MHIN  20
     C*                    PARM           $OTYP   1
     C*                    PARM           $KOHZ   8
     C*                    PARM           $KOUS  10
     F*   IN  $NONY   4A  DELIVERY CODE                            *
     F*   "   $NKOJ   1A  FACTORY                                  *
     F*   "   $NUKE   4A  DOCK                                     *
     F*   "   $MHIN  20A  CUSTOMER PART                            *
     F*   OUT $OTYP   1A  ORDER ENTRY TYPE                         *
     F*       $KOHZ   8A  ENTRY DATE                               *
     F*       $KOUS  10A  ENTRY USER                               *
      **************************************************************
     FABBPL51 IF  E           K        DISK
     FABBPL63 IF  E           K        DISK
     FABFPL1C IF  E           K        DISK
     FEDIPL47 IF  E           K        DISK
      ***********************************************************
     I            DS
     I                                        1  20 K#MHIN
     I                                        1   5 K#MHN1
     I                                        6  10 K#MHN2
     I                                       11  15 K#MHN3
     I                                       16  20 K#MHN4
     I            DS
     I                                        1   80ABKOHZ
     I                                        1   40ABKOYY
     I                                        5   60ABKOMM
     I                                        7   80ABKODD
      ****************************************************
      * MAIN ROUTINE
      ****************************************************
     C                     EXSR #INIT
      * CHECK ABBPL51 =====================================
     C           K#PL51    SETGTABBPL51
     C           K#PL51    REDPEABBPL51                  98
     C           *IN98     IFEQ *OFF
     C                     MOVE 'E'       $OTYP
     C                     MOVELBBRCDT    $KOHZ
     C                     MOVEL'EDI'     $KOUS     P
     C                     ENDIF
      *
      * CHECK ABFPL1C (FORD) ==============================
     C**         $OTYP     IFEQ *BLANK
      * GET USER PART
     C                     MOVE *BLANK    XUPART 40
     C           K#PL47    SETLLEDIPL47
     C                     DO   *HIVAL
     C           K#PL47    READEEDIPL47                  97
     C   97                LEAVE
     C                     MOVELE5UPRT    XUPART
     C           E5NONY    IFEQ K#NONY
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           XUPART    IFNE *BLANK
     C           K#PL1C    SETGTABFPL1C
     C           K#PL1C    REDPEABFPL1C                  96
     C           *IN96     IFEQ *OFF
     C                     MOVE 'E'       $OTYP
     C           FBDATE    ADD  20000000  NUM8    80
     C                     MOVELNUM8      $KOHZ
     C                     MOVEL'EDI'     $KOUS     P
     C                     ENDIF
     C                     ENDIF
     C**                   ENDIF
      *
      * CHECK ABBPL63 =====================================
     C**         $OTYP     IFEQ *BLANK
     C           K#PL51    SETGTABBPL63
     C           K#PL51    REDPEABBPL63                  95
     C           *IN95     IFEQ *OFF
     C                     MOVE 'M'       $OTYP
     C                     MOVELABKOHZ    $KOHZ
     C                     MOVELABKOME    $KOUS
     C                     ENDIF
     C**                   ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ****************************************************
      * INITIALIZE
      ****************************************************
     C           #INIT     BEGSR
     C*
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4        IN
     C                     PARM           $NKOJ   1        IN
     C                     PARM           $NUKE   4        IN
     C                     PARM           $MHIN  20        IN
     C                     PARM           $OTYP   1        OUT
     C                     PARM           $KOHZ   8        OUT
     C                     PARM           $KOUS  10        OUT
     C*
     C           K#PL51    KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#NKOJ  1
     C                     KFLD           K#NUKE  4
     C                     KFLD           K#MHN1  5
     C                     KFLD           K#MHN2  5
     C                     KFLD           K#MHN3  5
     C                     KFLD           K#MHN4  5
     C*
     C           K#PL1C    KLIST
     C                     KFLD           XUPART
     C                     KFLD           K#NONY
     C*
     C           K#PL47    KLIST
     C                     KFLD           K#MHN1
     C                     KFLD           K#MHN2
     C                     KFLD           K#MHN3
     C                     KFLD           K#MHN4
      *
     C                     MOVEL$NONY     K#NONY
     C                     MOVEL$NKOJ     K#NKOJ
     C                     MOVEL$NUKE     K#NUKE
     C                     MOVEL$MHIN     K#MHIN
      *
     C                     MOVE *BLANK    $OTYP
     C                     MOVE *BLANK    $KOHZ
     C                     MOVE *BLANK    $KOUS
      *
     C                     ENDSR
