     FAFAPL6Y1IF  E           K        DISK
TCHK2FAFAPL6X3IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FALBPL30 IF  E           K        DISK
     FFCETL11 IF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
      *------------------------------------------------------------
     E                    ERR     1  20 20
      *------------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I            DS
     I                                        1   80K@DATE
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80F8KDAT
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
TCHK2I            DS
TCHK2I                                        1  10 K@KOME
TCHK2I                                        1   6 K@KOMC
TCHK2I                                       10  10 K@KOMS
TCHK2I            DS
TCHK2I                                        1   80AYKSDT
TCHK2I                                        1   40K@KOYY
TCHK2I                                        5   60K@KOMM
TCHK2I                                        7   80K@KODD
TCHK2I            DS
TCHK2I                                        1   60AYKSTM
TCHK2I                                        1   20K@KOHH
TCHK2I                                        3   40K@KOSS
TCHK2I            DS
TCHK2I                                        1   80AXKODT
TCHK2I                                        1   40AXKOYY
TCHK2I                                        5   60AXKOMM
