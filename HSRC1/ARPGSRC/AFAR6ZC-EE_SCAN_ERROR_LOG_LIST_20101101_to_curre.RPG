      *--------------------------------------------------------
      *   MAIN ROUTINE
      *--------------------------------------------------------
     C                     EXSR #OUT
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *--------------------------------------------------------
      * INITIALIZE
      *--------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
      *
     C                     Z-ADD20101102  K@DATE
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     Z-ADDF8KDAT    K@DATE
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     TIME           @@TIM   60
     C                     MOVE *ALL'-'   W@LINE150
     C                     MOVEL*BLANK    W@OPER  6
     C                     MOVEL*BLANK    W@SHFT  1
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  OUTPUT
      *--------------------------------------------------------
     C           #OUT      BEGSR
      *
     C                     MOVE *OFF      *IN98
     C           K@DATE    SETLLAFAPL6Y1
      *
     C                     DO   *HIVAL
      *
     C                     READ AFAPL6Y1                 91
     C   91                LEAVE
      *
     C******     AYERID    IFEQ '11'
     C******               ITER
     C******               END
      *
     C           AYOPER    IFNE W@OPER
     C                     MOVELAYOPER    K@OPER  60
     C           K@OPER    CHAINALBPL30              90
     C  N90                MOVELALWKNM    P@WKNM 20 P
     C   90                MOVELAYOPER    P@WKNM    P
     C                     MOVELAYOPER    W@OPER
     C                     MOVEL*BLANK    W@SHFT
     C                     ELSE
     C                     MOVEL*BLANK    P@WKNM
     C                     END
      *
     C           AYSHFT    IFNE W@SHFT
     C                     MOVELAYSHFT    W@SHFT  1
     C                     MOVELAYSHFT    P@SHFT  1
     C                     ELSE
     C                     MOVEL*BLANK    P@SHFT
     C                     END
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     END
     C  N98                MOVE *ON       *IN98
      *
     C                     SELEC
     C           AYERSC    WHEQ 'LOCATION'
     C                     MOVELAYERSC    W@@NM  16
     C           AYERSC    WHEQ 'LOT ID'
     C                     MOVELAYERSC    W@@NM
     C           AYERSC    WHEQ 'LOQ K#'
     C                     MOVEL'LOQ KANB'W@@NM
     C                     MOVE 'AN      'W@@NM
     C           AYERSC    WHEQ 'APICS K3'
     C           AYERSC    OREQ 'APICS K4'
     C                     MOVEL'APICS KA'W@@NM
     C                     MOVE 'NBAN    'W@@NM
     C                     ENDSL
TCHK2C                     MOVELW@@NM     P@SCNM 12 P
      *
TCHK2C                     MOVELAYKSTM    P@KSTM  40
TCHK2 *
TCHK3C                     MOVEL*BLANK    P@PT#1  5
TCHK3C                     MOVEL*BLANK    P@PT#2  5
TCHK3C                     MOVEL*BLANK    P@PT#3  2
TCHK3C                     MOVEL*BLANK    P@LOC   8
TCHK3 *
TCHK2C                     MOVEL*BLANK    K@KOME
TCHK2C                     MOVELAYOPER    K@KOMC
TCHK2C                     MOVELAYSHFT    K@KOMS
TCHK2C           K@6X3     KLIST
TCHK2C                     KFLD           K@KOME
TCHK2C                     KFLD           K@KOYY
TCHK2C                     KFLD           K@KOMM
TCHK2C                     KFLD           K@KODD
TCHK2C                     KFLD           K@KOHH
TCHK2C                     KFLD           K@KOSS
TCHK2C           K@6X3     SETGTAFAPL6X3
TCHK3C                     DO   *HIVAL
TCHK2C           K@KOME    READEAFAPL6X3                 92
TCHK3C*TCHK2     *IN92     IFEQ *OFF
TCHK3C*TCHK2               Z-ADDAXKODT    P@CODT  80
TCHK3C*TCHK2               Z-ADDAXKOTM    P@COTM  40
TCHK3C*TCHK2               ELSE
TCHK3C*TCHK2               Z-ADD*ZERO     P@CODT
TCHK3C*TCHK2               Z-ADD*ZERO     P@COTM
TCHK3C*TCHK2               END
TCHK3C           *IN92     IFEQ *ON
TCHK3C                     Z-ADD*ZERO     P@CODT
TCHK3C                     Z-ADD*ZERO     P@COTM
TCHK3C                     LEAVE
TCHK3C                     END
TCHK3C           P@PT#1    IFNE *BLANK
TCHK3C           P@LOC     ANDNE*BLANK
TCHK3C                     LEAVE
TCHK3C                     END
TCHK3C                     Z-ADDAXKODT    P@CODT  80
TCHK3C                     Z-ADDAXKOTM    P@COTM  40
TCHK3C           P@PT#1    IFEQ *BLANK
TCHK3C           AXZETI    ANDNE*BLANK
TCHK3C           AXZETI    CHAINFCETL11              93
TCHK3C           *IN93     IFEQ *OFF
TCHK3C                     MOVELA2BHB1    P@PT#1
TCHK3C                     MOVELA2BHB2    P@PT#2
TCHK3C                     MOVELA2BHB3    P@PT#3
TCHK3C                     END
TCHK3C                     END
TCHK3C           P@LOC     IFEQ *BLANK
TCHK3C           AXDKND    ANDEQ'LOCATION'
TCHK3C                     MOVELAXDATA    P@LOC
TCHK3C                     END
TCHK3C                     ENDDO
TCHK2 *
     C                     MOVE AYERID    @2      20
TCHK2C                     MOVELERR,@2    P@MSG  20
      *
     C                     EXCPT@DTL
      *
     C                     ENDDO
      *
     C                     ENDSR
      *-------------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                         UDATE Y  115
     O                         @@TIM    124 '  :  :  '
     O                                  127 'P.'
     O                         PAGE  Z  132
     O        E   02           @HED
     O                                   65 'EE(4-POINT)'
     O                                   80 'SCAN ERROR LOG'
     O        E   04           @HED
     O                                    8 'OPERATOR'
TCHK3O                                   24 'SHIFT'
TCHK3O                                   35 'SCAN DATE'
TCHK3O                                   40 'TIME'
TCHK3O                                   54 'SCREEN NAME'
TCHK3O                                   68 'SCANNED DATA'
TCHK3O                                   90 'ERROR MESSAGE'
TCHK3O                                  108 'CORRECTED'
TCHK3O                                  124 'PART NO.'
TCHK3O                                  134 'LOC'
TCHK3O        E   05           @HED
TCHK3O                         W@LINE   150
TCHK3O        E 1              @DTL
     O                         P@WKNM    20
TCHK3O                         P@SHFT    22
TCHK3O                         AYKSDTY   35
TCHK3O                         P@KSTM    41 '  :  '
TCHK3O                         P@SCNM    55
TCHK3O                         AYERDT    76
TCHK2O                         P@MSG     97
TCHK2O                         P@CODT   108 '    /  /  '
TCHK2O                         P@COTM   114 '  :  '
TCHK3O                         P@PT#1   121
TCHK3O                         P@PT#2   127
TCHK3O                         P@PT#3   130
TCHK3O                         P@LOC    139
