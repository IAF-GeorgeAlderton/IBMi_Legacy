     C                     GOTO STEP1
     C                     END
      *
     C           IKOS      IFNE '0'
     C           IKOS      ANDNE'1'
     C           IKOS      ANDNE'2'
     C                     SETON                     0199
     C                     MOVE ER,2      MSG
     C                     GOTO STEP1
     C                     END
      *
     C           ICODE     IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVE ER,3      MSG
     C                     GOTO STEP1
     C                     END
      *
     C                     SETOF                     10
