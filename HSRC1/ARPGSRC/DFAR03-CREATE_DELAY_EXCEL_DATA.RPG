     C*
     **==============================================================**
     **  メインルーチン
     **==============================================================**
     C*---<初期処理>---*
     C                     EXSR #INIT
     C                     EXCPTHD
     C*---<主処理>---*
     C           *LOVAL    SETLLDFAWP021
     C                     EXSR #RED10
     C*
     C           *IN80     DOWEQ'0'                        ¬DO_01
     C*頭ゼロ消去右詰め文字  NOMINAL LENGTH
     C                     MOVE W2KUBI    HSKUBI
     C**
     C                     MOVE *BLANK    INSUJI
     C                     MOVE HSKUBL    INSUJI 110
     C                     MOVE *BLANK    OTMOJI 11
     C                     MOVE *BLANK    CHKFLG  1
     C                     CALL 'MRHR47'
     C                     PARM           INSUJI
     C                     PARM           OTMOJI
     C                     PARM           CHKFLG
     C           CHKFLG    IFEQ ' '
     C                     MOVE OTMOJI    HSKUBL
     C                     ENDIF
     C           HSKUBR    IFEQ '00'
     C                     MOVE *BLANK    HSKUBR
     C                     SETON                     70
     C                     ENDIF
     C                     EXSR #DTL10
     C                     EXSR #RED10
     C                     ENDDO                           ｢DO_01
     C*
     C*---<終了処理>---*
      *
     C           @CNT      IFEQ 0
     C                     MOVE '*'       PRTN
     C                     ENDIF
     C*
      *
     C                     SETON                     LR
     C                     RETRN
     C*
     C**************************************************************************
     C*         Ｓ　Ｕ　Ｂ　－　Ｒ　Ｏ　Ｕ　Ｔ　Ｉ　Ｎ　Ｅ
     C**************************************************************************
     C*-------------------------------------------------------------------------
     C*          #INIT    初期処理
     C*-------------------------------------------------------------------------
     C           #INIT     BEGSR
     C*
     C                     TIME           S@TIME
     C                     Z-ADDS@DYMM    W@SMM
     C                     Z-ADDS@DYDD    W@SDD
     C                     Z-ADDS@DYYY    W@SYY4
     C                     Z-ADD0         @CNT    60
     C                     MOVE *BLANK    PRTN
     C*
     C                     ENDSR
     C*-------------------------------------------------------------------------
     C*          #RED10    READ WORK FILE
     C*-------------------------------------------------------------------------
     C           #RED10    BEGSR
     C*
     C                     DO   *HIVAL                     ¬DO_01
     C                     READ DFAWP021                 80
     C   80                LEAVE
     C*
     C                     LEAVE
     C                     ENDDO                           ｢DO_01
     C*
     C                     ENDSR
     C*-------------------------------------------------------------------------
     C*          #DTL10    DETAIL WRITE
     C*-------------------------------------------------------------------------
     C           #DTL10    BEGSR
     C*
     C                     MOVELW2SHN1    P1SHN1
     C                     MOVELW2SHN2    P1SHN2
     C                     MOVELW2SHN3    P1SHN3
     C                     MOVE '-'       P1SHF1
     C                     MOVE '-'       P1SHF2
     C           P1SHN3    IFEQ *BLANK                      *IF01
     C                     MOVE ' '       P1SHF2
     C           P1SHN2    IFEQ *BLANK                      *IF02
     C                     MOVE ' '       P1SHF1
     C                     ENDIF                            *EIF02
     C                     ENDIF                            *EIF01
      *
     C                     MOVELW2UHN1    P1UHN1
     C                     MOVELW2UHN2    P1UHN2
     C                     MOVELW2UHN3    P1UHN3
     C                     MOVELW2UHN4    P1UHN4
     C                     MOVE '-'       P1UHF1
     C                     MOVE '-'       P1UHF2
     C                     MOVE '-'       P1UHF3
     C           P1UHN4    IFEQ *BLANK
     C                     MOVE ' '       P1UHF3
     C           P1UHN3    IFEQ *BLANK
     C                     MOVE ' '       P1UHF2
     C           P1UHN2    IFEQ *BLANK
     C                     MOVE ' '       P1UHF1
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C*
     C                     MOVELW2BHN1    P1BHN1
     C                     MOVELW2BHN2    P1BHN2
     C                     MOVELW2BHN3    P1BHN3
     C                     MOVE '-'       P1BHF1
     C                     MOVE '-'       P1BHF2
     C           P1BHN3    IFEQ *BLANK                      *IF01
     C                     MOVE ' '       P1BHF2
     C           P1BHN2    IFEQ *BLANK                      *IF02
     C                     MOVE ' '       P1BHF1
     C                     ENDIF                            *EIF02
     C                     ENDIF                            *EIF01
     C*
     C                     MOVELW2KH11    P1KHN1
     C                     MOVELW2KH12    P1KHN2
     C                     MOVELW2KH13    P1KHN3
     C                     MOVE '-'       P1KHF1
     C                     MOVE '-'       P1KHF2
     C           P1KHN3    IFEQ *BLANK                      *IF01
     C                     MOVE ' '       P1KHF2
     C           P1KHN2    IFEQ *BLANK                      *IF02
     C                     MOVE ' '       P1KHF1
     C                     ENDIF                            *EIF02
     C                     ENDIF                            *EIF01
     C*
     C                     MOVELW2KH21    P2KHN1
     C                     MOVELW2KH22    P2KHN2
     C                     MOVELW2KH23    P2KHN3
     C                     MOVE '-'       P2KHF1
     C                     MOVE '-'       P2KHF2
     C           P2KHN3    IFEQ *BLANK                      *IF01
     C                     MOVE ' '       P2KHF2
     C           P2KHN2    IFEQ *BLANK                      *IF02
     C                     MOVE ' '       P2KHF1
     C                     ENDIF                            *EIF02
     C                     ENDIF                            *EIF01
      *
      *  BOXES DIVIDED BY ISSUE LOT
     C           W2ILOT    IFEQ *ZERO
     C                     Z-ADD1         W2ILOT
     C                     END
     C           W2HKSU    DIV  W2ILOT    W2KMAI  40       *発行枚数
     C                     MVR            W@MVR   80       *余り
     C           W@MVR     IFNE *ZERO                      ~¬IF_02
     C                     ADD  1         W2KMAI           *発行枚数
     C                     END                             _｢IF_02
      *
     C* COMMA TO DOT
     C           W2MME1    IFNE *BLANK                     ~¬IF_02
     C                     MOVE *BLANK    INSUJ2
     C                     MOVELW2MME1    INSUJ2100
     C                     MOVE *BLANK    OTMOJ2100
     C                     MOVE *BLANK    CHKFLG  1
     C                     CALL 'MRHR6C'
     C                     PARM           INSUJ2
     C                     PARM           OTMOJ2
     C                     PARM           CHKFLG
     C           CHKFLG    IFEQ ' '
     C                     MOVELOTMOJ2    W2MME1
     C                     ENDIF
     C                     ENDIF
     C* COMMA TO DOT
     C           W2MME2    IFNE *BLANK                     ~¬IF_02
     C                     MOVE *BLANK    INSUJ2
     C                     MOVELW2MME2    INSUJ2100
     C                     MOVE *BLANK    OTMOJ2100
     C                     MOVE *BLANK    CHKFLG  1
     C                     CALL 'MRHR6C'
     C                     PARM           INSUJ2
     C                     PARM           OTMOJ2
     C                     PARM           CHKFLG
     C           CHKFLG    IFEQ ' '
     C                     MOVELOTMOJ2    W2MME2
     C                     ENDIF
     C                     ENDIF
     C**
     C*頭ゼロ消去右詰め文字  NOMINAL LENGTH
     C                     MOVE W2KUBI    HSKUBI
     C**
     C                     MOVE *BLANK    INSUJI
     C                     MOVE HSKUBL    INSUJI 110
     C                     MOVE *BLANK    OTMOJI 11
     C                     MOVE *BLANK    CHKFLG  1
     C                     CALL 'MRHR47'
     C                     PARM           INSUJI
     C                     PARM           OTMOJI
     C                     PARM           CHKFLG
     C           CHKFLG    IFEQ ' '
     C                     MOVE OTMOJI    HSKUBL
     C                     ENDIF
     C*頭ゼロ消去右詰め文字  NOMINAL SIZE
     C                     MOVE W2TUSZ    HSTUSZ
     C*
     C                     MOVE *BLANK    INSUJI
     C                     MOVE HSTUSL    INSUJI 110
     C                     MOVE *BLANK    OTMOJI 11
     C                     MOVE *BLANK    CHKFLG  1
     C                     CALL 'MRHR47'
     C                     PARM           INSUJI
     C                     PARM           OTMOJI
     C                     PARM           CHKFLG
     C           CHKFLG    IFEQ ' '
     C                     MOVE OTMOJI    HSTUSL
     C                     ENDIF
     C*頭ゼロ消去右詰め文字 MATERIAL PROPETIES
     C                     MOVE W2KIKI    HSKIKI
     C*
     C                     MOVE *BLANK    INSUJI
     C                     MOVE HSKIKL    INSUJI 110
     C                     MOVE *BLANK    OTMOJI 11
     C                     MOVE *BLANK    CHKFLG  1
     C                     CALL 'MRHR47'
     C                     PARM           INSUJI
     C                     PARM           OTMOJI
     C                     PARM           CHKFLG
     C           CHKFLG    IFEQ ' '
     C                     MOVE OTMOJI    HSKIKL
     C                     ENDIF
     C*頭ゼロ消去右詰め文字    WIRE DIAMETER
     C                     MOVE W2KAZI    HSKAZI
     C*
     C                     MOVE *BLANK    INSUJI
     C                     MOVE HSKAZL    INSUJI 110
     C                     MOVE *BLANK    OTMOJI 11
     C                     MOVE *BLANK    CHKFLG  1
     C                     CALL 'MRHR47'
     C                     PARM           INSUJI
     C                     PARM           OTMOJI
     C                     PARM           CHKFLG
     C           CHKFLG    IFEQ ' '
     C                     MOVE OTMOJI    HSKAZL
     C                     ENDIF
     C*頭ゼロ消去右詰め文字
     C                     MOVE W2SOZI    HSSOZI
     C**
     C                     MOVE *BLANK    INSUJI
     C                     MOVE HSSOZL    INSUJI 110
     C                     MOVE *BLANK    OTMOJI 11
     C                     MOVE *BLANK    CHKFLG  1
     C                     CALL 'MRHR47'
     C                     PARM           INSUJI
     C                     PARM           OTMOJI
     C                     PARM           CHKFLG
     C           CHKFLG    IFEQ ' '
     C                     MOVE OTMOJI    HSSOZL  5
     C                     ENDIF
     C*頭ゼロ消去右詰め文字
     C                     MOVE W2KASI    HSKASI  7
     C**
     C                     MOVE *BLANK    INSUJI
     C                     MOVE HSKASL    INSUJI 110
     C                     MOVE *BLANK    OTMOJI 11
     C                     MOVE *BLANK    CHKFLG  1
     C                     CALL 'MRHR47'
     C                     PARM           INSUJI
     C                     PARM           OTMOJI
     C                     PARM           CHKFLG
     C           CHKFLG    IFEQ ' '
     C                     MOVE OTMOJI    HSKASL  5
     C                     ENDIF
      *
     C                     SELEC                           ¬SELEC_01
     C           W2TEHI    WHEQ 'A'                        +WHEN_01
     C                     MOVEL@PI,01    W2TEHN 30
     C           W2TEHI    WHEQ 'B'                        +WHEN_01
     C                     MOVEL@PI,02    W2TEHN
