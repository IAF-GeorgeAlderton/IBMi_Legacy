     C****************************************************************
     C*  MAIN
     C****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C           *NAMVAR   DEFN           GDKD01  20
     C                     IN   *NAMVAR
     C                     Z-ADDGDKD01    COUNT   20
     C*
     C                     EXSR #INIT
     C                     MOVE *BLANK    D1INVO
     C*
     C           @DSP01    TAG
     C                     EXFMTDSP01
     C                     MOVEA'00'      *IN,11
     C                     MOVEL'0'       *IN99
     C                     MOVE *BLANK    D#MSG
     C* < F1=ON >
     C           *INKA     CABEQ'1'       @END
     C*
     C                     EXSR #CHK01
     C           *IN99     CABEQ'1'       @DSP01
     C* < F5=OFF >
     C           *INKE     CABEQ'0'       @DSP01
     C*
     C*
     C*
     C*
     C*
     C           D1INVO    SETLLGDIPL261
     C                     DO   *HIVAL
     C           D1INVO    READEGDIPL261                 10
     C   10                LEAVE
     C           IKSKJY    IFEQ 'D'                        DELETE CODE
     C           IKSKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C*<UPDATE>
     C                     EXSR #RAT01
     C                     EXSR #UPD01
     C                     ENDDO
      *
     C           *IN40     IFEQ '1'
     C                     EXCPT#TO
     C                     END
     C                     MOVE *BLANK    D1INVO
     C********             GOTO @DSP01
      *
     C* <END>
     C           @END      TAG
     C                     SETON                     LR
     C                     RETRN
     C****************************************************************
     C           #INIT     BEGSR                                     *
     C****************************************************************
     C****
     C                     MOVEA'00'      *IN,11
     C                     MOVEL'0'       *IN99
     C                     MOVE *BLANK    D#MSG
     C                     Z-ADD*DATE     W1DATE
     C                     Z-ADD*ZERO     D1DATE
     C*
     C                     ENDSR
     C****************************************************************
     C           #CHK01    BEGSR                                     *
     C****************************************************************
     C**第１画面チェック**
      *
     C           D1INVO    SETLLGDIPL261
     C                     DO   *HIVAL
     C           D1INVO    READEGDIPL261            N    77
     C   77                LEAVE
     C           IKSKJY    IFEQ 'D'                        DELETE CODE
     C           IKSKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C                     LEAVE
     C                     ENDDO
     C**
     C           *IN77     IFEQ '1'
     C                     MOVEL'1'       *IN11
     C  N99                MOVELMSG,1     D#MSG
     C  N99                MOVEL'1'       *IN99
     C                     GOTO @CHK1E
     C                     END
     C           *IN77     IFEQ '0'
     C           IKNYUK    IFNE *BLANK
     C                     MOVEL'1'       *IN11
     C  N99                MOVELMSG,3     D#MSG
     C  N99                MOVEL'1'       *IN99
     C                     GOTO @CHK1E
     C                     END
     C                     END
      *
     C           D1YY      IFEQ 0
     C           D1MM      ORLT 01
     C           D1MM      ORGT 12
     C           D1DD      ORLT 01
     C           D1DD      ORGT 31
     C                     MOVEL'1'       *IN12
     C  N99                MOVELMSG,2     D#MSG
     C  N99                MOVEL'1'       *IN99
     C                     GOTO @CHK1E
     C                     END
      *
     C           D1DATE    IFGT *DATE
     C                     MOVEL'1'       *IN12
     C  N99                MOVELMSG,2     D#MSG
     C  N99                MOVEL'1'       *IN99
     C                     GOTO @CHK1E
     C                     END
      *
     C           @CHK1E    ENDSR
     C****************************************************************
     C           #RAT01    BEGSR                                     *
     C****************************************************************
     C*<>
     C*RATPL01 READ (RATE MASTER)
     C                     Z-ADDIKSKOY    @@YY    40
     C                     Z-ADDIKSKOM    @@MM    20
     C                     MOVE 'JPY'     @@CODE  3
     C           RATKEY    KLIST
     C                     KFLD           @@YY
     C                     KFLD           @@MM
     C                     KFLD           @@CODE
     C           RATKEY    CHAINRATPL011             10
     C   10                Z-ADD0         RARATE
     C*
     C                     ENDSR
     C****************************************************************
     C           #UPD01    BEGSR                                     *
     C****************************************************************
     C*<>
     C*
     C                     MOVEL*BLANK    #ER
     C                     TIME           @@TIME
     C                     Z-ADDD1YY      IKNYUY
     C                     Z-ADDD1MM      IKNYUM
     C                     Z-ADDD1DD      IKNYUD
     C                     MOVEL'*'       IKNYUK
     C                     EXSR #UPD02
     C                     Z-ADD*DATE     IKKOHZ
     C                     Z-ADD@TIME     IKKOTM
     C                     MOVELPPUSER    IKKOME
     C                     UPDATGDIPL261
     C                     EXSR #UPD03
     C*
     C                     ENDSR
     C****************************************************************
     C           #UPD02    BEGSR                                     *
     C****************************************************************
     C*<>
     C           KEY1      KLIST
     C                     KFLD           IKODER
     C                     KFLD           IKITEM
     C*
     C                     Z-ADD0         IIODRY
     C                     Z-ADD0         IIODRM
     C                     Z-ADD0         IIODRD
     C                     MOVE *BLANK    IIIFMK
     C                     TIME           @@TIME
     C                     SETOF                     10
     C           KEY1      SETLLGDIPL161
     C                     DO   *HIVAL
     C           KEY1      READEGDIPL161                 10
     C   10                LEAVE
     C           IISKJY    IFEQ 'D'                        DELETE CODE
     C           IISKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C                     LEAVE
     C                     ENDDO
     C** 発注データなし
     C           *IN10     IFEQ '1'
     C                     MOVE '1'       #ER,1
     C                     END
     C**
     C           *IN10     IFEQ '0'
     C** すでに納入済み
     C           IIIFMK    IFEQ '*'
     C                     MOVE '2'       #ER,2
     C                     GOTO UPDEND
     C                     END
     C** キャンセル済み
     C           IIIFMK    IFEQ 'C'
     C                     MOVE '3'       #ER,3
     C                     GOTO UPDEND
     C                     END
     C                     ADD  IKSURY    IIIFSU
     C           IIIFSU    IFGE IISURY
     C                     MOVEL'*'       IIIFMK
     C                     Z-ADDW1YEAR    IIIFNY
     C                     Z-ADDW1MONT    IIIFNM
     C                     Z-ADDW1DAY     IIIFND
     C                     Z-ADDD1DATE    IIIFHZ
     C                     END
     C                     Z-ADD*DATE     IIKOHZ
     C                     Z-ADD@TIME     IIKOTM
     C                     MOVELPPUSER    IIKOME
     C                     UPDATGDIPL161
     C                     END
     C*
     C           UPDEND    ENDSR
     C*****************************************************************
     C           #UPD03    BEGSR                                     *
     C****************************************************************
     C*<>
     C           KEY2      KLIST
     C                     KFLD           WVEND
     C                     KFLD           WTYPE
     C                     KFLD           GDKKEY
     C*
     C                     MOVE '8990'    WVEND   4
     C                     MOVE 'K'       WTYPE   1
     C                     MOVE *BLANK    GDKKEY 20
     C                     MOVELIKKATA    GDKKEY
     C           KEY2      SETLLGDKPL011                 10
     C                     MOVEA'0'       *IN,90
     C                     DO   *HIVAL
     C           ##1       TAG
     C           KEY2      READEGDKPL011                 10
     C           *IN10     IFEQ '0'
     C           ISSKJY    IFEQ 'D'
     C           ISSKHZ    IFLE *DATE
     C                     GOTO ##1
     C                     END
     C                     END
     C           ISSTHZ    IFGT IKJYHZ
     C                     GOTO ##1
     C                     END
     C           ISENHZ    IFLT IKJYHZ
     C                     GOTO ##1
     C                     END
     C                     MOVEA'1'       *IN,90
     C                     END
     C  N10                END
     C                     Z-ADD0         WTANK   82
     C           *IN90     IFEQ '0'
     C                     Z-ADD0         WTKP   145
     C                     MOVE '4'       #ER,4
     C                     ELSE
     C*          IKHANY    IFEQ 'S'
     C                     Z-ADDISTKP1    WTKP
     C                     Z-ADDISTKP1    WTANK   82
     C*                    END
     C*          IKHANY    IFEQ 'A'
     C*                    Z-ADDISTKP2    WTKP
     C*                    END
     C**ＩＡＦ単価とＡＳＪ単価アンマッチ
     C           WTKP      IFNE IKTANK
     C                     MOVE '5'       #ER,5
     C                     END
     C                     END
     C*
     C                     MOVE *BLANK    ITSKJY
     C                     Z-ADD0         ITSKYY
     C                     Z-ADD0         ITSKMM
     C                     Z-ADD0         ITSKDD
     C                     Z-ADD*YEAR     ITKOYY
     C                     Z-ADDUMONTH    ITKOMM
     C                     Z-ADDUDAY      ITKODD
     C                     Z-ADD@TIMEH    ITKOHH
     C                     Z-ADD@TIMEM    ITKOSS
     C                     MOVE PPUSER    ITKOME
     C                     MOVE IKINVO    ITINVO
     C                     Z-ADDIKODER    ITODER
     C                     Z-ADDIKITEM    ITITEM
     C                     Z-ADDIKIKBN    ITIKBN
 %001C                     MOVE IKPARE    ITPARE
     C                     Z-ADDIKBXNO    ITBXNO
     C                     MOVE WTYPE     ITTYPE
     C                     MOVELIKKATA    ITHIN
     C                     MOVEL*BLANK    ITNAME
     C                     MOVE WVEND     ITVEND
     C                     MOVE *BLANK    ITKAMO
     C                     Z-ADDIKSBOX    ITHAKO
     C                     Z-ADDIKSURY    ITSRY
     C                     Z-ADDWTKP      ITTAN
     C                     MOVE *BLANK    ITTKBN
     C           ITSRY     MULT ITTAN     ITKIN
     C                     Z-ADDRARATE    ITRATE
     C                     Z-ADD0         ITDOLL
     C           ITRATE    IFNE 0
     C           ITKIN     DIV  ITRATE    ITDOLL
     C                     END
     C                     Z-ADDIIODRY    ITHTYY
     C                     Z-ADDIIODRM    ITHTMM
     C                     Z-ADDIIODRD    ITHTDD
     C                     Z-ADDD1YY      ITUKYY
     C                     Z-ADDD1MM      ITUKMM
     C                     Z-ADDD1DD      ITUKDD
     C                     Z-ADDIKSKOY    ITSAYY
     C                     Z-ADDIKSKOM    ITSAMM
     C                     Z-ADDIKSKOD    ITSADD
     C                     Z-ADDIKSKOY    ITSIYY
     C                     Z-ADDIKSKOM    ITSIMM
     C                     Z-ADDIKSKOD    ITSIDD
     C                     MOVELIKHANY    ITYUSO
      *
     C                     DO   COUNT
     C           ITSIMM    IFEQ 12
     C                     ADD  1         ITSIYY
     C                     Z-ADD1         ITSIMM
     C                     ELSE
     C                     ADD  1         ITSIMM
     C                     END
     C                     END
     C                     Z-ADDITSIMM    A       20
     C           A         IFEQ 2
     C           ITSIYY    DIV  4         WWW001  40
     C                     MVR            WWW002  40
     C           WWW002    IFEQ 0
     C                     Z-ADD13        A
     C                     END
     C                     END
     C                     Z-ADDMM,A      ITSIDD
     C*
     C                     Z-ADD0         ITMMYY
     C                     Z-ADD0         ITMMMM
     C                     Z-ADD0         ITMMDD
     C                     WRITEGDKPL051
     C*
     C           WER       IFNE *BLANK
      *
     C           *IN40     IFEQ '0'
     C                     EXCPT#HED
     C                     SETON                     40
     C                     END
     C           *INOF     IFEQ '1'
     C                     EXCPT#TO
     C                     EXCPT#HED
     C                     MOVEL'0'       *INOF
     C                     END
      *
     C           IKHANY    IFEQ 'S'
     C                     MOVEL'SHIP'    WHANY   4
     C                     END
     C           IKHANY    IFEQ 'A'
     C                     MOVEL'AIR '    WHANY
     C                     END
     C                     EXCPT#DTL
     C                     END
     C*
     C                     ENDSR
     C*****************************************************************
     OQPRINT  E   02           #HED
