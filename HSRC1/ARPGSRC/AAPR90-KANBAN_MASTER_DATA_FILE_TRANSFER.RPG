     H            Y.
     F** AAPR90 ****************************
     F* KANBAN MASTER DATA FILE TRANSFER   *
     F*  A-MAMIYA              2000.10.20  *
     F**************************** AAPR90 **
     FAAPPP01 IP  E                    DISK
     FAANPP01 IS  E                    DISK
     FAAPWP90 O   F     128            DISK
     FAAPWP91 O   F     128            DISK
     IAAPPP011    01
     IAANPP011    02
      *削除コード
     I            DS
     I                                        1   80L5SKHZ
     I                                        1   40L5SKYY
     I                                        5   60L5SKMM
     I                                        7   80L5SKDD
      *有効日
     I            DS
     I                                        1   80L5UKHZ
     I                                        1   40L5UKYY
     I                                        5   60L5UKMM
     I                                        7   80L5UKDD
      *失効日
     I            DS
     I                                        1   80L5STHZ
     I                                        1   40L5STYY
     I                                        5   60L5STMM
     I                                        7   80L5STDD
      *削除データの為、終了
     C           *IN01     IFEQ *ON
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    ANDLE*DATE
     C           L5STYY    ORNE 9999
     C                     GOTO @END
     C                     END
      *有効日・失効日
     C           *DATE     IFGE L5UKHZ
     C           *DATE     ANDLEL5STHZ
     C                     ELSE
     C                     GOTO @END
     C                     END
      *
     C           L5TKR2    IFNE 'R3'
     C           *IN10     IFEQ '0'
     C                     EXCPTHD1
     C                     SETON                     10
     C                     END
     C                     SETOF                     30
     C           L5SHN3    IFEQ *BLANK
     C                     SETON                     30
     C                     END
     C                     EXCPTDT1
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN02     IFEQ *ON
     C           L7SKJY    ANDEQ*BLANK
     C           L7STYY    ANDEQ9999
     C           *IN21     IFEQ '0'
     C                     EXCPTHD2
     C                     SETON                     21
     C                     END
     C                     EXCPTDT2
     C                     END
      *
     C           @END      TAG
      *
     OAAPWP90 E                HD1
     O                                      'LOCATION'
     O                                      ','
     O                                      'PART NO'
     O                                      ','
     O                                      'CONTAINER'
     O        E                DT1
     O                         L5TKR1
     O                                      '-'
     O                         L5TKR2
     O                                      '-'
     O                         L5TKR3
     O                                      '-'
     O                         L5TKR4
     O                                      ','
     O                         L5SHN1
     O                                      '-'
     O                         L5SHN2
     O                N30                   '-'
     O                         L5SHN3
     O                                      ','
     O                         L5SYOSZ
     OAAPWP91 E                HD2
     O                                      'LOCATION'
     O                                      ','
     O                                      'PART NO'
     O                                      ','
     O                                      'CONTAINER'
     O        E                DT2
     O                         L7TKR1
     O                                      '-'
     O                         L7TKR2
     O                                      '-'
     O                         L7TKR3
     O                                      '-'
     O                         L7TKR4
     O                                      ','
     O                         L7SHN1
     O                         L7SHN2
     O                         L7SHN3
     O                                      ','
     O                         L7SYOSZ
