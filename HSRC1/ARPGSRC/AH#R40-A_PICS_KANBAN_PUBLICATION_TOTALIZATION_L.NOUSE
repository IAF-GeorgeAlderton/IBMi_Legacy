  E3 C                     END
     C           @END2     TAG
 E2  C  N20                END
E1   C                     END
      *
     C*  ﾃcﾌﾞb
     C*
S1   C           BMON      IFEQ 8907
     C                     Z-ADD0         I
      *
     C                     DO   *HIVAL
     C                     SETOF                     30
     C                     READ AH#PP111                 30
      *
     C           *IN,30    CABEQ'1'       @@@@
      *
     C           *IN,30    IFEQ '0'
     C           CFSKJY    IFEQ 'D'
     C           CFSKHZ    ANDLE*DATE
     C                     GOTO @END3
     C                     END
      *
     C           YM        CABNECFHTYM    @END3
      *
     C           CFBMON    IFEQ 8990
     C           CFBMON    OREQ 8982
     C           CFBMON    OREQ 8974
     C           CFBMON    OREQ 9032
     C           CFBMON    OREQ 9040
     C           CFBMON    OREQ 9245
     C           CFBMON    OREQ 9253
     C           CFBMON    OREQ 9024
     C           CFBMON    OREQ 9431
