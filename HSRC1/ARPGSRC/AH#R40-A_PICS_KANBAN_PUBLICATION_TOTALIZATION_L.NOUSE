  E5 C                     END
     C           @END4     TAG
  E4 C  N40                END
      *
     C           @@@@      TAG
  E3 C                     END
 E2  C                     END
E1   C                     END
      *
     C           I         IFEQ 0
     C                     MOVEA'11'      *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,5     ERR
     C                     GOTO STP1
     C                     ELSE
