     C*  ﾉj
     C*
S1   C           BMON      IFNE 9999
     C           BMON      ANDNE8888
     C           BMON      ANDNE8907
      *
     C                     Z-ADD0         I
     C                     Z-ADD0         HBM
     C                     Z-ADDBMON      HBM,1
 S2  C           BMON      IFEQ 8990
     C                     Z-ADD5665      HBM,2
     C                     Z-ADD8958      HBM,3
 E2  C                     END
      *
     C                     Z-ADD1         W       20
 S2  C           1         DO   3         W
  S3 C           HBM,W     IFNE 0
     C                     Z-ADDHBM,W     WBMON   40
      *
     C           KEY1      SETLLAH#TL111
      *
  S4 C                     DO   *HIVAL
     C                     SETOF                     40
     C           KEY1      READEAH#TL111                 40
      *
     C           *IN,40    CABEQ'1'       @@@@
      *
  S5 C           *IN,40    IFEQ '0'
  S6 C           CFSKJY    IFEQ 'D'
     C           CFSKHZ    ANDLE*DATE
     C                     GOTO @END4
  E6 C                     END
      *
  S6 C           CFBMON    IFEQ 5665
     C           CFBMON    OREQ 8958
     C                     Z-ADD8990      @BMON
     C                     ELSE
     C                     Z-ADDCFBMON    @BMON
  E6 C                     END
      *
     C                     Z-ADDCFHTYY    @YY
     C                     Z-ADDCFHTMM    @MM
     C                     Z-ADDCFHTDD    @DD
     C                     Z-ADDCFMAIS    @MAIS
     C                     Z-ADDCFHTBB    @BIN
     C                     ADD  1         I
      *
     C                     SETON                     U1
     C                     EXCPTF01
