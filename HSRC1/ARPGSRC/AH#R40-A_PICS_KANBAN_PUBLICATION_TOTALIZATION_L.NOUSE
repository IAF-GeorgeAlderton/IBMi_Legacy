     C           KEY1      KLIST
     C                     KFLD           WBMON
     C                     KFLD           YY
     C                     KFLD           MM
      *
     C           *ENTRY    PLIST
     C                     PARM           SRE     4
     C                     PARM           BM      4
     C                     PARM           WY      4
     C                     PARM           WM      2
      *
     C           STP0      TAG
     C                     Z-ADD0         BMON
     C                     Z-ADD0         YM
      *
     C           STP1      TAG
     C                     EXFMTAH#PW401
     C                     MOVEA'00'      *IN,01
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    ERR
      *
     C           *INKA     IFEQ '1'
     C                     MOVEL'1'       *INLR
     C                     RETRN
     C                     END
      *
     C*  ﾃcﾆﾞｭc kｩｮh
     C*
     C           BMON      IFEQ 0
     C                     MOVEA'1'       *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,1     ERR
     C                     GOTO STP1
     C                     END
      *
     C           BMON      IFEQ 8907
     C                     MOVELBMON      SRE     4
     C                     ELSE
     C                     MOVE *BLANK    SRE
     C                     END
      *
     C*  ﾍlﾞi kｩｮh
     C*
     C           YY        IFEQ 0
     C                     MOVEA'1'       *IN,02
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,2     ERR
     C                     GOTO STP1
     C                     END
      *
     C           YY        IFLT 1987
     C           MM        ORGT 12
     C           MM        ORLT 01
     C                     MOVEA'1'       *IN,02
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,3     ERR
     C                     GOTO STP1
     C                     END
      *
     C                     Z-ADD*DATE     XYMD
     C                     Z-ADD*DATE     #YMD
     C           XMM       SUB  1         #MM
     C           #MM       IFEQ 0
     C                     Z-ADD12        #MM
     C           #YY       SUB  1         #YY
     C                     END
      *
     C           YM        IFLT #YM
     C           YM        ORGT XYM
     C                     MOVEA'1'       *IN,02
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,4     ERR
     C                     GOTO STP1
     C                     END
      *
     C  NKE                GOTO STP1
      *
     C*---------------
     C* huyn ﾑc
     C*---------------
     C                     MOVE BMON      BM
     C                     MOVE YY        WY
     C                     MOVE MM        WM
      *
     C                     Z-ADD0         @BMON   40
     C                     Z-ADD0         @YY     40
     C                     Z-ADD0         @MM     20
     C                     Z-ADD0         @DD     20
     C                     Z-ADD0         @MAIS   40
     C                     Z-ADD0         @BIN    20
     C                     Z-ADD0         @KOJO   40
      *
      *
     C*  mﾞｰj qgjﾞﾆ
      *
     C*  ﾇsﾞm ﾉ ﾎﾞy]
S1   C           BMON      IFEQ 9999
     C                     Z-ADD0         I       50
      *
 S2  C                     DO   *HIVAL
     C                     SETOF                     10
     C                     READ AH#PP111                 10
      *
     C           *IN,10    CABEQ'1'       @@@@
      *
  S3 C           *IN,10    IFEQ '0'
  S4 C           CFSKJY    IFEQ 'D'
     C           CFSKHZ    ANDLE*DATE
     C                     GOTO @END1
  E4 C                     END
      *
     C           YM        CABNECFHTYM    @END1
      *
  S4 C           CFBMON    IFEQ 5665
     C           CFBMON    OREQ 8958
     C                     Z-ADD8990      @BMON
     C                     ELSE
     C                     Z-ADDCFBMON    @BMON
  E4 C                     END
      *
     C                     Z-ADDCFHTYY    @YY
     C                     Z-ADDCFHTMM    @MM
     C                     Z-ADDCFHTDD    @DD
     C                     Z-ADDCFMAIS    @MAIS
     C                     Z-ADDCFHTBB    @BIN
     C                     Z-ADD9999      @KOJO
     C                     ADD  1         I
      *
     C                     SETON                     U1
     C                     EXCPTF01
      *
  E3 C                     END
     C           @END1     TAG
 E2  C  N10                END
E1   C                     END
      *
     C*  ibfhf]ﾒ ﾇsﾞm
     C*
S1   C           BMON      IFEQ 8888
     C                     Z-ADD0         I
      *
 S2  C                     DO   *HIVAL
     C                     SETOF                     20
     C                     READ AH#PP111                 20
      *
     C           *IN,20    CABEQ'1'       @@@@
