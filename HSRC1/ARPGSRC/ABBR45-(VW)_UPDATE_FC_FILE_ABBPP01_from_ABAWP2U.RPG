     C                     EXSR #INIT
      *
     C           STP1      TAG
     C           *IN91     DOWEQ*OFF
     C                     SETOF                     910409
     C                     SETOF                     0314
     C                     READ ABAWP2U                  91
     C** 02                GOTO ENDIF
     C           *IN91     IFEQ *OFF
      * CHECK VALIDITY
     C                     MOVELABMHIN    K@MHIN
     C           K@P50     SETGTABBPL51
     C           K@P50     REDPEABBPL51                  99
      *
     C           *IN99     IFEQ *OFF
     C**JW1      BBFLG2    ANDNE*BLANK
JW1  C           BBFLG1    ANDNE*BLANK
     C                     ITER
     C                     ENDIF
     C*----------------------------------------------*
     C* CALCULATE WEEKLY TOTAL                       *
     C*----------------------------------------------*
     C                     EXSR #ADJ1
     C*----------------------------------------------*
     C* N MONTH WORKING DAYS                         *
     C* USER WORKING DAYS, IAF WORKING DAYS          *
     C*----------------------------------------------*
     C           ABTOKU    IFEQ @TOKU1
     C           ABNKOJ    ANDEQ@NKOJ1
     C                     ELSE
      *
     C                     Z-ADDABTOKU    @TOKU1
     C                     MOVE ABNKOJ    @NKOJ1
      *
     C*--------------------------------------------*
     C* CHECK CUSTOMER/DELIVERY                    *
     C*--------------------------------------------*
     C                     SETOF                     03
     C           K@AGD2    CHAINAGDPL311             03
     C           *IN03     IFEQ '0'
     C                     EXSR #CT1
     C                     ELSE
      *
     C*--------------------------------*
     C* CHECK CUSTOMER                             *
     C*--------------------------------*
     C                     SETOF                     03
     C                     MOVE *BLANK    WWNKOJ  1
     C           K@AGD3    CHAINAGDPL311             03
     C           *IN03     IFEQ '0'
     C                     EXSR #CT2
     C                     ELSE
      *
     C*----------------*
     C* IAF            *
     C*----------------*
     C           @TKBN     IFNE 'A'
     C                     EXSR #CT3
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C*----------------------------------------------*
     C* N+1 MONTH WORKING DAYS                       *
     C* USER WORKING DAYS, IAF WORKING DAYS          *
     C*----------------------------------------------*
     C           ABTOKU    IFEQ @TOKU2
     C           ABNKOJ    ANDEQ@NKOJ2
     C                     ELSE
      *
     C                     Z-ADDABTOKU    @TOKU2
     C                     MOVE ABNKOJ    @NKOJ2
      *
     C*--------------------------------------------*
     C* CHECK CUSTOMER/DELIVERY                    *
     C*--------------------------------------------*
     C                     SETOF                     03
     C           K@AGD6    CHAINAGDPL311             03
     C           *IN03     IFEQ '0'
     C                     EXSR #CY1
     C                     ELSE
      *
     C*--------------------------------*
     C* CHECK CUSTOMER                 *
     C*--------------------------------*
     C                     SETOF                     03
     C                     MOVE *BLANK    WWNKOJ
     C           K@AGD7    CHAINAGDPL311             03
     C           *IN03     IFEQ '0'
     C                     EXSR #CY2
     C                     ELSE
      *
     C*----------------*
     C* IAF            *
     C*----------------*
     C           @YKBN     IFNE 'A'
     C                     EXSR #CY3
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADD1         B       20
     C           1         DO   31        B
     C           FNS,B     IFNE 0
     C                     GOTO SAP1
     C                     ENDIF
     C                     ENDDO
      *
     C           FS1       DIV  WCD       WSUR1   70
     C                     MVR            WSUR2   70
     C           WSUR2     IFNE 0
     C                     ADD  1         WSUR1
     C                     ENDIF
      *
     C                     Z-ADD1         B
     C           1         DO   31        B
     C           HIZ1,B    IFNE 0
     C           HIZ1,B    IFEQ 1
     C                     Z-ADDWSUR1     FNS,B
     C                     ELSE
     C           WSUR1     DIV  2         FNS,B
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C           SAP1      TAG
     C*----------------------------------------------*
     C* READ FCCP                                    *
     C*----------------------------------------------*
     C                     EXSR #FCCP
     C*----------------------------------------------*
     C* READ ABBP                                    *
     C*----------------------------------------------*
     C                     EXSR #ABBP
      * READ ABB
     C                     SETOF                     03
     C           K@ABB1    CHAINABBNL011             03
     C           *IN03     IFEQ *ON
     C                     MOVE Q5SHN1    Q5HSH1
     C                     MOVE Q5SHN2    Q5HSH2
     C                     MOVE Q5SHN3    Q5HSH3
     C                     WRITEABBNL011
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
     C*==============================================*
     C* ADJUST DATA                                  *
     C*==============================================*
     C           #ADJ1     BEGSR
      *
     C                     Z-ADDABNJS1    FS1     70
     C                     Z-ADDABNJS2    FS2     70
     C                     Z-ADDABNJS3    FS3     70
     C                     Z-ADDABNJS4    FS4     70
     C                     Z-ADDABNJS5    FS5     70
     C                     Z-ADD0         ABSYOS  50
      *
     C                     ENDSR
     C*==============================================*
     C* READ FCCPP11                                 *
     C*==============================================*
     C           #FCCP     BEGSR
      *
     C                     Z-ADDABTOKU    B4TOKU
     C                     Z-ADDABNONY    B4NONY
     C                     MOVE ABNKOJ    B4NKOJ
     C                     MOVE ABNUKE    B4NUKE
     C                     MOVE ABSBAN    B4SBAN
     C                     MOVELABMHIN    B4MHIN
      *
     C                     SETOF                     04
     C                     Z-ADDUYM1      B4MAHZ
     C           K@FCC1    CHAINFCCPL111             04
      *
     C                     EXSR #SUB
      *
     C                     Z-ADDABSYOS    FNSY    50
     C                     Z-ADDABSYOS    WSYOS   50
     C                     MOVE 'C'       FNST    1
      *
     C           B4TOKU    IFEQ B4NONY
     C                     MOVE B4NKOJ    B4TKOJ
     C                     MOVE B4NUKE    B4TUKE
     C                     ELSE
     C                     MOVE *BLANK    B4TKOJ
     C                     MOVE *BLANK    B4TUKE
     C                     ENDIF
      *
     C                     SETOF                     03
     C                     MOVE *BLANK    B4TMEI
     C           B4TOKU    CHAINFGBPL011             03
     C           *IN03     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     03
     C                     ENDIF
     C           *IN03     IFEQ '0'
     C                     MOVELB2SMEI    B4TMEI
     C                     ENDIF
      *
     C                     SETOF                     03
     C                     MOVE *BLANK    B4NMEI
     C           B4NONY    CHAINFGBPL011             03
     C           *IN03     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     03
     C                     ENDIF
     C           *IN03     IFEQ '0'
     C                     MOVELB2SMEI    B4NMEI
     C                     ENDIF
      *
     C                     MOVE *BLANK    B4SKBN
     C                     Z-ADD0         B4SKHZ
     C                     Z-ADD*DATE     B4KOHZ
     C                     TIME           B4TIME
     C                     MOVE *BLANK    B4KONA
     C                     Z-ADDUYM1      B4NNHZ
     C                     Z-ADDUYM2      B4N1HZ
     C                     Z-ADDUYM3      B4N2HZ
     C                     Z-ADDFS1       B4NNNA
     C                     Z-ADDFS2       B4N1NA
     C                     Z-ADDFS3       B4N2NA
     C                     MOVE '*'       B4NAIJ
     C                     MOVE ABNOKN    B4NOKN
      *
     C                     SETOF                     03
     C                     Z-ADD0         WHIZK   20
     C                     Z-ADD0         WKAIS   20
     C                     Z-ADD0         WNBIN   20
     C           K@GAD1    CHAINGADPL111             03
     C           *IN03     IFEQ '0'
     C           B5SKJY    ANDEQ'D'
     C           B5SKHZ    ANDLE*DATE
     C                     SETON                     03
     C                     ENDIF
     C           *IN03     IFEQ '0'
     C                     Z-ADDB5HIZK    WHIZK
     C                     Z-ADDB5KAIS    WKAIS
     C                     Z-ADDB5NBIN    WNBIN
     C                     ENDIF
      *
     C*----------------------*
     C* READ FCCPL11         *
     C*----------------------*
     C           *IN04     IFEQ '1'
      *
     C           ABSYOS    IFEQ 0
     C                     SETOF                     03
     C           SKEY      CHAINFCEPL011             03
     C           *IN03     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     03
     C                     ENDIF
     C           *IN03     IFEQ '0'
     C           A2SYHZ    IFGT *DATE
     C                     Z-ADDA2KSYS    FNSY
     C                     ELSE
     C                     Z-ADDA2SSYS    FNSY
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADD1         B4MAST
      *
     C           @SXX1     TAG
     C                     SETOF                     03
     C           K@FCC2    CHAINFCCPL131             03
     C           *IN03     IFEQ '0'
      *
     C                     SETOF                     03
     C           1         CHAINFCCNP32              03
     C           *IN03     IFEQ '0'
     C                     MOVE *BLANK    XRKBN   1
      *
     C                     SETOF                     03
     C           K@FCC3    CHAINFCCPL331             03
     C           *IN03     IFEQ '0'
     C                     Z-ADDB4RECD    B4MAST
     C                     MOVE '*'       B4RKBN
     C                     UPDATFCCPL331
     C                     ENDIF
      *
     C                     EXCPT@UP
     C                     ENDIF
     C  N03                GOTO @SXX1
     C                     ELSE
      *
     C                     SETOF                     03
     C           1         CHAINFCCNP32              03
     C           *IN03     IFEQ '0'
     C                     SETOF                     03
     C           K@FCC2    CHAINFCCPL321             03
     C           *IN03     IFEQ '0'
