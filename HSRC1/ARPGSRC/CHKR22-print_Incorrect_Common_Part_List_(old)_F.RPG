     H            Y.
     F***CHKR22*****************************************************************
     F*  PROGRAM    : PRINT INCORRECT COMMON PART LIST                         *
     F*             : READ FAAPP02 AND CHAIN AB#PP10 AND COMPARE IAF PART      *
     F*             : RUN IN FCKC00 (10:10AM BY JOBSCDE)                       *
     F*  WRITTEN    : 5/1/2016                                                 *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F*------------------------------
     F*  PARAMETER
     F*  $CNT    4A # OF ERROR
     F*  $UPD    1A Y/N
     F**************************************************************************
     FFAAPL05 IF  E           K        DISK
     FAB#PL19DUF  E           K        DISK
     FAB#PLAA UF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
     I            DS
     I                                        1  20 BAMHIN
     I                                        1   5 BAMHN1
     I                                        6  10 BAMHN2
     I                                       11  15 BAMHN3
     I                                       16  20 BAMHN4
     I            DS
     I                                        1  12 BASHIN
     I                                        1   5 BASHN1
     I                                        6  10 BASHN2
     I                                       11  12 BASHN3
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR @INIT
      *
     C           *IN98     DOWEQ*OFF
     C                     READ FAAPL05                  98
     C           *IN98     IFEQ *OFF
     C           B7SKBN    ANDNE'D'
      * CHAIN WITH FAC + DOCK
     C                     MOVELB7TOKU    KATOKU
     C                     MOVELB7NONY    KANONY
     C                     MOVELB7MHN1    KAMHN1
     C                     MOVELB7MHN2    KAMHN2
     C                     MOVELB7MHN3    KAMHN3
     C                     MOVELB7MHN4    KAMHN4
     C           KEY       SETLLAB#PL19D
     C                     MOVEL*OFF      *IN99
     C           *IN99     DOWEQ*OFF
     C           KEY       READEAB#PL19D                 99
     C           *IN99     IFEQ *OFF
     C           BASKJY    ANDNE'D'
     C           BAURYY    ANDEQ0
     C                     EXSR #CHK
     C           CHKFLG    IFEQ *ON
     C                     EXSR @PRINT
      * UPDATE
     C           $UPD      IFEQ 'Y'
     C           BASHIN    ANDNE@BBHR5
     C           @BBHR5    ANDNE'???'
     C**         BAURYY    ANDEQ0
     C                     MOVEL@BBHR5    BASHIN
     C                     UPDATAB#PP101
      *PPA1
     C           K#PPA1    KLIST
     C                     KFLD           BANOHZ
     C                     KFLD           BANOBN
     C                     KFLD           BANONY
     C                     KFLD           BANKOJ
     C                     KFLD           BANUKE
     C                     KFLD           BAODRN
     C                     KFLD           BASBAN
     C                     KFLD           BAMHIN
      *
     C           K#PPA1    CHAINAB#PLAA              97
     C           *IN97     IFEQ *OFF
     C                     MOVEL@BBHR5    BASHIN
     C                     UPDATAB#PLAA1
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVELSEQ#      $CNT
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  CHECK                                             *
      *----------------------------------------------------*
     C           #CHK      BEGSR
      *
     C                     MOVE *OFF      CHKFLG  1
     C                     SELEC
     C           B7NKJO    WHNE *BLANK
     C           B7NUKE    ANDNE*BLANK
     C           B7NKJO    IFEQ BANKOJ
     C           B7NUKE    ANDEQBANUKE
     C           BASHN1    IFNE B7SHN1
     C           BASHN2    ORNE B7SHN2
     C           BASHN3    ORNE B7SHN3
     C                     MOVE *ON       CHKFLG
     C                     ENDIF
     C                     ENDIF
      *
     C           B7NKJO    WHEQ *BLANK
     C           B7NKJO    ANDEQ*BLANK
     C           BASHN1    IFNE B7SHN1
     C           BASHN2    ORNE B7SHN2
     C           BASHN3    ORNE B7SHN3
     C                     MOVE *ON       CHKFLG
     C                     ENDIF
      *
     C           B7NKJO    WHNE *BLANK
     C           B7NKJO    ANDEQBANKOJ
     C           BASHN1    IFNE B7SHN1
     C           BASHN2    ORNE B7SHN2
     C           BASHN3    ORNE B7SHN3
     C                     MOVE *ON       CHKFLG
     C                     ENDIF
      *
     C           B7NUKE    WHNE *BLANK
     C           B7NUKE    ANDEQBANUKE
     C           BASHN1    IFNE B7SHN1
     C           BASHN2    ORNE B7SHN2
     C           BASHN3    ORNE B7SHN3
     C                     MOVE *ON       CHKFLG
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           @PRINT    BEGSR
      * CHECK BBHR50
     C                     MOVELBATOKU    PTOKU
     C                     MOVELBANONY    PNONY
     C                     MOVELBANKOJ    PNKOJ
     C                     MOVELBANUKE    PNUKE
     C                     MOVELBAMHIN    @MHIN
     C                     MOVEL*BLANK    @SHIN
     C                     MOVEL*BLANK    @FLG
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           @MHIN  20
     C                     PARM           @SHIN  12
     C                     PARM           @FLG    1
      *
     C                     MOVE *BLANK    @BBHR5 12
     C           @FLG      IFEQ *BLANK
     C                     MOVEL@SHIN     @BBHR5
     C                     ELSE
     C                     MOVEL'???'     @BBHR5
     C                     ENDIF
      * NOT PRINT
     C           BASHIN    IFEQ @BBHR5
     C                     GOTO XPRINT
     C                     ENDIF
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *CONVERT
     C           ' ':'_'   XLATEBAEDIK    XAEDIK  1
     C           ' ':'_'   XLATEBAMHN1    XAMHN1  5
     C           ' ':'_'   XLATEBAMHN2    XAMHN2  5
     C           ' ':'_'   XLATEBAMHN3    XAMHN3  5
     C           ' ':'_'   XLATEBASHN1    XASHN1  5
     C           ' ':'_'   XLATEBASHN2    XASHN2  5
     C           ' ':'_'   XLATEBASHN3    XASHN3  2
     C           ' ':'_'   XLATEB7SHN1    X7SHN1  5
     C           ' ':'_'   XLATEB7SHN2    X7SHN2  5
     C           ' ':'_'   XLATEB7SHN3    X7SHN3  2
     C           ' ':'_'   XLATEBAODRN    XAODRN 10
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C           XPRINT    ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           @INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $CNT    4
     C                     PARM           $UPD    1
      *
     C           KEY       KLIST
     C                     KFLD           KATOKU
     C                     KFLD           KANONY
     C                     KFLD           KAMHN1
     C                     KFLD           KAMHN2
     C                     KFLD           KAMHN3
     C                     KFLD           KAMHN4
      *
     C           *LIKE     DEFN BATOKU    KATOKU
     C           *LIKE     DEFN BANONY    KANONY
     C           *LIKE     DEFN BAMHN1    KAMHN1
     C           *LIKE     DEFN BAMHN2    KAMHN2
     C           *LIKE     DEFN BAMHN3    KAMHN3
     C           *LIKE     DEFN BAMHN4    KAMHN4
      *
     C                     Z-ADD*DATE     @DATE   80
     C                     TIME           @TIME   60
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     MOVEL'0000'    $CNT
      *
     C           $UPD      IFEQ 'Y'
     C                     MOVE *ON       *IN17
     C                     ELSE
     C                     MOVE *OFF      *IN17
     C                     MOVE 'N'       $UPD
     C                     ENDIF
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                N17                17 '(UPD=N)'
     O                 17                17 '(UPD=Y)'
     O                                   40 '** INCORRECT IAF PAR'
     O                                   60 'T (ORDER VS COMMON) '
     O                                   80 '**       FIX: CALL C'
     O                                  100 'HKR22 (/0000/ /N/)  '
     O                                  110 'DATE'
     O                         @DATE    122 '    .  .  '
     O                         @TIME    132 '  :  :  '
     O                                  135 'P.'
     O                         PAGE  Z  139
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   14 'CUST'
     O                                   21 'DELV'
     O                                   35 'SHP_DATE_BIN'
     O                                   48 'USER_PART'
     O                                   71 'IAF PART    '
     O                                   89 'IAF PART     '
     O                                   94 'F'
     O                                  100 'DOCK'
     O                                  111 'ORD#'
     O                                  131 'ORD_QTY'
JW   O                                  140 'BBHR50 '
     O        E 1              @HDR
     O                                   48 '(PP10)   '
     O                                   71 '(PP10)      '
     O                                   89 '(FAAPP02)    '
     O        E 1              @HDR
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O                                  120 '--------------------'
     O                                  140 '--------------------'
     O                                  145 '-----'
     O        E 1              @DTL
     O                         SEQ#    +001
     O                         XAEDIK  +001
     O                         BATOKU  +003
     O                         BANONY  +003
     O                         BANOYY  +003
     O                         BANOMM  +000
     O                         BANODD  +000
     O                         BANOBN  +001
     O                         XAMHN1  +004
     O                         XAMHN2  +000
     O                         XAMHN3  +000
     O                         XASHN1  +005
     O                         XASHN2  +000
     O                         XASHN3  +000
     O                         X7SHN1  +005
     O                         X7SHN2  +000
     O                         X7SHN3  +000
     O                         BANKOJ  +005
     O                         BANUKE  +003
     O                         XAODRN  +006
     O                         BASRYOJ +001
JW   O                         @BBHR5  +001
     O**      E 1              @FOT
     O**                                 20 '** THERE IS NO TARGE'
     O**                                 40 'T DATA **           '
