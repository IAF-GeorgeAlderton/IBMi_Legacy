     C                     ADD  W1N1SR    WKN1SR
     C                     ADD  W1N2SR    WKN2SR
     C                     READ GCRWP211                 80
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *-------------------------------------------*
      * GCRWP22                                   *
      *-------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARGCRWP221
     C                     MOVELWKKATA    W2KATA
