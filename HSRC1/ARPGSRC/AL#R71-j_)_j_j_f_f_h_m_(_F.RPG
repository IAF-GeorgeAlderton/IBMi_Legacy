      *通路優先順
     C                     MOVELW1TKR2    P1BLK
     C                     Z-ADD0         P9SORT
     C                     MOVEL*BLANK    P9SITE
     C                     MOVEL*BLANK    P9SECT
     C                     CALL 'AL#R69'
     C                     PARM           P1BLK   2
     C                     PARM           P9SORT  50
     C                     PARM           P9SITE  1
     C                     PARM           P9SECT  2
     C                     MOVELP9SORT    W1#K01
      *列　昇順降順
     C                     MOVE W1TKR3    A       20
     C                     SELEC
     C           P9SITE    WHEQ '1'
     C                     MOVELW1TKR3    W1#K02           昇順
     C           P9SITE    WHEQ '2'
     C           100       SUB  A         A                降順
