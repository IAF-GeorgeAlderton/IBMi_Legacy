     C                     MOVE *BLANK    MSG
      *
     C           D@BARC    IFEQ *BLANK
     C  N99                MOVELER,7      MSG
     C                     SETON                     6199
     C                     ENDIF
      * UPLOAD AC#PP2F
     C                     MOVELD@BARC    P@ASN
     C                     CALL 'AC#R24'
     C                     PARM           P@ASN   8
      * CHECK BARCODE
     C           D@BARC    CHAINAC#PP2F              90
     C           *IN90     IFEQ *ON
     C  N99                MOVELER,1      MSG
     C                     SETON                     6199
     C                     ENDIF
      * CHECK CONSOLIDATED ASN
     C           *IN90     IFEQ *OFF
     C           *IN99     ANDEQ*OFF
     C           AFBIN     ANDNE99
     C  N99                MOVELER,8      MSG
     C                     SETON                     6199
     C                     ENDIF
      *
     C           *IN90     IFEQ *OFF
     C                     MOVE AFLBLD    @STR    1
     C**                   MOVE AFTOKU    K@TOKU
     C**                   MOVE AFNONY    WWNONY
     C                     MOVE AFNONY    K@NONY
     C                     MOVE AFNKOJ    K@NKOJ
     C**                   MOVE AFBIN     WWNOBN
     C                     MOVE AFNUKE    K@NUKE
     C                     Z-ADDAFSHDT    K@YMD
     C                     Z-ADDAFBIN     K@NOBN
      *
     C           K#14      SETLLAC#PL14
     C           *IN90     DOUEQ*ON
     C           K#14      READEAC#PL14                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BANOBN    ANDEQAFBIN
      *
     C                     MOVELBAODRN    K@ODRN
     C           K#2AI     CHAINAB#PL2A             N95
     C           *IN95     IFEQ *OFF
     C           D@TRAL    IFEQ *BLANK
     C                     MOVELACTRLR    D@TRAL
     C                     ENDIF
     C           D@SCAC    IFEQ *BLANK
     C                     MOVELACSCAC    D@SCAC
     C                     ENDIF
     C                     ENDIF
      *
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C           D@MPL     IFEQ *BLANK
     C           D@BLOL    ANDEQ*BLANK
     C  N99                MOVELER,4      MSG
     C                     SETON                     6399
     C                     ENDIF
      *
     C           D@TRAL    IFEQ *BLANK
     C  N99                MOVELER,2      MSG
     C                     SETON                     6299
     C                     ENDIF
      *
     C           D@SCAC    IFEQ *BLANK
     C  N99                MOVELER,5      MSG
     C                     SETON                     6599
     C                     ENDIF
      *
     C           D@PRT     IFLT '1'
     C           D@PRT     ORGT '9'
     C  N99                MOVELER,6      MSG
     C                     SETON                     6499
     C                     ENDIF
      * IF NO ERROR, (GOTO SCAN CHECK)
     C           *IN99     IFEQ *OFF
     C                     EXSR #SCK
     C           RRN1      IFGT *ZERO
     C                     MOVE '02'      @@ID
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *-------------------------------------------------------------
      *  SCAN CHECK
      *-------------------------------------------------------------
     C           #SCK      BEGSR
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     MOVE *ON       *IN32
     C                     WRITECTL01
     C                     MOVE *OFF      *IN32
      *
     C                     MOVE *BLANK    XXODRN 10
     C           D@BARC    SETLLAC#PP2F
     C           *IN80     DOUEQ*ON
     C           D@BARC    READEAC#PP2F                  80
     C           *IN80     IFEQ *OFF
     C           AFODRN    IFEQ XXODRN
     C                     ITER
     C                     ENDIF
     C                     MOVE AFODRN    XXODRN
      *
     C                     MOVE AFNONY    D@NONY
     C                     MOVE AFNKOJ    D@NKOJ
     C                     MOVE AFNUKE    D@NUKE
     C                     Z-ADDAFSHDT    D@SHDT
     C                     MOVE AFBIN     D@BIN
     C                     MOVE AFBIN     WNOBN   20
     C                     MOVE AFNONY    WNONY   40
     C                     MOVE AFNONY    XNONY   4
     C                     Z-ADDAFNONY    K@NONY
     C                     MOVE AFNKOJ    K@NKOJ
     C                     MOVELAFNUKE    K@NUKE
     C                     MOVE AFNKOJ    WNKOJ   1
     C                     MOVELAFNUKE    WNUKE   4
     C                     Z-ADDAFSHDT    K@YMD
     C                     Z-ADDAFBIN     K@NOBN
     C           K#14      SETLLAC#PL14
     C           *IN90     DOUEQ*ON
     C           K#14      READEAC#PL14                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BAODRN    ANDEQAFODRN
      *
     C                     MOVE BANONY    @@NONY
     C                     MOVE BANOBN    @@NOBN
     C                     Z-ADD*ZERO     @@QTY   90
     C           K#70      SETLLAC#PL70
     C           *IN91     DOUEQ*ON
     C           K#70      READEAC#PL70                  91
     C           *IN91     IFEQ *OFF
     C           EKSKJY    ANDEQ*BLANK
     C                     ADD  EKSRYO    @@QTY
     C                     ENDIF
     C                     ENDDO
      *
     C           @@QTY     IFLT BASRYO
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     MOVE BASHN1    S@PRT1
     C                     MOVE BASHN2    S@PRT2
     C                     MOVE BASHN3    S@PRT3
     C                     Z-ADD@@QTY     S@QTY2
     C                     Z-ADDBASRYO    S@QTY1
     C           BASRYO    SUB  @@QTY     S@QTY3
     C                     MOVE BATOKU    H@TOKU
     C                     MOVE BANONY    H@NONY
     C                     MOVE BANKOJ    H@NKOJ
     C                     MOVE BANUKE    H@NUKE
     C                     MOVE BAMHN1    H@MHN1
     C                     MOVE BAMHN2    H@MHN2
     C                     MOVE BAMHN3    H@MHN3
     C                     MOVE BAMHN4    H@MHN4
     C                     MOVE BAODRN    H@ODRN
     C                     MOVE BANOYY    H@NOYY
     C                     MOVE BANOMM    H@NOMM
     C                     MOVE BANODD    H@NODD
     C                     MOVE BANOBN    H@NOBN
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDDO
