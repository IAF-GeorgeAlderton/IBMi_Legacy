     C*
     C*--- 初期設定 ---*
     C*
     C  N05                Z-ADD0         GDTA    30
     C  N05                Z-ADD0         GHAK    40
     C  N05                Z-ADD0         NGBN1   30
     C  N05                Z-ADD0         NGBN2   30
     C  N05                Z-ADD0         NGBN3   30
     C  N05                Z-ADD0         NGBN4   30
     C  N05                Z-ADD0         HBN
     C  N05                SETON                     05
     C                     ADD  1         GDTA
     C                     ADD  CFMHKO    GHAK
     C*
     C*--- 遅れ便の計算 ---*
     C*
     C*-- 合成ＫＥＹ --*
     C           MHI       KLIST
     C                     KFLD           CFSYYY
     C                     KFLD           CFSYMM
     C                     KFLD           CFSYDD
     C                     Z-ADD0         A       30
     C                     Z-ADD0         B       30
     C                     Z-ADD0         C       20
     C                     SETOF                     10
     C           MHI       SETLLAGDPL121
     C           1         DO   *HIVAL
     C                     READ AGDPL121                 10
     C           *IN10     IFEQ '0'
     C           CFBYY2    IFEQ *ZERO
     C           CFBYY1    IFEQ F8KAYY
     C           CFBMM1    ANDEQF8KAMM
     C           CFBDD1    ANDEQF8KADD
     C                     SETON                     10
     C                     END
     C                     ELSE
     C           CFBYY2    IFEQ F8KAYY
     C           CFBMM2    ANDEQF8KAMM
     C           CFBDD2    ANDEQF8KADD
     C                     SETON                     10
     C                     END
     C                     END
     C           *IN10     IFEQ '0'
     C           F8MAEY    IFEQ 'S'
     C           F8MAEY    OREQ 'E'
     C                     ADD  1         A
     C                     ELSE
     C           F8HIRU    IFNE '*'
     C                     ADD  1         B
     C                     END
     C                     END
     C                     END
     C                     END
     C  N10                END
      *
     C           CFCIBI    DIV  2         C
     C                     MULT C         A
     C           B         MULT CFCIBI    B
     C                     ADD  B         A
     C           CFBYY2    IFEQ *ZERO
     C                     ADD  CFBBB1    A
     C                     ELSE
     C                     ADD  CFBBB2    A
     C                     END
     C                     SUB  CFSYBB    A
      *
     C           A         IFNE 0
     C           A         IFLT 0
     C                     Z-ADD1         A
     C                     END
     C                     END
     C           A         IFNE 0
     C           A         IFGE 13
     C                     ADD  1         HBN,13
     C                     ELSE
     C                     ADD  1         HBN,A
     C                     END
     C                     END
      *
     C           A         IFNE 0
     C           A         IFEQ 1
     C                     ADD  1         NGBN1
     C                     ELSE
     C           A         IFEQ 2
     C                     ADD  1         NGBN2
     C                     ELSE
     C           A         IFEQ 3
     C                     ADD  1         NGBN3
     C                     ELSE
     C                     ADD  1         NGBN4
     C                     END
     C                     END
     C                     END
     C                     END
     CL1                   EXCPTDT
