     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P@DTYM  60
     C                     PARM           P@PP01  1
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
     C                     Z-ADD*DATE     W@DATE
     C                     Z-ADDW@DTYM    W@NTYM  60
      * N+1
     C                     Z-ADDW@DTYM    W@P1YM
     C           W@DTMM    IFEQ 12
     C                     ADD  1         W@P1YY
     C                     Z-ADD1         W@P1MM
     C                     ELSE
     C                     ADD  1         W@P1MM
     C                     ENDIF
      * N-1
     C           W@DTMM    IFEQ 1
     C                     SUB  1         W@DTYY
     C                     Z-ADD12        W@DTMM
     C                     ELSE
     C                     SUB  1         W@DTMM
     C                     ENDIF
     C                     Z-ADDW@DTYM    W@M1YM
      * N-2
     C                     Z-ADDW@M1YM    W@M2YM
     C           W@M1MM    IFEQ 1
     C                     SUB  1         W@M2YY
     C                     Z-ADD12        W@M2MM
     C                     ELSE
     C                     SUB  1         W@M2MM
     C                     ENDIF
      * N-3
     C                     Z-ADDW@M2YM    W@M3YM
     C           W@M2MM    IFEQ 1
     C                     SUB  1         W@M3YY
     C                     Z-ADD12        W@M3MM
     C                     ELSE
     C                     SUB  1         W@M3MM
     C                     ENDIF
      * N WORK DAY
     C                     MOVELP@DTYM    K#DTYY
     C                     MOVE P@DTYM    K#DTMM
     C                     Z-ADD0         W@NWDY  31
     C                     EXSR #SB100
     C                     Z-ADDW@KAD     W@NWDY  31
      * N+1 WORK DAY
     C                     Z-ADDW@P1YY    K#DTYY
     C                     Z-ADDW@P1MM    K#DTMM
     C                     Z-ADD0         W@P1DY  31
     C                     EXSR #SB100
     C                     Z-ADDW@KAD     W@P1DY  31
      * N-1 WORK DAY
     C                     Z-ADDW@DTYY    K#DTYY
     C                     Z-ADDW@DTMM    K#DTMM
     C                     Z-ADD0         W@1WDY  31
     C                     EXSR #SB100
     C                     Z-ADDW@KAD     W@1WDY  31
      * N-2 WORK DAY
     C                     Z-ADDW@M2YY    K#DTYY
     C                     Z-ADDW@M2MM    K#DTMM
     C                     Z-ADD0         W@M2DY  31
     C                     EXSR #SB100
     C                     Z-ADDW@KAD     W@M2DY  31
      * N-3 WORK DAY
     C                     Z-ADDW@M3YY    K#DTYY
     C                     Z-ADDW@M3MM    K#DTMM
     C                     Z-ADD0         W@M3DY  31
     C                     EXSR #SB100
     C                     Z-ADDW@KAD     W@M3DY  31
      *６ヶ月前
     C                     Z-ADD*DATE     W6DATE
     C           W6DTMM    IFGE 7
     C                     SUB  6         W6DTMM
     C                     ELSE
     C                     SUB  1         W6DTYY
     C                     ADD  6         W6DTMM
     C                     ENDIF
      *
     C           *LOVAL    SETLLFCEPL011
     C                     READ FCEPL011                 80
     C           *IN80     DOWEQ'0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #SB400
     C                     ENDIF
     C                     READ FCEPL011                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------------------------*
      * AGDPP11                                     *
      *---------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C           KEYF8     KLIST
     C                     KFLD           K#DTYY  40
     C                     KFLD           K#DTMM  20
     C                     Z-ADD0         W@KAD   31
     C           KEYF8     SETLLAGDPL12
     C           KEYF8     READEAGDPL12                  80
     C           *IN80     DOWEQ'0'
     C           F8HIRU    IFEQ *BLANK
     C                     ADD  0.5       W@KAD
     C                     ENDIF
     C           F8YORU    IFEQ *BLANK
     C                     ADD  0.5       W@KAD
     C                     ENDIF
     C           KEYF8     READEAGDPL12                  80
     C                     ENDDO
      *
     C           KEYF8     SETLLABMPPL1
     C           KEYF8     READEABMPPL1                  80
     C           *IN80     DOWEQ'0'
     C                     Z-ADDLLKADO    W@KAD
     C           KEYF8     READEABMPPL1                  80
     C                     ENDDO
      *
     CSR         ESB100    ENDSR
      *---------------------------------------------*
      * FORECAST                                    *
      *---------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     Z-ADDA2SSYS    W@SSYS  50
     C           A2SYHZ    IFGT *DATE
     C                     Z-ADDA2KSYS    W@SSYS
     C                     ENDIF
     C                     Z-ADD0         P9GEKN
     C                     Z-ADD0         P9HIKN
     C                     Z-ADD0         P9KAD
     C                     CALL 'ABMR96'
     C                     PARM           A2BHB1  5
     C                     PARM           A2BHB2  5
     C                     PARM           A2BHB3  2
     C                     PARM           P9GEKN 120
     C                     PARM           P9HIKN 120
     C                     PARM           P9KAD   31
     C                     PARM           P9YMD3  80
     C                     PARM           P9KOS3  1
     C                     Z-ADDP9GEKN    W@GEKN 100
     C                     Z-ADDP9HIKN    W@HIKN 100
     C                     Z-ADDP9KAD     W@STDY  31
     C                     MOVELP9KOS3    W@KOS3  1
      *
     C           KEYQ5     KLIST
     C                     KFLD           K@DTYM  60
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C                     Z-ADDP@DTYM    K@DTYM
     C                     MOVEL'0'       W@ABB   1
     C                     Z-ADD0         W@FSMN  90
     C                     Z-ADD0         W@FSM1  90
     C                     Z-ADD0         W@FSRY  90
     C                     Z-ADD0         W@NSRY  90
     C                     Z-ADD0         W@USM1  90
     C                     Z-ADD0         W@USM2  90
     C                     Z-ADD0         W@USM3  90
     C           KEYQ5     SETLLABBPL061
     C           KEYQ5     READEABBPL061                 81
     C           *IN81     DOWEQ'0'
     C                     MOVEL'1'       W@ABB   1
     C                     Z-ADDQ5NNNM    W@FSMN  90
     C                     Z-ADDQ51NNM    W@FSM1  90
     C           Q5NNNM    IFGE Q51NNM
     C                     Z-ADDQ5NNNM    W@FSRY  90
     C                     ELSE
     C                     Z-ADDQ51NNM    W@FSRY  90
     C                     ENDIF
     C                     Z-ADDW@DTYM    W@URYM  60
     C                     EXSR #SB410
     C                     EXSR #SB411
     C           W@NKBN    IFEQ 'U'
     C                     Z-ADDW@DTYM    W@URYM  60
     C                     EXSR #SB420
     C                     ELSE
     C           Q5NNNM    IFGE Q51NNM
     C                     Z-ADDQ5NNNM    W@NSRY  90
     C                     ELSE
     C                     Z-ADDQ51NNM    W@NSRY  90
     C                     ENDIF
     C                     ENDIF
     C                     SELEC
     C           P@PP01    WHEQ '1'
     C           W@PP01    IFEQ '1'
     C                     EXSR #SB500
     C                     ENDIF
     C                     OTHER
     C                     EXSR #SB500
     C                     ENDSL
     C           KEYQ5     READEABBPL061                 81
     C                     ENDDO
      *
     C           W@ABB     IFEQ '0'
     C                     MOVEL'U'       W@NKBN  1
     C                     Z-ADD0         Q5TOKU
     C                     Z-ADD0         Q5NONY
     C                     MOVEL*BLANK    Q5NKOJ
     C                     MOVEL*BLANK    Q5NUKE
     C                     MOVEL*BLANK    Q5MHN1
     C                     MOVEL*BLANK    Q5MHN2
     C                     MOVEL*BLANK    Q5MHN3
     C                     MOVEL*BLANK    Q5MHN4
     C                     MOVELA2BHB1    Q5SHN1
     C                     MOVELA2BHB2    Q5SHN2
     C                     MOVELA2BHB3    Q5SHN3
     C                     Z-ADD0         Q5NTYM
     C                     Z-ADDW@DTYM    W@URYM  60
     C                     EXSR #SB430
     C                     Z-ADD0         W@FSRY  90
     C           P@PP01    IFNE '1'
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *---------------------------------------------*
      * FORECAST  USER M/F                          *
      *---------------------------------------------*
     CSR         #SB410    BEGSR
      *
     C           KEYS2     KLIST
     C                     KFLD           Q5TOKU
     C                     KFLD           Q5NONY
     C                     KFLD           K5NKOJ  1
     C                     KFLD           K5NUKE  4
     C                     MOVELQ5NKOJ    K5NKOJ
     C                     MOVELQ5NUKE    K5NUKE
     C                     MOVEL'U'       W@NKBN  1
     C                     MOVEL'0'       W@PP01  1
     C           KEYS2     CHAINABMPP011             23
     C           *IN23     IFEQ '0'
     C           S2SKJY    ANDEQ'D'
     C           S2SKHZ    ANDLE*DATE
     C                     SETON                     23
     C                     ENDIF
      *
     C           *IN23     IFEQ '1'
     C                     MOVEL*BLANK    K5NUKE
     C           KEYS2     CHAINABMPP011             23
     C           *IN23     IFEQ '0'
     C           S2SKJY    ANDEQ'D'
     C           S2SKHZ    ANDLE*DATE
     C                     SETON                     23
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN23     IFEQ '1'
     C                     MOVEL*BLANK    K5NKOJ
     C           KEYS2     CHAINABMPP011             23
     C           *IN23     IFEQ '0'
     C           S2SKJY    ANDEQ'D'
     C           S2SKHZ    ANDLE*DATE
     C                     SETON                     23
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN23     IFEQ '0'
     C                     MOVEL'1'       W@PP01
     C                     MOVEL'N'       W@NKBN
     C                     ENDIF
      *
     C           Q5NNNM    IFEQ 0
     C           Q51NNM    ANDEQ0
     C                     MOVEL'U'       W@NKBN
     C                     ENDIF
      *
     CSR         ESB410    ENDSR
      *---------------------------------------------*
      * SALES DATA                                  *
      *---------------------------------------------*
     CSR         #SB411    BEGSR
      * N-1
     C                     Z-ADDW@M1YY    @5DTYY
     C                     Z-ADDW@M1MM    @5DTMM
     C                     CALL 'ABMR41'
     C                     PARM           Q5TOKU
     C                     PARM           Q5NONY
     C                     PARM           Q5NKOJ
     C                     PARM           Q5NUKE
     C                     PARM           Q5MHN1
     C                     PARM           Q5MHN2
     C                     PARM           Q5MHN3
     C                     PARM           Q5MHN4
     C                     PARM           @5DTYY  40
     C                     PARM           @5DTMM  20
     C                     PARM           P9USRY  90
     C                     Z-ADDP9USRY    W@USM1  90
      * N-2
     C                     Z-ADDW@M2YY    @5DTYY
     C                     Z-ADDW@M2MM    @5DTMM
     C                     CALL 'ABMR41'
     C                     PARM           Q5TOKU
     C                     PARM           Q5NONY
     C                     PARM           Q5NKOJ
     C                     PARM           Q5NUKE
     C                     PARM           Q5MHN1
     C                     PARM           Q5MHN2
     C                     PARM           Q5MHN3
     C                     PARM           Q5MHN4
     C                     PARM           @5DTYY  40
     C                     PARM           @5DTMM  20
     C                     PARM           P9USRY  90
     C                     Z-ADDP9USRY    W@USM2  90
      * N-3
     C                     Z-ADDW@M3YY    @5DTYY
     C                     Z-ADDW@M3MM    @5DTMM
     C                     CALL 'ABMR41'
     C                     PARM           Q5TOKU
     C                     PARM           Q5NONY
     C                     PARM           Q5NKOJ
     C                     PARM           Q5NUKE
     C                     PARM           Q5MHN1
     C                     PARM           Q5MHN2
     C                     PARM           Q5MHN3
     C                     PARM           Q5MHN4
     C                     PARM           @5DTYY  40
     C                     PARM           @5DTMM  20
     C                     PARM           P9USRY  90
     C                     Z-ADDP9USRY    W@USM3  90
      *
     C                     Z-ADD0         W@GSRY 100
     C           W@USM1    ADD  W@USM2    W@GSRY
     C                     ADD  W@USM3    W@GSRY
     C                     Z-ADD0         W@KAD
     C           W@1WDY    ADD  W@M2DY    W@KAD
     C                     ADD  W@M3DY    W@KAD
     C           W@KAD     IFNE 0
     C           W@GSRY    DIV  W@KAD     W@NSRY
     C                     MULT 20        W@NSRY
     C                     ENDIF
      *
     CSR         ESB411    ENDSR
      *---------------------------------------------*
      * COMP  FORECAST - SALES                      *
      *---------------------------------------------*
     CSR         #SB420    BEGSR
      *
     C                     Z-ADD0         @5NNNM 100
     C           Q5NNNM    IFGE Q51NNM
     C                     Z-ADDQ5NNNM    @5NNNM
     C                     ELSE
     C                     Z-ADDQ51NNM    @5NNNM
     C                     ENDIF
      *
     C           @5NNNM    IFGE W@NSRY
     C                     Z-ADD@5NNNM    W@NSRY  90
     C                     MOVEL'N'       W@NKBN
     C                     ENDIF
      *
     CSR         ESB420    ENDSR
      *---------------------------------------------*
      * SALES DATA                                  *
      *---------------------------------------------*
     CSR         #SB430    BEGSR
      *
     C           KEYB12    KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C                     KFLD           W@M3YY
     C                     KFLD           W@M3MM
      *
     C           KEYB13    KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C                     Z-ADD0         W@NSRY  90
     C                     Z-ADD0         W@GSRY 100
     C                     Z-ADD0         W@USM1  90
     C                     Z-ADD0         W@USM2  90
     C                     Z-ADD0         W@USM3  90
     C           KEYB12    SETLLAB#PL071
     C           KEYB13    READEAB#PL071                 82
     C           *IN82     DOWEQ'0'
     C           B1NOYM    ANDLEW@M1YM
     C           B1SKJY    IFEQ 'D'
     C           B1SKHZ    ANDLE*DATE
     C                     ELSE
     C                     ADD  B1SRYO    W@GSRY
     C                     SELEC
     C           B1NOYM    WHEQ W@M1YM
     C                     ADD  B1SRYO    W@USM1
     C           B1NOYM    WHEQ W@M2YM
     C                     ADD  B1SRYO    W@USM2
     C           B1NOYM    WHEQ W@M2YM
     C                     ADD  B1SRYO    W@USM2
     C                     ENDSL
     C                     ENDIF
     C           KEYB12    READEAB#PL071                 82
     C                     ENDDO
      *
     C                     Z-ADD0         W@KAD
     C           W@1WDY    ADD  W@M2DY    W@KAD
     C                     ADD  W@M3DY    W@KAD
     C           W@KAD     IFNE 0
     C           W@GSRY    DIV  W@KAD     W@NSRY
     C                     MULT 20        W@NSRY
     C                     ENDIF
      *
     CSR         ESB430    ENDSR
      *---------------------------------------------*
      * FORECAST ABMWP12                            *
      *---------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEY81     KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
      *
     C                     CLEARABMWP121
     C                     Z-ADD*DATE     W1CRDT
     C                     Z-ADDQ5TOKU    W1TOKU
     C                     Z-ADDQ5NONY    W1NONY
     C                     MOVELQ5NKOJ    W1NKOJ
     C                     MOVELQ5NUKE    W1NUKE
     C                     MOVELQ5MHN1    W1MHN1
     C                     MOVELQ5MHN2    W1MHN2
     C                     MOVELQ5MHN3    W1MHN3
     C                     MOVELQ5MHN4    W1MHN4
     C                     MOVELQ5SHN1    W1SHN1
     C                     MOVELQ5SHN2    W1SHN2
     C                     MOVELQ5SHN3    W1SHN3
     C                     MOVEL*BLANK    W1OHN1
     C                     MOVEL*BLANK    W1OHN2
     C                     MOVEL*BLANK    W1OHN3
     C                     Z-ADDW@NSRY    W1NSRY
     C                     Z-ADDW@NTYM    W1NTYM
     C                     Z-ADDW@M1YM    W1URY1
     C                     Z-ADDW@M2YM    W1URY2
     C                     Z-ADDW@M3YM    W1URY3
     C                     MOVELW@NKBN    W1NKBN
     C                     MOVEL'0'       W1OMIT
     C           KEY81     CHAINABMPP811             41
     C           *IN41     IFEQ '0'
     C           CNSKJY    ANDEQ'D'
     C           CNSKHZ    ANDLE*DATE
     C                     SETON                     41
     C                     ENDIF
     C           *IN41     IFEQ '0'
     C                     MOVEL'1'       W1OMIT
     C                     ENDIF
      *立上６ヶ月は自動処理しない
     C           W1OMIT    IFEQ '0'
     C           A2TAHZ    IFGT W6DATE
     C                     MOVEL'2'       W1OMIT
     C                     ENDIF
     C                     ENDIF
      *３ヶ月以内の手動更新ありは自動処理しない
     C           W1OMIT    IFEQ '0'
     C           W@KOS3    IFEQ '1'
     C                     MOVEL'3'       W1OMIT
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADDW@FSMN    W1FSMN
     C                     Z-ADDW@FSM1    W1FSM1
     C                     Z-ADDW@USM1    W1USM1
     C                     Z-ADDW@USM2    W1USM2
     C                     Z-ADDW@USM3    W1USM3
     C                     Z-ADDW@NWDY    W1NWDY
     C                     Z-ADDW@P1DY    W1AWDY
     C                     Z-ADDW@1WDY    W11WDY
     C                     Z-ADDW@M2DY    W12WDY
     C                     Z-ADDW@M3DY    W13WDY
     C           W@NWDY    IFNE 0
     C           W@FSMN    DIV  W@NWDY    W1FSDN
     C                     ENDIF
     C           W@P1DY    IFNE 0
     C           W@FSM1    DIV  W@P1DY    W1FSD1
     C                     ENDIF
     C           W@1WDY    IFNE 0
     C           W@USM1    DIV  W@1WDY    W1USD1
     C                     ENDIF
     C           W@M2DY    IFNE 0
     C           W@USM2    DIV  W@M2DY    W1USD2
     C                     ENDIF
     C           W@M3DY    IFNE 0
     C           W@USM3    DIV  W@M3DY    W1USD3
     C                     ENDIF
      *
     C           W@NKBN    IFEQ 'N'
     C           W@NWDY    IFNE 0
     C           W@FSRY    DIV  W@NWDY    W1NSRD
     C                     ENDIF
     C                     ELSE
     C           W@NSRY    DIV  20        W1NSRD
     C                     ENDIF
      * PASS THROUGH
     C                     CALL 'ABMR1A'
     C                     PARM           W1SHN1
     C                     PARM           W1SHN2
     C                     PARM           W1SHN3
     C                     PARM           P@PAS   1
     C                     MOVELP@PAS     W1PAS
     C                     Z-ADDW@GEKN    W1GEKN
     C                     Z-ADDW@SSYS    W1SSYS
     C                     Z-ADDW@HIKN    W1HIKN
     C                     Z-ADDW@STDY    W1STDY
      *
     C                     WRITEABMWP121
      *
     CSR         ESB500    ENDSR
