     H            Y.
     F** UTLR51D ************************************************************
     F*  UTILITY - UTILITY - RETRIEVE PACKING LIST#                         *
     F*  WRITTEN: JW (SRA)   2025.05.07                                     *
     F*---------------------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR51D'
     F*                    PARM           $NOHZ   8
     F*                    PARM           $CUST   4
     F*                    PARM           $NONY   4
     F*                    PARM           $NKOJ   1
     F*                    PARM           $NUKE   4
     F*                    PARM           $BINN   2
     F*                    PARM           $RLHZ   8
     F*                    PARM           $ODRN  10
     F*                    PARM           $PICK#  9
     F*   IN  $NOHZ   8  SHIP DATE
     F*       $CUST   4  CUSTOMER
     F*       $NONY   4  DELIVERY
     F*       $NKOJ   1  FACTORY
     F*       $NUKE   4  DOCK
     F*       $BINN   2  BIN
     F*       $RLHZ   8  RELEASE DATE
     F*       $ODRN  10  ORDER#
     F*   OUT $PICK#  9  PICK SLIP#
      *--------------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           $NOHZ   8
     C                     PARM           $CUST   4
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $BINN   2
     C                     PARM           $RLHZ   8
     C                     PARM           $ODRN  10
     C                     PARM           $PICK#  9
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
      * CHECK 1
     C                     CALL 'UTLR51A'
     C                     PARM           $NOHZ   8
     C                     PARM           $CUST   4
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $BINN   2
     C                     PARM           $RLHZ   8
     C                     PARM           $ODRN  10
     C                     PARM           $PICK#  9
     C                     PARM           $RTN    1
      * CHECK 2
     C           $PICK#    IFEQ *BLANK
     C           $ODRN     ANDNE*BLANK
     C                     MOVE *BLANK    $ODRN            GET PL# BY PO#=BLANK
     C                     CALL 'UTLR51A'
     C                     PARM           $NOHZ   8
     C                     PARM           $CUST   4
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $BINN   2
     C                     PARM           $RLHZ   8
     C                     PARM           $ODRN  10
     C                     PARM           $PICK#  9
     C                     PARM           $RTN    1
     C                     ENDIF
      *
      * CHECK 3
     C           $PICK#    IFEQ *BLANK
     C                     MOVE *BLANK    $ODRN            GET PL# BY PO#=BLANK
     C                     CALL 'UTLR51A'
     C                     PARM           $NOHZ   8
     C                     PARM           $CUST   4
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $BINN   2
     C                     PARM           $RLHZ   8
     C                     PARM           $ODRN  10
     C                     PARM           $PICK#  9
     C                     PARM           $RTN    1
     C                     ENDIF
      * CHECK 4 (FORD)
     C           $PICK#    IFEQ *BLANK
     C                     MOVEL'11111'   $ODRN            GET PL# BY PO#=11111
     C                     CALL 'UTLR51A'
     C                     PARM           $NOHZ   8
     C                     PARM           $CUST   4
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $BINN   2
     C                     PARM           $RLHZ   8
     C                     PARM           $ODRN  10
     C                     PARM           $PICK#  9
     C                     PARM           $RTN    1
     C                     ENDIF
      * CHECK 5 (FORD)
     C           $PICK#    IFEQ *BLANK
     C                     MOVEL'11111'   $ODRN            GET PL# BY PO#=11111
     C                     MOVEL$RLHZ     $NOHZ            BY RELEASE DATE
     C                     CALL 'UTLR51A'
     C                     PARM           $NOHZ   8
     C                     PARM           $CUST   4
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $BINN   2
     C                     PARM           $RLHZ   8
     C                     PARM           $ODRN  10
     C                     PARM           $PICK#  9
     C                     PARM           $RTN    1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
