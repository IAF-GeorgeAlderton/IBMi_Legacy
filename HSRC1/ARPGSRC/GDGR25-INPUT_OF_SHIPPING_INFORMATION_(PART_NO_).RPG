     C****************************************************************
     C* MAIN
     C****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C*
     C           KEY01     KLIST
     C                     KFLD           D1ODER
     C                     KFLD           D1ITEM
     C                     KFLD           D1IKBN
     C                     KFLD           D1PARE
     C*================================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C           @STEP     CASEQ'#CHK2U  '#CHK2
     C           @STEP     CASEQ'#UPD    '#UPD
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*================================================================
     C*  INIT
     C*================================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     MOVE *BLANK    D1KBN
     C                     Z-ADD0         D1ODER
     C                     Z-ADD0         D1ITEM
     C                     Z-ADD0         D1IKBN
 %001C                     MOVE *BLANK    D1PARE
     C                     MOVE *BLANK    D1INVO
     C                     Z-ADD0         D1RECV
     C                     Z-ADD0         D1ASJ
     C                     Z-ADD0         D1SKO
     C                     Z-ADD0         D1TOY
     C                     MOVE *BLANK    D1ERR
     C*
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
     C*================================================================
     C*  DSP1
     C*================================================================
     C           #DSP1     BEGSR
     C                     EXFMTDSP01
     C                     MOVE '#CHK1   '@STEP
     C* < F1=ON >
     C           *INKA     IFEQ *ON
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C                     ENDSR
     C*================================================================
     C*  CHK1
     C*================================================================
     C           #CHK1     BEGSR
     C                     MOVEA'00000000'*IN,11           11 - 18
     C                     MOVEA'0'       *IN,19           19
     C                     SETOF                     99
     C                     MOVE *BLANK    D1ERR
     C*  UPDATE
     C           D1KBN     IFNE '0'
     C           D1KBN     ANDNE'2'
      *                         ..KOUSINN KUBUNN ERR..
     C  N99                MOVELMSG,1     D1ERR
     C  N99                SETON                     1199
     C                     ENDIF
     C*
     C           D1ODER    IFEQ 0
     C  N99                MOVELMSG,7     D1ERR
     C  N99                SETON                     1299
     C                     ENDIF
     C           D1ITEM    IFEQ 0
     C  N99                MOVELMSG,8     D1ERR
     C  N99                SETON                     1399
     C                     ENDIF
 %001C           D1PARE    IFEQ *BLANK
     C  N99                MOVELMSG,9     D1ERR
     C  N99                SETON                     1999
     C                     ENDIF
     C*
     C           KEY01     CHAINGDGPL25             N90
S1   C           *IN90     IFEQ *ON
 S2  C           D1KBN     IFEQ '0'                        CANCEL
      *                         ..MITOUROKU         ..
     C  N99                MOVELMSG,2     D1ERR
     C  N99                SETON                     1213
     C  N99                SETON                     1999
 X2  C                     ELSE
     C                     CLEARGDGPL251
 E2  C                     ENDIF
X1   C                     ELSE
 S2  C           IESKJY    IFEQ 'D'                        DELETE CODE
     C           IESKHZ    ANDLE*DATE
  S3 C           D1KBN     IFEQ '2'                        ADD
     C                     CLEARGDGPL251
  E3 C                     ENDIF
  S3 C           D1KBN     IFEQ '0'                        CANCEL
      *                         ..SAKUJYO ZUMI..
     C  N99                MOVELMSG,3     D1ERR
     C  N99                SETON                     1213
     C  N99                SETON                     1999
  E3 C                     ENDIF
 X2  C                     ELSE
  S3 C           D1KBN     IFEQ '2'                        ADD
      *                         ..TOUROKU ZUMI      ..
     C  N99                MOVELMSG,4     D1ERR
     C  N99                SETON                     1213
     C  N99                SETON                     1999
  E3 C                     ENDIF
 E2  C                     ENDIF
E1   C                     ENDIF
     C*
     C*  TUIKA JI NO CHECK
     C*
S1   C           D1KBN     IFEQ '2'                        ADD
      *                         ..MINYUURYOKU ..
 S2  C           D1INVO    IFEQ *BLANK
     C  N99                MOVELMSG,5     D1ERR
     C  N99                SETON                     1599
 E2  C                     ENDIF
     C*
     C           D1RECV    IFEQ 0
     C  N99                MOVELMSG,20    D1ERR
     C  N99                SETON                     1499
     C                     ELSE
     C           D1JYYY    IFLT 2000
     C  N99                MOVELMSG,6     D1ERR
     C  N99                SETON                     1499
     C                     ENDIF
     C           D1JYMM    IFLE 0
     C           D1JYMM    ORGT 12
     C  N99                MOVELMSG,6     D1ERR
     C  N99                SETON                     1499
     C                     ENDIF
     C           D1JYDD    IFLE 0
     C           D1JYDD    ORGT 31
     C  N99                MOVELMSG,6     D1ERR
     C  N99                SETON                     1499
     C                     ENDIF
     C                     ENDIF
     C*
     C           D1ASJ     IFEQ 0
     C  N99                MOVELMSG,10    D1ERR
     C  N99                SETON                     1699
     C                     ELSE
     C           D1ASJY    IFLT 2000
     C  N99                MOVELMSG,6     D1ERR
     C  N99                SETON                     1699
     C                     ENDIF
     C           D1ASJM    IFLE 0
     C           D1ASJM    ORGT 12
     C  N99                MOVELMSG,6     D1ERR
     C  N99                SETON                     1699
     C                     ENDIF
     C           D1ASJD    IFLE 0
     C           D1ASJD    ORGT 31
     C  N99                MOVELMSG,6     D1ERR
     C  N99                SETON                     1699
     C                     ENDIF
     C                     ENDIF
     C*
     C           D1SKO     IFEQ 0
     C  N99                MOVELMSG,11    D1ERR
     C  N99                SETON                     1799
     C                     ELSE
     C           D1SKOY    IFLT 2000
     C  N99                MOVELMSG,6     D1ERR
     C  N99                SETON                     1799
     C                     ENDIF
     C           D1SKOM    IFLE 0
     C           D1SKOM    ORGT 12
     C  N99                MOVELMSG,6     D1ERR
     C  N99                SETON                     1799
     C                     ENDIF
     C           D1SKOD    IFLE 0
     C           D1SKOD    ORGT 31
     C  N99                MOVELMSG,6     D1ERR
     C  N99                SETON                     1799
     C                     ENDIF
     C                     ENDIF
     C*
     C           D1TOY     IFEQ 0
     C  N99                MOVELMSG,12    D1ERR
     C  N99                SETON                     1899
     C                     ELSE
     C           D1TOYY    IFLT 2000
     C  N99                MOVELMSG,6     D1ERR
     C  N99                SETON                     1899
     C                     ENDIF
     C           D1TOYM    IFLE 0
     C           D1TOYM    ORGT 12
     C  N99                MOVELMSG,6     D1ERR
     C  N99                SETON                     1899
     C                     ENDIF
     C           D1TOYD    IFLE 0
     C           D1TOYD    ORGT 31
     C  N99                MOVELMSG,6     D1ERR
     C  N99                SETON                     1899
     C                     ENDIF
     C                     ENDIF
E1   C                     ENDIF
     C*
     C           *IN99     IFEQ *OFF
     C           D1KBN     IFEQ '0'                        CANCEL
     C                     SETON                     20
     C                     MOVELIEINVO    D1INVO
     C                     Z-ADDIERECV    D1RECV
     C                     Z-ADDIEASJ     D1ASJ
     C                     Z-ADDIESKO     D1SKO
     C                     Z-ADDIETOY     D1TOY
     C                     MOVELIEHIN1    D2HIN1
     C                     MOVELIEHIN2    D2HIN2
     C                     MOVELIEHIN3    D2HIN3
     C                     Z-ADDIESYOS    D2SYOS
     C                     Z-ADDIESBOX    D2SBOX
     C                     Z-ADDIETANK    D2TANK
     C                     MOVELIEHANY    D2HANY
     C                     ELSE
     C                     SETOF                     20
     C                     MOVEL*BLANK    D2HIN1
     C                     MOVEL*BLANK    D2HIN2
     C                     MOVEL*BLANK    D2HIN3
     C                     Z-ADD0         D2SYOS
     C                     Z-ADD0         D2SBOX
     C                     Z-ADD0         D2TANK
     C                     MOVEL*BLANK    D2HANY
     C                     ENDIF
     C                     MOVE '#DSP2   '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C                     ENDSR
     C*================================================================
     C*  DSP2
     C*================================================================
     C           #DSP2     BEGSR
     C                     EXFMTDSP02
     C                     MOVE '#CHK2   '@STEP
     C* < F3=ON >
     C           *INKC     IFEQ *ON
     C                     MOVEA*ALL'0'   *IN
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C* < F5=ON >
     C           *INKE     IFEQ *ON
     C                     MOVE '#CHK2U  '@STEP
     C                     ENDIF
     C                     ENDSR
     C*================================================================
     C*================================================================
     C*  CHK2
     C*================================================================
     C           #CHK2     BEGSR
     C                     MOVEA'00000000'*IN,21           21 - 28
     C                     SETOF                     99
     C                     MOVE *BLANK    D1ERR
     C*
     C           D2HIN1    IFEQ *BLANK
     C           D2HIN2    ANDEQ*BLANK
     C           D2HIN3    ANDEQ*BLANK
     C  N99                MOVELMSG,13    D1ERR
     C  N99                SETON                     2199
     C                     ENDIF
     C*                    Z-ADD0         D2SYOS
     C*                    Z-ADD0         D2SBOX
     C*                    Z-ADD0         D2TANK
     C*                    MOVEL*BLANK    D2HANY
     C**
     C           KEY02     KLIST
     C                     KFLD           D2HIN1
     C                     KFLD           D2HIN2
     C                     KFLD           D2HIN3
      *
     C                     SETOF                     50
     C           KEY02     CHAINFCEPL011             50
     C           *IN50     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     50
     C                     END
     C           *IN50     IFEQ '1'
     C  N99                MOVELMSG,14    D1ERR
     C  N99                SETON                     2199
     C                     ENDIF
     C*
     C           D2SYOS    IFEQ 0
     C  N99                MOVELMSG,15    D1ERR
     C  N99                SETON                     2299
     C                     ENDIF
     C*
     C           D2SBOX    IFEQ 0
     C  N99                MOVELMSG,16    D1ERR
     C  N99                SETON                     2399
     C                     ENDIF
     C*
     C           D2TANK    IFEQ 0
     C  N99                MOVELMSG,17    D1ERR
     C  N99                SETON                     2499
     C                     ENDIF
     C*
     C           D2HANY    IFEQ *BLANK
     C  N99                MOVELMSG,18    D1ERR
     C  N99                SETON                     2599
     C                     ENDIF
     C*
     C           D2HANY    IFEQ 'S'
     C           D2HANY    OREQ 'A'
     C                     ELSE
     C  N99                MOVELMSG,19    D1ERR
     C  N99                SETON                     2599
     C                     ENDIF
     C*
     C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK2U  '
     C                     MOVE '#UPD    '@STEP
     C                     ELSE
     C                     MOVE '#DSP2   '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
     C*================================================================
     C*  UPD
     C*================================================================
     C           #UPD      BEGSR
     C           KEY01     CHAINGDGPL25              90
     C           *IN90     IFEQ *OFF
     C           D1KBN     IFEQ '0'                        CANCEL
     C                     TIME           @@TIME
     C                     MOVE 'D'       IESKJY
     C                     Z-ADD*DATE     IESKHZ
     C                     Z-ADD*DATE     IEKOHZ
     C                     Z-ADD@TIME     IEKOTM
     C                     MOVE PPUSER    IEKOME
     C                     UPDATGDGPL251
     C                     ENDIF
     C           D1KBN     IFEQ '2'                        ADD
     C                     TIME           @@TIME
     C                     MOVE ' '       IESKJY
     C                     Z-ADD0         IESKHZ
     C                     Z-ADD*DATE     IEKOHZ
     C                     Z-ADD@TIME     IEKOTM
     C                     MOVE PPUSER    IEKOME
     C                     EXSR #MOVE
     C                     UPDATGDGPL251
     C                     ENDIF
     C                     ELSE
     C           D1KBN     IFEQ '2'                        ADD
     C                     TIME           @@TIME
     C                     MOVE ' '       IESKJY
     C                     Z-ADD0         IESKHZ
     C                     Z-ADD*DATE     IEKOHZ
     C                     Z-ADD@TIME     IEKOTM
     C                     MOVE PPUSER    IEKOME
     C*
     C                     EXSR #MOVE
     C                     WRITEGDGPL251
     C                     ENDIF
     C                     ENDIF
     C*
     C           D1KBN     IFEQ '0'                        CANCEL
     C                     MOVEL*BLANK    D1INVO
     C                     Z-ADD0         D1RECV
     C                     Z-ADD0         D1ASJ
     C                     Z-ADD0         D1SKO
     C                     Z-ADD0         D1TOY
     C                     ENDIF
     C                     MOVEL*BLANK    D1KBN
     C                     Z-ADD0         D1ODER
     C                     Z-ADD0         D1ITEM
     C                     Z-ADD0         D1IKBN
 %001C                     MOVE *BLANK    D1PARE
     C                     MOVEA*ALL'0'   *IN
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
     C*================================================================
     C           #MOVE     BEGSR
     C                     MOVE D1INVO    IEINVO
     C                     Z-ADDD1ODER    IEODER
     C                     Z-ADDD1ITEM    IEITEM
     C                     Z-ADDD1IKBN    IEIKBN
 %001C                     MOVE D1PARE    IEPARE
     C                     MOVELD2HIN1    IEHIN1
     C                     MOVELD2HIN2    IEHIN2
     C                     MOVELD2HIN3    IEHIN3
     C                     Z-ADDD2SYOS    IESYOS
     C                     Z-ADDD2SBOX    IESBOX
     C           D2SYOS    MULT D2SBOX    IESURY
     C                     Z-ADDD2TANK    IETANK
     C                     MOVELD2HANY    IEHANY
     C                     Z-ADDD1RECV    IERECV
     C                     Z-ADDD1ASJ     IEASJ
     C                     Z-ADDD1SKO     IESKO
     C                     Z-ADDD1TOY     IETOY
     C                     Z-ADD*DATE     IEINP
     C                     Z-ADD0         IENYUY
     C                     Z-ADD0         IENYUM
     C                     Z-ADD0         IENYUD
     C                     MOVE *BLANK    IENYUK
     C                     ENDSR
     C*================================================================
**  MSG (mｰﾎﾞﾓ ﾃx]n)
E-01 MUST INPUT < 0.2 > FOR UPDATE INSTRUCTION.
E-02 ITEM NO NOT FOUND IN ORDER SHEET.
E-03 THIS ITEM NO IS ALREADY CANCEL.
E-04 THIS ITEM NO IS ALREADY FINISH.
E-05 INPUT INVOICE NO.
E-06 INCORRECT DATE.
E-07 INPUT ORDER NO.
E-08 INPUT ITEM NO.
E-09 INPUT PALLETE NO.
E-10 INPUT ASJ PROCESSING DATE.
E-11 INPUT DEPARTURE JP PORT DATE.
E-12 INPUT CALCULATION ARRIVAL KSCHEDULE DATE.
E-13 INPUT PART NO.
E-14 PART NOT FOUND IN PART M/F.
E-15 INPUT QTY/BOX
E-16 INPUT BOX
E-17 INPUT UNIT PRICE
E-18 INPUT CARRY CODE
E-19 CARRY CODE IS WRONG
E-20 INPUT ORDER RECEIVED DATE.
