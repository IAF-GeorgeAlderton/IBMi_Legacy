     H            Y.
     F** ABMR4J *********************************************
     F* FCEPP40検索→売上実績取得
     F*   SAKAKI.       2019.12.26                          *
     F*******************************************************
     FFCEPL41 IF  E           K        DISK
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20WTITH
     I                                        3   40WTITM
     I                                        5   60WTITS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I            DS
     I                                        1   60@@YM
     I                                        1   40@YY
     I                                        5   60@MM
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
      *
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
      *
     C           *ENTRY    PLIST
     C                     PARM           PKMHN1  5
     C                     PARM           PKMHN2  5
     C                     PARM           PKMHN3  2
     C                     PARM           P9TAKO 112
     C                     PARM           P9DUPH  30
      *
     C                     MOVELPKMHN1    #KMHN1
     C                     MOVELPKMHN2    #KMHN2
     C                     MOVELPKMHN3    #KMHN3
     C                     Z-ADD0         P9TAKO
     C                     Z-ADD0         P9DUPH
     C                     EXSR #SB400
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------*
      * FCEPL41より完成品       *
      *---------------------------*
     CSR         #SB400    BEGSR
      *
     C           KEYMD1    KLIST
     C                     KFLD           #KMHN1  5
     C                     KFLD           #KMHN2  5
     C                     KFLD           #KMHN3  2
      *
     C           KEYMD1    SETLLFCEPL41
     C           KEYMD1    READEFCEPL41                  83
     C           *IN83     DOWEQ'0'
     C                     EXSR #SB700
     C           KEYMD1    READEFCEPL41                  83
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *---------------------------*
      * A-PICS 売上実績
      *---------------------------*
     CSR         #SB700    BEGSR
      * SALES DATA
     C                     CALL 'ABMR4C'
     C                     PARM           F4PRT1
     C                     PARM           F4PRT2
     C                     PARM           F4PRT3
     C                     PARM           P8TAKO 112
     C                     PARM           P8DUPH  30
     C                     ADD  P8TAKO    P9TAKO
     C                     ADD  P8DUPH    P9DUPH
      *
     CSR         ESB700    ENDSR
