      *
     C                     MOVEL*ZERO     A9X
     C                     Z-ADD9         Y
     C                     Z-ADD9         Z
     C                     DO   9
     C           A9,Y      IFNE *BLANK
     C                     MOVELA9,Y      A9X,Z
