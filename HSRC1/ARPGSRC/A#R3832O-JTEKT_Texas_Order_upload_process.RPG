      * ------
      *
      * PART#
     C                     Z-ADD*ZERO     X       30
     C                     Z-ADD*ZERO     Y       30
     C                     Z-ADD*ZERO     Z       30
     C                     MOVEL*BLANK    MHN
      *
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C           AY,X      OREQ ' '
     C                     LEAVE
     C                     END
     C           AY,X      IFEQ '-'
     C                     ITER
     C                     END
     C                     ADD  1         Z
     C                     MOVELAY,X      MHN,Z
     C                     ENDDO
      *
     C                     MOVEAMHN       AWMHNX
      *
      * KANBAN#
     C                     Z-ADD1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
      *
     C                     Z-ADDX         Y
     C                     MOVEL*BLANK    ID
     C                     Z-ADD*ZERO     Z
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C           AY,Y      IFEQ ','
     C           AY,Y      OREQ ' '
     C                     LEAVE
     C                     END
     C                     ADD  1         Z
     C                     MOVELAY,Y      ID,Z
     C                     ENDDO
     C                     MOVEAID        AWSBAN
      *
      * QTY/CONT
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
      *
     C                     Z-ADDX         Y
     C                     MOVEL*BLANK    A9
     C                     Z-ADD*ZERO     Z
      *
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C           AY,Y      IFEQ ','
     C           AY,Y      OREQ ' '
     C                     LEAVE
     C                     END
     C                     ADD  1         Z
     C                     MOVELAY,Y      A9,Z
     C                     ENDDO
      *
     C                     MOVEL*ZERO     A9X
     C                     Z-ADD9         Y
     C                     Z-ADD9         Z
     C                     DO   9
     C           A9,Y      IFNE *BLANK
     C                     MOVELA9,Y      A9X,Z
     C                     SUB  1         Z
     C                     END
     C                     SUB  1         Y
     C           Y         IFEQ *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVE @9C       @9      90
     C                     Z-ADD@9        AWSYOS
      *
      * ORDER QTY
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
      *
     C                     Z-ADDX         Y
     C                     MOVEL*BLANK    A9
     C                     Z-ADD*ZERO     Z
      *
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C           AY,Y      IFEQ ','
     C           AY,Y      OREQ ' '
     C                     LEAVE
     C                     END
     C                     ADD  1         Z
     C                     MOVELAY,Y      A9,Z
