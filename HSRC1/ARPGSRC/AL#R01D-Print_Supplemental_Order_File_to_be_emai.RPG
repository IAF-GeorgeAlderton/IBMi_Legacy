     H            Y.
     F** AL#R01D *******************************************
     F*  PRINT SUPPLEMENTAL ORDER DATA                     *
     F*  LEC     2020.02.10                                *
     F******************************************************
     FAL#WP01 IF  F     256            DISK
     FAL#PP21 IF  E           K        DISK
     FAB#PPDC IF  E           K        DISK
     FAL#PL06 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *
     E                    TBL     1   1 50
      *
     IAL#WP01 AA  01
     I                                        1 256 IALL
     I                                        1   1 IRECT
     I                                        2   2 ICADT
     I                                        3  32 ISUPI
     I                                       33  37 ISUPC
     I                                       38  39 IDOCK
     I                                       40  43 IKNB#
     I                                       44  55 IMHN
     I                                       44  48 IMHN1
     I                                       49  53 IMHN2
     I                                       54  55 IMHN3
     I                                       56  65 ILIAD
     I                                       66  75 ISTAD
     I                                       76  80 IQTBO
     I                                       81 100 ISUPN
     I                                      101 109 IMART
     I                                      110 118 ISURT
     I                                      119 126 IULDA
     I                                      127 134 ISHID
     I                                      135 140 ISHIT
     I                                      141 152 IORD#
     I                                      153 156 IBOX#
     I                                      157 160 IBOXT
     I                                      161 165 INAMC
     I                                      166 182 IINKK
     I                                      183 184 ILPOS
     I                                      185 194 INAM2
     I                                      195 196 INAM3
     I                                      197 198 IPALT
     I                                      199 208 INAD5
     I                                      209 210 INAD6
     I                                      211 255 IFILL
     I                                      241 250 IMAN#
     I                                      251 252 IBIN#
     I                                      256 256 ITERM
      *
      * EDITED PART NUMBER
     I            DS
     I                                        1  12 PART#
     I                                        1   5 MHN1
     I                                        6   6 DASH
     I                                        7  11 MHN2
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           PRT     1
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     READ AL#WP01                  90
     C           *IN90     DOWEQ'0'
     C           IRECT     IFEQ '2'
     C                     EXSR #SB400
     C           GETAAA    IFEQ '0'
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     READ AL#WP01                  90
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AL#PP02
      *-----------------------------------------------------
     CSR         #SB400    BEGSR
      *
     C                     MOVEL'0'       GETAAA  1
     C           IALL      SETLLAL#PL061
     C           IALL      READEAL#PL061                 88
     C           *IN88     DOWEQ'0'
     C           GETAAA    ANDEQ'0'
     C           CASKJY    IFEQ 'D'
     C           CASKHZ    ANDLESDATE
     C                     ELSE
     C                     MOVEL'1'       GETAAA
     C                     ENDIF
     C           IALL      READEAL#PL061                 88
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *-----------------------------------------------------
      *  WRITE DETAIL
      *-----------------------------------------------------
     C           #SB500    BEGSR
      *
     C           W@1STP    IFEQ *ON
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     MOVEL*OFF      W@1STP
     C                     ENDIF
      *
     C           INAMC     CHAINAL#PP211             26
     C           *IN26     IFEQ *OFF
     C           C2SKJY    ANDEQ'D'
     C           C2SKHZ    ANDLESDATE
     C                     SETON                     26
     C                     ENDIF
      *
     C           *IN26     IFEQ *OFF
     C                     MOVELC2NONY    INONY   4
     C                     ELSE
     C                     MOVEL*BLANKS   INONY
     C                     ENDIF
      *
     C           INAMC     IFEQ '60EXP'
     C                     MOVELIDOCK     INUKE   4 P
     C           INUKE     CHAINAB#PPDC              26
     C           *IN26     IFEQ *OFF
     C                     MOVELADNONY    INONY
     C                     ELSE
     C                     MOVEL*BLANKS   INONY
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVELISHID     SHIPDT  80
     C                     MOVELISHIT     SHIPTM  40
      *
     C                     MOVELIMHN1     MHN1
     C                     MOVELIMHN2     MHN2
      *
     C                     MOVELIBOX#     BOX#    40
     C                     MOVELIBOXT     BXTL    40
      *
     C                     EXCPT@DTL
     C                     MOVE 'Y'       PRT
      *
     C                     ENDSR
      *-----------------------------------------------------
      * INITIAL SET
      *-----------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     MOVEL'-'       DASH    1
     C                     TIME           WTIME
     C                     MOVEL*ON       W@1STP  1
      *
     C                     ENDSR
      *
      *-----------------------------------------------------
     OQPRINT  E   01           @HED
     O                         W#PGM     10
     O                         TBL,1     72
     O                                   87 'DATE'
     O                         SDATE Y   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O        E   02           @HED
     O                                   87 'TIME'
     O                         STIME     98 '  :  :  '
     O        E   03           @HED
     O                                   11 'SHIP DATE'
     O                                   18 'TIME'
     O                                   25 'ROUTE'
     O                                   34 'PLANT'
     O                                   43 'DELV CD'
     O                                   49 'DOCK'
     O                                   58 'ORDER #'
     O                                   67 'PL'
     O                                   81 'PART NUMBER'
     O                                   88 'KAN#'
     O                                   94 'BOX#'
     O                                   99 'TOTL'
     O                                  112 'MANIFEST#'
     O                                  120 'BIN#'
     O        E 1              @DTL
     O                         SHIPDTY   11
     O                         SHIPTM    18 ' 0:  '
     O                         ISURT     29
     O                         INAMC     34
     O                         INONY     42
     O                         IDOCK     48
     O                         IORD#     63
     O                         IPALT     67
     O                         PART#     82
     O                         IKNB#     88
     O                         BOX#  Z   94
     O                         BXTL  Z   99
     O                         IMAN#    113
     O                         IBIN#    119
** TBL
        << TOYOTA SUPPLEMENTAL ORDER UPLOAD >>
