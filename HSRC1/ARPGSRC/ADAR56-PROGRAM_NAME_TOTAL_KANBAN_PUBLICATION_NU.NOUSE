     C           KEY1      CHAINFCEPL011             21
     C           *IN21     IFEQ '0'
     C                     MOVE A2ZETI    CFZENO
     C           A2SYHZ    IFGT *DATE
     C                     MOVE A2KSYT    WSYOT            ﾌﾃﾆｬ
     C                     ELSE
     C                     MOVE A2SSYT    WSYOT            ﾌﾃﾆｬ
