     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     21
     C                     END
     C           *IN21     IFEQ '0'
      *
     C                     Z-ADD16        X       20
     C                     Z-ADD1         Y       20
     C           1         DO   15        Y
     C                     SETOF                     10
     C           X         SUB  Y         Z       20
     C                     MOVELCKHZ,Z    WYMD    80
     C           WYMD      IFGT *DATE
     C           CKQR,Z    IFEQ 'C'
     C           CKQR,Z    OREQ 'D'
     C           CKQR,Z    OREQ 'E'
     C                     SETON                     10
     C                     MOVE CKQR,Z    WKDAI
     C                     MOVE CKQT,Z    WTKRO
     C                     END
     C                     ELSE
      *
     C           CKKR,Z    IFEQ 'C'
     C           CKKR,Z    OREQ 'D'
     C           CKKR,Z    OREQ 'E'
