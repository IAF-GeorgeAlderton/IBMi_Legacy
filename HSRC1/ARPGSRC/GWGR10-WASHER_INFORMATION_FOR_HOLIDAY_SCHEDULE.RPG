     H            Y/
     F***************************************************
     F*   WASHER - INQUIRY
     F*                                                 *
     F***************************************************
     FFCEPL01 IF  E           K        DISK
     FMCENP13 IF  E           K        DISK
     FAKBPL08 IF  E           K        DISK
     FAB#PL18 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FABBPL02 IF  E           K        DISK
     FGWSHP01 O   E                    DISK
      *------------------------------------------------------------
     E                    CUST       10  4 0
      *------------------------------------------------------------
     I            DS
     I                                        1  40 CUST
     I                                        1   40CUST1
     I                                        5   80CUST2
     I                                        9  120CUST3
     I                                       13  160CUST4
     I                                       17  200CUST5
     I                                       21  240CUST6
     I                                       25  280CUST7
     I                                       29  320CUST8
     I                                       33  360CUST9
     I                                       37  400CUST10
     I            DS
     I                                        1   80BADATE
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I            DS
     I                                        1  12 MCPRT
     I                                        1   5 MCSHN1
     I                                        6  10 MCSHN2
     I                                       11  12 MCSHN3
     I            DS
     I                                        1   6 L1LOC
     I                                        1   1 L1TKR1
     I                                        2   3 L1TKR2
     I                                        4   5 L1TKR3
     I                                        6   6 L1TKR4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C                     EXSR #OUT
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#FCEP    KLIST
     C                     KFLD           L1SHN1
     C                     KFLD           L1SHN2
     C                     KFLD           L1SHN3
     C           K#MC      KLIST
     C                     KFLD           K@SHN1
     C                     KFLD           K@SHN2
     C                     KFLD           K@SHN3
     C           K#AB      KLIST
     C                     KFLD           K@SHN1
     C                     KFLD           K@SHN2
     C                     KFLD           K@SHN3
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C                     KFLD           K@DD    20
      *
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C           K#AGDX    KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
      *
     C           *LIKE     DEFN MCSHN1    K@SHN1
     C           *LIKE     DEFN MCSHN2    K@SHN2
     C           *LIKE     DEFN MCSHN3    K@SHN3
     C                     Z-ADD*YEAR     K@YY
      *
     C           *MONTH    ADD  1         K@MM
     C           K@MM      IFGT 12
     C                     ADD  1         K@YY
     C                     SUB  12        K@MM
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     W@2     20
     C                     EXSR #AGD
     C                     Z-ADD@@D       W@2
      *
     C                     ADD  1         K@MM
     C           K@MM      IFGT 12
     C                     ADD  1         K@YY
     C                     SUB  12        K@MM
     C                     ENDIF
     C                     EXSR #AGD
     C                     Z-ADD@@D       W@3     20
      *
     C                     ENDSR
      *------------------------------------------------------
      *  WORKING DAYS
      *------------------------------------------------------
     C           #AGD      BEGSR
      *
     C                     Z-ADD*ZERO     @@D     20
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C           K#AGD     READEAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     ADD  1         @@D
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR SUB FILE
      *------------------------------------------------------
     C           #OUT      BEGSR
      *
     C           *LOVAL    SETLLAKBPL08
      *--> LOCATION
     C           *IN80     DOUEQ*ON
     C                     READ AKBPL08                  80
      *
     C           *IN80     IFEQ *OFF
     C           L1SKJY    ANDNE'D'
     C           L1STYY    ANDEQ9999
     C           L1BMON    ANDEQ8990
     C                     CLEARWRKR
     C           K#FCEP    CHAINFCEPL01              90
     C           *IN90     IFEQ *OFF
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE L1SHN1    PART1
     C                     MOVE L1SHN2    PART2
     C                     MOVE L1SHN3    PART3
     C                     MOVE L1LOC     LOC
     C                     Z-ADDL1KSSU    @@QTY  110
     C           @@QTY     DIV  L1SYOS    SETB      H
      * DAILY USAGE
     C                     Z-ADD*ZERO     @QTY2  110
     C                     Z-ADD*ZERO     @QTY3  110
     C                     Z-ADD*ZERO     @QTY4  110
     C                     Z-ADD*ZERO     Y       20
     C           K#FCEP    SETLLMCENP13
     C           *IN97     DOUEQ*ON
     C           K#FCEP    READEMCENP13                  97
B01  C           *IN97     IFEQ *OFF
      *
     C                     MOVE MCSHN1    K@SHN1
     C                     MOVE MCSHN2    K@SHN2
     C                     MOVE MCSHN3    K@SHN3
      *
     C                     EXSR #RSLT
     C                     EXSR #FRC
     C                     ENDIF
     C                     ENDDO
      *
     C           @QTY2     DIV  10        @@QTY     H
     C           @@QTY     DIV  L1SYOS    DAYQ      H
     C           @QTY3     DIV  W@2       @@QTY     H
     C           @@QTY     DIV  L1SYOS    JUL       H
     C           @QTY4     DIV  W@3       @@QTY     H
     C           @@QTY     DIV  L1SYOS    AUG       H
     C                     WRITEWRKR
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   RESULT
      *------------------------------------------------------
     C           #RSLT     BEGSR
      *
     C                     Z-ADD*YEAR     K@YY
     C                     Z-ADD*MONTH    K@MM
     C                     Z-ADD*DAY      K@DD
     C                     Z-ADD*ZERO     @CNT    20
     C                     Z-ADD*ZERO     Y       20
      *
     C           K#AGDX    SETGTAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C                     ADD  1         @CNT
     C           @CNT      IFEQ 10
     C                     Z-ADDF8KAYY    K@YY
     C                     Z-ADDF8KAMM    K@MM
     C                     Z-ADDF8KADD    K@DD
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           K#AB      SETLLAB#PL18
     C           *IN90     DOUEQ*ON
     C           K#MC      READEAB#PL18                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
      *
     C           BADATE    IFGT *DATE
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  BASRYO    @QTY2
     C           BATOKU    LOKUPCUST                     10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         Y
     C           Y         IFLE 10
     C                     MOVE BATOKU    CUST,Y
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   FORECAST
      *------------------------------------------------------
     C           #FRC      BEGSR
      *
     C           K#MC      SETLLABBPL02
     C           *IN90     DOUEQ*ON
     C           K#MC      READEABBPL02                  90
     C           *IN90     IFEQ *OFF
     C                     ADD  Q51NNM    @QTY3
     C                     ADD  Q52NNM    @QTY4
     C           Q5TOKU    LOKUPCUST                     10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         Y
     C           Y         IFLE 10
     C                     MOVE Q5TOKU    CUST,Y
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
