 |   C                     MOVE *BLANK    P@LOC2
 |   C                     MOVE *BLANK    P@LOCH
 |   C                     MOVE *BLANK    P@LOC3
JW3  C                     ENDIF
      *
JW3  C* SORT CODE
 |   C                     MOVELWKSHN1    P@SHN1
 |   C                     MOVELWKSHN2    P@SHN2
 |   C                     MOVELWKSHN3    P@SHN3
 |   C                     MOVELP@SHN     $SHIN
 |   C                     CALL 'UTLR57'
 |   C                     PARM           $SHIN  12
 |   C                     PARM           $SRTN  20
 |   C                     PARM           $SRT#  20
 |   C                     PARM           $RTN    1
JW5   * MERGE FLD1 & FLD2
 |   C                     MOVEL$SRTN     $FLD1     P
 |   C                     MOVEL$SRT#     $FLD2     P
 |   C                     CALL 'UTLC11'
 |   C                     PARM           $FLD1 128
 |   C                     PARM           $FLD2 128
 |   C                     PARM           $FLD3 128
 |   C                     MOVEL$FLD3     P@SRT   7
 |    *
 |   C**                   MOVEL$SRTN     P@SRT   7
 |   C**                   MOVEL$SRT#     LTR3    3
JW5  C**                   MOVE LTR3      P@SRT
      *
     C                     ENDDO
      *
     C                     ENDSR
