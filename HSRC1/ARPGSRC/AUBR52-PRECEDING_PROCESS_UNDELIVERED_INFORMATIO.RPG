     C           SUM       TAG
     C           @YN       IFEQ 'X'
     C           @YN       OREQ 'Z'
     C           AIG       IFNE *ZERO
     C           @KCODE    IFNE 9999
     C                     MOVE @KCODE    AIBUMN
     C                     MOVE @KCODE    AIB
     C                     END
     C                     MOVE OHZ1      AIYEAR
     C                     MOVE OHZ2      AIMNTH
     C                     MOVE OHZ3      AIDAYS
     C                     MOVE AIG       AIGOUK
