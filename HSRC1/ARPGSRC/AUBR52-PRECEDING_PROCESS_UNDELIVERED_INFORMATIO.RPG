     C                     SETON                     1199
     C                     GOTO $100S
     C                     END
     C                     END
     C*===== 工場コードチェック=====*
     C           @KCODE    IFNE 9999
     C           @KCODE    CHAINFGBPL011             10
     C           *IN10     IFEQ '1'
