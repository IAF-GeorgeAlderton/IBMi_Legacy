     C                     SETON                       99
     C                     GOTO $100S
     C                     END
     C                     MOVE @KCODE    #KCODE
     C           #KEY      CHAINAH#TL161             71
     C           *IN71     IFEQ '1'
     C                     SETON                     1099
     C                     MOVEL$MSG,6    @ERR
     C                     GOTO $100S
     C                     END
     C                     END
     C*===== 条件のチエック=====*
     C           @JOKEN    IFNE 'A'
     C           @JOKEN    IFNE 'B'
     C           @JOKEN    IFNE 'C'
