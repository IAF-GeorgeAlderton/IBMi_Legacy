     F*** FCHR37 *******************************************
     F* MACHINE ABILITY M/F INQUIRY                                 *
     F*            M-OKUDA             1983.06.16          *
     F******************************************************
     FFCHPW37 CF  E                    WORKSTN
     FFCHPL11 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     E                    ER      1   7 60               d[-xlﾈbﾆﾞ
     I            DS
     I                                        1   80SHIZK
     I                                        1   40M8SKYY
     I                                        5   60M8SKMM
     I                                        7   80M8SKDD
     I            DS
     I                                        1   80KHIZK
     I                                        1   40M8KOYY
     I                                        5   60M8KOMM
     I                                        7   80M8KODD
     I            DS
     I                                        1   3 KBAN
     I                                        1   1 K1
     I                                        2   2 K2
     I                                        3   3 K3
     C                     Z-ADD0         BMON
     C                     Z-ADD0         KHIZK
     C           STEP1     TAG
     C                     EXFMTFCHPW371
     C   KA                GOTO END
     C                     SETOF                     979899
     C           BMON      CHAINFGBPL011             99
     C           *IN99     IFEQ '1'
     C                     MOVE '1'       *IN97
     C                     MOVE ER,1      MSG
     C                     GOTO STEP1
     C                     ELSE
     C                     MOVELB2SMEI    BMEI   10
     C                     END
     C           KBAN      IFEQ *BLANK
     C                     MOVE '1'       *IN98
     C                     MOVE '1'       *IN99
     C                     MOVELER,2      MSG
     C                     GOTO STEP1
     C                     END
     C           K1        IFEQ *BLANK
     C                     MOVE '1'       *IN98
     C                     MOVE '1'       *IN99
     C                     MOVELER,3      MSG
     C                     GOTO STEP1
     C                     END
     C           K2        IFEQ *BLANK
     C                     MOVE '1'       *IN98
     C                     MOVE '1'       *IN99
     C                     MOVELER,4      MSG
     C                     GOTO STEP1
     C                     END
     C           K3        IFEQ *BLANK
     C                     MOVE '1'       *IN98
     C                     MOVE '1'       *IN99
     C                     MOVELER,5      MSG
     C                     GOTO STEP1
     C                     END
     C           KKEY      KLIST
     C                     KFLD           BMON
     C                     KFLD           KBAN
     C                     SETOF                     01
     C           KKEY      CHAINFCHPL111             01
     C           *IN01     IFEQ '1'
     C                     MOVE '1'       *IN98
     C                     MOVE '1'       *IN99
     C                     MOVE ER,6      MSG
     C                     GOTO STEP1
     C                     END
     C           M8SKJY    IFEQ 'D'
     C           SHIZK     IFLE *DATE
     C                     MOVE '1'       *IN98
     C                     MOVE '1'       *IN99
     C                     MOVE ER,7      MSG
     C                     GOTO STEP1
     C                     END
     C                     END
     C                     EXFMTFCHPW372
     C                     MOVE *BLANK    KBAN
     C                     Z-ADD0         BMON
     C                     GOTO STEP1
     C           END       TAG
     C                     SETON                     LR
**
E-01 SECTION CODE YOU INPUT DOESN'T EXIST
E-02 MACHINE NO. ISN'T INPUT
E-03 THE FIRST COLUMN OF MACHINE NO. IS BLANK
E-04 THE SECOND COLUMN OF MACHINE NO. IS BLANK
E-05 THE THIRD COLUMN OF MACHINE NO. IS BLANK
E-06 MACHINE ABILITY M/F DOESN'T EXIST
E-07 MACHINE ABILITY M/F IS ELIMINATED
