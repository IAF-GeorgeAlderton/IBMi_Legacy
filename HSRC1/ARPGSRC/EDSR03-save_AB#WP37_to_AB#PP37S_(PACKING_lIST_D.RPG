     H            Y.
     F** EDSR03 ********************************************
     F*  SAVE AB#WP37 TO AB#PP37S (PACKING LIST DATA)      *
     F*  WRITTEN: JW (SRA)   2024.03.18                    *
     F*----------------------------------------------------*
     FAB#WP37 IF  E                    DISK
     FAB#PP37SO   E                    DISK
      *--------------------------------------------------------
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
      * INITIAL SETTING
     C                     TIME           SDATE
      *
      * SAVE AB#WP37 --------------------------------------
     C                     DO   *HIVAL
     C                     READ AB#WP37                  98
     C   98                LEAVE
      *
     C                     SELEC
     C           A7BARC    WHNE *BLANK
     C                     EXSR #HDR
     C           A7PART    WHNE *BLANK
     C                     EXSR #PRT
     C           A7TBOX    WHNE 0
     C                     EXSR #TRL
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------------
      * SAVE HEADER
      *--------------------------------------------------------
     C           #HDR      BEGSR
      *
     C                     Z-ADDTODAY     S7CRHZ
     C                     Z-ADDNOW       S7CRTM
     C                     MOVEL#USER     S7CRUS
     C                     MOVELA7BARC    S7SERL
     C                     MOVEL'H'       S7TYP
     C                     Z-ADDA7TOKU    S7TOKU
     C                     Z-ADDA7NONY    S7NONY
     C                     MOVELA7NKOJ    S7NKOJ
     C                     MOVELA7NUKE    S7NUKE
     C                     Z-ADDA7DEDT    S7NOHZ
     C                     Z-ADDA7DETM    S7NOBN
     C                     MOVELA7ORD#    S7ODRN
     C                     WRITEAB#P37S1
      *
     C                     MOVELA7MAN#    S7MAN# 18
      *
     C                     ENDSR
      *--------------------------------------------------------
      * SAVE PART
      *--------------------------------------------------------
     C           #PRT      BEGSR
      *
     C                     MOVEL'P'       S7TYP
      *
     C                     SELEC
     C           S7TOKU    WHEQ 5149                       FORD
     C           A7EOR#    ANDEQ*BLANK
     C                     MOVEL'11111'   S7ODRN    P
     C           S7TOKU    WHEQ 3411                       TOYOTA
     C           A7EOR#    ANDEQ*BLANK
     C                     MOVELS7MAN#    S7ODRN
     C*****      S7TOKU    WHEQ 3315                       TOYOTA BOSHOKU
     C*****      A7EOR#    ANDEQ*BLANK
     C*****                MOVELS7MAN#    S7ODRN
     C*****      S7TOKU    WHEQ 4821                       SENSATA TECH
     C*****      A7EOR#    ANDEQ*BLANK
     C*****                MOVELS7MAN#    S7ODRN
     C                     OTHER
     C           A7EOR#    IFNE *BLANK
     C                     MOVELA7EOR#    S7ODRN
     C                     ENDIF
     C                     ENDSL
      *
     C           S7ODRN    IFEQ *BLANK
     C           S7MAN#    ANDNE*BLANK
     C                     MOVELS7MAN#    S7ODRN
     C                     ENDIF
      *
     C                     WRITEAB#P37S1
      *
     C                     ENDSR
      *--------------------------------------------------------
      * SAVE TRAILER
      *--------------------------------------------------------
     C           #TRL      BEGSR
      *
     C**                   Z-ADDTODAY     S7CRHZ
     C**                   Z-ADDNOW       S7CRTM
     C**                   MOVEL#USER     S7CRUS
     C**                   MOVELS7BARC    S7SERL
     C                     MOVEL'T'       S7TYP
     C**                   Z-ADDA7TOKU    S7TOKU
     C**                   Z-ADDA7NONY    S7NONY
     C**                   MOVELA7NKOJ    S7NKOJ
     C**                   MOVELA7NUKE    S7NUKE
     C**                   Z-ADDA7DEDT    S7NOHZ
     C**                   Z-ADDA7DETM    S7NOBN
     C**                   MOVELA7EOR#    S7ODRN
     C                     WRITEAB#P37S1
      *
     C                     ENDSR
