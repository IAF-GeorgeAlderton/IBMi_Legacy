TCHK1C*          *IN80     IFEQ '1'
TCHK1C           *INKK     IFEQ '1'
     C                     CALL 'GKBR30'  @ENTRY
     C           PERR      IFEQ '*'
     C                     SETON                     99
     C                     MOVELER,03     MSG
     C                     GOTO @SCR1
     C                     END
     C                     GOTO @SCR1
     C                     END
     C*
     C           @ZAIC     IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVELER,01     MSG
     C                     GOTO @SCR1
     C                     END
     C*
     C           @ZAIK     IFEQ 0
     C                     SETON                     0399
     C                     MOVELER,02     MSG
     C                     GOTO @SCR1
     C                     END
     C/SPACE 1
     C*****************************************************
     C* MO-NO3   mﾞｰj ﾈﾛhn
     C*****************************************************
     C           KEY       KLIST
     C                     KFLD           @ZAIC
     C                     KFLD           @ZAIK
     C                     EXSR #CLR2
     C                     Z-ADD0         A       50
     C           KEY       SETLLGKBNP211
     C                     DO   *HIVAL
     C                     SETOF                     30
     C           KEY       READEGKBNP211                 30
     C   30                GOTO STP1
     C                     ADD  1         A
     C           A         CABGT12        STP1
     C                     Z-ADDA         @NO,A
     C                     EXSR #SUB1
     C           STP1      TAG
     C  N30                END
     C                     XFOOT@JRY      #JRYO
     C                     XFOOT@SRY      #SRYO
     C           @NO,12    COMP 0                        70
     C*
     C           A         IFEQ 0
     C                     SETON                     99
     C                     MOVELER,03     MSG
     C                     GOTO @SCR1
     C                     END
     C/SPACE 1
