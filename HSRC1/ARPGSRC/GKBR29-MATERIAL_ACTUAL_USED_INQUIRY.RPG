     C* ROLL-UP
     C           *IN,81    IFEQ '1'
     C                     EXSR #RLUP
     C           *IN,99    IFEQ '1'
     C  N11      #JRYO     ADD  WJRY      #JRYO
     C  N11      #SRYO     ADD  WSRY      #SRYO
     C  N11                SETON                     11
     C                     MOVE '1'       *IN70
     C                     MOVE *ALL'-'   @LIN
