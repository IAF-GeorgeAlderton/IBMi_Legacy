     C*****************************************************
     C* MO-NO2   fﾞx]-1
     C*****************************************************
     C           @SCR1     TAG
     C                     EXFMTGKBPW291
     C                     MOVEA'00'      *IN,02
     C                     MOVEA'00'      *IN,10
     C                     MOVEA'0'       *IN,99
