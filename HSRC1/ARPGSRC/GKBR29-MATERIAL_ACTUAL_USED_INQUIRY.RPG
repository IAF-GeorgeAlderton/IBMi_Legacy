     C                     ENDSR
     C/SPACE 1
     C*****************************************************
     C* MO-NO8   SUBRUTN   ROLL-UP
     C*****************************************************
     C           #RLUP     BEGSR
     C           @KEY,12   CABEQ*BLANK    $RLUP          99
     C                     Z-ADD@NO,12    XXNO    50
     C                     MOVEL@KEY,12   #KEY
     C                     Z-ADD0         A
     C           SETKEY    KLIST
     C                     KFLD           W1ZAIC
     C                     KFLD           W1ZAIK
     C                     KFLD           W1HIN1
     C                     KFLD           W1HIN2
     C                     KFLD           W1HIN3
     C                     KFLD           W1SKYU
     C                     KFLD           W1JRYO
     C                     KFLD           W1SRYO
     C                     KFLD           W1STAN
     C           SETKEY    SETGTGKBNP211
     C                     DO   *HIVAL
     C           KEY       READEGKBNP211                 99
     C   99                GOTO $RLUP
     C                     ADD  1         A
     C           A         IFEQ 1
     C                     EXSR #CLR2
     C                     END
     C           XXNO      ADD  A         @NO,A
     C                     EXSR #SUB1
     C                     ADD  @JRY,A    WJRY
     C                     ADD  @SRY,A    WSRY
     C           A         CABGE12        $RLUP
     C                     END
     C           $RLUP     ENDSR
     C/SPACE 1
     C*****************************************************
     C* MO-NO9   SUBRUTN   ROLL-DOWN
     C*****************************************************
     C           #RLDN     BEGSR
     C           @KEY,1    CABEQ*BLANK    $RLDN          99
     C                     Z-ADD13        A
     C                     Z-ADD@NO,1     XXNO
     C                     MOVE @KEY,1    #KEY
     C           SETKEY    SETLLGKBNP211
     C                     DO   *HIVAL
     C                     READPGKBNP211                 99
     C   99                GOTO $RLDN
     C           W1ZAIC    CABNE@ZAIC     $RLDN      9999
     C           W1ZAIK    CABNE@ZAIK     $RLDN      9999
     C                     SUB  1         A
     C           A         IFEQ 12
     C                     EXSR #CLR2
     C                     END
     C           XXNO      SUB  1         @NO,A
     C                     Z-ADD@NO,A     XXNO
     C                     EXSR #SUB1
     C           WJRY      SUB  @JRY,A    WJRY
     C           WSRY      SUB  @SRY,A    WSRY
     C           A         CABLE1         $RLDN
     C                     END
     C           $RLDN     ENDSR
**  ER (ERROR-MESSAGE)
E-01 INPUT MATERIAL CODE
E-02 INPUT COMPLETION WIRE DIAMETER
