     F************************* ECSR02 ***/
     FECSPW02 CF  E                    WORKSTN
     FECSPL08 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     E                    ER      1  14 60               ERROR MESSAGE
     I            DS
     I                                        1   8 SDATE
     I                                        1   4 SYY
     I                                        5   6 SMM
     I                                        7   8 SDD
     I            DS
     I                                        1   8 EDATE
     I                                        1   4 EYY
     I                                        5   6 EMM
     I                                        7   8 EDD
     I            DS
     I                                        1   80EQSKHZ
     I                                        1   40EQSKYY
     I                                        5   60EQSKMM
     I                                        7   80EQSKDD
     I            DS
     I                                        1   80EQYOHZ
     I                                        1   40EQYOYY
     I                                        5   60EQYOMM
     I                                        7   80EQYODD
      *
     C           *ENTRY    PLIST
     C                     PARM           USER   10
      *
      *
     C                     MOVE *BLANK    SDATE
     C                     MOVE *BLANK    EDATE
     C           STEP1     TAG
     C                     EXFMTECSPW021
     C                     SETOF                     010299
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
      *
     C           SDATE     IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STEP1
     C                     ENDIF
      *
     C           EDATE     IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVE ER,2      MSG
     C                     GOTO STEP1
     C                     ENDIF
      *
     C           SMM       IFGT '12'
     C           SMM       ORLT '01'
     C           SDD       ORGT '31'
     C           SDD       ORLT '01'
     C                     SETON                     0199
     C                     MOVE ER,3      MSG
     C                     GOTO STEP1
     C                     ENDIF
      *
     C           EMM       IFGT '12'
     C           EMM       ORLT '01'
     C           EDD       ORGT '31'
     C           EDD       ORLT '01'
     C                     SETON                     0299
     C                     MOVE ER,3      MSG
     C                     GOTO STEP1
     C                     ENDIF
      *
     C           SDATE     IFGT EDATE
     C                     SETON                     010299
     C                     MOVE ER,3      MSG
     C                     GOTO STEP1
     C                     ENDIF
      *
     C           *INKE     IFNE '1'
     C                     GOTO STEP1
     C                     ENDIF
      *
     C                     MOVE SYY       SDATYY  40
     C                     MOVE SMM       SDATMM  20
     C                     MOVE SDD       SDATDD  20
      *
     C                     Z-ADD0         WSDAT   80
     C                     MOVE SDATE     WSDAT
     C                     Z-ADD0         WEDAT   80
     C                     MOVE EDATE     WEDAT
      *
     C           KEY1      KLIST
     C                     KFLD           SDATYY
     C                     KFLD           SDATMM
     C                     KFLD           SDATDD
      *
     C           KEY1      SETLLECSPL081
     C                     DO   *HIVAL
     C                     SETOF                     70
     C                     READ ECSPL081                 70
      *
     C           *IN70     IFEQ '1'
     C                     GOTO NDAT
     C                     ENDIF
      *
     C           *IN70     IFEQ '0'
     C           EQSKJY    IFEQ 'D'
     C           EQSKHZ    ANDLE*DATE
     C                     GOTO NDAT
     C                     ENDIF
     C           WEDAT     IFLT EQYOHZ
     C                     SETON                     70
     C                     GOTO NDAT
     C                     ENDIF
      *
     C           *IN10     IFEQ '0'
     C           *INOF     OREQ '1'
     C                     SETON                     1020
     C                     SETOF                     OF
     C                     TIME           WTIME   60
     C                     EXCPTHD
     C                     END
     C                     EXCPTDAT
      *
     C                     ENDIF
      *
     C           NDAT      TAG
     C  N70                ENDDO
      *
     C           *IN20     IFEQ '0'
     C                     SETON                     010299
     C                     MOVE ER,4      MSG
     C                     GOTO STEP1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
     OQPRINT  E  102           HD
     O                                   12 'PGM-ECSR02'
     O                                  131 '.....................'
     O        E  1             HD
     O                                  131 '.         .         .'
     O        E  1             HD
     O                                   89 'TIME'
     O                         WTIME     98 '  :  :  '
     O                                  131 '.         .         .'
     O        E  1             HD
     O                                   59 'DIE OUTGOING DATA LIST'
     O                                   89 'DATE'
     O                         UDATE Y   98
     O                                  104 'PAGE'
     O                         PAGE1 Z  108
     O                                  131 '.....................'
     O        E  1             HD
     O                         WSDAT     21 '    .  .  '
     O                                   24 '-'
     O                         WEDAT     36 '    .  .  '
     O                                  110 'DAMAGE SITVATION'
     O                                  118 'SHIFT'
     O        E  2             HD
     O                                   15 'NEW DIE NO.'
     O                                   25 'USE DAY'
     O                                   36 'NUMBER'
     O                                   51 'NACHINE NO.'
     O                                   60 'SECTION'
     O                                   67 'TEAM'
     O                                   77 'PROCESS'
     O                                   92 'MACHINE-GROUP'
     O                                  105 'INSTRUCTION'
     O                                  124 'INSTRUCTION'
     O        E  1             DAT
     O                         EQKAT1     6
     O                                    7 '-'
     O                         EQKAT2    11
     O                                   12 '-'
     O                         EQKAT3    13
     O                         EQYOYY    22
     O                                   23 '.'
     O                         EQYOMM    25
     O                                   26 '.'
