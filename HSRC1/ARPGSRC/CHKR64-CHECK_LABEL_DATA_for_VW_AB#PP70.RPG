     C*
     C                     EXSR #INIT
      *
     C                     SETON                     71
     C                     WRITEDSP01
     C                     EXFMTSFCTL1
     C                     SETOF                     71
     C                     MOVEA'0'       *IN,99
     C                     Z-ADD$$RRN     DSPRRN
     C                     SELEC
      * F3 END
     C           *INKC     WHEQ *ON
     C                     LEAVE
     C                     OTHER
     C                     EXSR #PROC
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*  INITIAL SETTING
     C*===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     EXCPTHD
     C*  SFLCLR
     C                     SETON                     82
     C                     WRITESFCTL1
     C                     SETOF                     82
     C                     Z-ADD0         RRN     40
     C                     Z-ADD0         ENDRRN  40
     C                     MOVE *BLANK    @@UMU   1        データ有無
     C*
     C*          1         SETLLAB#PL7I
     C*-------------------------
S1   C                     DO   *HIVAL
     C                     READ AB#PL7I                  90
     C   90                LEAVE
 S2  C           J8SKJY    IFEQ 'D'
     C                     ITER
 E2  C                     ENDIF
     C*
     C                     MOVELJ8PROF    @USRID
     C                     MOVELJ8NAME    @USRNM
