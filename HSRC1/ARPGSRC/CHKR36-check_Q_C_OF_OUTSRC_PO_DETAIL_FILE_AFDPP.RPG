     H            Y.
     F***CHKR36*****************************************************************
     F*  PROGRAM    : CHECK Q/C OF OUTSRC PO DETAIL FILE (AFDPP10)             *
     F*             : READ AFDPP10                                             *
     F*  WRITTEN    : 10/05/2018                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAFDPL18 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *---------------------------------------------------
     E                    MSG     1   2 40
     I            DS
     I                                        1  140@DATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ***********************************************************
     C                     EXSR @INIT
      *
     C           @FROM     SETLLAFDPL18
     C                     DO   *HIVAL
     C                     READ AFDPL18                  98
     C   98                LEAVE
      * END?
     C           ADKODT    IFGT @TO
     C                     LEAVE
     C                     ENDIF
      * SKIP?
     C           ADSKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      * GET Q/C
     C           KEY1      CHAINFCEPL01              99
     C           *IN99     IFEQ *OFF
     C           A2GSKD    ANDEQ'D'
     C           *IN99     OREQ *ON
     C                     MOVELMSG,1     @MSG
     C**                   EXSR #PRINT
     C                     ITER
     C                     ENDIF
      *
     C           A2SSYS    IFNE ADSYOS
     C                     MOVELMSG,2     @MSG
     C                     EXSR #PRINT
     C                     ITER
     C                     ENDIF
      *
     C                     ENDDO
      * SET RETURN CODE
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           @INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $FROM   8
     C                     PARM           $TO     8
     C                     PARM           $RTN    1
      *
     C           KEY1      KLIST
     C                     KFLD           ADPAR1
     C                     KFLD           ADPAR2
     C                     KFLD           ADPAR3
      *
     C                     MOVE *BLANK    $RTN
     C                     MOVEL$FROM     @FROM   80
     C                     MOVEL$TO       @TO     80
     C                     TIME           @DATE
     C                     Z-ADD0         SEQ#    50
     C                     Z-ADD88        LIN#    30
     C                     MOVE *BLANK    @MSG   30
      *
     C                     ENDSR
      ************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** OUTSRC PO DETAIL '
     O                                   60 'Q/C ERROR LIST **   '
     O                                   99 'DATE'
     O                         TODAY    102 '    .  .  '
     O                         NOW      112 '  :  :  '
     O                                  115 'P.'
     O                         PAGE  Z  119
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   14 'UPD_DATE'
     O                                   21 'TIME'
     O                                   32 'WORKER'
     O                                   39 'ORDER#'
     O                                   43 'BIN'
     O                                   48 'SUPP'
     O                                   53 'PART'
     O                                   72 'ZETI'
     O                                   79 'Q/C'
     O                                   88 'PART M'
     O                                   94 'MSG'
     O        E 1              @DTL
     O                         SEQ#  Z +000
     O                         ADKODT  +001 '    /  /  '
     O                         ADKOTM  +001 '0 :  :  '
     O                         ADWORK  +001
     O                         ADODNO  +001
     O                         ADBINN  +001
     O                         ADSUPP  +001
     O                         ADPAR1  +001
     O                         ADPAR2  +001
     O                         ADPAR3  +001
     O                         ADZETI  +005
     O                         ADSYOS1 +001
     O                         A2SSYS1 +003
     O                         @MSG    +003
** MSG
Q/C NOT FOUND!
Q/C NOT SAME WITH PART MASTER!'
