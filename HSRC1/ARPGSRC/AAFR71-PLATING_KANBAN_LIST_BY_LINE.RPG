     H            Y.
     F*** AAFR71 *************************************
     F*  PLATING KANBAN LIST BY LINE*
     F* .. TUNNEL KANBAN M/F FROM DATA SELECT ..*
     F*           H.ITO            88.02.25          *
     F*----------+-----+----------+-----------------------------------*
     F*2021.03.09|DCS. |T.MITSUI  | CHANGE WITH THE NUMBER OF FIGURES *
     F*          |     |          |          EXPANSION OF THE "KANBAN"*
     F****************************************************** AAFR71 ***
     FAAGTL05 IP  E           K        DISK
     FAAFWP70 O   F      80            DISK                      A
     IAAGTL051    01
     I                                              O4AKROL1
     C           *ENTRY    PLIST
     C                     PARM           PBMON   4        ﾎﾞy]
     C                     PARM           PKBN    1        ﾃｰnﾞjbﾎﾟ
     C                     PARM           PRAIN   1        [b]
     C                     MOVE PBMON     WBMON   40
     C/SPACE 1
     C           *INL1     IFEQ '1'
     C                     SETOF                     02
     C                     END
     C/SPACE 1
     C           *IN02     IFEQ '0'
     C           O4SKJY    IFEQ 'D'
     C           O4SKHZ    ANDLE*DATE
     C                     GOTO END
     C                     END
     C           O4STHZ    IFLE *DATE
     C                     GOTO END
     C                     END
     C/SPACE 1
     C           O4DTKO    IFEQ '2'
     C                     GOTO END
     C                     END
     C           O4SYOS    IFEQ 0
     C                     GOTO END
     C                     END
     C/SPACE 1
     C                     SETON                     02
     C           PRAIN     IFNE '*'
     C           O4RAIN    IFNE PRAIN
     C                     GOTO END
     C                     END
     C                     END
     C/SPACE 1
     C           WBMON     IFNE 9999
     C           PKBN      IFEQ '1'
     C           WBMON     IFNE O4MAKB
     C                     GOTO END
     C                     END
     C                     ELSE
     C           WBMON     IFNE O4KOCD
     C                     GOTO END
     C                     END
     C                     END
     C                     END
     C/SPACE 1
     C                     SETON                     U1
     C                     EXCPTDT
     C                     END
     C           END       TAG
     OAAFWP70 EADD             DT
     O                         O4SHIN    12
     O                         O4RAIN    13
     O                         O4KTSU    22
     O                         O4BARA    24
     O                         O4BARB    26
     O                         O4AKRO    32
     O                         O4SYOS    37
     O                                   39 '00'
     O                         O4MAIS    42
