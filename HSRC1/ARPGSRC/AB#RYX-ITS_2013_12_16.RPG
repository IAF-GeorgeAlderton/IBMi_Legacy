     FABBPW7L CF  E                    WORKSTN
     FABBPP7G UF  E           K        DISK                      A
     E                    ER      1  19 65
      *
      *
     I            DS
     I                                        1   1 TEST
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     I              '0123456789'          C         WKCKSU
      *----------------------------------------------------*
      *
      *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVE '01'      DSPSW   2
      *
     C                     MOVEL*BLANK    @KOSN
     C                     MOVEL*BLANK    @MCN#
      *
     CSR         #S100E    ENDSR
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     CSR         #S200E    ENDSR
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
      *
     C                     SETON                     LR
     C                     RETRN
      *
     CSR         #S300E    ENDSR
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTABBPW7L1
     C                     SETOF                     313233
     C                     SETOF                     343536
     C                     SETOF                     99
     C                     MOVEL*BLANK    @ERR
     C                     MOVEL*BLANK    @SIZE
      * F1
     C           *IN01     IFEQ '1'
     C                     MOVE '99'      DSPSW
     C                     GOTO #S210E
     C                     ENDIF
      * F12
     C           *IN12     IFEQ '1'
     C*                    CALL 'KB104R'
     C                     GOTO #S210E
     C                     ENDIF
      *
     C           @KOSN     IFEQ *BLANK
     C                     MOVELER,1      @ERR
     C                     SETON                     3199
     C                     GOTO #S210E
     C                     ENDIF
      *
     C           @KOSN     IFEQ '0'
     C           @KOSN     OREQ '1'
     C           @KOSN     OREQ '2'
     C                     ELSE
     C                     MOVELER,2      @ERR
     C                     SETON                     3199
     C                     GOTO #S210E
     C                     ENDIF
      *
     C           @MCN#     IFEQ *BLANK
     C                     MOVELER,1      @ERR
     C                     SETON                     3299
     C                     GOTO #S210E
     C                     ENDIF
     C*
     C           @MCN#     CHAINABBPP7G1             21
     C           *IN21     IFEQ '0'
     C           A#SKJY    ANDEQ'D'
     C                     SETON                     21
     C                     ENDIF
      *
     C           *IN21     IFEQ '1'
     C           @KOSN     IFEQ '0'
     C           @KOSN     OREQ '1'
     C                     MOVELER,5      @ERR
     C                     SETON                     3199
     C                     GOTO #S210E
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN21     IFEQ '0'
     C           @KOSN     IFEQ '2'
     C                     MOVELER,6      @ERR
     C                     SETON                     3199
     C                     GOTO #S210E
     C                     ENDIF
     C                     ENDIF
     C*
     C           @KOSN     IFEQ '0'
     C           @KOSN     OREQ '1'
     C           A#SIZE    IFEQ 'M6 '
     C                     MOVEL'1'       @SIZE
     C                     ENDIF
     C           A#SIZE    IFEQ 'M8 '
     C                     MOVEL'2'       @SIZE
     C                     ENDIF
     C           A#SIZE    IFEQ 'M10'
     C                     MOVEL'3'       @SIZE
     C                     ENDIF
     C           A#SIZE    IFEQ 'NUT'
     C                     MOVEL'4'       @SIZE
     C                     ENDIF
     C           A#SIZE    IFEQ 'TS '
     C                     MOVEL'5'       @SIZE
     C                     ENDIF
     C*
     C                     ENDIF
     C*
     C                     MOVEL'02'      DSPSW
      *
     CSR         #S210E    ENDSR
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C                     EXFMTABBPW7L2
     C                     SETOF                     313233
     C                     SETOF                     99
     C                     MOVEL*BLANK    @ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVEL*BLANK    @KOSN
     C                     MOVEL*BLANK    @MCN#
     C                     MOVE '01'      DSPSW
     C                     GOTO #S220E
     C                     ENDIF
      *
     C           @SIZE     IFEQ *BLANK
     C                     MOVELER,1      @ERR
     C                     SETON                     3399
     C                     GOTO #S220E
     C                     ENDIF
     C*
     C           @SIZE     IFNE '1'
     C           @SIZE     ANDNE'2'
     C           @SIZE     ANDNE'3'
     C           @SIZE     ANDNE'4'
     C           @SIZE     ANDNE'5'
     C                     MOVELER,1      @ERR
     C                     SETON                     3399
     C                     GOTO #S220E
     C                     ENDIF
      *
     C           *IN05     IFEQ '0'
     C                     GOTO #S220E
     C                     ENDIF
      *
     C           @MCN#     CHAINABBPP7G1             21
     C                     SELEC
     C           @KOSN     WHEQ '0'
     C                     EXSR #DLT
     C           @KOSN     WHEQ '1'
     C                     EXSR #UPD
     C           @KOSN     WHEQ '2'
     C                     EXSR #WRT
     C                     ENDSL
      *
     C                     MOVEL*BLANK    @KOSN
     C                     MOVEL*BLANK    @MCN#
     C                     MOVE '01'      DSPSW   2
      *
     CSR         #S220E    ENDSR
      *----------------------------------------------------*
      *DELETE                                              *
      *----------------------------------------------------*
     CSR         #DLT      BEGSR
      *
     C           *IN21     IFEQ '0'
     C                     MOVEL'D'       A#SKJY
     C                     Z-ADDWTIHZ     A#DATE
     C                     MOVELWJFB      A#TIME
     C                     MOVELW#USER    A#USER
     C                     MOVELW#PGM     A#PGID
     C*
     C                     UPDATABBPP7G1
     C                     ENDIF
      *
     CSR         EDLT      ENDSR
      *----------------------------------------------------*
      *CHANGE                                              *
      *----------------------------------------------------*
     CSR         #UPD      BEGSR
      *
     C           *IN21     IFEQ '0'
     C*
     C                     Z-ADDWTIHZ     A#DATE
     C                     MOVELWJFB      A#TIME
     C                     MOVELW#USER    A#USER
     C                     MOVELW#PGM     A#PGID
     C                     MOVEL@MCN#     A#MANO
     C*                    MOVEL@SIZE     A#SIZE
     C           @SIZE     IFEQ '1'
     C                     MOVEL'M6 '     A#SIZE
     C                     ENDIF
     C           @SIZE     IFEQ '2'
     C                     MOVEL'M8 '     A#SIZE
     C                     ENDIF
     C           @SIZE     IFEQ '3'
     C                     MOVEL'M10'     A#SIZE
     C                     ENDIF
     C           @SIZE     IFEQ '4'
     C                     MOVEL'NUT'     A#SIZE
     C                     ENDIF
     C           @SIZE     IFEQ '5'
     C                     MOVEL'TS '     A#SIZE
     C                     ENDIF
     C*
     C                     UPDATABBPP7G1
     C                     ENDIF
      *
     CSR         EUPD      ENDSR
      *----------------------------------------------------*
      *ADD                                                 *
      *----------------------------------------------------*
     CSR         #WRT      BEGSR
      *
     C                     CLEARABBPP7G1
     C*
     C                     Z-ADDWTIHZ     A#DATE
     C                     MOVELWJFB      A#TIME
     C                     MOVELW#USER    A#USER
     C                     MOVELW#PGM     A#PGID
     C                     MOVEL@MCN#     A#MANO
     C*                    MOVEL@SIZE     A#SIZE
     C*
     C           @SIZE     IFEQ '1'
     C                     MOVEL'M6 '     A#SIZE
     C                     ENDIF
     C           @SIZE     IFEQ '2'
     C                     MOVEL'M8 '     A#SIZE
     C                     ENDIF
     C           @SIZE     IFEQ '3'
     C                     MOVEL'M10'     A#SIZE
     C                     ENDIF
     C           @SIZE     IFEQ '4'
     C                     MOVEL'NUT'     A#SIZE
     C                     ENDIF
     C           @SIZE     IFEQ '5'
     C                     MOVEL'TS '     A#SIZE
     C                     ENDIF
     C*
     C           *IN21     IFEQ '0'
     C                     UPDATABBPP7G1
     C                     ELSE
     C                     WRITEABBPP7G1
     C                     ENDIF
      *
     CSR         EWRT      ENDSR
