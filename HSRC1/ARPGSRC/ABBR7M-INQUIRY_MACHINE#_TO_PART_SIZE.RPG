     H** ABBR7M *******************************************************
     H* INQUIRY MACHINE# TO PART SIZE                                   *
     H*
     H*  KIRI 15.09.15
     H*****************************************************************
     H            Y/                                    1
     FABBPW7M CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN1  KSFILE SFREC1
      * MACHINE MASTER          *
     FABBPP7G IF  E           K        DISK
      *****************************************************************
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *     <<
      *
     I           SDS
     I                                     *PROGRAM W@PGM
     I                                      244 253 W@WSID
     I                                      254 263 W@USER
     I                                      264 269 W@JBNO
     C*===============================================================
     C           *ENTRY    PLIST
     C                     PARM           P@MANO  3        MACHINE#
     C                     PARM           P@LOCT  6        LOCATION
     C*===============================================================
     C*  START  PROGRAM
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
     C                     TIME           @TIME
     C                     MOVEA*ALL'0'   *IN
      *
     C* SFLCLR
     C                     SETON                     72
     C                     WRITESFCTL1
     C                     SETOF                     72
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         ENDRRN  40
      *
     C           KEY01     KLIST
     C                     KFLD           P@MANO  3        MACHINE#
     C                     KFLD           P@LOCT  6        LOCATION
      *
     C           KEY01     SETLLABBPP7G
     C                     MOVE *BLANK    P@MANO           MACHINE#
     C                     MOVE *BLANK    P@LOCT           LOCATION
      *-----------------------------------
     C                     DO   *HIVAL
     C                     READ ABBPP7G                  90
     C   90                LEAVE
     C*
     C           A#SKJY    IFEQ 'D'                        DELETE CODE
     C                     ITER
     C                     ENDIF
     C*
     C                     MOVE A#MANO    S1MANO           MACHINE#
     C                     MOVE A#LOCT    S1LOCT           LOCATION
     C                     MOVE A#SIZE    S1SIZE           SIZE
     C*
     C                     ADD  1         RRN1
     C                     WRITESFREC1
     C*
     C                     ENDDO
      *-----------------------------------
     C                     Z-ADDRRN1      ENDRRN
     C                     Z-ADD1         RRN1             エラー
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
      *===============================================================
      *  画面１　表示
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     SETON                     70
     C           ENDRRN    IFNE 0
     C                     SETON                     71
     C                     ENDIF
     C                     WRITEDSP99
     C                     EXFMTSFCTL1
     C                     SETOF                     707199
     C                     Z-ADD$$RRN     RRN1
     C*----------
     C                     SELEC
     C* <F3> END
     C           *INKC     WHEQ *ON
     C           *INKL     OREQ *ON
     C                     MOVE '#END    '@STEP
     C* <F10> DOWNLOAD
     C           *INKJ     WHEQ *ON
     C                     CALL 'DNLC01'
     C* <PAGE UP/DOWN>
     C           *IN73     WHEQ *ON
     C           *IN73     OREQ *ON
     C                     MOVE '#DSP1   '@STEP
     C* <ENTER>
     C                     OTHER
     C           $RRN      IFNE 0
     C           $RRN      CHAINSFREC1               95
     C           *IN95     IFEQ *OFF
     C                     MOVE S1MANO    P@MANO           MACHINE#
     C                     MOVE S1LOCT    P@LOCT           LOCATION
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
     C                     ENDSR
      *===============================================================
      *===============================================================
