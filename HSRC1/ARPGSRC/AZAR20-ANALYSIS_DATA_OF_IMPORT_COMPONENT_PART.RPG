     C           ICSKJY    ANDEQ*BLANK
     C           ICINVO    ANDEQ*BLANK
     C           ICSEIH    ANDEQ'3'
     C           ICIFMK    ANDEQ*BLANK
      *
     C           K#IC      CHAINAZAPP51              85
     C           *IN85     IFEQ *OFF
     C           'FREEWAY' SCAN Z5MEMO                   86
     C  N86      'DISUSE'  SCAN Z5MEMO                   86
     C  N86      'AAC'     SCAN Z5MEMO                   86
     C   86                ITER
     C                     ENDIF
      *
     C                     ADD  1         I
     C                     MOVE ICODER    INV,I
     C                     EXSR #D35
     C                     Z-ADDF8YMD     DAT,I
     C           I         IFEQ 4
     C                     LEAVE
     C                     ENDIF
     C           ICODER    SETGTGDGPL181
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
      * SET ALL THE DATA FOR SCREEN BEFORE PRINTING
     C           *IN80     IFEQ *OFF
     C           *IN80     DOUEQ*ON
     C                     EXSR #SET1
     C                     ENDDO
     C                     ENDIF
      *
     C                     TIME           @@TIM   60
     C                     Z-ADD*ZERO     WRRN    40
     C                     MOVE *OFF      *IN98
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           S@INVQ    ADD  S@RCVQ    @@BOX
     C                     SUB  S@ABQY    @@BOX
     C                     ADD  S@ADJT    @@BOX
     C                     Z-ADD@@BOX     H@BAL
     C           S@MBQY    IFNE 0
     C           @@BOX     DIV  S@MBQY    S@DAYS    H
     C                     ENDIF
     C                     UPDATSFL01
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
     C  N98                MOVE *ON       *IN98
      *
     C                     EXSR #DTL
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  DETAIL INFORMATION
      *------------------------------------------------------
     C           #DTL      BEGSR
      *
     C                     MOVE *BLANK    AST
     C                     Z-ADD*ZERO     QTY
     C                     Z-ADD*ZERO     QAV
     C                     Z-ADD*ZERO     ORD
     C                     Z-ADD*ZERO     @O      20
     C           1         DO   @I        I
     C           INV,I     IFNE *BLANK
     C                     MOVE INV,I     K@INV
     C                     Z-ADDDAT,I     K@YMD
     C           K#G28X    SETLLGDGPL28
     C           *IN92     DOUEQ*ON
     C           K#G28X    READEGDGPL28                  92
     C           *IN92     IFEQ '0'
     C           IESKJY    ANDEQ' '
     C           IENYUK    ANDEQ' '
     C           IEHANY    ANDEQ'S'
     C                     ADD  IESBOX    QTY,I
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           1         DO   4         I
      *
     C           INV,I     IFNE *BLANK
     C                     MOVE INV,I     K@ORDN
     C           K#G18     SETLLGDGPL18
     C           *IN92     DOUEQ*ON
     C           K#G18     READEGDGPL18                  92
     C           *IN92     IFEQ '0'
     C           ICSKJY    ANDEQ' '
     C           ICIFMK    ANDEQ' '
     C           ICINVO    ANDEQ*BLANK
     C                     ADD  ICMAIS    QTY,I
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDDO
      *
      *
      * ON BOARD(ORDER BALANCE)
     C                     Z-ADD*ZERO     W@ONBD  30
     C           K#BTA     SETGTGDGPL19
     C           *IN92     DOUEQ*ON
     C           K#BTA     REDPEGDGPL19                  92
     C           *IN92     IFEQ *OFF
     C           ICSKJY    ANDEQ*BLANK
     C           ICINVO    IFNE *BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ADD  ICMAIS    W@ONBD
     C                     ENDIF
     C                     ENDDO
      *
     C           K#BTA     SETLLGDGPL27
     C           *IN95     DOUEQ*ON
     C           K#BTA     READEGDGPL27                  95
     C           *IN95     IFEQ *OFF
     C           IESKJY    ANDEQ*BLANK
     C           IEHANY    ANDEQ'S'
     C                     ADD  IESBOX    W@ONBD
     C                     ENDIF
     C                     ENDDO
      *
     C           1         DO   4         I
     C           S@MBQY    IFNE *ZERO
     C           QTY,I     DIV  S@MBQY    QAV,I     H
     C                     ENDIF
     C           QAV,I     IFLT 5
     C                     MOVE '*'       AST,I
     C                     ENDIF
     C                     ENDDO
      * ORDER
     C                     Z-ADD*ZERO     W@OQY   20
     C                     Z-ADD*ZERO     K@ORDR  60
      * SCANNED NOT ORDERED
     C                     Z-ADD*ZERO     W@SCAN  30
     C           K#BTA     SETLLGDGPL01
     C           *IN94     DOUEQ*ON
     C           K#BTA     READEGDGPL01                  94
     C           *IN94     IFEQ *OFF
     C           IASKJY    ANDEQ*BLANK
     C                     ADD  IAMAIS    W@SCAN
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD*ZERO     W@OQY   20
     C           K#BTA     SETLLGDGPL10
     C           *IN92     DOUEQ*ON
     C           K#BTA     READEGDGPL10                  92
     C           *IN92     IFEQ '0'
     C           IBSKJY    ANDEQ' '
     C                     ADD  IBMAIS    W@OQY
     C                     ENDIF
     C                     ENDDO
      *
     C                     ADD  W@SCAN    W@OQY
      *
     C           S@DAYS    IFLT 5
     C                     MOVE '*'       W@AST   1
     C                     ELSE
     C                     MOVE *BLANK    W@AST
     C                     ENDIF
      *
     C                     MOVE *BLANK    W@AST2
     C                     Z-ADD*ZERO     W@AVL
     C           S@MBQY    IFNE *ZERO
     C           W@OQY     DIV  S@MBQY    W@AVL   31H
     C                     ENDIF
     C           W@AVL     IFLT 5
     C                     MOVE '*'       W@AST2  1
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     WKBKAN
     C           K#BTA     SETLLMCENP131
     C           *IN93     DOUEQ*ON
     C           K#BTA     READEMCENP131                 93
     C           *IN93     IFEQ *OFF
     C                     ADD  MCSRYO    WKBKAN  90
     C                     ENDIF
     C                     ENDDO
      * CAL. ACTUAL QTY. PAR DAY
     C           WKBKAN    DIV  20        @@BKAN  70
     C                     MVR            @MVR    50
     C           @MVR      IFNE *ZERO
     C                     ADD  1         @@BKAN
     C                     ENDIF
      *
      * CAL. ACTUAL # OF KANBAN PAR DAY
     C           H@QTBX    IFNE *ZERO
     C           @@BKAN    DIV  H@QTBX    W#KAN   92
     C                     ELSE
     C                     Z-ADD*ZERO     W#KAN
     C                     END
     C*
     C           W#KAN     MULT H@LTIM    W#AKAN  92
     C           W#AKAN    ADD  0.9       AZAKAN  92
     C                     MOVE AZAKAN    @@2
     C                     Z-ADDAZAKAN    @@AKAN  50
     C           @@2       IFNE *ZERO
     C                     ADD  1         @@AKAN
     C                     ENDIF
      *
     C                     Z-ADDH@KMAX    W@KMAX  50
     C                     Z-ADDS@RCVQ    W@RCVQ  30
      *
     C                     XFOOTQTY       W@TOT   40
     C                     ADD  W@OQY     W@TOT
     C                     ADD  H@BAL     W@TOT     H
      * KANBAN AT MACHINE
     C                     Z-ADD*ZERO     W@FLQ   30
     C           K#BTA     CHAINBTAPP411             30
     C           *IN30     IFEQ '0'
     C           B4SKJY    ANDEQ*BLANK
     C                     Z-ADDB4MAIS    W@FLQ   30
     C                     MULT -1        W@FLQ
     C                     END
      * PLANNED
     C                     Z-ADD*ZERO     W@PLAN  30
     C           K#BTA5    SETLLBTAPL05
     C           *IN94     DOUEQ*ON
     C           K#BTA5    READEBTAPL05                  94
     C           *IN94     IFEQ *OFF
     C           BTSKJY    ANDEQ*BLANK
     C           *DAY      DO   31        A       30
     C                     Z-SUB#MH,A     LMINU   30
     C                     Z-ADD#PH,A     LPLUS   30
     C           LMINU     ADD  LPLUS     W@PLN   30
     C                     ADD  W@PLN     W@PLAN
     C                     ENDDO
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE H@BAL     @@2     20
     C                     Z-ADDH@BAL     @@7     70
     C           @@2       IFNE *ZERO
     C                     ADD  1         @@7
     C                     ENDIF
     C           @@7       ADD  W@FLQ     W@KANQ  50
     C                     ADD  W@ONBD    W@KANQ
     C                     ADD  W@SCAN    W@KANQ
     C                     ADD  W@PLAN    W@KANQ
     C*          W@KAN     IFLT *ZERO
     C*                    Z-ADDW@KAN     W@KANQ  30
     C*                    ELSE
     C*                    MOVE W@KAN     @@2     20
     C*                    Z-ADDW@KAN     W@KANQ
     C*          @@2       IFNE *ZERO
     C*                    ADD  1         W@KANQ
     C*                    ENDIF
     C*                    ENDIF
      *
     C           H@KMAX    SUB  W@KANQ    W@KANQ
     C*                    Z-ADDW@KAN     W@KANQ  30
     C*          W@KAN     IFGT *ZERO
     C*                    MOVE W@KAN     @@2     20
     C*          @@2       IFNE *ZERO
     C*                    ADD  1         W@KANQ
     C*                    ENDIF
     C********             ENDIF
      *
     C                     EXCPT@DTL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  PRINT - 2
      *------------------------------------------------------
     C           #PRT2     BEGSR
      * DATE(8 WEEKS)
     C                     Z-ADD*ZERO     @D1
     C                     Z-ADD*ZERO     @D2
     C                     Z-ADD*ZERO     @D3
     C                     Z-ADD*YEAR     K@YY
     C                     Z-ADD*MONTH    K@MM
     C                     Z-ADD*DAY      K@DD
     C           @STDT     IFLT *DATE
     C                     Z-ADD@STDT     K@YMD
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     I
     C                     Z-ADD*ZERO     @@CNT
     C                     Z-ADD*ZERO     OUT
     C                     Z-ADD*ZERO     @@ORD   60
     C                     MOVE *OFF      *IN91
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READ AGDPL12                  90
     C           *IN90     IFEQ *OFF
      *
      * SHIPPING INFORMATION
     C           K#29      SETLLGDGPL29
     C           *IN91     DOUEQ*ON
     C           K#29      READEGDGPL29                  91
     C           *IN91     IFEQ *OFF
     C           IESKJY    ANDEQ*BLANK
     C           IEHANY    ANDEQ'S'
     C           IENYUK    ANDEQ*BLANK
     C                     ADD  1         I
     C                     MOVE IEINVO    @IV,I
     C                     Z-ADD@@CNT     @D3,I
     C                     Z-ADDIETYMD    @D2,I
     C                     Z-ADD*ZERO     @@CNT
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
      *
      * ORDER INFORMATION
     C                     Z-ADDF8YMD     IN
     C                     MOVE '0'       ID
     C*          F8YMD     IFLT 20010420
     C                     Z-SUB35        DAYS
     **                    ELSE
     C*                    Z-SUB30        DAYS
     C*                    ENDIF
      *
     C                     CALL 'AFDR98'  P#98
     C                     Z-ADDOUT       K@OYMD
     C           K#17      SETLLGDGPL17
     C           *IN91     DOUEQ*ON
     C           K#17      READEGDGPL17                  91
     C           *IN91     IFEQ *OFF
     C           ICSKJY    ANDEQ*BLANK
     C           ICINVO    ANDEQ*BLANK
     C           ICSEIH    ANDEQ'3'
     C           ICIFMK    ANDEQ*BLANK
      *
     C           K#IC      CHAINAZAPP51              85
     C           *IN85     IFEQ *OFF
     C           'FREEWAY' SCAN Z5MEMO                   86
     C  N86      'DISUSE'  SCAN Z5MEMO                   86
     C  N86      'AAC'     SCAN Z5MEMO                   86
     C   86                ITER
     C                     ENDIF
      * SMALLEST ORDER NUMBER
     C           @@ORD     IFEQ *ZERO
     C                     Z-ADDICODER    @@ORD
     C                     ENDIF
      *
     C                     ADD  1         I
     C                     MOVE ICODER    @IV,I
     C                     Z-ADD@@CNT     @D3,I
     C                     Z-ADDF8YMD     @D2,I
     C                     Z-ADD*ZERO     @@CNT
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN91     IFEQ *ON
     C           K#17      SETLLGDGPL17
     C                     READ GDGPL17                  91
     C                     ENDIF
      *
     C           *IN91     IFEQ *ON
     C           F8YOBI    ANDEQ3
     C                     ADD  1         I
     C                     Z-ADD@@CNT     @D3,I
     C                     Z-ADDF8YMD     @D2,I
     C                     Z-ADD*ZERO     @@CNT
     C                     ENDIF
      *
     C           I         IFEQ 8
     C                     LEAVE
     C                     ENDIF
      *
     C           F8HIRU    IFEQ *BLANK
     C                     ADD  1         @@CNT
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD@D2       @D4
      *
     C                     Z-ADD*ZERO     WRRN    40
     C                     Z-ADD*ZERO     @@CNT
     C                     MOVE *OFF      *IN98
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
      *
     C           *IN98     IFEQ *OFF
     C                     EXCPT@HED2
     C                     ENDIF
     C  N98                MOVE *ON       *IN98
      *
     C                     EXSR #DTL2
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  PRINT - 2
      *------------------------------------------------------
     C           #DTL2     BEGSR
      *
      * ORDER
     C                     Z-ADD*ZERO     W@OQY   20
     C                     Z-ADD*ZERO     K@ORDR  60
     C           K#BTA     SETLLGDGPL01
     C           *IN94     DOUEQ*ON
     C           K#BTA     READEGDGPL01                  94
     C           *IN94     IFEQ *OFF
     C           IASKJY    ANDEQ*BLANK
     C********             ADD  IAMAIS    W@OQY
     C                     ENDIF
     C                     ENDDO
      *
     C           K#BTA     SETLLGDGPL10
     C           *IN92     DOUEQ*ON
     C           K#BTA     READEGDGPL10                  92
     C           *IN92     IFEQ '0'
     C           IBSKJY    ANDEQ' '
     C                     ADD  IBMAIS    W@OQY
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD*ZERO     @Q1
     C                     Z-ADD*ZERO     @Q2
     C                     Z-ADD*ZERO     @Q3
     C                     Z-ADD*ZERO     @Q6
     C                     Z-ADD*ZERO     @Q4
     C**                   Z-ADD*ZERO     @Q5
     C***        S@MBQY    MULT 5         W@5DYS  52
      * IN
     C           K#BTA     SETLLGDGPL27
     C           *IN95     DOUEQ*ON
     C           K#BTA     READEGDGPL27                  95
     C           *IN95     IFEQ *OFF
     C           IESKJY    ANDEQ*BLANK
     C           IEHANY    ANDEQ'S'
     C                     Z-ADD1         I
     C           IEINVO    LOKUP@IV,I                    10
     C   10                ADD  IESBOX    @Q1,I
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           @@ORD     CHAINGDGPL18              95
     C           *IN95     IFEQ *OFF
     C                     Z-ADDICODRY    K@YY
     C                     Z-ADDICODRM    K@MM
     C                     Z-ADDICODRD    K@DD
     C           K#G19     SETLLGDGPL19
     C           *IN95     DOUEQ*ON
     C           K#BTA     READEGDGPL19                  95
     C           *IN95     IFEQ *OFF
     C           ICSKJY    ANDEQ*BLANK
     C           ICINVO    ANDEQ*BLANK
     C           ICIFMK    ANDEQ*BLANK
      ** CALCULATE ARRAVAL DATE
     C                     MOVE ICODER    @@6     6
     C                     Z-ADD1         I
     C           @@6       LOKUP@IV,I                    10
     C   10                ADD  ICMAIS    @Q1,I
      *
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      * SCANNED
     C                     MOVEA'00000000'*IN,1
     C                     Z-ADD*ZERO     @@TOT   30
     C           W@OQY     IFNE *ZERO
     C                     Z-ADD*YEAR     ICODRY
     C                     Z-ADD*MONTH    ICODRM
     C                     Z-ADD*DAY      ICODRD
     C                     EXSR #D35
     C                     Z-ADDF8YMD     @@SYMD  80
     C                     Z-ADD*ZERO     II      20
      *
     C           1         DO   8         I
     C           @@SYMD    IFLT @D2,I
     C                     LEAVE
     C                     ENDIF
     C                     Z-ADDI         II      20
     C                     ENDDO
      *
     C           II        IFNE *ZERO
     C           II        DO   8         I
     C           @Q1,I     IFEQ *ZERO
     C           @@SYMD    ANDGE@D2,I
     C                     ADD  W@OQY     @Q1,I
     C                     MOVE *ON       *IN,I
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     XFOOT@Q1       @@TOT
     C           H@BAL     DIV  1         @ANS    30
     C                     MVR            @MVRX   52
     C           @MVRX     IFGT *ZERO
     C                     ADD  1         @ANS
     C                     ENDIF
     C                     ADD  @ANS      @@TOT
      *
     C*****      H@BAL     ADD  W@OQY     @@BAL   72
     C                     Z-ADDH@BAL     @@BAL   72
      *
     C           1         DO   8         I
      * OUT
     C           S@MBQY    MULT @D3,I     @Q2,I
      * BALANCE
     C           @@BAL     ADD  @Q1,I     @@BAL
     C                     SUB  @Q2,I     @@BAL
     C                     Z-ADD@@BAL     @Q3,I
     C           @Q3,I     DIV  1         @Q6,I
     C                     MVR            @MVRX   52
     C           @MVRX     IFGT *ZERO
     C                     ADD  1         @Q6,I
     C                     ENDIF
      *
     C           S@MBQY    IFNE *ZERO
     C           @Q3,I     DIV  S@MBQY    @Q4,I     H
     C                     ENDIF
     C**         @Q4,I     SUB  W@5DYS    @Q5,I
     C                     ENDDO
      *
     C                     ADD  1         @@CNT
     C           @@CNT     IFGT 11
     C                     EXCPT@HED2
     C                     Z-ADD1         @@CNT
     C                     ENDIF
      *
     C                     EXCPT@DTL2
      *
     C                     ENDSR
