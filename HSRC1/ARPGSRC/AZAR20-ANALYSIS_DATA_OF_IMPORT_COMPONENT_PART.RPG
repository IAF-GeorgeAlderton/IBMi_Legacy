     C                     ADD  1         @DAY
     C*          ICODER    IFLE 020303
     C*          @DAY      ANDEQ30
     C*          ICODER    ORGT 020303
     C           @DAY      IFEQ 35
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
