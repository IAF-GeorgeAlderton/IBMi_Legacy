     H            Y.
     F** UTLR05 ********************************************
     F*  PROGRAM: UTILITY - GET PREVIOUS LOCATION BY CURRENT LOCATION
     F*  WRITTEN: JW (SRA)                                 *
     F*           01/28/2016                               *
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR05'
     F*                    PARM           $LOC    4
     F*                    PARM           $SHN1   5
     F*                    PARM           $SHN2   5
     F*                    PARM           $SHN3   2
     F*                    PARM           $PLOC   4
     F*                    PARM           $RTN    1
     F*  IN  $LOC  :  4A LOCATION2-3
     F*      $SHN1 :  5A IAF PART1
     F*      $SHN2 :  5A IAF PART2
     F*      $SHN3 :  2A IAF PART3
     F*  OUT $PLOC :  4A PREVIOUS2-3
     F*      $RTN  :  1A RETURN CODE (BLANK/*)
     F******************************************************
     E                    LC         15  6
     I            DS
     I                                        1  90 LC
     I                                        1   6 CKNB01
     I                                        7  12 CKNB02
     I                                       13  18 CKNB03
     I                                       19  24 CKNB04
     I                                       25  30 CKNB05
     I                                       31  36 CKNB06
     I                                       37  42 CKNB07
     I                                       43  48 CKNB08
     I                                       49  54 CKNB09
     I                                       55  60 CKNB10
     I                                       61  66 CKNB11
     I                                       67  72 CKNB12
     I                                       73  78 CKNB13
     I                                       79  84 CKNB14
     I                                       85  90 CKNB15
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
      *
     C                     EXSR @INIT
      *
     C                     CALL 'AAMRSC'
     C                     PARM           $SHN1
     C                     PARM           $SHN2
     C                     PARM           $SHN3
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
      *
     C                     MOVEAPTKR      LC
     C                     EXSR #SRCH
      *
     C                     SETON                     LR
     C                     RETRN
      *=============================================================
      *                    SEARCH LOCATION
      *=============================================================
     C           #SRCH     BEGSR
      *
     C                     MOVE *BLANK    SVLOC   4
     C                     MOVE *BLANK    OK      2
     C           1         DO   15        IX      20
     C           LC,IX     IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
      *
     C           4         SUBSTLC,IX:2   FLD4    4
     C                     MOVELFLD4      FLD2    2
     C           FLD2      IFEQ '--'
     C                     ITER
     C                     ENDIF
      *
     C           FLD4      IFEQ $LOC
     C                     MOVE 'OK'      OK
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVELFLD4      SVLOC
      *
     C                     ENDDO
      *
     C           SVLOC     IFNE *BLANK
     C           OK        ANDEQ'OK'
     C                     MOVELSVLOC     $PLOC
     C                     ELSE
     C                     MOVE *BLANK    $PLOC
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     ENDSR
      *=============================================================
      *                    INITIAL PROCESS
      *=============================================================
     C           @INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $LOC    4
     C                     PARM           $SHN1   5
     C                     PARM           $SHN2   5
     C                     PARM           $SHN3   2
     C                     PARM           $PLOC   4
     C                     PARM           $RTN    1
      *
     C                     CLEAR$PLOC
     C                     CLEAR$RTN
      *
     C                     ENDSR
