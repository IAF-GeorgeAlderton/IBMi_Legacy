     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $CUST   4
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
      *
     C           $CUST     IFEQ *BLANK
