     C                     ENDIF
     C*
     C                     ADD  1         Z
     C                     MOVE W@DLV     DLV,Z
     C                     ADD  1         RRN0
     C*
     C                     CLEARSFL00
JW   C                     Z-ADDBBTOKU    S@CUST
     C                     Z-ADDBBNONY    S@NONY
     C                     MOVELBBNKOJ    S@NKOJ
     C                     MOVELBBNUKE    S@NUKE
