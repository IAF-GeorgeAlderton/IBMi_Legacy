     C                     MOVEL*ON       *IN56
     C                     MOVEL*ON       N#MODE
      *
     C           D@CUST    IFNE *ZERO
      *
JW2  C           D@CUST    IFEQ 9999
 |   C           0000      SETLLABBPL04
 |   C                     ELSE
 |   C           D@CUST    SETLLABBPL04
JW2  C                     ENDIF
      *
     C                     ELSE
     C           D@NONY    SETLLABBPL05
     C                     END
      *
     C           *IN90     DOUEQ*ON
      *
     C           D@CUST    IFNE *ZERO
      *
JW2  C           D@CUST    IFEQ 9999
 |   C                     READ ABBPL04                  90
 |   C                     ELSE
 |   C           D@CUST    READEABBPL04                  90
JW2  C                     ENDIF
      *
     C                     ELSE
     C           D@NONY    READEABBPL05                  90
     C                     END
     C   90                LEAVE
      *
     C           D@NONY    IFNE *ZERO
     C           D@NONY    IFNE Q5NONY
     C                     ITER
     C                     END
     C                     END
     C           D@NKOJ    IFNE *BLANK
     C           D@NKOJ    IFNE Q5NKOJ
