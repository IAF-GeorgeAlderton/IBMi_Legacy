     H            Y.
     F** ABBR7O3 *********************************
     F*  DOWNLOAD PRIORITY KANBAN LIST DATA      *
     F*  JW       2022.06.28                     *
JW1  F*  JW       2022.07.21 ADDED PARAMETER SHFT*
     F********************************************
     FABBWP72 IF  E           K        DISK
     FABBWP72AO   E           K        DISK
      *--------------------------------------------------
     E                    HDR     1  30 10
     I            DS
     I                                        1  14 W7PRT
     I                                        1   5 W7PRT1
     I                                        7  11 W7PRT2
     I                                       13  14 W7PRT3
     I            DS
     I                                        1   6 $LOCX
     I                                        1   1 $LOC1
     I                                        2   3 $LOC2
     I                                        4   5 $LOC3
     I                                        6   6 $LOC4
      *--------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           PSHFT   1
      *
     C                     EXSR #HDR
      *
     C                     DO   *HIVAL
     C                     READ ABBWP72                  98
     C   98                LEAVE
      *
     C                     EXSR #MOVE
      *
     C                     WRITEABBWP7A1
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
      * OUTPUT HEADER
      *-----------------------------------------------
     C           #HDR      BEGSR
      *
     C                     MOVELHDR,01    WADATE
     C                     MOVELHDR,02    WASIZE
     C                     MOVELHDR,03    WASEQN
     C                     MOVELHDR,04    WAEXNO
     C                     MOVELHDR,05    WALCID
     C                     MOVELHDR,06    WALOC4
JW   C                     MOVEL'OUTSRC'  WAMRK
     C                     MOVELHDR,07    WAPRT
     C                     MOVELHDR,08    WAKNID
     C                     MOVELHDR,09    WAKQTY
     C                     MOVELHDR,10    WAISDT
     C                     MOVELHDR,11    WAMCHN
     C                     MOVELHDR,12    WACMNT
     C                     MOVELHDR,13    WALOTS
     C                     MOVELHDR,14    WAKAN
     C                     MOVELHDR,15    WALOC
     C                     MOVELHDR,16    WAPRC
     C                     MOVELHDR,17    WAFIL1
     C                     MOVELHDR,18    WAFIL2
     C                     MOVELHDR,19    WAFIL3
     C                     MOVELHDR,20    WAFIL4
     C                     MOVELHDR,21    WAFIL5
     C                     MOVELHDR,22    WASHFT
      *
     C                     WRITEABBWP7A1
      *
     C                     ENDSR
      *-----------------------------------------------
      * SET DATA
      *-----------------------------------------------
     C           #MOVE     BEGSR
      *
     C                     CLEARABBWP7A1
     C                     MOVELW7DATE    WADATE
     C                     MOVELW7SIZE    WASIZE
     C                     MOVELW7SEQN    WASEQN
     C                     MOVELW7EXNO    WAEXNO
     C                     MOVELW7LCID    WALCID
      * LOCATION
     C                     MOVELW7LOC4    LTR4    4
     C                     MOVELLTR4      LTR3    3
     C                     MOVE '-'       LTR3
     C                     MOVE LTR4      LTR5    5
     C                     MOVELLTR3      LTR5
     C                     MOVELLTR5      WALOC4
      * OUTSRC
     C                     MOVELW7PRT     P@SHN     P
     C                     CALL 'UEXR05A'
     C                     PARM           P@SHN  15
     C                     PARM           P@OUTS  1
     C                     PARM           P@DEPT  4
     C           P@OUTS    IFEQ 'N'
     C                     MOVE *BLANK    WAMRK
     C                     ELSE
     C                     MOVEL'$'       WAMRK
     C                     ENDIF
      *
     C                     MOVELW7PRT     WAPRT
     C                     MOVELW7KNID    WAKNID
     C                     MOVELW7KQTY    WAKQTY
      *  DATE
     C                     MOVELW7ISDT    $DATE1
     C                     CALL 'EDTR01 '
     C                     PARM           $DATE1  8
     C                     PARM           $TIME1  6
     C                     PARM           $YMD    3
     C                     PARM           $DATE2 10
     C                     PARM           $TIME2  8
     C                     MOVEL$DATE2    WAISDT
      *
     C                     MOVELW7MCHN    WAMCHN
     C                     MOVELW7CMNT    WACMNT
     C                     MOVELW7LOTS    WALOTS
     C                     MOVELW7KAN     WAKAN
      * LOCATION
     C                     MOVELW7LOC     $LOCX
     C                     CALL 'EDTR06'
     C                     PARM           $LOC1   1
     C                     PARM           $LOC2   2
     C                     PARM           $LOC3   2
     C                     PARM           $LOC4   1
     C                     PARM           $LOC    9
     C                     MOVEL$LOC      WALOC
      *
     C                     MOVELW7PRC     WAPRC
     C                     MOVELW7FIL1    WAFIL1
     C                     MOVELW7FIL2    WAFIL2
     C                     MOVELW7FIL3    WAFIL3
     C                     MOVELW7FIL4    WAFIL4
     C                     MOVELW7FIL5    WAFIL5
JW1  C                     MOVELPSHFT     WASHFT
      *
     C                     ENDSR
** HDR(10A)
DATE         1  A
SIZE         2  B
SEQ#         3  C
EX#          4  D
POS          5  E
LOCATION     6  F
PART#        7  G
KANBAN_ID    8  H
#_KANBAN     9  I
ISSUE_DATE  10  J
MACHUNE     11  K
COMMENT     12  L
LOT#        13  M
KANB_TYPE   14  N
FNL_LOC     15  O
FNL_PROC    16  P
FLAG        17  Q
99          18  R
1ST MCN     19  S
LOC4        20  T
1ST SIZE    21  U
SHIFT       22  V
            23  W
            24  X
            25  Y
            26  Z
            27  AA
            28  AB
            29  AC
            30  AD
