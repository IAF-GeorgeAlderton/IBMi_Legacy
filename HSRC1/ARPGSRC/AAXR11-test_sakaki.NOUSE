     H            Y.
     F** AAXR11 **************************************
     F* .. LTEST                                     *
     F* T-SAKAKI                        87.10.09     *
     F************************************** AAXR11 **
     FFCEPP01 IF  E                    DISK
     FAAXWP22 O   F     256            DISK
      *
     E                    OBM        15  4               部門
     E                    OKB        15  3               機番
     E                    OTK        15  6               所番地
     E                    OSH        15  1               かんばん種類
     E                    OKO        15  3               工程
     E                    OHB        15 12               品番
      *
     I            DS
     I                                        1  12 CFHINA
     I                                        1   5 A2BHB1
     I                                        6  10 A2BHB2
     I                                       11  12 A2BHB3
      *
     C                     EXCPTOHED
      *
     C                     SETOF                     40
     C           1         SETLLFCEPP01
     C                     DO   *HIVAL
     C                     READ FCEPP01                  40
     C           *IN40     IFEQ '0'
     C*
     C           A2GSKD    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C           AAMRSC    PLIST
     C                     PARM           A2BHB1  5
     C                     PARM           A2BHB2  5
     C                     PARM           A2BHB3  2
     C                     PARM           PBMN   60
     C                     PARM           PKBN   45
     C                     PARM           PTKR   90
     C                     PARM           PSHR   15
     C                     PARM           PKOT   45
     C                     PARM           PHBN  180
     C                     PARM           STATUS  1
      *
     C                     MOVE *BLANK    PBMN   60
     C                     MOVE *BLANK    PKBN   45
     C                     MOVE *BLANK    PTKR   90
     C                     MOVE *BLANK    PSHR   15
     C                     MOVE *BLANK    PKOT   45
     C                     MOVE *BLANK    PHBN  180
     C                     MOVE *BLANK    STATUS  1
      *
     C                     MOVEA*BLANK    OBM
     C                     MOVEA*BLANK    OKB
     C                     MOVEA*BLANK    OTK
     C                     MOVEA*BLANK    OSH
     C                     MOVEA*BLANK    OKO
     C                     MOVEA*BLANK    OHB
      *
     C                     CALL 'AAMRSC'  AAMRSC
      *
     C                     MOVEAPBMN      OBM
     C                     MOVEAPKBN      OKB
     C                     MOVEAPTKR      OTK
     C                     MOVEAPSHR      OSH
     C                     MOVEAPKOT      OKO
     C                     MOVEAPHBN      OHB
      *
     C                     SETOF                     77
      *
      *-----------------------------------
S1   C           1         DO   15        @X      20
 S2  C           OKO,@X    IFEQ *BLANK                     工程
 S2  C                     LEAVE
 S2  C                     ENDIF
 S2  C           OKO,@X    IFEQ 'VNL'                      工程
     C                     SETON                     77
 S2  C                     ENDIF
     C                     ENDDO
      *-----------------------------------
 S2  C           *IN77     IFEQ *OFF
     C                     ITER
 S2  C                     ENDIF
 S2  C*
     C                     CALL 'UTLR57'
     C                     PARM           CFHINA 12
     C                     PARM           W1SRTN 20
     C                     PARM           W1SRT# 20
     C                     PARM           W1RTN   1
      *
     C                     MOVELW1SRTN    W1XX1   5
     C                     MOVELW1SRT#    W1XX2   5
      *
     C                     EXCPTODAT
     C*
     C                     ENDIF
     C  N40                ENDDO
      *-----------------------------------
      *
     C                     SETON                     LR
     C                     RETRN
