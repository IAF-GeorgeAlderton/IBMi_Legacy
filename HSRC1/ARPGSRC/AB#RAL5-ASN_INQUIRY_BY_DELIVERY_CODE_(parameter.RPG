     H            Y.
      ** AB#RAL5 *********************************************
      *  ASN INQUIRY BY DELIVERY CODE                        *
      *  J.WATANABE 2022.09.28                               *
      ********************************************************
     FAB#PWAL5CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     FAB#PL78BIF  E           K        DISK
      ********************************************************
     E                    MSG     1  12 60
      *
     I            DS
     I                                        1   80P8NOHZ
     I                                        1   40P8NOYY
     I                                        5   60P8NOMM
     I                                        7   80P8NODD
      *
     I            DS
     I                                        1   80K#NOHZ
     I                                        1   40K#NOYY
     I                                        5   60K#NOMM
     I                                        7   80K#NODD
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *-----------------------------------------------------------*
      *     M  A  I  N  L  I  N  E      SFL1                      *
      *-----------------------------------------------------------*
      *
     C                     EXSR #INIT
      *
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP1
     C           W@ID      CASEQ'02'      #SFL1
     C                     ENDCS
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *************************************************************
      * DISPLAY 1ST SCREEN
      *************************************************************
     C           #DSP1     BEGSR
      *
     C                     EXFMTDSP01
     C                     MOVEL*BLANKS   XMSG
     C                     MOVE *OFF      *IN85
     C                     MOVE *OFF      *IN41
     C                     MOVE *OFF      *IN42
     C                     MOVE *OFF      *IN43
      * F1/F3: EXIT
     C           *INKA     IFEQ *ON
     C           *INKC     OREQ *ON
     C           *INKL     OREQ *ON
     C                     MOVEL'99'      W@ID
     C                     GOTO XDSP1
     C                     ENDIF
      *
     C                     EXSR #CHK1
      *
     C           *IN85     IFEQ *OFF
     C                     MOVEL'02'      W@ID
     C                     ENDIF
      *
     C           XDSP1     ENDSR
      *************************************************************
      *  CHECK ENTRY DATA
      *************************************************************
     C           #CHK1     BEGSR
      * DELIVERY#
     C           XNONY     IFEQ 0
     C                     MOVELMSG,8     XMSG
     C                     SETON                     4185
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     MOVELXNONY     $DLV
     C                     CALL 'UTLR62'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTN    1
     C           $RTN      IFEQ '*'
     C                     MOVELMSG,9     XMSG
     C                     SETON                     4185
     C                     GOTO XCHK1
     C                     ENDIF
     C                     MOVEL$NAME1    XNAME
      * CHECK ASN DATE FROM
     C           XASNFR    IFEQ *BLANK
     C                     MOVELMSG,6     XMSG
     C                     SETON                     4285
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     MOVE XASNFR    $SRC
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$TRUE1    @ASNFR  80
     C                     MOVEL$TRUE2    XASNFR
     C                     ELSE
     C                     MOVELMSG,1     XMSG
     C                     SETON                     4285
     C                     GOTO XCHK1
     C                     ENDIF
      * CHECK ASN DATE TO
     C           XASNTO    IFEQ *BLANK
     C                     MOVELMSG,7     XMSG
     C                     SETON                     4385
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           XASNTO    IFEQ '99999999'
     C                     Z-ADD99999999  @ASNTO  80
     C                     ELSE
     C                     MOVE XASNTO    $SRC
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$TRUE1    @ASNTO  80
     C                     MOVEL$TRUE2    XASNTO
     C                     ELSE
     C                     MOVELMSG,2     XMSG
     C                     SETON                     4385
     C                     GOTO XCHK1
     C                     ENDIF
     C                     ENDIF
      *
     C           @ASNFR    IFGT @ASNTO
     C                     MOVELMSG,3     XMSG
     C                     SETON                     424385
     C                     ENDIF
      * CHECK SHP DATE FROM
     C           XSHPFR    IFNE *BLANK
     C                     MOVE XSHPFR    $SRC
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$TRUE1    @SHPFR  80
     C                     MOVEL$TRUE2    XSHPFR
     C                     ELSE
     C                     MOVELMSG,10    XMSG
     C                     SETON                     4485
     C                     GOTO XCHK1
     C                     ENDIF
     C                     ENDIF
      * CHECK SHP DATE TO
     C           XSHPTO    IFEQ *BLANK
     C           XSHPTO    IFEQ '99999999'
     C                     Z-ADD99999999  @SHPTO  80
     C                     ELSE
     C                     MOVE XSHPTO    $SRC
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$TRUE1    @SHPTO  80
     C                     MOVEL$TRUE2    XSHPTO
     C                     ELSE
     C                     MOVELMSG,11    XMSG
     C                     SETON                     4585
     C                     GOTO XCHK1
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C           @SHPFR    IFGT @SHPTO
     C                     MOVELMSG,12    XMSG
     C                     SETON                     444585
     C                     ENDIF
      * IF NO ERROR --------
     C           *IN85     IFEQ *OFF
     C                     EXSR #SET1
      *
     C           RCNT      IFGT 0
     C                     MOVEL'02'      W@ID
     C                     ELSE
     C                     MOVELMSG,4     XMSG
     C                     SETON                     414285
     C                     ENDIF
     C                     ENDIF
      *
     C           XCHK1     ENDSR
      ************************************************************
      *  SET DATA FOR SFL01
      ************************************************************
     C           #SET1     BEGSR
      *
     C                     EXSR #CLRS1
      *
     C                     Z-ADDXNONY     K#NONY
     C                     Z-ADD@ASNFR    K#NOHZ
     C           K#78B     SETLLAB#PL78B
     C                     DO   *HIVAL
     C           XNONY     READEAB#PL78B                 97
     C   97                LEAVE
      * IGNORE
     C           P8SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * END?
     C           P8NOHZ    IFGT @ASNTO
     C                     LEAVE
     C                     ENDIF
      *
     C                     CLEARSFL01
     C                     Z-ADDP8NOHZ    S1NOHZ
     C                     MOVELP8BINN    S1BIN
     C                     MOVELP8SERL    S1SERL
     C**                   MOVELP8NKOJ    S1NKOJ
     C                     MOVELP8NUKE    S1NUKE
     C                     MOVELP8ODRN    S1ODRN
     C                     Z-ADDP8PLDT    S1PLHZ
     C                     Z-ADDP8PLTM    S1PLTM
     C                     MOVELP8PLNM    S1PLUS
     C                     ADD  1         RRN1
     C                     WRITESFL01
      *
     C                     ENDDO
      *
     C                     Z-ADDRRN1      RCNT
      *
     C                     ENDSR
      ************************************************************
      *  DSPLAY 2ND SCREEN
      ************************************************************
     C           #SFL1     BEGSR
      *
     C                     EXSR #SET1
      *
     C                     WRITEDSP99
     C                     MOVEL'1'       *IN70
     C                     EXFMTCTL01
     C                     MOVEL*BLANKS   XMSG
     C                     MOVEL'0'       *IN85
     C                     MOVEL'0'       *IN70
      *
     C                     SELEC
      * F3: EXIT
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * F12: BACK
     C           *INKL     WHEQ *ON
     C                     EXSR #SEL
     C           S1SELX    IFEQ 'P'
     C                     MOVEL'99'      W@ID
     C                     ELSE
     C                     MOVE '01'      W@ID
     C                     MOVE *BLANK    $SERL
     C                     ENDIF
      * ENTER
     C                     OTHER
     C                     EXSR #SEL
     C           S1SELX    IFEQ 'P'
     C                     MOVEL'99'      W@ID
     C                     ELSE
     C           S1SELX    IFNE *BLANK
     C                     CALL 'AB#R985'                  PL INQ
     C                     PARM           $SERL
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************
      * CLEAR SUB FILE 01
      *************************************************************
     C           #CLRS1    BEGSR
      *
     C                     SETON                     71
     C                     WRITECTL01
     C                     SETOF                     71
     C                     Z-ADD0         RRN1
      *
     C                     ENDSR
      *************************************************************
      * CHECK SELECTION
      *************************************************************
     C           #SEL      BEGSR
      *
     C                     MOVE *BLANK    S1SELX  1
     C           1         DO   RCNT      RRN1
      *
     C           RRN1      CHAINSFL01                50
     C           *IN50     IFEQ *OFF
     C           S1SEL     ANDNE' '
     C                     MOVELS1SERL    $SERL
     C                     MOVELS1SEL     S1SELX
     C                     MOVE *BLANK    S1SEL
     C                     UPDATSFL01
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************
      * INITIAL SETTING
      *************************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SERL   9        OUT
      *
     C           K#78B     KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#NOYY  40
     C                     KFLD           K#NOMM  20
     C                     KFLD           K#NODD  20
      *
     C                     TIME           SDATE
     C                     MOVEL*BLANKS   XMSG
     C                     MOVEL'01'      W@ID    2
     C                     MOVELTODAY     XASNFR    P
     C                     MOVELTODAY     XASNTO    P
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         RCNT    40
      *
     C                     ENDSR
      *************************************************************
** (ERR) (60A).....2.........3.........4.........5.........6
ASN FROM_DATE IS INCORRECT !                                 01
ASN TO_DATE IS INCORRECT !                                   02
ASN FROM_DATE > TO_DATE !                                    03
NO DATA FOUND !                                              04
PRESS F5 TO PROCESS...                                       05
ENTER FROM_DATE !                                            06
ENTER TO_DATE !                                              07
ENTER DELIVERY CODE!                                         08
DELIVERY CODE NOT FOUND IN MASTER!                           09
SHIP FROM_DATE IS INCORRECT !                                10
SHIP TO_DATE IS INCORRECT !                                  11
SHIP FROM_DATE > TO_DATE !                                   12
