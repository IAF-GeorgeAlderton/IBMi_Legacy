 |   C                     MOVELS2SERL    SVSERL 10
 |   C**                   MOVELS2CONS    SVCONS  1
 |   C                     MOVELS2ODRN    SVODRN 10
 |   C                     Z-ADD99        S2BINN
 |   C                     MOVEL$BAR2     S2SERL
 |   C                     MOVEL$ODRN     S2ODRN
 |   C**                   MOVEL'P'       S2CONS
 |   C                     EXSR @SFCHK
 |   C           SFFLG     IFEQ 'OK'
 |    * WRITE PARENT CONSOLIDATED PACKING LIST#
 |   C                     WRITESFL020
 |   C                     ADD  1         RRN2
 |   C                     ENDIF
 |    *
 |   C                     Z-ADDSVBINN    S2BINN
 |   C                     MOVELSVSERL    S2SERL
 |   C**                   MOVELSVCONS    S2CONS
 |   C                     MOVELSVODRN    S2ODRN
 |   C                     ENDIF
 |    *
JW2  C                     ENDSR
