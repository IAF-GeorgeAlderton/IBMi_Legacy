     C******************************************************
     C*  MAIN
     C******************************************************
     C*
     C                     EXSR @INT
     C*
     C                     EXSR @F1RTN
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C*
     C******************************************************
     C*  INITTIAL SET
     C******************************************************
     C           @INT      BEGSR
     C*
     C                     TIME           WWTIME
     C*
     C                     Z-ADD@@YY      F1SHFY
     C                     Z-ADD@@MM      F1SHFM
     C                     Z-ADD@@DD      F1SHFD
     C                     Z-ADD*ZERO     F1SHTY
     C                     Z-ADD*ZERO     F1SHTM
     C                     Z-ADD*ZERO     F1SHTD
     C                     MOVEL*BLANK    F1NONY
     C                     MOVEL*BLANK    F1NUKE
     C                     Z-ADD*ZERO     F1BINN
TANE C*                    MOVEL'Y'       F1STS
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
     C*
     C                     Z-ADD*ZERO     W1SHFY  40
     C                     Z-ADD*ZERO     W1SHFM  20
     C                     Z-ADD*ZERO     W1SHFD  20
     C                     Z-ADD*ZERO     W1SHTY  40
     C                     Z-ADD*ZERO     W1SHTM  20
     C                     Z-ADD*ZERO     W1SHTD  20
     C                     Z-ADD*ZERO     W1CUST  40
     C                     Z-ADD*ZERO     W1NONY  40
     C                     MOVEL*BLANK    W1NUKE  4
     C                     Z-ADD*ZERO     W1BINN  20
     C                     MOVEL*BLANK    W1STS   1
     C*
     C           *LIKE     DEFN H2NKOJ    HXNKOJ
     C           *LIKE     DEFN S2SEL     SXSEL
     C           *LIKE     DEFN S2CUST    SXCUST
     C           *LIKE     DEFN S2NONY    SXNONY
     C           *LIKE     DEFN S2NUKE    SXNUKE
JW   C           *LIKE     DEFN S2BOX     SXBOX
JW   C           *LIKE     DEFN S2EDIK    SXEDIK
     C           *LIKE     DEFN S2BINN    SXBINN
     C           *LIKE     DEFN S2ODRN    SXODRN
     C           *LIKE     DEFN S2SERL    SXSERL
     C**         *LIKE     DEFN S2CONS    SXCONS
     C           *LIKE     DEFN S2LPDT    SXLPDT
     C           *LIKE     DEFN S2ASDT    SXASDT
     C           *LIKE     DEFN S2SPDT    SXSPDT
     C           *LIKE     DEFN S2SHNM    SXSHNM
     C           *LIKE     DEFN S2SHDT    SXSHDT
     C           *LIKE     DEFN S2PO#P    SXPO#P
     C           *LIKE     DEFN S2PLDT    SXPLDT
     C           *LIKE     DEFN S2SHTM    SXSHTM
     C           *LIKE     DEFN S2LPTM    SXLPTM
     C           *LIKE     DEFN S2ASTM    SXASTM
     C           *LIKE     DEFN S2SPTM    SXSPTM
     C           *LIKE     DEFN S2PO#O    SXPO#O
     C           *LIKE     DEFN S2DUM1    SXDUM1
     C           *LIKE     DEFN S2PLTM    SXPLTM
     C           *LIKE     DEFN S2DUM2    SXDUM2
     C*
     C                     ENDSR
     C******************************************************
     C*  FMT010
     C******************************************************
     C           @F1RTN    BEGSR
     C*
     C                     DO   *HIVAL
     C*
     C                     MOVEL*OFF      *IN48
     C                     MOVEL*OFF      *IN47
     C                     WRITEFMT099
     C                     EXFMTFMT010
     C   KA                LEAVE
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
     C*
     C                     EXSR @SHCHK
     C           *IN49     IFEQ *ON
     C                     ITER
     C                     END
     C*
     C                     EXSR @F2RTN
     C   KA                LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  SHIP DATE CHECK
     C******************************************************
     C           @SHCHK    BEGSR
     C*
     C           F1SHFY    IFEQ *ZERO
     C           F1SHFM    ANDEQ*ZERO
     C           F1SHFD    ANDEQ*ZERO
     C                     MOVELERR,1     MSG
     C                     MOVEL*ON       *IN49
     C                     GOTO XSHCHK
     C                     END
     C*
     C           F1SHFY    IFEQ *ZERO
     C           F1SHFM    OREQ *ZERO
     C                     MOVELERR,1     MSG
     C                     MOVEL*ON       *IN49
     C                     GOTO XSHCHK
     C                     END
     C*
     C           F1SHTY    IFEQ 0
     C           F1SHTM    ANDEQ0
     C           F1SHTD    ANDEQ0
     C                     Z-ADDF1SHFY    F1SHTY
     C                     Z-ADDF1SHFM    F1SHTM
     C                     Z-ADDF1SHFD    F1SHTD
     C                     END
      *
     C           F1SHTY    IFNE 0
     C           F1SHTY    ANDNE9999
     C           F1SHTM    IFEQ 0
     C                     MOVELERR,4     MSG
     C                     MOVEL*ON       *IN49
     C                     GOTO XSHCHK
     C                     END
     C                     END
      *
     C           F1SHTM    IFNE *ZERO
     C           F1SHTY    IFEQ *ZERO
     C                     MOVELERR,4     MSG
     C                     MOVEL*ON       *IN49
     C                     GOTO XSHCHK
     C                     END
     C                     END
     C*
     C           F1SHTY    IFNE *ZERO
     C           F1SHTM    ORNE *ZERO
     C                     Z-ADDF1SHFY    W1SHFY
     C                     Z-ADDF1SHFM    W1SHFM
     C                     Z-ADDF1SHTY    W1SHTY
     C                     Z-ADDF1SHTM    W1SHTM
     C           W1SFDT    IFGT W1STDT
     C                     MOVELERR,5     MSG
     C                     MOVEL*ON       *IN49
     C                     GOTO XSHCHK
     C                     END
     C                     END
     C*
     C           XSHCHK    ENDSR
     C******************************************************
     C*  @F2RTN
     C******************************************************
     C           @F2RTN    BEGSR
     C*
     C                     EXSR @F2SET
     C                     Z-ADD1         W#RNP2  40
     C*
     C                     DO   *HIVAL
     C*
     C                     MOVEL*ON       *IN48
     C                     MOVEL*ON       *IN47
     C                     WRITEFMT099
     C                     Z-ADDW#RNP2    #RCN02
     C                     EXFMTCTL020
     C   KA
     COR KL                LEAVE
     C*
     C  NKJ                MOVELN#MODE    *IN43
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP2
     C                     END
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
     C*
     C           *INKF     IFEQ *ON
     C           F1SHFY    ORNE W1SHFY
     C           F1SHFM    ORNE W1SHFM
     C           F1SHFD    ORNE W1SHFD
     C           F1SHTY    ORNE W1SHTY
     C           F1SHTM    ORNE W1SHTM
     C           F1SHTD    ORNE W1SHTD
     C           F1CUST    ORNE W1CUST
     C           F1NONY    ORNE W1NONY
     C           F1NUKE    ORNE W1NUKE
     C           F1BINN    ORNE W1BINN
TANE C*          F1STS     ORNE W1STS
     C                     EXSR @SHCHK
     C   49                ITER
     C                     EXSR @F2SET
     C                     Z-ADD1         W#RNP2
     C                     ITER
     C                     END
     C*
     C                     EXSR @F3RTN
     C   KA                LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  SFL020 SET
     C******************************************************
     C           @F2SET    BEGSR
 .   C                     MOVE *BLANK    F1NAME
JW5   * GET DELIVERY NAME
 .   C           F1CUST    IFEQ 0
 .   C           F1NONY    ANDEQ0
 .   C                     MOVELERR,6     F1NAME
JW5  C                     ENDIF
      *
 .   C           F1NAME    IFEQ *BLANK
 .   C           F1NONY    IFNE 0
 .   C                     MOVELF1NONY    $DLV
     C                     ELSE
 .   C           F1CUST    IFNE 0
 .   C                     MOVELF1CUST    $DLV
     C                     ENDIF
     C                     ENDIF
      *
 .   C                     CALL 'UTLR62'
 .   C                     PARM           $DLV    4
 .   C                     PARM           $GRP    3
 .   C                     PARM           $NAME1 15
 .   C                     PARM           $NAME2 50
 .   C                     PARM           $RTN    1
 .   C                     MOVE $NAME1    LTR17  17
 .   C                     MOVELLTR17     F1NAME
 .   C                     MOVEL'='       F1NAME
 .   C                     MOVE '='       F1NAME
JW5  C                     ENDIF
      *
     C                     MOVEL*ON       *IN41
     C                     WRITECTL020
     C                     MOVEL*OFF      *IN41
     C                     MOVEL*OFF      *IN42
     C                     Z-ADD*ZERO     RRN2    40
     C*
     C                     MOVEL*ON       *IN43
     C                     MOVEL*ON       N#MODE
     C*
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
     C                     Z-ADD70        P@LEN
     C                     MOVELCMD,1     P@CMD
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN AB#WP98
     C*
     C* SET SHP-TO DATE CONDITION
     C           F1SHTY    IFNE *ZERO
     C                     Z-ADDF1SHTY    W@SHTY
     C                     ELSE
     C                     Z-ADDF1SHFY    W@SHTY
     C                     END
     C           F1SHTM    IFNE *ZERO
     C                     Z-ADDF1SHTM    W@SHTM
     C                     ELSE
     C                     Z-ADDF1SHFM    W@SHTM
     C                     END
     C           F1SHTD    IFNE *ZERO
     C                     Z-ADDF1SHTD    W@SHTD
     C                     ELSE
     C                     Z-ADDF1SHFD    W@SHTD
     C           F1SHFD    IFEQ *ZERO
     C                     Z-ADD99        W@SHTD
     C                     END
     C                     END
     C*
     C           K#L1NA    KLIST
     C                     KFLD           K@SHYY
     C                     KFLD           K@SHMM
     C                     KFLD           K@SHDD
     C           K#L1NB    KLIST
     C                     KFLD           K@SHYY
     C                     KFLD           K@SHMM
     C                     Z-ADDF1SHFY    K@SHYY
     C                     Z-ADDF1SHFM    K@SHMM
     C                     Z-ADDF1SHFD    K@SHDD
     C           F1SHFD    IFEQ *ZERO
     C           K#L1NB    SETLLAB#PL1N
     C                     ELSE
     C           K#L1NA    SETLLAB#PL1N
     C                     END
      *
     C*LOOP ====================================
     C                     DO   *HIVAL
      *
     C                     READ AB#PL1N                  98
     C   98                LEAVE
     C**         BASKJY    IFNE *BLANK
JW2  C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C*
     C           BANODT    IFGT W@TODT
     C                     LEAVE
     C                     END
     C*
     C* CUST
     C           F1CUST    IFNE *ZERO
     C           F1CUST    IFNE BATOKU
     C                     ITER
     C                     END
     C                     END
     C* DELI
     C           F1NONY    IFNE *ZERO
     C           F1NONY    IFNE BANONY
     C                     ITER
     C                     END
     C                     END
     C* DOCK
     C           F1NUKE    IFNE *BLANK
     C           F1NUKE    IFNE BANUKE
     C                     ITER
     C                     END
     C                     END
     C* BIN#
     C           F1BINN    IFNE *ZERO
     C           F1BINN    IFNE BANOBN
     C                     ITER
     C                     END
     C                     END
     C*
     C           K#L78A    KLIST
     C                     KFLD           BANOYY
     C                     KFLD           BANOMM
     C                     KFLD           BANODD
     C                     KFLD           BATOKU
     C                     KFLD           BANONY
     C                     KFLD           BANKOJ
     C                     KFLD           BANUKE
     C                     KFLD           BANOBN
     C           K#L78A    SETLLAB#PL78
     C                     MOVEL*OFF      W@BFND  1        O# BLANK FND
     C                     MOVEL*OFF      W@OFND  1        O# FOUND
     C                     DO   *HIVAL
     C           K#L78A    READEAB#PL78                  96
     C   96                LEAVE
     C**         P8SKJY    IFNE *BLANK
JW2  C           P8SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C           P8ODRN    IFEQ *BLANK
     C                     MOVEL*ON       W@BFND
     C                     END
     C           P8ODRN    IFEQ BAODRN
     C                     MOVEL*ON       W@OFND
     C                     LEAVE
     C                     END
     C                     ENDDO
     C*
     C                     MOVEL*OFF      *IN95
     C           W@BFND    IFEQ *ON
     C           W@OFND    ANDEQ*OFF
     C                     MOVEL*OFF      *IN96
     C           K#L78A    SETLLAB#PL78
     C                     DO   *HIVAL
     C           K#L78A    READEAB#PL78                  95
     C   95                LEAVE
     C**         P8SKJY    IFNE *BLANK
JW2  C           P8SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C           P8ODRN    IFEQ *BLANK
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     END
     C*
     C* CREATE SUB-FILE
     C                     CLEARSFL020
     C*
     C                     MOVELBATOKU    S2CUST
     C                     MOVELBANONY    S2NONY
     C                     MOVELBANUKE    S2NUKE
JW   C                     MOVELBANUKE    X2NUKE
      *
JW   C                     MOVELBAEDIK    S2EDIK
     C                     Z-ADDBANOBN    S2BINN
     C                     Z-ADDBANODT    S2SHDT
JW5  C**                   MOVELBAODRN    S2PO#O
     C                     MOVELBANKOJ    H2NKOJ
      * GET PO#
     C                     MOVELBANONY    $NONY
     C                     MOVELBANKOJ    $NKOJ
     C                     MOVELBANUKE    $NUKE
     C                     MOVELBANODT    $NOHZ
     C                     MOVELBANOBN    $NOBN
     C                     CALL 'UEXR20C'
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $NOHZ   8
     C                     PARM           $NOBN   2
     C                     PARM           $PO#   10
JW5  C                     MOVEL$PO#      S2PO#O
     C* SHIP TIME
     C**         BANOTM    IFNE *ZERO
     C           BANOTM    MULT 100       W2TM@
     C                     MOVELW2TM@H    W2TMHH
     C                     MOVEL':'       W2TMD1
     C                     MOVELW2TM@M    W2TMMM
     C                     MOVEL':'       W2TMD2
     C                     MOVELW2TM@S    W2TMSS
     C                     MOVELW2TM      S2SHTM
     C**                   END
      *
     C**JW3      K#GADP    KLIST
     C**                   KFLD           BATOKU
     C**                   KFLD           BANONY
     C**                   KFLD           BANKOJ
     C**                   KFLD           BANUKE
     C**         K#GADP    CHAINGADPL11              94
     C**N94                MOVELB5KMEI    S2SHNM
      *
     C           BANONY    CHAINFGBPL01              94
     C  N94                MOVELB2SMEI    S2SHNM
     C   94                MOVE *BLANK    S2SHNM
      *
     C           K#PP98    KLIST
     C                     KFLD           BATOKU
     C                     KFLD           BANONY
     C           K#PP98    CHAINAB#PP98              97
     C*
     C           *IN96     IFEQ *ON
     C           *IN95     OREQ *ON
     C*
%0001C***        *IN97     IFEQ *ON
     C***        P9SKJY    ORNE *BLANK
     C***                  MOVEL*ALL'*'   S2ASDT
     C***                  END
     C*
     C                     ELSE
     C*
     C                     MOVELP8ODRN    S2ODRN
     C                     MOVELP8ODRN    S2PO#P
JW2  C**                   MOVELP8SKJY    S2CONS
JW1  C**                   MOVELP8SERL    S2SERL
JW1   * RETRIEVE PRIMARY SERIAL NO --------------
 |   C                     MOVELP8NODT    $NOHZ
 |   C                     MOVELP8CUST    $CUST
 |   C                     MOVELP8NONY    $NONY
 |   C                     MOVELP8NKOJ    $NKOJ
 |   C                     MOVELP8NUKE    $NUKE
 |   C                     MOVELP8BINN    $BINN
 |   C                     MOVELP8RLDT    $RLHZ
 |   C                     MOVELP8ODRN    $ODRN
 |   C                     CALL 'UTLR51'
 |   C                     PARM           $NOHZ   8
 |   C                     PARM           $CUST   4
 |   C                     PARM           $NONY   4
 |   C                     PARM           $NKOJ   1
 |   C                     PARM           $NUKE   4
 |   C                     PARM           $BINN   2
 |   C                     PARM           $RLHZ   8
 |   C                     PARM           $ODRN  10
 |   C                     PARM           $PICK#  9
 |   C                     PARM           $RTN    1
 |   C           $RTN      IFEQ '*'
 |   C                     MOVELP8SERL    S2SERL
 |   C**                   MOVE *BLANK    S2SER2
 |   C                     ELSE
 |   C                     MOVEL$PICK#    S2SERL
 |   C**                   MOVELP8SERL    S2SER2
 |   C                     ENDIF
JW1   * -------------------------------------------
     C                     Z-ADDP8PLDT    S2PLDT
     C           P8PLTM    IFNE *ZERO
     C                     Z-ADDP8PLTM    W2TM@
     C                     MOVELW2TM@H    W2TMHH
     C                     MOVEL':'       W2TMD1
     C                     MOVELW2TM@M    W2TMMM
     C                     MOVEL':'       W2TMD2
     C                     MOVELW2TM@S    W2TMSS
     C                     MOVELW2TM      S2PLTM
     C                     END
      *
     C           P8LPDT    IFNE *ZERO
     C                     Z-ADDP8LPDT    W2DT@
     C                     MOVELW2DT@Y    W2DTYY
     C                     MOVEL'/'       W2DTS1
     C                     MOVELW2DT@M    W2DTMM
     C                     MOVEL'/'       W2DTS2
     C                     MOVELW2DT@D    W2DTDD
     C                     MOVELW2DT      S2LPDT
     C                     ELSE
     C           BATOKU    IFEQ 3411
     C           BATOKU    OREQ 0541
     C           BATOKU    OREQ 3423
     C           BANONY    IFNE 0323
     C                     MOVEL*ALL'*'   S2LPDT
     C                     END
     C                     END
     C                     END
     C*
     C           P8LPTM    IFNE *ZERO
     C                     Z-ADDP8LPTM    W2TM@
     C                     MOVELW2TM@H    W2TMHH
     C                     MOVEL':'       W2TMD1
     C                     MOVELW2TM@M    W2TMMM
     C                     MOVEL':'       W2TMD2
     C                     MOVELW2TM@S    W2TMSS
     C                     MOVELW2TM      S2LPTM
     C                     END
     C*
%0001C***        *IN97     IFEQ *ON
     C***        P9SKJY    ORNE *BLANK
     C***                  MOVEL*ALL'*'   S2ASDT
     C***                  ELSE
     C           P8ASDT    IFNE *ZERO
