     H            Y.
     F** BAHR02 *********************************
     F*  UPDATE  OF L / T M/F IN  PROCESS
     F* A.IDOTA               1994.10.11        *
     F********************************* BAHR02 **
     FBAHPW02 CF  E                    WORKSTN
     FBAHPL02 UF  E           K        DISK                      A
     E                    ER      1   9 60               MSG
     E                    BM      1   1  4 0             部門
     I            DS
     I                                        1   60WTIME
     I                                        1   20HH
     I                                        3   40SS
     C           *ENTRY    PLIST
     C                     PARM           US     10
      * KEY *
     C           KEY       KLIST
     C                     KFLD           BMN
     C                     KFLD           @KTI
     C                     TIME           WTIME   60
      *****************************************************************
      * 初期設定                                             MAIN   *
      *****************************************************************
     C           STP00     TAG
     C                     MOVE *BLANK    @KBN
     C                     MOVE *BLANK    @BMN
     C                     MOVE *BLANK    @KTI
     C                     Z-ADD0         @LIT
     C                     SETOF                     010203
     C                     SETOF                     047099
     C                     SETOF                     KAKCKE
      *****************************************************************
      * 画面・１                                             MAIN   *
      *****************************************************************
     C           STP10     TAG
     C                     EXFMTBAHPW021
      * END *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C                     SETOF                     010203
     C                     SETOF                     0499
      *更新区分*
     C           @KBN      IFNE '0'
     C           @KBN      ANDNE'1'
     C           @KBN      ANDNE'2'
     C                     MOVELER,01     MSG
     C                     SETON                     0199
     C                     GOTO STP10
     C                     END
      *部門*
     C           @BMN      IFEQ *BLANK
     C                     MOVELER,02     MSG
     C                     SETON                     0299
     C                     GOTO STP10
     C                     END
      *
     C                     MOVEL@BMN      BMN     40
     C                     SETOF                     30
     C           BMN       LOKUPBM                       30
     C           *IN30     IFEQ '0'
     C                     MOVELER,03     MSG
     C                     SETON                     0299
     C                     GOTO STP10
     C                     END
      *工程*
     C           @KTI      IFEQ *BLANK
     C                     MOVELER,04     MSG
     C                     SETON                     0399
     C                     GOTO STP10
     C                     END
      * ﾎｦbﾓ kｩｮh *
     C                     SETOF                     30
     C           KEY       CHAINBAHPL021             30
      *取消*
     C           @KBN      IFEQ '0'
     C           *IN30     IFEQ '1'
     C                     MOVELER,05     MSG
     C                     SETON                     0199
     C                     GOTO STP10
     C                     END
     C           *IN30     IFEQ '0'
     C           BBSKJY    ANDEQ'D'
     C                     MOVELER,06     MSG
     C                     SETON                     0199
     C                     GOTO STP10
     C                     END
     C                     Z-ADDBBLITM    @LIT
     C                     END
      *変更*
     C           @KBN      IFEQ '1'
     C           *IN30     IFEQ '1'
     C                     MOVELER,07     MSG
     C                     SETON                     0199
     C                     GOTO STP10
     C                     END
     C           *IN30     IFEQ '0'
     C           BBSKJY    ANDEQ'D'
     C                     MOVELER,07     MSG
     C                     SETON                     0199
     C                     GOTO STP10
     C                     END
     C                     Z-ADDBBLITM    @LIT
     C                     END
      *追加*
     C           @KBN      IFEQ '2'
     C           *IN30     IFEQ '0'
     C           BBSKJY    ANDNE'D'
     C                     MOVELER,08     MSG
     C                     SETON                     0199
     C                     GOTO STP10
     C                     END
     C                     END
      *****************************************************************
      *  L/T入力                                             MAIN   *
      *****************************************************************
     C                     SETON                     70
     C           STP20     TAG
     C                     EXFMTBAHPW021
      * END *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      * KEY入力*
     C           *INKC     IFEQ '1'
     C                     GOTO STP00
     C                     END
     C                     SETOF                     010203
     C                     SETOF                     0499
      * L/T *
     C           @LIT      IFEQ 0
     C                     MOVELER,09     MSG
     C                     SETON                     0499
     C                     GOTO STP20
     C                     END
      *更新*
     C           *INKE     IFEQ '0'
     C                     GOTO STP20
     C                     END
      *
     C           @KBN      IFEQ '2'
     C                     MOVE *BLANK    BBSKJY
     C                     Z-ADD0         BBSKYY
     C                     Z-ADD0         BBSKMM
     C                     Z-ADD0         BBSKDD
     C                     Z-ADD0         BBKOYY
     C                     Z-ADD0         BBKOMM
     C                     Z-ADD0         BBKODD
     C                     Z-ADD0         BBKOHH
     C                     Z-ADD0         BBKOSS
     C                     MOVE *BLANK    BBKOME
     C                     Z-ADD0         BBBMON
     C                     MOVE *BLANK    BBKOTI
     C                     Z-ADD0         BBLITM
     C                     Z-ADDBMN       BBBMON
     C                     MOVEL@KTI      BBKOTI
     C                     END
      *
     C           @KBN      IFEQ '0'
     C                     MOVEL'D'       BBSKJY
     C                     Z-ADD*YEAR     BBSKYY
     C                     Z-ADDUMONTH    BBSKMM
     C                     Z-ADDUDAY      BBSKDD
     C                     END
      *
     C                     Z-ADD*YEAR     BBKOYY
     C                     Z-ADDUMONTH    BBKOMM
     C                     Z-ADDUDAY      BBKODD
     C                     Z-ADDHH        BBKOHH
     C                     Z-ADDSS        BBKOSS
     C                     MOVELUS        BBKOME
     C                     Z-ADD@LIT      BBLITM
      *
     C           @KBN      IFEQ '1'
     C           @KBN      OREQ '0'
     C           *IN30     IFEQ '0'
     C                     UPDATBAHPL021
     C                     END
     C                     END
     C           @KBN      IFEQ '2'
     C           *IN30     IFEQ '1'
     C                     WRITEBAHPL021
     C                     ELSE
     C                     UPDATBAHPL021
     C                     END
     C                     END
     C                     GOTO STP00
**  ERR / MSG
E-01 UPDATE INSTRUCTION IS <0 1 2>.
E-02 INPUT  SECTION CODE
E-03 SECTION CODE YOU INPUT IS NOT RIGHT
E-04 INPUT  PROCESS
E-05 THERE ISN'T  CANCEL DATA
E-06 DATA IS CANCELLED  ALREADY
E-07 THERE ISN'T  CHANGE DATA
E-08 THER IS DATA
E-09 INPUT L  T.
