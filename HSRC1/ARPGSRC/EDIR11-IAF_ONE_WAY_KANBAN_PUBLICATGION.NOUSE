     C                     END
     C                     MOVE HEX       WHEX
      * INTRAL COMPANY ACCOMODATED QUANTITY AND USER ACCOMODATED
      * QUANTITY MOTH    EFSYOS=0
     C                     MOVE EFSYOS    WSYOS   50
