     H            Y
     F** ALCRS1 *******************************************************
     F*                                                               *
     F*                                                               *
     F*  14.07.23 T.SAKAHSITA                                         *
     F*  16.07.25 T.SAKAKI  %0001 ADD ALRPL08 FOR RETRIEVAL FOR P/T   *
     F*  20.11.05  DCS. T.MITSUI  ADD ALRPL35                         *
     F*****************************************************************
     FALCPL06 IF  E           K        DISK
%0001FALRPL08 IF  E           K        DISK
     FALRPL35 IF  E           K        DISK
     F*
     IR1SBAR      DS
     I                                        1   1 R1SBKK
     I                                        2   5 R1SBZN
     I                                        6   8 R1SBTN
     I                                        9  10 R1SBPN
     I*
     C           *ENTRY    PLIST
     C*                                IN ------
     C                     PARM           P@CHYU  1
     C                     PARM           P@ZETI  4
     C                     PARM           P@PAGE  3
     C                     PARM           P@HTHZ  80       KANBAN PUBLICATION
     C*                               OUT ------
     C                     PARM           P@DATE  80       PICKING DATE
     C                     PARM           P@TIME  60       PICKING TIME
     C*
     C                     MOVE P@CHYU    K@CHYU
     C                     MOVE P@ZETI    K@ZETI
     C                     MOVE P@PAGE    K@PAGE
     C*
     C                     Z-ADD0         P@DATE
     C                     Z-ADD0         P@TIME
     C*
     C           ALCKEY    KLIST
     C                     KFLD           K@CHYU  1
     C                     KFLD           K@ZETI  4
     C                     KFLD           K@PAGE  3
     C*
     C           ALRKEY    KLIST
     C                     KFLD           K@ZETI  4
     C                     KFLD           K@PAGE  3
     C*
     C           ALRKY2    KLIST
     C                     KFLD           K@ZETI  4
     C*
     C           ALCKEY    SETGTALCPL06
     C                     DO   *HIVAL
     C           ALCKEY    REDPEALCPL06                  88
     C   88                LEAVE
     C           A8B2LZ    IFEQ *BLANK
     C                     ITER
     C                     END
     C           A8DATE    IFLT P@HTHZ
     C                     ITER
     C                     END
     C           A8ERR     IFEQ 'E'
     C                     ITER
     C                     END
     C                     Z-ADDA8DATE    P@DATE
     C                     Z-ADDA8TIME    P@TIME
     C                     LEAVE
     C                     ENDDO
     C*
     C           *IN88     IFEQ *ON
     C           ALRKEY    SETGTALRPL08
     C                     DO   *HIVAL
     C           ALRKEY    REDPEALRPL08                  88
     C   88                LEAVE
     C           PTKODT    IFLT P@HTHZ
     C                     ITER
     C                     END
     C           PTOKNG    IFEQ 'NG'
     C                     ITER
     C                     END
     C                     Z-ADDPTCODT    P@DATE
     C                     Z-ADDPTCOTM    P@TIME
     C                     LEAVE
     C                     ENDDO
     C                     ENDIF
     C*
     C           *IN88     IFEQ '1'
     C           ALRKY2    SETGTALRPL35
     C           ALRKY2    REDPEALRPL35                  88
     C           *IN88     DOWEQ'0'
     C           P@DATE    ANDEQ*ZERO
     C           R1SKJY    IFEQ *BLANK
     C           R1COHZ    ANDGEP@HTHZ
     C           R1SBTN    ANDEQP@PAGE
     C           R1HNTE    ANDEQ'OK'
     C                     Z-ADDR1COHZ    P@DATE
     C                     Z-ADDR1COTI    P@TIME
     C                     ELSE
     C           ALRKY2    REDPEALRPL35                  88
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
     C*
     C                     SETON                     LR
     C                     RETRN
