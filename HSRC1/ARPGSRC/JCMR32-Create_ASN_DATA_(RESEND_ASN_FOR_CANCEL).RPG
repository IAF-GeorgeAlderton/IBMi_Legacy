     H            Y.
      ** JCMR32 ********************************************************
      *  CREATE ASN DATA (RESEND ASN FOR CANCEL)                       *
      *  JW     2022/06/22                                             *
      ******************************************************************
     FAB#EP63SIF  E           K        DISK
     FAB#EP64SIF  E           K        DISK
     FAB#EP65SIF  E           K        DISK
     FAB#EL66SIF  E           K        DISK
     FEB#EP63 O   E                    DISK
     FEB#EP64 O   E                    DISK
     FEB#EP65 O   E                    DISK
     FEB#EP66 O   E                    DISK
      *---------------------------------------------------
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************
      *  MAIN
      *************************************************************
      * INITIALIZE
     C                     EXSR #INIT
      *
      * GET LATEST HEADER
     C           $SHID     SETLLAB#EL66S
     C                     DO   *HIVAL
     C           $SHID     READEAB#EL66S                 96
     C   96                LEAVE
      *
     C           E6NONY    IFNE @NONY
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADDE6CRDT    SVCRDT
     C                     Z-ADDE6CRTM    SVCRTM
     C                     ENDDO
      *
     C           SVCRDT    IFEQ 0
     C                     MOVE '*'       $RTN
     C                     ELSE
     C                     EXSR #ASN
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------------------
      * CRAETE ASN DATA
      *-----------------------------------------------------------
     C           #ASN      BEGSR
      * OUTPUT EP66
     C                     MOVE '01'      E6RMD
     C                     WRITEEB#EP661
      * OUTPUT EP63 ---------------------
     C           $SHID     SETLLAB#EP63S
     C                     DO   *HIVAL
     C           $SHID     READEAB#EP63S                 93
     C   93                LEAVE
      *
     C           E3CRDT    IFNE SVCRDT
     C           E3CRTM    ORNE SVCRTM
     C                     ITER
     C                     ENDIF
      *
     C                     WRITEEB#EP631
     C                     ENDDO
      * OUTPUT EP64 ---------------------
     C           $SHID     SETLLAB#EP64S
     C                     DO   *HIVAL
     C           $SHID     READEAB#EP64S                 94
     C   94                LEAVE
      *
     C           E4CRDT    IFNE SVCRDT
     C           E4CRTM    ORNE SVCRTM
     C                     ITER
     C                     ENDIF
      *
     C                     WRITEEB#EP641
     C                     ENDDO
      * OUTPUT EP65 ---------------------
     C           $SHID     SETLLAB#EP65S
     C                     DO   *HIVAL
     C           $SHID     READEAB#EP65S                 95
     C   95                LEAVE
      *
     C           E5CRDT    IFNE SVCRDT
     C           E5CRTM    ORNE SVCRTM
     C                     ITER
     C                     ENDIF
      *
     C                     WRITEEB#EP651
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *          INITIALIZE
      *-----------------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4
     C                     PARM           $SHID  10
     C                     PARM           $RTN    1
      *
     C                     MOVEL$NONY     @NONY   40
     C                     MOVE *BLANK    $RTN
     C                     TIME           WSDT
     C                     Z-ADD0         SVCRDT  80
     C                     Z-ADD0         SVCRTM  60
      *
     C                     ENDSR
