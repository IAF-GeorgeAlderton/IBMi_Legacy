     H            Y.
     F** EJGR01 *********************************************
     F*  SET UP GENTRAN MAPPING TABLE                       *
     F*             W.WATANABE     2016.12.09               *
     F*******************************************************
     FEJGWP01 IF  E                    DISK
     FEJGPP00 UF  E           K        DISK                      A
     F*******************************************************
     E                    TB1         5  1
     E                    TB2         5  1
     E                    TBL        12  1
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     F*******************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ EJGWP01                  91
     C   91                LEAVE
      * IGNORE HEADER
     C           FLD#A     IFEQ 'REC ID'
     C           FLD#A     OREQ 'Rec ID'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELFLD#A     K@RCID
     C                     MOVELFLD#B     K@RTYP
     C                     MOVELFLD#C     K@EFIL
     C                     MOVELFLD#C     K@EFLD
     C                     MOVELFLD#E     K@EGRP
     C                     MOVELFLD#F     K@AFIL
     C                     MOVELFLD#G     K@AFLD
      *
     C           K@EJG     CHAINEJGPP00              92
     C           *IN92     IFEQ *OFF
     C                     EXSR #UPD
     C                     ELSE
     C                     EXSR #WRT
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      ******************************************************
      *          UPDATE RECORD
      ******************************************************
     C           #UPD      BEGSR
     C                     EXSR #SET
     C                     UPDATEJGPP001
     C                     ENDSR
      ******************************************************
      *          WRITE  RECORD
      ******************************************************
     C           #WRT      BEGSR
     C                     EXSR #SET
     C                     WRITEEJGPP001
     C                     ENDSR
      ******************************************************
      *          SET RECOED DATA
      ******************************************************
     C           #SET      BEGSR
     C                     CLEAREJGPP001
      *
     C                     MOVELFLD#A     E0RCID
     C                     MOVELFLD#B     E0RTYP
     C                     MOVELFLD#C     E0EFIL
     C                     MOVELFLD#D     E0EFLD
     C                     MOVELFLD#E     E0EGRP
     C                     MOVELFLD#F     E0AFIL
     C                     MOVELFLD#G     E0AFLD
     C                     MOVELFLD#H     E0ENAM
     C                     MOVELFLD#I     E0MO
      *
     C                     SELEC
     C           FLD#J     WHEQ 'AN'
     C           FLD#J     OREQ 'ID'
     C           FLD#J     OREQ 'DT'
     C           FLD#J     OREQ 'TM'
     C           FLD#J     OREQ 'R '
     C           FLD#J     OREQ 'N '
     C           FLD#J     OREQ 'N0'
     C                     MOVELFLD#J     E0FTYP
     C                     OTHER
     C                     MOVEL'AN'      E0FTYP
     C                     ENDSL
      * MIN LENGTH
     C                     MOVEAFLD#K     TB1
     C                     EXSR #CONV
     C                     Z-ADDNUM5      E0MIN
      * LENGTH
     C                     MOVEAFLD#L     TB1
     C                     EXSR #CONV
     C                     Z-ADDNUM5      E0LNG
      * START POSITION
     C                     MOVEAFLD#M     TB1
     C                     EXSR #CONV
     C                     Z-ADDNUM5      E0POS1
      * END POSISION
     C                     MOVEAFLD#N     TB1
     C                     EXSR #CONV
     C                     Z-ADDNUM5      E0POS2
      *
     C                     MOVELFLD#O     E0ANAM
     C                     Z-ADD0         E0DEC
      *
     C                     ENDSR
      ******************************************************
      *          CONVERT LTRT TO NUM
      ******************************************************
     C           #CONV     BEGSR
      *
     C                     CLEARTB2
     C                     Z-ADD6         IX      20
     C                     Z-ADD6         IY      20
     C                     Z-ADD0         NUM5    50
     C           1         DO   5
     C                     SUB  1         IX
     C           IX        IFLE 0
     C                     LEAVE
     C                     ENDIF
     C           TB1,IX    IFEQ *BLANK
     C                     ITER
     C                     ENDIF
     C                     SUB  1         IY
     C                     MOVELTB1,IX    TB2,IY
     C                     ENDDO
      *
     C                     MOVEATB2       LTR5    5
     C           ' ':'0'   XLATELTR5      LTR5
     C                     MOVELLTR5      NUM5
      *
     C                     ENDSR
      ******************************************************
      *          INITIAL SET
      ******************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           @CSV   12
     C                     PARM           @OPT    1
      *
     C           K@EJG     KLIST
     C                     KFLD           K@RCID 10
     C                     KFLD           K@RTYP  1
     C                     KFLD           K@EFIL  4
     C                     KFLD           K@EFLD  8
     C                     KFLD           K@EGRP  5
     C                     KFLD           K@AFIL  4
     C                     KFLD           K@AFLD  8
      *
     C                     Z-ADD*DATE     @DATE   80
     C                     TIME           @TIME   60
      * REPLACE(CLEAR) EJGPP00
     C           @OPT      IFEQ 'R'
     C                     MOVEA@CSV      TBL
     C                     Z-ADD1         X       20
     C           '.'       LOKUPTBL,X                    99
     C           *IN99     IFEQ *ON
     C                     SUB  1         X
     C           X         IFGT 0
     C           X         SUBST@CSV:1    LTR12  12
     C                     MOVELLTR12     LTR10  10
     C           LTR10     SETLLEJGPP00
      *
     C           *IN98     DOWEQ*OFF
     C           LTR10     READEEJGPP00                  98
     C           *IN98     IFEQ *OFF
     C                     DELETEJGPP001
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
