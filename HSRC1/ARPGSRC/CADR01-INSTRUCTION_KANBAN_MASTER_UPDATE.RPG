     C**                   MOVE CKKO,A    ##KO,B
     C**                   MOVE CKBM,A    ##BM,B
     C**                   MOVE CKKB,A    ##KI,B
     C**                   END
     C**                   END
     C**                   END
      **
     C**-----------------*
     C**CHECK OQ PROCESS *
     C**-----------------*
     C**                   SETOF                       80
     C**                   MOVE *BLANK    AAMSW   1
     C**                   Z-ADD1         A
      **
     C**         'OQ '     LOKUP##KO,A                   80
     C**N80      'LOQ'     LOKUP##KO,A                   80
      **
     C**         *IN80     IFEQ '1'
     C**                   MOVE '*'       AAMSW
     C**                   END
      **
     C**                   ENDSR
     C***************************************************
     C* PROCESS CHECK
     C***************************************************
     C           #CHKP     BEGSR
      *
     C*------------------*
     C* CHECK OQ PROCESS *
     C*------------------*
     C                     Z-ADD1         J       20
     C                     MOVEL*BLANK    W@OQ    1
      *
     C           'OQ '     LOKUPC2KO,J                   80
     C  N80      'LOQ'     LOKUPC2KO,J                   80
     C   80                MOVEL'*'       W@OQ
     C*-----------------------*
     C* CHECK LAN/AOQ PROCESS *
     C*-----------------------*
     C                     Z-ADD1         J
     C                     MOVEL*BLANK    W@LAN   1
      *
     C           'LAN'     LOKUPC2KO,J                   80
     C  N80      'AOQ'     LOKUPC2KO,J                   80
     C   80                MOVEL'*'       W@LAN
     C*--------------------*
     C* CHECK S.T. PROCESS *
     C*--------------------*
     C                     Z-ADD1         J
     C                     MOVEL*BLANK    W@ST    1
      *
     C           'BZ '     LOKUPC2KO,J                   80
     C  N80      'DS '     LOKUPC2KO,J                   80
     C  N80      'DSM'     LOKUPC2KO,J                   80
     C   80                MOVEL'*'       W@ST
     C*-------------------------*
     C* CHECK 2ND PROC PRCOCESS *
     C*-------------------------*
     C                     Z-ADD1         J
     C                     MOVEL*BLANK    W@JC    1
      *
     C           'JC '     LOKUPC2KO,J                   80
     C  N80      'SD '     LOKUPC2KO,J                   80
     C  N80      'COS'     LOKUPC2KO,J                   80
     C   80                MOVEL'*'       W@JC
     C*-------------------------*
     C* CHECK HN  PROC PRCOCESS *
     C*-------------------------*
     C                     Z-ADD1         J
     C                     MOVEL*BLANK    W@HN    1
      *
     C           'HN '     LOKUPC2KO,J                   80
     C   80                MOVEL'*'       W@HN
      *
     C                     ENDSR
     C***************************************************
      *社内かんばん切替マスターより自工程後にA-PICSかんばん有りか*
     C***************************************************
     CSR         #SUB1     BEGSR
     C           WKEY      KLIST
     C                     KFLD           KHIN1
     C                     KFLD           KHIN2
     C                     KFLD           KHIN3
      *
     C                     MOVE *BLANK    KHIN1   5
     C                     MOVE *BLANK    KHIN2   5
     C                     MOVE *BLANK    KHIN3   2
      *
     C                     MOVELC2SHN1    KHIN1
     C                     MOVELC2SHN2    KHIN2
     C                     MOVELC2SHN3    KHIN3
     C                     MOVE *BLANK    CHK     1
      *
     C                     SETOF                     77
     C           WKEY      CHAINAAMPL111             77
     C           *IN77     IFEQ '0'
     C           CKSKJY    IFEQ 'D'
     C           CKSKHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADD1         #X      20
     C                     Z-ADD0         @X      20
     C                     Z-ADDC2UBIN    WUBIN
     C                     Z-ADDC2SBIN    WSBIN
      *
     C           1         DO   15        #X
     C           @UKO,#X   IFGE C2UKHB
     C           @UKO,#X   ANDLTC2STHB
     C                     ADD  1         @X
     C                     MOVE NKAB,#X   @KS,@X
     C                     MOVE NTKR,#X   @TK,@X
     C                     ELSE
     C                     ADD  1         @X
     C                     MOVE OKAB,#X   @KS,@X
     C                     MOVE OTKR,#X   @TK,@X
     C                     END
     C                     ENDDO
      *
     C                     Z-ADD1         $X      20
     C           C2TKRO    LOKUP@TK,$X                   88
      *
     C                     ADD  1         $X
     C                     Z-ADD$X        #X      20
     C           @X        IFNE 0
     C           $X        DO   @X        #X
     C           @KS,#X    IFNE *BLANK
      *
     C           @KS,#X    IFEQ 'C'
     C           @KS,#X    OREQ 'D'
     C           @KS,#X    OREQ 'E'
     C           @KS,#X    OREQ '0'
     C           @KS,#X    OREQ 'F'
     C                     MOVE '*'       CHK
     C                     END
      *
     C                     END
     C                     ENDDO
     C                     END
      *
     C                     END
     C                     END
%0001CSR         #ESUB1    ENDSR
