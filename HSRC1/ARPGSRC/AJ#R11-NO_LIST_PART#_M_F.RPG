     H            Y.
     F** AJ#R11 *********************************************
     F* NO LIST PART# M/F
     F*    ITS.             2015.05.21                      *
     F*******************************************************
     FAJ#PW11 CF  E                    WORKSTN
     FAJ#PP11 UF  E           K        DISK                      A
     FFCEPL01 IF  E           K        DISK
     E                    ER      1  11 65
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  14 SDATE
     I                                        1   6 STIME
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTAJ#PW111
     C                     MOVEL*BLANK    D1ERR
     C                     SETOF                     313233
     C                     SETOF                     349930
      *
     C                     TIME           WTIME
     C           *IN01     IFEQ '1'
     C                     MOVEL'99'      DSPSW   2
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           *IN08     IFEQ '1'
     C                     CALL 'AJ#R12'
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1UPD     IFEQ '0'
     C           D1UPD     OREQ '2'
     C                     ELSE
     C                     SETON                     3099
     C                     MOVELER,1      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1SHN1    IFEQ *BLANK
     C           D1SHN2    ANDEQ*BLANK
     C           D1SHN3    ANDEQ*BLANK
     C                     SETON                     3199
     C                     MOVELER,2      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           KEYCN     KLIST
     C                     KFLD           D1SHN1
     C                     KFLD           D1SHN2
     C                     KFLD           D1SHN3
      *
     C           KEYCN     CHAINFCEPL011             20
     C           *IN20     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     20
     C                     ENDIF
     C           D1UPD     IFEQ '2'
     C           *IN20     IFEQ '1'
     C                     SETON                     3199
     C                     MOVELER,5      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
     C           KEYCN     CHAINAJ#PP111             20
     C           *IN20     IFEQ '0'
     C           CNSKJY    ANDEQ'D'
     C           CNSKHZ    ANDLE*DATE
     C                     SETON                     20
     C                     ENDIF
      *
     C                     SELEC
     C           D1UPD     WHEQ '0'
     C           *IN20     IFEQ '1'
     C                     SETON                     303199
     C                     MOVELER,3      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
     C           D1UPD     WHEQ '2'
     C           *IN20     IFEQ '0'
     C                     SETON                     303199
     C                     MOVELER,4      D1ERR
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDSL
      *
     C                     MOVEL'02'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C                     EXFMTAJ#PW112
     C                     MOVEL*BLANK    D1ERR
     C                     SETOF                     313233
     C                     SETOF                     349930
      *
     C           *IN03     IFEQ '1'
     C                     MOVEL'01'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           *IN05     IFEQ '1'
     C                     EXSR #SB500
     C                     MOVELD1UPD     Z1UPD
     C                     MOVELD1SHN1    Z1SHN1
     C                     MOVELD1SHN2    Z1SHN2
     C                     MOVELD1SHN3    Z1SHN3
     C                     MOVEL*BLANK    D1UPD
     C                     MOVEL*BLANK    D1SHN1
     C                     MOVEL*BLANK    D1SHN2
     C                     MOVEL*BLANK    D1SHN3
     C                     MOVEL'01'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * UPDATE                                             *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYCN     CHAINAJ#PP111             20
      *
     C                     SELEC
      *
     C           D1UPD     WHEQ '0'
     C                     MOVEL'D'       CNSKJY
     C                     Z-ADD0         CNSKHZ
     C           *IN20     IFEQ '0'
     C                     UPDATAJ#PP111
     C                     ENDIF
      *
     C           D1UPD     WHEQ '2'
     C                     CLEARAJ#PP111
     C                     Z-ADD*DATE     CNKOHZ
     C                     TIME           CNKOTI
     C                     MOVELW#USER    CNKOME
     C                     MOVELD1SHN1    CNSHN1
     C                     MOVELD1SHN2    CNSHN2
     C                     MOVELD1SHN3    CNSHN3
     C           *IN20     IFEQ '0'
     C                     UPDATAJ#PP111
     C                     ELSE
     C                     WRITEAJ#PP111
     C                     ENDIF
      *
     C                     ENDSL
      *
     CSR         ESB500    ENDSR
**
ER-1 INPUT 1 OR 2.
ER-2 INPUT PART#.
ER-3 NO DATA.
ER-4 ALREADY EXIST.
ER-5 NO PART# M/F.
