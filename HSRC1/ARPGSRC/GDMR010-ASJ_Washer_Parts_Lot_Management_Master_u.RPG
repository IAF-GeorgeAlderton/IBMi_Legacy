      *
     C                     DO
      *
     C           F2SHN1    IFEQ *BLANK
     C                     SETON                     5169
     C                     MOVELERR,2     MSG
     C                     LEAVE
     C                     END
     C* CHANGE DATE
     C           F2CHGD    IFEQ *ZERO
     C                     SETON                     5569
     C           MSG       IFEQ *BLANK
