     C                     END
     C                     MOVELM1PRT3    W@SHN3
     C                     MOVELW@SHIN    S1SHIN
     C                     MOVELM1PRT1    H1SHN1
     C                     MOVELM1PRT2    H1SHN2
     C                     MOVELM1PRT3    H1SHN3
     C*
     C                     Z-ADDM1CHGD    S1CHGD
     C                     Z-ADDM1LOTO    S1LOTO
     C                     Z-ADDM1LOTN    S1LOTN
     C*
