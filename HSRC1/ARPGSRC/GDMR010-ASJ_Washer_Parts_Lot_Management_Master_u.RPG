     C           F2BKCO    IFNE *BLANK
     C           F2BKCO    CHAINGDMPL20              97
     C           *IN97     IFEQ *OFF
     C           M2SKJY    ANDEQ*BLANK
     C                     MOVELM2BKNM    F2BKNO
     C                     ELSE
     C                     SETON                     5769
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,7     MSG
