     C                     END
     C* NEW PROCESS COLOR
     C           F2PCCN    IFEQ *BLANK
     C                     SETON                     5469
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,8     MSG
     C                     END
     C                     MOVEL*BLANK    F2PCNN
     C                     END
     C           F2PCCN    IFNE *BLANK
     C           F2PCCN    CHAINGDMPL30              97
     C           *IN97     IFEQ *OFF
     C           M3SKJY    ANDEQ*BLANK
     C                     MOVELM3PCNM    F2PCNN
     C                     ELSE
     C                     SETON                     5469
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,9     MSG
