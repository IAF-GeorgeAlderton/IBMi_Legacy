     C                     SETON                     5569
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,11    MSG
     C                     END
     C                     LEAVE
     C                     END
     C                     END
      * COMPONENT KANBAN M/F
     C           K#KEY     KLIST
     C                     KFLD           F2SHN1
     C                     KFLD           F2SHN2
     C                     KFLD           F2SHN3
     C           K#KEY     SETGTAKBPL07
     C                     DO   *HIVAL
     C           K#KEY     REDPEAKBPL07                  97
     C   97                LEAVE
     C           L1SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           L1UKHZ    IFGT F2CHGD
     C                     ITER
     C                     END
     C           L1STHZ    IFLE F2CHGD
     C                     ITER
     C                     ENDIF
     C           L1BMON    IFNE 8990
     C                     ITER
     C                     END
     C                     LEAVE
     C                     ENDDO
     C*
     C           *IN97     IFEQ *ON
     C                     SETON                     5169
     C                     MOVELERR,3     MSG
     C                     LEAVE
     C                     END
     C* LOT# M/F
     C           W@NEWF    IFEQ *ON
     C           K#KEY     CHAINGDMPL10              97
     C           *IN97     IFEQ *OFF
     C           M1SKJY    ANDEQ*BLANK
     C                     SETON                     5169
     C                     MOVELERR,4     MSG
     C                     LEAVE
     C                     END
     C                     END
     C* NEW LOT SIZE
     C           F2LOTN    IFLE *ZERO
     C                     SETON                     5269
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,5     MSG
     C                     END
     C                     END
     C* NEW BOX KIND
     C           F2BKCN    IFEQ *BLANK
     C                     SETON                     5369
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,6     MSG
     C                     END
     C                     MOVEL*BLANK    F2BKNN
     C                     END
     C           F2BKCN    IFNE *BLANK
     C           F2BKCN    CHAINGDMPL20              97
