     C                     MOVEL*BLANK    F2BKNO
     C                     END
     C                     ELSE
     C                     MOVEL*BLANK    F2BKNO
     C                     END
     C* OLD PROCESS COLOR
     C           F2PCCO    IFNE *BLANK
     C           F2PCCO    CHAINGDMPL30              97
     C           *IN97     IFEQ *OFF
     C           M3SKJY    ANDEQ*BLANK
     C                     MOVELM3PCNM    F2PCNO
     C                     ELSE
     C                     SETON                     5869
     C           MSG       IFEQ *BLANK
