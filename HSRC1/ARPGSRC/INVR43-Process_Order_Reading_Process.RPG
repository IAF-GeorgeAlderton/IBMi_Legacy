     H            Y.                                    1
     F** INVR43 **********************************
     F*工程順読み処理
     F* SHORTしている工程の生産時間を設定
     F*
     F********************************** INVR42 **
     FINVWP41 UP  E                    DISK
      *
     E                    TB1     1  16  4   TB2     2 0
      *
     IINVWP411
     I                                              A2BHB1L1
     I                                              A2BHB2L1
     I                                              A2BHB3L1
      *
     I            DS
     I                                        1  140W@TIME
     I                                        1   60W@THMS
     I                                        1   20W@TH
     I                                        3   40W@TM
     I                                        5   60W@TS
     I                                        7  140W@DYMD
     I                                        7  100W@DY
     I                                       11  120W@DM
     I                                       13  140W@DD
      *
     I            DS
     I                                        1  140@@TIME
     I                                        1   60@@THMS
     I                                        1   20@@TH
     I                                        3   40@@TM
     I                                        5   60@@TS
     I                                        7  140@@DYMD
     I                                        7  100@@DY
     I                                       11  120@@DM
     I                                       13  140@@DD
     I            DS
     I                                        1  260WWDATE
     I                                        1   60WWDAT1
     I                                        7  200WWYMDT
     I                                        7  140WWYMD
     I                                       15  200WWTIM
     I                                       21  260WWDAT2
      *
     C           *INL1     IFEQ '1'
     C                     Z-ADD0         @@TIME
     C                     END
      * 90119A0281
     C           A2BHB1    IFEQ '90119'
     C           A2BHB2    ANDEQ'A0281'
     C           A2BHB3    ANDEQ'  '
     C                     Z-ADD0         SAKA    40
     C                     END
      * LT
     C           P#KOTE    IFEQ 'BM '
     C                     Z-ADD0         SAKA
     C                     END
     C                     CALL 'INVRS3'
     C                     PARM           P#BMON
     C                     PARM           P#KOTE
     C                     PARM           P#KIBN
     C                     PARM           @DAY    20
     C                     PARM           @JJ     20
     C                     PARM           @MN     20
     C                     PARM           @SHTG   2
      *
     C           W@SHTQ    IFNE 0
     C           @@TIME    IFEQ 0
     C                     Z-ADDW@TIME    @@TIME
     C                     END
     C                     EXSR #TIME
     C                     ELSE
     C                     Z-ADD0         @@TIME
     C                     END
      *
     C                     Z-ADD@@DYMD    ##DYMD
     C                     Z-ADD@@THMS    ##THMS
      *
     C                     UPDATINVWP411
      *-----------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     TIME           W@TIME
      *
     C                     Z-ADDW@DYMD    A@IDAT  80
     C                     Z-ADDW@THMS    A@ITIM  60
     C                     MOVE 'F'       A@PF    1
     C                     Z-ADD60        A@PA    50
     C                     Z-ADD0         A@ODAT  80
     C                     Z-ADD0         A@OTIM  60
      *
     C                     CALL 'DATR49'
     C                     PARM           A@IDAT  80
     C                     PARM           A@ITIM  60
     C                     PARM           A@PF    1
     C                     PARM           A@PA    50
     C                     PARM           A@ODAT  80
     C                     PARM           A@OTIM  60
      *
     C                     Z-ADDA@ODAT    W@DYMD
     C                     Z-ADDA@OTIM    W@THMS
     C                     Z-ADD0         W@TM
     C                     Z-ADD0         W@TS
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #TIME     BEGSR
      *
     C                     MOVE *BLANK    KEY
     C                     MOVELP#KOTE    KEY     4
     C           P#BMON    IFEQ '0111'
     C           P#KOTE    ANDEQ'BZ '
     C                     MOVELP#KIBN    KIBN    1
     C                     MOVE KIBN      KEY
     C                     END
      *
     C* * *                Z-ADD0         @JJ     20
     C                     Z-ADD1         @Z      20
     C           KEY       LOKUPTB1,@Z                   88
     C           *IN88     IFEQ '1'
     C* * *                Z-ADDTB2,@Z    @JJ
     C                     Z-ADDTB2,@Z    TB2,@Z
     C                     END
      *
     C                     Z-ADD0         WWDAT1
     C                     Z-ADD@@DYMD    WWYMD
     C                     Z-ADD@@THMS    WWTIM
     C                     Z-ADD0         WWDAT2
      *
     C                     MOVE WWDATE    PIDATE 260
     C                     MOVE 'D'       PF      1
     C                     Z-ADD@DAY      PA      50
     C                     Z-ADD0         PODATE 260
     C                     CALL 'YX003G'
     C                     PARM           PIDATE 260
     C                     PARM           PF      1
     C                     PARM           PA      50
     C                     PARM           PODATE 260
      *
     C                     MOVE PODATE    PIDATE
     C                     MOVE 'J'       PF      1
     C                     Z-ADD@JJ       PA      50
     C                     Z-ADD0         PODATE 260
     C                     CALL 'YX003G'
     C                     PARM           PIDATE 260
     C                     PARM           PF      1
     C                     PARM           PA      50
     C                     PARM           PODATE 260
      *
     C                     MOVE PODATE    PIDATE
     C                     MOVE 'F'       PF      1
     C                     Z-ADD@MN       PA      50
     C                     Z-ADD0         PODATE 260
     C                     CALL 'YX003G'
     C                     PARM           PIDATE 260
     C                     PARM           PF      1
     C                     PARM           PA      50
     C                     PARM           PODATE 260
      *
     C                     MOVE PODATE    WWDATE
     C                     Z-ADDWWYMD     @@DYMD
     C                     Z-ADDWWTIM     @@THMS
      *
     C                     ENDSR
      *
** TB1/TB2
BM  04
HD  03
RL  03
OQ  05
LAN 02
AOQ 02
LOQ 06
BZ A08
BZ B08
BZ C03
BZ D06
DS  04
DSM 04
SB  01
KRO 01
JC  01
