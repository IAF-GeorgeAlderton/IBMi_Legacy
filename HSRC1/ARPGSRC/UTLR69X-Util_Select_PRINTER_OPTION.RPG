     H            Y.
     F** UTLR68 ********************************************
     F*  PROGRAM: UTILITY- GET LOT SIZE                    *
     F*  WRITTEN: JW (SRA) 2019.01.03                      *
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR68'
     F*                    PARM           $SHN   12
     F*                    PARM           $DATE   8
     F*                    PARM           $LOT    2
     F*                    PARM           $RTN    1
     F*  IN  $SHN  : 12A IAF PART
     F*      $DATE :  8A TARGET DATE (BLANK=TODAY)
     F*  OUT $LOT  :  2A LOT SIZE
     F*      $RTN  :  1A RETURN CODE (BLANK/*)
     F******************************************************
     FAAHTL06 IF  E           K        DISK
     FAAFTL06 IF  E           K        DISK
      *===================================================
      * SYSTEM DATE
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      * KEY FIELDS
     I            DS
     I                                        1  12 K#SHN
     I                                        1   5 K#SHN1
     I                                        6  10 K#SHN2
     I                                       11  12 K#SHN3
      * KEY FIELDS
     I            DS
     I                                        1   80K#STHZ
     I                                        1   40K#STYY
     I                                        5   60K#STMM
     I                                        7   80K#STDD
      * EFFECTIVE START (AAH)
     I            DS
     I                                        1   80L6UKHZ
     I                                        1   40L6UKYY
     I                                        5   60L6UKMM
     I                                        7   80L6UKDD
      * EFFECTIVE END   (AAH)
     I            DS
     I                                        1   80L6STHZ
     I                                        1   40L6STYY
     I                                        5   60L6STMM
     I                                        7   80L6STDD
      * EFFECTIVE START (AAP)
     I            DS
     I                                        1   80L5UKHZ
     I                                        1   40L5UKYY
     I                                        5   60L5UKMM
     I                                        7   80L5UKDD
      * EFFECTIVE END   (AAP)
     I            DS
     I                                        1   80L5STHZ
     I                                        1   40L5STYY
     I                                        5   60L5STMM
     I                                        7   80L5STDD
      * LOCATION
     I            DS
     I                                        1   6 K@LOC
     I                                        1   1 K@LOC1
     I                                        2   3 K@LOC2
     I                                        4   5 K@LOC3
     I                                        6   6 K@LOC4
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      * GET LAST LOCATION
     C                     MOVEL$SHIN     P@SHIN
     C                     CALL 'UTLR21'
     C                     PARM           P@SHIN 12
     C                     PARM           $LLOC   6
     C                     PARM           $LQC    50
     C                     PARM           $LPRC   3
     C                     PARM           $LDPT   40
     C                     PARM           $ZETI   4
     C                     PARM           $RTN1   1
      *
     C                     EXSR #AAH
      *
     C           @LOT      IFEQ 0
     C                     EXSR #AAF
     C                     ENDIF
      *
     C           @LOT      IFEQ 0
     C                     MOVEL'00'      $LOT
     C                     MOVE '*'       $RTN
     C                     ELSE
     C                     Z-ADD@LOT      @NUM2   20
     C                     MOVEL@NUM2     $LOT
     C                     MOVE *BLANK    $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *===================================================
      *          CHECK AAH - PART WITHDRAWAL KANBAN M/F
      *===================================================
     C           #AAH      BEGSR
      *
     C                     Z-ADD0         @LOT
     C                     MOVEL$SHIN     K#SHN
     C           K#AAX     SETLLAAHTL06
     C                     DO   *HIVAL
     C           K#AAX     READEAAHTL06                  88
     C   88                LEAVE
      *
     C           L6SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           TODAY     IFLT L6UKHZ
     C           TODAY     ORGT L6STHZ
     C                     ITER
     C                     ENDIF
      *
     C           L6LOTO    IFEQ 0
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADDL6LOTO    @LOT    20
     C                     LEAVE
      *
     C                     ENDDO
      *
     C                     ENDSR
      *===================================================
      *          CHECK AAF - PLATING KANBAN M/F
      *===================================================
     C           #AAF      BEGSR
      *
     C           K#AAX     SETLLAAFTL06
     C                     DO   *HIVAL
     C           K#AAX     READEAAFTL06                  88
     C   88                LEAVE
      *
     C           A3SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           TODAY     IFLT A3UKHZ
     C           TODAY     ORGT A3STHZ
     C                     ITER
     C                     ENDIF
      *
     C           A3BARA    IFEQ 0
     C           A3BARB    ANDEQ0
     C                     ITER
     C                     ENDIF
      *
     C           A3BARA    IFGE A3BARB
     C                     Z-ADDA3BARA    @LOT
     C                     ELSE
     C                     Z-ADDA3BARB    @LOT
     C                     ENDIF
      *
     C                     LEAVE
      *
     C                     ENDDO
      *
     C                     ENDSR
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SHIN  12
     C                     PARM           $DATE   8
     C                     PARM           $LOT    2
     C                     PARM           $RTN    1
      *
     C           K#AAX     KLIST
     C                     KFLD           K#SHN1  5
     C                     KFLD           K#SHN2  5
     C                     KFLD           K#SHN3  2
     C**                   KFLD           K#STYY  40
     C**                   KFLD           K#STMM  20
     C**                   KFLD           K#STDD  20
      * SYSTEM DATE
     C                     TIME           SDATE
     C                     MOVEL'00'      $LOT
     C                     MOVE *BLANK    $RTN
      *
     C           $DATE     IFNE *BLANK
     C                     MOVEL$DATE     TODAY
     C                     ENDIF
      *
     C                     ENDSR
      *====================================================
