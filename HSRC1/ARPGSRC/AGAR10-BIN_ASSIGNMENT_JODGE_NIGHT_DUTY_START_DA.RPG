     H            Y.
     F** AGAR10 **********************************
     F*BIN ASSIGNMENT JODGE NIGHT DUTY START DATE & EXIT DATE *
     F*        NOV.11,86. GBC                    *
     F********************************** AGAR10 **
     FAAIPL11 IF  E           K        DISK
     I            DS
     I                                        1   80CDSTHZ
     I                                        1   40CDSTYY
     I                                        5   60CDSTMM
     I                                        7   80CDSTDD
     I            DS
     I                                        1   80CDENHZ
     I                                        1   40CDENYY
     I                                        5   60CDENMM
     I                                        7   80CDENDD
     C****************************************************************
     C*  START PROGRAM  <AGAR10>                                     *
     C****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           F04     4
     C*
     C                     Z-ADD0         CDSTHZ
     C                     Z-ADD0         CDENHZ
     C                     Z-ADD0         CDTOHZ
     C                     Z-ADD0         CDYOHZ
     C           *LOVAL    SETLLAAIPL111
     C                     READ AAIPL111                 10
     C   10                GOTO @END
     C*
     C           CDSTHZ    IFEQ CDYOHZ
     C                     CALL 'AGAR12'
     C                     PARM           F04
     C                     ELSE
     C           CDSTHZ    IFEQ CDTOHZ
     C                     CALL 'AGAR13'
     C                     PARM           F04
     C                     ELSE
     C           CDENHZ    IFEQ CDYOHZ
     C                     CALL 'AGAR14'
     C                     PARM           F04
     C                     ELSE
     C           CDENHZ    IFEQ CDTOHZ
     C                     CALL 'AGAR15'
     C                     PARM           F04
     C                     ELSE
     C                     CALL 'AGAR11'
     C                     PARM           F04
     C                     END
     C                     END
     C                     END
     C                     END
     C*
     C           @END      TAG
     C                     MOVEL'1'       *INLR
     C                     RETRN
