     H            Y.
     F*********************************************************
     F* INTRAL COMPANY SERVICE BIN M/F AAKR12 *
     F* M S K                                                 *
     F*********************************************************
     FAAKTL13 IP  E           K        DISK
     FRGAPL11 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FAAKPR12 O   E             99     PRINTER
     E                    $MSG    1   4 14
     IAAKTL131    01
     I                                              DFBSYUL1
     I            DS
     I                                        1   2 WKBINN
     I                                        3   3 WKUND
     I                                        4   5 WKBINS
     I                                        1   5 WKBIN
     I            DS
     I                                        1   4 WKSUN
     I                                        1   1 IN1
     I                                        2   3 SUN
     I                                        4   4 OUT1
     I            DS
     I                                        1   4 WKMON
     I                                        1   1 IN2
     I                                        2   3 MON
     I                                        4   4 OUT2
     I            DS
     I                                        1   4 WKTUE
     I                                        1   1 IN3
     I                                        2   3 TUE
     I                                        4   4 OUT3
     I            DS
     I                                        1   4 WKWED
     I                                        1   1 IN4
     I                                        2   3 WED
     I                                        4   4 OUT4
     I            DS
     I                                        1   4 WKTHU
     I                                        1   1 IN5
     I                                        2   3 THU
     I                                        4   4 OUT5
     I            DS
     I                                        1   4 WKFRI
     I                                        1   1 IN6
     I                                        2   3 FRI
     I                                        4   4 OUT6
     I            DS
     I                                        1   4 WKSAT
     I                                        1   1 IN7
     I                                        2   3 SAT
     I                                        4   4 OUT7
     I            DS
     I                                        1   1 IN
     I                                        2   3 SUN1
     I                                        4   5 MON1
     I                                        6   7 TUE1
     I                                        8   9 WED1
     I                                       10  11 THU1
     I                                       12  13 FRI1
     I                                       14  15 SAT1
     I                                       16  16 OUT
     I                                        1  16 NOUNY
     C           *ENTRY    PLIST
     C                     PARM           PARM1  10
     C           FSW       IFEQ ' '
     C                     MOVE PARM1     #WKEY  10
     C           #WKEY     CHAINRGAPL111             70
     C           *IN70     IFEQ '0'
     C                     MOVELJ8NAME    @HNAME
     C                     END
     C                     TIME           @TIME
     C                     MOVE *DATE     @DATE
     C                     Z-ADD1         @PAGE
     C                     MOVEL'*'       FSW     1
     C                     WRITEAAKPR121
     C                     END
     C                     MOVE DFTSEQ    @JUN
     C                     MOVE DFBSYU    @BINSH
     C                     Z-ADD0         DCTR    10
     C           DFGKKB    IFEQ 'M'
     C                     MOVEL$MSG,1    @JOTAI
     C                     END
     C           DFGKKB    IFEQ 'G'
     C                     MOVEL$MSG,2    @JOTAI
     C                     END
     C           DFGKKB    IFEQ 'K'
     C                     MOVEL$MSG,3    @JOTAI
     C                     END
     C           DFGKKB    IFEQ 'I'
     C                     MOVEL$MSG,4    @JOTAI
     C                     END
     C           DFGKKB    IFEQ ' '
     C           DFSUND    IFNE *BLANK
     C                     ADD  1         DCTR    10
     C                     MOVE 'SUN '    WKSUN
     C                     END
     C           DFMOND    IFNE *BLANK
     C                     ADD  1         DCTR
     C                     MOVE 'MON '    WKMON
     C                     END
     C           DFTUED    IFNE *BLANK
     C                     ADD  1         DCTR
     C                     MOVE 'TUE '    WKTUE
     C                     END
     C           DFWEDD    IFNE *BLANK
     C                     ADD  1         DCTR
     C                     MOVE 'WED '    WKWED
     C                     END
     C           DFTHUD    IFNE *BLANK
     C                     ADD  1         DCTR
     C                     MOVE 'THR '    WKTHU
     C                     END
     C           DFFRID    IFNE *BLANK
     C                     ADD  1         DCTR
     C                     MOVE 'FRI '    WKFRI
     C                     END
     C           DFSATD    IFNE *BLANK
     C                     ADD  1         DCTR
     C                     MOVE 'SAT '    WKSAT
     C                     END
     C           DCTR      IFEQ 7
     C                     MOVEL$MSG,1    @JOTAI
     C                     ELSE
     C                     MOVEL'  '      IN
     C                     MOVE '  '      OUT
     C                     MOVE SUN       SUN1
     C                     MOVE MON       MON1
     C                     MOVE TUE       TUE1
     C                     MOVE WED       WED1
     C                     MOVE THU       THU1
     C                     MOVE FRI       FRI1
     C                     MOVE SAT       SAT1
     C                     MOVE NOUNY     @JOTAI
     C                     END
     C                     END
     C                     MOVE DFBINN    WKBINN
     C                     MOVE DFBINS    WKBINS
     C                     MOVE '/'       WKUND
     C                     MOVE WKBIN     @BINS
     C           DFCBIN    IFNE *ZERO
     C                     MOVE DFCBIN    @CHG
     C                     ELSE
     C                     MOVE *BLANK    @CHG
     C                     END
     C                     MOVE DFHRYR    @KUBUN
     C                     MOVE DFSTHH    @HH1
     C                     MOVE DFSTMM    @MM1
     C                     MOVE DFSBMN    @CORD1
     C                     MOVE DFSBMN    #BKEY   40
     C           #BKEY     CHAINFGBPL011             71
     C           *IN71     IFEQ '0'
     C                     MOVELB2SMEI    @NAME1
     C                     ELSE
     C                     MOVE *BLANK    @NAME1
     C                     END
     C                     MOVE DFTYHH    @HH2
     C                     MOVE DFTYMM    @MM2
     C                     MOVE DFCDAY    @CHO
     C                     MOVE DFTMHH    @HH3
     C                     MOVE DFTMMM    @MM3
     C                     MOVE DFTBMN    @CORD2
     C                     MOVE DFTBMN    #BKEY   40
     C           #BKEY     CHAINFGBPL011             71
     C           *IN71     IFEQ '0'
     C                     MOVELB2SMEI    @NAME2
     C                     ELSE
     C                     MOVE *BLANK    @NAME2
     C                     END
     C                     WRITEAAKPR122
     C                     MOVE *BLANK    @JOTAI
     C                     MOVE *BLANK    NOUNY
     C                     MOVE *BLANK    WKSUN
     C                     MOVE *BLANK    WKMON
     C                     MOVE *BLANK    WKTUE
     C                     MOVE *BLANK    WKWED
     C                     MOVE *BLANK    WKTHU
     C                     MOVE *BLANK    WKFRI
     C                     MOVE *BLANK    WKSAT
     C           *IN99     IFEQ '1'
     C                     ADD  1         @PAGE
     C                     WRITEAAKPR121
     C                     SETOF                       99
     C                     END
     CL1                   WRITEAAKPR123
**
DELV EVERY DAY
DELV EVEN DAY
DELV ODD DAY
DELV EVR 2DAYS
