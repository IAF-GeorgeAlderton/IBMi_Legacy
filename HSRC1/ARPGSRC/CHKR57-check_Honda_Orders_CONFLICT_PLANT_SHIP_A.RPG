     H            Y.
     F** CHKR57 ****************************************************************
     F*  PROGRAM    : CHECK HONDA ORDERS CONFLICT PLANT/SHIP CODE              *
     F*  WRITTEN    : 2019.07.03                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#PL2A5IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           @DATE     SETLLAB#PL2A5
     C                     DO   *HIVAL
     C                     READ AB#PL2A5                 98
     C   98                LEAVE
      * SELECT
     C           ACUPID    IFEQ '1'
     C                     ITER
     C                     ENDIF
      * FIRST ?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     Z-ADDACNONY    SVNONY
     C                     MOVELACNKOJ    SVNKOJ
     C                     MOVELACNUKE    SVNUKE
     C                     Z-ADDACBIN     SVBIN
     C                     MOVELACPLNT    SVPLNT
     C                     MOVELACSHCD    SVSHCD
     C                     ENDIF
      * BREAK ?
     C           ACNONY    IFNE SVNONY
     C           ACNKOJ    ORNE SVNKOJ
     C           ACNUKE    ORNE SVNUKE
     C           ACBIN     ORNE SVBIN
     C                     EXSR #BRK1
     C                     ENDIF
      * DETAIL PROCESS
     C           ACPLNT    IFNE SVPLNT
     C           ACSHCD    ORNE SVSHCD
     C                     EXSR #PRINT
     C                     MOVELACPLNT    SVPLNT
     C                     MOVELACSHCD    SVSHCD
     C                     ENDIF
      *
     C                     ENDDO
      * LAST BRAEK
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK1
     C                     ENDIF
      *
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  BREAK                                             *
      *----------------------------------------------------*
     C           #BRK1     BEGSR
      *
     C                     Z-ADDACNONY    SVNONY
     C                     MOVELACNKOJ    SVNKOJ
     C                     MOVELACNUKE    SVNUKE
     C                     Z-ADDACBIN     SVBIN
     C                     MOVELACPLNT    SVPLNT
     C                     MOVELACSHCD    SVSHCD
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $DATE   8
     C                     PARM           $RTN    1
      *
     C                     MOVEL$DATE     @DATE   80
     C                     MOVE *BLANK    $RTN
     C                     TIME           SDATE
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
      *
     C                     Z-ADD0         SVNONY  40
     C                     MOVE *BLANK    SVNKOJ  1
     C                     MOVE *BLANK    SVNUKE  4
     C                     Z-ADD0         SVBIN   20
     C                     MOVE *BLANK    SVPLNT  3
     C                     MOVE *BLANK    SVSHCD 10
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** CHECK HONDA ORDER'
     O                                   60 'S CONFLICT PLANT/SHI'
     O                                   80 'P CODE **           '
     O                                   89 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                                  106 'P.'
     O                         PAGE  Z  110
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   12 'CUST'
     O                                   17 'DELV'
     O                                   33 'SHP_DATE'
     O                                   40 'BIN#'
     O                                   54 'PLANT/SHIP 1'
     O                                   72 'PLANT/SHIP 2'
     O        E 1              @DTL
     O                         SEQ#  1 +000
     O                         ACTOKU  +003
     O                         ACNONY  +001
     O                         ACNKOJ  +001
     O                         ACNUKE  +001
     O                         ACPLSH  +001 '    /  /  '
     O                         ACBIN   +002
     O                         ACPLNT  +003
     O                                 +001 '/'
     O                         ACSHCD  +001
     O                         SVPLNT  +002
     O                                 +001 '/'
     O                         SVSHCD  +001
     O**                       XNAME   +003
