     H            Y.
     F** AJCR10 ***********************************
     F* ..SELECT ELECTRIC POWER OFF MENU..        *
     F*    H AMANO             03.06.06           *
     F*                                           *
     F* TCHK1 02/27/14 CHG INITIAL DISPLAY TIME   *
JW1  F* JW    12/09/16 ADD CALL AJCC15            *
JW2  F* JW    02/07/18 CHG SCREEN FORMAT NAME     *
JW3  F* JW  2025.12.05 CHG SELECTION              *
     F*********************************************
     FAJCPW10 CF  E                    WORKSTN
     FAGDPL12 IF  E           K        DISK
     E**                  ER      1   5 60
JW3  E                    ER      1   7 60
     I            DS
     I                                        1   6 JIKN
     I                                        1   2 @HH
     I                                        3   4 @MM
     I                                        5   6 @SS
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80F8YMD
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
      *
     C                     Z-ADD2         INO1
TCHK1C*                    MOVEL'130000'  JIKN
TCHK1C                     MOVEL'060000'  JIKN
     C                     MOVEL'N'       INO3
     C                     Z-ADD*DATE     K@YMD
     C           K#AGD     SETGTAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READ AGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8YOBI    ANDEQ7
     C                     MOVE F8YMD     IDATE
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           STP1      TAG
     C**JW2                EXFMTAJCPW011
JW2  C                     EXFMTAJCPW101
     C                     SETOF                     0199
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           INO1      IFEQ 0
     C                     SETON                     0199
     C**                   MOVE ER,1      MSG
JW3  C                     MOVE ER,6      MSG              SELECT "2"
     C                     GOTO STP1
     C                     END
      *
     C**         INO1      IFNE 1
     C**         INO1      ANDNE2
JW3  C           INO1      IFNE 2
     C                     SETON                     0199
     C**                   MOVE ER,2      MSG
JW3  C                     MOVE ER,6      MSG              SELECT "2"
     C                     GOTO STP1
     C                     END
      *
     C           INO1      IFEQ 1
     C           *INKE     IFEQ '0'
     C                     GOTO STP1
     C                     ELSE
      *
     C                     MOVE INO1      PNO1    1
     C                     MOVE *BLANK    PNO2    1
     C                     MOVE *BLANK    JIKN
     C                     MOVE *BLANK    PNO3    1
      *
     C                     CALL 'AJCC02'
     C                     PARM           PNO1
     C                     PARM           PNO2
     C                     PARM           JIKN
     C                     PARM           PNO3
     C                     END
     C                     END
      *
     C                     Z-ADD1         INO2
      *
     C           STP2      TAG
     C*JW2                 EXFMTAJCPW012
JW2  C                     EXFMTAJCPW102
     C                     SETOF                     0299
     C                     SETOF                     030405
      *
     C           *INKB     IFEQ '1'
     C                     Z-ADD0         INO1
     C                     GOTO STP1
     C                     END
      *
     C           INO2      IFEQ 0
     C                     SETON                     0299
     C**                   MOVE ER,1      MSG
JW3  C                     MOVE ER,7      MSG              SELET "1"
     C                     GOTO STP2
     C                     END
      *
     C**         INO2      IFNE 1
     C**         INO2      ANDNE2
     C**         INO2      ANDNE3
     C**         INO2      ANDNE4
JW3  C           INO2      IFNE 1
     C                     SETON                     0299
     C**                   MOVE ER,2      MSG
JW3  C                     MOVE ER,7      MSG              SELET "1"
     C                     GOTO STP2
     C                     END
      *
     C           INO2      IFEQ 1
      *
JW3  C           JIKN      IFEQ *BLANK
 .   C                     SETON                     0399
 .   C                     MOVE ER,3      MSG
 .   C                     GOTO STP2
JW3  C                     END
      *
     C           JIKN      IFNE *BLANK
      *
     C           @HH       IFGT '23'
     C                     SETON                     0399
     C                     MOVE ER,3      MSG
     C                     GOTO STP2
     C                     END
      *
     C           @MM       IFGT '59'
     C                     SETON                     0399
     C                     MOVE ER,3      MSG
     C                     GOTO STP2
     C                     END
      *
     C           @SS       IFGT '59'
     C                     SETON                     0399
     C                     MOVE ER,3      MSG
     C                     GOTO STP2
     C                     END
      *
     C           IDATE     IFEQ *BLANK
     C                     SETON                     0599
     C                     MOVE ER,5      MSG
     C                     GOTO STP2
     C                     ENDIF
      *
     C                     MOVE IDATE     K@YMD
     C           K@YMD     IFLT *DATE
     C                     SETON                     0599
     C                     MOVE ER,5      MSG
     C                     GOTO STP2
     C                     ENDIF
      *
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     0599
     C                     MOVE ER,5      MSG
     C                     GOTO STP2
     C                     ENDIF
      *
     C           K@YMD     IFEQ *DATE
     C                     TIME           @TIM    60
     C                     MOVE @TIM      @TIMC   6
     C           JIKN      IFLE @TIMC
     C                     SETON                     059903
     C                     MOVE ER,5      MSG
     C                     GOTO STP2
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
      *
     C**         INO3      IFNE 'Y'
     C**         INO3      ANDNE'N'
JW3  C           INO3      IFNE 'N'
     C                     SETON                     0499
     C                     MOVE ER,4      MSG
     C                     GOTO STP2
     C                     END
     C                     END
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP2
     C                     END
      *
JW1   * UPDATE DTAARA(AJCC10D1)
JW1  C                     MOVELIDATE     $DATE
JW1  C                     MOVELJIKN      $TIME
JW1  C                     CALL 'AJCC15'
JW1  C                     PARM           $DATE   8
JW1  C                     PARM           $TIME   6
      *
     C                     MOVE INO1      PNO1    1
     C                     MOVE INO2      PNO2    1
     C                     MOVE INO3      PNO3    1
     C                     MOVE IDATE     DAT6    6
      *
     C                     CALL 'AJCC10'
     C                     PARM           PNO1
     C                     PARM           PNO2
     C                     PARM           JIKN
     C                     PARM           PNO3
     C                     PARM           DAT6
      *
     C                     SETON                     LR
     C                     RETRN
      *-------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
      *
     C                     ENDSR
      *-------------------------------------------------
** ER (60A) .......2.........3.........4.........5.........6
E-01 NUMBER IS NOT INPUT.
E-02 NUMBER IS NOT RIGHT.
E-03 BACKUP TIME IS NOT CORRECT
E-04 POWER DOWN OPTION IS NOT CORRECT
E-05 DATE ERROR.
E-06 SELECT "2"                                                JW3
E-07 SELECT "1"                                                JW3
