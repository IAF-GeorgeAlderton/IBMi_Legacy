      *--------------------------------------------------------------
      *     MAIN ROUTINE
      *--------------------------------------------------------------
     C                     Z-ADD0         ERRCD   20
      * CHECK DOCK CODE
     C           ABDOCK    IFNE @@DOCK
     C                     EXSR #DCHK
     C                     MOVE *BLANK    K@PART
     C                     MOVEL*BLANK    @MHIN
     C                     EXSR #P20
     C                     ENDIF
      *
     C           ERRCD     IFEQ *ZERO
     C           ABCUST    IFNE @@TOKU
     C           WNONY     ORNE @@NONY
     C           K#25      CHAINABAEP25              90
     C           *IN90     IFEQ *ON
     C                     MOVE ABCUST    AACUST
     C                     Z-ADDWNONY     AASHTO
     C                     WRITEABAEP251
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVELABDOCK    @@DOCK  5
     C                     MOVE ABCUST    WTOKU   40
     C                     MOVE ABFACT    WNKOJ   1
      *
     C           ABPART    IFNE @@PART
     C           @MHIN     OREQ *BLANK
      *
     C                     EXSR #PCHK
     C                     Z-ADD*ZERO     @@CNT   30
      * CUM QTY
     C                     EXSR #CUM
      *
     C                     MOVELABREL#    K@POR#
     C                     MOVEL@MHIN     WIPAR
TCHK2C*          KEY9      CHAINABRPP30              95
TCHK2C*          *IN95     IFEQ *ON
TCHK2C*                    MOVE '1'       @OK
TCHK2C*                    ELSE
TCHK2C*                    MOVE *BLANK    @OK     1
TCHK2C*                    ENDIF
      * ABRPP30
     C                     EXSR #P30
      *
      * ABRPP20
     C                     MOVELABPART    K@PART    P
     C                     EXSR #P20
      *
E01  C                     ENDIF
      *
     C                     MOVE ABPART    @@PART 40
     C                     MOVE ABREL#    @@REL# 10
      *
     C                     Z-ADDWNONY     @@NONY  40
     C                     MOVE ABCUST    @@TOKU  4
      * FORECAST FILE
     C                     MOVE *OFF      *IN77
     C                     MOVEL'C'       WNOKN   1
     C                     MOVE ABCUST    K@CUST
     C           KEY5      SETLLGADPL111
     C           *IN10     DOUEQ*ON
     C           KEY5      READEGADPL111                 10
     C           *IN10     IFEQ *OFF
     C           B5SKJY    ANDEQ*BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C*
     C           *IN10     IFEQ '1'
     C                     SETON                     0577
     C                     Z-ADD2         ERRCD
     C                     ELSE
     C                     EXSR #FCST
     C           WSURY     CABEQ*ZERO     @JUMP
     C                     ENDIF
      *
     C                     EXCPTDTL
     C* ABRPP10
TCHK2C*          @OK       IFEQ '1'
     C                     EXSR #P10
TCHK2C*                    ENDIF
      *
     C           @JUMP     TAG
      *------------------------------------------------------
      *  CHECK DOCK CODE
      *------------------------------------------------------
     C           #DCHK     BEGSR
      *
     C           ABCUST    IFEQ '2855'
     C                     MOVEL'2855'    WNONY
     C                     END
     C           ABCUST    IFEQ '2856'
     C                     MOVEL'2856'    WNONY
     C                     END
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK PART CODE
      *------------------------------------------------------
     C           #PCHK     BEGSR
      *
     C                     MOVEAABPART    IUHN
     C                     MOVE *BLANK    WUHN
     C                     Z-ADD0         X       20
     C                     Z-ADD0         Y       20
     C           1         DO   40        X
     C           IUHN,X    IFNE *BLANK
     C           IUHN,X    ANDNE'-'
     C                     ADD  1         Y
     C                     MOVE IUHN,X    WUHN,Y
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAWUHN      @MHIN  40
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CUM QTY
      *------------------------------------------------------
     C           #CUM      BEGSR
      *
     C                     Z-ADD*ZERO     WWCUM  100
     C                     MOVE ABDOCK    K32
     C                     MOVEL@MHIN     K33    12
     C                     Z-ADDABCSDT    @@DAT6
     C                     MOVE *LOVAL    K31     60
     C           KEY3      SETGTABRPL0X
     C           *IN90     DOUEQ*ON
     C           KEY7      REDPEABRPL0X                  90
     C           *IN90     IFEQ '0'
     C           FBQTCD    ANDEQ'W'
     C                     Z-ADDFBQTY1    WWCUM
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           WWCUM     IFEQ *ZERO
     C                     MOVEL@MHIN     WIPAR
     C                     MOVELABDOCK    K@DOC
     C           K#FA      SETLLABRAL01
     C           *IN90     DOUEQ*ON
     C           K#FA      READEABRAL01                  90
     C           *IN90     IFEQ *OFF
     C           CFCAMN    ANDNE*ZERO
     C                     Z-ADDCFCAMN    WWCUM
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  WRITE RECORDS TO ABRPP30
      *------------------------------------------------------
     C           #P30      BEGSR
      *
TCHK2C*                    MOVE *BLANK    @OK     1
     C                     MOVEL@MHIN     WIPAR
     C                     MOVELABREL#    K@POR#
     C           KEY8      CHAINABRPP301             91
     C           *IN91     IFEQ '1'
     C                     CLEARABRPP301
     C                     Z-ADD*YEAR     CGUPDY
     C                     Z-ADD*MONTH    CGUPDM
     C                     Z-ADD*DAY      CGUPDD
     C                     Z-ADDWTIHH     CGUPTH
     C                     Z-ADDWTIMM     CGUPTM
     C                     MOVE #USER     CGUPNM
     C                     MOVE ABDOCK    CGDOCK
     C                     MOVE WIPAR     CGPART
     C                     MOVELABREL#    CGPOR#
     C                     Z-ADDABSIDT    CGSIDT
     C                     Z-ADDABHSDT    CGHSDT
     C                     WRITEABRPP301
     C*
TCHK2C*                    MOVE '1'       @OK     1
     C                     ELSE
      *
      *  SCHEDULE ISSUDE DATE IS LATER
      * OR
      *  SCHEDULE ISSUDE DATE IS SAME & RELEASE # IS BIGGER
TCHK2C*          @OK       IFEQ '1'
     C           ABSIDT    IFGT CGSIDT
     C           ABSIDT    OREQ CGSIDT
     C           ABREL#    ANDGTCGPOR#
     C                     Z-ADD*YEAR     CGUPDY
     C                     Z-ADD*MONTH    CGUPDM
     C                     Z-ADD*DAY      CGUPDD
     C                     Z-ADDWTIHH     CGUPTH
     C                     Z-ADDWTIMM     CGUPTM
     C                     MOVE #USER     CGUPNM
     C                     MOVELABREL#    CGPOR#
     C                     Z-ADDABSIDT    CGSIDT
     C                     Z-ADDABHSDT    CGHSDT
     C                     UPDATABRPP301
TCHK2C*                    MOVE '1'       @OK     1
     C                     ENDIF
TCHK2C*                    ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  WRITE RECORDS TO ABRPP10
      *------------------------------------------------------
     C           #P10      BEGSR
      *
     C                     CLEARABRPP101
     C                     MOVELABREL#    FBREL#
     C                     Z-ADDABHSDT    FBHSDT
     C                     Z-ADDABHEDT    FBHEDT                       T DATE
     C                     Z-ADDABSIDT    FBSIDT                       DATE
     C                     MOVELABDOCK    FBDOCK                       UE DATE
     C                     MOVELABPART    FBPART
     C                     MOVEL@MHIN     FBIPAR
     C                     MOVELABORD#    FBORD#
     C                     MOVELABRDCD    FBRDCD
     C                     MOVELABRD#     FBRD#
     C                     MOVELABEXCD    FBEXCD
     C                     MOVELABEX#     FBEX#
     C                     Z-ADDABQTY1    FBQTY1
     C                     Z-ADDWWQTY     FBQTY2                       T DATE
     C           ABQTCD    IFEQ 'W'
     C                     MOVE ABQTCD    FBQTCD                       DATE
     C                     Z-ADDABCSDT    FBCEDT
     C                     ELSE
     C                     MOVE 'M'       FBQTCD
     C                     Z-ADDABCSDT    FBCSDT                       UE DATE
     C                     Z-ADDABCEDT    FBCEDT
     C                     ENDIF
      *
     C                     Z-ADDABFIED    FBFIED
     C                     Z-ADDABFIQT    FBFIQT
     C                     Z-ADDABFISD    FBFISD
     C                     Z-ADDABMTED    FBMTED
     C                     Z-ADDABMTED    FBMTED
     C                     Z-ADDABMTQT    FBMTQT
     C                     Z-ADDABMTSD    FBMTSD
     C                     Z-ADDABSHQT    FBSHQT
     C                     Z-ADDABSHSD    FBSHSD
     C                     Z-ADDABSHLD    FBSHLD
     C                     Z-ADD*DATE     FBDATE
     C                     TIME           FBTIME
     C                     WRITEABRPP101
      *
     C                     ENDSR
      *------------------------------------------------------
      *  WRITE RECORDS TO ABRPP20
      *------------------------------------------------------
     C           #P20      BEGSR
      *
     C                     Z-ADD0         @@CNT
     C           K#11      SETLLABAEP16
     C           *IN90     DOUEQ*ON
     C           K#11      READEABAEP16                  90
     C           *IN90     IFEQ *OFF
     C                     CLEARABRPP201
     C                     Z-ADDAESIDT    FDSIDT
     C                     MOVELAEDOCK    FDDOCK
     C                     MOVELAEPART    FDPART
     C                     MOVEL@MHIN     FDIPAR
     C                     ADD  1         @@CNT
     C                     Z-ADD@@CNT     FDLIN#
     C                     TIME           FDTIME
     C                     Z-ADD*DATE     FDDATE
     C                     MOVELAENOTE    FDNOTE
     C                     WRITEABRPP201
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  WRITE RECORDS TO FORECAST FILE
      *------------------------------------------------------
     C           #FCST     BEGSR
      *
     C                     Z-ADD0         B       20
     C                     Z-ADD0         HYM
     C                     Z-ADD0         WKAD    20
     C                     Z-ADDABCSDT    WNYMD
     C                     Z-ADDABQTY1    WSURY  100
      *
     C           ABQTCD    IFEQ 'W'
     C           KEY4      SETLLAGDPL121
B01  C                     DO   7
     C                     SETOF                     10
     C                     READ AGDPL121                 10
B02  C           *IN10     IFEQ '0'
B03  C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         B
     C                     ADD  1         WKAD
     C                     Z-ADDF8KAHZ    HYM,B
TCHK2C*                    Z-ADDF8KAHZ    XXYMD   80
E03  C                     END
E02  C                     END
E01  C  N10                ENDDO
      *
     C                     MOVE *OFF      *IN20
B01  C           WKAD      IFEQ *ZERO
     C                     MOVE *ON       *IN20
     C           KEY4      SETLLAGDPL121
B01  C                     DO   7
     C                     SETOF                     10
     C                     READPAGDPL121                 10
B02  C           *IN10     IFEQ '0'
B03  C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         B
     C                     ADD  1         WKAD
     C                     Z-ADDF8KAHZ    HYM,B
TCHK2C*          B         IFEQ 1
TCHK2C*                    Z-ADDF8KAHZ    XXYMD   80
TCHK2C*                    ENDIF
E03  C                     END
E02  C                     END
E01  C  N10                ENDDO
      *
     C                     SORTAHYM
     C                     ENDIF
     C                     ENDIF
      *
     C           ABQTCD    IFNE 'W'
TCHK2C*                    Z-ADDXXYMD     WNYMD
TCHK2C           ABCEDT    IFEQ *ZERO
TCHK2C                     Z-ADDABCSDT    W@CEDT
TCHK2C                     ADD  1         W@CEMM
TCHK2C           W@CEMM    IFGT 12
TCHK2C                     ADD  1         W@CEYY
TCHK2C                     Z-ADD1         W@CEMM
TCHK2C                     END
TCHK2C                     SUB  1         W@CEDD
TCHK2C                     Z-ADDW@CEDT    ABCEDT
TCHK2C           W@CEDD    IFLE *ZERO
TCHK2C                     Z-ADDW@CEDT    WNYMD
TCHK2C           KEY4      SETLLAGDPL121
TCHK2C                     READPAGDPL121                 10
TCHK2C  N10                Z-ADDF8KAHZ    ABCEDT
TCHK2C                     Z-ADDABCSDT    WNYMD
TCHK2C                     END
TCHK2C                     END
     C           KEY4      SETLLAGDPL121
     C           *IN10     DOUEQ*ON
     C                     READ AGDPL121                 10
     C           *IN10     IFEQ *OFF
B03  C           F8HIRU    ANDEQ*BLANK
     C           F8YORU    ANDEQ*BLANK
     C           F8YOBI    ANDLT6
     C           F8KAHZ    IFGT ABCEDT
     C                     LEAVE
     C                     ENDIF
     C                     ADD  1         B
     C                     ADD  1         WKAD
     C                     Z-ADDF8KAHZ    HYM,B
     C                     ENDIF
     C                     ENDDO
TCHK2C*                    Z-ADDABCEDT    XXYMD
     C                     ENDIF
      *
B01  C           WSURY     CABEQ*ZERO     @@FCST
      *
     C           WSURY     SUB  WWCUM     WWQTY  100
      *
TCHK3C           WKAD      IFEQ *ZERO
TCHK3C                     Z-ADD*ZERO     WSURY
TCHK3C                     GOTO @@FCST
TCHK3C                     END
TCHK3C*
TCHK3C           WWQTY     IFLT *ZERO
TCHK3C                     Z-ADD*ZERO     WSURY
TCHK3C                     GOTO @@FCST
TCHK3C                     END
TCHK3C*
     C           WWQTY     DIV  WKAD      WKSUR   70H
      *
     C                     Z-ADDWSURY     WWCUM
      *
     C                     Z-ADD1         A       20
B01  C           1         DO   30        A
B02  C           HYM,A     IFNE 0
     C                     Z-ADDHYM,A     @NYMD
     C                     SETOF                     11
     C                     MOVE '0000'    WSBAN   4
     C           KEY2      CHAINABAWP10              11
B03  C           *IN11     IFEQ '1'
     C                     CLEARABAWP101
     C                     MOVE ABCUST    ABTOKU
     C                     Z-ADDWNONY     ABNONY
     C                     MOVE ABFACT    ABNKOJ
     C                     MOVE *BLANK    ABNUKE
     C                     MOVE '0000'    ABSBAN
     C                     MOVELWMHIN     ABMHIN
     C                     Z-ADD@NYM      ABDATE
     C                     Z-ADD0         HSU
     C                     Z-ADDWKSUR     HSU,D
     C                     XFOOTHSU       ABNNSU
     C                     MOVE WNOKN     ABNOKN
     C                     WRITEABAWP101
     C                     ELSE
      *
     C           *IN20     IFEQ *OFF
     C                     Z-ADDWKSUR     HSU,D
     C                     ELSE
     C                     ADD  WKSUR     HSU,D
     C                     ENDIF
      *
     C                     XFOOTHSU       ABNNSU
B04  C           ABNOKN    IFNE 'C'
     C                     MOVE WNOKN     ABNOKN
E04  C                     ENDIF
      *
     C                     UPDATABAWP101
E03  C                     ENDIF
E02  C                     ENDIF
E01  C                     ENDDO
      *
     C           @@FCST    ENDSR
     C*****************************************************************
     C           *INZSR    BEGSR
      *
     C           KEY2      KLIST
     C                     KFLD           WTOKU   40
     C                     KFLD           WNONY   40
     C                     KFLD           WNKOJ   1
     C                     KFLD           #NUKE   4
     C                     KFLD           WMHN1   5
     C                     KFLD           WMHN2   5
     C                     KFLD           WMHN3   5
     C                     KFLD           WMHN4   5
     C                     KFLD           @NYM
      * FOR ABRPP10(SETGT)
     C           KEY3      KLIST
     C                     KFLD           K32     5
     C                     KFLD           K33
     C                     KFLD           @@DAT6  60
     C                     KFLD           K31
      * FOR ABRPP10(READPE)
     C           KEY7      KLIST
     C                     KFLD           K32
     C                     KFLD           K33
      *
     C           KEY4      KLIST
     C                     KFLD           WNYY
     C                     KFLD           WNMM
     C                     KFLD           WNDD
TCHK2C           KEY4A     KLIST
TCHK2C                     KFLD           WNYY
TCHK2C                     KFLD           WNMM
      *
     C           KEY5      KLIST
     C                     KFLD           K@CUST  40
     C                     KFLD           WNONY   40
     C                     KFLD           ABFACT
     C*                    KFLD           ABNUKE
      *
     C* KEY FILE ABRPP30
     C           KEY8      KLIST
     C                     KFLD           ABDOCK
     C                     KFLD           WIPAR  12
     C           KEY9      KLIST
     C                     KFLD           ABDOCK
     C                     KFLD           WIPAR
     C                     KFLD           ABSIDT
     C                     KFLD           K@POR#  6
     C           K#25      KLIST
     C                     KFLD           WTOKU   40
     C                     KFLD           WNONY   40
     C           K#FA      KLIST
     C                     KFLD           K@DOC   4
     C                     KFLD           WIPAR  12
     C           K#11      KLIST
     C                     KFLD           ABPRTR
     C                     KFLD           ABDOCK
     C                     KFLD           K@PART 40
      *
     C                     TIME           WTMDT
     C                     MOVE *BLANK    #NUKE
     C                     Z-ADD*ZERO     WNYMD
      *
     C                     ENDSR
     C*****************************************************************
     OOUTFILE EADD             DTL
     O                         ABCUST     4
     O                 77      ABDOCK     9
     O                N77      WNONY      8
     O                N77      ABFACT     9
     O                         #NUKE     13
     O                         WSBAN     17
     O                         WMHIN     37
     O                         WNYMD     45
     O                         WSURY     55
     O                         ERRCD     57
