     F******************************************** ANAR1E **
     FABAEP15 IP  E                    DISK
     FABAEP16 IF  E           K        DISK
     FGADPL11 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FABAWP10 UF  E           K        DISK                      A
     FABRPP10 O   E           K        DISK
     FABRPP20 O   E           K        DISK
     FABRPP30 UF  E           K        DISK                      A
     FABAEP25 IF  E           K        DISK                      A
     FABRAL01 IF  E           K        DISK
     FOUTFILE O   F     256            DISK                      A
     FABRPL10 IF  E           K        DISK
     F            ABRPP101                          KRENAMEABRPL0X
     F****************************************************
     E                    HSU        31  7 0
     E                    HYM        30  8 0
     E                    HNB        20  1
     E                    @HNB       20  1
     E                    WSR        15  1
     E                    XSR         8  1
     E                    IUHN       40  1
     E                    WUHN       20  1
     E                    CD         14  1               QTY CODE
     E                    DAS        14  6 0             CUM START DATE
     E                    DAE        14  6 0             CUM END   DATE
     E                    CUM        14 10 0             CUM QTY
     E                    QTY        14 10 0             NET QTY
      * DOCK CODE = INUKE + 'A'
     I            DS
