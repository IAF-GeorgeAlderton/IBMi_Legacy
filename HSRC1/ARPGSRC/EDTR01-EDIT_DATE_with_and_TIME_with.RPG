     H            Y.
     F** EDTR01  ***************************************
     F*  EDIT DATE WITH "/" AND TIME WITH ":"          *
     F*  J.WATANABE    2021.11.17                      *
     F*------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'EDTR01 '
     F*                    PARM           $DATE1  8
     F*                    PARM           $TIME1  6
     F*                    PARM           $YMD    3
     F*                    PARM           $DATE2 10
     F*                    PARM           $TIME2  8
     F*  IN  $DATE1  8A ORIGINAL DATE
     F*      $TIME1  6A OROGINAL TIME
     F*      $YMD    3A 'YMD' OR 'MDY' OR 'DMY'
     F*  OUT $DATE2 10A EDITED DATE
     F*      $TIME2  8A EDITED TIME
      *--------------------------------------
      *  WHEN $DATE1=BLANK, THEN DEFAULT TODAY
      *  WHEN $TIME1=BLANK, THEN DEFAULT CURRENT TIME
      *  WHEN $YMD  =BLANK, THEN DEFAULT 'YMD'
     F**************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   8 YDATE1
     I                                        1   4 YYY1
     I                                        5   6 YMM1
     I                                        7   8 YDD1
     I            DS
     I                                        1  10 YDATE2
     I                                        1   4 YYY2
     I                                        5   5 YSL1
     I                                        6   7 YMM2
     I                                        8   8 YSL2
     I                                        9  10 YDD2
     I            DS
     I                                        1   8 MDATE1
     I                                        1   2 MMM1
     I                                        3   4 MDD1
     I                                        5   8 MYY1
     I            DS
     I                                        1  10 MDATE2
     I                                        1   2 MMM2
     I                                        3   3 MSL1
     I                                        4   5 MDD2
     I                                        6   6 MSL2
     I                                        7  10 MYY2
     I            DS
     I                                        1   6 WTIME1
     I                                        1   2 WHH1
     I                                        3   4 WMM1
     I                                        5   6 WSS1
     I            DS
     I                                        1   8 WTIME2
     I                                        1   2 WHH2
     I                                        3   3 WCL1
     I                                        4   5 WMM2
     I                                        6   6 WCL2
     I                                        7   8 WSS2
      *=========================
      * MAIN ROUTINE
      *=========================
     C                     EXSR #INIT
      *
     C                     SELEC
      *
     C           $YMD      WHEQ 'YMD'
     C                     EXSR #YMD
      *
     C           $YMD      WHEQ 'MDY'
     C           $YMD      OREQ 'DMY'
     C                     EXSR #MDY
      *
     C                     OTHER
     C                     EXSR #YMD
     C                     ENDSL
      *
     C                     EXSR #TIME
      *
     C                     SETON                     LR
     C                     RETRN
      *=========================
      * EDIT YMD
      *=========================
     C           #YMD      BEGSR
      *
     C                     MOVEL$DATE1    YDATE1
     C                     MOVELYYY1      YYY2
     C                     MOVELYMM1      YMM2
     C                     MOVELYDD1      YDD2
     C                     MOVELYDATE2    $DATE2
      *
     C                     ENDSR
      *=========================
      * EDIT MDY/DMY
      *=========================
     C           #MDY      BEGSR
      *
     C                     MOVEL$DATE1    MDATE1
     C                     MOVELMYY1      MYY2
     C                     MOVELMMM1      MMM2
     C                     MOVELMDD1      MDD2
     C                     MOVELMDATE2    $DATE2
      *
     C                     ENDSR
      *=========================
      * EDIT TIME
      *=========================
     C           #TIME     BEGSR
      *
     C                     MOVEL$TIME1    WTIME1
     C                     MOVELWHH1      WHH2
     C                     MOVELWMM1      WMM2
     C                     MOVELWSS1      WSS2
     C                     MOVELWTIME2    $TIME2
      *
     C                     ENDSR
      *=========================
      * INITIAL SET
      *=========================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $DATE1  8
     C                     PARM           $TIME1  6
     C                     PARM           $YMD    3
     C                     PARM           $DATE2 10
     C                     PARM           $TIME2  8
      *
     C                     TIME           SDATE
     C           $DATE1    IFEQ *BLANK
     C           $DATE1    OREQ '00000000'
     C                     MOVELTODAY     $DATE1
     C                     ENDIF
      *
     C           $TIME1    IFEQ *BLANK
     C           $TIME1    OREQ '000000'
     C                     MOVELNOW       $TIME1
     C                     ENDIF
      *
     C           $YMD      IFEQ *BLANK
     C                     MOVEL'YMD'     $YMD
     C                     ENDIF
      *
     C           $YMD      IFNE 'YMD'
     C           $YMD      ANDNE'MDY'
     C           $YMD      ANDNE'DMY'
     C                     MOVEL'YMD'     $YMD
     C                     ENDIF
      *
     C                     MOVE '/'       YSL1
     C                     MOVE '/'       YSL2
     C                     MOVE '/'       MSL1
     C                     MOVE '/'       MSL2
     C                     MOVE ':'       WCL1
     C                     MOVE ':'       WCL2
      *
     C                     ENDSR
