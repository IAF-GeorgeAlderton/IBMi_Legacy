     I                                       91 100 C6KNNA
      *
     C           *ENTRY    PLIST
     C                     PARM           P@BARC 20
     C                     PARM           P@NO    20
     C                     PARM           P@KND   80
     C                     PARM           P@KNT   60
     C                     PARM           P@KNN  10
      *
     C                     CALL 'BARR81'
     C                     PARM           P@BARC 20
     C                     PARM           P@KRKB  1
     C                     PARM           P@ZETI  4
     C                     PARM           P@TEHI  3
     C                     PARM           P@PAGN  2
     C                     PARM           P@BCKA  1
     C                     PARM           P@BCTK  1
     C                     PARM           P@BCYK  1
     C                     PARM           P@BCHK  1
     C                     PARM           P@BCKD  1
      *
     C                     MOVE P@ZETI    K@ZETI  4
      *
     C                     MOVELP@TEHI    P#MOJI 20
     C                     MOVE '03'      P#KETA  2
     C                     MOVE *BLANK    P#RTN   1
     C                     CALL 'CHKR90'
     C                     PARM           P#MOJI 20
     C                     PARM           P#KETA  2
     C                     PARM           P#RTN   1
     C           P#RTN     IFEQ '0'
     C                     MOVELP@TEHI    K@TEHI  3
     C                     ELSE
     C                     MOVEL'999'     K@TEHI
     C                     END
      *
     C           KEY       KLIST
     C                     KFLD           K@ZETI
     C                     KFLD           K@TEHI
      *
     C           KEY       SETGTCA#PL02
      *
     C                     DO   *HIVAL
     C           KEY       REDPECA#PL02                  77
     C   77                LEAVE
      *
     C           *IN77     IFEQ '0'
     C           C6SKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C                     END
      *
     C                     LEAVE
      *
     C                     ENDDO
      *
     C   77                GOTO @END
      *
     C                     Z-ADDP@NO      @X      20
     C                     Z-ADDP@KND     KND,@X
     C                     Z-ADDP@KNT     KNT,@X
     C                     MOVE P@KNN     KNN,@X
      *
     C           @X        ADD  1         @Y      20
      *
     C           @Y        IFGE 11
     C                     MOVEL'1'       C6FFLG
      *
     C                     ELSE
     C           KOT,@Y    IFEQ *BLANK
     C                     MOVEL'1'       C6FFLG
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     UPDATCA#PL021
      *
     C           @END      TAG
      *
     C                     SETON                     LR
     C                     RETRN
      *
