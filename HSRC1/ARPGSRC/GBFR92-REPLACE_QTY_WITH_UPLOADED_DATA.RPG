     F** GBFR92 *******************************
     F*  UPDATE QTY                           *
     F*        SEP/06/2002                    *
     F*                                       *
     F*
     F******************************* AB#R2S **
     FNEWVOL  IP  F     256            DISK
     FGBFWP90 UF  E           K        DISK                      A
      *--------------------------------------------------------
     E                    A12        12  1
     E                    AXX        12  1
      *--------------------------------------------------------
     INEWVOL  AA  01
     I                                        1   4 NBR
     I                                       13  22 PART
     I                                      154 165 QTY
     I            DS
     I                                        1  20 GMHIN
     I                                        1   5 GBMHN1
     I                                        6  10 GBMHN2
     I                                       11  15 GBMHN3
     I                                       16  20 GBMHN4
     I            DS
     I                                        1  20 KMHIN
     I                                        1   5 K@MHN1
     I                                        6  10 K@MHN2
     I                                       11  15 K@MHN3
     I                                       16  20 K@MHN4
      *
     C           K#KEY     KLIST
     C                     KFLD           K@TOKU  40
     C                     KFLD           K@MHN1
     C                     KFLD           K@MHN2
     C                     KFLD           K@MHN3
     C                     KFLD           K@MHN4
      *
     C           NBR       IFGT '0001'
     C                     MOVELPART      KMHIN     P
     C                     Z-ADD3411      K@TOKU
      *
     C                     MOVEAQTY       A12
     C                     MOVE *ALL'0'   AXX
     C                     Z-ADD12        X       20
     C                     Z-ADD12        Y       20
     C                     DO   *HIVAL
     C           A12,X     IFNE ','
     C           A12,X     ANDNE*BLANK
     C                     MOVE A12,X     AXX,Y
     C                     SUB  1         Y
     C                     ENDIF
     C                     SUB  1         X
     C           X         IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAAXX       WQTY   12
     C                     MOVE WQTY      WSURY  120
     C           WSURY     IFNE *ZERO
     C           K#KEY     CHAINGBFWP90              90
     C           *IN90     IFEQ *OFF
     C           GBNQTY    ADD  WSURY     GBNQTY
     C                     UPDATGBFWP901
     C                     ELSE
     C                     Z-ADDK@TOKU    GBTOKU
     C                     MOVELKMHIN     GMHIN
     C                     Z-ADDWSURY     GBNQTY
     C                     WRITEGBFWP901
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
