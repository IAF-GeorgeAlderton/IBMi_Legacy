     C                     SETON                     22
      *
     C           WBIN      IFEQ WCIBI
      *
     C*------------------------------*
     C*  ..繰越箱数累積ファイル..  *
     C*------------------------------*
     C                     Z-ADD0         CESKHZ
     C                     Z-ADD*DATE     CEKOHZ
     C                     TIME           CETIME
     C                     Z-ADD9431      CEBMON
     C                     Z-ADDYMD       CEHAHZ
     C                     Z-ADDWBIN      CEHABN
     C                     MOVE CBSHN1    CESHN1
     C                     MOVE CBSHN2    CESHN2
     C                     MOVE CBSHN3    CESHN3
     C                     Z-ADD0         CESHKS
     C                     Z-ADD0         CENUHZ
     C                     Z-ADD0         CENUBN
     C                     Z-ADDCBHK,H    CEKHKS
     C                     Z-ADDWYOHZ     CEWAHZ
     C                     Z-ADD01        CEWABN
     C                     Z-ADDCBHK,H    CEMDKS
     C                     Z-ADDYMD       CEMDHZ
     C                     Z-ADDH         CEMDBN
     C                     WRITEAFBPP111
      *
     C                     ADD  CBHK,H    CBHN01
     C                     Z-ADD0         CBHK,H
     C           D         IFLE WBIN
     C                     Z-ADD99        CBBI,H
     C                     END
     C                     ELSE
      *
     C                     Z-ADD0         CBBI,H
      *
     C*------------------------------*
     C*  ..繰越箱数累積ファイル..  *
     C*------------------------------*
     C                     Z-ADD0         CESKHZ
     C                     Z-ADD*DATE     CEKOHZ
     C                     TIME           CETIME
     C                     Z-ADD9431      CEBMON
     C                     Z-ADDYMD       CEHAHZ
     C                     Z-ADDWBIN      CEHABN
