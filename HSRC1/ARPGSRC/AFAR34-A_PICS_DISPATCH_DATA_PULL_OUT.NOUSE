      *
     C*------------------------------*
     C*      ..サブルーチン..      *
     C*  ..コンテナ別に箱数加算..  *
     C*------------------------------*
     C           SBMSK     BEGSR
      *
     C                     Z-ADD0         @MSKB   10
     C           WCLHJ     SUB  @MAIS1    @MAISS  50
     C           $MAIS     IFLE @MAISS
     C                     Z-ADD1         @MSKB
     C                     ADD  $MAIS     @MAIS1
     C                     ELSE
      *
     C           WCLHJ     SUB  @MAIS2    @MAISS
     C           $MAIS     IFLE @MAISS
     C                     Z-ADD2         @MSKB
     C                     ADD  $MAIS     @MAIS2
     C                     END
     C                     END
      *
     C*--------------------------------------------*
     C*  ..コンテナ別箱数ファイル（熊本工場）..  *
     C*--------------------------------------------*
     C           @MSKB     IFNE 0
      *
     C                     SETOF                     23
     C           KEY6      CHAINAFANP341             23
     C           *IN23     IFEQ '0'
     C                     ADD  $MAIS     CHHKSU
     C                     UPDATAFANP341
     C                     ELSE
      *
     C                     MOVE @SHN1     CHSHN1
     C                     MOVE @SHN2     CHSHN2
     C                     MOVE @SHN3     CHSHN3
     C                     Z-ADD$MAIS     CHHKSU
     C                     Z-ADD@MSKB     CHCONT
     C                     MOVE @DTKB     CHDTKB
     C                     Z-ADD@HTYY     CHHTYY
     C                     Z-ADD@HTMM     CHHTMM
     C                     Z-ADD@HTDD     CHHTDD
     C                     Z-ADD@HTBB     CHHTBB
     C                     WRITEAFANP341
     C                     END
     C                     END
      *
     C                     ENDSR
