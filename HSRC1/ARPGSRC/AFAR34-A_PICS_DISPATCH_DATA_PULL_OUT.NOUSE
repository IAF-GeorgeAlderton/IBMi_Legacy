     C           WHINR     IFNE DASHIN
     C                     MOVE DASHIN    WHINR  12
     C                     EXSR SUBRC
     C           WCBKO     IFEQ 0
     C                     Z-ADD1         WCBKO
     C                     END
     C                     END
     C           DAMAIS    DIV  WCBKO     $MAIS   61H
     C                     Z-ADD$MAIS     WSURY
     C                     ADD  $MAIS     @MAIS
      *
     C                     MOVE DAHIN1    @SHN1   5
     C                     MOVE DAHIN2    @SHN2   5
     C                     MOVE DAHIN3    @SHN3   2
     C                     MOVE 'R'       @DTKB   1
     C                     Z-ADDDAHTYY    @HTYY   40
     C                     Z-ADDDAHTMM    @HTMM   20
     C                     Z-ADDDAHTDD    @HTDD   20
     C                     Z-ADDDAHTBB    @HTBB   20
     C                     EXSR SBMSK
      *
     C*--------------------------*
     C*  ..下限値　ＩＦＬＴ..  *
     C*--------------------------*
     C           @MAIS     IFLT WKA
     C                     ADD  $MAIS     WMAIS
     C                     MOVE *BLANK    WRSKG   1
     C                     MOVE DAMLIN    WRAIN   1
