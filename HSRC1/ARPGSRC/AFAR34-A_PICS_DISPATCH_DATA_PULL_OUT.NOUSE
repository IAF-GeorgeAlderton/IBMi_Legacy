     C                     MOVE *BLANK    WRSKG
     C                     MOVE DAMLIN    WRAIN
     C                     Z-ADDDACODE    WMBMN
     C                     EXSR SUBDH
     C                     EXSR SUBRO
     C                     END
     C                     END
     C                     END
     C  N10                END
      *
     C*------------------------------*
     C*  ..時刻別計算便マスター..  *
     C*------------------------------*
     C                     SETOF                     10
