     C                     MOVE CBSHN2    CESHN2
     C                     MOVE CBSHN3    CESHN3
     C                     Z-ADD0         CESHKS
     C                     Z-ADD0         CENUHZ
     C                     Z-ADD0         CENUBN
     C                     Z-ADD0         CEKHKS
     C                     Z-ADD0         CEWAHZ
     C                     Z-ADD0         CEWABN
     C                     Z-ADDCBHK,H    CEMDKS
     C                     Z-ADDYMD       CEMDHZ
     C                     Z-ADDH         CEMDBN
     C                     WRITEAFBPP111
     C                     END
      *
     C                     ENDSR
