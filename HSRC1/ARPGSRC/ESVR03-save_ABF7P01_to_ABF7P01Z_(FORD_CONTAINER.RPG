     H            Y.
     F** ESVR03 ********************************************
     F*  PROGRAM: SAVE ABF7P01 TO ABF7P01Z                 *
     F*  WRITTEN: JW (SRA) 2024.10.08                      *
     F*----------------------------------------------------*
     FABF7P01 IF  E                    DISK
     FABF7P01ZO   E                    DISK
      *--------------------------------------------------------
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
      * MAIN ROUTINE
      *--------------------------------------------------------
     C                     EXSR #INIT
      *
      * SAVE ABF7P01 --------------------------------------
     C                     DO   *HIVAL
     C                     READ ABF7P01                  98
     C   98                LEAVE
      *
     C                     Z-ADDTODAY     F7CRDT
     C                     Z-ADDNOW       F7CRTM
     C                     MOVEL#USER     F7CRUS
     C                     MOVEL'ABF7P01 'F7CRPF
     C                     MOVEL#WSID     F7CRMB
     C                     ADD  1         @CNT
     C                     Z-ADD@CNT      F7CR#
      * GET PL#
     C           F7CRDT    IFNE SVCRDT
     C           F7CRPF    ORNE $FILE
     C           F7CRUS    ORNE $USER
     C           F7CUST    ORNE $PLNT
     C           F7SEQ#    ORNE $SEQ#
     C                     Z-ADDF7CRDT    SVCRDT
     C                     MOVELF7CRDT    $CRHZ
     C                     MOVELF7CRPF    $FILE
     C                     MOVELF7CRUS    $USER
     C                     MOVELF7CUST    $PLNT
     C                     MOVELF7SEQ#    $SEQ#
     C                     CALL 'UTLR51C'
     C                     PARM           $CRHZ
     C                     PARM           $FILE
     C                     PARM           $USER
     C                     PARM           $PLNT
     C                     PARM           $SEQ#
     C                     PARM           $PICK#
     C                     ENDIF
     C                     MOVEL$PICK#    F7CRWS
      *
     C                     WRITEABF7P1Z1
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------------
      * INITIAL SETTING
      *--------------------------------------------------------
     C           #INIT     BEGSR
      *
     C                     TIME           SDATE
      *
     C                     Z-ADD0         SVCRDT  80
     C                     MOVE *BLANK    $CRHZ   8
     C                     MOVE *BLANK    $FILE  10
     C                     MOVE *BLANK    $USER  10
     C                     MOVE *BLANK    $PLNT   5
     C                     MOVE '000000'  $SEQ#   6
     C                     MOVE *BLANK    $PICK#  9
     C                     Z-ADD0         @CNT    40
      *
     C                     ENDSR
