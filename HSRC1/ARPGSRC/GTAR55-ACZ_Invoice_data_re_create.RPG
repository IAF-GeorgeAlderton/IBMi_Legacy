     C******************************************************
     C* MAIN
     C******************************************************
     C                     EXSR #INIT
     C*
     C                     EXSR #DISP
     C*
     C                     SETON                     LR
     C                     RETRN
     C******************************************************
     C* INIT
     C******************************************************
     C           #INIT     BEGSR
     C*
     C                     TIME           WSDT
      *
     C                     ENDSR
     C******************************************************
     C* DISP
     C******************************************************
     C           #DISP     BEGSR
     C*
     C                     EXSR #CRT
     C*
     C                     ENDSR
     C******************************************************
     C* CREATE INVOICE DETAIL DATA
     C******************************************************
     C           #CRT      BEGSR
     C*
     C           K#L13     KLIST
     C                     KFLD           W@NOYY
     C                     KFLD           W@NOMM
     C                     KFLD           W@NODD
     C                     Z-ADD20130830  W@NODT
     C                     Z-ADD*ZERO     W@CNT1  40
     C*
     C           K#L13     SETLLGTATL13
     C*
     C                     DO   *HIVAL
     C*
     C           K#L13     READEGTATL13                  96
     C   96                LEAVE
     C           G1SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C                     ADD  1         W@CNT1
     C*
     C           K#W50     KLIST
     C                     KFLD           K@CASE  4
     C                     KFLD           K@ORD# 12
     C                     KFLD           K@ITM#  5
     C                     KFLD           K@UHIN 20
     C                     MOVELG1CASE    K@CASE
     C                     MOVEL*BLANK    W@ORD#
     C                     MOVELG1ODKG    W@ORD1
     C                     MOVEL'-'       W@ORD2
     C                     MOVELG1ODR1    W@ORD3
     C                     MOVEL'-'       W@ORD4
     C                     MOVELG1ODR2    W@ORD5
     C                     MOVEL'-'       W@ORD6
     C                     MOVELG1ODR3    W@ORD7
     C                     MOVELW@ORD#    K@ORD#
     C                     MOVELG1ITEM    K@ITM#
     C                     MOVEL*BLANK    W@MHIN
     C                     MOVELG1IHN1    W@MHN1
     C                     MOVELG1IHN2    W@MHN3
     C                     MOVELG1IHN3    W@MHN5
     C                     MOVELG1IHN4    W@MHN7
     C           W@MHN3    IFNE *BLANK
     C                     MOVEL'-'       W@MHN2
     C                     END
     C           W@MHN5    IFNE *BLANK
     C                     MOVEL'-'       W@MHN4
     C                     END
     C           W@MHN7    IFNE *BLANK
     C                     MOVEL'-'       W@MHN6
     C                     END
     C                     MOVELW@MHIN    K@UHIN
     C           K#W50     CHAINGTAWP50              95
     C           *IN95     IFEQ *ON
     C                     EXSR @EDIT
     C                     END
     C*
     C                     ADD  1         G5CONT
     C                     ADD  G1ISYS    G5QTY
     C*
     C           G5QTY     MULT G5PRIC    G5AMNT
     C           G5QTY     MULT G5KASI    G5WGHT
     C*
     C   95                WRITEGTAWP501
     C  N95                UPDATGTAWP501
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*
     C******************************************************
     C           @EDIT     BEGSR
     C*
     C                     CLEARGTAWP501
     C*
     C                     MOVEL'IAF'     W@INV1
     C                     MOVEL'-'       W@INV2
     C                     MOVEL'CZ'      W@INV3
     C                     MOVEL'-'       W@INV4
     C                     MOVELG1INV2    W@INV5
     C                     MOVELW@INV#    G5INV#
     C*
     C                     MOVELK@CASE    G5CAS#
     C                     MOVELW@ORD#    G5ORD#
     C                     MOVELK@ITM#    G5ITM#
     C                     MOVELK@UHIN    G5UHIN
     C*
     C                     MOVELG1ITK1    W@LOC1
     C                     MOVELG1ITK2    W@LOC3
     C                     MOVELG1ITK3    W@LOC5
     C                     MOVELG1ITK4    W@LOC7
     C                     MOVEL'-'       W@LOC2
     C                     MOVEL'-'       W@LOC4
     C                     MOVEL'-'       W@LOC6
     C                     MOVELW@LOC     G5ULOC
     C*
     C                     MOVEL*BLANK    W@SHIN
     C                     MOVELG1SHN1    W@SHN1
     C                     MOVELG1SHN2    W@SHN3
     C                     MOVELG1SHN3    W@SHN5
     C           W@SHN3    IFNE *BLANK
     C                     MOVEL'-'       W@SHN2
     C                     END
     C           W@SHN5    IFNE *BLANK
     C                     MOVEL'-'       W@SHN4
     C                     END
     C                     MOVELW@SHIN    G5SHIN
     C*
     C           K#FCE     KLIST
     C                     KFLD           G1SHN1
     C                     KFLD           G1SHN2
     C                     KFLD           G1SHN3
     C           K#FCE     CHAINFCEPL01              93
     C           *IN93     IFEQ *OFF
     C                     MOVELA2SMEI    G5PNAM
     C                     Z-ADDA2KASI    G5KASI
     C                     END
     C*
     C                     Z-ADDG1ISYS    G5QPC
     C*
     C                     MOVE '0170'    @TOKU   4
     C                     MOVE '0170'    @NONY   4
     C                     MOVE '0'       @NKOJ   1
     C                     MOVE '00  '    @NUKE   4
     C                     MOVE G1MHIN    @MHIN  20
     C                     MOVE G1NODT    @HIZK   8
     C                     Z-ADD0         @TANK  105
     C                     MOVE *BLANK    @CHEK   1
     C                     CALL 'FBCR10'
     C                     PARM           @TOKU
     C                     PARM           @NONY
     C                     PARM           @NKOJ
     C                     PARM           @NUKE
     C                     PARM           @MHIN
     C                     PARM           @HIZK
     C                     PARM           @TANK
     C                     PARM           @CHEK
     C                     Z-ADD@TANK     G5PRIC
     C*
     C                     ENDSR
