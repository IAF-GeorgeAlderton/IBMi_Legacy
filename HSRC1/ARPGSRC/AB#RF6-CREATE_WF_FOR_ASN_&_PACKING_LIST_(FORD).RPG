     C           @MAIN     BEGSR
     C* MANIFEST # EXISTS     = AMENDED ORDER DATA
     C* MANIFEST # NOT EXISTS = FIRST ORDER DATA
     C                     MOVE PSIRE     WSIRE   40
     C                     MOVE PNOHZ     WNOHZ   80
     C                     Z-ADDPBIN      WBIN    20
     C           KEY3      CHAINABF4P011             92
B01  C           *IN92     IFEQ '0'
     C*
     C                     READ AB#WP4B                  90
B02  C           *IN90     DOWEQ'0'
     C                     Z-ADD*ZERO     M
     C                     Z-ADD*ZERO     N
     C*
     C                     EXSR @UPD1                      UPDATE ABF6P01
     C                     EXSR @MOVE1                     CREATE NEW ABF6
     C                     READ AB#WP4B                  90
E02  C                     END
     C*
     C                     ELSE
     C*
     C                     READ AB#WP4B                  90
B02  C           *IN90     DOWEQ'0'
     C                     Z-ADD*ZERO     M
     C                     Z-ADD*ZERO     N
     C*
     C                     EXSR @MOVE1                     CREATE NEW ABF6
     C                     READ AB#WP4B                  90
E02  C                     END
     C*
E01  C                     END
