     C                     END
     C*
     C                     MOVE 'S'       FCPBCD
     C                     EXSR @SEQS
     C                     MOVE PMANI     FCASN#
     C*
     C                     Z-ADD*ZERO     FC#CON           # OF HAKO
     C                     ADD  ISYOS     WKRQTY
     C                     Z-ADDW##PLT    FC#PLT
     C                     Z-ADDSVRQTY    FCRQTY
     C                     Z-ADDFCSEQ#    @@SEQ#  60
JW4   * ADJUST FCCPAR
 "   C                     EXSR #ADJP
      *
     C                     WRITEABF6P011
     C                     END
     C*
     C* SET MASTER LABEL DATA
     C           WKRQTY    IFNE *ZERO
     C                     MOVE 'M'       FCPBCD
     C                     EXSR @SEQM
     C                     MOVE PMANI     FCASN#
     C                     Z-ADDWKRQTY    FCRQTY
     C                     Z-ADD*ZERO     WKRQTY
     C                     MOVE *BLANK    FCSERL
     C                     Z-ADD@@BOX     FC#CON           # OF HAKO
JW4   * ADJUST FCCPAR
 "   C                     EXSR #ADJP
      *
     C                     WRITEABF6P011
     C                     END
     C*
     C****       PSIRE     IFNE '5150'
     C           WWNVNA    IFEQ ' '
     C                     ADD  W##PLT    W#PLT
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
JW4  C*  #ADJP : ADJUST FCCPAR (REMOVE FIRST CHARACTER IF IT IS BLANK)
 .   C**************************************************************************
 .   C           #ADJP     BEGSR
 .    *
 .   C                     MOVELFCCPAR    LTR2    2
 .   C           LTR2      IFEQ ' W'
 .   C                     MOVE FCCPAR    LTR19  19
 .   C                     MOVELLTR19     FCCPAR    P
 .   C                     ENDIF
 .    *
JW4  C                     ENDSR
     C**************************************************************************
     C*  @SEQM : SET SEQ # AS MASTER LABEL
     C**************************************************************************
     C           @SEQM     BEGSR
     C*
     C* GET THE SEQUENCE NUMBER
     C** FIRST ORDER DATA
     C           *IN92     IFEQ '1'
     C*
     C           WSEQ#     IFEQ 999999
     C                     Z-ADD1         WSEQ#
     C                     ELSE
     C                     ADD  1         WSEQ#
     C                     END
     C                     Z-ADDWSEQ#     FCSEQ#
     C*
     C** AMENDED ORDER DATA
     C                     ELSE
     C                     ADD  1         M
     C           PLT,M     IFEQ *ZERO
     C           PLT,M     ORLT @@SEQ#
     C*
     C           WSEQ#     IFEQ 999999
     C                     Z-ADD1         WSEQ#
     C                     ELSE
     C                     ADD  1         WSEQ#
     C                     END
     C*
     C                     Z-ADDWSEQ#     FCSEQ#
     C                     MOVE ' '       FCPRNT
     C*
     C                     ELSE
     C                     Z-ADDPLT,M     FCSEQ#
     C*
     C           *IN86     IFEQ *ON
     C           QTY,M     ANDNE*ZERO
     C           QTY,M     ANDEQWKRQTY
     C                     MOVE 'P'       FCPRNT
     C                     ENDIF
      *
     C*  88                MOVE ' '       FCPRNT
     C* N88 86             MOVE 'P'       FCPRNT
     C* N88N86             MOVE ' '       FCPRNT
     C                     END
     C*
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*  @SEQS : SET SEQ # AS BOX
     C**************************************************************************
     C           @SEQS     BEGSR
     C*
     C* GET THE SEQUENCE NUMBER
     C** FIRST ORDER DATA
     C           *IN92     IFEQ '1'
     C*
     C           WSEQ#     IFEQ 999999
     C                     Z-ADD1         WSEQ#
     C                     ELSE
     C                     ADD  1         WSEQ#
     C                     END
     C*
     C                     Z-ADDWSEQ#     FCSEQ#
     C                     MOVE *BLANK    FCSERL
      *
     C           K#FW      CHAINABF6PW1              96
     C           *IN96     IFEQ *ON
     C                     Z-ADDFCSHDT    WCSHDT
     C                     Z-ADDFCSHTM    WCSHTM
     C                     MOVE FCDOCK    WCDOCK
     C                     Z-ADDFCCUST    WCCUST
     C                     Z-ADDFCDELY    WCDELY
     C                     Z-ADDW##PLT    WC#PLT
     C                     MOVE *BLANK    WCPRNT
     C                     Z-ADDFCRYYY    WCRYYY
     C                     Z-ADDFCRMMM    WCRMMM
     C                     Z-ADDFCRDDD    WCRDDD
      *
     C                     WRITEABF6PW11
     C                     ELSE
     C                     MOVE *BLANK    WCPRNT
     C                     UPDATABF6PW11
     C                     ENDIF
     C*
     C** AMENDED ORDER DATA
     C                     ELSE
     C                     ADD  1         N
     C           BOX,N     IFEQ *ZERO
     C*
     C           WSEQ#     IFEQ 999999
     C                     Z-ADD1         WSEQ#
     C                     ELSE
     C                     ADD  1         WSEQ#
     C                     END
     C*
     C                     Z-ADDWSEQ#     FCSEQ#
     C                     MOVE ' '       FCPRNT
     C                     MOVE *BLANK    FCSERL
      *
     C           K#FW      CHAINABF6PW1              96
     C           *IN96     IFEQ *ON
     C                     Z-ADDFCSHDT    WCSHDT
     C                     Z-ADDFCSHTM    WCSHTM
     C                     MOVE FCDOCK    WCDOCK
     C                     Z-ADDFCCUST    WCCUST
     C                     Z-ADDFCDELY    WCDELY
     C                     Z-ADDW##PLT    WC#PLT
     C                     MOVE *BLANK    WCPRNT
     C                     Z-ADDFCRYYY    WCRYYY
     C                     Z-ADDFCRMMM    WCRMMM
     C                     Z-ADDFCRDDD    WCRDDD
      *
     C                     WRITEABF6PW11
     C                     ELSE
     C                     MOVE *BLANK    WCPRNT
     C                     UPDATABF6PW11
     C                     ENDIF
     C*
     C                     ELSE
     C                     Z-ADDBOX,N     FCSEQ#
     C                     MOVE SRL,N     FCSERL
      *
     C           PLL,N     IFNE W##PLT
      *
     C           K#FW      CHAINABF6PW1              96
     C           *IN96     IFEQ *ON
     C                     Z-ADDFCSHDT    WCSHDT
     C                     Z-ADDFCSHTM    WCSHTM
     C                     MOVE FCDOCK    WCDOCK
     C                     Z-ADDFCCUST    WCCUST
     C                     Z-ADDFCDELY    WCDELY
     C                     Z-ADDW##PLT    WC#PLT
     C                     MOVE *BLANK    WCPRNT
     C                     Z-ADDFCRYYY    WCRYYY
     C                     Z-ADDFCRMMM    WCRMMM
     C                     Z-ADDFCRDDD    WCRDDD
      *
     C                     WRITEABF6PW11
     C                     ELSE
     C                     MOVE *BLANK    WCPRNT
     C                     UPDATABF6PW11
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN89     IFEQ *ON
     C                     MOVE ' '       FCPRNT
     C                     ELSE
     C           SRL,N     IFNE *BLANK
     C                     MOVE 'P'       FCPRNT
     C                     ELSE
     C                     MOVE ' '       FCPRNT
     C                     ENDIF
     C                     ENDIF
      *
     C                     END
     C*
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*  @END : END
     C**************************************************************************
     C           @END      BEGSR
     C*
     C                     CLOSEABF6L02
     C*
     C* WRITE OR UPDAT MANIFEST #
     C* (ASN NEEDS HAKO&WEIT, SO WRITE MANIFEST HERE AFTER PROCESS.)
     C                     Z-ADD2000      YBKOYY
     C                     ADD  WWYY      YBKOYY           UPDATE YEAR
     C                     Z-ADDWWMM      YBKOMM                  MONTH
     C                     Z-ADDWWDD      YBKODD                  DAY
     C                     Z-ADDWWHH      YBKOHH                  HOUR
     C                     Z-ADDWWNN      YBKOSS                  MINUTE
     C                     MOVELPUSR      YBKOME                  USER
     C                     Z-ADDWSIRE     YBSUPP           DELIVERY
     C                     Z-ADDWNOHZ     YBSHDT           SHIP DATE
     C                     Z-ADDWBIN      YBBIN                 BIN
     C                     MOVE PDOCK     YBDOCK           RECEVING
     C                     Z-ADDWTBOX     YBCONT           TOTAL # OF BOXES
     C                     Z-ADD*ZERO     YBNOHZ           INVOICE DATE
     C*
     C***        PSIRE     IFEQ '5150'
     C***        WWNVNA    IFEQ *BLANK
     C                     Z-ADDW##PLT    YB#PAL
     C*
     C***                  ELSE
     C***                  Z-ADDW#PLT     YB#PAL           #OF PALLETE
     C***                  END
      *
     C* CALUCULATE TARE
     C* (0.7 * HAKO) + (23.675 * PALLETE)
     C           0.7       MULT WTBOX     WEIGH   62
     C                     ADD  WEIGH     WTARE
     C**JW1      23.675    MULT YB#PAL    WEIGH
JW1  C           6.5       MULT YB#PAL    WEIGH
     C                     ADD  WEIGH     WTARE
     C*
     C                     Z-ADDTEIGH     YBWEIT           NET   WEIGHT
     C                     Z-ADDWTARE     YBTARE           TARE  WEIGHT
     C                     MOVE *BLANK    YBTRIL           TRAILER #
     C                     MOVE PMANI     YBMANI
     C                     Z-ADDWREYY     YBREYY           UPDATE YEAR
     C                     Z-ADDWREMM     YBREMM                  MONTH
     C                     Z-ADDWREDD     YBREDD                  DAY
     C*
     C* PRINT P/S AT THE FIRST TIME
     C           *IN92     IFEQ '1'
     C* GET PACKING SLIP NUMBER
     C                     READ ABFGP01R                 95
     C                     Z-ADD2000      QAKOYY
     C                     ADD  WWYY      QAKOYY           UPDATE YEAR
     C                     Z-ADDWWMM      QAKOMM                  MONTH
     C                     Z-ADDWWDD      QAKODD                  DAY
     C                     Z-ADDWWHH      QAKOHH                  HOUR
     C                     Z-ADDWWNN      QAKOSS                  MINUTE
     C                     MOVELPUSR      QAKOME                  USER
     C*
     C* SET P/S# TO PAKING SLIP NUMBER FILE
     C           *IN95     IFEQ '1'
     C                     Z-ADD1         QAPS#
     C                     WRITEABFGP01R
     C*
     C                     ELSE
     C                     ADD  1         QAPS#
     C                     UPDATABFGP01R
     C                     END
     C*
     C* IF  1ST.TIME,SET P/S#
     C* NOT 1ST.TIME,USE PRSENT P/S#
     C                     Z-ADDQAPS#     YBPS#
     C                     END
     C*
     C                     Z-ADDYBPS#     PPS#
     C   92                WRITEABF4P011
     C  N92                UPDATABF4P011
     C*
TCHK1C                     Z-ADDWSEQ#     CTNBR1
TCHK1C                     UPDATAB#PPCT1
TCHK1C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C                     ENDSR
