     C*
     C                     CLEARPLT
     C                     CLEARBOX
     C                     CLEARPLL
     C                     CLEARSRL
     C                     CLEARQTY
     C                     Z-ADD*ZERO     I
     C                     Z-ADD*ZERO     J
     C*
     C           KEY4      SETLLABF6P011
     C           KEY4      READEABF6P011                 93
     C*
B01  C           *IN93     DOWEQ'0'
     C*
B015 C           FCSKJY    IFNE 'D'
     C           FCPRNT    ANDNE'C'
     C*
     C           FCPRNT    IFEQ 'P'
     C                     MOVE *ON       *IN86
     C                     ELSE
     C                     MOVE *OFF      *IN86
     C                     ENDIF
     C*
B02  C           FCPBCD    IFEQ 'S'
     C* QTY/CONT CHANGED
     C           ISYOS     IFEQ FCUQTY
     C                     SETOF                     89
     C*
     C                     ELSE
     C                     SETON                     89
     C                     END
     C                     ENDIF
     C* SAVE SEQUENCE NUMBER
B02  C           FCPBCD    IFEQ 'M'
     C*
     C* REQUESTED QTY WAS CHANGED
     C           ISRYO     IFEQ FCRQTY
     C                     SETOF                     88
     C*
     C                     ELSE
     C                     SETON                     88
     C                     END
      *
     C*
     C                     ADD  1         I
     C                     Z-ADDFCSEQ#    PLT,I            MASTER SEQ.
     C                     Z-ADDFCRQTY    QTY,I            MASTER SEQ.
     C*
     C                     ELSE
     C                     ADD  1         J
     C                     Z-ADDFCSEQ#    BOX,J            CONT. SEQ.
     C                     Z-ADDFC#PLT    PLL,J            CONT. SEQ.
     C                     MOVE FCSERL    SRL,J
E02  C                     END
     C*
     C                     MOVE 'D'       FCSKJY           DELETE CODE
     C                     Z-ADD2000      FCSKYY
     C                     ADD  WWYY      FCSKYY           UPDATE YEAR
     C                     Z-ADDWWMM      FCSKMM                  MONTH
     C                     Z-ADDWWDD      FCSKDD                  DAY
     C                     MOVELPUSR      FCKOME                  USER
     C                     UPDATABF6P011
     C*
E015 C                     END
     C           KEY4      READEABF6P011                 93
E01  C                     END
