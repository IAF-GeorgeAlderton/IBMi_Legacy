     H            Y.
     F** VVVRA2 ****************************
     F* UPDATE PGM-FILE TABLE              *
     F**************************************
     FVVVPPA0 UF  E                    DISK
     FVVVPPA1 IF  E           K        DISK
      *
     C                     READ VVVPPA01                 81
     C           *IN81     DOWEQ'0'
     C                     EXSR #SB001
     C                     READ VVVPPA01                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *-----------------------------------------*
      *                                         *
      *-----------------------------------------*
     CSR         #SB001    BEGSR
      *
     C           VVFNAM    IFNE *BLANK
     C                     MOVELVVFNAM    #KFNAM 10
     C           #KFNAM    CHAINVVVPPA11             21
     C           *IN21     IFEQ '0'
     C                     MOVELVVRFI     VVRFI
     C                     UPDATVVVPPA01
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB001    ENDSR
