      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
      *
     C           ACALL     PLIST
     C                     PARM           ASTLR   2        SETON LR ﾍｭcﾆg
     C                     PARM           L6KTSU
     C                     PARM           L6KEIS
     C                     PARM           L6LTIM
     C                     PARM           L6SYOS
     C                     PARM           L6LOTO
     C                     PARM           L6MAXH
     C                     PARM           WMAIS
      *
     C                     TIME           WTIME
     C           1         SETLLABMWP211
     C                     READ ABMWP211                 21
     C           *IN21     DOWEQ'0'
     C           W2OMIT    IFEQ '0'
     C           W2PAS     ANDEQ'0'
     C                     EXSR #SB200
     C                     UPDATABMWP211
     C                     ENDIF
     C                     READ ABMWP211                 21
     C                     ENDDO
      *
     C                     MOVE 'LR'      ASTLR   2
     C                     CALL 'ABCR07'  ACALL
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------*
      *引取かんばん検索         *
      *---------------------------*
     CSR         #SB200    BEGSR
      *
     C           KEYL61    KLIST
     C                     KFLD           #K1HB5  5
     C                     KFLD           #K2HB5  5
     C                     KFLD           #K3HB2  2
      *
     C                     MOVELW2SHN1    #K1HB5
     C                     MOVELW2SHN2    #K2HB5
     C                     MOVELW2SHN3    #K3HB2
     C           KEYL61    SETGTAAHTL061
     C           KEYL61    REDPEAAHTL061                 82
     C           *IN82     DOWEQ'0'
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    ANDLE*DATE
     C                     ELSE
     C           L6STHZ    IFEQ 99999999
     C***        L6KMAX    IFEQ 999
     C           L6KMAX    IFEQ 99999
     C                     MOVEL'6'       W2OMIT
     C                     ELSE
     C                     EXSR #SB400
     C                     EXSR #SB410
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYL61    REDPEAAHTL061                 82
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *---------------------------*
      * GHCPP21より設定数       *
      *---------------------------*
     CSR         #SB400    BEGSR
      *
     C                     SETOF                     99
     C           KEYMD1    KLIST
     C                     KFLD           #KMBN1  1
     C                     KFLD           #KMBN2  2
     C                     KFLD           #KMBN3  2
     C                     KFLD           #KMBN4  1
     C                     KFLD           #KMHN1  5
     C                     KFLD           #KMHN2  5
     C                     KFLD           #KMHN3  2
      *
     C                     MOVELL6ATK1    #KMBN1
     C                     MOVELL6ATK2    #KMBN2
     C                     MOVELL6ATK3    #KMBN3
     C                     MOVELL6ATK4    #KMBN4
     C                     MOVELL6SHN1    #KMHN1
     C                     MOVELL6SHN2    #KMHN2
     C                     MOVELL6SHN3    #KMHN3
     C                     MOVEL'0'       FGET2   1
     C                     Z-ADD0         WKSRYO  90
     C           KEYMD1    SETLLGHDTL211
     C           KEYMD1    READEGHDTL211                 83
     C           *IN83     DOWEQ'0'
     C                     Z-ADDMDSRYO    WKSRYO
     C                     MOVEL'1'       FGET2
     C           KEYMD1    READEGHDTL211                 83
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *---------------------------*
      *かんばん枚数計算         *
      *---------------------------*
     CSR         #SB410    BEGSR
      *
     C                     MOVEL*BLANK    P@PAS
     C                     CALL 'ABMR1B'
     C                     PARM           L6SHN1
     C                     PARM           L6SHN2
     C                     PARM           L6SHN3
     C                     PARM           P@PAS   1
      *
     C                     Z-ADDL6SYOS    @BSSYS  70
     C                     MOVELL6SYOT    @BSSYT  1
     C                     Z-ADDL6KTSU    @BKTSU  90
     C                     Z-ADDL6KMAX    @BKMAX  90
     C                     Z-ADDL6MAXH    @BMAXH  30
     C                     Z-ADDL6LOTO    @BKLOT  30
     C                     Z-ADDL6PADJ    @BPADJ  30
     C                     Z-ADDL6AUAJ    @BAUAJ  30
     C                     Z-ADDL6DUPH    @BDUPH  30
     C                     Z-ADDL6OTHH    @BOTHH  30
     C                     MOVEL*BLANK    @5DUP@  1
     C                     Z-ADD0         @5DUP#  30
     C           WKSRYO    DIV  20        @3KTSU  90
     C                     SELEC
     C           @3KTSU    WHLT L6KTSU
     C                     MOVEL'51'      L6STI1
     C           @3KTSU    WHGT L6KTSU
     C                     MOVEL'52'      L6STI1
     C                     ENDSL
      *
     C                     Z-ADD0         W@HAKD  51
     C           WKSRYO    DIV  20        W@KSSU  90
     C           W2SSYS    IFNE 0
     C           W@KSSU    DIV  W2SSYS    W@HAKD
     C                     ENDIF
     C           W@HAKD    IFEQ 0
     C                     Z-ADD0.1       W@HAKD
     C                     ENDIF
      * A-PICS
     C                     CALL 'ABMR43'
     C                     PARM           L6SHN1
     C                     PARM           L6SHN2
     C                     PARM           L6SHN3
     C                     PARM           P9BMON  40
     C                     PARM           P9PROC  3
     C                     PARM           P9TKR   6
     C                     PARM           P9SHR   1
     C                     MOVEL'0'       APICS   1
     C           L6ATKR    IFEQ P9TKR
     C                     MOVEL'1'       APICS   1
     C                     ENDIF
     C           APICS     IFEQ '1'
     C                     EXSR #SB700
     C                     ELSE
     C                     EXSR #SB710
     C                     ENDIF
      *
     C           L6DOUT    IFEQ 'Y'
     C                     Z-ADDL6KMAX    L6KAIS
     C                     ENDIF
     C                     Z-ADDL6KMAX    WKMAX   50
      *
     C           WKSRYO    DIV  20        L6KTSU
     C           WKSRYO    DIV  20        L6KSSU
     C                     Z-ADDL6KALL    WKALL   50
     C                     Z-ADDL6KMIN    WMIN    50
     C                     Z-ADDL6KMAX    WMAX    50
     C                     Z-ADDL6KMAX    SVKMAX  50
     C           L6KALL    IFLT L6KMAX
     C                     Z-ADDL6KMAX    WALL    50
     C                     ELSE
     C                     Z-ADDL6KALL    WALL
     C                     ENDIF
     C                     Z-ADDL6KSNK    KSKBN   10
      *
     C           L6DTKO    IFNE '0'
      *
     C           L6SYOS    IFEQ 0
     C                     MOVEL'6'       W2OMIT
     C                     GOTO ESB410
     C                     ENDIF
      *
     C                     Z-ADD0         WMAIS   50
     C                     MOVE *BLANK    ASTLR            SETON LR ﾍｭcﾆg
      *自動処理調整をゼロにするA-PICS以外
     C           APICS     IFEQ '0'
     C                     Z-ADD0         W1MAIS  40
     C                     ADD  L6KAIH    W1MAIS
     C                     ADD  L6SINH    W1MAIS
     C                     ADD  L6DUPH    W1MAIS
     C                     ADD  L6HRH1    W1MAIS
