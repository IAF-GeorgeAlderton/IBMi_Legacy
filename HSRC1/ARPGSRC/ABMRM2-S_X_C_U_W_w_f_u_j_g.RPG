     C                     ENDIF
      *
     C*****      WMAIS     IFGT 999
     C           WMAIS     IFGT 9999
     C                     MOVEL'6'       W2OMIT
     C                     GOTO ESB410
     C                     ENDIF
      *
     C                     ENDIF
      *
     CSR         ESB410    ENDSR
      *---------------------------*
      * A-PICS 最大日当り出荷（売上実績から）   *
      *---------------------------*
     CSR         #SB700    BEGSR
      *
     C                     MOVEL*BLANK    @5DUP@
     C                     Z-ADD0         @5DUP#
     C                     CALL 'ABMR44'
     C                     PARM           L6SHN1
     C                     PARM           L6SHN2
     C                     PARM           L6SHN3
     C                     PARM           P9NOHZ  80
     C                     PARM           P9HAKO  90
      * ORDER DATA(N) ABMR4G(NOT PT)
      * ORDER DATA(N,N+1) ABMR4E(PT)
     C                     Z-ADD0         P7NOHZ
     C                     Z-ADD0         P7HAKO
     C           P@PAS     IFEQ '0'
     C                     CALL 'ABMR4G'
     C                     PARM           L6SHN1
     C                     PARM           L6SHN2
     C                     PARM           L6SHN3
     C                     PARM           P7NOHZ  80
     C                     PARM           P7HAKO  90
     C                     ELSE
     C                     CALL 'ABMR4E'
     C                     PARM           L6SHN1
     C                     PARM           L6SHN2
     C                     PARM           L6SHN3
     C                     PARM           P7NOHZ  80
     C                     PARM           P7HAKO  90
     C                     ENDIF
      *
     C           P7HAKO    IFGT P9HAKO
     C                     Z-ADDP7NOHZ    P9NOHZ
     C                     Z-ADDP7HAKO    P9HAKO
     C                     ENDIF
      *
     C                     CALL 'ABMR4C'
     C                     PARM           L6SHN1
     C                     PARM           L6SHN2
     C                     PARM           L6SHN3
     C                     PARM           P9TAKO 112
     C                     PARM           P9DUPH  30
      *
     C                     Z-ADD0         WKDUPH  51
     C                     Z-ADD0         W@HAKD  51
     C           WKSRYO    DIV  20        W@KSSU  90
     C           W2SSYS    IFNE 0
     C           W@KSSU    DIV  W2SSYS    W@HAKD
     C                     ENDIF
     C           W@HAKD    IFEQ 0
     C                     Z-ADD0.1       W@HAKD
     C                     ENDIF
     C           P9HAKO    SUB  W@HAKD    WKDUPH
     C                     Z-ADD0         @3DUPH  30
     C           WKDUPH    IFGE 1
     C           WKDUPH    ADD  0.9       @3DUPH
     C                     ENDIF
     C                     Z-ADD0         DUPSA   30
     C                     Z-ADD0         DUPPER  71
     C                     ADD  P9DUPH    @3DUPH
     C                     Z-ADD@3DUPH    @5DUP#
     C           @BDUPH    SUB  @3DUPH    DUPSA
     C           DUPSA     DIV  W@HAKD    DUPPER    H
     C           DUPSA     IFGE 16
     C           DUPPER    ANDGE5
     C           DUPSA     ORLE -16
     C           DUPPER    ANDGE5
     C                     MOVEL'@'       @5DUP@
     C                     ELSE
     C                     Z-ADD@3DUPH    L6DUPH
     C                     Z-ADD0         L6AMXH
     C                     ADD  L6KAIH    L6AMXH
     C                     ADD  L6SINH    L6AMXH
     C                     ADD  L6DUPH    L6AMXH
     C                     ADD  L6HRH1    L6AMXH
     C                     ADD  L6HRH2    L6AMXH
     C                     ADD  L6HRH3    L6AMXH
     C                     ADD  L6HRH4    L6AMXH
     C                     ADD  L6HRYO    L6AMXH
     C                     ADD  L6OTHH    L6AMXH
     C                     ADD  L6HLTS    L6AMXH
     C                     ADD  L6JTEI    L6AMXH
     C                     ADD  L6SKJI    L6AMXH
     C                     ADD  L6PADJ    L6AMXH
     C                     ADD  L6AUAJ    L6AMXH
     C                     Z-ADDL6AMXH    L6MAXH
     C                     ENDIF
      *
     CSR         ESB700    ENDSR
      *---------------------------*
      * A-PICS 以外　調整枚数
      *---------------------------*
     CSR         #SB710    BEGSR
      *
     C                     Z-ADD0         WKADJU  30
     C           KEYB6     KLIST
     C                     KFLD           L6SHN1
     C                     KFLD           L6SHN2
     C                     KFLD           L6SHN3
     C           KEYB6     CHAINABMPPB61             94
     C           *IN94     IFEQ '0'
     C           AISKJY    ANDEQ'D'
     C           AISKHZ    ANDLE*DATE
     C                     SETON                     94
     C                     ENDIF
     C           *IN94     IFEQ '0'
     C                     Z-ADDAIADJU    WKADJU
     C                     ELSE
     C                     EXSR #SB711
     C                     ENDIF
      *
     CSR         ESB710    ENDSR
      *---------------------------*
      * A-PICS 以外　調整枚数
      *---------------------------*
     CSR         #SB711    BEGSR
      *
     C                     Z-ADD0         W@HAKD  51
     C           WKSRYO    DIV  20        W@KSSU  90
     C           W2SSYS    IFNE 0
     C           W@KSSU    DIV  W2SSYS    W@HAKD
     C*******    W2NSRD    DIV  W2SSYS    W@HAKD
     C                     ENDIF
     C           W@HAKD    IFEQ 0
     C                     Z-ADD0.1       W@HAKD
     C                     ENDIF
     C                     Z-ADD0         WKADJU  30
     C           KEYB5     KLIST
     C                     KFLD           L6KCD1
     C                     KFLD           L6KCD2
     C                     MOVEL'0'       GET     1
     C           KEYB5     SETLLABMPPB51
     C           KEYB5     READEABMPPB51                 94
     C           *IN94     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           AHSKJY    IFEQ 'D'
     C           AHSKHZ    ANDLE*DATE
     C                     ELSE
     C                     SELEC
     C           AHFUGO    WHEQ '1'
     C           W@HAKD    IFLT AHHTSU
     C                     Z-ADDAHADJU    WKADJU
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           AHFUGO    WHEQ '2'
     C           W@HAKD    IFGT AHHTSU
     C                     Z-ADDAHADJU    WKADJU
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           AHFUGO    WHEQ '3'
     C           W@HAKD    IFEQ AHHTSU
     C                     Z-ADDAHADJU    WKADJU
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           AHFUGO    WHEQ '4'
     C           W@HAKD    IFLE AHHTSU
     C                     Z-ADDAHADJU    WKADJU
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           AHFUGO    WHEQ '5'
     C           W@HAKD    IFGE AHHTSU
     C                     Z-ADDAHADJU    WKADJU
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           AHFUGO    WHEQ '6'
     C           W@HAKD    IFNE AHHTSU
     C                     Z-ADDAHADJU    WKADJU
     C                     MOVEL'1'       GET
     C                     ENDIF
     C                     ENDSL
     C                     ENDIF
     C           KEYB5     READEABMPPB51                 94
     C                     ENDDO
      *
     CSR         ESB711    ENDSR
      *---------------------------*
      * A-PICS 以外　調整枚数
      *---------------------------*
     CSR         #SB720    BEGSR
