     C                     ADD  L6JTEI    W1MAIS
     C                     ADD  L6SKJI    W1MAIS
     C                     ADD  L6PADJ    W1MAIS
     C                     ADD  L6OTHH    W1MAIS
     C                     Z-ADDW1MAIS    L6MAXH
     C                     Z-ADDW1MAIS    L6AMXH
     C                     Z-ADD0         L6AUAJ
     C                     ENDIF
     C                     CALL 'ABCR07'  ACALL
     C           APICS     IFEQ '0'
