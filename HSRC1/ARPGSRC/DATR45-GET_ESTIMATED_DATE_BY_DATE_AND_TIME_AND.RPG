     F** DATR45 ********************************************
     F* GET ESTIMATED DATE BY DATE AND TIME AND +/-        *
     F*      T.SAKAKI..........            2017.03.27      *
     F******************************************** DATR45 **
     I*
     I            DS
     I                                        1  260INIG
     I                                        7  140INHZ
     I                                       15  180INJF
     I            DS
     I                                        1  260OTIG
     I                                        7  140OTHZ
     I                                       15  180OTJF
     I*
     C           *ENTRY    PLIST
     C                     PARM           IDATE   8
     C                     PARM           ITIME   4
     C                     PARM           ODATE   8
     C                     PARM           OTIME   4
     C                     PARM           FUGO    1
     C                     PARM           FUN     5
     C*
     C                     MOVEL*BLANK    ODATE
     C                     MOVEL*BLANK    OTIME
     C                     MOVEL'F'       PF
     C                     Z-ADD0         PIDATE
     C                     Z-ADD0         PODATE
     C                     Z-ADD0         #DATE   80
     C                     Z-ADD0         #TIME   40
     C                     Z-ADD0         INIG
     C                     Z-ADD0         OTIG
     C                     Z-ADD0         #FN     50
     C                     Z-ADD0         PA
     C                     MOVELIDATE     INHZ
     C                     MOVELITIME     INJF
     C                     MOVELFUN       #FN
     C*
     C                     Z-ADDINIG      PIDATE
     C*
     C           FUGO      IFEQ '+'
     C                     Z-ADD#FN       PA
     C                     ENDIF
     C           FUGO      IFEQ '-'
     C                     SUB  #FN       PA
     C                     ENDIF
     C*
     C                     CALL 'YX003G'
     C                     PARM           PIDATE 260
     C                     PARM           PF      1
     C                     PARM           PA      50
     C                     PARM           PODATE 260
     C*
     C                     Z-ADDPODATE    OTIG
     C                     MOVELOTHZ      ODATE
     C                     MOVELOTJF      OTIME
     C*
     C                     SETON                     LR
     C                     RETRN
