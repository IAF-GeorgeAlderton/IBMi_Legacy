     H            Y.
      ** ALDR9Z  ********************************************
      * STORE IN INTRA LOCATION FOR KANBAN C,A WITH LOT IDS *
      *  COPIED FROM ALDR9X                                 *
      *   LEC  2024.11.06                                   *
     F*******************************************************
     FALDPW9Z CF  E                    WORKSTN
     FFCETL11 IF  E           K        DISK
     FABHTL06 IF  E           K        DISK
     FADHTL06 IF  E           K        DISK
     FAAFTL06 IF  E           K        DISK
     FAAPPL06 IF  E           K        DISK
     FAANPL06 IF  E           K        DISK
     FAKBPL06 IF  E           K        DISK
     FAKCPL02 IF  E           K        DISK
     FALDPP35 UF  E                    DISK                      A
     FALDPP36 UF  E                    DISK                      A
      *
     E                    ER      1  25 60
     E                    KBN        32256
     E                    QRC        32256
     E                    LOTS        4  8
      *
     I            DS
     I                                        1  14 D2SHN
     I                                        1   5 D2SHN1
     I                                        6   6 D2SF1
     I                                        7  11 D2SHN2
     I                                       12  12 D2SF2
     I                                       13  14 D2SHN3
      *
     I            DS
     I                                        1  20 D1BAR1
     I                                        1   4 X@ZETI
     I                                        5   5 X@LOC1
     I                                        6   6 X@LC2A
     I                                        6   7 X@LOC2
     I                                        8   9 X@LOC3
     I                                       10  10 X@LOC4
     I                                       11  20 X@BCHK
     I                                        1   2 X@OS1
     I                                        3  16 X@OS2
      *
     ID2BAR2      DS
     I                                        1   1 BCTYPE
     I                                        1   3 QRTYPE
     I                                        5   5 QRKDAI
     I                                        1 256 QR1
     I                                      257 512 QR2
      *ATC TAG
     I                                        1   4 T@ZETI
      *MEKI
     I                                        2   5 A@ZETI
     I                                        6   8 A@LOT#
      *PTKANBAN
     I                                        2   5 P@ZETI
     I                                        6  11 P@ORDN
     I                                       13  16 P@LOTN
     I                                        6  11 P@ORD#
     I                                       12  12 P@KCD1
     I                                       13  16 P@LOT#
      *INTER
     I                                        2   5 #2ZETI
     I                                        6   7 #2BMNA
     I                                        8   8 #2KDAI
     I                                        9  11 #2KOTI
     I                                       12  14 #2HKNO
      *AKB
     I                                        6   9 #3SIRE
     I                                       10  10 #3KCD1
      *
     I                                        1 256 D2BARA
     I                                      257 512 D2BARB
      *
     I@@BAR       DS
     I                                        1 256 @@BARA
     I                                      257 512 @@BARB
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I            DS
     I                                        1   80A2TRHZ
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
      *
     I            DS
     I                                        1   80L7SKHZ
     I                                        1   40L7SKYY
     I                                        5   60L7SKMM
     I                                        7   80L7SKDD
      *
     I            DS
     I                                        1   80L7STHZ
     I                                        1   40L7STYY
     I                                        5   60L7STMM
     I                                        7   80L7STDD
      *
     I            DS
     I                                        1   80M1SKHZ
     I                                        1   40M1SKYY
     I                                        5   60M1SKMM
     I                                        7   80M1SKDD
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTIME6
     I                                        1   20WJI
     I                                        3   40WFN
     I                                        5   60WSC
     I                                        7  140WDATE
     I                                        7  100WYY
     I                                       11  120WMM
     I                                       13  140WDD
      *
     I            DS
     I                                        1   80IEYMD
     I                                        1   40IESKOY
     I                                        5   60IESKOM
     I                                        7   80IESKOD
      *
     I            DS
     I                                        1  32 LOTIDS
     I                                        1   8 D3LOT1
     I                                        9  16 D3LOT2
     I                                       17  24 D3LOT3
     I                                       25  32 D3LOT4
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           INLOCN 20
     C                     PARM           INBARA256
     C                     PARM           POPR    6
     C                     PARM           PITMNM 20
     C                     PARM           PISECT  1
     C                     PARM           PFLG    1
      *
      * DUMMY READ
     C                     READ ALDPP35             N    55
     C                     READ ALDPP36             N    55
      *
      *----------------------------------------------------*
      * MAINLINE                                           *
      *----------------------------------------------------*
     C                     MOVEL'01'      DSPSW   2
     C                     TIME           WTIME
      *
     C           DSPSW     DOUEQ'99'
      *
     C                     SELEC
     C           DSPSW     WHEQ '01'
     C                     EXSR #SB100
     C           DSPSW     WHEQ '02'
     C                     EXSR #SB200
     C           DSPSW     WHEQ '03'
     C                     EXSR #SB300
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *
      *----------------------------------------------------*
      * FIRST SCREEN - Display Screen for Location Entry   *
      *----------------------------------------------------*
     C           #SB100    BEGSR
      *
     C           INLOCN    IFEQ *BLANKS
     C                     EXFMTALDPW991
     C                     ELSE
     C                     MOVELINLOCN    D1BAR1
     C                     MOVE *BLANKS   INLOCN
     C                     Z-ADD1         PGMLVL  10
     C                     ENDIF
      *
     C                     SETOF                     9931
     C                     MOVEL*BLANKS   D9ERR
      *
     C                     MOVEL*BLANK    FNCHK1  5
     C                     MOVEL*BLANK    FNCHK2  2
     C           5         SUBSTD1BAR1:1  FNCHK1
      *
     C           FNCHK1    IFEQ 'XXXXX'
     C           2         SUBSTD1BAR1:6  FNCHK2
     C           FNCHK2    IFEQ '01'
     C                     SETON                     01
     C                     ELSE
     C                     SETON                     99
     C                     MOVELER,6      D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D1BAR1
     C                     GOTO ESB100
     C                     ENDIF
     C                     ENDIF
      *
      * if any Function Key was hit other than F1, just display
      * screen 1 again.
     C                     SELEC
     C           *IN01     WHEQ '1'
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB100
     C           *IN02     WHEQ '1'
     C           *IN03     OREQ '1'
     C           *IN04     OREQ '1'
     C           *IN05     OREQ '1'
     C           *IN06     OREQ '1'
     C           *IN07     OREQ '1'
     C           *IN08     OREQ '1'
     C           *IN09     OREQ '1'
     C           *IN10     OREQ '1'
     C           *IN11     OREQ '1'
     C           *IN12     OREQ '1'
     C                     GOTO ESB100
     C                     OTHER
     C                     ENDSL
      *
     C           D1BAR1    IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     MOVE '1'       D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D1BAR1
     C                     GOTO ESB100
     C                     ENDIF
      *
     C           X@BCHK    IFNE *BLANK
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     MOVE '2'       D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D1BAR1
     C                     GOTO ESB100
     C                     ENDIF
      *
     C                     MOVEL*BLANK    W1SHN1  5
     C                     MOVEL*BLANK    W1SHN2  5
     C                     MOVEL*BLANK    W1SHN3  2
     C                     MOVEL*BLANK    W1TBN1  1
     C                     MOVEL*BLANK    W1TBN2  2
     C                     MOVEL*BLANK    W1TBN3  2
     C                     MOVEL*BLANK    W1TBN4  1
     C                     MOVEL*BLANK    D1ZETI  4
      *
     C           4         SUBSTD1BAR1:1  D1ZETI
     C           1         SUBSTD1BAR1:5  W1TBN1
     C           2         SUBSTD1BAR1:6  W1TBN2
     C           2         SUBSTD1BAR1:8  W1TBN3
     C           1         SUBSTD1BAR1:10 W1TBN4
      *
      * get part information from PART INFORMATION M/F
      *
     C           D1ZETI    CHAINFCETL111             21
     C           *IN21     IFEQ *OFF
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELA2BHB1    W1SHN1
     C                     MOVELA2BHB2    W1SHN2
     C                     MOVELA2BHB3    W1SHN3
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN21     IFEQ *ON
     C           D1ZETI    CHAINAKCPL021             21
     C           *IN21     IFEQ *OFF
     C           M1SKJY    IFEQ 'D'
     C           M1SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELM1KHN1    W1SHN1
     C                     MOVELM1KHN2    W1SHN2
     C                     MOVELM1KHN3    W1SHN3
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN21     IFEQ *ON
     C                     SETON                     99
     C                     MOVELER,3      D9ERR
     C                     MOVE '1'       D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D1BAR1
     C                     GOTO ESB100
     C                     ENDIF
     C                     MOVELD1BAR1    D2BAR1
     C                     MOVEL*BLANK    D2SHN
     C                     MOVELW1SHN1    D2SHN1
     C                     MOVEL'-'       D2SF1
     C                     MOVELW1SHN2    D2SHN2
     C                     MOVEL'-'       D2SF2
     C                     MOVELW1SHN3    D2SHN3
     C                     MOVEL*BLANK    D2BAR2
     C                     Z-ADD0         D2CNT
     C                     MOVEL'02'      DSPSW
      *
     C           ESB100    ENDSR
      *------------------------------------------------------*
      * get all kanban QR codes                              *
      *------------------------------------------------------*
     C           #SB200    BEGSR
      *
     C                     MOVE 'N'       DONE    1
     C                     MOVEL*BLANK    XXBAR2256
      *
     C                     MOVE '001'     W@HKSU  3
      *
     C           INBARA    IFNE *BLANK
     C                     MOVELINBARA    D2BAR2
     C                     MOVEL*BLANKS   INBARA
     C                     ENDIF
      *
     C           DONE      DOWEQ'N'
     C                     EXSR #SB210
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------*
      * SECOND SCREEN - Display Screen to Input APICS KANBAN *
      *------------------------------------------------------*
     C           #SB210    BEGSR
      *
     C                     DO
      *
     C           D2BAR2    IFEQ *BLANK
     C                     EXFMTALDPW992
     C                     ENDIF
      *
     C                     SETOF                     9931
     C                     MOVEL*BLANKS   D9ERR
      *
      *
      * if any Function Key was hit other than F1, just display
      * screen 2 again.
     C                     SELEC
     C           *IN01     WHEQ '1'
     C           PGMLVL    ANDEQ*ZERO
     C                     MOVEL'01'      DSPSW
     C                     MOVEL*BLANK    D1BAR1
     C                     MOVEA*BLANKS   KBN
     C                     MOVEA*BLANKS   QRC
     C                     Z-ADD*ZERO     IX
     C                     Z-ADD*ZERO     XX
     C                     MOVE 'Y'       DONE
     C                     LEAVE
     C           *IN01     WHEQ '1'
     C           PGMLVL    ANDGT*ZERO
     C                     MOVEL'99'      DSPSW
     C                     MOVEL*BLANK    D1BAR1
     C                     MOVEA*BLANKS   KBN
     C                     MOVEA*BLANKS   QRC
     C                     Z-ADD*ZERO     IX
     C                     Z-ADD*ZERO     XX
     C                     MOVE 'Y'       DONE
     C                     LEAVE
     C           *IN02     WHEQ '1'
     C           *IN03     OREQ '1'
     C           *IN04     OREQ '1'
     C           *IN05     OREQ '1'
     C           *IN06     OREQ '1'
     C           *IN07     OREQ '1'
     C           *IN08     OREQ '1'
     C           *IN09     OREQ '1'
     C           *IN10     OREQ '1'
     C           *IN11     OREQ '1'
     C           *IN12     OREQ '1'
     C                     LEAVE
     C                     OTHER
     C                     ENDSL
      *
     C           D2BAR2    IFEQ *BLANK
      *
     C           QRC,01    IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,4      D9ERR
     C                     MOVE '1'       D9ERR
     C                     EXSR #SB290
     C                     LEAVE
     C                     ELSE
     C                     MOVEL'03'      DSPSW
     C                     MOVE 'Y'       DONE
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     MOVELD2BAR2    XXBAR2
      *
      * make sure kanban scanned was type C...OR A...
     C           QRKDAI    IFNE 'C'
     C           QRKDAI    ANDNE'A'
     C                     SETON                     99
     C                     MOVELER,4      D9ERR
     C                     MOVE '2'       D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D2BAR2
     C                     LEAVE
     C                     ENDIF
      *
      * get part information from PART M/F
      *
     C           4         SUBSTD2BAR2:7  D2ZETI  4        QR
      *
     C           D2ZETI    CHAINFCETL111             21
     C           *IN21     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ELSE
     C                     MOVELA2BHB1    W2SHN1  5
     C                     MOVELA2BHB2    W2SHN2  5
     C                     MOVELA2BHB3    W2SHN3  2
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN21     IFEQ *ON
     C           D1ZETI    CHAINAKCPL021             21
     C           *IN21     IFEQ *OFF
     C           M1SKJY    IFEQ 'D'
     C           M1SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELM1KHN1    W2SHN1
     C                     MOVELM1KHN2    W2SHN2
     C                     MOVELM1KHN3    W2SHN3
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN21     IFEQ *ON
     C                     SETON                     99
     C                     MOVELER,3      D9ERR
     C                     MOVE '2'       D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D2BAR2
     C                     LEAVE
     C                     ENDIF
      *
      *
     C           KEYKAN    KLIST
     C                     KFLD           W2SHN1
     C                     KFLD           W2SHN2
     C                     KFLD           W2SHN3
     C                     MOVEL'0'       GETKAN  1
      *
      *///////////////////////////////////
     C           BCTYPE    IFEQ 'I'
     C                     SELEC
     C           P@KCD1    WHEQ '0'
     C                     EXSR #AAP01
     C           P@KCD1    WHEQ '6'
     C                     EXSR #AAN01
     C           P@KCD1    WHEQ '3'
     C                     EXSR #AKB01
     C                     ENDSL
     C                     ELSE
      *
     C           BCTYPE    IFGE '0'
     C           BCTYPE    ANDLE'9'
     C                     SELEC
     C           #2KDAI    WHEQ 'A'
     C           #2KDAI    OREQ 'Y'
     C                     EXSR #ABH01
     C           #2KDAI    WHEQ 'B'
     C                     EXSR #ADH01
     C                     ENDSL
     C                     ELSE
     C           QRKDAI    IFNE 'A'
     C                     EXSR #AAF01
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C           #3KCD1    IFEQ '3'
     C           #3SIRE    IFEQ '2323'
     C           #3SIRE    OREQ '2525'
     C                     EXSR #AKB02
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVE 'N'       #TYPEA  1
     C           QRKDAI    IFEQ 'A'
     C                     MOVE '1'       GETKAN
     C                     MOVE 'Y'       #TYPEA
     C                     ENDIF
      *
     C           GETKAN    IFEQ '0'
     C                     SETON                     99
     C                     MOVELER,10     D9ERR
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D2BAR2
     C                     LEAVE
     C                     ENDIF
      *
      *
      *-----------------------------------
      * check to make sure it's NOT in the last 32 kanbans scanned.
      *   if so, set error as duplicate kanban.
      *-----------------------------------
     C           XXBAR2    LOKUPKBN                      41
     C           *IN41     IFEQ *ON
     C                     MOVEL'NG'      WKOKNG
     C                     MOVELER,7      D9ERR
     C                     MOVE '07'      ERRCOD  2
     C                     MOVELXXBAR2    D2BAR2
     C                     EXSR #SB500
     C                     SETON                     99
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D2BAR2
     C                     LEAVE
     C                     ENDIF
      *-----------------------------------
      * check for qr duplicate scan in results file...
      *
     C                     EXSR CHKDUP
      *
     C           *IN99     IFEQ *ON
     C                     MOVEL'NG'      WKOKNG
     C                     MOVELER,16     D9ERR
     C                     MOVE '16'      ERRCOD  2
     C                     MOVELXXBAR2    D2BAR2
     C                     EXSR #SB500
     C                     SETON                     99
     C                     EXSR #SB290
     C                     MOVEL*BLANK    D2BAR2
     C                     LEAVE
     C                     ENDIF
      *
      *-----------------------------------
      * check to make sure it's a match.
      *-----------------------------------
     C           D2ZETI    IFNE D1ZETI
     C                     MOVEL'NG'      WKOKNG
     C                     MOVE '05'      ERRCOD
     C                     MOVELXXBAR2    D2BAR2
     C                     EXSR #SB500
     C                     SETON                     99
     C                     MOVELER,5      D9ERR
     C                     EXSR #SB290
     C                     LEAVE
     C                     ENDIF
      *
      * if there are no errors,
      * save kanban barcode with the last 32 successful scans.
     C           *IN99     IFEQ *OFF
     C                     EXSR SAVKBN
     C                     ADD  1         D2CNT
      * if 16 kanbans were scanned, then done so get lot ids.
     C           D2CNT     IFEQ 16
     C                     MOVEL'03'      DSPSW
     C                     MOVE 'Y'       DONE
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C           #TYPEA    IFEQ 'Y'
     C                     MOVEL'03'      DSPSW
     C                     MOVE 'Y'       DONE
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVEL*BLANK    D2BAR2
      *
     C                     ENDSR
      *------------------------------------------------------*
      * THIRD SCREEN - Display Screen to Input LOT IDS     *
      *----------------------------------------------------*
     C           #SB300    BEGSR
      *
      * calculate # of lot ids needed...
     C           XX        DIV  4         #LTIDS  10
     C                     MVR            REM     21
     C           REM       IFGT *ZERO
     C           #LTIDS    ANDLT4
     C                     ADD  1         #LTIDS
     C                     ENDIF
      *
      * type A kanbans need 4 lot ids for X-rack locn...
     C           #TYPEA    IFEQ 'Y'
     C                     Z-ADD4         #LTIDS
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     LOTCNT
     C                     EXSR GETLOT
      *
     C           *IN99     IFEQ *OFF
     C           *IN01     ANDEQ*OFF
     C                     MOVEL'OK'      WKOKNG  2
     C                     MOVE *BLANKS   ERRCOD
      *
      * write out all kanbans...
     C                     Z-ADDXX        TIMES   20
     C                     DO   TIMES     XX
     C                     MOVELQRC,XX    D2BAR2
     C                     EXSR #SB500
     C                     ENDDO
      *
     C                     EXSR #SB501
      *
      *  OK
     C                     EXFMTALDPW900
      *
     C                     SELEC
     C           PGMLVL    WHEQ *ZERO
     C                     MOVEL'01'      DSPSW
     C           PGMLVL    WHGT *ZERO
     C                     MOVEL'99'      DSPSW
     C                     ENDSL
      *
     C                     MOVEL*BLANK    D1BAR1
     C                     MOVEA*BLANKS   KBN
     C                     MOVEA*BLANKS   QRC
     C                     Z-ADD*ZERO     IX
     C                     Z-ADD*ZERO     XX
      *
     C                     ENDIF
      *
     C           ESB300    ENDSR
      *----------------------------------------------------*
      * ABHPP01
      *----------------------------------------------------*
     C           #ABH01    BEGSR
      *
     C                     SETOF                         83
     C           KEYKAN    SETLLABHTL061
     C           KEYKAN    READEABHTL061                 83
     C           *IN83     DOWEQ'0'
     C           GETKAN    ANDEQ'0'
     C           M6SKJY    IFEQ 'D'
     C           M6SKHZ    ANDLEWDATE
     C                     ELSE
     C           M6STHZ    IFGT WDATE
     C           M6JBN1    IFEQ X@LOC1
     C           M6JBN2    ANDEQX@LOC2
     C           M6JBN3    ANDEQX@LOC3
     C           M6JBN4    ANDEQX@LOC4
     C                     MOVEL'1'       GETKAN
     C                     MOVELM6JBN1    W2ABN1  1
     C                     MOVELM6JBN2    W2ABN2  2
     C                     MOVELM6JBN3    W2ABN3  2
     C                     MOVELM6JBN4    W2ABN4  1
     C                     MOVEL*BLANK    W2ORDN
     C                     MOVEL*BLANK    W2LOTN
     C           QRKDAI    IFNE 'C'
     C                     MOVELM6LOTK    W@HKSU
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYKAN    READEABHTL061                 83
     C                     ENDDO
      *
     C           EABH01    ENDSR
      *----------------------------------------------------*
      * ADHPP01
      *----------------------------------------------------*
     C           #ADH01    BEGSR
      *
     C                     SETOF                         83
     C           KEYKAN    SETLLADHTL06
     C           KEYKAN    READEADHTL06                  83
     C           *IN83     DOWEQ'0'
     C           GETKAN    ANDEQ'0'
     C           J6SKJY    IFEQ 'D'
     C           J6SKHZ    ANDLEWDATE
     C                     ELSE
     C           J6STHZ    IFGT WDATE
     C           J6ATK1    IFEQ X@LOC1
     C           J6ATK2    ANDEQX@LOC2
     C           J6ATK3    ANDEQX@LOC3
     C           J6ATK4    ANDEQX@LOC4
     C                     MOVEL'1'       GETKAN
     C                     MOVELJ6ATK1    W2ABN1  1
     C                     MOVELJ6ATK2    W2ABN2  2
     C                     MOVELJ6ATK3    W2ABN3  2
     C                     MOVELJ6ATK4    W2ABN4  1
     C                     MOVEL*BLANK    W2ORDN
     C                     MOVEL*BLANK    W2LOTN
     C           QRKDAI    IFNE 'C'
     C                     MOVE '000'     W@HKSU
     C                     MOVE J6LOTO    W@HKSU
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYKAN    READEADHTL06                  83
     C                     ENDDO
      *
     C           EADH01    ENDSR
      *----------------------------------------------------*
      * AAFPP01
      *----------------------------------------------------*
     C           #AAF01    BEGSR
      *
     C                     SETOF                         83
     C           KEYKAN    SETLLAAFTL061
     C           KEYKAN    READEAAFTL061                 83
     C           *IN83     DOWEQ'0'
     C           GETKAN    ANDEQ'0'
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLEWDATE
     C                     ELSE
     C           A3STHZ    IFGT WDATE
     C           A3ATK1    IFEQ X@LOC1
     C           A3ATK2    ANDEQX@LOC2
     C           A3ATK3    ANDEQX@LOC3
     C           A3ATK4    ANDEQX@LOC4
     C                     MOVEL'1'       GETKAN
     C                     MOVELA3ATK1    W2ABN1  1
     C                     MOVELA3ATK2    W2ABN2  2
     C                     MOVELA3ATK3    W2ABN3  2
     C                     MOVELA3ATK4    W2ABN4  1
     C                     MOVEL*BLANK    W2ORDN  6
     C                     MOVEL*BLANK    W2LOTN  4
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYKAN    READEAAFTL061                 83
     C                     ENDDO
      *
     C           EAAF01    ENDSR
      *----------------------------------------------------*
      * AAPPP01
      *----------------------------------------------------*
     C           #AAP01    BEGSR
      *
     C                     SETOF                         83
     C           KEYKAN    SETLLAAPPL061
     C           KEYKAN    READEAAPPL061                 83
     C           *IN83     DOWEQ'0'
     C           GETKAN    ANDEQ'0'
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    ANDLEWDATE
     C                     ELSE
     C           L5STHZ    IFGT WDATE
     C           L5TKR1    IFEQ X@LOC1
     C           L5TKR2    ANDEQX@LOC2
     C           L5TKR3    ANDEQX@LOC3
     C           L5TKR4    ANDEQX@LOC4
     C                     MOVEL'1'       GETKAN
     C                     MOVELL5TKR1    W2ABN1  1
     C                     MOVELL5TKR2    W2ABN2  2
     C                     MOVELL5TKR3    W2ABN3  2
     C                     MOVELL5TKR4    W2ABN4  1
     C                     MOVELP@ORDN    W2ORDN  6
     C                     MOVELP@LOTN    W2LOTN  4
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYKAN    READEAAPPL061                 83
     C                     ENDDO
      *
     C           EAAP01    ENDSR
      *----------------------------------------------------*
      * AANPP01
      *----------------------------------------------------*
     C           #AAN01    BEGSR
      *
     C                     SETOF                         83
     C           KEYKAN    SETLLAANPL061
     C           KEYKAN    READEAANPL061                 83
     C           *IN83     DOWEQ'0'
     C           GETKAN    ANDEQ'0'
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    ANDLEWDATE
     C                     ELSE
     C           L7STHZ    IFGT WDATE
     C           L7TKR1    IFEQ X@LOC1
     C           L7TKR2    ANDEQX@LOC2
     C           L7TKR3    ANDEQX@LOC3
     C           L7TKR4    ANDEQX@LOC4
     C                     MOVEL'1'       GETKAN
     C                     MOVELL7TKR1    W2ABN1  1
     C                     MOVELL7TKR2    W2ABN2  2
     C                     MOVELL7TKR3    W2ABN3  2
     C                     MOVELL7TKR4    W2ABN4  1
     C                     MOVELP@ORDN    W2ORDN  6
     C                     MOVELP@LOTN    W2LOTN  4
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYKAN    READEAANPL061                 83
     C                     ENDDO
      *
     C           EAAN01    ENDSR
      *----------------------------------------------------*
      * AKBPP01  PT
      *----------------------------------------------------*
     C           #AKB01    BEGSR
      *
     C                     SETOF                         83
     C           D2ZETI    SETLLAKBPL061
     C           D2ZETI    READEAKBPL061                 83
     C           *IN83     DOWEQ'0'
     C           GETKAN    ANDEQ'0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    ANDLEWDATE
     C                     ELSE
     C           L1STHZ    IFGT WDATE
     C           L1TKR1    IFEQ X@LOC1
     C           L1TKR2    ANDEQX@LOC2
     C           L1TKR3    ANDEQX@LOC3
     C           L1TKR4    ANDEQX@LOC4
     C                     MOVEL'1'       GETKAN
     C                     MOVELL1TKR1    W2ABN1  1
     C                     MOVELL1TKR2    W2ABN2  2
     C                     MOVELL1TKR3    W2ABN3  2
     C                     MOVELL1TKR4    W2ABN4  1
     C                     MOVELP@ORDN    W2ORDN  6
     C                     MOVELP@LOTN    W2LOTN  4
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           D2ZETI    READEAKBPL061                 83
     C                     ENDDO
      *
     C           EAKB01    ENDSR
      *----------------------------------------------------*
      * AKBPP01  LOCAL VENDER
      *----------------------------------------------------*
     C           #AKB02    BEGSR
      *
     C                     SETOF                         83
     C           D2ZETI    SETLLAKBPL061
     C           D2ZETI    READEAKBPL061                 83
     C           *IN83     DOWEQ'0'
     C           GETKAN    ANDEQ'0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    ANDLEWDATE
     C                     ELSE
     C           L1STHZ    IFGT WDATE
     C                     MOVEL'1'       GETKAN
     C                     MOVELL1TKR1    W2ABN1  1
     C                     MOVELL1TKR2    W2ABN2  2
     C                     MOVELL1TKR3    W2ABN3  2
     C                     MOVELL1TKR4    W2ABN4  1
     C                     MOVEL*BLANK    W2ORDN  6
     C                     MOVEL*BLANK    W2LOTN  4
     C                     ENDIF
     C                     ENDIF
     C           D2ZETI    READEAKBPL061                 83
     C                     ENDDO
      *
     C           EAKB02    ENDSR
      *----------------------------------------------------*
      *     LOT ID SCREEN
      *----------------------------------------------------*
     C           GETLOT    BEGSR
      *
     C           *IN01     DOUEQ*ON
      *
     C                     MOVE *BLANKS   D3LOT
     C                     EXFMTALDPW993
     C                     MOVEL*BLANK    D9ERR
     C                     MOVE *OFF      *IN99
      *
     C                     SELEC
     C           *IN01     WHEQ *ON
     C                     MOVE *BLANKS   D2BAR2
     C                     MOVE *BLANKS   LOTIDS
     C                     MOVE *BLANKS   D3LOT
     C                     MOVEL'02'      DSPSW
      *
     C                     OTHER
     C                     EXSR CHKLOT
      *
     C           *IN99     IFEQ *OFF
     C           LOTCNT    ANDEQ#LTIDS
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *     LOT ID SCREEN CHECK
      *----------------------------------------------------*
     C           CHKLOT    BEGSR
      *
     C                     MOVELD3LOT     W4LOT1  8
     C                     MOVE D3LOT     W4CHKD  1
     C                     SETOF                     9961
      *
     C                     DO
      *
     C           D3LOT     IFEQ *BLANK
     C           D3LOT1    ANDEQ*BLANK
     C           D3LOT2    ANDEQ*BLANK
     C           D3LOT3    ANDEQ*BLANK
     C           D3LOT4    ANDEQ*BLANK
     C                     SETON                     9961
     C                     MOVELER,14     D9ERR
     C                     LEAVE
     C                     ENDIF
      *
      * if lot is blank but all lot ids haven't been scanned yet, error
     C           D3LOT     IFEQ *BLANK
     C           LOTCNT    ANDLT#LTIDS
     C                     SETON                     9961
     C                     MOVELER,17     D9ERR
     C                     LEAVE
     C                     ENDIF
      *
      * check digit...
     C           W4LOT1    IFGT *BLANKS
     C                     MOVELW4LOT1    PMAREA    P
     C                     MOVE '007'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     EXSR #SB600
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C                     MOVELER,2      D9ERR
     C                     MOVE '1'       D9ERR
     C                     ENDIF
      *
     C           PMCHK     IFNE W4CHKD
     C                     SETON                     9961
     C                     MOVELER,2      D9ERR
     C                     MOVE '2'       D9ERR
     C                     LEAVE
     C                     ENDIF
      *
     C   99                LEAVE
      *
     C           D3LOT     IFEQ D3LOT1
     C           D3LOT     OREQ D3LOT2
     C           D3LOT     OREQ D3LOT3
     C           D3LOT     OREQ D3LOT4
     C                     SETON                     9961
     C           D9ERR     IFEQ *BLANK
     C                     MOVELER,15     D9ERR
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C                     SELEC
     C           D3LOT1    WHEQ *BLANK
     C                     MOVELD3LOT     D3LOT1
     C           D3LOT2    WHEQ *BLANK
     C                     MOVELD3LOT     D3LOT2
     C           D3LOT3    WHEQ *BLANK
     C                     MOVELD3LOT     D3LOT3
     C           D3LOT4    WHEQ *BLANK
     C                     MOVELD3LOT     D3LOT4
     C                     ENDSL
     C                     ENDIF
      *
     C                     ADD  1         LOTCNT  10       LOT ID COUNT
      *
     C                     ENDDO
      *
     C           *IN99     IFEQ *ON
     C                     EXFMTALDPW999
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      * ALDPP35 - Write Record to INTRA Store Location     *
      *----------------------------------------------------*
     C           #SB500    BEGSR
      *
     C                     MOVELD2BAR2    @@BARA
      *
     C* create code 39 barcode...
     C                     CALL 'UEXR13'
     C                     PARM           @@BARA
     C                     PARM           @@BARB
     C                     PARM           P9BAR  20
      *
     C                     MOVELP9BAR     C2BAR2 20
      *
      * write to ALDPP35
     C                     TIME           WTIME
     C                     CLEARALDPP351
     C                     Z-ADDWDATE     A9KODT
     C                     TIME           A9KOTM
     C                     MOVELW#WSID    A9WSID
     C                     MOVELW#USER    A9USER
     C                     MOVELW#JBNO    A9JOBN
     C                     MOVELW#PGM     A9KOPG
     C                     MOVELPOPR      A9WOKR
     C                     Z-ADDWDATE     A9CODT
     C                     TIME           A9COTM
     C                     MOVELD1BAR1    A9LBAR
     C                     MOVELD1ZETI    A9LZET
     C                     MOVELW1SHN1    A9LHN1
     C                     MOVELW1SHN2    A9LHN2
     C                     MOVELW1SHN3    A9LHN3
     C                     MOVELW1TBN1    A9TBN1
     C                     MOVELW1TBN2    A9TBN2
     C                     MOVELW1TBN3    A9TBN3
     C                     MOVELW1TBN4    A9TBN4
      **
     C                     MOVELC2BAR2    A9ABAR
     C                     MOVELD2BAR2    A9ABQR
      **
     C                     MOVELW2SHN1    A9AHN1
     C                     MOVELW2SHN2    A9AHN2
     C                     MOVELW2SHN3    A9AHN3
     C                     MOVELW2ABN1    A9ABN1
     C                     MOVELW2ABN2    A9ABN2
     C                     MOVELW2ABN3    A9ABN3
     C                     MOVELW2ABN4    A9ABN4
      *
      * PASS THRU kanban barcodes start with an I...
      * if barcode is a pass thru kanban, then blank out
      * apics product and page numbers.
     C           1         SUBSTA9ABAR:1  BCID    1
     C           BCID      IFGE '0'
     C           BCID      ANDLE'9'
     C                     MOVEL*BLANK    A9TEHA
     C                     MOVEL*BLANK    A9PAGE
     C                     MOVELD2ZETI    A9PTOR
     C           3         SUBSTA9ABAR:12 A9PTLT
     C                     ELSE
     C                     MOVELD2ZETI    A9AZET
     C           3         SUBSTA9ABAR:6  A9TEHA
     C           2         SUBSTA9ABAR:9  A9PAGE
     C                     ENDIF
      *
     C                     MOVELWKOKNG    A9OKNG
     C                     MOVELERRCOD    A9ERCD
     C                     MOVELPISECT    A9SECT
     C                     MOVELW2ORDN    A9ORDN
     C                     MOVELW2LOTN    A9LOTN
     C                     WRITEALDPP351
      *
     C                     ENDSR
      *----------------------------------------------------*
      * ALDPP36 - Write Record to INTRA Store Loc LOT IDS  *
      *----------------------------------------------------*
     C           #SB501    BEGSR
      * write to ALDPP36
     C                     CLEARALDPP361
     C                     Z-ADDA9KODT    B9KODT
     C                     Z-ADDA9KOTM    B9KOTM
     C                     MOVELW#WSID    B9WSID
     C                     MOVELW#USER    B9USER
     C                     MOVELW#JBNO    B9JOBN
     C                     MOVELW#PGM     B9KOPG
     C                     MOVELPOPR      B9WOKR
     C                     Z-ADDA9CODT    B9CODT
     C                     Z-ADDA9COTM    B9COTM
      *
     C                     MOVELA9ABAR    B9ABAR
      *
     C                     MOVEALOTIDS    LOTS
     C                     DO   4         N       40
      *
     C           LOTS,N    IFNE *BLANK
     C                     MOVELLOTS,N    B9LOT
     C                     WRITEALDPP361
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVE *BLANKS   D3LOT
     C                     MOVE *BLANKS   LOTIDS
     C                     MOVEALOTIDS    LOTS
      *
     C                     ENDSR
      *----------------------------------------------------*
      * Call Program to Get Check Digit                    *
      *----------------------------------------------------*
     C           #SB600    BEGSR
      *
     C                     CALL 'ALBRCC'
     C                     PARM           PMAREA100        INPUT DATA
     C                     PARM           PMBYTE  3        LENGTH
     C                     PARM           PMCHK   1        CHECKS DIGITS
     C                     PARM           PMRTCD  1        RETRN CODE
      *
     C                     ENDSR
      *
      *----------------------------------------------------*
      * ERROR SCREEN - Display Error on Screen             *
      *----------------------------------------------------*
     C           #SB290    BEGSR
      *
     C           D9ERR     IFEQ ER,5
      *
     C*  PASSWORD LOCK
     C                     MOVE PISECT    P1PGM
     C                     MOVELD9ERR     P1ERR
     C                     MOVELW#PGM     P1PID
     C                     MOVELPOPR      P1KOME    P
     C                     Z-ADD*ZERO     P1DTTM
     C                     CALL 'AM#R09'
     C                     PARM           P1PGM   20
     C                     PARM           P1ERR  25
     C                     PARM           P1PID  10
     C                     PARM           P1KOME 10
     C                     PARM           P1DTTM 140
     C                     MOVEL*ON       W@ERCK  1
      *
     C                     ELSE
      *
     C                     WRITEALDPW998
     C                     EXFMTALDPW999
      *
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      * Save Kanban barcode with the last 32 scanned.      *
      *----------------------------------------------------*
     C           SAVKBN    BEGSR
      *
     C           IX        IFEQ 32
     C                     Z-ADD1         IX      20
     C                     ELSE
     C                     ADD  1         IX
     C                     ENDIF
      *
     C                     MOVELD2BAR2    KBN,IX
      *
      * save QR code for writing output...
     C                     DO
      *
     C           XX        IFGE 32
     C                     LEAVE
     C                     ELSE
     C                     ADD  1         XX      20
     C                     ENDIF
      *
     C                     MOVELD2BAR2    QRC,XX
      *
     C                     ENDDO
      *
     C                     ENDSR
      *
      *----------------------------------------------------*
      * INTRA STOCK UPDATE SUB ROUTINE               *
      *----------------------------------------------------*
     C           #SBSTA    BEGSR
      *
     C                     MOVE '0111'    P#BMON  4
     C                     Z-ADD0         P#HKSU  50
     C                     MOVE W@HKSU    P#HKSU
      *
     C           A9ABQR    IFNE *BLANK
     C           256       SUBSTA9ABQR:1  P#QR11256
     C           256       SUBSTA9ABQR:257P#QR12256
     C                     ENDIF
      *
     C                     MOVEL*BLANK    P#BAR2
     C                     MOVEL*BLANK    P#QR21
     C                     MOVEL*BLANK    P#QR22
      *
     C                     CALL 'STAR00'
     C                     PARM WDATE     P#TIHZ  80
     C                     PARM WTIME6    P#TITI  60
     C                     PARM           P#BMON  4
     C                     PARM W1SHN1    P#SHN1  5
     C                     PARM W1SHN2    P#SHN2  5
     C                     PARM W1SHN3    P#SHN3  2
     C                     PARM W2ABN1    P#ATK1  1
     C                     PARM W2ABN2    P#ATK2  2
     C                     PARM W2ABN3    P#ATK3  2
     C                     PARM W2ABN4    P#ATK4  1
     C                     PARM '1'       P#SYOR  1
     C                     PARM '1'       P#ZAIK  1
     C                     PARM           P#HKSU  50
     C                     PARM POPR      P#TMCD 10
     C                     PARM PITMNM    P#TMNM 20
     C                     PARM W#PGM     P#PGM  10
     C                     PARM A9ABAR    P#BAR1 20
     C                     PARM           P#QR11256
     C                     PARM           P#QR12256
     C                     PARM           P#BAR2 20
     C                     PARM           P#QR21256
     C                     PARM           P#QR22256
      *
     C                     ENDSR
      *----------------------------------------------------*
      * check for qr duplicate scan in results file...
      *----------------------------------------------------*
     C           CHKDUP    BEGSR
      *
     C                     CALL 'ALDR49Z'
     C                     PARM           QR1   256
     C                     PARM           QR2   256
     C                     PARM           RTNC    1
      *
     C           RTNC      IFEQ 'E'
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
**
INPUT LOCATION BARCODE.                                        1
CHECK DIGIT ERROR.                                             2
PARTS MASTER ERROR.                                            3
INVALID QR CODE.                                               4
NONMATCH ERROR.                                                5
FNC KEY ERROR.                                                 6
DUPLICATE KANBAN.                                              7
APICS STOP ALERT.                                              8
PT STOP ALERT.                                                 9
NO KANBAN M/F.                                                10
OLD KANBAN. NEED SWITCH.                                      11
ATC PART NO MASTER ERR.                                       12
INVALID LOCATION                                              13
LOT ID INVALID                                                14
DUPLICATE LOT ID.                                             15
ALREADY SCANNED.                                              16
SCAN ALL LOT IDS.                                             17
