     H            Y.
      ** ABHRS1W********************************
      *  INTRA-PROCESS KANBAN M/F --> CSV DATA *
      *  JW    2019.03.31                      *
      ******************************************
     FABHWPS4 IF  E           K        DISK
     FABHWPS4WO   E           K        DISK
      *================================================================
      *  START  PROGRAM
      *===============================================================
      *
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         SEQ#    30
     C                     Z-ADD0         SVGOKE  80
     C                     Z-ADD0         SVNNNM 100
     C                     Z-ADD0         SV1NNM 100
     C                     Z-ADD0         SV2NNM 100
     C                     MOVE *BLANK    SVAKT  10
     C                     MOVE *BLANK    SVSIZ  10
     C                     MOVE *BLANK    SVKEIS 10
     C                     MOVE *BLANK    SVKGUN 10
      *
     C                     DO   *HIVAL
     C                     READ ABHWPS4                  98
     C   98                LEAVE
      * FIRST ?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELW@KBN     SVKBN   3
     C                     EXSR #HEAD
     C                     ENDIF
      * BREAK ?
     C           W@KBN     IFNE SVKBN
     C                     EXSR #BRK1
     C                     ENDIF
      * DETAIL PROCESS
     C                     MOVELW@AKT     SVAKT
     C                     MOVELW@SIZ     SVSIZ
     C                     MOVELM@KEIS    SVKEIS
     C                     MOVELM@KGUN    SVKGUN
     C                     ADD  WWGOKE    SVGOKE
     C                     ADD  WWNNNM    SVNNNM
     C                     ADD  WW1NNM    SV1NNM
     C                     ADD  WW2NNM    SV2NNM
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C* HEADER
     C*===============================================================
     C           #HEAD     BEGSR
      *
     C                     MOVEL'PROCESS' X@AKT     P
     C                     MOVEL'MACHIN'  X@KBN     P
     C                     MOVEL'SIZE'    X@SIZ     P
     C                     MOVEL'MCN TYPE'X@KEIS    P
     C                     MOVEL'GROUP'   X@KGUN    P
     C                     MOVEL'N-1'     XWGOKE    P
     C                     MOVEL'N'       XWNNNM    P
     C                     MOVEL'N+1'     XW1NNM    P
     C                     MOVEL'N+2'     XW2NNM    P
      *
     C                     WRITEABHWP4W1
      *
     C                     ENDSR
     C*===============================================================
     C* BREAK
     C*===============================================================
     C           #BRK1     BEGSR
      *
     C                     MOVELSVAKT     X@AKT     P
     C                     MOVELSVKBN     X@KBN     P
     C                     MOVELSVSIZ     X@SIZ     P
     C                     MOVELSVKEIS    X@KEIS    P
     C                     MOVELSVKGUN    X@KGUN    P
     C                     MOVELSVGOKE    XWGOKE    P
     C                     MOVELSVNNNM    XWNNNM    P
     C                     MOVELSV1NNM    XW1NNM    P
     C                     MOVELSV2NNM    XW2NNM    P
     C                     WRITEABHWP4W1
      * RESET
     C                     MOVELW@KBN     SVKBN
     C                     Z-ADD0         SVGOKE
     C                     Z-ADD0         SVNNNM
     C                     Z-ADD0         SV1NNM
     C                     Z-ADD0         SV2NNM
      *
     C                     ENDSR
