     C****************************************************************
     C*           ＭＡＩＮ　ＲＯＵＴＩＮＥ                         *
     C****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C*
     C           KEY01     KLIST
     C                     KFLD           ICHIN1
     C                     KFLD           ICHIN2
     C                     KFLD           ICHIN3
     C****************
     C*  初期処理  *
     C****************
     C           @STR      TAG
     C                     EXSR #INIT
     C****************
     C*  第一画面  *
     C****************
     C           @DSP1     TAG
     C                     SETOF                     20
     C                     WRITEDSPM1
     C                     EXFMTDSP01
     C                     MOVE *BLANK    D#MSG
     C                     MOVEA'0'       *IN,99
     C* < F1=ON >
     C           *INKA     CABEQ'1'       @END
     C                     EXSR #CHK1
     C   99                GOTO @DSP1
     C****************
     C*  第二画面  *
     C****************
     C           @DSP2     TAG
     C                     SETON                     20
     C                     WRITEDSPM1
     C                     EXFMTDSP02
     C                     MOVE *BLANK    D#MSG
     C                     MOVEA'0'       *IN,99
     C* < F1=ON >
     C           *INKA     CABEQ'1'       @END
     C           *INKC     CABEQ'1'       @DSP1
     C           *INKE     CABEQ'0'       @DSP2
     C                     EXSR #UPD
     C*
     C                     GOTO @STR
     C****************
     C           @END      TAG
     C                     SETON                     LR
     C                     RETRN
     C****************************************************************
     C*           ＳＵＢ　　ＲＯＵＴＩＮＥ                         *
     C****************************************************************
     C           #INIT     BEGSR                                     *
     C****************************************************************
     C**初期処理**
     C* < fﾞx] ﾎｧｰﾓnﾞ hﾒaｰ >
     C                     Z-ADD0         D1ITEM
     C                     SETOF                     11
     C                     SETOF                     99
     C*
     C                     ENDSR
     C****************************************************************
     C           #CHK1     BEGSR                                     *
     C****************************************************************
     C                     SETOF                     11  99
     C**第１画面チェック**
     C           D1ITEM    SETLLGDGPL16
     C                     DO   *HIVAL
     C           D1ITEM    READEGDGPL16             N    90
     C   90                LEAVE
     C           ICSKJY    IFEQ 'D'
     C           ICSKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C                     LEAVE
     C                     ENDDO
     C*
     C           *IN90     IFEQ *ON
     C  N99                MOVELMSG,1     D#MSG
     C                     SETON                     1199
     C                     ELSE
     C           KEY01     SETLLFCEPL01
     C                     DO   *HIVAL
     C           KEY01     READEFCEPL01                  91
     C   91                LEAVE
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C                     LEAVE
     C                     ENDDO
     C  N91                MOVELA2SMEI    D2NAME
     C                     MOVE *ALL'-'   D2HIN
     C                     MOVE ICHIN1    D2HIN1
     C                     MOVE ICHIN2    D2HIN2
     C                     MOVE ICHIN3    D2HIN3
     C           ICHIN3    IFEQ *BLANK
     C                     MOVE '   '     D2HIN
     C                     END
     C                     Z-ADDICSURY    D2SURY
     C                     Z-ADDICSURT    D2SURT
     C                     MOVE ICIFMK    D2IFMK
     C                     ENDIF
     C*
     C                     ENDSR
     C****************************************************************
     C           #UPD      BEGSR                                     *
     C****************************************************************
     C           D1ITEM    SETLLGDGPL16
     C                     DO   *HIVAL
     C           D1ITEM    READEGDGPL16                  90
     C   90                LEAVE
     C           ICSKJY    IFEQ 'D'
     C           ICSKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C                     LEAVE
     C                     ENDDO
     C*
     C           *IN90     IFEQ *OFF
     C                     TIME           @@TIME
     C                     MOVE 'C'       ICIFMK
     C                     Z-ADD*DATE     ICIFHZ
     C                     Z-ADD*DATE     ICKOHZ
     C                     Z-ADD@TIME     ICKOTM
     C                     MOVE PPUSER    ICKOME
     C                     UPDATGDGPL161
     C                     ENDIF
     C                     ENDSR
     C****************************************************************
