     C                     ITER
     C                     ENDIF
      *
     C           D@ORDR    IFNE *BLANK
     C           BAODRN    ANDNED@ORDR
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE *BLANK    @@F     1
     C                     MOVE BANONY    @NON4   4
     C           @NON4     CHAINABF9L01              96
     C           *IN96     IFEQ *OFF
     C                     MOVE '1'       @@F
     C                     ELSE
     C                     MOVE *BLANK    @@F
     C                     ENDIF
      *
     C                     MOVE BATOKU    @TOKU   4
     C                     MOVE BANONY    @NONY   4
     C                     MOVE BANKOJ    @NKOJ   1
     C                     MOVE BANUKE    @NUKE   4
      *
     C                     MOVE BAMHIN    @MHIN  20
     C                     MOVE BANOHZ    @HIZK   8
     C                     Z-ADD0         @TANK  105
     C                     MOVE *BLANK    @CHEK   1
      *
     C                     CALL 'FBCR10'
     C                     PARM           @TOKU
     C                     PARM           @NONY
     C                     PARM           @NKOJ
     C                     PARM           @NUKE
     C                     PARM           @MHIN
     C                     PARM           @HIZK
     C                     PARM           @TANK
     C                     PARM           @CHEK
      * UNIT PRICE ERROR
     C           @TANK     IFEQ 0
     C                     MOVE BANONY    D@NONY
     C                     MOVE BANKOJ    D@FACT
     C                     MOVE BANUKE    D@DOCK
     C                     MOVE BAMHN1    D@PRT1
     C                     MOVE BAMHN2    D@PRT2
     C                     MOVE BAMHN3    D@PRT3
     C                     EXFMTDSP03
      *
     C                     MOVE '1'       P@END
     C                     MOVE *ON       *INLR
     C                     RETRN
     C                     END
      *
     C                     MOVE BASBAN    #SBAN   4
     C                     Z-ADDBANOBN    #BIN    20
      *
     C           BATOKU    IFEQ 0873
     C                     MOVELBAINVN    #ODR1
     C                     ELSE
     C                     MOVE BAODRN    #ODR1  10
     C                     END
      * FORD
     C           @@F       IFEQ '1'
     C           BANOBN    IFEQ 0
     C                     Z-ADD01        PNOBI
     C                     ELSE
     C                     Z-ADDBANOBN    PNOBI
     C                     END
     C           KEY4      CHAINABF4P01              96
     C           *IN96     IFEQ '0'
     C                     MOVE *BLANK    #ODR1
     C                     MOVELYBPS#     FPS#
     C                     MOVELFNO       #ODR1
     C                     ENDIF
     C                     ENDIF
      * HONDA
     C           BANONY    IFEQ 0295
     C           BANONY    OREQ 2020
     C           BAINVN    IFNE *BLANK
     C                     MOVELB1NB1     #ODR1
     C                     ENDIF
     C                     ENDIF
      *
  B6 C           BANONY    IFEQ 3347
  B6 C           BANONY    OREQ 3348
     C                     MOVE '1406'    #SIRE   4
     C                     MOVE '0'       #SIRK   1
  E6 C                     END
      *
  B6 C           BANONY    IFEQ 3931
  B6 C           BANONY    OREQ 3932
     C                     MOVE '1406'    #SIRE
     C                     MOVE '0'       #SIRK
  E6 C                     END
      *
  B6 C           BANONY    IFEQ 3804
  B6 C           BANONY    OREQ 3805
     C                     MOVE '1406'    #SIRE
     C                     MOVE '0'       #SIRK
  E6 C                     END
      *
  B6 C           BANONY    IFEQ 0506
  B6 C           BANONY    OREQ 0437
     C                     MOVE 'C742'    #SIRE
     C                     MOVE '1'       #SIRK
  E6 C                     END
      *
     C                     Z-ADDBANOHZ    WNOHZ   60
     C                     MOVELBANUKE    WNUKE   2
     C                     Z-ADDBASRYO    WSRYO  100
     C                     MOVELBAMHIN    WMHIN  30
     C                     Z-ADD@TANK     WTANK  134
     C                     MOVE BACARD    WCARD   4
     C                     MOVELBAINVN    WINVO  16
     C                     Z-ADDBASYOS    WSYOS   60
     C           BASYOS    IFEQ *ZERO
     C           BAUSYS    ANDNE*ZERO
