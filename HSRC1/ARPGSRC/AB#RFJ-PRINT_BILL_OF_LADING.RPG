     C           *ENTRY    PLIST
     C                     PARM           P@CAR  15
      *
     C           #CHG      PLIST
     C                     PARM           PIN    305
     C                     PARM           POUT   30
     C                     PARM           PLEN    20
      *
     CL1                   EXSR #MOVE
     CL2                   EXSR #TOTAL
     C*****************************************************************
     CSR         #MOVE     BEGSR
     C*****************************************************************
     C                     EXSR #JURYO
      *
     C                     MOVEL*BLANK    O#PLT   3
     C                     Z-ADD0         PLEN
     C                     Z-ADDW#PLT     PIN
     C                     MOVE *BLANK    POUT
     C                     CALL 'AB#R2N'  #CHG
     C                     MOVE POUT      O#PLT
      *
     C                     MOVEL*BLANK    O#CON   4
     C                     Z-ADD0         PLEN
     C                     Z-ADDW#CON     PIN
     C                     MOVE *BLANK    POUT
     C                     CALL 'AB#R2N'  #CHG
     C                     MOVE POUT      O#CON
      *
     C                     ADD  1         Z       20
     C                     MOVELIPLAN     @DE,Z
     C                     MOVELIDOCK     @DO,Z
     C                     MOVE WPS#      @PS,Z
     C                     MOVE O#PLT     @#P,Z
     C                     MOVE O#CON     @#C,Z
     C                     MOVE WWTG      @TG,Z
     C                     MOVE WWTT      @TT,Z
     C                     MOVE WWTN      @TN,Z
     C                     Z-ADD0         W#CON
     C           Z         IFEQ 17
     C                     EXSR #WRITE
     C                     END
     CSR         EMOVE     ENDSR
     C*****************************************************************
     CSR         #TOTAL    BEGSR
     C*****************************************************************
      * TARE WEIGNT
     C                     MOVE *BLANK    @@TT    9
     C                     Z-ADD2         PLEN
     C                     Z-ADD@WTT      PIN
     C                     MOVE *BLANK    POUT
     C                     CALL 'AB#R2N'  #CHG
     C                     MOVE POUT      @@TT
      * NET WEIGNT
     C                     MOVE *BLANK    @@TN    9
     C                     Z-ADD2         PLEN
     C                     Z-ADD@WTN      PIN
     C                     MOVE *BLANK    POUT
     C                     CALL 'AB#R2N'  #CHG
     C                     MOVE POUT      @@TN
      * GROSS WEIGNT
     C                     MOVE *BLANK    @@TG    9
     C                     Z-ADD2         PLEN
     C                     Z-ADD@WTG      PIN
     C                     MOVE *BLANK    POUT
     C                     CALL 'AB#R2N'  #CHG
     C                     MOVE POUT      @@TG
      *
     C                     MOVEL*BLANK    O#PLT   3
     C                     Z-ADD0         PLEN
     C                     Z-ADD@#PLT     PIN
     C                     MOVE *BLANK    POUT
     C                     CALL 'AB#R2N'  #CHG
     C                     MOVE POUT      O#PLT
      *
     C                     MOVEL*BLANK    O#CON   4
     C                     Z-ADD0         PLEN
     C                     Z-ADD@#CON     PIN
     C                     MOVE *BLANK    POUT
     C                     CALL 'AB#R2N'  #CHG
     C                     MOVE POUT      O#CON
      *
     C                     ADD  1         Z       20
     C                     MOVEL*BLANK    @DE,Z
     C                     MOVEL*BLANK    @DO,Z
     C                     MOVEL'TOTAL'   @PS,Z
     C                     MOVE O#PLT     @#P,Z
     C                     MOVE O#CON     @#C,Z
     C                     MOVE @@TG      @TG,Z
     C                     MOVE @@TT      @TT,Z
     C                     MOVE @@TN      @TN,Z
     C                     EXSR #WRITE
     C                     Z-ADD0         @WTT
     C                     Z-ADD0         @WTN
     C                     Z-ADD0         @WTG
     C                     Z-ADD0         @#PLT
     C                     Z-ADD0         @#CON
     CSR         ETOTAL    ENDSR
     C*****************************************************************
     CSR         #WRITE    BEGSR
     C*****************************************************************
      *
     C           KEY1      KLIST
     C                     KFLD           IDELY
     C                     KFLD           WDOCK
      *
     C           KEY2      KLIST
     C                     KFLD           IDELY
     C                     KFLD           IDOCK
     C                     KFLD           ISIYY
     C                     KFLD           ISIMM
     C                     KFLD           ISIDD
     C                     KFLD           IREYY
     C                     KFLD           IREMM
     C                     KFLD           IREDD
      *
     C           KEY3      KLIST
     C                     KFLD           IDELY
     C                     KFLD           IDOCK
     C                     KFLD           ISIHZ
     C                     KFLD           ISIBN
     C                     KFLD           IREYY
     C                     KFLD           IREMM
     C                     KFLD           IREDD
      *
     C                     MOVEL*BLANK    @FLAG   1
     C                     MOVELIDELY     WDELY   4
     C                     MOVELIDOCK     WDOCK   4
     C           KEY1      SETGTABFDL01R             20
     C           *IN20     DOUEQ*ON
     C           KEY1      REDPEABFDL01R                 20
     C           *IN20     IFEQ '0'
     C                     SELEC
     C           QASKJY    WHEQ 'D'
     C           QASKHZ    ANDLE*DATE
     C                     ITER
     C           QAEFHZ    WHGT *DATE
     C                     ITER
     C                     OTHER
      *
     C           IDELY     IFEQ 5150
     C                     MOVELTB1,1     AFCANM
     C                     ELSE
     C                     MOVEL'PENSKE'  AFCANM
     C                     ENDIF
      *
     C                     MOVELP@CAR     AFCANM    P
     C*
     C                     LEAVE
     C                     ENDSL
     C                     END
     C                     END
     C           *IN20     IFEQ '1'
     C                     MOVEL'*'       @FLAG
     C                     END
      *
     C           *IN20     IFEQ '0'
     C                     SETOF                     20
     C           KEY2      SETLLAB#PL161
     C           *IN20     DOUEQ*ON
     C           KEY2      READEAB#PL161                 20
     C           *IN20     IFEQ '0'
     C           BASKJY    ANDEQ*BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN20     IFEQ '1'
     C                     MOVEL'*'       @FLAG
     C                     ELSE
TCHK2C*          BAJYKB    IFNE *BLANK
TCHK2C*                    MOVEL'*'       @FLAG
TCHK2C*                    END
     C                     END
     C                     END
      *
     C                     MOVELIBINO     @@4     4
     C           @@4       IFEQ '5149'
     C                     MOVELTB1,2     AFCANM
     C                     ENDIF
      *
     C                     MOVELP@CAR     AFCANM    P
      *
     C           @FLAG     IFNE *BLANK
     C           @@4       IFEQ '5149'
     C                     MOVE *BLANK    @FLAG
     C                     ENDIF
     C                     ENDIF
      *
     C                     SETOF                     20
     C           WDELY     CHAINEDIPL401             20
     C           *IN20     IFEQ '0'
     C           BASKJY    IFEQ 'D'
     C**JW       BASKHZ    ANDLE*DATE
     C                     ELSE
     C           @FLAG     IFEQ '*'
     C           @@4       OREQ '5149'
     C                     MOVELE4ADD1    AFTONM
     C                     MOVELE4ADD2    AFAD01
     C                     MOVELE4ADD3    AFAD02
     C                     MOVELE4ADD4    AFAD03
     C                     MOVELE4ADD5    AFAD04
     C                     END
     C           @FLAG     IFEQ ' '
     C                     MOVELCMT,1     AFTONM
     C                     END
     C                     END
     C                     END
      *
     C                     MOVEL*BLANK    AFCANO
     C**************       MOVE ISIHZ     AFSHDT
     C                     MOVE SHDT      AFSHDT
     C                     MOVE IREHZ     AFRLDT
     C                     MOVELIBINO     AFBLNO
JW1   * ADDRESS
 .   C           AFPSN2    IFEQ 'TOTAL'
 .   C                     EXSR #ADDR
JW1  C                     ENDIF
      *
      * OUTPUT ABFFO01
     C                     WRITEABFFP01R
      *
     C                     MOVEL*BLANK    AFCANM
     C                     MOVEL*BLANK    AFCANO
     C                     MOVEL*BLANK    AFSHDT
     C                     MOVEL*BLANK    AFRLDT
     C                     MOVEL*BLANK    AFTONM
     C                     MOVEL*BLANK    AFAD01
     C                     MOVEL*BLANK    AFAD02
     C                     MOVEL*BLANK    AFAD03
     C                     MOVEL*BLANK    AFAD04
     C                     MOVEL*BLANK    AFBLNO
     C                     MOVEL*BLANK    @DE
     C                     MOVEL*BLANK    @DO
     C                     MOVEL*BLANK    @PS
     C                     MOVEL*BLANK    @#P
     C                     MOVEL*BLANK    @#C
     C                     MOVEL*BLANK    @TG
     C                     MOVEL*BLANK    @TT
     C                     MOVEL*BLANK    @TN
     C                     MOVEL*BLANK    @@TG
     C                     MOVEL*BLANK    @@TT
     C                     MOVEL*BLANK    @@TN
     C                     Z-ADD0         Z
     CSR         EWRITE    ENDSR
     C*****************************************************************
JW1  CSR         #ADDR     BEGSR
     C*****************************************************************
     C           WDELY     CHAINEDIPL401             21
      *
     C           *IN21     IFEQ *OFF
     C           BASKJY    ANDNE'D'
     C                     MOVELE4ADD1    AFTONM
     C                     MOVELE4ADD2    AFAD01
     C                     MOVELE4ADD3    AFAD02
     C                     MOVELE4ADD4    AFAD03
     C                     MOVELE4ADD5    AFAD04
     C                     ENDIF
      *
JW1  C                     ENDSR
     C*****************************************************************
     CSR         #JURYO    BEGSR
     C*****************************************************************
     C                     Z-ADD0         W#PLT   30
TCHK1C*                    Z-ADD0         W#CON   30
TCHK1C                     Z-ADD0         W#CON   40
     C                     Z-ADD0         WPS#    60
     C                     MOVEL*BLANK    WWTG    9
     C                     MOVEL*BLANK    WWTT    9
     C                     MOVEL*BLANK    WWTN    9
     C                     Z-ADD0         TWTG    72
     C                     Z-ADD0         TWTT    72
     C                     Z-ADD0         TWTN    72
     C                     SETOF                     20
     C           KEY3      CHAINABF4P011             20
     C           *IN20     IFEQ '0'
     C           YBSKJY    IFEQ 'D'
     C           YBSKHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADDYB#PAL    W#PLT
     C                     ADD  W#PLT     @#PLT   30
     C                     Z-ADDYBCONT    W#CON
TCHK1C*                    ADD  W#CON     @#CON   30
TCHK1C                     ADD  W#CON     @#CON   40
     C                     Z-ADDYBPS#     WPS#
     C                     ADD  WPS#      @PS#    60
     C                     Z-ADDYBTARE    TWTT
     C                     ADD  TWTT      @WTT    72
     C                     Z-ADDYBWEIT    TWTN
     C                     ADD  TWTN      @WTN    72
     C           TWTT      ADD  TWTN      TWTG
     C                     ADD  TWTG      @WTG    72
      * TARE WEIGNT
     C                     Z-ADD2         PLEN
     C                     Z-ADDTWTT      PIN
     C                     MOVE *BLANK    POUT
     C                     CALL 'AB#R2N'  #CHG
     C                     MOVE POUT      WWTT
      * NET WEIGNT
     C                     Z-ADD2         PLEN
     C                     Z-ADDTWTN      PIN
     C                     MOVE *BLANK    POUT
     C                     CALL 'AB#R2N'  #CHG
     C                     MOVE POUT      WWTN
      * GROSS WEIGNT
     C                     Z-ADD2         PLEN
     C                     Z-ADDTWTG      PIN
     C                     MOVE *BLANK    POUT
     C                     CALL 'AB#R2N'  #CHG
     C                     MOVE POUT      WWTG
      *
     C                     END
     C                     END
     CSR         EJURYO    ENDSR
