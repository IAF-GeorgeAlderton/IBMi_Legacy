     C           #PRT1     BEGSR
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     EXCPT@HDR
     C                     ENDIF
      *
     C                     EXCPT@DTL1
      *
     C                     ENDSR
      *-----------------------------------------------------
      *
      *-----------------------------------------------------
     C           #PRT2     BEGSR
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     EXCPT@HDR
     C                     ENDIF
      *
     C                     EXCPT@DTL2
     C                     ENDSR
      *-----------------------------------------------------
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** CUSTOMER GROUP M.'
     O                                   60 ' UPDATE RESULT **   '
     O                         UDATE     80 '  .  .  '
     O                         @TIME     90 '  :  :  '
     O                         #USER    102
     O        E   03           @HDR
     O                                    7 'GRP'
     O                                   12 'NONY'
     O                                   17 ' NUM'
     O                                   20 'ST'
     O                                   24 'CNT'
     O        E 1              @DTL1
     O                                    3 'BFR'
     O                         S4GRP   +  1
     O                         E4NONY  +  1
     O                         S4NNY2  +  1
     O                         S4STCD  +  1
     O                         S4CNT   +  1
     O        E 1              @DTL1
     O                                    3 'AFT'
     O                         E4GRP   +  1
     O                         E4NONY  +  1
     O                         E4NNY2  +  1
     O                         E4STCD  +  1
     O                         E4CNT   +  1
     O        E 1              @DTL1
     O                                    1 '*'
     O        E 1              @DTL2
     O                                    3 'ADD'
     O                         E4GRP   +  1
     O                         E4NONY  +  1
     O                         E4NNY2  +  1
     O                         E4STCD  +  1
     O                         E4CNT   +  1
     O        E 1              @DTL2
     O                                    1 '*'
