     H            Y,
      *** EDIR43 ************************************************
      * UPDATE ADDRESS MASTER BY AB#PL1D (TOYOTA)               *
      * J.WATANABE 2017.09.06                                   *
      ***********************************************************
     FAB#PL75BIF  E           K        DISK
     FEDIPP42 UF  E           K        DISK                      A
     FQPRINT  O   F     198     OF     PRINTER
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ***********************************************************
      * TOYOTA  (CUST=3411)
     C                     EXSR #TYT
      * SUBARU  (CUST=3611)
     C                     EXSR #SBR
      * VW      (CUST=8450/8520)
     C                     EXSR #VW
      * HITACHI (CUST=5810)
     C                     EXSR #HTC
      *
     C                     SETON                     LR
     C                     RETRN
      *============================================
      * TOYOTA (CUST=3411)
      *============================================
     C           #TYT      BEGSR
     C                     MOVE 'Y'       FIRST   1
     C                     TIME           @TIME   60
      *
     C           3411      SETLLAB#PL75B
     C                     MOVE *OFF      *IN98
     C           *IN98     DOWEQ*OFF
     C           3411      READEAB#PL75B                 98
     C           *IN98     IFEQ *OFF
     C           PUNONY    ANDNE0
     C           PUSKJY    ANDNE'D'
     C           PUNONY    ANDNESVNONY
      * CHAIN
     C                     MOVELPUNONY    LTR4    4
     C           LTR4      CHAINEDIPP42              99
     C           *IN99     IFEQ *OFF
     C                     MOVE 'N'       UPDFLG  1
      * SET DELEIVERY (NUMERIC)
     C                     MOVELPUNONY    NUM4    40
     C           NUM4      IFNE E4NNY2
     C                     MOVE 'Y'       UPDFLG
     C                     MOVELE4NNY2    S4NNY2  40
     C                     MOVELPUNONY    E4NNY2
     C                     ENDIF
      *
     C                     MOVELE4STCD    S4STCD  2
      * IF COUNTRY<>'USA'
     C           E4CNT     IFNE 'USA'
     C           E4STCD    ANDNE' '
     C                     MOVE 'Y'       UPDFLG
     C                     MOVELE4STCD    S4STCD
     C                     MOVEL'  '      E4STCD
     C                     ENDIF
      *
     C                     MOVELE4CNT     S4CNT   3
      * IF COUTRY='US '
     C           E4CNT     IFEQ 'US '
     C                     MOVE 'Y'       UPDFLG
     C                     MOVELE4CNT     S4CNT
     C                     MOVEL'USA'     E4CNT
     C                     ENDIF
      * IF COUNTRY<>'MX '
     C           E4CNT     IFEQ 'MX '
     C                     MOVE 'Y'       UPDFLG
     C                     MOVELE4CNT     S4CNT
     C                     MOVEL'MEX'     E4CNT
     C                     ENDIF
      *
 **  C           E4GRP     IFNE 'TYT'
     C                     MOVE 'Y'       UPDFLG
     C                     MOVELE4GRP     S4GRP   3
 **  C                     MOVEL'TYT'     E4GRP
     C                     ENDIF
      *
     C           UPDFLG    IFEQ 'Y'
     C                     MOVEL'BATCH43' E4KOPG
     C                     UPDATEDIPP421
     C                     EXSR #PRT1
     C                     ENDIF
      *
     C                     MOVELPUNONY    SVNONY  40
     C                     ITER
     C                     ENDIF
      *
     C           *IN99     IFEQ *ON
     C                     CLEAREDIPP421
     C                     MOVELPUNONY    E4NONY
     C                     MOVELPUNONY    E4NNY2
     C                     MOVE *BLANK    E4STCD
 **  C                     MOVEL'TYT'     E4GRP
     C                     MOVE *BLANK    E4CNT
     C                     Z-ADD*DATE     E4CRHZ
     C                     TIME           E4CRTM
     C                     MOVEL#USER     E4CRME
     C                     MOVEL'EDIR43  'E4CRPG
     C                     WRITEEDIPP421
     C                     EXSR #PRT2
     C                     MOVELPUNONY    SVNONY  40
     C                     ITER
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *============================================
