     H            Y.
      ** GDMR060 *******************************************
      *  ASJ WASHER PARTS ORDER ADJUSTMENT FILE UPDATE     *
      *                                                    *
      * TCHK1 11/11/10 CREATE                              *
      ******************************************************
     FGDMPW060CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL010
     F                                              KINFDS @INFDS
     FGDMPL10 IF  E           K        DISK
     FGDMPL60 UF  E           K        DISK                      A
     FAKBPL07 IF  E           K        DISK
      *---------------------------------------------------
     E                    ERR     1  15 60
      *---------------------------------------------------
     I@INFDS      DS
     I                                     *STATUS  @STTS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME(6) + DATE(8)
     I            DS
     I                                        1  140WWTIME
     I                                        1   60WTIME
     I                                        1   40WTIM4
     I                                        7  120WSDATE
     I                                        9  120@@YM4
     I                                        7  120@@YM6
     I                                        7  140@@YMD
     I                                        7  100@@YY
     I                                       11  120@@MM
     I                                       13  140@@DD
     I            DS
     I                                        1  14 W@SHIN
     I                                        1   5 W@SHN1
     I                                        6   6 W@SHNA
     I                                        7  11 W@SHN2
     I                                       12  12 W@SHNB
     I                                       13  14 W@SHN3
      * ----------------------------------------------------
     C                     TIME           WWTIME
      ******************************************************
      *  MAIN
      ******************************************************
     C*
     C                     EXSR @S1INT
     C                     EXSR @S1SET
      *
     C                     DO   *HIVAL
      *
     C                     WRITEFMT090
     C                     Z-ADDW#RCN1    #RCN01
     C                     EXFMTCTL010
     C   KA                LEAVE
      *
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RCN1
     C                     END
      *
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      W#P1ER  1
      * add new
     C           *INKH     IFEQ *ON
     C                     EXSR @S2ADD
     C   KA                LEAVE
     C   KL                ITER
     C                     EXSR @S1INT
     C                     EXSR @S1SET
     C                     ITER
     C                     END
      * change
     C                     EXSR @S2CHG
     C   KA                LEAVE
     C   KL                ITER
     C                     EXSR @S1INT
     C                     EXSR @S1SET
     C                     ITER
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C*----------------------------------------------------*
      *  1ST SCREEN INITIALIZE
     C*----------------------------------------------------*
     C           @S1INT    BEGSR
      *
     C                     MOVEL*ON       *IN41
     C                     WRITECTL010
     C                     MOVEL*OFF      *IN41
      *
     C                     Z-ADD1         W#RCN1  40
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  SET LOT MANAGEMENT
     C*----------------------------------------------------*
     C           @S1SET    BEGSR
      *
     C                     Z-ADD*ZERO     RRN1    40
     C           *LOVAL    SETLLGDMPL60
      *
     C                     DO   *HIVAL
      *
     C                     READ GDMPL60             N    98
     C   98                LEAVE
     C           M6SKJY    IFNE *BLANK
     C                     ITER
     C                     END
      *
     C                     CLEARSFL010
     C*
     C                     MOVEL*BLANK    W@SHIN
     C                     MOVELM6PRT1    W@SHN1
     C           W@SHN2    IFNE *BLANK
     C                     MOVEL'-'       W@SHNA
     C                     END
     C                     MOVELM6PRT2    W@SHN2
     C           W@SHN3    IFNE *BLANK
     C                     MOVEL'-'       W@SHNB
     C                     END
     C                     MOVELM6PRT3    W@SHN3
     C                     MOVELW@SHIN    S1SHIN
     C                     MOVELM6PRT1    H1SHN1
     C                     MOVELM6PRT2    H1SHN2
     C                     MOVELM6PRT3    H1SHN3
     C*
     C                     Z-ADDM6ADJ#    S1MAIS
     C*
     C           K#L10     KLIST
     C                     KFLD           M6PRT1
     C                     KFLD           M6PRT2
     C                     KFLD           M6PRT3
     C           K#L10     CHAINGDMPL10              96
     C           *IN96     IFEQ *OFF
     C           M1SKJY    ANDEQ*BLANK
     C                     Z-ADDM1CHGD    S1CHGD
     C                     Z-ADDM1LOTN    S1LOTN
     C                     Z-ADDM1LOTO    S1LOTO
     C                     END
     C*
     C                     ADD  1         RRN1
     C                     WRITESFL010
     C*
     C                     ENDDO
     C*
     C           RRN1      IFEQ *ZERO
     C                     CLEARSFL010
     C                     Z-ADD1         RRN1
     C                     MOVEL*ON       *IN31
     C                     WRITESFL010
     C                     MOVEL*ON       *IN69
     C                     MOVELERR,1     MSG
     C                     MOVEL*OFF      *IN31
     C                     END
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  ADD NEW RECORD
     C*----------------------------------------------------*
     C           @S2ADD    BEGSR
      *
     C                     EXSR @S2INT
     C                     MOVEL'    ADD' F2ACTN    P
      *
     C                     DO   *HIVAL
      *
     C                     EXFMTFMT020
     C   KA                LEAVE
     C           *INKL     IFEQ *ON
     C                     MOVEL*OFF      *IN69
     C                     MOVEL*BLANK    MSG
     C                     LEAVE
     C                     END
      *
     C                     MOVEL*OFF      *IN69
     C                     MOVEL*ON       W@NEWF  1
     C                     EXSR @S2CHK
     C           *IN69     IFEQ *OFF
     C           *INKE     IFEQ *ON
     C                     EXSR @ADDF
     C           *IN69     IFEQ *OFF
     C                     LEAVE
     C                     END
     C                     END
     C                     END
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  INITIAL SET TO FMT020
     C*----------------------------------------------------*
     C           @S2INT    BEGSR
      *
     C                     SETOF                     515263
     C                     SETOF                     616269
      *
     C                     MOVEL*BLANK    F2SHN1
     C                     MOVEL*BLANK    F2SHN2
     C                     MOVEL*BLANK    F2SHN3
     C                     Z-ADD*ZERO     F2MAIS
     C                     Z-ADD*ZERO     F2CHGD
     C                     Z-ADD*ZERO     F2LOTN
     C                     Z-ADD*ZERO     F2LOTO
      *
     C                     MOVEL*BLANK    MSG
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  CHECK FMT020
     C*----------------------------------------------------*
     C           @S2CHK    BEGSR
      *
     C                     SETOF                     5152
     C                     MOVEL*BLANK    MSG
      *
     C                     DO
      *
     C           F2SHN1    IFEQ *BLANK
     C           F2SHN2    OREQ *BLANK
     C                     SETON                     5169
     C                     MOVELERR,2     MSG
     C                     LEAVE
     C                     END
      *
     C           K#KEY     KLIST
     C                     KFLD           F2SHN1
     C                     KFLD           F2SHN2
     C                     KFLD           F2SHN3
     C           K#KEY     SETGTAKBPL07
     C                     DO   *HIVAL
     C           K#KEY     REDPEAKBPL07                  97
     C   97                LEAVE
     C           L1SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           L1UKHZ    IFGT @@YMD
     C                     ITER
     C                     END
     C           L1STHZ    IFLE @@YMD
     C                     ITER
     C                     END
     C           L1BMON    IFNE 8990
     C                     ITER
     C                     END
     C                     LEAVE
     C                     ENDDO
     C*
     C           *IN97     IFEQ *ON
     C                     SETON                     5169
     C                     MOVELERR,3     MSG
     C                     LEAVE
     C                     END
     C*
     C           W@NEWF    IFEQ *ON
     C           K#KEY     CHAINGDMPL60              97
     C           *IN97     IFEQ *OFF
     C           M6SKJY    ANDEQ*BLANK
     C                     SETON                     5169
     C                     MOVELERR,4     MSG
     C                     LEAVE
     C                     END
     C                     END
     C*
     C           *INKE     IFEQ *ON
     C           F2MAIS    IFEQ *ZERO
     C                     SETON                     5269
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,5     MSG
     C                     END
     C                     LEAVE
     C                     END
     C                     END
     C*
     C           K#KEY     CHAINGDMPL10              96
     C           *IN96     IFEQ *ON
     C           M1SKJY    ORNE *BLANK
     C                     Z-ADD*ZERO     F2CHGD
     C                     Z-ADD*ZERO     F2LOTN
     C                     Z-ADD*ZERO     F2LOTO
     C                     SETON                     5169
     C                     MOVELERR,7     MSG
     C                     ELSE
     C                     Z-ADDM1CHGD    F2CHGD
     C                     Z-ADDM1LOTN    F2LOTN
     C                     Z-ADDM1LOTO    F2LOTO
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  WRITE NEW RECORD
     C*----------------------------------------------------*
     C           @ADDF     BEGSR
      *
     C                     DO
      *
     C           K#KEY     CHAINGDMPL60              98
     C           *IN98     IFEQ *OFF
     C           M6SKJY    ANDEQ*BLANK
     C                     SETON                     515269
     C                     MOVELERR,6     MSG
     C                     LEAVE
     C                     END
     C*
     C                     CLEARGDMPP601
     C*
     C                     EXSR @EDTF
      *
     C           *IN98     IFEQ *OFF
     C                     UPDATGDMPP601
     C                     ELSE
     C                     WRITEGDMPP601
     C                     END
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  EDIT RECORD (NEW/CHANGE)
     C*----------------------------------------------------*
     C           @EDTF     BEGSR
     C*
     C                     TIME           WWTIME
     C                     Z-ADD@@YMD     M6KODT
     C                     Z-ADDWTIM4     M6KOTM
     C                     MOVEL#PGM      M6KOPG
     C                     MOVEL#WSID     M6KOWS
     C                     MOVEL#USER     M6KOID
     C*
     C                     MOVELF2SHN1    M6PRT1
     C                     MOVELF2SHN2    M6PRT2
     C                     MOVELF2SHN3    M6PRT3
     C                     Z-ADDF2MAIS    M6ADJ#
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  CHANGE/DELETE MAIN
     C*----------------------------------------------------*
     C           @S2CHG    BEGSR
      *
     C                     Z-ADD*ZERO     RRN1
      *
     C                     DO   *HIVAL
      *
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL010               98
     C   98                LEAVE
     C           S1SEL     IFEQ *BLANK
     C                     ITER
     C                     END
      *
     C                     EXSR @S2CDP
     C   KA                LEAVE
      *
     C                     MOVEL*BLANK    S1SEL
     C                     MOVEL*ON       *IN32
     C                     UPDATSFL010
     C                     MOVEL*OFF      *IN32
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  CHANGE/DELETE SET
     C*----------------------------------------------------*
     C           @S2CDP    BEGSR
      *
     C                     EXSR @S2INT
     C           S1SEL     IFEQ 'C'
     C                     MOVEL'  CHANGE'F2ACTN    P
     C                     MOVEL*ON       *IN61
     C                     ELSE
     C                     MOVEL'  DELETE'F2ACTN    P
     C                     MOVEL*ON       *IN62
     C                     MOVEL*ON       *IN63
     C                     END
     C                     MOVELH1SHN1    F2SHN1
     C                     MOVELH1SHN2    F2SHN2
     C                     MOVELH1SHN3    F2SHN3
     C                     Z-ADDS1MAIS    F2MAIS
     C                     Z-ADDS1CHGD    F2CHGD
     C                     Z-ADDS1LOTN    F2LOTN
     C                     Z-ADDS1LOTO    F2LOTO
      *
     C                     DO   *HIVAL
      *
     C                     EXFMTFMT020
     C   KA                LEAVE
     C           *INKL     IFEQ *ON
     C                     MOVEL*OFF      *IN69
     C                     MOVEL*BLANK    MSG
     C                     LEAVE
     C                     END
      *
     C                     MOVEL*OFF      *IN69
     C           S1SEL     IFEQ 'C'
     C                     MOVEL*OFF      W@NEWF
     C                     EXSR @S2CHK
     C                     END
     C           *IN69     IFEQ *OFF
     C           *INKE     IFEQ *ON
     C                     EXSR @CHGF
     C           *IN69     IFEQ *OFF
     C                     LEAVE
     C                     END
     C                     END
     C                     END
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  UPDAT
     C*----------------------------------------------------*
     C           @CHGF     BEGSR
      *
     C                     DO
      *
     C           K#KEY     CHAINGDMPL60              98
     C           *IN98     IFEQ *ON
     C                     LEAVE
     C                     END
      *
     C           S1SEL     IFEQ 'D'
     C                     TIME           WWTIME
     C                     MOVEL'D'       M6SKJY
     C                     Z-ADD@@YMD     M6SKDT
     C                     Z-ADDWTIM4     M6SKTM
     C                     MOVEL#PGM      M6SKPG
     C                     MOVEL#WSID     M6SKWS
     C                     MOVEL#USER     M6SKID
     C                     ELSE
     C                     EXSR @EDTF
     C                     END
      *
     C                     UPDATGDMPP601
      *
     C                     ENDDO
      *
     C                     ENDSR
