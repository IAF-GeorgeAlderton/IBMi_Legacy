     H            Y.
     F** AB#R2N ***********************************************************
     F*  CONVERT NUMERIC -> CHARCTER(ZERO SUPPLESS&ADD COMMA              *
     F*  TCH 2000.10.30                                                   *
     F*                                                                   *
     F******************************************************* AB#R2K ******
     E                    IN         25  1 0
     E                    OUT        30  1
     E                    IN2         5  1 0
     F******************************************************************
     I*
     I            DS
     I                                        1  250IN
     I                                       26  300IN2
     I                                       26  30 WIN2
     I                                        1  305WPIN
     C           *ENTRY    PLIST
     C                     PARM           PIN    305
     C                     PARM           POUT   30
     C                     PARM           PLEN    20
      *
     C                     Z-ADDPIN       WPIN
     C                     Z-ADDPLEN      R       20
     C                     MOVE *BLANK    OUT
     C                     Z-ADD*ZERO     I       20
     C                     Z-ADD25        M       20
     C                     Z-ADD30        U       20
     C* INPUT = ZERO
     C           PIN       IFEQ *ZERO
     C                     MOVE *ZERO     OUT,30
     C                     GOTO #END
     C                     END
     C* SET DECIMAL
     C           WIN2      IFNE *ZERO
B01  C           1         DO   PLEN
     C                     MOVE IN2,R     OUT,U
     C                     SUB  1         U
     C                     SUB  1         R
E01  C                     END
     C*
     C                     MOVE '.'       OUT,U
     C                     SUB  1         U
     C                     END
     C* SET INTEGER
     C                     SETOF                     90
B01  C           *IN90     DOUEQ'1'
     C                     ADD  1         I
B02  C           I         IFGT 25
     C                     MOVE *ZERO     OUT,U
     C                     GOTO #END
E02  C                     END
     C*
     C           IN,I      IFNE *ZERO
     C                     SETON                     90
     C                     END
E01  C                     END
      *
     C                     Z-ADD*ZERO     A       30
B01  C           M         DOULTI
     C                     ADD  1         A
     C           A         IFEQ 4
     C                     MOVE ','       OUT,U
     C                     Z-ADD*ZERO     A
     C                     ELSE
     C                     MOVE IN,M      OUT,U
     C                     SUB  1         M
     C                     ENDIF
     C                     SUB  1         U
     C                     END
      *
     C           #END      TAG
     C                     MOVEAOUT       POUT
      *
     C                     SETON                     LR
     C                     RETRN
