     H            Y.
      **AB#R99A ********************************************
      * ASN STATUS INQUIRY                                 *
      *                                                    *
      * TCHK1 : 01/19/07 CREATE                            *
      * -----------------------                            *
JW1   * JW      2022.10.10 CREATE FRPM AB#R99              *
      ******************************************************
     FAB#PW99ACF  E                    WORKSTN
     F                                        RRN2  KSFILE SFL020
     F                                        RRN3  KSFILE SFL030
     F                                              KINFDS @INFDS
     FAB#PL75 IF  E           K        DISK
     FAB#PL1N IF  E           K        DISK
     FGADPL11 IF  E           K        DISK
     FAB#PP98 IF  E           K        DISK
      *---------------------------------------------------
     E                    ERR     1  10 70
      *---------------------------------------------------
     I@INFDS      DS
     I                                     *STATUS  @STTS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME(6) + DATE(6)
     I            DS
     I                                        1  140STIME
     I                                        1   60NOW
     I                                        7  140TODAY
      * SHIP DATE(FROM)
     I            DS
     I                                        1   80F1SHF
     I                                        1   40F1SHFY
     I                                        5   60F1SHFM
     I                                        7   80F1SHFD
      * SHIP DATE(TO)
     I            DS
     I                                        1   80F1SHT
     I                                        1   40F1SHTY
     I                                        5   60F1SHTM
     I                                        7   80F1SHTD
      * SHIP DATE(KEY)
     I            DS
     I                                        1   80K@SHDT
     I                                        1   40K@SHYY
     I                                        5   60K@SHMM
     I                                        7   80K@SHDD
      * SHIP DATE(AB#PL75)
     I            DS
     I                                        1   80PUNODT
     I                                        1   40PUNOYY
     I                                        5   60PUNOMM
     I                                        7   80PUNODD
      * SHIP-TO DATE(SCREEN SELECT CONDITION)
     I            DS
     I                                        1   80W@TODT
     I                                        1   40W@SHTY
     I                                        5   60W@SHTM
     I                                        7   80W@SHTD
      *
     I            DS
     I                                        1  15 W3MHIN
     I                                        1   5 W3MHI1
     I                                        6  10 W3MHI2
     I                                       11  15 W3MHI3
      *
     I            DS
     I                                        1  12 W3SHIN
     I                                        1   5 W3SHI1
     I                                        6  10 W3SHI2
     I                                       11  12 W3SHI3
      *
     I            DS
     I                                        1   80W3SHDT
     I                                        1   40W3SHYY
     I                                        5   60W3SHMM
     I                                        7   80W3SHDD
     C******************************************************
     C*  MAIN
     C******************************************************
     C*
     C                     EXSR #INT
     C*
     C                     EXSR #F1RTN
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C******************************************************
     C*  1ST SCREEN
     C******************************************************
     C           #F1RTN    BEGSR
     C*
     C                     DO   *HIVAL
     C*
     C                     MOVEL*OFF      *IN88
     C                     MOVEL*OFF      *IN87
     C                     WRITEFMT099
     C                     EXFMTFMT010
     C   KA                LEAVE
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     313233
     C                     SETOF                     85
     C*
     C                     EXSR #CHK1
     C           *IN85     IFEQ *ON
     C                     ITER
     C                     END
     C*
     C                     EXSR #F2RTN
     C   KA                LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  SHIP DATE CHECK
     C******************************************************
     C           #CHK1     BEGSR
     C* SHIP DATE FROM
     C           F1SHF     IFEQ 0
     C                     MOVELERR,1     MSG
     C                     SETON                     31  85
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     MOVELF1SHF     $SRC      P
     C                     CALL 'UTLR01'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE   8
     C                     PARM           $RTN1   1
     C           $RTN1     IFNE *BLANK
     C                     MOVELERR,2     MSG
     C                     SETON                     31  85
     C                     GOTO XCHK1
     C                     ENDIF
      * SHIP DATE TO
     C           F1SHT     IFEQ 0
     C                     Z-ADDF1SHF     F1SHT
     C                     ENDIF
      *
     C           F1SHT     IFEQ 0
     C                     MOVELERR,3     MSG
     C                     SETON                     32  85
     C                     GOTO XCHK1
     C                     END
      *
     C           F1SHTY    IFNE 9999
     C                     MOVELF1SHT     $SRC      P
     C                     CALL 'UTLR01'
     C                     PARM           $SRC
     C                     PARM           $TRUE
     C                     PARM           $RTN1
     C           $RTN1     IFNE *BLANK
     C                     MOVELERR,4     MSG
     C                     SETON                     32  85
     C                     GOTO XCHK1
     C                     ENDIF
     C                     ENDIF
      *
     C           F1SHF     IFGT F1SHT
     C                     MOVELERR,5     MSG
     C                     SETON                     313285
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           F1STS     IFNE 'Y'
     C           F1STS     ANDNE'N'
     C                     MOVELERR,7     MSG
     C                     SETON                     33  85
     C                     GOTO XCHK1
     C                     ENDIF
     C*
     C           XCHK1     ENDSR
     C******************************************************
     C*  2ND SCREEN
     C******************************************************
     C           #F2RTN    BEGSR
     C*
     C                     EXSR #F2SET
     C                     Z-ADD1         W#RNP2  40
     C*
     C                     DO   *HIVAL
     C*
     C                     MOVEL*ON       *IN88
     C                     MOVEL*ON       *IN87
     C                     WRITEFMT099
     C                     Z-ADDW#RNP2    #RCN02
     C                     EXFMTCTL020
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN85
     C   KA
     COR KL                LEAVE
     C*
     C  NKJ                MOVELN#MODE    *IN45
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP2
     C                     END
     C*
     C           *INKF     IFEQ *ON
     C           F1SHF     ORNE SVSHF
     C           F1SHT     ORNE SVSHT
     C           F1CUST    ORNE SVCUST
     C           F1NONY    ORNE SVNONY
     C           F1NUKE    ORNE SVNUKE
     C           F1BINN    ORNE SVBINN
     C           F1STS     ORNE SVSTS
     C                     EXSR #CHK1
     C   85                ITER
     C                     EXSR #F2SET
     C                     Z-ADD1         W#RNP2
     C                     ITER
     C                     END
     C*
     C                     EXSR #F3RTN
     C   KA                LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  SFL020 SET
     C******************************************************
     C           #F2SET    BEGSR
     C*
     C                     MOVEL*ON       *IN41
     C                     WRITECTL020
     C                     MOVEL*OFF      *IN41
     C                     MOVEL*OFF      *IN42
     C                     Z-ADD*ZERO     RRN2    40
     C*
     C                     MOVEL*OFF      *IN45
     C                     MOVEL*OFF      N#MODE
     C* SET SHP-TO DATE CONDITION
     C           F1SHTY    IFNE *ZERO
     C                     Z-ADDF1SHTY    W@SHTY
     C                     ELSE
     C                     Z-ADDF1SHFY    W@SHTY
     C                     END
     C           F1SHTM    IFNE *ZERO
     C                     Z-ADDF1SHTM    W@SHTM
     C                     ELSE
     C                     Z-ADDF1SHFM    W@SHTM
     C                     END
     C           F1SHTD    IFNE *ZERO
     C                     Z-ADDF1SHTD    W@SHTD
     C                     ELSE
     C                     Z-ADDF1SHFD    W@SHTD
     C           F1SHFD    IFEQ *ZERO
     C                     Z-ADD99        W@SHTD
     C                     END
     C                     END
     C*
     C           K#L75A    KLIST
     C                     KFLD           K@SHYY
     C                     KFLD           K@SHMM
     C                     KFLD           K@SHDD
     C           K#L75B    KLIST
     C                     KFLD           K@SHYY
     C                     KFLD           K@SHMM
     C                     Z-ADDF1SHFY    K@SHYY
     C                     Z-ADDF1SHFM    K@SHMM
     C                     Z-ADDF1SHFD    K@SHDD
     C           F1SHFD    IFEQ *ZERO
     C           K#L75B    SETLLAB#PL75
     C                     ELSE
     C           K#L75A    SETLLAB#PL75
     C                     END
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AB#PL75                  98
     C   98                LEAVE
     C           PUSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           PUNODT    IFGT W@TODT
     C                     LEAVE
     C                     END
     C*
     C           K#PP98    KLIST
     C                     KFLD           PUCUST
     C                     KFLD           PUNONY
     C           K#PP98    CHAINAB#PP98              97
     C   97                ITER
     C           P9SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C* CUST
     C           F1CUST    IFNE *ZERO
     C           F1CUST    IFNE PUCUST
     C                     ITER
     C                     END
     C                     END
     C* DELI
     C           F1NONY    IFNE *ZERO
     C           F1NONY    IFNE PUNONY
     C                     ITER
     C                     END
     C                     END
     C* DOCK
     C           F1NUKE    IFNE *BLANK
     C           F1NUKE    IFNE PUNUKE
     C                     ITER
     C                     END
     C                     END
     C* BIN#
     C           F1BINN    IFNE *ZERO
     C           F1BINN    IFNE PUBINN
     C                     ITER
     C                     END
     C                     END
     C* STATUS
     C           F1STS     IFEQ 'Y'
     C           PUASDT    IFEQ 0
     C                     ITER
     C                     END
     C                     END
     C*
     C           K#L1NA    KLIST
     C                     KFLD           PUNOYY
     C                     KFLD           PUNOMM
     C                     KFLD           PUNODD
     C                     KFLD           PUBINN
     C                     KFLD           PUCUST
     C                     KFLD           PUNONY
     C                     KFLD           PUNKOJ
     C                     KFLD           PUNUKE
     C           K#L1NA    SETLLAB#PL1N
     C                     DO   *HIVAL
     C           K#L1NA    READEAB#PL1N                  96
     C   96                LEAVE
     C           BASKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           PUODRN    IFNE *BLANK
     C           PUODRN    IFNE BAODRN
     C                     ITER
     C                     END
     C                     END
     C                     LEAVE
     C                     ENDDO
     C   96                ITER
     C*
     C* CREATE SUB-FILE
     C                     CLEARSFL020
     C*
     C                     MOVELPUCUST    S2CUST
     C                     MOVELPUNONY    S2NONY
     C                     MOVELPUNUKE    S2NUKE
     C                     Z-ADDPUBINN    S2BINN
     C                     MOVELPUSERL    S2SERL
     C                     Z-ADDPULPDT    S2LPDT
     C                     MOVELPUODRN    S2ODRN
     C                     Z-ADDPUASDT    S2ASDT
     C                     Z-ADDPUSPDT    S2SPDT
     C                     MOVELPUNKOJ    H2NKOJ
     C           K#GADP    KLIST
     C                     KFLD           PUCUST
     C                     KFLD           PUNONY
     C                     KFLD           PUNKOJ
     C                     KFLD           PUNUKE
     C           K#GADP    CHAINGADPL11              95
     C  N95                MOVELB5KMEI    S2SHNM
     C                     Z-ADDPUNODT    S2SHDT
     C*
     C           PUASDT    IFEQ *ZERO
     C                     MOVEL*ON       *IN52
     C                     ELSE
     C                     MOVEL*OFF      *IN52
     C                     END
     C*
     C                     MOVEL*ALL'-'   S2DUMY
     C*
     C                     ADD  1         RRN2
     C                     WRITESFL020
     C*
     C           RRN2      IFEQ 9999
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C           RRN2      IFEQ *ZERO
     C                     CLEARSFL020
     C                     Z-ADD1         RRN2
     C                     MOVEL*ON       *IN51
     C                     WRITESFL020
     C                     MOVEL*OFF      *IN51
     C                     MOVEL*ON       *IN85
     C                     MOVELERR,6     MSG
     C                     END
     C*
     C           RRN2      IFEQ 9999
     C                     MOVEL*ON       *IN85
     C                     MOVELERR,3     MSG
     C                     END
     C*
     C                     Z-ADDF1SHF     SVSHF
     C                     Z-ADDF1SHT     SVSHT
     C                     Z-ADDF1CUST    SVCUST
     C                     Z-ADDF1NONY    SVNONY
     C                     MOVELF1NUKE    SVNUKE
     C                     Z-ADDF1BINN    SVBINN
     C                     MOVELF1STS     SVSTS
     C*
     C                     ENDSR
     C******************************************************
     C*  #F3RTN
     C******************************************************
     C           #F3RTN    BEGSR
     C*
     C                     Z-ADD*ZERO     RRN2    40
     C*
     C                     DO   *HIVAL
     C*
     C                     ADD  1         RRN2
     C           RRN2      CHAINSFL020               94
     C   94                LEAVE
     C           S2SEL     IFEQ *BLANK
     C                     ITER
     C                     END
     C*
     C                     MOVEL*BLANK    S2SEL
     C           S2ASDT    IFEQ *ZERO
     C                     MOVEL*ON       *IN52
     C                     ELSE
     C                     MOVEL*OFF      *IN52
     C                     END
     C                     UPDATSFL020
     C*
     C                     EXSR #F3SET
     C                     Z-ADD1         W#RNP3  40
     C*
     C                     DO   *HIVAL
     C*
     C                     MOVEL*ON       *IN88
     C                     MOVEL*OFF      *IN87
     C                     WRITEFMT099
     C                     Z-ADDW#RNP3    #RCN03
     C                     EXFMTCTL030
      * F3/F12: BACK
     C   KA
     COR KL                LEAVE
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP3
     C                     END
     C*
     C                     ENDDO
      * F1: EXIT
     C   KA                LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  SFL030 SET
     C******************************************************
     C           #F3SET    BEGSR
     C*
     C                     MOVEL*ON       *IN61
     C                     WRITECTL030
     C                     MOVEL*OFF      *IN61
     C                     MOVEL*OFF      *IN62
     C                     Z-ADD*ZERO     RRN3    40
     C*
     C                     Z-ADDS2SHDT    C3SHDT
     C                     MOVELS2CUST    C3CUST
     C                     MOVELS2NONY    C3NONY
     C                     MOVELH2NKOJ    C3NKOJ
     C                     MOVELS2NUKE    C3NUKE
     C                     Z-ADDS2BINN    C3BINN
     C                     MOVELS2SHNM    C3SHNM
     C                     MOVELS2SERL    C3SERL
     C*
     C           K#L1NB    KLIST
     C                     KFLD           W3SHYY
     C                     KFLD           W3SHMM
     C                     KFLD           W3SHDD
     C                     KFLD           S2BINN
     C                     KFLD           K@CUST
     C                     KFLD           K@NONY
     C                     KFLD           H2NKOJ
     C                     KFLD           S2NUKE
     C                     Z-ADDS2SHDT    W3SHDT
     C                     MOVELS2CUST    K@CUST  40
     C                     MOVELS2NONY    K@NONY  40
     C           K#L1NB    SETLLAB#PL1N
     C*
     C                     DO   *HIVAL
     C           K#L1NB    READEAB#PL1N                  96
     C   96                LEAVE
     C           BASKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           S2ODRN    IFNE *BLANK
     C           S2ODRN    IFNE BAODRN
     C                     ITER
     C                     END
     C                     ELSE
     C           K#L75C    KLIST
     C                     KFLD           BANOYY
     C                     KFLD           BANOMM
     C                     KFLD           BANODD
     C                     KFLD           BATOKU
     C                     KFLD           BANONY
     C                     KFLD           BANKOJ
     C                     KFLD           BANUKE
     C                     KFLD           BANOBN
     C                     KFLD           BADEYY
     C                     KFLD           BADEMM
     C                     KFLD           BADEDD
     C                     KFLD           BAODRN
     C           K#L75C    CHAINAB#PL75              90
     C           *IN90     IFEQ *OFF
     C           PUSKJY    ANDEQ' '
     C                     ITER
     C                     END
     C                     END
     C*
     C* CREATE SUB-FILE
     C                     CLEARSFL030
     C*
     C                     MOVELBAMHN1    W3MHI1
     C                     MOVELBAMHN2    W3MHI2
     C                     MOVELBAMHN3    W3MHI3
     C                     MOVELW3MHIN    S3MHIN
     C                     MOVELBASHN1    W3SHI1
     C                     MOVELBASHN2    W3SHI2
     C                     MOVELBASHN3    W3SHI3
     C                     MOVELW3SHIN    S3SHIN
     C                     MOVELBASBAN    S3SBAN
     C           BAUSYS    IFNE *ZERO
     C                     Z-ADDBAUSYS    S3SYOS
     C                     ELSE
     C                     Z-ADDBASYOS    S3SYOS
     C                     END
     C                     Z-ADDBASRYO    S3SRYO
     C                     MOVELBAINVN    S3INVN
     C                     MOVELBAODRN    S3ODRN
     C*
     C                     ADD  1         RRN3
     C                     WRITESFL030
     C*
     C           RRN3      IFEQ 9999
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C           RRN3      IFEQ *ZERO
     C                     CLEARSFL030
     C                     Z-ADD1         RRN3
     C                     WRITESFL030
     C                     MOVEL*ON       *IN85
     C                     MOVELERR,6     MSG
     C                     END
     C*
     C           RRN2      IFEQ 9999
     C                     MOVEL*ON       *IN85
     C                     MOVELERR,3     MSG
     C                     END
     C*
     C                     ENDSR
     C******************************************************
     C*  INITTIAL SET
     C******************************************************
     C           #INT      BEGSR
     C*
     C                     TIME           STIME
     C*
     C                     Z-ADDTODAY     F1SHF
     C                     Z-ADD9999      F1SHTY
     C                     Z-ADD0         F1SHTM
     C                     Z-ADD0         F1SHTD
     C                     MOVEL*BLANK    F1NONY
     C                     MOVEL*BLANK    F1NUKE
     C                     Z-ADD0         F1BINN
     C                     MOVEL'Y'       F1STS
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN85
     C*
     C                     Z-ADD0         SVSHF   80
     C                     Z-ADD*ZERO     SVSHT   80
     C                     Z-ADD*ZERO     SVCUST  40
     C                     Z-ADD*ZERO     SVNONY  40
     C                     MOVEL*BLANK    SVNUKE  4
     C                     Z-ADD*ZERO     SVBINN  20
     C                     MOVEL*BLANK    SVSTS   1
     C*
     C                     ENDSR
** ERR(70A) .......2.........3.........4.........5.........6.........7
ENTER SHIP DATE (FROM)!                                                 01
SHIP DATE (FROM) IS INVALID!                                            02
ENTER SHIP DATE (TO)!                                                   03
SHIP DATE (TO) IS INVALID!                                              04
SHIP (FROM) IS GRAETER THAN SHIP (TO)!                                  05
NO DATA FOUND!                                                          06
ASN FLAG SHOULD BE Y OR N!                                              07
