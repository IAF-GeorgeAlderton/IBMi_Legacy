     C**************************************************************************
     C*                    MAIN ROUTINE
     C**************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C           @@ID      CASEQ'02'      #SCRN2
     C           @@ID      CASEQ'03'      #SCRN3
     C           @@ID      CASEQ'04'      #SCRN4
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C**************************************************************************
     C*         INITIALIZE
     C**************************************************************************
     C           *INZSR    BEGSR
      *
     C           P#BRC     PLIST
     C                     PARM           PMAREA100
     C                     PARM           PMBYTE  3
     C                     PARM           PMCHK   1
     C                     PARM           PMRTCD  1
     C           K#AP11    KLIST
     C                     KFLD           WWZETI
     C                     KFLD           WWORDR
      *
     C           K#KEY     KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C           K#ABB     KLIST
     C                     KFLD           K@DATE  80
     C                     KFLD           WBAR
     C           K#ABH     KLIST
     C                     KFLD           K@FCT   40
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C           K#ABHX    KLIST
     C                     KFLD           K@FCT   40
     C                     KFLD           W@CPR1
     C                     KFLD           W@CPR2
     C                     KFLD           W@CPR3
     C           K#AGD     KLIST
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C                     KFLD           K@DD    20
      *
     C                     Z-ADD*YEAR     K@YY
     C                     Z-ADD*MONTH    K@MM
     C                     Z-ADD*DAY      K@DD
     C                     Z-ADD*ZERO     @@CNT   20
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C                     ADD  1         @@CNT
     C           @@CNT     IFEQ 7
     C                     Z-ADDF8YMD     @YMDB   80
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD*DATE     K@DATE
     C                     Z-ADD0111      K@FCT
      *
     C                     MOVE '01'      @@ID    2
     C                     MOVE 'A'       @@K     1
     C*
     C                     ENDSR
     C*************************************************************************
     C*          IST SCREEN
     C**************************************************************************
     C           #SCRN1    BEGSR
      *
     C           @@K       IFEQ 'A'
     C                     MOVE KEY,1     D@KEY
     C                     MOVE TTL,1     D@TTL
     C                     ELSE
     C                     MOVE KEY,2     D@KEY
     C                     MOVE TTL,2     D@TTL
     C                     ENDIF
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKG     WHEQ *ON
     C                     MOVE '03'      @@ID
     C           *INKE     WHEQ *ON
     C           @@K       IFEQ 'A'
     C                     MOVE 'P'       @@K
     C                     ELSE
     C                     MOVE 'A'       @@K
     C                     ENDIF
      *
     C           *INKD     WHEQ *ON
     C           @@BRCD    IFEQ *BLANK
     C                     MOVE *ON       *IN99
     C                     MOVELERR,5     ERR1
     C                     EXFMTERR01
     C                     ELSE
     C                     MOVE '02'      @@ID
     C                     MOVEL@@BRCD    D@KNBN
     C********             Z-ADD@@NBRS    D@NBRS
     C                     Z-ADD*ZERO     D@NBRS
     C                     Z-ADD@@LOT     D@LOT
     C           @@LOT     COMP *ZERO                1111
     C                     ENDIF
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #WRT
     C                     CLEARDSP01
     C                     ELSE
     C                     EXFMTERR01
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
     C**************************************************************************
     C*     CHECK
     C**************************************************************************
     C           #CHK1     BEGSR
     C*
     C                     MOVE *BLANK    ERR1                         F5
     C                     MOVE *BLANK    ERR2                         F5
     C                     SETOF                     996162
      *
     C           D@KNBN    IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     ERR1
     C                     ELSE
      *
     C                     MOVE D@KNBN    WBAR
     C           WWZETI    CHAINFCETL11              90
B01  C           *IN90     IFEQ *ON
     C                     SETON                     9961
     C                     MOVELERR,1     ERR1
     C                     ENDIF
      *
     C           K#ABB     CHAINABBPL72              90
     C           *IN90     IFEQ *OFF
     C                     SETON                     9961
     C                     MOVELERR,2     ERR1
     C                     MOVELERR,3     ERR2
     C                     ENDIF
      * CHECK DIGIT
     C                     MOVELWBAR      PMAREA    P
     C                     MOVE '014'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'  P#BRC
     C           PMRTCD    IFNE *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     ERR1
     C                     ELSE
     C           PMCHK     IFNE WWCHK
     C                     SETON                     9961
     C                     MOVELERR,1     ERR1
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C                     SELEC
     C           WWKANS    WHGE '0'
     C           WWKANS    ANDLE'9'
      *
     C                     Z-ADD1         D@NBRS
     C                     Z-ADD*ZERO     W@ISDT  80
      * LOCATION
     C           K#KEY     CHAINAAMPL11              90
     C                     Z-ADD1         X       20
     C           WWPROC    LOKUPPRC,X                    10
     C           *IN10     IFEQ *OFF
     C                     MOVE ' '       WWPROC
     C           WWPROC    LOKUPPRC,X                    10
     C                     ENDIF
      *
     C                     DO   *HIVAL
     C                     SUB  1         X
     C           X         IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
      *
     C           LOC,X     IFEQ '------'
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #CMT
      *
     C                     LEAVE
     C                     ENDDO
      *
     C                     SELEC
     C           WWPROC    WHEQ 'LAN'
     C                     MOVE 'L'       W@KID
     C           WWPROC    WHEQ 'RL '
     C                     MOVE 'R'       W@KID
     C           WWPROC    WHEQ 'RT '
     C           WWPROC    OREQ 'SK '
     C                     MOVE 'R'       W@KID
     C           WWID      WHEQ 'B'
     C                     MOVE 'Q'       W@KID
     C           WWPROC    WHEQ 'AOQ'
     C                     MOVE '1'       W@KID
     C           WWPROC    WHEQ 'RRT'
     C                     MOVE '2'       W@KID
     C           WWPROC    WHEQ 'SB '
     C                     MOVE 'S'       W@KID
     C           WWPROC    WHEQ 'KRO'
     C                     MOVE 'K'       W@KID
     C           WWPROC    WHEQ 'FRL'
     C                     MOVE 'F'       W@KID
     C           WWPROC    WHEQ 'BZ '
     C                     MOVE 'Z'       W@KID
     C           WWPROC    WHEQ 'YLS'
     C                     MOVE 'Y'       W@KID
     C           WWPROC    WHEQ 'HN '
     C                     MOVE 'H'       W@KID
     C                     OTHER
7    C                     SETON                     9961
     C                     MOVELERR,1     ERR1
     C                     ENDSL
      *
      *
     C                     OTHER
      *
      ** PLATING OR APICS?
     C*          WWORDR    IFEQ '999'
     C*          *IN90     ANDEQ*OFF
     C*                    MOVE '04'      @@ID
     C*                    ELSE
      * PLASTIC
     C           @@K       IFEQ 'P'
     C                     EXSR #PLC
      *
     C                     ELSE
      * APICS
     C                     EXSR #APC
      *
     C                     ENDIF
     C******               ENDIF
      *
     C                     ENDSL
      *
     C                     ENDIF
     C                     ENDIF
     C*
     C                     ENDSR
      *----------------------------------------------
     C           #PLC      BEGSR
      *----------------------------------------------
     C                     MOVE 'P'       W@KID   1
     C                     Z-ADD4         D@NBRS
     C                     Z-ADD*ZERO     W@ISDT  80
      *
     C           K#KEY     CHAINAAMPL11              90
     C                     Z-ADD1         X       20
     C           'C'       LOKUPKK,X                     10
     C* N10                Z-ADD1         X       20
     C* N10      'DCF'     LOKUPPRC,X                    10
      *
     C           *IN10     IFEQ *OFF
7    C                     SETON                     9961
     C                     MOVELERR,4     ERR1
     C                     ELSE
      *
     C                     DO   *HIVAL
     C                     SUB  1         X
     C           X         IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
      *
     C           LOC,X     IFEQ '------'
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #CMT
      *
     C                     LEAVE
     C                     ENDDO
      *
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------
     C           #APC      BEGSR
      *----------------------------------------------
     C           K#AP11    CHAINAH#PL11              90
     C           *IN90     IFEQ *OFF
     C           CFSKJY    ANDEQ'D'
     C                     MOVE *ON       *IN90
     C                     ENDIF
      *
     C   90      K#AP11    CHAINAFAPP60              90
      *
     C           *IN90     IFEQ *ON
7    C                     SETON                     9961
     C                     MOVELERR,5     ERR1
     C                     ELSE
      *
     C           K#AP11    CHAINAH#PL11              90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDCFMAIS    D@NBRS
     C                     Z-ADDCFHTHZ    W@ISDT  80
     C                     ELSE
     C           K#AP11    CHAINAFAPP60              90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDAACOPY    D@NBRS
     C                     Z-ADDAAYMD     W@ISDT
     C                     ENDIF
     C                     ENDIF
      *
     C***        D@NBRS    IFEQ *ZERO
     C                     Z-ADD4         D@NBRS
     C***                  ENDIF
      *
     C                     MOVE 'A'       W@KID
     C           K#KEY     CHAINAGAPL31              90
     C           K#KEY     CHAINAAMPL11              90
     C                     Z-ADD1         X       20
     C           CBKDAI    LOKUPKK,X                     10
     C           *IN10     IFEQ *OFF
7    C                     SETON                     9961
     C                     MOVELERR,5     ERR1
     C                     ELSE
     C                     DO   *HIVAL
     C                     SUB  1         X
     C           X         IFEQ *ZERO
     C                     LEAVE
     C                     ENDIF
      *
     C           LOC,X     IFEQ '------'
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #CMT
      *
     C                     LEAVE
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------
     C           #CMT      BEGSR
      *----------------------------------------------
     C                     MOVEL*BLANK    W@MCHN  3
     C                     MOVELLOC,X     W@LOCT
     C                     MOVELMCN,X     W@MCHN
     C                     MOVE PRT,X     W@CPRT 12
     C           W@LL      IFEQ 'H'
     C********             MOVELMCN,1     W@MCHN  3
     C                     MOVE *BLANK    W@CMNT 20
     C                     ELSE
     C                     EXSR #MCN
      *
     C                     MOVEA@LC       W@CMNT
     C**                   Z-ADD1         W       20
     C**         'RL '     LOKUPPRC,W                    10
     C** 10                MOVE MCN,W     W@MCHN
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*    2ND SCREEN
     C**************************************************************************
     C           #SCRN2    BEGSR
      *
     C                     EXFMTDSP02
      *
     C           *INKC     IFEQ *ON
     C                     MOVE '99'      @@ID
     C                     ELSE
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C                     EXSR #UPD
     C                     CLEARDSP01
     C                     MOVE '01'      @@ID
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*     CHECK
     C**************************************************************************
     C           #CHK2     BEGSR
     C*
     C                     MOVE *BLANK    ERR1                         F5
     C                     SETOF                     996162
      *
     C           D@NBRS    IFEQ *ZERO
     C                     ADD  1         D@NBRS
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*     UPDAT
     C**************************************************************************
     C           #UPD      BEGSR
      *
     C                     MOVE D@KNBN    WBAR
      *
     C           K#ABB     CHAINABBPL72              90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDD@NBRS    A7KQTY
     C                     UPDATABBPP701
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*    4TH SCREEN
     C**************************************************************************
     C           #SCRN4    BEGSR
      *
     C                     EXFMTDSP04
      *
     C           *INKC     IFEQ *ON
     C                     MOVE '99'      @@ID
     C                     ELSE
     C                     EXSR #CHK4
     C           *IN99     IFEQ *OFF
     C                     EXSR #WRT
     C                     CLEARDSP01
     C                     MOVE '01'      @@ID
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*     CHECK
     C**************************************************************************
     C           #CHK4     BEGSR
     C*
     C                     MOVE *BLANK    ERR1                         F5
     C                     SETOF                     996162
      *
     C           D@KKID    IFNE *BLANK
     C           D@KKID    ANDNE'P'
     C                     SETON                     9961
     C                     ELSE
     C           D@KKID    IFEQ *BLANK
     C                     EXSR #APC
     C                     ELSE
     C                     EXSR #PLC
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*       LOCATION, MACHINE
     C**************************************************************************
     C           #MCN      BEGSR
     C*
     C                     MOVE *BLANK    @LC
     C                     Z-ADD*ZERO     Y       20
     C           1         DO   15        X
     C           1         SUBSTLOC,X:2   @@LL    1
     C           LOC,X     IFNE *BLANK
     C           LOC,X     ANDNEW@LOCT
     C           @@LL      ANDGE'A'
     C           @@LL      ANDLE'Z'
     C           @@LL      ANDNE'P'
     C                     ADD  1         Y
     C           4         SUBSTLOC,X:2   @LC,Y
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C**************************************************************************
     C*       WRITE A RECORD
     C**************************************************************************
     C           #WRT      BEGSR
     C*
     C                     CLEARABBPP701
     C                     Z-ADD*DATE     A7DATE
     C                     TIME           A7TIME
     C                     MOVEL#USER     A7USER
     C                     MOVEL#WSID     A7WSID
     C                     MOVEL#PGM      A7PGID
     C                     MOVELD@KNBN    A7BRCD
     C                     MOVELA2BHB1    A7PRT1
     C                     MOVELA2BHB2    A7PRT2
     C                     MOVELA2BHB3    A7PRT3
     C                     Z-ADDD@NBRS    A7KQTY
     C                     MOVELW@KID     A7KNID
     C                     Z-ADDW@ISDT    A7ISDT
     C                     MOVELW@LOCT    A7LOCT
     C                     MOVELW@CMNT    A7CMNT
     C                     MOVELW@MCHN    A7MCHN
     C                     MOVE W@LOCT    K@LOCT
      *
     C           A7KNID    IFNE 'P'
     C           K#ABH     SETGTABHPL02
     C           *IN95     DOUEQ*ON
     C           K#ABH     REDPEABHPL02                  95
     C           *IN95     IFEQ *OFF
     C           M6SKJY    ANDEQ*BLANK
     C           M6LPDT    ANDEQ*ALL'9'
     C                     Z-ADDM6LOTK    A7LOTS
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      * COMMON PARTS
     C           *IN95     IFEQ *ON
     C           K#ABHX    SETGTABHPL02
     C           *IN95     DOUEQ*ON
     C           K#ABHX    REDPEABHPL02                  95
     C           *IN95     IFEQ *OFF
     C           M6SKJY    ANDEQ*BLANK
     C           M6LPDT    ANDEQ*ALL'9'
     C                     Z-ADDM6LOTK    A7LOTS
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     WRITEABBPP701
     C                     MOVELD@KNBN    @@BRCD 15
     C                     Z-ADDD@NBRS    @@NBRS  30
     C                     Z-ADDA7LOTS    @@LOT   30
      *
     C                     ENDSR
     C**************************************************************************
     C*    3RD SCREEN
     C**************************************************************************
     C           #SCRN3    BEGSR
      *
     C                     EXFMTDSP03
      *
     C           *INKC     IFEQ *ON
     C                     MOVE '99'      @@ID
     C                     ELSE
     C                     EXSR #CHK3
     C           *IN99     IFEQ *ON
     C                     EXFMTERR01
     C                     ELSE
     C                     EXSR #DLT
     C                     CLEARDSP01
     C                     MOVE '01'      @@ID
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*     CHECK
     C**************************************************************************
     C           #CHK3     BEGSR
     C*
     C                     MOVE *BLANK    ERR1                         F5
     C                     MOVE *BLANK    ERR2                         F5
     C                     SETOF                     996162
      *
     C           D@KNBN    IFEQ *BLANK
     C                     SETON                     9961
     C                     MOVELERR,1     ERR1
     C                     ELSE
      *
     C                     MOVE D@KNBN    WBAR
     C           K#ABB     CHAINABBPL72              90
     C           *IN90     IFEQ *ON
     C                     SETON                     9961
     C                     MOVELERR,1     ERR1
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
