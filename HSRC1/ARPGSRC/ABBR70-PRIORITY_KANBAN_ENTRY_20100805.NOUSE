     H***ABBR70*****************************************************************
     H* PRIORITY KANBAN SCAN                                                   *
     H*        09/27/01(TCH)
     H*
     H*        01/24/03(TCH)
     H*             MACHINE = UNDER THE SAME LOCATION                          *
     H*             LOT = SEE ALSO THE COMMON PART.
     H**************************************************************************
     FABBPW70 CF  E                    WORKSTN
     FAH#PL11 IF  E           K        DISK
     FFCETL11 IF  E           K        DISK
     FAAMPL11 IF  E           K        DISK
     FAFAPP60 IF  E           K        DISK
     FAGAPL31 IF  E           K        DISK
     FABHPL02 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FABBPL72 UF  E           K        DISK                      A
      **************************************************************************
     E                    ERR     1   6 15
     E                    KEY     1   2 10
     E                    TTL     1   2 15
     E                    PRC        15  3               PROCESS
     E                    LOC        15  6               LOCATION
     E                    @LC        15  4               LOCATION
     E                    KK         15  1               KANBAN
     E                    MCN        15  3               MACHINE
     E                    PRT        15 12               PART NUMBER
      **************************************************************************
     I* KANBAN TYPE,ABSOLUTE#,ORDER#,SEHIN KUBUN,LOT#
