     C           KEY1      KLIST
     C                     KFLD           HIN1
     C                     KFLD           HIN2
     C                     KFLD           HIN3
      *
     C           KEY2      KLIST
     C                     KFLD           BMON    40
     C                     KFLD           KIBN1   3
      *
     C           STP0      TAG
     C                     MOVE *BLANK    KBN
     C                     MOVE *BLANK    HIN1
     C                     MOVE *BLANK    HIN2
     C                     MOVE *BLANK    HIN3
     C                     MOVE *BLANK    KOJO
     C                     MOVE *BLANK    SITU
     C                     Z-ADD0         ZIKI
     C                     Z-ADD0         HITU
     C                     Z-ADD0         THIZ
     C******************************************************
     C*  EXFMT  <fﾞx] 1>                                   *
     C******************************************************
     C           STP1      TAG
     C                     EXFMTFCQPW511
     C                     MOVEA'0'       *IN,01
     C                     MOVEA'0'       *IN,50
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    ERR
      *  CMD-1
     C           *INKA     IFEQ '1'
     C                     MOVEL'1'       *INLR
     C                     RETRN
     C                     END
     C******************************************************
     C*  <fﾞx] 1 ﾉ kｩｮh>                                   *
     C******************************************************
      *
     C*  hﾎﾞ] kｩｮh
     C*
     C           KBN       IFNE '1'
     C           KBN       ANDNE'2'
     C           KBN       ANDNE'3'
     C                     MOVEA'1'       *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,1     ERR
     C                     GOTO STP1
     C                     END
      *
     C                     MOVE *BLANK    NAME
     C           KBN       LOKUPTAB1      TAB2           11
     C   11                MOVELTAB2      NAME
      *
     C           KBN       COMP '1'                  5050
      *
     C           STP2      TAG
     C                     EXFMTFCQPW512
     C                     MOVEA'00'      *IN,01
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    ERR
      *  CMD-3
     C   KC                GOTO STP0
      *
     C           HIN1      IFEQ *BLANK
     C           HIN2      ANDEQ*BLANK
     C           HIN3      ANDEQ*BLANK
     C                     MOVEA'1'       *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,2     ERR
     C                     GOTO STP2
     C                     END
      *
     C           *IN,50    IFEQ '1'
     C*          KOJO      IFNE '0'
     C*          KOJO      ANDNE'1'
     C*          KOJO      ANDNE'2'
     C*          KOJO      ANDNE'3'
     C*          KOJO      ANDNE'4'
     C*          KOJO      ANDNE'5'
     C           KOJO      IFNE '6'
     C*          KOJO      ANDNE'7'
     C*          KOJO      ANDNE'9'
     C                     MOVEA'1'       *IN,02
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,3     ERR
     C                     GOTO STP2
     C                     END
     C                     END
      *
     C           KBN       IFEQ '1'
     C           KBN       OREQ '3'
      *
     C                     MOVE *BLANK    SW      1
     C                     MOVE *BLANK    KOT
     C                     MOVE *BLANK    KB1
     C                     Z-ADD0         KBM
     C                     MOVE *BLANK    KNM
      *
     C           KEY1      CHAINAAMPL111             12
     C           *IN,12    IFEQ '1'
     C                     MOVEA'1'       *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,4     ERR
     C                     GOTO STP2
     C                     END
      *
     C           CKSKJY    IFEQ 'D'
     C           CKSKHZ    ANDLE*DATE
     C                     MOVEL'*'       SW
     C                     END
      *
     C                     MOVE *BLANK    @TEHI
     C                     MOVE *BLANK    @TENM
     C                     MOVE *BLANK    SITU
     C                     Z-ADD0         ZIKI
     C                     Z-ADD0         HITU
     C                     Z-ADD0         THIZ
     C           KEY1      CHAINFCEPL011             13
     C           *IN,13    IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,13
     C                     END
      *
     C           *IN,13    IFEQ '0'
     C                     MOVELA2ZANM    SITU
     C                     Z-ADDA2KAZI    ZIKI
     C                     Z-ADDA2GEKN    HITU
     C                     Z-ADDA2TAHZ    THIZ
     C                     MOVELA2TEHI    @TEHI
     C*          A2TEHI    IFEQ 'Z'
     C*                    MOVEL'限定'  @TENM
     C*                    END
      *
     C*          A2TEHI    IFEQ 'S'
     C*                    MOVEL'試作'  @TENM
     C*                    END
      *
     C*          A2TEHI    IFEQ 'G'
     C*                    MOVEL'号口'  @TENM
     C*                    END
      *
     C                     Z-ADD1         Z       20
     C                     SETOF                     77
     C           A2TEHI    LOKUPTH1,Z                    77
      *
     C           *IN77     IFEQ '1'
     C                     MOVELTH2,Z     @TENM
     C                     END
      *
     C                     END
      *
     C                     Z-ADD1         A       20
     C                     Z-ADD0         B       20
     C                     DO   15        A
     C                     MOVELKHZ,A     WHZ     80
     C           *DATE     IFLT WHZ
     C           QKO,A     IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE QKO,A     KOT,B
     C                     Z-ADDQBM,A     KBM,B
     C                     MOVELQKB,A     KB1,B
     C                     END
     C                     ELSE
     C           NKO,A     IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE NKO,A     KOT,B
     C                     Z-ADDNBM,A     KBM,B
     C                     MOVE NKB,A     KB1,B
     C                     END
     C                     END
     C                     END
      *
     C                     MOVE *BLANK    KNM
     C                     DO   15        C       20
     C           KBM,C     CHAINFGBPL011             30
     C           *IN30     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,30
     C                     END
      *
     C  N30                MOVELB2SMEI    KNM,C
     C                     END
      *
     C                     MOVE *BLANK    NAM
     C                     DO   15        C
     C                     Z-ADDKBM,C     BMON
     C                     MOVELKB1,C     KIBN1
     C           KEY2      CHAINMFAPL221             14
     C           *IN,14    IFEQ '0'
     C           M@SKJY    ANDEQ'D'
     C           M@SKHZ    ANDLE*DATE
     C                     MOVEL'1'       *IN,14
     C                     END
      *
     C           *IN,14    IFEQ '0'
     C                     MOVELM@KEIS    NAM,C
     C                     END
     C                     END
      *
     C           SW        IFEQ '*'
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,5     ERR
     C                     END
      *
     C           STP3      TAG
     C                     EXFMTFCQPW513
      *
     C           *INKA     IFEQ '1'
     C                     MOVEL'1'       *INLR
     C                     RETRN
     C                     END
      *
     C           *INKC     IFEQ '1'
     C                     MOVE *BLANK    HIN1
     C                     MOVE *BLANK    HIN2
     C                     MOVE *BLANK    HIN3
     C                     MOVE *BLANK    KOJO
     C                     GOTO STP2
     C                     END
      *
     C           KBN       IFNE '3'
     C                     GOTO STP3
     C                     END
     C                     END
      *
     C           KBN       IFEQ '2'
     C           KBN       OREQ '3'
     C                     MOVE *BLANK    XXX
     C                     CALL 'FCQR52'
     C                     PARM           HIN1
     C                     PARM           HIN2
     C                     PARM           HIN3
     C                     PARM           KOJO
     C                     PARM           XXX     1
     C                     PARM           KBN     1
     C           XXX       IFEQ '1'
     C                     MOVEL'1'       *INLR
     C                     RETRN
     C                     ELSE
     C           KBN       IFEQ '3'
     C           XXX       IFEQ '2'
     C                     GOTO STP3
     C                     END
     C           XXX       IFEQ '3'
     C                     MOVE *BLANK    HIN1
     C                     MOVE *BLANK    HIN2
     C                     MOVE *BLANK    HIN3
     C                     MOVE *BLANK    KOJO
     C                     GOTO STP2
     C                     END
     C                     ELSE
     C                     MOVE *BLANK    HIN1
     C                     MOVE *BLANK    HIN2
     C                     MOVE *BLANK    HIN3
     C                     MOVE *BLANK    KOJO
     C                     GOTO STP2
     C                     END
     C                     END
     C                     END
