      **** GDGR60 ****************************************************
      *       YEARLY UPDAT HANDLING
      *     G.B.C                              97/03/06
      ****************************************************************
     H            Y/                                    1
     FGDGPL20 IF  E           K        DISK
     FGDGWP60 IF  E                    DISK                      A
     I****************************************************************
     I*発注実績
     I            DS
     I                                        1   40WKYY
     I                                        1   4 WKDATE
     C****************************************************************
     C*           ＭＡＩＮ　ＲＯＵＴＩＮＥ                         *
     C****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C                     PARM           PPDATE  4
     C                     PARM           PPGO    2
     C****************************************************************
     C                     MOVE PPDATE    WKDATE
     C           WKYY      SUB  5         WKYY2   40
     C                     SETOF                     50
     C*--------------------
B1   C                     DO   *HIVAL
     C                     READ GDGPL20                  90
     C   90                LEAVE
     C*
 B2  C           IDJSYY    IFGE WKYY2
     C                     LEAVE
 E2  C                     ENDIF
     C*
     C                     SETON                     50
     C                     WRITEGDGPP201
E1   C                     ENDDO
     C*--------------------
     C* <終　了>
     C           @END      TAG
     C   50                MOVE 'GO'      PPGO
     C  N50                MOVE 'NG'      PPGO
     C                     SETON                     LR
     C                     RETRN
     C* DUMMY READ
     C                     READ GDGWP60                  90
     C*****************************************************************
