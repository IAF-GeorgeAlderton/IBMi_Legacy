     H            Y.                                    1
     F** AACR02 ******************************
     F*CREATE BAR CODE M/F LIST
     F* A:N.HAYAKAWA               86.08.30  *
     F****************************************
     FAACPL01 IP  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FQPRINT  O   F      80     OF     PRINTER
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
     C                     SETOF                     0102
     C  N03                TIME           WTIME   60
     C  N03                SETON                     0203
     C*
     C           T8SKJY    IFEQ 'D'
     C           T8SKHZ    IFLE *DATE
     C                     GOTO STEP99
     C                     END
     C                     END
     C                     SETON                     01
     C           STEP99    TAG
     C*--------------------*
     C*   細目マスター   *
     C*--------------------*
     C                     SETOF                     30
     C           T8BUKO    CHAINFGBPL011             30
     C           *IN30     IFEQ '1'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C                     MOVELB2SMEI    WNM    15
     OQPRINT  H  102   02
     O       OR        OF
     O                                   80 '+---------+'
     O        H  1     02
     O       OR        OF
     O                                    7 'APICS'
     O                                   58 'TIME'
     O                         WTIME Y   67
     O                                   80 '|         |'
     O        H  1     02
     O       OR        OF
     O                                   12 'AACR02-1 '
     O                                   58 'DATE'
     O                         UDATE Y   67
     O                                   80 '|         |'
     O        H  2     02
     O       OR        OF
     O                                   35 '** BAR CODE'
     O                                   47 'M/F LIST **'
     O                                   63 'PAGE'
     O                         PAGE  Z   67
     O                                   80 '+---------+'
