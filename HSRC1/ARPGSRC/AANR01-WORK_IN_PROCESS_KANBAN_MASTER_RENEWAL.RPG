     C           @011      ENDSR
%0002 *-----------------------------------------------------*
     C           #SB100    BEGSR
     C                     MOVE *BLANK    HHIN1   5
     C                     MOVE *BLANK    HHIN2   5
     C                     MOVE *BLANK    HHIN3   2
     C                     SETOF                     30
     C           BKEY      CHAINFCEPL41              30
     C           *IN30     IFEQ '0'
     C                     MOVE F4PRT1    HHIN1
     C                     MOVE F4PRT2    HHIN2
     C                     MOVE F4PRT3    HHIN3
     C                     END
      *
     C           KEYA      KLIST
     C                     KFLD           HHIN1
     C                     KFLD           HHIN2
     C                     KFLD           HHIN3
     C                     SETOF                     30
     C           KEYA      CHAINAAMPL111             30
     C           *IN30     IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADD1         @A      20
     C                     Z-ADD0         @B      20
     C           1         DO   15        @A
     C           KKO,@A    IFNE *BLANK
     C                     ADD  1         @B
     C                     MOVE KKO,@A    CKO,@B
     C                     END
     C                     ENDDO
     C                     END
      *
     C                     Z-ADD1         @A
     C                     Z-ADD0         @B
     C                     MOVE *BLANK    WKO     3
     C                     SETOF                     30
     C           'HN '     LOKUPCKO,@A                   30
     C           *IN30     IFEQ '1'
     C           @A        ADD  1         @B
     C                     MOVE CKO,@B    WKO
     C                     END
      *
     C                     MOVE *BLANK    CFLG    1
     C                     Z-ADD1         @A
     C                     MOVE *BLANK    WIRO    1
     C           WKO       IFNE *BLANK
     C                     SETOF                     30
     C           WKO       LOKUPTB5,@A                   30
     C           *IN30     IFEQ '1'
     C                     MOVE TB6,@A    WIRO
     C                     MOVE '*'       CFLG
     C                     END
     C                     END
      *
     C           ESB100    ENDSR
      *------------------------------------*
      *安全在庫理由                      *
      *------------------------------------*
     CSR         #SBTYO    BEGSR
      *
     C                     MOVELL7TKR1    P3ATK1
     C                     MOVELL7TKR2    P3ATK2
     C                     MOVELL7TKR3    P3ATK3
     C                     MOVELL7TKR4    P3ATK4
     C                     MOVELL7UKYY    P3UKYY
     C                     MOVELL7UKMM    P3UKMM
     C                     MOVELL7UKDD    P3UKDD
     C                     MOVELL7UBIN    P3UBIN
     C                     CALL 'ANZR99'
     C                     PARM           P3ATK1  1
     C                     PARM           P3ATK2  2
     C                     PARM           P3ATK3  2
     C                     PARM           P3ATK4  1
     C                     PARM           P3UKYY  40
     C                     PARM           P3UKMM  20
     C                     PARM           P3UKDD  20
     C                     PARM           P3UBIN  20
      *
     CSR         ESBTYO    ENDSR
