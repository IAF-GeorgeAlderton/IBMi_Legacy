     H            Y.
     F****************************************************************
     F*  PROGRAM    : FBCR80                                         *
     F*  WRITTEN    : 11/12/2015                                     *
     F*  WRITTEN BY : JW (SRA)                                       *
     F*  FUNCTION   : READ FBCWP80(CSV) AND VALIDATE FIELDS          *
     F*             : IF ERROR, CREATE ERROR REPORT                  *
     *  ATTENTION  : COMPILE WITH OPTION - ALLOW NULL VALUES *YES
JW1  F*  JW           2017.06.09 CHG PRINT                           *
JW2  F*  JW           2019.04.05 FIX BUG                             *
     F****************************************************************
     FFBCWP80 IF  E                    DISK
     FFAAPL05 IF  E           K        DISK
     FFBCPL32 IF  E           K        DISK
     FFBCPL07 IF  E           K        DISK
     FFBCPL08 IF  E           K        DISK
     FFBCWP81 O   E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *---------------------------------------------------------------
     E                    CSV        80  1
     E                    FLD        20  1
     E                    MV1        30  1
     E                    MV2        20  1
     E                    MSG     1   7 80
      *---------------------------------------------------------------
      *
     I              '0123456789'          C         WKCKSU
      *
     I            DS
     I                                        1  12 K@SHN
     I                                        1   5 K@SHN1
     I                                        6  10 K@SHN2
     I                                       11  12 K@SHN3
     I            DS
     I                                        1  20 @MHIN
     I                                        1   5 @MHIN1
     I                                        6  10 @MHIN2
     I                                       11  15 @MHIN3
     I                                       16  20 @MHIN4
     I            DS
     I                                        1   6 W@FLD6
     I                                        1   65W@NUM6
     ID10@DT      DS
     I                                        1   4 D10@YY
     I                                        6   7 D10@MM
     I                                        9  10 D10@DD
     ID8@DT       DS
     I                                        1   4 D8@YY
     I                                        5   6 D8@MM
     I                                        7   8 D8@DD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ******************************************************
      *                    MAIN PROCESS
      ******************************************************
      * Initial Process
     C                     EXSR @INIT
      * Validate APR Data
     C                     EXSR @CHK1
      * Validate Price Table
     C                     EXSR @CHK2
      * Print Footer
     C           NM@CNT    ADD  ER@CNT    TTL#
      *
     C           SEQ       IFEQ 0
      * If No Error
     C                     MOVE *OFF      #STS
     C                     MOVE MSG,6     FLD37  37
     C                     MOVELWR@CNT    FLD37
     C                     MOVE MSG,6     FLD52  52
     C                     MOVELDAT#      FLD52
     C                     MOVELMSG,6     #MSG1
     C                     MOVE FLD52     #MSG1
     C                     MOVE FLD37     #MSG1
     C                     ELSE
      * If Error
     C                     MOVE *ON       #STS
     C           DAT#      SUB  IG@CNT    OK#     50
     C                     EXCPTFOT1
     C                     MOVE MSG,7     FLD36  36
     C                     MOVELOK#       FLD36
     C                     MOVE MSG,7     FLD46  46
     C                     MOVELWR@CNT    FLD46
     C                     MOVE MSG,7     FLD61  61
     C                     MOVELER@CNT    FLD61
     C                     MOVELMSG,7     #MSG2
     C                     MOVE FLD61     #MSG2
     C                     MOVE FLD46     #MSG2
     C                     MOVE FLD36     #MSG2
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ******************************************************
      *          Validate APR Data
      ******************************************************
     C           @CHK1     BEGSR
     C                     MOVE *OFF      *IN80
      *
     C           *IN80     DOUEQ*ON
     C                     READ FBCWP80                  80
     C           *IN80     IFEQ *OFF
     C                     ADD  1         LIN#
     C                     EXSR @GET
      * If Header, Skip
     C           #HDFLG    IFEQ *ON
     C                     GOTO @SKIP
     C                     ENDIF
      *
     C                     ADD  1         DAT#
     C                     MOVE *OFF      #IGFLG  1
      * Check Valid Date -------------------------
     C                     MOVEL#VLDAT    @VLDAT
     C                     CALL 'UTLR01'
     C                     PARM           @VLDAT 10
     C                     PARM           #TRUE   8
     C                     PARM           #RTN    1
     C           #RTN      IFNE *BLANK
      * Print Error Report
     C                     ADD  1         ER@CNT
     C                     ADD  1         IG@CNT
     C                     MOVE *ON       #IGFLG
     C                     MOVELMSG,2     XMSG
     C                     EXSR @PRINT
     C                     ENDIF
      * Check Part1------------------------------------
      *      (*) CHAIN FAAPP02(B7)
     C                     MOVE *OFF      EXIST1  1
     C                     MOVE *BLANK    K@SHN
     C                     MOVEL#PART2    @MHIN
     C                     MOVE *OFF      *IN98
     C           K#PART    SETLLFAAPL05
     C           *IN98     DOWEQ*OFF
     C           K#PART    READEFAAPL05                  98
     C           *IN98     IFEQ *OFF
     C           B7TOKU    ANDEQ5149
     C                     MOVE *ON       EXIST1
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      * Check Part2------------------------------------
      *      (*) CHAIN FBCPL08(FB)
     C                     MOVE *OFF      EXIST2  1
     C                     MOVEL#PART2    @MHIN
     C                     Z-ADD5149      K@TOKU
     C                     MOVE *OFF      *IN98
     C           K#PL08    CHAINFBCPL08              98
     C           *IN98     IFEQ *OFF
     C                     MOVE *ON       EXIST2
     C                     ENDIF
      * Print Error Report
     C           EXIST1    IFEQ *OFF
     C           EXIST2    ANDEQ*OFF
     C                     MOVE *BLANK    @TOKU
     C                     MOVE *BLANK    @NONY
     C                     ADD  1         WR@CNT
     C                     ADD  1         IG@CNT
     C                     MOVE *ON       #IGFLG
     C                     MOVELMSG,4     XMSG
     C                     EXSR @PRINT
     C                     ELSE
     C           EXIST1    IFEQ *ON
     C                     MOVELB7TOKU    @TOKU
     C                     MOVELB7NONY    @NONY
     C                     MOVELB7SHN1    K@SHN1
     C                     MOVELB7SHN2    K@SHN2
     C                     MOVELB7SHN3    K@SHN3
     C                     ELSE
     C           EXIST2    IFEQ *ON
     C                     MOVELFBTOKU    @TOKU
     C                     MOVELFBNONY    @NONY
     C                     MOVELFBSHN1    K@SHN1
     C                     MOVELFBSHN2    K@SHN2
     C                     MOVELFBSHN3    K@SHN3
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
      * Check PLANT (NOT CHECK IF PART NOT FOUND)-----
     C           EXIST1    IFEQ *ON
     C           EXIST2    OREQ *ON
      * Check PLANT 1 --------------------------
     C           PLT1      IFNE *BLANK
     C                     MOVE *BLANK    @TOKU
     C                     MOVE *BLANK    @NONY
     C                     MOVE *BLANK    KEY10  10
     C                     MOVELPLT1      KEY10
     C           KEY10     CHAINFBCPL32              99
      *
     C           *IN99     IFEQ *ON
     C                     MOVE *ON       #IGFLG
     C                     ADD  1         ER@CNT
     C                     ADD  1         IG@CNT
     C                     MOVELMSG,1     XMSG
     C                     MOVE XMSG      FLD29  29
     C                     MOVELPLT1      FLD29
     C                     MOVE FLD29     XMSG
     C                     EXSR @PRINT
     C                     ELSE
      * CHECK W/PRICE MASTER, IF CUST/DELIV EXISTS IN 2 CHAR PALNT MASTER
     C           KEY07     CHAINFBCPL07              96
     C           *IN96     IFEQ *ON
     C           FSNONY    ANDNE9999
     C                     ADD  1         WR@CNT
     C           FSTOKU    IFEQ 0
     C                     MOVEL'5149'    @TOKU
     C                     ELSE
     C                     MOVELFSTOKU    @TOKU
     C                     ENDIF
      *
     C                     MOVELFSNONY    @NONY
     C                     MOVELMSG,3     XMSG
     C                     MOVEL'WARN1'   XMSG
     C                     MOVE XMSG      FLD29
     C                     MOVELPLT1      FLD29
     C                     MOVE FLD29     XMSG
     C                     EXSR @PRINT
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
      * Check PLANT 2--------------------------
     C           PLT2      IFNE *BLANK
     C                     MOVE *BLANK    @TOKU
     C                     MOVE *BLANK    @NONY
     C                     MOVE *BLANK    KEY10
     C                     MOVELPLT2      KEY10
     C           KEY10     CHAINFBCPL32              99
     C           *IN99     IFEQ *ON
     C                     MOVE *ON       #IGFLG
     C                     ADD  1         ER@CNT
     C                     ADD  1         IG@CNT
     C           FSTOKU    IFEQ 0
     C                     MOVEL'5149'    @TOKU
     C                     ELSE
     C                     MOVELFSTOKU    @TOKU
     C                     ENDIF
      *
     C                     MOVELFSNONY    @NONY
     C                     MOVELMSG,1     XMSG
     C                     MOVE XMSG      FLD29
     C                     MOVELPLT2      FLD29
     C                     MOVE FLD29     XMSG
     C                     EXSR @PRINT
      * CHECK W/PRICE MASTER, IF EXIST CUST/DELIV
     C                     ELSE
     C           KEY07     CHAINFBCPL07              96
     C           *IN96     IFEQ *ON
     C           FSNONY    ANDNE9999
     C                     ADD  1         WR@CNT
     C                     MOVELFSTOKU    @TOKU
     C                     MOVELFSNONY    @NONY
     C                     MOVELMSG,3     XMSG
     C                     MOVEL'WARN2'   XMSG
     C                     MOVE XMSG      FLD29
     C                     MOVELPLT2      FLD29
     C                     MOVE FLD29     XMSG
     C                     EXSR @PRINT
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
      * Check PLANT 3 -------------------------
     C           PLT3      IFNE *BLANK
     C                     MOVE *BLANK    @TOKU
     C                     MOVE *BLANK    @NONY
     C                     MOVE *BLANK    KEY10
     C                     MOVELPLT3      KEY10
     C           KEY10     CHAINFBCPL32              99
     C           *IN99     IFEQ *ON
     C                     MOVE *ON       #IGFLG
     C                     ADD  1         ER@CNT
     C                     ADD  1         IG@CNT
     C                     MOVELMSG,1     XMSG
     C                     MOVE XMSG      FLD29
     C                     MOVELPLT3      FLD29
     C                     MOVE FLD29     XMSG
     C                     EXSR @PRINT
      * CHECK W/PRICE MASTER, IF EXIST CUST/DELIV
     C                     ELSE
     C           KEY07     CHAINFBCPL07              96
     C           *IN96     IFEQ *ON
     C           FSNONY    ANDNE9999
     C                     ADD  1         WR@CNT
     C                     MOVELMSG,3     XMSG
     C                     MOVEL'WARN3'   XMSG
     C                     MOVE XMSG      FLD29
     C                     MOVELPLT3      FLD29
     C                     MOVE FLD29     XMSG
     C                     EXSR @PRINT
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
      * Check PLANT 4--------------------------
     C           PLT4      IFNE *BLANK
     C                     MOVE *BLANK    @TOKU
     C                     MOVE *BLANK    @NONY
     C                     MOVE *BLANK    KEY10
     C                     MOVELPLT4      KEY10
     C           KEY10     CHAINFBCPL32              99
     C           *IN99     IFEQ *ON
     C                     MOVE *ON       #IGFLG
     C                     ADD  1         ER@CNT
     C                     ADD  1         IG@CNT
     C**                   MOVELFSTOKU    @TOKU
     C           FSTOKU    IFEQ 0
     C                     MOVEL'5149'    @TOKU
     C                     ELSE
     C                     MOVELFSTOKU    @TOKU
     C                     ENDIF
      *
     C                     MOVELFSNONY    @NONY
     C                     MOVELMSG,1     XMSG
     C                     MOVE XMSG      FLD29
     C                     MOVELPLT4      FLD29
     C                     MOVE FLD29     XMSG
     C                     EXSR @PRINT
      * CHECK W/PRICE MASTER, IF EXIST CUST/DELIV
     C                     ELSE
     C           KEY07     CHAINFBCPL07              96
     C           *IN96     IFEQ *ON
     C           FSNONY    ANDNE9999
     C                     ADD  1         WR@CNT
     C                     MOVELFSTOKU    @TOKU
     C                     MOVELFSNONY    @NONY
     C                     MOVELMSG,3     XMSG
     C                     MOVEL'WARN4'   XMSG
     C                     MOVE XMSG      FLD29
     C                     MOVELPLT4      FLD29
     C                     MOVE FLD29     XMSG
     C                     EXSR @PRINT
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
      * Check PLANT 5--------------------------
     C           PLT5      IFNE *BLANK
     C                     MOVE *BLANK    @TOKU
     C                     MOVE *BLANK    @NONY
     C                     MOVE *BLANK    KEY10
     C                     MOVELPLT5      KEY10
     C           KEY10     CHAINFBCPL32              99
     C           *IN99     IFEQ *ON
     C                     MOVE *ON       #IGFLG
     C                     ADD  1         ER@CNT
     C                     ADD  1         IG@CNT
      **                   MOVELFSTOKU    @TOKU
     C           FSTOKU    IFEQ 0
     C                     MOVEL'5149'    @TOKU
     C                     ELSE
     C                     MOVELFSTOKU    @TOKU
     C                     ENDIF
      *
     C                     MOVELFSNONY    @NONY
     C                     MOVELMSG,1     XMSG
     C                     MOVE XMSG      FLD29
     C                     MOVELPLT5      FLD29
     C                     MOVE FLD29     XMSG
     C                     EXSR @PRINT
      * CHECK W/PRICE MASTER, IF EXIST CUST/DELIV
     C                     ELSE
     C           KEY07     CHAINFBCPL07              96
     C           *IN96     IFEQ *ON
     C           FSNONY    ANDNE9999
     C                     ADD  1         WR@CNT
     C                     MOVELFSTOKU    @TOKU
     C                     MOVELFSNONY    @NONY
     C                     MOVELMSG,3     XMSG
     C                     MOVEL'WARN5'   XMSG
     C                     MOVE XMSG      FLD29
     C                     MOVELPLT5      FLD29
     C                     MOVE FLD29     XMSG
     C                     EXSR @PRINT
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
      * Check PLANT 6--------------------------
     C           PLT6      IFNE *BLANK
     C                     MOVE *BLANK    @TOKU
     C                     MOVE *BLANK    @NONY
     C                     MOVE *BLANK    KEY10
     C                     MOVELPLT6      KEY10
     C           KEY10     CHAINFBCPL32              99
     C           *IN99     IFEQ *ON
     C                     MOVE *ON       #IGFLG
     C                     ADD  1         ER@CNT
     C                     ADD  1         IG@CNT
     C**                   MOVELFSTOKU    @TOKU
     C           FSTOKU    IFEQ 0
     C                     MOVEL'5149'    @TOKU
     C                     ELSE
     C                     MOVELFSTOKU    @TOKU
     C                     ENDIF
      *
     C                     MOVELFSNONY    @NONY
     C                     MOVELMSG,1     XMSG
     C                     MOVE XMSG      FLD29
     C                     MOVELPLT6      FLD29
     C                     MOVE FLD29     XMSG
     C                     EXSR @PRINT
      * CHECK W/PRICE MASTER, IF EXIST CUST/DELIV
     C                     ELSE
     C           KEY07     CHAINFBCPL07              96
     C           *IN96     IFEQ *ON
     C           FSNONY    ANDNE9999
     C                     ADD  1         WR@CNT
     C                     MOVELFSTOKU    @TOKU
     C                     MOVELFSNONY    @NONY
     C                     MOVELMSG,3     XMSG
     C                     MOVEL'WARN6'   XMSG
     C                     MOVE XMSG      FLD29
     C                     MOVELPLT6      FLD29
     C                     MOVE FLD29     XMSG
     C                     EXSR @PRINT
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
      *
      * IF ERROR, SKIP --------------------------------
     C           #IGFLG    IFEQ *ON
     C                     GOTO @SKIP
     C                     ENDIF
      *
      * IF NO ERROR, WRITE FBCWP81 (WORK)--------------
     C           PLT1      IFNE *BLANK
     C                     MOVELPLT1      KEY10
     C                     EXSR #WRT
     C                     ENDIF
     C           PLT2      IFNE *BLANK
     C                     MOVELPLT2      KEY10
     C                     EXSR #WRT
     C                     ENDIF
     C           PLT3      IFNE *BLANK
     C                     MOVELPLT3      KEY10
     C                     EXSR #WRT
     C                     ENDIF
     C           PLT4      IFNE *BLANK
     C                     MOVELPLT4      KEY10
     C                     EXSR #WRT
     C                     ENDIF
     C           PLT5      IFNE *BLANK
     C                     MOVELPLT5      KEY10
     C                     EXSR #WRT
     C                     ENDIF
     C           PLT6      IFNE *BLANK
     C                     MOVELPLT6      KEY10
     C                     EXSR #WRT
     C                     ENDIF
      * ------------------------------------------
     C           @SKIP     TAG
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      ******************************************************
      *          Validate Price Table
      ******************************************************
     C           @CHK2     BEGSR
      *
      *
     C                     ENDSR
      ******************************************************
      *          WRITE FBCWP81
      ******************************************************
     C           #WRT      BEGSR
      *
     C           KEY10     SETLLFBCPL32
     C                     MOVE *OFF      *IN97
     C           *IN97     DOWEQ*OFF
     C           KEY10     READEFBCPL32                  97
     C           *IN97     IFEQ *OFF
     C           FSTOKU    ANDEQ5149
     C           FSNONY    ANDNE9999
     C                     Z-ADDLIN#      F8LINE
     C                     Z-ADDFSTOKU    F8TOKU
     C                     Z-ADDFSNONY    F8NONY
     C                     MOVELKEY10     F8PLNT
     C                     MOVEL#TRUE     F8EFDT
     C                     MOVEL#PART2    @MHIN
     C                     MOVEL@MHIN1    F8MHN1
     C                     MOVEL@MHIN2    F8MHN2
     C                     MOVEL@MHIN3    F8MHN3
     C                     MOVEL@MHIN4    F8MHN4
     C                     MOVELK@SHN1    F8SHN1
     C                     MOVELK@SHN2    F8SHN2
     C                     MOVELK@SHN3    F8SHN3
     C                     Z-ADD#UP       F8UP
     C                     Z-ADD@DATE     F8CDAT
     C                     Z-ADD@TIME     F8CTIM
     C                     MOVEL#USER     F8USER
     C                     MOVEL#PGM      F8PGM
      * SET DEFAULT FLAG
     C           F8MHN1    IFEQ SVMHN1
     C           F8MHN2    ANDEQSVMHN2
     C           F8MHN3    ANDEQSVMHN3
     C           F8MHN4    ANDEQSVMHN4
     C                     MOVE *BLANK    F8DFLT
     C                     ELSE
     C                     MOVE '*'       F8DFLT
     C                     ENDIF
      *
     C                     WRITEFBCWP811
      *
     C                     MOVELF8MHN1    SVMHN1
     C                     MOVELF8MHN2    SVMHN2
     C                     MOVELF8MHN3    SVMHN3
     C                     MOVELF8MHN4    SVMHN4
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      ******************************************************
      *          @GET: GET INPUT FIELDS
      ******************************************************
     C           @GET      BEGSR
     C**JW1                MOVE *BLANK    #SHPTO  5
     C                     MOVE *BLANK    #VLDAT 10
     C                     MOVE *BLANK    #PART  15
     C                     MOVE *BLANK    #PLANT 15
     C                     Z-ADD0         #UP     65
     C                     MOVE *OFF      #HDFLG  1        HEADER FLAG
      *
     C                     Z-ADD*ZERO     IX      50
     C                     Z-ADD*ZERO     IY      50
      * FILL UP BLANK
     C           FLD3      IFEQ *BLANK
     C                     MOVELFLD3SV    FLD3
     C                     ENDIF
     C           FLD4      IFEQ *BLANK
     C                     MOVELFLD4SV    FLD4
     C                     ENDIF
      * VALID DATE ------------------------------------
     C                     MOVELFLD1      #VLDAT
      * PART# ---------------------------------------
     C                     MOVELFLD2      #PART
     C                     MOVELFLD2      #PART2 20
      *       (1) Remove '-' from #PART and save to MV2
     C                     Z-ADD1         IX
     C                     Z-ADD0         IY
     C                     MOVEA#PART     MV1
     C                     MOVEA#PART     MV2
     C           '-'       LOKUPMV1,IX                   99
     C           *IN99     IFEQ *ON
     C           IX        SUB  1         IY
     C           1         DO   20
     C                     ADD  1         IX
     C                     ADD  1         IY
     C           MV1,IX    IFEQ *BLANK
     C                     MOVE MV1,IX    MV2,IY
     C                     LEAVE
     C                     ELSE
     C                     MOVE MV1,IX    MV2,IY
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *       (2) Remove '-' from #PART and save to #PART2
     C                     Z-ADD1         IX
     C                     Z-ADD0         IY
     C                     MOVEAMV2       MV1
     C           '-'       LOKUPMV1,IX                   99
     C           *IN99     IFEQ *ON
     C           IX        SUB  1         IY
     C           1         DO   20
     C                     ADD  1         IX
     C                     ADD  1         IY
     C           MV1,IX    IFEQ *BLANK
     C                     MOVE MV1,IX    MV2,IY
     C                     LEAVE
     C                     ELSE
     C                     MOVE MV1,IX    MV2,IY
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
     C                     MOVEAMV2       #PART2
      * PLANT ---------------------------------------
     C                     MOVELFLD3      #PLANT
     C                     MOVEA*BLANK    MV1
     C                     MOVEAFLD3      MV1
     C                     MOVE *BLANK    PLT1    2
     C                     MOVE *BLANK    PLT2    2
     C                     MOVE *BLANK    PLT3    2
     C                     MOVE *BLANK    PLT4    2
     C                     MOVE *BLANK    PLT5    2
     C                     MOVE *BLANK    PLT6    2
     C                     Z-ADD0         P1CNT   20
     C                     Z-ADD0         P2CNT   20
     C                     Z-ADD0         P3CNT   20
     C                     Z-ADD0         P4CNT   20
     C                     Z-ADD0         P5CNT   20
     C                     Z-ADD0         P6CNT   20
     C           1         DO   30        IX
     C           MV1,IX    IFNE ' '
     C           MV1,IX    ANDNE','
     C                     SELEC
     C           P1CNT     WHEQ 0
     C                     MOVELMV1,IX    PLT1
     C                     ADD  1         P1CNT
     C           P1CNT     WHEQ 1
     C                     MOVE MV1,IX    PLT1
     C                     ADD  1         P1CNT
     C           P2CNT     WHEQ 0
     C                     MOVELMV1,IX    PLT2
     C                     ADD  1         P2CNT
     C           P2CNT     WHEQ 1
     C                     MOVE MV1,IX    PLT2
     C                     ADD  1         P2CNT
     C           P3CNT     WHEQ 0
     C                     MOVELMV1,IX    PLT3
     C                     ADD  1         P3CNT
     C           P3CNT     WHEQ 1
     C                     MOVE MV1,IX    PLT3
     C                     ADD  1         P3CNT
     C           P4CNT     WHEQ 0
     C                     MOVELMV1,IX    PLT4
     C                     ADD  1         P4CNT
     C           P4CNT     WHEQ 1
     C                     MOVE MV1,IX    PLT4
     C                     ADD  1         P4CNT
     C           P5CNT     WHEQ 0
     C                     MOVELMV1,IX    PLT5
     C                     ADD  1         P5CNT
     C           P5CNT     WHEQ 1
     C                     MOVE MV1,IX    PLT5
     C                     ADD  1         P5CNT
     C           P6CNT     WHEQ 0
     C                     MOVELMV1,IX    PLT6
     C                     ADD  1         P6CNT
     C           P6CNT     WHEQ 1
     C                     MOVE MV1,IX    PLT6
     C                     ADD  1         P6CNT
     C                     OTHER
     C                     Z-ADD31        IX
     C                     ENDSL
     C                     ENDIF
     C                     ENDDO
      * ADJUST PLANT CODE ('1' --> '01')
     C           PLT1      IFNE *BLANK
     C           P1CNT     ANDEQ1
     C                     MOVE PLT1      LTR3    3
     C                     MOVEL'0'       LTR3
     C                     MOVELLTR3      PLT1
     C                     ENDIF
     C           PLT2      IFNE *BLANK
     C           P2CNT     ANDEQ1
     C                     MOVE PLT2      LTR3
     C                     MOVEL'0'       LTR3
     C                     MOVELLTR3      PLT2
     C                     ENDIF
     C           PLT3      IFNE *BLANK
     C           P3CNT     ANDEQ1
     C                     MOVE PLT3      LTR3
     C                     MOVEL'0'       LTR3
     C                     MOVELLTR3      PLT3
     C                     ENDIF
     C           PLT4      IFNE *BLANK
     C           P4CNT     ANDEQ1
     C                     MOVE PLT4      LTR3
     C                     MOVEL'0'       LTR3
     C                     MOVELLTR3      PLT4
     C                     ENDIF
     C           PLT5      IFNE *BLANK
     C           P5CNT     ANDEQ1
     C                     MOVE PLT5      LTR3
     C                     MOVEL'0'       LTR3
     C                     MOVELLTR3      PLT5
     C                     ENDIF
     C           PLT6      IFNE *BLANK
     C           P6CNT     ANDEQ1
     C                     MOVE PLT6      LTR3
     C                     MOVEL'0'       LTR3
     C                     MOVELLTR3      PLT6
     C                     ENDIF
     C* UNIT PRICE -------------------------------------
     C                     Z-ADD0         IX
     C                     Z-ADD0         IY
     C                     MOVEL*ALL'0'   FLD
     C                     CLEARCSV
     C                     MOVEAFLD4      CSV
     C                     DO   *HIVAL
     C                     ADD  1         IX
     C           CSV,IX    IFEQ ' '
     C                     LEAVE
     C                     ENDIF
     C           CSV,IX    IFEQ '.'
     C                     ITER
     C                     ENDIF
     C                     ADD  1         IY
     C                     MOVELCSV,IX    FLD,IY
     C                     ENDDO
      *
     C                     MOVEAFLD       W@FLD6
      * CHECK NUMERIC
     C           WKCKSU    CHECKW@FLD6                   99
     C           *IN99     IFEQ *OFF
     C                     Z-ADDW@NUM6    #UP
     C                     ENDIF
      *
      * IF PRICE FIELD = 0, THEN IT IS HEADER --------
     C           #UP       IFEQ 0
     C                     MOVE *ON       #HDFLG
     C                     ENDIF
      * SAVE FIELD
     C                     MOVELFLD3      FLD3SV
     C                     MOVELFLD4      FLD4SV
      *
     C                     ENDSR
      ******************************************************
      *          @PRINT: PRINT ERROR REPORT
      ******************************************************
     C           @PRINT    BEGSR
      *
     C   OF                EXCPTHDR1
     C   OF                SETOF                     OF
     C                     ADD  1         SEQ
      *
     C                     EXCPTDTL1
      *
     C                     ENDSR
      ******************************************************
      *                  INITIAL ROUTINE
      ******************************************************
     C           @INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           #STS    1
     C                     PARM           #MSG1  80
     C                     PARM           #MSG2  80
      *
     C           K#PART    KLIST
     C                     KFLD           @MHIN1
     C                     KFLD           @MHIN2
     C                     KFLD           @MHIN3
     C                     KFLD           @MHIN4
      *
     C           KEY07     KLIST
     C                     KFLD           FSTOKU
     C                     KFLD           FSNONY
     C                     KFLD           @MHIN1
     C                     KFLD           @MHIN2
     C                     KFLD           @MHIN3
     C                     KFLD           @MHIN4
      *
     C           K#PL08    KLIST
     C                     KFLD           @MHIN1
     C                     KFLD           @MHIN2
     C                     KFLD           @MHIN3
     C                     KFLD           @MHIN4
     C                     KFLD           K@TOKU  40
      *
     C                     Z-ADD*DATE     @DATE   80
     C                     TIME           @TIME   60
     C                     MOVE *ON       *INOF
     C                     MOVE *OFF      #STS
     C                     CLEAR#MSG1
     C                     CLEAR#MSG2
     C                     MOVE *BLANK    XMSG   37
     C                     Z-ADD0         SEQ     50
     C                     Z-ADD0         ER@CNT  50
     C                     Z-ADD0         WR@CNT  50
     C                     Z-ADD0         NM@CNT  50
     C                     Z-ADD0         IG@CNT  50
     C                     Z-ADD0         DAT#    50
     C                     Z-ADD0         TTL#    50
     C                     Z-ADD0         LIN#    50
     C                     MOVE *BLANK    FLD3   30
     C                     MOVE *BLANK    FLD4   20
     C                     MOVE *BLANK    FLD3SV 20
     C                     MOVE *BLANK    FLD4SV 20
     C                     MOVE *BLANK    @TOKU   4
     C                     MOVE *BLANK    @NONY   4
     C                     MOVE *BLANK    SVMHN1  5
     C                     MOVE *BLANK    SVMHN2  5
     C                     MOVE *BLANK    SVMHN3  5
     C                     MOVE *BLANK    SVMHN4  5
      *
     C                     ENDSR
      *************************************************************
      *                    OUTPUT                                 *
      *************************************************************
     OQPRINT  E  102           HDR1
     O                                    8 'PROGRAM:'
     O                         #PGM      19
     O                         #USER     32
     O                                   60 '<< ERROR REPORT >>'
     O                                  100 'DATE'
     O                         @DATE    111 '    .  .  '
     O                         @TIME    120 '  :  :  '
     O                         PAGE  Z  130
     O                                  126 'PAGE'
     O        E  1             HDR1
     O                                    4 'ERR'
     O                                   11 'LINE#'
     O**JW1                              17 'SHPTO'
     O                                   16 'CUST'
     O                                   21 'DELV'
     O                                   32 'VALID_DATE'
     O                                   42 'USER_PART'
     O                                   60 'INTRAL PART'
     O                                   72 'UNIT_PRICE'
     O                                   82 'PLANT'
     O                                  105 'ERROR MSG'
     O        E  1             HDR1
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O                                  120 '--------------------'
     O                                  130 '----------'
      *
     O        E  1             DTL1
     O                         SEQ   Z    5
     O                         LIN#  Z   11
     O**JW1                    #SHPTO    17
     O                         @TOKU     16
     O                         @NONY     21
     O                         #VLDAT    32
     O                         #PART     48
     O                         K@SHN1    54
     O                         K@SHN2    60
     O                         K@SHN3    63
     O                         #UP   3   72
     O                         PLT1      79
     O                         PLT2      82
     O                         PLT3      85
     O                         PLT4      88
     O                         PLT5      91
     O                         PLT6      94
     O                         XMSG     132
      *
     O        E  1             FOT1
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O                                  120 '--------------------'
     O                                  130 '----------'
      *
     O        E  1             FOT1
     O                                   18 '** TOTAL RECORDS:'
     O                         DAT#  3   23
