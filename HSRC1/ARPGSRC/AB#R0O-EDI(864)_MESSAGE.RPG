     FAB#EP95 IF  E                    DISK
     FAB#EP96 IF  E           K        DISK
     FAB#PL2I IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *---------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *---------------------------------------------------------
     C                     DO   *HIVAL
     C                     READ AB#EP95                  97
     C   97                LEAVE
      * PRINT HEADER
     C                     EXCPT@HED1
      * PRINT EP96
     C                     EXSR #DTL1
      * PRINT PP2A
     C                     EXSR #DTL2
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *--------------------------------------------------
      * PRINT DETAIL1                                   -
      *--------------------------------------------------
     C           #DTL1     BEGSR
      *
     C                     MOVE *BLANK    SVRENO 20
     C                     MOVE *BLANK    XXRENO 20
     C                     Z-ADD0         CNT     30
      *
     C           K#KEY     SETLLAB#EP96
     C                     DO   *HIVAL
     C           K#KEY     READEAB#EP96                  96
     C   96                LEAVE
      *
     C                     ADD  1         CNT
      *
     C           CNT       IFEQ 1
     C                     MOVELAERENO    XXRENO 20
     C                     ELSE
     C                     MOVE *BLANK    XXRENO
     C                     ENDIF
      *
     C                     EXCPT@DTL1
      *
     C           SVRENO    IFEQ *BLANK
     C                     MOVELAERENO    SVRENO 20
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *--------------------------------------------------
      * PRINT AB#PP2A DATA                              -
      *--------------------------------------------------
     C           #DTL2     BEGSR
      *
     C                     MOVELSVRENO    @@14   14
JW1  C           @@14      SETLLAB#PL2I
     C                     DO   *HIVAL
JW1  C           @@14      READEAB#PL2I                  95
     C   95                LEAVE
JW2  C                     MOVELACODRN    XXODRN 12
JW2  C                     Z-ADDACQNTY    XXQNTY  50
     C                     EXCPT@DTL2
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *  INITIALIZE
      *-----------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#KEY     KLIST
     C                     KFLD           ADCRDT
     C                     KFLD           ADCRTM
     C                     KFLD           ADPLNT
      *
     C                     MOVE *ALL'-'   @LINE 132
     C                     TIME           @@TIME  60
     C                     MOVE *BLANK    @@REF  20
      *
     C                     ENDSR
