     OQPRINT  E   01           @HED1
     O                         #PGM       9
     O                                   99 'DATE'
     O                         UDATE Y  102
     O                         @@TIME   112 '  :  :  '
     O                                  115 'P.'
     O                         PAGE  Z  119
