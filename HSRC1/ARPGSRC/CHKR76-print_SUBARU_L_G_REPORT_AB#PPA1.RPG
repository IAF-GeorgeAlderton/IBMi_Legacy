     H            Y.
     F***CHKR76*****************************************************************
     F*  PROGRAM    : PRINT SUBARU "L" "G" REPORT                              *
     F*  WRITTEN    : 7/24/2019                                                *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#PLAJ IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      **************************************************************************
     I            DS
     I                                        1  10 BAODRN
     I                                        1   1 ORD1
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C                     EXSR #MAIN
      *
     C           SEQ#      IFGE 1
     C                     MOVE '*'       $RTN
     C                     ELSE
     C                     MOVE ' '       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  MAIN RUOTINE                                      *
      *----------------------------------------------------*
     C           #MAIN     BEGSR
      *
     C                     Z-ADDTODAY     K#NOHZ
     C           K#PLAJ    SETLLAB#PLAJ
     C                     DO   *HIVAL
     C                     READ AB#PLAJ                  98
     C   98                LEAVE
      *
     C           BANONY    IFNE 3611
     C                     LEAVE
     C                     ENDIF
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * PRINT
     C           ORD1      IFEQ 'L'
     C           ORD1      OREQ 'G'
     C                     EXSR #PRINT
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      * PRINT HEADER
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD4         LIN#
     C                     ENDIF
      * PRINT BREAK
     C           BANOHZ    IFNE SVNOHZ
     C           SEQ#      ANDNE0
     C                     EXCPT@BRK
     C                     ADD  1         LIN#
     C                     Z-ADDBANOHZ    SVNOHZ
     C                     ENDIF
      * ADJUST
     C           BACRME    IFEQ 'EDIUSER'
     C                     MOVEL'EDI862'  @USER   6 P
     C                     ELSE
     C                     MOVELBACRME    @USER
     C                     ENDIF
      * PRINT DETAIL
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C           K#PLAJ    KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#NKOJ  1
     C                     KFLD           K#NUKE  4
     C                     KFLD           K#NOHZ  80
      *
     C                     TIME           @SDATE
     C                     Z-ADD3611      K#NONY
     C                     MOVEL'0'       K#NKOJ
     C                     MOVEL'00  '    K#NUKE
     C                     Z-ADDTODAY     K#NOHZ
     C                     Z-ADD0         SVNOHZ  80
      *
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** SUBARU "L" "G" OR'
     O                                   60 'DER REPOPT BY SHIP D'
     O                                   80 'ATE **              '
     O                                   99 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                         PAGE  Z  109
     O                                  106 'P.'
     O        E   02           @HDR
     O                                   15 'SHIP DATE FROM:'
     O                         TODAY     26 '    /  /  '
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   11 'CUST'
     O                                   17 'DELV'
     O                                   27 'SHP_DATE'
     O                                   33 'BIN'
     O                                   44 'USER_PART'
     O                                   58 'ORDER#'
     O                                   76 'QTY'
     O                                   81 'TYPE'
     O                                   90 'CRT_DATE'
     O                                   98 'TIME'
     O                                  106 'BY'
     O        E   04           @HDR
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O                                  120 '--------------------'
     O                                  130 '----------'
     O        E 1              @DTL
     O                         SEQ#  Z +001
     O                         BATOKU  +002
     O                         BANONY  +002
     O                         BANOHZ  +002 '    /  /  '
     O                         BANOBN  +002
     O                         BAMHN1  +002
     O                         BAMHN2  +001
     O                         BAMHN3  +001
     O                         BAODRN  +000
     O                         BASRYO1 +001
     O                         BAEDIK  +003
     O                         BACRHZ  +002 '    /  /  '
     O                         BACRTM  +002 '0 :  :  '
     O                         @USER   +002
     O        E 1              @BRK
     O                                    1 '.'
