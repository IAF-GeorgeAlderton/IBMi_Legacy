TCHK1C           KEY9A     CHAINAH#WP3Y              88
     C                     Z-ADDAHBIN     AHBN
     C                     Z-ADDAHYMD     @AHYMD
     C                     Z-ADDAHYMD     WYMDX
     C                     Z-ADDAHYM      @KYM
     C*----------------------------------------------------*
     C* SET   HEADER
     C*----------------------------------------------------*
     C           US        CHAINRGAPL111             90
     C  N90                MOVELJ8NAME    J8NM             USER NAME
     C   90                MOVEL*BLANK    J8NM
     C*----------------------------------------------------*
     C* WRITE HEADER
     C*----------------------------------------------------*
     C                     SETOF                     10
     C                     ADD  1         PAG     50
     C                     Z-ADD*DATE     WDATE0
     C                     TIME           STMDT
     C                     Z-ADDITIME     @STIME
     C                     WRITEHED
     C                     SETOF                     21
     C*----------------------------------------------------*
     C* EDIT PART NUMBER
     C*----------------------------------------------------*
     C                     MOVE AHZAIS    @ZAIS
     C                     Z-ADDAHZAIK    @ZAIK
      *
     C*---------------------------------------------------------------*
     C* CHANGE GET THE DATE OF INVESTIGATION + 1 DAY
     C*      GET THE DATE OF INVESTIGATION
     C*---------------------------------------------------------------*
     C                     MOVE AHYY      #KHY
     C                     MOVE AHMM      #KHM
     C                     MOVE AHDD      #KHD
     C*---------------------------------------------------------------*
     C*  ..BEFORE 10 DAYS WORKING DAY
     C*---------------------------------------------------------------*
     C           KEY2      SETGTAGDPL121
     C                     Z-ADD11        U       20
     C                     Z-ADD0         @YMD
     C                     Z-ADD0         YMD8
     C                     Z-ADD0         HMD
     C                     MOVE *BLANK    HCD
     C                     Z-ADD0         CNT     20
      *
B01  C           1         DO   10        I       20
     C                     SETOF                     20
     C                     READPAGDPL121                 99
B02  C           *IN99     IFEQ '0'
B03  C           I         IFEQ 1
     C                     Z-ADDF8YMD     WSYMD   80
E03  C                     END
      *
     C                     Z-ADDF8YMD     WYMD
      *
     C                     SUB  1         U
     C                     Z-ADDF8MD      HMD,U
     C                     Z-ADDF8YMD     @YMD,U
     C                     Z-ADDF8YMD     YMD8,U
      *
B03  C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     MOVE '*'       HCD,U
     C*
     C* SUMMARY WORKING DAYS FOR DELIVERY RESULT AVERAGE
     C                     ELSE
     C                     ADD  1         CNT
E03  C                     END
      *
E02  C                     END
E01  C  N99                END
      *
     C                     MOVE WYMD      PYMD1
     C                     MOVE WSYMD     PYMD2
     C*---------------------------------------------------------------*
     C*  AFTER 10 DAYS WORKING DAYS
     C*  FROM INVESTIGATION DAY + 1DAY
     C*---------------------------------------------------------------*
     C                     MOVE AHYY      #KHY
     C                     MOVE AHMM      #KHM
     C                     MOVE AHDD      #KHD
     C           KEY2      SETGTAGDPL121
     C                     Z-ADD0         U       20
     C                     Z-ADD10        Q       20
     C                     Z-ADD10        S       20
     C                     Z-ADD0         @HMD
     C                     MOVE *BLANK    @HCD
      *
B01  C           1         DO   10        I       20
     C                     SETOF                     20
     C                     READ AGDPL121                 99
B02  C           *IN99     IFEQ '0'
B03  C           I         IFEQ 1
     C                     Z-ADDF8YMD     WDATE2           PRTF(FROM)2ND.
     C                     MOVE F8KAYY    FXKAY4
     C                     MOVE F8KAMM    FXKAMM
     C                     MOVE F8KADD    FXKADD
     C                     Z-ADDF8YMD     WKSYMD  80
     C                     Z-ADDF8YMD8    WSYMD8  80
E03  C                     END
      *
     C                     MOVE F8KAYY    FXKAY4
     C                     MOVE F8KAMM    FXKAMM
     C                     MOVE F8KADD    FXKADD
     C                     Z-ADDF8YMD     WKEYMD  80
     C                     Z-ADDF8YMD8    WEYMD8  80
      *
     C                     ADD  1         U
     C                     ADD  1         Q
     C                     ADD  1         S
     C                     Z-ADDF8MD      @HMD,U
     C                     Z-ADDF8YMD     @YMD,S
     C                     Z-ADDF8YMD     YMD8,S
      *
B03  C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     MOVE '*'       @HCD,U
E03  C                     END
E02  C                     END
E01  C  N99                END
     C                     Z-ADDF8YMD     @WSYMD           PRTF(TO)2ND.
      *
     C                     MOVE AHYY      #KHY
     C                     MOVE AHMM      #KHM
     C                     MOVE '00'      #KHD
     C* SUMMARY N MONTH WORKING DAY
     C           KEY2      SETLLAGDPL121
B01  C           *IN99     DOUEQ*ON
     C           KEY5      READEAGDPL121                 99
     C           *IN99     IFEQ *OFF
B02  C           F8HIRU    ANDEQ' '
     C           F8YORU    ANDEQ' '
     C                     ADD  1         WKDAY1  20
E02  C                     ENDIF
     C*
E01  C                     ENDDO
     C* WORKING DAY
     C                     Z-ADDWKDAY1    @CDS
TCHK2C*TCHK1     K@KAKE    IFEQ 0002
TCHK2C           K@KAKE    IFEQ 8990
TCHK1C                     MOVE '1'       @ASJ
TCHK1C                     ELSE
TCHK1C                     MOVE *BLANK    @ASJ    1
TCHK1C                     ENDIF
TCHK1 *
TCHK1C           K@KAKE    CHAINFGBPL01              92
TCHK1C           *IN92     IFEQ *OFF
TCHK1C                     MOVELB2SMEI    ISUPNM
TCHK1C                     ELSE
TCHK1C                     MOVEL*BLANK    ISUPNM
TCHK1C                     ENDIF
TCHK1 *
