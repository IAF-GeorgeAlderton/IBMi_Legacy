     C                     Z-ADD0         IGH
     C                     Z-ADD0         D       20
     C                     MOVE *BLANK    BNCHI
     C*
TCHK1C           KEY9      SETGTIZAPL01
     C           *IN98     DOUEQ*ON
TCHK1C           KEY9      REDPEIZAPL01                  98
B01  C           *IN98     IFEQ *OFF
B02  C           ZCSKJY    ANDNE'D'
     C*
TCHK1C           ZCKAKE    IFNE K@KAKE
TCHK1C                     ITER
TCHK1C                     END
