     C                     Z-ADD0         CBMN
     C                     Z-ADD0         HKB
     C                     MOVE *BLANK    CKEY   10
      *
     C*--------------------*
     C*   ..SCREEN 1
     C*--------------------*
     C           STP1      TAG
     C                     EXFMTGCQPW321
     C                     SETOF                     010203
     C                     SETOF                     99
     C                     MOVE *BLANK    SHN
     C                     MOVE *BLANK    WKTI
     C                     MOVE *BLANK    WBMN
     C                     MOVE *BLANK    WKBN
      *
     C           *INKA     IFEQ '1'
     C                     MOVE CNT       PCNT
     C                     MOVE NO        PNO
     C           *INU1     IFEQ '1'
     C           NO        IFEQ '1'
     C                     EXSR HSUB
     C                     ELSE
     C                     EXSR SSUB
     C                     END
     C                     END
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C*--------------------*
     C*   FACTORY APPOINTMENT
     C*--------------------*
     C*          PKOJ      IFNE '0'
     C*          PKOJ      ANDNE'1'
     C*          PKOJ      ANDNE'2'
     C*          PKOJ      ANDNE'3'
     C*          PKOJ      ANDNE'4'
     C*          PKOJ      ANDNE'5'
     C*          PKOJ      ANDNE'6'
     C           PKOJ      IFNE '6'
     C                     SETON                     0399
     C                     MOVE ER,12     MSG
     C                     GOTO STP1
     C                     END
      *
     C*--------------------*
     C*   CONDITION APPOINTMENT
     C*--------------------*
     C           NO        IFNE '1'
     C           NO        ANDNE'2'
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
      *
     C*--------------------------*
     C*  LIST ORDER
     C*--------------------------*
     C           PRTY      IFNE '1'
     C           PRTY      ANDNE'2'
     C                     SETON                     0299
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
      *
     C*----------------*
     C*   NUMBER OF COPY
     C*----------------*
     C           CNT       IFEQ 0
     C                     Z-ADD1         CNT
     C                     END
      *
     C*--------------------*
     C*    SCREEN 2
     C*--------------------*
     C           NO        IFEQ '1'
     C           STP10     TAG
     C                     EXFMTGCQPW322
     C                     SETOF                     0199
      *
     C           *INKA     IFEQ '1'
     C                     MOVE CNT       PCNT
     C                     MOVE NO        PNO
     C           *INU1     IFEQ '1'
     C                     EXSR HSUB
     C                     END
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           *INKB     IFEQ '1'
     C                     MOVE *BLANK    PKOJ
     C                     MOVE *BLANK    PRTY
     C           *IN50     IFEQ '0'
     C                     MOVE *BLANK    NO
     C                     Z-ADD1         CNT
     C                     END
     C                     GOTO STP1
     C                     END
      *
     C*--------------------*
     C*   INTRAL COMPANY PART NUMBER
     C*--------------------*
     C           SHN       IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,3      MSG
     C                     GOTO STP10
     C                     END
      *
     C*--------------------------*
     C*  DIE ALLOTMENT M/F
     C*--------------------------*
%0001C           SHN       IFNE *ALL'9'
     C                     SETOF                     31
     C           KEY       SETLLGCQPL311
     C                     DO   *HIVAL
     C                     SETOF                     30
     C           KEY       READEGCQPL311                 30
     C           *IN30     IFEQ '0'
     C           DFSKJY    IFEQ 'D'
     C           DFSKHZ    ANDLE*DATE
     C                     ELSE
     C                     SETON                     3031
     C                     END
     C                     END
     C  N30                ENDDO
     C           *IN31     IFEQ '0'
     C                     SETON                     0199
     C                     MOVE ER,4      MSG
     C                     GOTO STP10
     C                     END
      *
     C*------------------------*
     C*  CHECK OF REPETITION
     C*------------------------*
     C                     SETOF                     30
     C           SHN       LOKUPHSN                      30
     C           *IN30     IFEQ '1'
     C                     SETON                     0199
     C                     MOVE ER,5      MSG
     C                     GOTO STP10
     C                     END
      *
     C           A         IFGE 9999
     C                     SETON                     0199
     C                     MOVE ER,10     MSG
     C                     GOTO STP10
     C                     END
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP10
     C                     END
      *
     C                     SETON                     50U1
     C                     ADD  1         A
     C                     MOVE PKOJ      HKJ,A
     C                     MOVE SHN       HSN,A
     C                     MOVE PRTY      HPY,A
     C                     MOVE SHN1      HIN1
     C                     MOVE '-'       HIN2
     C                     MOVE SHN2      HIN3
     C                     MOVE '-'       HIN4
     C                     MOVE SHN3      HIN5
     C                     MOVE *BLANK    SHN
     C                     GOTO STP10
     C                     END
%0001C                     END
      *
     C*--------------------------*
     C*  DIE ALLOTMENT M/F
%0001C*--------------------------*
     C           SHN       IFEQ *ALL'9'
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP10
     C                     END
      *
     C                     SETOF                     31
     C           *LOVAL    SETLLGCQPL311
     C                     DO   *HIVAL
     C                     SETOF                     30
     C                     READ GCQPL311                 30
     C           *IN30     IFEQ '0'
     C           DFSHIN    IFNE WSHN
     C                     MOVELDFSHIN    WSHN   12
     C           DFSKJY    IFEQ 'D'
     C           DFSKHZ    ANDLE*DATE
     C                     ELSE
     C                     SETON                     31
     C*------------------------*
     C*  CHECK OF REPETITION
     C*------------------------*
     C                     SETOF                     40
     C           SHN       LOKUPHSN                      40
     C           *IN40     IFEQ '0'
      *
     C           A         IFGE 9999
     C                     GOTO STP10
     C                     END
      *
     C                     SETON                     50U1
     C                     ADD  1         A
     C                     MOVE PKOJ      HKJ,A
     C                     MOVE DFSHIN    HSN,A
     C                     MOVE PRTY      HPY,A
     C                     END
      *
     C                     END
     C                     END
     C                     END
     C  N30                END
     C           *IN31     IFEQ '0'
     C                     SETON                     0199
     C                     MOVE ER,13     MSG
     C                     GOTO STP10
     C                     END
     C                     MOVE SHN1      HIN1
     C                     MOVE '-'       HIN2
     C                     MOVE SHN2      HIN3
     C                     MOVE '-'       HIN4
     C                     MOVE SHN3      HIN5
     C                     MOVE *BLANK    SHN
     C                     GOTO STP10
     C                     END
%0001 *
     C*--------------------*
     C*  SCREEN 3
     C*--------------------*
     C           STP20     TAG
     C                     EXFMTGCQPW323
     C                     SETOF                     010203
     C                     SETOF                     99
      *
     C           *INKA     IFEQ '1'
     C                     MOVE CNT       PCNT
     C                     MOVE NO        PNO
     C           *INU1     IFEQ '1'
     C                     EXSR SSUB
     C                     END
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           *INKB     IFEQ '1'
     C                     MOVE *BLANK    PKOJ
     C                     MOVE *BLANK    PRTY
     C           *IN50     IFEQ '0'
     C                     MOVE *BLANK    NO
     C                     Z-ADD1         CNT
     C                     END
     C                     GOTO STP1
     C                     END
      *
     C*----------------------------*
     C*  PROCESS. DEPARTMENT. MACHINE NO
     C*----------------------------*
     C           WKTI      IFEQ *BLANK
     C           WBMN      ANDEQ*BLANK
     C           WKBN      ANDEQ*BLANK
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,11     MSG
     C                     GOTO STP20
     C                     END
      *
     C*----------------*
     C*   PROCESS
     C*----------------*
     C           WKTI      IFNE *BLANK
     C                     SETOF                     30
     C           WKTI      CHAINFCETL03              30
     C           *IN30     IFEQ '0'
     C           A6GSKD    ANDEQ'D'
     C           A6GSHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '1'
     C                     SETON                     0199
     C                     MOVE ER,6      MSG
     C                     GOTO STP20
     C                     END
     C                     END
      *
     C*----------------*
     C*  DEPARTMENT
     C*----------------*
     C                     MOVE *BLANK    WSMI
     C           WBMN      IFNE *BLANK
     C                     SETOF                     30
     C                     MOVE WBMN      CBMN    40
     C           CBMN      CHAINFGBPL011             30
     C           *IN30     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '1'
     C           CBMN      ORNE 0111
     C                     SETON                     0299
     C                     MOVE ER,7      MSG
     C                     GOTO STP20
     C                     END
     C                     MOVELB2SMEI    WSMI
     C                     END
      *
     C*----------------------------*
     C*  MACHINE ABILITY M/F
     C*----------------------------*
     C           WBMN      IFNE *BLANK
     C           WKBN      IFNE *BLANK
     C                     SETOF                     30
     C           KEY1      CHAINMFAPL221             30
     C           *IN30     IFEQ '0'
     C           M@SKJY    ANDEQ'D'
     C           M@SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '1'
     C                     SETON                     0399
     C                     MOVE ER,8      MSG
     C                     GOTO STP20
     C                     END
     C                     END
     C                     END
      *
     C*------------------------*
     C*   CHECK OF REPETITION
     C*------------------------*
     C                     SETOF                     30
     C                     MOVE WKTI      HKTI
     C                     Z-ADDCBMN      HBMN
     C                     MOVE WKBN      HKBN
     C           HKEY      LOKUPHRT                      30
     C           *IN30     IFEQ '1'
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,9      MSG
     C                     GOTO STP20
     C                     END
      *
     C           A         IFGE 9999
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,10     MSG
     C                     GOTO STP10
     C                     END
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP20
     C                     END
      *
     C                     SETON                     50U1
     C                     ADD  1         A
     C                     MOVE PKOJ      HKJ,A
     C                     MOVE HKEY      HRT,A
     C                     MOVE PRTY      HPY,A
     C                     MOVE WKTI      ZKTI
     C                     MOVE WBMN      ZBMN
     C                     MOVE WKBN      ZKBN
     C                     MOVE WSMI      ZSMI
     C                     MOVE *BLANK    WKTI
     C                     MOVE *BLANK    WBMN
     C                     MOVE *BLANK    WKBN
     C                     Z-ADD0         CBMN
     C                     MOVE *BLANK    WSMI
     C                     GOTO STP20
      *
     C*------------------------*
     C*    SUB ROUTIN    *
     C* INTRAL COMPANY PART NUMBER APPOINTMENT
     C*------------------------*
     C           HSUB      BEGSR
     C                     SETOF                     32U1
     C                     Z-ADD1         X       40
     C           1         DO   9999      X
     C           HSN,X     IFEQ *BLANK
     C                     SETON                     32
     C                     ELSE
      *
     C*------------------------------------*
     C*  INTRAL KANBAN CHANGE M/F
     C*------------------------------------*
     C                     SETOF                     30
     C                     MOVE HSN,X     SHN
     C                     MOVE HKJ,X     WHKOJ   1
     C                     MOVE HPY,X     WPRTY   1
     C                     MOVE SHN1      WHIN1   5
     C                     MOVE SHN2      WHIN2   5
     C                     MOVE SHN3      WHIN3   2
     C                     MOVE *BLANK    HKO
     C                     Z-ADD0         HBM
     C                     MOVE *BLANK    HKN
     C                     MOVE *BLANK    HKS
     C           KEY       CHAINAAMPL111             30
     C           *IN30     IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
      *
     C           *IN30     IFEQ '0'
     C                     Z-ADD1         A
     C                     Z-ADD0         B       30
     C           1         DO   10        A
     C                     MOVELCKHZ,A    Z06     80
     C*          Z06       IFLE UDATE
     C           CKKO,A    IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE CKKO,A    HKO,B
     C                     Z-ADDCKBM,A    HBM,B
     C                     MOVE CKKB,A    HKN,B
     C                     END
     C*                    ELSE
      *
     C*          CKQK,A    IFNE *BLANK
     C*                    ADD  1         B
     C*                    MOVE CKQK,A    HKO,B
     C*                    Z-ADDCKQB,A    HBM,B
     C*                    MOVE CKQN,A    HKN,B
     C*                    END
     C*                    END
     C                     END
     C                     END
      *
     C                     EXSR $NWCHK
     C                     EXSR SUBRTN
      *
     C                     END
     C  N32                END
     C                     ENDSR
      *
     C*--------------------------------*
     C*    SUB ROUTIN
     C*    PROCESS. DEPARTMENT. MACHINE NO APPOINTMENT
     C*--------------------------------*
     C           SSUB      BEGSR
     C                     SETOF                     30U1
     C                     Z-ADD1         X
     C                     Z-ADD0         B
     C                     Z-ADD0         C       30
     C                     Z-ADD0         D       30
     C                     Z-ADD0         E       30
     C                     Z-ADD0         F       30
     C                     Z-ADD0         G       30
     C           1         DO   9999      X
     C           HRT,X     IFEQ *BLANK
     C                     SETON                     30
     C                     ELSE
      *
     C                     MOVE HRT,X     HKEY
     C                     MOVE HKJ,X     WHKOJ
     C                     MOVE HPY,X     WPRTY
     C           HBMN      IFEQ 0
     C           HKBN      ANDEQ*BLANK
     C                     ADD  1         B
     C                     MOVE HKTI      HKT,B
     C                     GOTO STP21
     C                     END
      *
     C           HKTI      IFEQ *BLANK
     C           HKBN      ANDEQ*BLANK
     C                     ADD  1         C
     C                     Z-ADDHBMN      HKB,C
     C                     GOTO STP21
     C                     END
      *
     C           HKTI      IFEQ *BLANK
     C           HBMN      ANDEQ0
     C                     ADD  1         D
     C                     MOVE HKBN      HKI,D
     C                     GOTO STP21
     C                     END
      *
     C           HKBN      IFEQ *BLANK
     C                     ADD  1         E
     C                     MOVELHKTI      WKTBM   7
     C                     MOVE HBMN      WKTBM
     C                     MOVE WKTBM     HK1,E
     C                     GOTO STP21
     C                     END
      *
     C           HBMN      IFEQ 0
     C                     ADD  1         F
     C                     MOVELHKTI      WKTKI   6
     C                     MOVE HKBN      WKTKI
     C                     MOVE WKTKI     HK2,F
     C                     GOTO STP21
     C                     END
      *
     C           HKTI      IFEQ *BLANK
     C                     ADD  1         G
     C                     MOVELHBMN      WBMKI   7
     C                     MOVE HKBN      WBMKI
     C                     MOVE WBMKI     HK3,G
     C                     END
      *
     C           STP21     TAG
     C                     END
     C  N30                END
      *
     C*------------------------------------*
     C*  INTRAL KANBAN CHANGE M/F
     C*------------------------------------*
     C           *LOVAL    SETLLAAMPL111
     C                     DO   *HIVAL
     C                     SETOF                     60
     C                     READ AAMPL111                 60
     C           *IN60     IFEQ '0'
     C           CKSKJY    IFEQ 'D'
     C           CKSKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     Z-ADD1         A
     C                     Z-ADD0         B
     C                     MOVE *BLANK    HKO
     C                     Z-ADD0         HBM
     C                     MOVE *BLANK    HKN
     C                     MOVE *BLANK    HKS
     C                     MOVE CKHIN1    WHIN1
     C                     MOVE CKHIN2    WHIN2
     C                     MOVE CKHIN3    WHIN3
     C           1         DO   10        A
     C                     MOVELCKHZ,A    Z06
     C*          Z06       IFLE UDATE
     C           CKKO,A    IFNE *BLANK
     C                     ADD  1         B
     C                     MOVE CKKO,A    HKO,B
     C                     Z-ADDCKBM,A    HBM,B
     C                     MOVE CKKB,A    HKN,B
     C                     END
     C*                    ELSE
     C*                    ADD  1         B
     C*                    MOVE CKQK,A    HKO,B
     C*                    Z-ADDCKQB,A    HBM,B
     C*                    MOVE CKQN,A    HKN,B
     C*                    END
     C                     END
      *
     C                     SETOF                     61
     C                     Z-ADD1         A
     C           1         DO   10        A
     C           HKO,A     IFEQ *BLANK
     C                     SETON                     61
     C                     ELSE
      *
     C                     MOVE HKO,A     HKTI
     C                     Z-ADDHBM,A     HBMN
     C                     MOVE HKN,A     HKBN
      *
     C                     Z-ADD1         X       40
     C           1         DO   9999      X
     C                     SETOF                     62
     C           HRT,X     IFEQ *BLANK
     C                     SETON                     62
     C                     ELSE
      *
     C                     MOVE HRT,X     CKEY
     C           HRT,X     IFEQ HKEY
     C                     EXSR $NWCHK
     C                     EXSR SUBRTN
     C                     GOTO STP22
     C                     END
      *
     C                     MOVELHKTI      WKTBM
     C                     MOVE HBMN      WKTBM
     C           HK1,X     IFEQ WKTBM
     C                     EXSR $NWCHK
     C                     EXSR SUBRTN
     C                     GOTO STP22
     C                     END
      *
     C                     MOVELHKTI      WKTKI
     C                     MOVE HKBN      WKTKI
     C           HK2,X     IFEQ WKTKI
     C                     EXSR $NWCHK
     C                     EXSR SUBRTN
     C                     GOTO STP22
     C                     END
      *
     C                     MOVELHBMN      WBMKI
     C                     MOVE HKBN      WBMKI
     C           HK3,X     IFEQ WBMKI
     C                     EXSR $NWCHK
     C                     EXSR SUBRTN
     C                     GOTO STP22
     C                     END
      *
     C           HKT,X     IFEQ HKTI
     C                     EXSR $NWCHK
     C                     EXSR SUBRTN
     C                     GOTO STP22
     C                     END
      *
     C           HKB,X     IFEQ HBMN
     C                     EXSR $NWCHK
     C                     EXSR SUBRTN
     C                     GOTO STP22
     C                     END
      *
     C           HKBN      IFNE *BLANK
     C           HKI,X     IFEQ HKBN
     C                     EXSR $NWCHK
     C                     EXSR SUBRTN
     C                     GOTO STP22
     C                     END
     C                     END
      *
     C           STP22     TAG
     C                     END
     C  N62                END
     C                     END
     C  N61                END
      *
     C                     END
     C                     END
     C  N60                END
     C                     ENDSR
      *
     C*--------------------------------*
     C*   SUB ROUTIN
     C*--------------------------------*
     C           SUBRTN    BEGSR
      *
     C                     SETON                     6162
      *
     C*----------------------------*
     C* MACHINE ABILITY M/F
     C*----------------------------*
     C                     Z-ADD1         B
     C           1         DO   10        B
     C           KEY2      CHAINMFAPL221             30
     C           *IN30     IFEQ '0'
     C           M@SKJY    IFEQ 'D'
     C           M@SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVE M@KEIS    HKS,B
     C                     END
     C                     END
     C                     END
      *
     C*--------------------------*
     C*   DIE ALLOTMENT M/F
     C*--------------------------*
     C           KEY3      SETLLGCQPL311
     C                     DO   *HIVAL
     C                     SETOF                     33
     C           KEY3      READEGCQPL311                 33
     C           *IN33     IFEQ '0'
     C           DFSKJY    IFEQ 'D'
     C           DFSKHZ    ANDLE*DATE
     C                     ELSE
      *
     C*------------------------------------*
     C* CHECK OF NEW DIE NO.  AND  OLD DIE NO.
     C*------------------------------------*
     C                     SETON                     31
     C                     Z-ADD1         B
     C           1         DO   15        B
     C           B         IFLE 7
     C           B         IFEQ 3
     C           DFKA,B    IFNE '-'
     C                     SETOF                     31
     C                     END
     C                     ELSE
     C                     SETOF                     31
     C           DFKA,B    LOKUPDEC                      31
     C                     END
     C                     ELSE
     C           DFKA,B    IFNE *BLANK
     C                     SETOF                     31
     C                     END
     C                     END
     C   31                END
      *
     C*------------------------------------*
     C*   DIE SPEC INPUT CODE M/F
     C*------------------------------------*
     C                     MOVE *BLANK    WNKAT
     C                     MOVE *BLANK    WOKAT  15
     C                     MOVE *BLANK    WKATA
     C                     MOVE *BLANK    WKANM  10
     C                     MOVE *BLANK    CNKAT
     C           *IN31     IFEQ '1'
     C                     MOVE DFKATA    WNKAT
     C                     SETOF                     30
     C           WKAT1     CHAINFCQPL211             30
     C           *IN30     IFEQ '0'
     C           O9SKJY    ANDEQ'D'
     C           O9SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '0'
     C                     MOVELO9KANM    WKANM
     C                     END
      *
     C*--------------------------*
     C*   DIE SPEC M/F
     C*--------------------------*
     C                     SETOF                     30
     C           KEY4      CHAINFCQPL311             30
     C           *IN30     IFEQ '0'
     C           Q4SKJY    ANDEQ'D'
     C           Q4SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '0'
     C                     MOVELQ4QKAT    WOKAT
     C                     END
     C                     ELSE
      *
     C*--------------------------*
     C*   DIE SPEC M/F
     C*--------------------------*
     C                     SETOF                     30
     C                     MOVE DFKATA    WOKAT
     C           DFKATA    CHAINFCQPL321             30
     C           *IN30     IFEQ '0'
     C           Q4SKJY    ANDEQ'D'
     C           Q4SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '0'
     C                     MOVE Q4KAT1    CNKT1
     C                     MOVE '-'       CN1
     C                     MOVE Q4KAT2    CNKT2
     C                     MOVE CNKAT     WNKAT
      *
     C*------------------------------------*
     C*  DIE SPEC INPUT CODE M/F
     C*------------------------------------*
     C                     SETOF                     30
     C           Q4KAT1    CHAINFCQPL211             30
     C           *IN30     IFEQ '0'
     C           O9SKJY    ANDEQ'D'
     C           O9SKHZ    ANDLE*DATE
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '0'
     C                     MOVELO9KANM    WKANM
     C                     END
     C                     END
     C                     END
      *
     C           WPRTY     IFEQ '1'
     C                     MOVE WNKAT     WKATA
     C                     ELSE
     C                     MOVE WOKAT     WKATA
     C                     END
      *
     C*------------------------------*
     C*   DIE KANBAN M/F
     C*   NEW DIE NO
     C*------------------------------*
     C           KEYA1     KLIST
     C                     KFLD           @NKT1
     C                     KFLD           @NKT2
     C                     KFLD           @NKT3
      *
     C                     MOVE *BLANK    WTKRO
     C           WNKAT     IFNE *BLANK
     C                     MOVE *BLANK    @NKAT
     C                     MOVE WNKT1     @NKT1
     C                     MOVE WNKT2     @NKT2
      *
     C           KEYA1     SETLLGCQPL121
     C                     DO   *HIVAL
     C                     SETOF                     30
     C           KEYA1     READEGCQPL121                 30
     C           *IN30     IFEQ '0'
     C           T6SKJY    IFEQ 'D'
     C           T6SKHZ    ANDLE*DATE
     C                     ELSE
     C           *DATE     IFGE T6KIHZ
     C                     SETON                     30
     C                     MOVE T6TKR2    WTKR2
     C                     MOVE T6TKR3    WTKR3
     C                     MOVE T6TKR4    WTKR4
     C                     END
     C                     END
     C                     END
     C  N30                END
     C                     ELSE
      *
     C*------------------------------*
     C*   DIE KANBAN M/F
     C*   OLD DIE NO
     C*------------------------------*
     C*          WOKAT     SETLLGCQTL121
     C*                    DO   *HIVAL
     C*                    SETOF                     30
     C*          WOKAT     READEGCQTL121                 30
     C*          *IN30     IFEQ '0'
     C*          T6SKJY    IFEQ 'D'
     C*          T6SKHZ    ANDLE*DATE
     C*                    ELSE
     C*          WHKOJ     IFEQ T6TKR1
     C*                    SETON                     30
     C*                    MOVE T6TKR2    WTKR2
     C*                    MOVE T6TKR3    WTKR3
     C*                    MOVE T6TKR4    WTKR4
     C*                    MOVE T6TKR5    WTKR5
     C*                    END
     C*                    END
     C*                    END
     C* N30                END
     C                     END
      *
     C           WTKR3     IFNE *BLANK
     C                     MOVE '-'       H1
     C                     END
     C           WTKR4     IFNE *BLANK
     C                     MOVE '-'       H2
     C                     END
     C           WTKR5     IFNE *BLANK
     C                     MOVE '-'       H3
     C                     END
      *
     C                     SETON                     U1
      *-- MSK 05.02.99
     C           DFKSEI    IFEQ 99
     C                     MOVEL*BLANK    WKANM
     C                     MOVELER,13     WKANM
     C                     END
      *
     C                     MOVEL'L'       PLST    1
     C                     MOVELNWFLG     @@PRKB  1
      *--
     C                     EXCPTDT
      *
     C                     END
     C                     END
     C  N33                END
     C                     ENDSR
