     C           KEY7      READEWK400L11                 40
     C           *IN40     DOWEQ'0'
     C           NWFLG     ANDEQ'0'
      *
     C           K4SKJY    IFEQ 'D'
     C           K4SKHZ    ANDLE*DATE
