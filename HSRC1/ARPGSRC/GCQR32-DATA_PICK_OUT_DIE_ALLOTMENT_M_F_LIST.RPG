     C           KEY       SETLLGCQPL311
     C                     DO   *HIVAL
     C           KEY       READEGCQPL311                 30
     C   30                LEAVE
     C           DFSKJY    IFEQ 'D'
     C           DFSKHZ    ANDLE*DATE
