      ** UAFR01 **********************************************
      *  UPDATE KANBAN MASTER (AAFPP01) - TEMP               *
      *  J.WATANABE  2020.04.14                              *
      ********************************* UAAR03 ***************
     FUAFPW01 CF  E                    WORKSTN
     FAAFPL05 UF  E           K        DISK
     FAAAPL01 IF  E           K        DISK
     FAAFPP01SO   E                    DISK
      *
     E                    MSG     1   5 60
     E                    A3J         6  2
     E                    AAJ         6  2
     E                    XJK         6  2
     E                    ZJK         6  2
     E                    XJN         6 15
     E                    ZJN         6 15
     I            DS
     I                                        1  12 A3JX
     I                                        1  12 A3J
     I                                        1   2 A3JOK1
     I                                        3   4 A3JOK2
     I                                        5   6 A3JOK3
     I                                        7   8 A3JOK4
     I                                        9  10 A3JOK5
     I                                       11  12 A3JOK6
     I            DS
     I                                        1  12 AAJX
     I                                        1  12 AAJ
     I                                        1   2 AAJOK1
     I                                        3   4 AAJOK2
     I                                        5   6 AAJOK3
     I                                        7   8 AAJOK4
     I                                        9  10 AAJOK5
     I                                       11  12 AAJOK6
     I            DS
     I                                        1  12 XJKX
     I                                        1  12 XJK
     I                                        1   2 XJK1
     I                                        3   4 XJK2
     I                                        5   6 XJK3
     I                                        7   8 XJK4
     I                                        9  10 XJK5
     I                                       11  12 XJK6
     I            DS
