     I           SDS
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *=================================================*
      *                    MAIN ROUTINE                 *
      *=================================================*
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     EXFMTDSP01
     C                     MOVE *BLANK    XMSG
     C                     MOVEA'000000'  *IN,41
     C                     MOVEA'000000'  *IN,51
      *
     C                     SELEC
      * F1 END?
     C           *INKA     WHEQ *ON
     C                     LEAVE
      *
     C                     OTHER
     C                     EXSR #CHK1
      *
     C           *IN85     IFEQ *ON
     C                     ITER
     C                     ENDIF
      *
     C           *INKE     IFEQ *ON
     C                     EXSR #UPD1
     C                     MOVELMSG,5     XMSG
     C                     MOVE *BLANK    XJKX
     C                     MOVE *BLANK    ZJKX
     C                     MOVE *BLANK    XJNX
     C                     MOVE *BLANK    ZJNX
     C                     ELSE
     C                     MOVELMSG,1     XMSG
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *=================================================*
      * CHECK        *
      *=================================================*
     C           #CHK1     BEGSR
      *
     C                     MOVE *OFF      *IN85
     C                     MOVEA*BLANK    XJN
     C                     MOVEA*BLANK    ZJN
     C                     Z-ADD0         XRCD
      *
     C           XJKX      IFEQ *BLANK
     C                     MOVE *ON       *IN85
     C                     MOVEA'111111'  *IN,41
     C                     MOVELMSG,2     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      * CHECK NAME
     C                     EXSR #NAME
     C           *IN85     IFEQ *ON
     C                     GOTO XCHK1
     C                     ENDIF
      * IF NO ERROR...
     C           *LOVAL    SETLLAAFPL05
     C                     DO   *HIVAL
     C                     READ AAFPL05                  98
     C   98                LEAVE
      *
     C           *IN98     IFEQ *OFF
     C           A3SKJY    ANDEQ'D'
     C                     ITER
     C                     ENDIF
      *
     C           *IN98     IFEQ *OFF
     C           A3JX      ANDEQXJKX
     C                     ADD  1         XRCD
     C                     ENDIF
     C                     ENDDO
      *
     C           XRCD      IFEQ 0
     C                     MOVE *ON       *IN85
     C                     MOVEA'111111'  *IN,41
     C                     MOVELMSG,3     XMSG
     C                     ELSE
     C                     MOVELMSG,1     XMSG
     C                     ENDIF
      *
     C           XCHK1     ENDSR
      *=================================================*
      * GET NAME      *
      *=================================================*
     C           #NAME     BEGSR
      * XJN
     C           1         DO   6         IX      20
     C           XJK,IX    IFNE *BLANK
     C                     MOVELXJK,IX    K#JOKN
     C                     MOVEL'C'       K#KANB
     C           K#01      CHAINAAAPL01              99
     C           *IN99     IFEQ *OFF
     C                     MOVELA5JOKM    XJN,IX
     C                     ELSE
     C                     MOVEL'???'     XJN,IX
     C           IX        ADD  40        IY      20
     C                     MOVE *ON       *IN,IY
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,4     XMSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      * ZJN
     C           1         DO   6         IX      20
     C           ZJK,IX    IFNE *BLANK
     C                     MOVELZJK,IX    K#JOKN
     C                     MOVEL'C'       K#KANB
     C           K#01      CHAINAAAPL01              99
     C           *IN99     IFEQ *OFF
     C                     MOVELA5JOKM    ZJN,IX
     C                     ELSE
     C                     MOVEL'???'     ZJN,IX
     C           IX        ADD  50        IY      20
     C                     MOVE *ON       *IN,IY
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,4     XMSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *=================================================*
      * UPDATE        *
      *=================================================*
     C           #UPD1     BEGSR
      *
     C                     Z-ADD0         XRCD
      *
     C           *LOVAL    SETLLAAFPL05
     C                     DO   *HIVAL
     C                     READ AAFPL05                  98
     C   98                LEAVE
      *
     C           A3SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           A3JX      IFEQ XJKX
     C                     ADD  1         XRCD
      * SAVE
     C                     MOVELZJKX      AAJX
     C                     Z-ADDTODAY     AAKOHZ
     C                     Z-ADDNOW       AAKOTM
     C                     MOVEL#USER     AAKOUS
     C                     WRITEAAFP01S1
      * UPD
     C                     MOVELZJKX      A3JX
     C                     UPDATAAFPP011
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *=================================================*
      * INITIALIZATION
      *=================================================*
     C           #INIT     BEGSR
      *
     C           K#01      KLIST
     C                     KFLD           K#JOKN  2
     C                     KFLD           K#KANB  1
      *
     C                     TIME           SDATE
     C                     ENDSR
      *=================================================*
