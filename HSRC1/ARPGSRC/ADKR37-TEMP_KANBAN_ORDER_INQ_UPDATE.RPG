     H            Y.
     F** ADKR37 **********************************
     F*臨時かんばん照会・更新                  *
     F*     KATOGI.        2015.12.21            *
     F********************************************
     FADKPP31 IF  E           K        DISK
     FADKWP36 O   E                    DISK                      A
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
      *
     C           *ENTRY    PLIST
     C                     PARM           P1APHZ  8
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           PCMD    2
      *
     C                     TIME           SDATE
      *
     C                     MOVE P1APHZ    K1APHZ  80
     C           K1APHZ    SETLLADKPP311
     C           K1APHZ    READEADKPP311                 80
     C           *IN80     DOWEQ'0'
     C           D3SKJY    IFEQ 'D'
     C           D3SKHZ    ANDLEWDATE
     C                     ELSE
     C**         D3EFLG    IFEQ *BLANK
     C                     EXSR #SB400
     C**                   ENDIF
     C                     ENDIF
     C           K1APHZ    READEADKPP311                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * SELECT DATA                                        *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEL'1'       GET     1
      *
     C           P1SHN1    IFNE *BLANK
     C           D3SHN1    IFNE P1SHN1
     C                     MOVEL'0'       GET
     C                     ENDIF
     C                     ENDIF
      *
     C           P1SHN2    IFNE *BLANK
     C           D3SHN2    IFNE P1SHN2
     C                     MOVEL'0'       GET
     C                     ENDIF
     C                     ENDIF
      *
     C           P1SHN3    IFNE *BLANK
     C           D3SHN3    IFNE P1SHN3
     C                     MOVEL'0'       GET
     C                     ENDIF
     C                     ENDIF
      *
     C           GET       IFEQ '1'
     C                     EXSR #SB500
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARADKWP361
     C                     MOVELD3SHN1    W6SHN1
     C                     MOVELD3SHN2    W6SHN2
     C                     MOVELD3SHN3    W6SHN3
     C                     Z-ADDD3BARL    W6BARL
     C                     Z-ADDD3MAIS    W6MAIS
     C                     Z-ADDD3APHZ    W6APHZ
     C                     Z-ADDD3APBN    W6APBN
     C                     MOVELD3EFLG    W6EFLG
     C                     Z-ADDD3MAIS    W6CHNG
     C                     WRITEADKWP361
      *
     CSR         ESB500    ENDSR
