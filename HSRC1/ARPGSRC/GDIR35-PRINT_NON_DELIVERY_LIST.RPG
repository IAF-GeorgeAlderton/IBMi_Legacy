     H            Y.                                    1
      ** GDIR35 *******************
      *  PRINT NON-DELIVERY LIST  *
      *  K.YASUDA    2000.11.07   *
      ******************* GDIR35 **
     FGDIPW35 CF  E                    WORKSTN
     FGDIPL15 IF  E           K        DISK
     FGDIPL18 IF  E           K        DISK
     FGDIWP35 O   F     128            DISK
     E                    ER      1   4 59
     E                    MID     1   2 20
     I            DS
     I                                        1   80IISKHZ
     I                                        1   40IISKYY
     I                                        5   60IISKMM
     I                                        7   80IISKDD
      *
     I            DS
     I                                        1   80IIFNHZ
     I                                        1   40IIIFNY
     I                                        5   60IIIFNM
     I                                        7   80IIIFND
      *
     I            DS
     I                                        1   6 IKATA
     I                                        1   2 IKAT1
     I                                        3   6 IKAT2
      *------*
      * PARM *
      *------*
     C           *ENTRY    PLIST
     C                     PARM           PNO     1
      *-----*
      * KEY *
      *-----*
     C           KEY       KLIST
     C                     KFLD           IKAT1
     C                     KFLD           IKAT2
      *-----*
      * INZ *
      *-----*
     C           STP1      TAG
     C                     MOVE *BLANK    @NO
     C                     MOVE *BLANK    IKAT1
     C                     MOVE *BLANK    IKAT2
     C                     MOVE *BLANK    ISODR
     C                     MOVE *BLANK    IEODR
      *----------*
      * SCREEN 1 *
      *----------*
     C           STP2      TAG
     C                     EXFMTGDIPW351
     C                     SETOF                     0199
      *-------*
      * CMD-1 *
      *-------*
     C           *INKA     IFEQ '1'
     C                     SETON                     LRU1
     C                     RETRN
     C                     END
      *------------*
      * SELECT NO. *
      *------------*
     C           @NO       IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVELER,1      MSG
     C                     GOTO STP2
     C                     END
      *
     C           @NO       IFNE '1'
     C           @NO       ANDNE'2'
     C           @NO       ANDNE'3'
     C           @NO       ANDNE'4'
     C                     SETON                     0199
     C                     MOVELER,2      MSG
     C                     GOTO STP2
     C                     END
      *
     C           @NO       IFEQ '1'
     C           @NO       OREQ '3'
     C                     MOVELMID,1     LIST
     C                     END
      *
     C           @NO       IFEQ '2'
     C           @NO       OREQ '4'
     C                     MOVELMID,2     LIST
     C                     END
      *----------*
      * SCREEN 2 *
      *----------*
     C           STP3      TAG
     C                     EXFMTGDIPW352
     C                     SETOF                     010203
     C                     SETOF                     99
      *-------*
      * CMD-3 *
      *-------*
     C           *INKC     IFEQ '1'
     C                     GOTO STP1
     C                     END
      *-----------*
      * ORDER NO. *
      *-----------*
     C           ISODR     IFNE *BLANK
     C           IEODR     ANDNE*BLANK
     C           ISODR     IFGT IEODR
     C                     SETON                       020399
     C                     MOVELER,4      MSG
     C                     GOTO STP3
     C                     END
     C                     END
      *-------*
      * CMD-5 *
      *-------*
     C           *INKE     IFEQ '0'
     C                     GOTO STP3
     C                     END
     C                     MOVE *BLANK    @CHK    1
      *--------------------*
      * PULL OUT PARTS NO. *
      *--------------------*
     C           IKATA     IFNE *BLANK
     C                     Z-ADD0         SODR    60
     C                     Z-ADD0         EODR    60
     C           ISODR     IFNE *BLANK
     C                     MOVELISODR     SODR
     C                     END
     C           IEODR     IFNE *BLANK
     C                     MOVELIEODR     EODR
     C                     END
      *
     C           KEY       SETLLGDIPL15
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY       READEGDIPL15                  10
     C           *IN10     IFEQ '0'
     C           IISKJY    IFEQ 'D'
     C           IISKHZ    ANDLE*DATE
     C                     ELSE
     C           SODR      IFNE 0
     C           EODR      ANDNE0
     C           IIODER    IFGE SODR
     C           IIODER    ANDLEEODR
     C           @NO       IFEQ '1'
     C           @NO       OREQ '3'
     C           IIIFMK    IFEQ *BLANK
     C                     EXCPTDT
     C                     MOVEL'*'       @CHK
     C                     END
     C                     END
     C           @NO       IFEQ '2'
     C           @NO       OREQ '4'
     C                     EXCPTDT
     C                     MOVEL'*'       @CHK
     C                     END
     C                     END
     C                     GOTO JUMP
     C                     END
      *
     C           SODR      IFNE 0
     C           EODR      ANDEQ0
     C           IIODER    IFGE SODR
     C           @NO       IFEQ '1'
     C           @NO       OREQ '3'
     C           IIIFMK    IFEQ *BLANK
     C                     EXCPTDT
     C                     MOVEL'*'       @CHK
     C                     END
     C                     END
     C           @NO       IFEQ '2'
     C           @NO       OREQ '4'
     C                     EXCPTDT
     C                     MOVEL'*'       @CHK
     C                     END
     C                     END
     C                     GOTO JUMP
     C                     END
      *
     C           SODR      IFEQ 0
     C           EODR      ANDNE0
     C           IIODER    IFLE EODR
     C           @NO       IFEQ '1'
     C           @NO       OREQ '3'
     C           IIIFMK    IFEQ *BLANK
     C                     EXCPTDT
     C                     MOVEL'*'       @CHK
     C                     END
     C                     END
     C           @NO       IFEQ '2'
     C           @NO       OREQ '4'
     C                     EXCPTDT
     C                     MOVEL'*'       @CHK
     C                     END
     C                     END
     C                     GOTO JUMP
     C                     END
      *
     C           @NO       IFEQ '1'
     C           @NO       OREQ '3'
     C           IIIFMK    IFEQ *BLANK
     C                     EXCPTDT
     C                     MOVEL'*'       @CHK
     C                     END
     C                     END
     C           @NO       IFEQ '2'
     C           @NO       OREQ '4'
     C                     EXCPTDT
     C                     MOVEL'*'       @CHK
     C                     END
     C           JUMP      TAG
     C                     END
     C                     END
     C  N10                ENDDO
     C                     GOTO END
     C                     END
      *--------------------*
      * PULL OUT ORDER NO. *
      *--------------------*
     C                     Z-ADD0         SODR    60
     C                     Z-ADD0         EODR    60
     C           ISODR     IFNE *BLANK
     C                     MOVELISODR     SODR
     C                     END
     C           IEODR     IFNE *BLANK
     C                     MOVELIEODR     EODR
     C                     END
      *
     C           SODR      IFNE 0
     C           EODR      ORNE 0
     C           SODR      IFEQ 0
     C           *LOVAL    SETLLGDIPL18
     C                     ELSE
     C           SODR      SETLLGDIPL18
     C                     END
     C                     DO   *HIVAL
     C                     SETOF                     10
     C                     READ GDIPL18                  10
     C           *IN10     IFEQ '0'
     C           IISKJY    IFEQ 'D'
     C           IISKHZ    ANDLE*DATE
     C                     ELSE
     C           EODR      IFNE 0
     C           IIODER    IFGT EODR
     C                     SETON                     10
     C                     GOTO SKIP
     C                     END
     C                     END
     C           @NO       IFEQ '1'
     C           @NO       OREQ '3'
     C           IIIFMK    IFEQ *BLANK
     C                     EXCPTDT
     C                     MOVEL'*'       @CHK
     C                     END
     C                     END
     C           @NO       IFEQ '2'
     C           @NO       OREQ '4'
     C                     EXCPTDT
     C                     MOVEL'*'       @CHK
     C                     END
     C                     GOTO SKIP
     C                     END
     C                     END
      *
     C           SKIP      TAG
     C  N10                ENDDO
     C                     GOTO END
     C                     END
      *----------------*
      * ALL ORDER DATA *
      *----------------*
     C                     DO   *HIVAL
     C                     SETOF                     10
     C                     READ GDIPL15                  10
     C           *IN10     IFEQ '0'
     C           IISKJY    IFEQ 'D'
     C           IISKHZ    ANDLE*DATE
     C                     ELSE
     C           @NO       IFEQ '1'
     C           @NO       OREQ '3'
     C           IIIFMK    IFEQ *BLANK
     C                     EXCPTDT
     C                     MOVEL'*'       @CHK
     C                     END
     C                     END
     C           @NO       IFEQ '2'
     C           @NO       OREQ '4'
     C                     EXCPTDT
     C                     MOVEL'*'       @CHK
     C                     END
     C                     END
     C                     END
     C  N10                ENDDO
      *
     C           END       TAG
     C           @CHK      IFEQ *BLANK
     C                     SETON                     99
     C                     MOVELER,3      MSG
     C                     GOTO STP3
     C                     END
      *
     C                     MOVEL@NO       PNO
     C                     SETON                     LR
     C                     RETRN
      *
     OGDIWP35 E                DT
     O                         IIKAT1     2
     O                         IIKAT2     6
     O                         IIKAT3     7
     O                         IIKAT4     8
     O                         IIODER    14
     O                         IIITEM    19
     O                         IIODRY    23
     O                         IIODRM    25
     O                         IIODRD    27
     O                         IISYOS    30
     O                         IIMAIS    35
     O                         IISURY    42
      *
     O                         IIHANY    43
     O                         IIDLVY    47
     O                         IIDLVM    49
     O                         IIDLVD    51
** MSG
E-01 INPUT NO.
E-02 INPUT NUMBER IS DIFFERENT.
E-03 THIS IS NOT IN DAYLY ORDER DATA FILE.
E-04 THE DATA IS PAST OF START DATA.
**
NON-DELIVERY LIST
ORDER HISTORY LIST
