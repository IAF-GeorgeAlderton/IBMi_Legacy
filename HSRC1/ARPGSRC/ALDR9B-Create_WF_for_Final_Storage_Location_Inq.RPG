     FALDPP25 IF  E                    DISK
     FALDWP98 O   E                    DISK                      A
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
      *
     I            DS
     I                                        1   6 A9TBN
     I                                        1   1 A9TBN1
     I                                        2   3 A9TBN2
     I                                        4   5 A9TBN3
     I                                        6   6 A9TBN4
      *
     I            DS
     I                                        1   6 WKMTK
     I                                        1   1 WKMTK1
     I                                        2   3 WKMTK2
     I                                        4   5 WKMTK3
     I                                        6   6 WKMTK4
      *
     I            DS
     I                                        1   6 WKMT2
     I                                        1   1 WKMT21
     I                                        2   3 WKMT22
     I                                        4   5 WKMT23
     I                                        6   6 WKMT24
      *
     I            DS
     I                                        1  12 WKLHN
     I                                        1   5 WKLHN1
     I                                        6  10 WKLHN2
     I                                       11  12 WKLHN3
      *
     I            DS
     I                                        1  140A9DE
     I                                        1   80A9CODT
     I                                        9  140A9COTM
      *
     I            DS
     I                                        1  140WKDE1
     I                                        1   80WKCOH1
     I                                        9  14 WKDET1
      *
     I            DS
     I                                        1  140WKDE2
     I                                        1   80WKCOH2
     I                                        9  14 WKDET2
      *
     C           *ENTRY    PLIST
     C                     PARM           P1MTK1  1
     C                     PARM           P1MTK2  2
     C                     PARM           P1MTK3  2
     C                     PARM           P1MTK4  1
     C                     PARM           P1MT21  1
     C                     PARM           P1MT22  2
     C                     PARM           P1MT23  2
     C                     PARM           P1MT24  1
     C                     PARM           P1COH1  8
     C                     PARM           P1COH2  8
     C                     PARM           P1COUS 10
     C                     PARM           P1HNTE  1
     C                     PARM           P1LHN  12
     C                     PARM           P1DET1  4
     C                     PARM           P1DET2  4
     C                     PARM           PCMD    2
      *
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
     C                     TIME           SDATE
     C                     Z-ADD0         WKSEQ   80
     C                     MOVELP1MTK1    WKMTK1
     C                     MOVELP1MTK2    WKMTK2
     C                     MOVELP1MTK3    WKMTK3
     C                     MOVELP1MTK4    WKMTK4
     C                     MOVELP1MT21    WKMT21
     C                     MOVELP1MT22    WKMT22
     C                     MOVELP1MT23    WKMT23
     C                     MOVELP1MT24    WKMT24
     C                     MOVELP1LHN     WKLHN
     C           WKMT21    IFEQ *BLANK
     C                     MOVEL*HIVAL    WKMT21
     C                     ENDIF
     C           WKMT22    IFEQ *BLANK
     C                     MOVEL*HIVAL    WKMT22
     C                     ENDIF
     C           WKMT23    IFEQ *BLANK
     C                     MOVEL*HIVAL    WKMT23
     C                     ENDIF
     C           WKMT24    IFEQ *BLANK
     C                     MOVEL*HIVAL    WKMT24
     C                     ENDIF
     C                     MOVELP1COH1    WKCOH1  80
     C                     MOVELP1COH2    WKCOH2  80
     C           WKCOH2    IFEQ 0
     C                     Z-ADD99999999  WKCOH2
     C                     ENDIF
     C                     MOVELP1DET1    WKDET1
     C                     MOVE '00'      WKDET1
     C                     MOVELP1DET2    WKDET2
     C           P1DET2    IFEQ '0000'
     C                     MOVEL'9999'    WKDET2
     C                     ENDIF
     C                     MOVE '59'      WKDET2
      *
     C           1         SETLLALDPP251
     C                     READ ALDPP251                 80
     C           *IN80     DOWEQ'0'
     C                     MOVEL'0'       GET     1
     C           A9SKJY    IFEQ 'D'
     C           A9SKDT    ANDLE*DATE
     C                     ELSE
     C                     EXSR #SB400
     C                     ENDIF
     C           GET       IFEQ '1'
     C                     EXSR #SB500
     C                     ENDIF
     C                     READ ALDPP251                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C           WKLHN1    IFNE *BLANKS
     C           A9LHN1    ANDNEWKLHN1
     C                     GOTO ESB400
     C                     ENDIF
      *
     C           WKLHN2    IFNE *BLANKS
     C           A9LHN2    ANDNEWKLHN2
     C                     GOTO ESB400
     C                     ENDIF
      *
     C           WKLHN3    IFNE *BLANKS
     C           A9LHN3    ANDNEWKLHN3
     C                     GOTO ESB400
     C                     ENDIF
      *
     C           A9TBN     IFLT WKMTK
     C                     GOTO ESB400
     C                     ENDIF
      *
     C           A9TBN     IFGT WKMT2
     C                     GOTO ESB400
     C                     ENDIF
      *
     C           A9DE      IFGE WKDE1
     C           A9DE      ANDLEWKDE2
      *                     good
     C                     ELSE
     C                     GOTO ESB400
     C                     ENDIF
      *
     C           P1COUS    IFEQ *BLANK
     C                     ELSE
     C           A9WOKR    IFNE P1COUS
     C                     GOTO ESB400
     C                     ENDIF
     C                     ENDIF
      *
     C                     SELEC
     C           P1HNTE    WHEQ ' '
     C           P1HNTE    WHEQ '1'
     C           A9OKNG    IFNE 'OK'
     C                     GOTO ESB400
     C                     ENDIF
     C           P1HNTE    WHEQ '2'
     C           A9OKNG    IFNE 'NG'
     C                     GOTO ESB400
     C                     ENDIF
     C                     ENDSL
      *
     C                     MOVEL'1'       GET
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARALDWP981
