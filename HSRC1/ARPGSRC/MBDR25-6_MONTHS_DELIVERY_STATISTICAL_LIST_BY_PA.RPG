     H            Y.
     F*** MBDR25 ********************************
     F* 6  MONTHS DELIVERY STATISTICAL LIST BY PART NO *
     F******************************** MBDR25 ***
     FMBDPW25 CF  E                    WORKSTN
     FFCEPL01 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FMBDPL01 IF  E           K        DISK
     FMBDWP25 O   E           K        DISK
     E                    HRT      1000 12               ncﾜhmﾞ-j KEY
     E                    ER      1   4 60               d[-xｮﾈ-ﾆﾞ
     I            DS
     I                                        1  12 @KEY
     I                                        1   5 @HIN1
     I                                        6  10 @HIN2
     I                                       11  12 @HIN3
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     C           *ENTRY    PLIST
     C                     PARM           USER   10
     C                     SETOF                     90
     C*
     C           @SCR1     TAG
     C                     EXFMTMBDPW251
     C                     SETOF                     0199
     C*
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C*
     C* ﾉcpｬcﾅg ﾉ kｩｮh
     C*
     C           @NONY     IFNE *BLANK
     C           @NONY     IFLT '0000'
     C                     SETON                     0299
     C                     MOVELER,03     MSG
     C                     GOTO @SCR1
     C                     END
     C                     MOVE @NONY     $NONY   40
     C                     SETOF                     30
     C           $NONY     CHAINFGBPL011             30
     C           *IN30     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C                     SETON                     30
     C                     END
     C           *IN30     IFEQ '1'
     C                     SETON                     0199
     C                     MOVELER,04     MSG
     C                     GOTO @SCR1
     C                     END
     C                     END
     C*
     C* ﾍ]ﾌﾞ] kｩｮh
     C*
     C           @KEY      IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVELER,01     MSG
     C                     GOTO @SCR1
     C                     END
     C*
     C* ﾎﾞﾍ]uﾇjｰ n kｩｮh
     C*
     C           KEY1      KLIST
     C                     KFLD           @HIN1
     C                     KFLD           @HIN2
     C                     KFLD           @HIN3
     C                     SETOF                     30
     C           KEY1      CHAINFCEPL011             30
     C   30                GOTO @001
     C           A2GSKD    CABNE'D'       @002
     C           A2GSHZ    CABGT*DATE     @002
     C           @001      TAG
     C                     SETON                     0199
     C                     MOVELER,02     MSG
     C                     GOTO @SCR1
     C           @002      TAG
     C*
     C* NKE                GOTO @SCR1
     C*
     C                     SETON                     70
     C                     SETOF                     30
     C                     Z-ADD1         A       40
     C           @KEY      LOKUPHRT,A                    30
     C           *IN30     IFEQ '0'
     C           KEY1      SETLLMBDPL011
     C                     DO   *HIVAL
     C                     SETOF                     31
     C           KEY1      READEMBDPL011                 31
     C   31                GOTO @END
     C           @NONY     IFNE *BLANK
     C           F3NONY    CABNE$NONY     @END
     C                     END
     C                     SETON                     U1
     C                     WRITEMBDWP251
     C           @END      TAG
     C  N31                END
     C                     ADD  1         B       40
     C                     MOVE @KEY      HRT,B
     C                     END
     C                     ADD  1         @CNT    40
     C                     SETON                     90
     C*
     C                     MOVE @HIN1     #HIN1
     C                     MOVE @HIN2     #HIN2
     C                     MOVE @HIN3     #HIN3
     C                     MOVE *BLANK    @HIN1
     C                     MOVE *BLANK    @HIN2
     C                     MOVE *BLANK    @HIN3
     C                     GOTO @SCR1
**  ER
E-01 INPUT PART NO
E-02 THERE IS NOT THIS P/N IN PART M/F
E-03 APPOINTMENT USER MUST BE NUMBER
E-04 THERE IS NOT THIS USER IN DETAILS M/F
