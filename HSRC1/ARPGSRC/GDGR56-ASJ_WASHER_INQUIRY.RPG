     H            Y/
     F***************************************************
     F*   ASJ WASHER - QUICK SCHEDULE                     *
     F*                                                 *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FGDGPW56 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FFCEPL01 IF  E           K        DISK
     FFCEPL11 IF  E           K        DISK
     FMCENP13 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FGDGPL27 IF  E           K        DISK
     FAKBPL04 IF  E           K        DISK
     FGDGPP60 UF  E           K        DISK                      A
     FQPRINT  O   F     132     OF     PRINTER
      *------------------------------------------------------------
     E                    CMD     1   2 78
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1  140W@TIME
     I                                        1   60W@HMS
     I                                        7  140W@YMD
     I                                        7  100W@YY
     I                                       11  120W@MM
     I                                       13  140W@DD
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   60@@MDY
     I                                        1   20@@MM
     I                                        3   40@@DD
     I                                        5   60@@YY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C           W@ID      CASEQ'02'      #DSP02
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#FCEP    KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C           K#ADGP    KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#ADGX    KLIST
     C                     KFLD           W@YY
     C                     KFLD           W@MM
     C           K#GDGP    KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C           K#GDGX    KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#GDGZ    KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C                     KFLD           K@IVNO
     C           K#MC      KLIST
     C                     KFLD           K@SHN1
     C                     KFLD           K@SHN2
     C                     KFLD           K@SHN3
     C           K#GD60    KLIST
     C                     KFLD           D@PRT1
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C                     KFLD           K@YMD
      *
     C           *LIKE     DEFN IEINVO    K@IVNO
     C           *LIKE     DEFN MCSHN1    K@SHN1
     C           *LIKE     DEFN MCSHN2    K@SHN2
     C           *LIKE     DEFN MCSHN3    K@SHN3
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @@RRN   40
     C                     MOVEL'01'      W@ID    2
     C                     TIME           W@TIME
     C                     Z-ADDW@YY      @@YY
     C                     Z-ADDW@MM      @@MM
     C                     Z-ADDW@DD      @@DD
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     MOVEL'02'      W@ID
     C                     EXSR #SET1
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
      ** WASHER OR NOT?
     C           K#FCEP    CHAINFCEPL01              90
     C           *IN90     IFEQ *OFF
     C                     MOVE *ON       *IN61
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR 2ND SCREEN
      *------------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     MOVE *ON       *IN51
     C                     WRITECTL01
     C                     MOVE *OFF      *IN51
     C                     Z-ADD*ZERO     RRN1
     C                     Z-ADD*ZERO     @@RRN
     C                     MOVE *OFF      *IN80
      *  HEADER INFORMATION
      *--> LOCATION
     C           K#FCEP    SETGTAKBPL041
     C           *IN98     DOUEQ*ON
     C           K#FCEP    REDPEAKBPL041                 98
B01  C           *IN98     IFEQ *OFF
B02  C           L1SKJY    ANDNE'D'
B02  C           L1STYY    ANDEQ9999
     C                     MOVELL1TKR1    D@LOC1
     C                     MOVELL1TKR2    D@LOC2
     C                     MOVELL1TKR3    D@LOC3
     C                     MOVELL1TKR4    D@LOC4
      * PCS/BOX
     C           L1SYOS    DIV  1000      D@PCBX
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      * DAILY USAGE
     C                     Z-ADD*ZERO     W@QTY   90
     C           K#FCEP    SETLLMCENP13
     C           *IN98     DOUEQ*ON
     C           K#FCEP    READEMCENP13                  98
B01  C           *IN98     IFEQ *OFF
     C                     MOVE MCSHN1    K@SHN1
     C                     MOVE MCSHN2    K@SHN2
     C                     MOVE MCSHN3    K@SHN3
     C                     EXSR #USG
     C                     ENDIF
     C                     ENDDO
      *
     C           W@QTY     DIV  1000      D@PCDY
      * SUBFILE
     C                     Z-ADDD@STCK    @@STCK  91
     C                     Z-ADDW@YY      K@YY
     C                     Z-ADDW@MM      K@MM
     C                     Z-ADDW@DD      K@DD
     C           K#ADGP    SETLLAGDPL12
     C                     EXSR #SET2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   DAILY USAGE
      *------------------------------------------------------
     C           #USG      BEGSR
      *
     C           K#MC      CHAINFCEPL11              90
     C           *IN90     IFEQ *OFF
     C           FCCD01    ANDNE*ZERO
     C           FCGK01    DIV  FCCD01    @@QTY   90
     C                     ADD  @@QTY     W@QTY
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR SUB FILE
      *------------------------------------------------------
     C           #SET2     BEGSR
      *
     C                     Z-ADD@@RRN     RRN1
      *
     C                     Z-ADD*ZERO     X       30
     C                     DO   *HIVAL
     C                     READ AGDPL12                  80
     C           *IN80     IFEQ *ON
     C                     LEAVE
     C                     ELSE
      *
     C                     CLEARSFL01
     C                     MOVELF8HIRU    S@HLDY
     C           F8KAMM    MULT 100       S@DATE
     C                     ADD  F8KADD    S@DATE
      * INVOICE INF.
     C                     Z-ADDF8KAYY    K@YY
     C                     Z-ADDF8KAMM    K@MM
     C                     Z-ADDF8KADD    K@DD
     C                     Z-ADDK@YMD     H@DATE
      *
     C           RRN1      IFEQ *ZERO
     C           K#GDGP    SETLLGDGPL27
     C                     ELSE
     C           K#GDGX    SETLLGDGPL27
     C                     ENDIF
      *
     C                     MOVE *OFF      *IN92
     C           *IN91     DOUEQ*ON
     C           RRN1      IFEQ *ZERO
     C           K#GDGP    READEGDGPL27                  91
     C                     ELSE
     C           K#GDGX    READEGDGPL27                  91
     C                     ENDIF
      *
     C           *IN91     IFEQ *OFF
     C           RRN1      IFEQ *ZERO
     C           IETOYY    IFGT F8KAYY
     C           IETOYM    ORGT F8KAMM
     C           IETOYD    ORGT F8KADD
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVE *ON       *IN92
     C                     MOVELIEINVO    S@IVNO
     C           D@PCBX    IFNE 0
     C           S@SPC1    DIV  D@PCBX    S@SBX1
     C                     ENDIF
      *
     C           IEHANY    IFEQ 'S'
     C           IESURY    DIV  1000      @@BOX   61
     C                     ADD  @@BOX     S@SEA
     C                     ADD  *ZERO     S@AIR
     C                     ELSE
     C           IESURY    DIV  1000      @@BOX
     C                     ADD  @@BOX     S@AIR
     C                     ADD  *ZERO     S@SEA
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *** FROM SAVED FILE
     C           K#GD60    CHAINGDGPP60             N91
     C           *IN91     IFEQ *OFF
     C           G6SKJY    ANDEQ*BLANK
     C                     MOVELG6IVNO    H@IVNO
     C                     MOVELG6IVNO    S@IVNO
     C           G6SEAQ    DIV  1000      @@BOX
     C                     ADD  @@BOX     S@SEA
     C           G6AIRQ    DIV  1000      @@BOX
     C                     ADD  @@BOX     S@AIR
     C                     ENDIF
      *
      * USAGE
     C           S@HLDY    IFEQ *BLANK
     C                     Z-ADDD@PCDY    S@USGE
     C                     ENDIF
     C                     ADD  @@STCK    S@SPC1
     C           S@SPC1    ADD  S@AIR     S@SPC2
     C                     ADD  S@SEA     S@SPC2
     C                     SUB  S@USGE    S@SPC2
     C           D@PCBX    IFNE 0
     C           S@SPC2    DIV  D@PCBX    S@SBX2
     C                     ENDIF
     C                     ADD  1         RRN1
     C                     WRITESFL01
      *
     C                     Z-ADDS@SPC2    @@STCK
      *
     C                     ADD  1         X
     C           X         IFEQ 15
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADDRRN1      #RCNO1
     C                     Z-ADDRRN1      @@RRN
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #DSP02    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN52
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN52
      *
     C                     Z-ADD@@REC     #RCNO1
     C                     SELEC
      * F3
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * F12
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
      * F5
     C           *INKE     WHEQ *ON
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C                     EXSR #WRT
     C                     ENDIF
      * F11
     C           *INKK     WHEQ *ON
     C                     EXSR #CHK2
     C                     EXSR #PRT
     C                     MOVEL'01'      W@ID
      * ROLL UP
     C           *IN38     WHEQ *ON
     C           *IN80     ANDEQ*OFF
     C                     EXSR #CHK2
     C                     EXSR #SET2
     C                     OTHER
     C                     EXSR #CHK2
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     MOVEA'00000'   *IN,61
     C                     MOVE *OFF      *IN99
     C                     Z-ADD*ZERO     WRRN    40
     C                     Z-ADDD@STCK    @@STCK
      *
     C                     DO   *HIVAL
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVEA'00000'   *IN,61
     C           S@IVNO    IFEQ *BLANK
     C           S@AIR     IFNE *ZERO
     C           S@SEA     ORNE *ZERO
     C                     SETON                     6199
     C                     ENDIF
     C                     ENDIF
      *
     C           S@AIR     IFEQ *ZERO
     C           S@SEA     ANDEQ*ZERO
     C           S@IVNO    ANDNE*BLANK
     C                     SETON                     6299
     C                     ENDIF
      *
     C                     Z-ADD@@STCK    S@SPC1
     C           S@SPC1    ADD  S@AIR     S@SPC2
     C                     ADD  S@SEA     S@SPC2
     C                     SUB  S@USGE    S@SPC2
     C           D@PCBX    IFNE 0
     C           S@SPC2    DIV  D@PCBX    S@SBX2
     C                     ENDIF
      *
     C                     Z-ADDS@SPC2    @@STCK
      *
     C                     UPDATSFL01
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  WRITE
      *------------------------------------------------------
     C           #WRT      BEGSR
      *
     C                     Z-ADD*ZERO     WRRN    40
     C                     DO   *HIVAL
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C           S@IVNO    IFNE *BLANK
     C           H@IVNO    ORNE *BLANK
      *
     C                     Z-ADDH@DATE    K@YMD
     C           K#GD60    CHAINGDGPP60              91
     C           *IN91     IFEQ *ON
     C                     CLEARGDGPP601
     C                     ENDIF
      *
      * DELETE
     C           H@IVNO    IFNE *BLANK
     C           S@IVNO    ANDEQ*BLANK
     C                     MOVE 'D'       G6SKJY
     C                     Z-ADD*DATE     G6SKDT
     C                     ELSE
      * UPDATE/WRITE
     C                     MOVE S@IVNO    G6IVNO
     C                     MOVE D@PRT1    G6HIN1
     C                     MOVE D@PRT2    G6HIN2
     C                     MOVE D@PRT3    G6HIN3
     C                     Z-ADDH@DATE    G6RCDT
      *
     C           S@AIR     IFNE *ZERO
     C                     MOVE 'A'       G6CARR
     C           S@AIR     MULT 1000      G6AIRQ
     C           G6AIRQ    DIV  L1SYOS    G6AIRB
     C                     ENDIF
     C           S@SEA     IFNE *ZERO
     C                     MOVE 'S'       G6CARR
     C           S@SEA     MULT 1000      G6SEAQ
     C           G6SEAQ    DIV  L1SYOS    G6SEAB
     C                     ENDIF
      *
     C           G6SEAB    ADD  G6AIRB    G6RCBX
     C           G6SEAQ    ADD  G6AIRQ    G6RCQT
      *
     C                     ENDIF
      *
     C                     Z-ADD*DATE     G6KODT
     C                     TIME           G6KOTM
     C                     MOVEL#USER     G6KOME
     C  N91                UPDATGDGPP601
     C   91                WRITEGDGPP601
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  OUTPUT
      *------------------------------------------------------
     C           #PRT      BEGSR
      *
     C                     MOVE *ALL'-'   @@LINE 66
     C                     Z-ADD*ZERO     WRRN    40
     C                     EXCPT@HED
      *
     C                     DO   *HIVAL
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C           *INOF     IFEQ *ON
     C                     EXCPT@HED
     C                     ENDIF
      *
     C                     EXCPT@DTL
      *
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                         @@MDY Y   59
     O                                   62 'P.'
     O                         PAGE  Z   66
     O        E   02           @HED
     O                                   43 'ASJ WASHER SCHEDULE'
     O                         W@HMS     59 '  :  :  '
     O        E   04           @HED
     O                                    6 'PART#:'
     O                         D@PRT1    12
     O                         D@PRT2    18
     O                         D@PRT3    21
     O                                   35 'PCS/BOX:'
     O                         D@PCBX4   42
     O                                   55 'LOCATION:'
     O                         D@LOC1    57
     O                         D@LOC2    60
     O                         D@LOC3    63
     O                         D@LOC4    65
     O        E   05           @HED
     O                                   10 'PCS/DAY:'
     O                         D@PCDY1   19
     O        E   06           @HED
     O                                   26 'STOCK'
     O                                   62 'BALANCE'
     O        E   07           @HED
     O                                    4 'DATE'
     O                                   14 'INV#'
     O                                   21 'B0X'
     O                                   29 'PCS'
     O                                   37 'AIR'
     O                                   44 'SEA'
     O                                   51 'USE'
     O                                   57 'B0X'
     O                                   65 'PCS'
     O        E   08           @HED
     O                         @@LINE    66
     O        E 1              @DTL
     O                         S@DATEY    5
     O                         S@HLDY     7
     O                         S@IVNO    15
     O                         S@SBX1M   22
     O                         S@SPC1M   30
     O                         S@AIR 4   37
     O                         S@SEA 4   44
     O                         S@USGE4   51
     O                         S@SBX2M   58
     O                         S@SPC2M   66
**  CMD
F3: EXIT
UNIT = K PCS    F3: EXIT   F5: SAVE INF.   F11: PRINT  F12: PREV
