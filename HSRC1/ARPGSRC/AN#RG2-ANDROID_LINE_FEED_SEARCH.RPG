     H            Y/
     F******************************************************
     F*  ANDROID LINE FEED SEARCH                          *
     F*                                                    *
     F* TCHK1 07/28/06 CREATE(COPY FROM AB#RG2)            *
     F******************************************************
     FAN#PWG2 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FABR2L03 IF  E           K        DISK
      *------------------------------------------------------------
     E                    CMD     1   2 78
     E                    MSG     1   1 78
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@REYY
     I                                        5   60K@REMM
     I                                        7   80K@REDD
     I            DS
     I                                        1  12 D@PART
     I                                        1   5 D@PRT1
     I                                        6  10 D@PRT2
     I                                       11  12 D@PRT3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#ABF     KLIST
     C                     KFLD           K@PART 20
     C                     KFLD           K@DOCK  5
      *
     C                     MOVEL'01'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           RRN1      IFEQ *ZERO
     C                     MOVE *ON       *IN99
     C                     MOVE *ON       *IN61
     C                     MOVE MSG,1     D@MSG
     C                     ELSE
     C                     MOVEL'02'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
      *
     C                     MOVELD@PART    K@PART
     C           K@PART    SETLLABR2L03
     C           *IN80     DOUEQ*ON
     C           K@PART    READEABR2L03                  80
     C           *IN80     IFEQ *OFF
     C                     MOVELAFSTID    K@DOCK
     C                     CLEARSFL01
     C           K#ABF     SETGTABR2L03
     C           K#ABF     REDPEABR2L03                  81
     C           *IN81     IFEQ *OFF
     C                     MOVELAFALFL    S@LF
     C                     MOVELAFRALF    S@RFL
     C                     SELEC
     C           AFSTID    WHEQ 'AIW01'
     C                     Z-ADD2855      S@NONY
     C           AFSTID    WHEQ 'AIL01'
     C                     Z-ADD2856      S@NONY
     C                     OTHER
     C                     Z-ADD*ZERO     S@NONY
     C                     ENDSL
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C           K#ABF     SETGTABR2L03
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     MOVEL'01'      W@ID
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
**  CMD
  F1:END     ENTER:CONTINUE
  F1:END     ENTER:GO BACK
