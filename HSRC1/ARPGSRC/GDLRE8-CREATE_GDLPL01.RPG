     H            Y.                                    1
     FGDLWPE0 IP  E                    DISK
      *
     FGDLPL01 UF  E           K        DISK                      A
      *
     C           KEY1      KLIST
     C                     KFLD           KSIRE   40
     C                     KFLD           KZAIS  15
     C                     KFLD           KZAIK   52
      *
     C           *ENTRY    PLIST
     C                     PARM           P@SIRE  4
     C                     PARM           P@FLG   1
      *
     C                     SETON                     U1
      *
     C           LASKJY    IFEQ 'D'
     C                     GOTO @END
     C                     END
      *
     C                     MOVE P@SIRE    N@SIRE  40
      *
     C           N@SIRE    IFEQ LASIRE
      *
     C           P@FLG     IFEQ '1'
      * GDLWPE0 -> GDLPP01
S1   C           W@ODER    IFNE 0
     C                     Z-ADDLASIRE    KSIRE
     C                     MOVELLAZAIS    KZAIS
     C                     MOVELLAZAIK    KZAIK
     C                     SETOF                     92
     C           KEY1      CHAINGDLPL01              92
 S2  C           *IN92     IFEQ '1'
     C                     Z-ADDW@ODER    LAMAIS
     C                     WRITEGDLPL011
 E2  C                     END
      *
 S2  C           *IN92     IFEQ '0'
  S3 C           LASKJY    IFEQ 'D'
     C                     MOVEL' '       LASKJY
     C                     Z-ADD0         LASKYY
     C                     Z-ADD0         LASKMM
     C                     Z-ADD0         LASKDD
     C                     Z-ADDW@ODER    LAMAIS
     C                     UPDATGDLPL011
  M3 C                     ELSE
     C                     ADD  W@ODER    LAMAIS
     C                     UPDATGDLPL011
  E3 C                     END
 E2  C                     END
E1   C                     END
      * GDLWPE0 -> BTBPP05
     C           W@NPLA    IFNE 0
     C                     MOVE LASIRE    P@SIRE  4
     C                     MOVE LAUKEI    P@UKEI  4
     C                     MOVE LAPTCD    P@PTCD  1
     C                     MOVE LAZAIS    P@ZAIS 15
     C                     MOVE LAZAIK    P@ZAIK  5
     C                     MOVELW@NXTD    P@KEYM  6
     C                     MOVE W@NXTD    P@KEYD  2
     C                     MOVE '000'     P@M     3
     C                     MOVE W@NPLA    P@P     3
     C                     CALL 'BTBR07'
     C                     PARM           P@SIRE  4
     C                     PARM           P@UKEI  4
     C                     PARM           P@PTCD  1
     C                     PARM           P@ZAIS 15
     C                     PARM           P@ZAIK  5
     C                     PARM           P@KEYM  6
     C                     PARM           P@KEYD  2
     C                     PARM           P@M     3
     C                     PARM           P@P     3
     C                     END
      * GDLWPE0 -> BTBPP41
     C                     MOVE LASIRE    P#SIRE  4
     C                     MOVE LAUKEI    P#UKEI  4
     C                     MOVE LAPTCD    P#PTCD  1
     C                     MOVE LAZAIS    P#ZAIS 15
     C                     MOVE LAZAIK    P#ZAIK  5
     C                     MOVE W@NADJ    P#NADJ  3
     C                     CALL 'BTBR42'
     C                     PARM           P#SIRE  4
     C                     PARM           P#UKEI  4
     C                     PARM           P#PTCD  1
     C                     PARM           P#ZAIS 15
     C                     PARM           P#ZAIK  5
     C                     PARM           P#NADJ  3
      *
     C                     END
      *
     C                     END
