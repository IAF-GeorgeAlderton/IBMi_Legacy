     H            Y.
      ** UEXR45B ***************************************************
      *  GET POSTING DATE FROM SALES DATA                          *
      *  JW     2021.10.26                                         *
      **************************************************************
      *  CALLING SEQ.                                              *
      *                    CALL 'UEXR45B'
      *                    PARM           $NONY   4
      *                    PARM           $NOHZ   8
      *                    PARM           $BIN    2
      *                    PARM           $NKOJ   1
      *                    PARM           $NUKE   4
      *                    PARM           $ODRN  10
      *                    PARM           $POHZ   8
      *                    PARM           $POTM   6
      *   IN  $NONY   4A  DELIV#                                   *
      *   "   $NOHZ   8A  SHIP DATE                                *
      *   "   $BIN    2A  BIN#                                     *
      *   "   $NKOJ   1A  FACTORY                                  *
      *   "   $NUKE   4A  DOCK                                     *
      *   "   $ODRN  10A  PO#                                      *
      *   OUT $POHZ   8A  POSTING DATE                             *
      *   "   $POTM   6A  POSTING TIME                             *
      **************************************************************
     FAB#PL0D IF  E           K        DISK
      ***********************************************************
      *
     I            DS
     I                                        1   80XNOHZ
     I                                        1   40$NOYY
     I                                        5   60$NOMM
     I                                        7   80$NODD
      *
     I            DS
     I                                        1   80B1URHZ
     I                                        1   40B1URYY
     I                                        5   60B1URMM
     I                                        7   80B1URDD
      *
     I            DS
     I                                        1   40B1KSTM
     I                                        1   20B1KSJI
     I                                        3   40B1KSPN
      * SYSTEM DATE
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      ****************************************************
      * MAIN ROUTINE
      ****************************************************
     C                     EXSR #INIT
      * find SALES DATA
     C           K#PL0D    SETLLAB#PL0D
     C                     DO   *HIVAL
     C           K#PL0D    READEAB#PL0D                  98
     C   98                LEAVE
      *
     C           B1SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELB1URHZ    $POHZ
     C                     MOVELB1KSTM    $POTM
     C                     LEAVE
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ****************************************************
      * INITIALIZE
      ****************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4        IN
     C                     PARM           $NOHZ   8        IN
     C                     PARM           $BIN    2        IN
     C                     PARM           $NKOJ   1        IN
     C                     PARM           $NUKE   4        IN
     C                     PARM           $ODRN  10        IN
     C                     PARM           $POHZ   8        OUT
     C                     PARM           $POTM   6        OUT
      *
     C           K#PL0D    KLIST
     C                     KFLD           K1NONY  40
     C                     KFLD           K1NOYY  40
     C                     KFLD           K1NOMM  20
     C                     KFLD           K1NODD  20
     C                     KFLD           K1NOBI  20
     C                     KFLD           K1NKOJ  1
     C                     KFLD           K1NUKE  4
     C                     KFLD           K1ODR1 10
      * SET KEY
     C                     MOVEL$NONY     K1NONY
     C                     MOVEL$NOHZ     XNOHZ
     C                     MOVEL$NOYY     K1NOYY
     C                     MOVEL$NOMM     K1NOMM
     C                     MOVEL$NODD     K1NODD
     C                     MOVEL$BIN      K1NOBI
     C                     MOVEL$NKOJ     K1NKOJ
     C                     MOVEL$NUKE     K1NUKE
     C                     MOVEL$ODRN     K1ODR1
      *
     C                     MOVEL'00000000'$POHZ
     C                     MOVEL'000000'  $POTM
     C                     TIME           SDATE
      *
     C                     ENDSR
