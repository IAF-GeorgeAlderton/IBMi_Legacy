     C           @001      TAG
     C*
     C                     MOVE *BLANK    @USER  10
     C                     SETOF                     31
     C           PARM1     CHAINRGAPL111             31
     C           *IN31     IFEQ '0'
     C           J8SKJY    ANDEQ'D'
