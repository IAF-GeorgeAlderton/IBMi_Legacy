     C                     Z-ADDR4SEYY    @SEYY
     C                     Z-ADDR4SEMM    @SEMM
     C                     Z-ADDR4SEDD    @SEDD
     C                     Z-ADDR4SEHH    @SEHH
     C                     Z-ADDR4SESS    @SESS
