     C           @SEYY     IFLE 89
     C                     SETON                     0499
     C                     MOVELER,14     MSG
     C                     GOTO @SCR2
     C                     END
     C*
     C* ﾈｮmbﾍﾞ lg
     C*
     C           @SEMM     IFEQ 0
     C                     SETON                     0599
     C                     MOVELER,15     MSG
     C                     GOTO @SCR2
     C                     END
     C           @SEMM     IFLT 01
     C           @SEMM     ORGT 12
     C                     SETON                     0599
     C                     MOVELER,16     MSG
     C                     GOTO @SCR2
     C                     END
     C*
     C* ﾈｮmbﾍﾞ ﾍ
     C*
