     C                     SETON                     020304
     C                     SETON                     99
     C                     MOVELER,07     MSG
     C                     GOTO @SCR1
     C                     END
     C           R4SKJY    IFEQ 'D'
     C           R4SKHZ    ANDLE*DATE
