     C                     SETOF                     20
     C                     Z-ADD1         A       10
     C           @KOSN     LOKUPKOCD,A                   20
     C           *IN20     IFEQ '0'
     C                     SETON                     0299
     C                     MOVELER,01     MSG
     C                     GOTO @SCR1
     C                     END
     C                     MOVELKONM,A    @KONM
     C*
     C* nhbﾅgTPX
     C*
