     C           *ENTRY    PLIST
     C                     PARM           PARM1  10        USER NAME
     C                     Z-ADD0         R4SKHZ
     C*
     C* fﾞx]-1
     C*
     C           @SCR1     TAG
     C                     EXFMTOAAPW151
     C                     SETOF                     020304
     C                     SETOF                     99
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C*
     C* ﾃcﾆ]hﾎﾞ]
     C*
