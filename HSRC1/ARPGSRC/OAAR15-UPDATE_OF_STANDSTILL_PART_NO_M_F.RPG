     C                     SETON                     0399
     C                     MOVELER,02     MSG
     C                     GOTO @SCR1
     C                     END
     C           @TOK6     IFEQ 'ZZZZZZ'
     C                     GOTO ZET
     C                     END
     C                     SETOF                     31
     C           @TOK6     CHAINALAPL021             31
     C           *IN31     IFEQ '1'
     C                     SETON                     0399
     C                     MOVELER,03     MSG
     C                     GOTO @SCR1
     C                     END
      *
     C           ZET       TAG
     C*
     C* ﾈﾞｮjbﾌﾞ]ﾃﾞc
     C*
     C           @ZETI     IFEQ *BLANK
     C                     SETON                     0499
     C                     MOVELER,04     MSG
     C                     GOTO @SCR1
     C                     END
     C                     SETOF                     31
     C           @ZETI     CHAINFCETL111             31
     C           *IN31     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     31
     C                     END
     C           *IN31     IFEQ '1'
     C                     SETON                     0499
     C                     MOVELER,05     MSG
     C                     GOTO @SCR1
     C                     END
     C           *IN31     IFEQ '0'
     C                     MOVELA2BHB1    @SHN1
     C                     MOVELA2BHB2    @SHN2
     C                     MOVELA2BHB3    @SHN3
     C                     END
     C*
     C* lbf
     C*
     C           KEY1      KLIST
     C                     KFLD           @TOK6
     C                     KFLD           @ZETI
     C                     SETOF                     30
     C           KEY1      CHAINOAAPL151             30
     C           @KOSN     IFEQ '2'
     C           *IN30     IFEQ '0'
     C           R4SKJY    IFEQ 'D'
     C           R4SKHZ    ANDLE*DATE
     C                     GOTO @001
     C                     END
     C                     SETON                     020304
     C                     SETON                     99
     C                     MOVELER,06     MSG
     C                     GOTO @SCR1
     C                     END
     C                     END
     C*
     C* s]ﾃc
     C*
     C           @KOSN     IFEQ '1'
