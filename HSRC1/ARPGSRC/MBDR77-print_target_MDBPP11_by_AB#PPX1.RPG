     H            Y.
     F** MBDR77 ****************************************************************
     F*  PROGRAM    : PRINT TARGET MDBPP11 BY AB#PPX1                          *
     F*  WRITTEN    : 4/03/2018                                                *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#PPX1 IF  E           K        DISK
     FMBDPL17 UF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
     E                    QT         12  7 0
     E                    UP         12 11 5
     I            DS
     I                                        1  840QT
     I                                        1   70F4TS01
     I                                        8  140F4TS02
     I                                       15  210F4TS03
     I                                       22  280F4TS04
     I                                       29  350F4TS05
     I                                       36  420F4TS06
     I                                       43  490F4TS07
     I                                       50  560F4TS08
     I                                       57  630F4TS09
     I                                       64  700F4TS10
     I                                       71  770F4TS11
     I                                       78  840F4TS12
     I            DS
     I                                        1 1325UP
     I                                        1  115F4TN01
     I                                       12  225F4TN02
     I                                       23  335F4TN03
     I                                       34  445F4TN04
     I                                       45  555F4TN05
     I                                       56  665F4TN06
     I                                       67  775F4TN07
     I                                       78  885F4TN08
     I                                       89  995F4TN09
     I                                      100 1105F4TN10
     I                                      111 1215F4TN11
     I                                      122 1325F4TN12
     I            DS
     I                                        1  20 B1MHIN
     I                                        1   5 B1MHN1
     I                                        6  10 B1MHN2
     I                                       11  15 B1MHN3
     I                                       16  20 B1MHN4
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           *LOVAL    SETLLAB#PPX1
     C           *IN91     DOWEQ*OFF
     C                     READ AB#PPX1                  91
     C           *IN91     IFEQ *OFF
     C           B1SKJY    ANDEQ*BLANK
     C                     EXSR #PROC
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------------*
      *  PROCESS                                           *
      *----------------------------------------------------*
     C           #PROC     BEGSR
      * SET KEY
     C                     Z-ADDB1URYY    K#TNEN
     C                     Z-ADDB1TOKU    K#TOKU
     C                     Z-ADDB1NONY    K#NONY
     C                     MOVELB1NKOJ    K#NKOJ
     C                     MOVELB1NUKE    K#NUKE
     C                     MOVELB1MHIN    K#MHIN
     C                     Z-ADD0         CNT     20
      *
     C           K#MB11    SETLLMBDPL17
     C                     MOVE *OFF      *IN92
     C           *IN92     DOWEQ*OFF
     C                     READ MBDPL17                  92
     C           *IN92     IFEQ *OFF
     C           F4SKJY    ANDEQ*BLANK
      *
     C           F4TOKU    IFEQ K#TOKU
     C           F4NONY    ANDEQK#NONY
     C           F4NKOJ    ANDEQK#NKOJ
     C           F4NUKE    ANDEQK#NUKE
     C           F4MHIN    ANDEQK#MHIN
     C                     ADD  1         CNT
     C                     EXSR #PRINT
      * UPDATE
     C           PMUPD     IFEQ 'Y'
     C                     EXSR #UPD
     C                     ENDIF
      *
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           CNT       IFGT 1
     C                     EXSR #PRT2
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  UPDATE MBDPP11                                    *
      *----------------------------------------------------*
     C           #UPD      BEGSR
     C                     MOVE 'N'       UFLG    1
      *
     C           1         DO   12        IX      20
      * END?
     C           F4TNEN    IFEQ 2018
     C           IX        ANDGE03
     C                     LEAVE
     C                     ENDIF
      *
     C                     SELEC
     C           F4TNEN    WHEQ B1URYY
     C           IX        ANDGTB1URMM
     C                     SUB  B1SRYO    QT,IX
     C                     MOVE 'Y'       UFLG
     C           F4TNEN    WHGT B1URYY
     C                     SUB  B1SRYO    QT,IX
     C                     MOVE 'Y'       UFLG
     C                     ENDSL
      * CHECK UP
     C           QT,IX     IFLE 0
     C                     Z-ADD0         UP,IX
     C                     MOVE 'Y'       UFLG
     C                     ENDIF
      *
     C                     ENDDO
      * TEMP ----
     C**                   GOTO @UPD
      *
     C           UFLG      IFEQ 'Y'
     C                     UPDATMBDPL171
     C                     ENDIF
      *
     C           @UPD      ENDSR
      *----------------------------------------------------*
      *  PRINT DETAIL                                      *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     MOVELF4MHIN    XXMHIN 15
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  PRINT BREAK                                       *
      *----------------------------------------------------*
     C           #PRT2     BEGSR
      *
     C                     EXCPT@BRK
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           PMUPD   1
      *
     C           K#MB11    KLIST
     C                     KFLD           K#TOKU  40
     C                     KFLD           K#NONY  40
     C                     KFLD           K#NKOJ  1
     C                     KFLD           K#NUKE  4
     C                     KFLD           K#MHIN 20
     C                     KFLD           K#TNEN  40
      *
     C                     TIME           @DT14  140
     C                     MOVE @DT14     @DATE   80
     C                     MOVEL@DT14     @TIME   60
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD90        LIN#    30
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   50 '** TARGET MBDPP11 **'
     O                                   99 'DATE'
     O                         @DATE    102 '    .  .  '
     O                         @TIME    112 '  :  :  '
     O                                  120 'P.'
     O                         PAGE  Z  124
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   11 'CUST'
     O                                   17 'DELV'
     O                                   20 'F'
     O                                   25 'DOCK'
     O                                   34 'YEAR'
     O                                   42 'USR PART'
     O                                   60 'BIL_DATE'
     O                                   70 'ERR_AMT'
     O                                   80 'Q.01'
     O                                   90 'Q.02'
     O                                  100 'Q.03'
     O                                  110 'Q.04'
     O                                  120 'Q.05'
     O                                  130 'Q.06'
     O                                  140 'Q.07'
     O                                  150 'Q.08'
     O                                  160 'Q.09'
     O                                  170 'Q.10'
     O                                  180 'Q.11'
     O                                  190 'Q.12'
     O        E 1              @DTL
     O                         SEQ#  Z +001
     O                         F4TOKU  +002
     O                         F4NONY  +002
     O                         F4NKOJ  +002
     O                         F4NUKE  +002
     O                         F4TNEN  +002
     O                         XXMHIN  +002
     O                         B1URYY  +001
     O                         B1URMM  +001
     O                         B1URDD  +001
     O                         B1SRYOJ +001
     O                         QT,01 J +000
     O                         QT,02 J +000
     O                         QT,03 J +000
     O                         QT,04 J +000
     O                         QT,05 J +000
     O                         QT,06 J +000
     O                         QT,07 J +000
     O                         QT,08 J +000
     O                         QT,09 J +000
     O                         QT,10 J +000
     O                         QT,11 J +000
     O                         QT,12 J +000
     O        E 1              @BRK
     O                                    5 '.'
      *
