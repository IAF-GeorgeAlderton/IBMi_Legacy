     H            Y/
     F** ABFR84 **********************************************
     F*  PRINT "FORECAST VS SALES (%) REPORT" (WEEK)         *
     F*  J.WATANABE 2018.07.13                               *
     F********************************************************
     FABFWL81 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
     F********************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ ABFWL81                  98
     C   98                LEAVE
      *
     C           C8FCYM    IFNE @TGTYM
     C                     ITER
     C                     ENDIF
      *
     C           C8NONY    CHAINFGBPL01              97
     C   97                MOVE *BLANK    B2SMEI
      *
     C                     EXSR #PRINT
     C                     ADD  C8FQTY    G8FQTY
     C                     ADD  C8SQTY    G8SQTY
     C                     ADD  C8FBOX    G8FBOX
     C                     ADD  C8SBOX    G8SBOX
      * PRINT GRAND TOTAL
     C           G8FBOX    IFNE 0
     C           G8SBOX    MULT 100       NUM12  120
     C           NUM12     DIV  G8FBOX    G8RATE    H
     C                     ENDIF
     C                     ENDDO
      *
     C           $PRINT    IFEQ 'Y'
     C                     EXCPT@GTL1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           $PRINT    IFEQ 'Y'
     C           LIN#      IFGE 64
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL1
     C                     ADD  1         LIN#
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $TGTYM  6
     C                     PARM           $PRINT  1
      *
     C                     MOVEL$TGTYM    @TGTYM  60
     C                     MOVEL$TGTYM    LTR4    4
     C                     MOVE $TGTYM    LTR2    2
     C                     MOVEL'    /  ' XTGTYM  7
     C                     MOVELLTR4      XTGTYM
     C                     MOVE LTR2      XTGTYM
      *
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
      *
     C                     Z-ADD0         G8FQTY 100
     C                     Z-ADD0         G8SQTY 100
     C                     Z-ADD0         G8FBOX 100
     C                     Z-ADD0         G8SBOX 100
     C                     Z-ADD0         G8RATE  61
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   30 '** FORECAST VS SALES'
     O                                   50 ' (%) REPORT **  FOR '
     O                         XTGTYM    57
     O                                   67 '==WEEK=='
     O                                   99 'DATE'
     O                         TODAY    102 '    .  .  '
     O                         NOW      112 '  :  :  '
     O                                  116 'P.'
     O                         PAGE  Z  120
     O        E   03           @HDR
     O                                    6 'DELIV'
     O                                   12 'NAME'
     O                                   36 'FORECAST'
     O                                   50 'SALES'
     O                                   66 'FORECAST'
     O                                   80 'SALES'
     O        E   04           @HDR
     O                                   36 '   (QTY)'
     O                                   50 ' (QTY)'
     O                                   66 '   (BOX)'
     O                                   80 ' (BOX)'
     O                                   93 'BOX RATE%'
      *
     O        E 1              @DTL1
     O                         C8NONY  +002
     O                         B2SMEI  +002
     O                         C8FQTYJ +002
     O                         C8SQTYJ +002
     O                         C8FBOXJ +002
     O                         C8SBOXJ +002
     O                         C8RATEJ +004
      *
     O        E 1              @GTL1
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
      *
     O        E 1              @GTL1
     O                         G8FQTYJ   37
     O                         G8SQTYJ   51
     O                         G8FBOXJ   67
     O                         G8SBOXJ   81
     O                         G8RATEJ   94
      *
