     C                     TIME           WTIME
     C                     Z-ADDWTIDD     W@TODY  20
      *
     C           *ENTRY    PLIST
     C                     PARM           P@YYMM  6
     C                     PARM           P@GYMD  6
     C                     MOVELP@YYMM    W@YYMM
     C                     MOVELP@GYMD    W@GYMD
      *システム年月がＡＢＡＤＳ１の年月より
      *小さいときは当日を１日にする
     C           #SSYM     IFLT W@YYMM
     C                     Z-ADD1         W@TODY
     C                     ENDIF
      *
     C                     Z-ADDW@YYYY    WSSYYY
     C                     Z-ADDW@MMMM    WSSMMM
     C                     Z-ADD01        WSSDDD
      *
     C                     Z-ADDWSSYYY    K@YY
     C                     Z-ADDWSSMMM    K@MM
     C                     Z-ADDWSSDDD    K@DD
      * N
     C                     Z-ADDWSSYYY    K@YYN
     C                     Z-ADDWSSMMM    K@MMN
     C                     Z-ADD01        K@DDN
      * N+1
     C           K@MMN     ADD  1         K@MM1
     C           K@MM1     IFGT 12
     C           K@YYN     ADD  1         K@YY1
     C                     Z-ADD1         K@MM1
     C                     ELSE
     C                     Z-ADDK@YYN     K@YY1
     C                     ENDIF
     C                     Z-ADD01        K@DD1
     C* N+2
     C           K@MM1     ADD  1         K@MM2
     C           K@MM2     IFGT 12
     C           K@YY1     ADD  1         K@YY2
     C                     Z-ADD1         K@MM2
     C                     ELSE
     C                     Z-ADDK@YY1     K@YY2
     C                     ENDIF
     C                     Z-ADD01        K@DD2
      * SET WORKDAY
     C           K#AGDA    KLIST
     C                     KFLD           K@YYN
     C                     KFLD           K@MMN
     C                     CLEARGDT
     C                     CLEARGHL
     C                     Z-ADD0         X       30
     C           K#AGDA    SETLLA#DPL12
     C                     READ A#DPL12                  22
     C           *IN22     DOWEQ'0'
     C           F8KAYM    ANDLEK@YM2
     C                     ADD  1         X
     C                     Z-ADDF8KA      GDT,X
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     MOVEL'Y'       GHL,X
     C                     ENDIF
     C                     READ A#DPL12                  22
     C                     ENDDO
      *
     C                     CLEARHDT
     C                     CLEARHHL
     C                     Z-ADD0         X       30
     C           K#AGDA    SETLLAGDPL12
     C                     READ AGDPL12                  22
     C           *IN22     DOWEQ'0'
     C           F8KAYM    ANDLEK@YM2
     C                     ADD  1         X
     C                     Z-ADDF8KA      HDT,X
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     MOVEL'Y'       HHL,X
     C                     ENDIF
     C                     READ AGDPL12                  22
     C                     ENDDO
      *
     C                     CLEAR@HTS
     C                     CLEAR@FUG
     C                     CLEAR@KIS
     C                     Z-ADD*ZERO     I       20
     C           *LOVAL    SETLLAHDPP05
     C                     READ AHDPP05                  90
     C           *IN90     DOWEQ'0'
     C           AHSKJY    IFEQ *BLANK
     C                     ADD  1         I       20
     C                     MOVELAHFUGO    @FUG,I
     C                     Z-ADDAHHTSU    @HTS,I
     C                     Z-ADDAHKISU    @KIS,I
     C                     ENDIF
     C                     READ AHDPP05                  90
     C                     ENDDO
     C                     Z-ADDI         W@MAXI  20
      *
     C                     EXSR #AAP
     C                     EXSR #AKB
     C                     EXSR #AAN
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------*
      * AAPPP01                           *
      *-----------------------------------*
     CSR         #AAP      BEGSR
      *
     C           *LOVAL    SETLLAAPPL06
     C                     READ AAPPL06                  99
     C*
     C           *IN99     DOWEQ'0'
     C           L5SKJY    IFEQ *BLANK
     C           L5BMON    ANDEQ8990
     C           L5STYY    ANDEQ9999
     C                     Z-ADD*ZERO     W@LOT#  30
     C                     Z-ADD*ZERO     W@SYS   50
     C                     Z-ADD*ZERO     W@W#01 112
     C                     Z-ADD*ZERO     W@GEKN  90
     C                     CLEAR@CGH
     C                     CLEAR@CGK
     C                     MOVELL5SHN1    K@SHN1
     C                     MOVELL5SHN2    K@SHN2
     C                     MOVELL5SHN3    K@SHN3
     C                     EXSR @SETT
     C           W@SYS     IFEQ *ZERO
     C           L5SYOS    IFNE *ZERO
     C                     Z-ADDL5SYOS    W@SYS
     C                     Z-ADDL5KSSU    W@W#01
     C                     Z-ADD00000000  @CGH,1
     C                     Z-ADDW@W#01    @CGK,1
     C                     ENDIF
     C                     ENDIF
      *
     C           W@SYS     IFNE *ZERO
     C                     Z-ADDL5HKSU    W@LOT#  30
     C                     EXSR @MAIN
     C                     ENDIF
      *
     C                     ENDIF
     C                     READ AAPPL06                  99
     C                     ENDDO
      *
     CSR         EAAP      ENDSR
      *-----------------------------------*
      * AKBPP01                           *
      *-----------------------------------*
     CSR         #AKB      BEGSR
      *
     C           *LOVAL    SETLLAKBPL04
     C                     READ AKBPL04                  99
     C*
     C           *IN99     DOWEQ'0'
     C           L1SKJY    IFEQ *BLANK
     C           L1BMON    ANDEQ8990
     C           L1STYY    ANDEQ9999
     C                     Z-ADD*ZERO     W@LOT#  30
     C                     Z-ADD*ZERO     W@SYS   50
     C                     Z-ADD*ZERO     W@W#01 112
     C                     Z-ADD*ZERO     W@GEKN  90
     C                     CLEAR@CGH
     C                     CLEAR@CGK
     C                     MOVELL1SHN1    K@SHN1
     C                     MOVELL1SHN2    K@SHN2
     C                     MOVELL1SHN3    K@SHN3
     C           L1SYOS    IFNE *ZERO
     C                     Z-ADDL1SYOS    W@SYS
     C                     Z-ADDL1KTSU    W@W#01
     C                     Z-ADD00000000  @CGH,1
     C                     Z-ADDW@W#01    @CGK,1
     C                     ENDIF
      *
     C           W@SYS     IFNE *ZERO
     C                     Z-ADD1         W@LOT#  30
     C                     EXSR @MAIN
     C                     ENDIF
      *
     C                     ENDIF
     C                     READ AKBPL04                  99
     C                     ENDDO
      *
     CSR         EAKB      ENDSR
      *-----------------------------------*
      * AANPP01                           *
      *-----------------------------------*
     CSR         #AAN      BEGSR
      *
     C           *LOVAL    SETLLAANPL06
     C                     READ AANPL06                  99
     C*
     C           *IN99     DOWEQ'0'
     C           L7SKJY    IFEQ *BLANK
     C           L7BMON    ANDEQ8990
     C           L7STYY    ANDEQ9999
     C                     Z-ADD*ZERO     W@LOT#  30
     C                     Z-ADD*ZERO     W@SYS   50
     C                     Z-ADD*ZERO     W@W#01 112
     C                     Z-ADD*ZERO     W@GEKN  90
     C                     CLEAR@CGH
     C                     CLEAR@CGK
     C                     MOVELL7SHN1    K@SHN1
     C                     MOVELL7SHN2    K@SHN2
     C                     MOVELL7SHN3    K@SHN3
     C                     EXSR @SETT
     C           W@SYS     IFEQ *ZERO
     C           L7SYOS    IFNE *ZERO
     C                     Z-ADDL7SYOS    W@SYS
     C                     Z-ADDL7KSSU    W@W#01
     C                     Z-ADD00000000  @CGH,1
     C                     Z-ADDW@W#01    @CGK,1
     C                     ENDIF
     C                     ENDIF
      *
     C           W@SYS     IFNE *ZERO
     C                     Z-ADD1         W@LOT#  30
     C                     EXSR @MAIN
     C                     ENDIF
      *
     C                     ENDIF
     C                     READ AANPL06                  99
     C                     ENDDO
      *
     CSR         EAAN      ENDSR
      *----------------------------------------------------
      *
      *----------------------------------------------------
     CSR         @SETT     BEGSR
     C*
     C           K#FCE     KLIST
     C                     KFLD           K@SHN1
     C                     KFLD           K@SHN2
     C                     KFLD           K@SHN3
     C           K#FCE     CHAINFCEPL01              98
     C           *IN98     IFEQ *ON
     C           A2GSKD    ORNE *BLANK
     C                     GOTO ESETT
     C                     ENDIF
     C           K#FCE     CHAINFCEPL11              97
     C           *IN97     IFEQ *ON
     C           FCSKJY    ORNE *BLANK
     C                     GOTO ESETT
     C                     ENDIF
      *
     C                     Z-ADDA2GEKN    W@GEKN
     C                     Z-ADDA2SSYS    W@SYS
      * MVOL
     C                     Z-ADD1         Z       20
     C           Z         DOWLE10
     C           CGH,Z     IFNE *ZERO
     C                     Z-ADDCGH,Z     @CGH,Z
     C           CGK,Z     DIV  20        W#N114 114
     C           W#N114    ADD  0.99      W@N070  70
     C                     Z-ADDW@N070    @CGK,Z
     C                     ENDIF
     C                     ADD  1         Z
     C                     ENDDO
     C*
     CSR         ESETT     ENDSR
      *-----------------------------------------------------
      *
      *-----------------------------------------------------
     CSR         @MAIN     BEGSR
      * VS FCEPP11,BTAPP05
     C                     Z-ADD0         A@YMD
     C                     Z-ADD*ZERO     W@MINS  90
     C                     CLEARGCG
     C                     CLEARHCG
     C                     CLEARKDS
     C                     CLEARGCB
      * 稼働差、計画発行の集計
     C                     EXSR ASUB1
      *
     C                     CLEARGMX
     C                     CLEARQMX
     C                     EXSR ZSUB                       上限
     C                     EXSR CSUB3                      稼働差
     C                     EXSR CSUB1                      実績と調整
     C                     EXSR CSUB6                      計画発行プラマイ
     C***                  EXSR CSUB4                      計画発行プラス
     C***                  EXSR CSUB2                      計画発行マイナス
     C                     EXSR CSUB5                      ＧＤＧＰＰ７５
     C                     EXSR BSUB                        PRICE MASTER
     C           K@YMDE    IFNE 0
     C                     EXSR ESUB
     C                     ENDIF
      *
     CSR         EMAIN     ENDSR
      *----------------------------------------------------
      * GEAPP16
      *----------------------------------------------------
     CSR         ESUB      BEGSR
      *
     C                     CLEARGEAPP161
     C                     MOVELK@SHN1    GASHN1
     C                     MOVELK@SHN2    GASHN2
     C                     MOVELK@SHN3    GASHN3
     C                     Z-ADDW@SYS     GASYOS
     C                     Z-ADD1         X
     C           X         DOWLE93
     C                     MOVELGDT,X     YM6     60
     C                     MOVE GDT,X     D       20
     C                     SELEC
     C           YM6       WHEQ K@YMN
     C                     Z-ADDGCG,X     GAGK,D
     C                     ADD  GCG,X     GANNSU
     C           YM6       WHEQ K@YM1
     C                     ADD  GCG,X     GAN1SU
     C           YM6       WHEQ K@YM2
     C                     ADD  GCG,X     GAN2SU
     C                     ENDSL
     C                     ADD  1         X
     C                     ENDDO
     C                     WRITEGEAPP161
      *
     CSR         EESUB     ENDSR
      *----------------------------------------------------
      * LIMIT
      *----------------------------------------------------
     CSR         ZSUB      BEGSR
      *
     C                     Z-ADD1         X
     C           X         DOWLE93
     C           GDT,X     IFNE 0
     C           GHL,X     ANDEQ'Y'
     C                     Z-ADDGCB,X     @DBOX# 147
     C                     EXSR #RATE
     C           GCB,X     MULT W@RATE    GMX,X
     C*****      GMX,X     MULT W@SYS     QMX,X
     C           GCG,X     MULT W@RATE    QMX,X
     C           GCG,X     IFGT QMX,X
     C                     Z-ADDQMX,X     GCG,X
     C                     ENDIF
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         EZSUB     ENDSR
      *----------------------------------------------------
      *
      *----------------------------------------------------
     CSR         ASUB1     BEGSR
      *
     C                     Z-ADD*ZERO     W@MINS
     C                     Z-ADD*ZERO     W#MINS  90
     C                     Z-ADD*ZERO     W#DAY   20
      *
     C                     Z-ADD1         X       30
     C           X         DOWLE93
      *
     C           GDT,X     IFGE *DATE
     C           GHL,X     IFEQ *BLANK
     C           HHL,X     ANDEQ*BLANK
     C                     ELSE
     C                     EXSR ASUB11
     C                     ENDIF
     C                     ENDIF
      *
     C                     ADD  1         X
     C                     ENDDO
      *
     C                     MOVEAGCG       HCG
     C                     Z-ADD*ZERO     WWN110 110
      *
     C           K#05      KLIST
     C                     KFLD           K@SHN1
     C                     KFLD           K@SHN2
     C                     KFLD           K@SHN3
     C                     KFLD           N@YMN   60
     C                     CLEARPLS
     C                     CLEARMNS
      * N
     C                     Z-ADDK@YMN     N@YMN
     C           K#05      CHAINBTAPL05              94
     C           *IN94     IFEQ '0'
     C           BTSKJY    ANDEQ'D'
     C           BTSKHZ    ANDLE*DATE
     C                     SETON                     94
     C                     ENDIF
     C           *IN94     IFEQ '0'
     C                     EXSR ASUB12
     C                     ENDIF
      * N+1
     C                     Z-ADDK@YM1     N@YMN
     C           K#05      CHAINBTAPL05              94
     C           *IN94     IFEQ '0'
     C           BTSKJY    ANDEQ'D'
     C           BTSKHZ    ANDLE*DATE
     C                     SETON                     94
     C                     ENDIF
     C           *IN94     IFEQ '0'
     C                     EXSR ASUB12
     C                     ENDIF
      * N+2
     C                     Z-ADDK@YM2     N@YMN
     C           K#05      CHAINBTAPL05              94
     C           *IN94     IFEQ '0'
     C           BTSKJY    ANDEQ'D'
     C           BTSKHZ    ANDLE*DATE
     C                     SETON                     94
     C                     ENDIF
     C           *IN94     IFEQ '0'
     C                     EXSR ASUB12
     C                     ENDIF
      *
     CSR         EASUB1    ENDSR
      *----------------------------------------------------
      *稼働差
      *----------------------------------------------------
     CSR         ASUB11    BEGSR
      *
     C                     MOVEL'0'       SETF    1
     C                     Z-ADD1         Z
     C                     Z-ADDGDT,X     X#YMD   80
     C           Z         DOWLE10
     C           SETF      ANDEQ'0'
     C           X#YMD     IFGE @CGH,Z
     C                     MOVEL'1'       SETF
     C           GHL,X     IFEQ *BLANK
     C                     ADD  @CGK,Z    KDS,X
     C                     ELSE
     C                     ADD  @CGK,Z    GCG,X
     C           @CGK,Z    DIV  W@SYS     GCB,X
     C                     ENDIF
     C                     ENDIF
     C                     ADD  1         Z
     C                     ENDDO
      *
     CSR                   ENDSR
      *----------------------------------------------------
      *
      *----------------------------------------------------
     CSR         ASUB12    BEGSR
      *
     C                     Z-ADD1         Z
     C           Z         DOWLE31
     C           HTZ,Z     IFEQ *BLANK
     C                     MOVELN@YMN     A@YMD
     C                     MOVE Z         A@YMD
     C                     Z-ADD1         A       30
     C           A@YMD     LOKUPGDT,A                    29
      * +
     C           HTP,Z     IFNE 0
     C           W@SYS     MULT HTP,Z     W@N110 110
     C           *IN29     IFEQ '1'
     C                     ADD  W@N110    PLS,A
     C                     ENDIF
     C                     ENDIF
      * -
     C           HTM,Z     IFNE 0
     C           W@SYS     MULT HTM,Z     W@N110 110
     C           *IN29     IFEQ '1'
     C                     ADD  W@N110    MNS,A
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ADD  1         Z
     C                     ENDDO
      *
     CSR                   ENDSR
      *----------------------------------------------------
      *
      *----------------------------------------------------
     C* PRICE MASTER EXPIRED
     CSR         BSUB      BEGSR
      *
     C                     Z-ADD0         K@YMDE
     C                     Z-ADD0         K@STHZ  80
      *
     C           K#SHIN    SETGTGDKPL04
     C           K#SHIN    REDPEGDKPL04                  93
     C           *IN93     DOWEQ'0'
     C           K@YMDE    ANDEQ0
     C           ISSKJY    IFEQ *BLANK
     C           ISENYM    IFGE W@YYMM
     C                     Z-ADDISENHZ    K@YMDE
     C                     Z-ADDISSTHZ    K@STHZ
     C                     ENDIF
     C                     ENDIF
     C           K#SHIN    REDPEGDKPL04                  93
     C                     ENDDO
      *
     C                     Z-ADD1         X
     C           X         DOWLE93
     C           GDT,X     IFLT K@STHZ
     C           GDT,X     ANDNE0
     C**         K@YMDE    ANDNE99999999
     C                     Z-ADD0         GCG,X
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------
      *
      *----------------------------------------------------
      * PREV ORDERED,ADJUSTMENT
     CSR         CSUB1     BEGSR
      *
     C           K#GDG     KLIST
     C                     KFLD           K@SHN1
     C                     KFLD           K@SHN2
     C                     KFLD           K@SHN3
     C                     KFLD           K@YYN
     C                     KFLD           K@MMN
     C                     KFLD           K@N020  20
     C                     Z-ADD1         K@N020
     C                     CLEARGDGF
     C                     MOVELN@YMN     A@YMD
      *
     C           K@N020    DOWLE31
     C           K@N020    ANDLTW@TODY
     C                     Z-ADDK@YYN     A@YY
     C                     Z-ADDK@MMN     A@MM
     C                     Z-ADDK@N020    A@DD
     C                     Z-ADD1         A
     C           A@YMD     LOKUPGDT,A                    29
     C           K#GDG     CHAINGDGPL19              92
     C           *IN92     IFEQ *OFF
     C           ICSKJY    ANDEQ*BLANK
     C           ICMAIS    MULT ICSYOS    W4MQTY  90
     C           *IN29     IFEQ '1'
     C                     Z-ADDW4MQTY    GCG,A
     C                     MOVEL'1'       GDGF,A
     C                     ENDIF
     C                     ELSE
     C           *IN29     IFEQ '1'
     C                     Z-ADD*ZERO     GCG,A
     C                     MOVEL'1'       GDGF,A
     C                     ENDIF
     C                     ENDIF
      *
     C                     ADD  1         K@N020
     C                     ENDDO
      *
      * ----------------------------------------------------
      *
     C                     Z-ADD0         W4MQTY  90
     C           K#FCE     CHAINBTAPP41              93
     C           *IN93     IFEQ *ON
     C           B4SKJY    ORNE *BLANK
     C                     ELSE
     C           B4MAIS    MULT W@SYS     W4MQTY  90
     C                     ENDIF
      *調整枚数を引く
     C                     Z-ADD1         X
     C           X         DOWLE93
     C           W4MQTY    ANDGT0
     C           GDT,X     IFNE 0
     C           GHL,X     ANDNE*BLANK
      * 実績は、対象にしない
     C           GDGF,X    ANDNE'1'
     C           W4MQTY    IFGT GCG,X
     C                     SUB  GCG,X     W4MQTY
     C                     Z-ADD*ZERO     GCG,X
     C                     ELSE
     C                     SUB  W4MQTY    GCG,X
     C                     Z-ADD*ZERO     W4MQTY
     C                     ENDIF
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         ECSUB1    ENDSR
      *----------------------------------------------------
      *計画発行マイナスの処理       * NOT USED
      *配列MNSは計画発行マイナスの値を正の値でセットしてある
      *----------------------------------------------------
     CSR         CSUB2     BEGSR
      *
     C                     Z-ADD0         PLNMNS 110
     C                     Z-ADD1         X
     C           X         DOWLE93
     C                     ADD  MNS,X     PLNMNS
     C                     EXSR CSUB21
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         ECSUB2    ENDSR
      *----------------------------------------------------
      *計画発行マイナスの処理       * NOT USED
      *----------------------------------------------------
     CSR         CSUB21    BEGSR
      *
     C           PLNMNS    IFGT 0
     C           GHL,X     IFEQ 'Y'
     C           GDGF,X    ANDNE'1'
     C                     SELEC
     C           GCG,X     WHGE PLNMNS
     C                     SUB  PLNMNS    GCG,X
     C                     Z-ADD0         PLNMNS
     C           GCG,X     WHLT PLNMNS
     C                     SUB  GCG,X     PLNMNS
     C                     Z-ADD0         GCG,X
     C                     ENDSL
     C                     ENDIF
     C                     ENDIF
      *
     CSR                   ENDSR
      *----------------------------------------------------
      *稼働差の処理　稼働差の分をプラスする
      *----------------------------------------------------
     CSR         CSUB3     BEGSR
      *
     C                     Z-ADD0         KADSA  110
     C                     Z-ADD1         X
     C           X         DOWLE93
     C                     EXSR CSUB31
     C                     ADD  KDS,X     KADSA
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         ECSUB3    ENDSR
      *----------------------------------------------------
      *稼働差の処理　稼働差の分をプラスする
      *----------------------------------------------------
     CSR         CSUB31    BEGSR
      *
     C           KADSA     IFGT 0
     C           GHL,X     IFEQ 'Y'
     C           GDGF,X    ANDNE'1'
     C           QMX,X     SUB  GCG,X     WKYO    70       余裕
     C           WKYO      IFGT 0
     C                     SELEC
     C           KADSA     WHGT WKYO
     C                     ADD  WKYO      GCG,X
     C                     SUB  WKYO      KADSA
     C           KADSA     WHLE WKYO
     C                     ADD  KADSA     GCG,X
     C                     Z-ADD0         KADSA
     C                     ENDSL
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     CSR                   ENDSR
      *----------------------------------------------------
      *計画発行のプラスの処理  * NOT USED
      *----------------------------------------------------
     CSR         CSUB4     BEGSR
      *
     C                     Z-ADD0         PLNPLS 110
     C                     Z-ADD1         X
     C           X         DOWLE93
     C                     ADD  PLS,X     PLNPLS
     C                     EXSR CSUB41
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         ECSUB4    ENDSR
      *----------------------------------------------------
      *計画発行のプラスの処理  * NOT USED
      *----------------------------------------------------
     CSR         CSUB41    BEGSR
      *
     C           PLNPLS    IFGT 0
     C           GHL,X     IFEQ 'Y'
     C           GDGF,X    ANDNE'1'
     C           QMX,X     SUB  GCG,X     WKYO    70       余裕
     C           WKYO      IFGT 0
     C                     SELEC
     C           PLNPLS    WHGT WKYO
     C                     ADD  WKYO      GCG,X
     C                     SUB  WKYO      PLNPLS
     C           PLNPLS    WHLE WKYO
     C                     ADD  PLNPLS    GCG,X
     C                     Z-ADD0         PLNPLS
     C                     ENDSL
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     CSR                   ENDSR
      *----------------------------------------------------
      *計画発行のプラスマイナスの処理
      *----------------------------------------------------
     CSR         CSUB6     BEGSR
      *
     C                     Z-ADD0         PLSMNS 110
     C                     Z-ADD1         X
     C           X         DOWLE93
     C                     ADD  PLS,X     PLSMNS
     C                     SUB  MNS,X     PLSMNS
     C                     EXSR CSUB61
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         ECSUB6    ENDSR
      *----------------------------------------------------
      *計画発行のプラスの処理
      *----------------------------------------------------
     CSR         CSUB61    BEGSR
      *
1    C           PLSMNS    IFGT 0
|2   C           GHL,X     IFEQ 'Y'
||   C           GDGF,X    ANDNE'1'
||   C           QMX,X     SUB  GCG,X     WKYO    70       余裕
||3  C           WKYO      IFGT 0
|||  C                     SELEC
|||  C           PLSMNS    WHGT WKYO
|||  C                     ADD  WKYO      GCG,X
|||  C                     SUB  WKYO      PLSMNS
|||  C           PLSMNS    WHLE WKYO
|||  C                     ADD  PLSMNS    GCG,X
|||  C                     Z-ADD0         PLSMNS
|||  C                     ENDSL
||3  C                     ENDIF
|2   C                     ENDIF
1    C                     ENDIF
      *
1    C           PLSMNS    IFLT 0
|2   C           GHL,X     IFEQ 'Y'
||   C           GDGF,X    ANDNE'1'
||   C           PLSMNS    MULT -1        W@MNS  110
||   C                     SELEC
||   C           GCG,X     WHGE W@MNS
||   C                     SUB  W@MNS     GCG,X
||   C                     Z-ADD0         PLSMNS
||   C           GCG,X     WHLT W@MNS
||   C                     ADD  GCG,X     PLSMNS
||   C                     Z-ADD0         GCG,X
||   C                     ENDSL
|2   C                     ENDIF
1    C                     ENDIF
      *
     CSR                   ENDSR
      *----------------------------------------------------
      *GDGPP75
      *----------------------------------------------------
     CSR         CSUB5     BEGSR
      *
     C                     Z-ADD0         PLNPLS 110
     C                     Z-ADD1         X
     C           X         DOWLE93
     C           GDT,X     IFNE 0
     C           GHL,X     ANDEQ'Y'
     C           GDGF,X    ANDNE'1'
     C                     EXSR CSUB51
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         ECSUB5    ENDSR
      *-----------------------------------------------------------
      *  GDGPP75
      *-----------------------------------------------------------
     CSR         CSUB51    BEGSR
      *
     C                     Z-ADD0         WNRATE  52
     C                     Z-ADDGDT,X     A@YMD
     C           K#GP75    KLIST
     C                     KFLD           A@YY    40
     C                     KFLD           A@MM    20
     C                     KFLD           A@DD    20
     C           K#GP75    CHAINGDGPP75              90
     C           *IN90     IFEQ *OFF
     C           GNSKJY    ANDEQ*BLANK
     C                     Z-ADDGNRATE    WNRATE
     C                     ELSE
     C                     Z-ADD1         WNRATE
     C                     ENDIF
     C*
     C                     MULT WNRATE    GCG,X
      *
     CSR                   ENDSR
      *-----------------------------------------------------------
      *  GET RATE(W@RATE)
      *-----------------------------------------------------------
     C           #RATE     BEGSR
     C*
     C                     Z-ADD*ZERO     W@RATE  52
     C                     MOVEL'0'       W@PP06  1
     C*
     C           K#FCE     CHAINAHDPP06              88
     C           *IN88     IFEQ *OFF
     C           AISKJY    ANDEQ*BLANK
     C                     Z-ADDAIKISU    W@RATE  52
     C                     MOVEL'1'       W@PP06
     C                     ENDIF
      *
     C                     Z-ADD1         I
     C           I         DOWLEW@MAXI
     C           W@PP06    ANDEQ'0'
     C* <
     C           @FUG,I    IFEQ '1'
     C           @DBOX#    ANDLT@HTS,I
     C                     Z-ADD@KIS,I    W@RATE
     C                     MOVEL'1'       W@PP06  1
     C                     ENDIF
     C* >
     C           @FUG,I    IFEQ '2'
     C           @DBOX#    ANDGT@HTS,I
     C                     Z-ADD@KIS,I    W@RATE
     C                     MOVEL'1'       W@PP06  1
     C                     ENDIF
     C* =
     C           @FUG,I    IFEQ '3'
     C           @DBOX#    ANDEQ@HTS,I
     C                     Z-ADD@KIS,I    W@RATE
     C                     MOVEL'1'       W@PP06  1
     C                     ENDIF
     C* <=
     C           @FUG,I    IFEQ '4'
     C           @DBOX#    ANDLE@HTS,I
     C                     Z-ADD@KIS,I    W@RATE
     C                     MOVEL'1'       W@PP06  1
     C                     ENDIF
      * >=
     C           @FUG,I    IFEQ '5'
     C           @DBOX#    ANDGE@HTS,I
     C                     Z-ADD@KIS,I    W@RATE
     C                     MOVEL'1'       W@PP06  1
     C                     ENDIF
      * <>
     C           @FUG,I    IFEQ '6'
     C           @DBOX#    ANDNE@HTS,I
     C                     Z-ADD@KIS,I    W@RATE
     C                     MOVEL'1'       W@PP06  1
     C                     ENDIF
     C*
     C                     ADD  1         I
     C                     ENDDO
      *
     C                     ENDSR
