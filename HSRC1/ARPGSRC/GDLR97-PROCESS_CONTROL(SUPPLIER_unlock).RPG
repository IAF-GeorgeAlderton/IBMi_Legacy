     H            Y.                                    1
      ** GDLR97 ********************************************
      *  SUPPLIER PROCESS UNLOCK
      *
      * TCHK1 03/18/08 CREATE(COPY FROM GDLR98)
      *******************************************************
     FGDLNP11 UF  E           K        DISK
     F*******************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I            DS
     I                                        1  140W@TIME
     I                                        1   20W@TH
     I                                        3   40W@TM
     I                                        5   60W@TS
     I                                        7  140W@DYMD
     I                                        7  100W@DY
     I                                       11  120W@DM
     I                                       13  140W@DD
     I            DS
     I                                        1   80L1KODT
     I                                        1   40L1KOYY
     I                                        5   60L1KOMM
     I                                        7   80L1KODD
     C******************************************************
     C*  MAIN
     C******************************************************
     C                     EXSR @INT
     C*
     C                     EXSR @MAIN
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C******************************************************
     C*  INITIAL
     C******************************************************
     C           @INT      BEGSR
     C*
     C           *ENTRY    PLIST
     C                     PARM           P@PROC  1        PROCESS CODE
     C                     PARM           P@SUPP  4        SUPPLIER
     C                     PARM           P@RTNC  1        RETURN CODE
     C                     MOVEL*BLANK    P@RTNC
     C*
     C                     TIME           W@TIME
     C*
     C                     ENDSR
     C******************************************************
     C*  MAIN
     C******************************************************
     C           @MAIN     BEGSR
     C*
     C           P@SUPP    CHAINGDLNP111             90
     C*
     C           *IN90     IFEQ *OFF
     C*
     C           P@PROC    IFEQ '1'
     C                     Z-ADD*ZERO     L1DATE
     C                     MOVEL*BLANK    L1PC01
     C                     MOVEL*BLANK    L1PC02
     C                     MOVEL*BLANK    L1PC03
     C                     MOVEL*BLANK    L1PC04
     C                     MOVEL*BLANK    L1PC05
     C                     END
     C           P@PROC    IFEQ '2'
     C                     MOVEL*BLANK    L1PC02
     C                     END
     C*
     C                     Z-ADDW@DYMD    L1KODT
     C                     Z-ADDW@TH      L1KOHH
     C                     Z-ADDW@TM      L1KOSS
     C                     MOVEL#PGM      L1KOPG
     C                     MOVEL#WSID     L1KOWS
     C                     MOVEL#USER     L1KOUS
     C                     UPDATGDLNP111
     C*
     C                     END
     C*
     C                     ENDSR
