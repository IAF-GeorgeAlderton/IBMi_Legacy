     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ ABBPP01                  98
     C   98                LEAVE
      *
     C           K#AB      CHAINABAWP101             90
     C           *IN90     IFEQ *OFF
     C           ABBFLG    ANDNE'9'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE Q5CHK2    Q5CHK1
     C                     Z-ADDQ5CHS2    Q5CHS1
     C                     MOVE *BLANK    Q5CHK2
     C                     Z-ADD0         Q5CHS2
     C                     MOVE Q5N1NK    Q5N2NK
     C                     Z-ADDQ5N1NM    Q5N2NM
     C                     Z-ADDN1        N2
     C                     MOVE Q5NNNK    Q5N1NK
     C                     Z-ADDQ5NNNM    Q5N1NM
     C                     Z-ADDNN        N1
     C                     MOVE Q51NNK    Q5NNNK
     C                     Z-ADDQ51NNM    Q5NNNM
     C                     Z-ADDQ51NNM    Q5NNOM
      *
     C           Q51NNM    DIV  WCD       WDNNM   90
     C                     MVR            WAMARI  90
     C                     Z-ADD1         #D
     C           1         DO   31        #D
     C           WDNNM     MULT HCD,#D    NN,#D
     C           WAMARI    IFNE 0
     C           HCD,#D    ANDNE0
     C           WAMARI    IFEQ 1
     C                     ADD  1         NN,#D
     C                     SUB  1         WAMARI
     C                     ELSE
     C                     ADD  HCD,#D    NN,#D
     C                     SUB  HCD,#D    WAMARI
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C*
     C                     MOVE Q52NNK    Q51NNK
     C                     Z-ADDQ52NNM    Q51NNM
     C                     Z-ADDQ52NNM    Q51NOM
     C                     MOVE *BLANK    Q52NNK
     C                     Z-ADD0         Q52NOM
     C                     Z-ADD0         Q52NNM
      *
     C           *IN90     IFEQ *OFF
     C                     Z-ADDABNNSU    Q52NNM
     C                     ENDIF
      *
     C                     Z-ADDQ5N3GM    Q5N4GM
     C                     Z-ADDQ5N3ND    Q5N4ND
     C                     Z-ADDQ5N2GM    Q5N3GM
     C                     Z-ADDQ5N2ND    Q5N3ND
     C                     Z-ADDQ5N1GM    Q5N2GM
     C                     Z-ADDQ5N1ND    Q5N2ND
     C                     Z-ADD0         Q5N1GM
     C                     Z-ADD0         Q5N1ND
     C                     Z-ADDWHIZ      Q5NTYM
     C                     Z-ADDWDATE     Q5NHHZ
     C                     MOVE '*'       Q5NSYR
      *
     C           Q5CHS1    IFEQ 0
     C           Q5CHS2    ANDEQ0
     C           Q5N2NM    ANDEQ0
     C           Q5N1NM    ANDEQ0
     C           Q5NNNM    ANDEQ0
     C           Q51NNM    ANDEQ0
     C           Q52NNM    ANDEQ0
     C           Q5N4GM    ANDEQ0
     C           Q5N3GM    ANDEQ0
     C           Q5N2GM    ANDEQ0
     C           Q5N1GM    ANDEQ0
     C                     DELETABBPP011
     C                     ELSE
     C                     UPDATABBPP011
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ****************************************************
      * INITIAL SETTING
      ****************************************************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           PHIZ    6
      *
     C           K#AB      KLIST
     C                     KFLD           Q5TOKU
     C                     KFLD           Q5NONY
     C                     KFLD           Q5NKOJ
     C                     KFLD           Q5NUKE
     C                     KFLD           Q5SEBN
     C                     KFLD           Q5MHN1
     C                     KFLD           Q5MHN2
     C                     KFLD           Q5MHN3
     C                     KFLD           Q5MHN4
     C                     KFLD           K@N2    60
      *
     C                     TIME           WTMDT
      *
     C                     MOVE PHIZ      WHIZ    60
     C                     MOVE PHIZ      K@N2
     C                     ADD  2         @@MM
     C           @@MM      IFGT 12
     C                     ADD  1         @@YY
     C                     SUB  12        @@MM
     C                     ENDIF
     C*
     C                     Z-ADD0         WCD     31
     C                     Z-ADD0         HCD
     C                     Z-ADDWHIZ      WWYM
      *
     C           KEY1      KLIST
     C                     KFLD           WWYY
     C                     KFLD           WWMM
      *
     C           KEY1      SETLLAGDPL121
     C                     DO   *HIVAL
     C                     SETOF                     21
     C           KEY1      READEAGDPL121                 21
     C   21                LEAVE
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADDF8KADD    #D      20
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  2         WCD
     C                     Z-ADD2         HCD,#D
     C                     ELSE
     C                     ADD  1         WCD
     C                     Z-ADD1         HCD,#D
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
