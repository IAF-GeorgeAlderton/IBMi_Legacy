     C                     MOVELSTSHN2    W@HIN2           *社内品番２
     C                     MOVELSTSHN3    W@HIN3           *社内品番３
     C                     MOVELW@HNBN    D2SHNB           *社内品番
     C                     END                             ｢IF_01
      *工程セット
     C                     MOVEL*BLANK    W@FRST  1        *初回ON
     C           D2RRN     DOWLT15                         ¬DO_01
     C                     CLEARSFLREC02
     C                     ADD  1         D2RRN
     C                     SETOF                     4243
      *
     C           *IN80     IFEQ '0'                        ~¬IF_01
     C                     Z-ADDSTKTNO    S2KTNO           *工程番号
