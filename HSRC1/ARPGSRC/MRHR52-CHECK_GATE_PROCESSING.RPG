     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #SET20   第二画面(G2) 項目セット処理
      *-------------------------------------------------------------------------
     C           #SET20    BEGSR
      * CTL
     C                     SETON                         33
     C                     WRITESFLCTL02
     C                     SETOF                         33
      *
     C                     Z-ADD*ZERO     D2RRN
     C                     Z-ADD*ZERO     W@RRNW  40
      *
     C                     MOVELW@TEH2    D2TEHI           *手配番号
     C                     MOVEL*BLANK    D2SHNB           *社内品番
      *試作手配データファイル(MRHPL51)
     C                     MOVELW@TH21    STTHI1           *手配№　絶対番号
     C                     MOVELW@TH22    STTHI2           *手配№　連番
     C                     Z-ADDW@GRHZ    STGRHZ           *登録日
     C                     Z-ADDW@GRTM    STGRTM           *登録時間
