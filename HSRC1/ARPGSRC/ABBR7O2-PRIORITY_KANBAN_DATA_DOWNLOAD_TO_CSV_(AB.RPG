     H            Y.
     F** ABBR7O2 *********************************
     F*  DOWNLOAD PRIORITY KANBAN LIST DATA      *
     F*  JW       2022.06.15                     *
     F********************************************
     FABBWP7B IF  E           K        DISK
     FABBWP7C O   E           K        DISK
      *--------------------------------------------------
     E                    HDR     1  30 10
     I            DS
     I                                        1  14 A7PRT
     I                                        1   5 A7PRT1
     I                                        7  11 A7PRT2
     I                                       13  14 A7PRT3
      *--------------------------------------------------
      *
     C                     EXSR #HDR
      *
     C                     DO   *HIVAL
     C                     READ ABBWP7B                  98
     C   98                LEAVE
      *
     C                     EXSR #MOVE
      *
     C                     WRITEABBWP7C1
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
      * OUTPUT HEADER
      *-----------------------------------------------
     C           #HDR      BEGSR
      *
     C                     MOVELHDR,01    X7SIZ
     C                     MOVELHDR,02    X7LCID
     C                     MOVELHDR,03    X7LOCT
     C                     MOVELHDR,04    X7PRT1
     C                     MOVELHDR,05    X7KQTY
     C                     MOVELHDR,06    X7KNID
     C                     MOVELHDR,07    X7ISDT
     C                     MOVELHDR,08    X7PRC1
     C                     MOVELHDR,09    X7MCHN
     C                     MOVELHDR,10    X7CMNT
     C                     MOVELHDR,11    X7LOTS
     C                     MOVELHDR,12    X7SHFT
     C                     MOVELHDR,13    X7NPRC
     C                     MOVELHDR,14    X7NMCH
     C                     MOVELHDR,15    X7NLOC
     C                     MOVELHDR,16    X7MSTQ
     C                     MOVELHDR,17    X7DSTQ
     C                     MOVELHDR,18    X7MSTB
     C                     MOVELHDR,19    X7DSTB
     C                     MOVELHDR,20    X7QPC
     C                     MOVELHDR,21    X7BRCD
     C                     MOVELHDR,22    X7DATE
     C                     MOVELHDR,23    X7TIME
     C                     MOVELHDR,24    X7USER
     C                     MOVELHDR,25    X7WSID
     C                     MOVELHDR,26    X7PGID
      *
     C                     WRITEABBWP7C1
      *
     C                     ENDSR
      *-----------------------------------------------
      * SET DATA
      *-----------------------------------------------
     C           #MOVE     BEGSR
      *
     C                     CLEARABBWP7C1
     C                     MOVELA7SIZ     X7SIZ
     C                     MOVELA7LCID    X7LCID
     C                     MOVELA7LOCT    X7LOCT
     C                     MOVELA7PRT     X7PRT1
     C                     MOVELA7KQTY    X7KQTY
     C                     MOVELA7KNID    X7KNID
      *
     C                     MOVELA7ISDT    $DATE1
     C                     MOVEL'000000'  $TIME1
     C                     MOVE 'YMD'     $YMD
     C                     CALL 'EDTR01 '
     C                     PARM           $DATE1  8
     C                     PARM           $TIME1  6
     C                     PARM           $YMD    3
     C                     PARM           $DATE2 10
     C                     PARM           $TIME2  8
     C                     MOVEL$DATE2    X7ISDT
     C           A7ISDT    IFEQ 0
     C                     MOVE *BLANK    X7ISDT
     C                     ENDIF
      *
     C                     MOVELA7PRC1    X7PRC1
     C                     MOVELA7MCHN    X7MCHN
     C                     MOVELA7CMNT    X7CMNT
     C                     MOVELA7LOTS    X7LOTS
     C                     MOVELA7SHFT    X7SHFT
     C                     MOVELA7NPRC    X7NPRC
     C                     MOVELA7NMCH    X7NMCH
      *
     C                     MOVELA7NLOC    $LOC6
     C                     CALL 'EDTR06B'
     C                     PARM           $LOC6   6
     C                     PARM           $LOC9   9
     C                     MOVEL$LOC9     X7NLOC
      *
     C                     MOVELA7MSTQ    X7MSTQ
     C                     MOVELA7DSTQ    X7DSTQ
      *
     C                     Z-ADDA7MSTB    $IN
     C                     CALL 'EDTR05A'
     C                     PARM           $IN    156
     C                     PARM           $TRUE  17
     C                     PARM           $RTN    1
     C                     MOVEL$TRUE     X7MSTB
      *
     C                     Z-ADDA7DSTB    $IN
     C                     CALL 'EDTR05A'
     C                     PARM           $IN    156
     C                     PARM           $TRUE  17
     C                     PARM           $RTN    1
     C                     MOVEL$TRUE     X7DSTB
      *
     C                     MOVELA7QPC     X7QPC
     C                     MOVELA7BRCD    X7BRCD
      *
     C                     MOVELA7DATE    $DATE1
     C                     MOVELA7TIME    $TIME1
     C                     MOVE 'YMD'     $YMD
     C                     CALL 'EDTR01 '
     C                     PARM           $DATE1  8
     C                     PARM           $TIME1  6
     C                     PARM           $YMD    3
     C                     PARM           $DATE2 10
     C                     PARM           $TIME2  8
     C                     MOVEL$DATE2    X7DATE
     C                     MOVEL$TIME2    X7TIME
      *
     C                     MOVELA7USER    X7USER
     C                     MOVELA7WSID    X7WSID
     C                     MOVELA7PGID    X7PGID
      *
     C                     ENDSR
** HDR(10A)
SIZE         1
POSITION     2
LOCATION     3
PART#        4
KANBAN_QTY   5
KANBAN_ID    6
ISSUE_DATE   7
PROCESS      8
MACHINE      9
COMMENT     10
LOT         11
SHIFT       12
NEXT_PROC   13
NEXT_MCN    14
NEXT_LOC    15
MONTH_QTY   16
DAILY_QTY   17
MONTH_BOX   18
DAILY_BOX   19
QPC         20
BARCODE     21
SCAN_DATE   22
SCAN_TIME   23
SCAN_USER   24
SCAN_WS     25
SCAN_PGM    26
