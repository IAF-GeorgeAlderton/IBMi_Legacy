     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C****************
     C*  初期処理  *
     C****************
     C           @STR      TAG
     C                     EXSR #INIT
     C****************
     C*  第一画面  *
     C****************
     C           @DSP1     TAG
     C                     SETOF                     20
     C                     WRITEDSPM1
     C                     EXFMTDSP01
     C                     MOVE *BLANK    D#MSG
     C* < F1=ON >
     C           *INKA     CABEQ'1'       @END
     C                     EXSR #CHK1
     C   99                GOTO @DSP1
     C****************
     C*  第二画面  *
     C****************
     C           @DSP2     TAG
     C                     SETON                     20
     C                     WRITEDSPM1
     C                     EXFMTDSP02
     C                     MOVE *BLANK    D#MSG
     C* < F1=ON >
     C           *INKA     CABEQ'1'       @END
     C           *INKC     CABEQ'1'       @DSP1
     C           *INKE     CABEQ'0'       @DSP2
     C                     EXSR #UPD
     C*
     C                     GOTO @STR
     C****************
     C           @END      TAG
     C                     SETON                     LR
     C                     RETRN
     C****************************************************************
     C*           ＳＵＢ　　ＲＯＵＴＩＮＥ                         *
