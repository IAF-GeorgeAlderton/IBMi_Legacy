     C           #INIT     BEGSR                                     *
     C****************************************************************
     C**初期処理**
     C* < fﾞx] ﾎｧｰﾓnﾞ hﾒaｰ >
     C                     Z-ADD0         D1ITEM
     C                     SETOF                     11
     C                     SETOF                     99
     C*
     C                     ENDSR
     C****************************************************************
     C           #CHK1     BEGSR                                     *
     C****************************************************************
     C                     SETOF                     11  99
     C**第１画面チェック**
     C           D1ITEM    SETLLGDIPL16
     C                     DO   *HIVAL
     C           D1ITEM    READEGDIPL16             N    90
     C   90                LEAVE
     C           IISKJY    IFEQ 'D'
     C           IISKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C                     LEAVE
     C                     ENDDO
     C*
     C           *IN90     IFEQ *ON
     C  N99                MOVELMSG,1     D#MSG
     C                     SETON                     1199
     C                     ELSE
     C                     MOVE IIKATA    D2KATA
     C                     Z-ADDIISURY    D2SURY
     C                     Z-ADDIISURT    D2SURT
     C                     MOVE IIIFMK    D2IFMK
     C                     ENDIF
     C*
     C                     ENDSR
     C****************************************************************
     C           #UPD      BEGSR                                     *
     C****************************************************************
     C           D1ITEM    SETLLGDIPL16
     C                     DO   *HIVAL
     C           D1ITEM    READEGDIPL16                  90
     C   90                LEAVE
     C           IISKJY    IFEQ 'D'
     C           IISKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C                     LEAVE
     C                     ENDDO
     C*
     C           *IN90     IFEQ *OFF
     C                     TIME           @@TIME
     C                     MOVE 'C'       IIIFMK
     C                     Z-ADD*DATE     IIIFHZ
     C                     Z-ADD*DATE     IIKOHZ
     C                     Z-ADD@TIME     IIKOTM
     C                     MOVE PPUSER    IIKOME
     C                     UPDATGDIPL161
     C                     ENDIF
     C                     ENDSR
     C****************************************************************
