     H            Y.
     F** ABBR75 *************************
     F*  PRIORITY KANBAN                *
     F*    MONTHLY SUMMARY              *
     F*                                 *
     F*  ADD DAILY ACTUAL BOXES
     F*                                 *
     F************************* ABBR75 **
     FABBPW75 CF  E                    WORKSTN
     FABBPL71 IF  E           K        DISK
     FAB#PL1A IF  E           K        DISK
     FABBWP75 UF  E           K        DISK                      A
      *--------------------------------------------------
     E                    DAT        31  5 0
     E                    QTY        31  5 0
     E                    WQ         31  5 0
     E                    MSG     1   1 78
      *--------------------------------------------------
     I            DS
     I                                        1   6 A7LOCT
     I                                        2   2 A702
     I                                        1   2 A701
     I            DS
     I                                        1   60W@YYMM
     I                                        1   40W@YY
     I                                        5   60W@MM
     I            DS
     I                                        1   40D@MMYY
     I                                        1   20D@MM
     I                                        3   40D@YY
     I            DS
     I                                        1 155 QTY
     I                                        1   50W7QT01
     I                                        6  100W7QT02
     I                                       11  150W7QT03
     I                                       16  200W7QT04
     I                                       21  250W7QT05
     I                                       26  300W7QT06
     I                                       31  350W7QT07
     I                                       36  400W7QT08
     I                                       41  450W7QT09
     I                                       46  500W7QT10
     I                                       51  550W7QT11
     I                                       56  600W7QT12
     I                                       61  650W7QT13
     I                                       66  700W7QT14
     I                                       71  750W7QT15
     I                                       76  800W7QT16
     I                                       81  850W7QT17
     I                                       86  900W7QT18
     I                                       91  950W7QT19
     I                                       96 1000W7QT20
     I                                      101 1050W7QT21
     I                                      106 1100W7QT22
     I                                      111 1150W7QT23
     I                                      116 1200W7QT24
     I                                      121 1250W7QT25
     I                                      126 1300W7QT26
     I                                      131 1350W7QT27
     I                                      136 1400W7QT28
     I                                      141 1450W7QT29
     I                                      146 1500W7QT30
     I                                      151 1550W7QT31
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           @END    1
      *
     C                     MOVE '01'      @@ID    2
     C                     MOVE *BLANK    @END
     C                     Z-ADD*ZERO     D@MMYY
      *
     C                     ENDSR
      *-----------------------------------------------
     C           #SCRN1    BEGSR
      *-----------------------------------------------
      *
     C                     EXFMTDSP01
      *
     C           *INKC     IFEQ *ON
     C                     MOVE '99'      @@ID
     C                     MOVE '1'       @END
     C                     ELSE
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #WRT
     C                     EXSR #WRT2
     C           @END      IFNE *BLANK
     C                     MOVE MSG,1     D@MSG
     C                     ELSE
     C                     MOVE '99'      @@ID
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------
     C           #CHK1     BEGSR
      *-----------------------------------------------
      *
     C                     SETOF                     6199
     C                     MOVE *BLANK    D@MSG
     C           D@MMYY    IFEQ *ZERO
     C                     SETON                     6199
     C                     ELSE
     C           D@MM      IFLE 0
     C           D@MM      ORGT 12
     C                     SETON                     6199
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------
     C           #WRT      BEGSR
      *-----------------------------------------------
      *
     C           2000      ADD  D@YY      W@YY
     C                     Z-ADDD@MM      W@MM
     C           W@YYMM    MULT 100       W@STRT  80
     C           W@STRT    ADD  31        W@END   80
     C                     MOVE *BLANK    W@LOC   2
     C                     Z-ADD*ZERO     WQ
     C                     Z-ADD*ZERO     DAT
     C                     MOVE '1'       @END
      *
     C           W@STRT    SETLLABBPL71
     C           *IN80     DOUEQ*ON
     C                     READ ABBPL71                  80
     C           *IN80     IFEQ *OFF
     C           A7DATE    ANDGTW@END
     C           *IN80     OREQ *ON
     C           W@LOC     IFNE *BLANK
     C                     EXSR #UPD
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
      *
     C           A7KQTY    IFEQ *ZERO
     C           A7SHFT    ORNE '3'
     C                     ITER
     C                     ENDIF
      *
     C           A701      IFNE W@LOC
     C           W@LOC     ANDNE*BLANK
     C                     EXSR #UPD
     C                     ENDIF
      *
     C                     MOVE A701      W@LOC
     C                     Z-ADDA7DATE    X       20
     C                     Z-ADDX         DAT,X
      *
     C           A7KNID    IFNE 'A'
     C           A7LOTS    ANDNE*ZERO
     C           A7LOTS    MULT A7KQTY    @@QTY   50
     C                     ELSE
     C                     Z-ADDA7KQTY    @@QTY
     C                     ENDIF
      *
     C                     ADD  @@QTY     WQ,X
      *
     C                     ENDDO
      *
     C                     ENDSR
      *--------------------------------------------------------
     C           #UPD      BEGSR
      *--------------------------------------------------------
     C                     MOVE *BLANK    K@ID
     C           K@ID      CHAINABBWP75              90
     C           *IN90     IFEQ *ON
     C                     CLEARABBWP751
     C                     MOVE K@ID      W7LCID
     C                     Z-ADDDAT       QTY
     C                     WRITEABBWP751
     C                     ELSE
     C           1         DO   31        X
     C           QTY,X     IFEQ *ZERO
     C           DAT,X     ANDNE*ZERO
     C                     Z-ADDDAT,X     QTY,X
     C                     ENDIF
     C                     ENDDO
     C                     UPDATABBWP751
     C                     ENDIF
      *
     C                     ADD  WQ        QTY
     C                     MOVE W@LOC     W@L1    1
     C                     SELEC
     C           W@L1      WHEQ 'H'
     C           W@L1      OREQ 'N'
     C           W@L1      OREQ 'S'
     C                     MOVE 'H'       K@ID    1
      *
     C           W@L1      WHEQ 'T'
     C           W@L1      OREQ 'L'
     C           W@L1      OREQ 'F'
     C           W@L1      OREQ 'J'
     C                     MOVE 'T'       K@ID
      *
     C           W@L1      WHEQ 'E'
     C           W@L1      OREQ 'G'
     C                     MOVE 'G'       K@ID
     C                     ENDSL
      *
     C           K@ID      CHAINABBWP75              90
     C           *IN90     IFEQ *ON
     C                     CLEARABBWP751
     C                     MOVE K@ID      W7LCID
     C                     ENDIF
     C                     ADD  WQ        QTY
     C  N90                UPDATABBWP751
     C   90                WRITEABBWP751
      *
     C                     Z-ADD*ZERO     WQ
     C                     MOVE *BLANK    @END
      *
     C                     ENDSR
      *-----------------------------------------------
     C           #WRT2     BEGSR
      *-----------------------------------------------
     C                     Z-ADD*ZERO     QTY
     C           W@STRT    SETLLAB#PL1A
     C           *IN90     DOUEQ*ON
     C                     READ AB#PL1A                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BANOHZ    IFGT W@END
     C                     LEAVE
     C                     ENDIF
      *
     C           BAUSYS    IFNE *ZERO
     C           BASYOS    ANDNE*ZERO
     C           BAUSYS    ANDNEBASYOS
     C                     ITER
     C                     ENDIF
      *
     C           BASYOS    IFEQ *ZERO
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADDBANODD    @D      20
     C           BAUSYS    IFNE *ZERO
     C           BASRYO    DIV  BAUSYS    @@QTY   50
     C                     ELSE
     C           BASYOS    IFNE *ZERO
     C           BASRYO    DIV  BASYOS    @@QTY   50
     C                     ENDIF
     C                     ENDIF
     C                     ADD  @@QTY     QTY,@D
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE 'X'       W7LCID
     C                     WRITEABBWP751
      *
     C                     ENDSR
      *-----------------------------------------------
** MSG
NO RECORD OF THE MONTH.
