     C           KEY1      KLIST
     C                     KFLD           AHHIN1
     C                     KFLD           AHHIN2
     C                     KFLD           AHHIN3
      *
     C           KEY2      KLIST
     C                     KFLD           AHHIN1
     C                     KFLD           AHHIN2
     C                     KFLD           AHHIN3
     C                     KFLD           @YY
     C                     KFLD           @MM
     C                     KFLD           @DD
      *
     C*------------------------------------------*
     C*   ..Ａ－ＰＩＣＳ　抜出累積ファイル..   *
     C*------------------------------------------*
     C           KEY2      SETLLAU#PL221
     C                     SETOF                     07
      *
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY1      READEAU#PL221                 10
     C           *IN10     IFEQ '0'
      *
     C                     SETON                     U207
     C                     Z-ADDAHYMD     YMD     80
     C                     Z-ADDAHBIN     BIN     20
     C                     EXCPTF01
      *
     C                     END
     C  N10                END
      *
     C           *IN07     IFEQ '0'
     C                     MOVE AHHIN1    CQSHN1
     C                     MOVE AHHIN2    CQSHN2
     C                     MOVE AHHIN3    CQSHN3
     C                     SETON                     U2
     C                     EXCPTF01
     C                     END
      *
     C*--------------------------------------*
     C*  ..未手配ファイル（受注データ）..  *
     C*--------------------------------------*
     C                     OPEN AD#PL11
     C           KEY2      SETLLAD#PL111
     C                     SETOF                     07
      *
     C                     DO   *HIVAL
     C                     SETOF                     20
     C           KEY1      READEAD#PL111                 20
     C           *IN20     IFEQ '0'
     C           CASKJY    IFEQ *BLANK
      *
     C                     SETON                     U207
     C                     Z-ADDAHYMD     WKYMD   80
     C                     Z-ADDAHBIN     WKBIN   20
     C                     MOVELCASHN1    WSHN1   5
     C                     MOVELCASHN2    WSHN2   5
     C                     MOVELCASHN3    WSHN3   2
     C                     Z-ADDCATOKU    WTOKU   40
     C                     Z-ADDCANONY    WNONY   40
     C                     MOVELCANKOJ    WNKOJ   1
     C                     MOVELCANUKE    WNUKE   4
     C                     Z-ADDCANOHZ    WNOHZ   80
     C                     MOVELCASKKB    WSKKB   1
     C                     MOVELCAGYOM    WGYOM   2
     C                     Z-ADDCANSRY    WNSRY   70
     C                     Z-ADDCATEHZ    WTEHZ   80
     C                     EXCPTF02
      *
     C                     END
     C                     END
     C  N20                END
     C                     CLOSEAD#PL11
      *
     C*----------------------------------------------*
     C*  ..Ａ－ＰＩＣＳ計画発行受注累積ファイル..  *
     C*----------------------------------------------*
     C                     OPEN BTAPL02
     C           KEY1      SETLLBTAPL021
     C                     Z-ADD*DATE     WYMD
      *
     C                     DO   *HIVAL
     C                     SETOF                     20
     C           KEY1      READEBTAPL021                 20
     C           *IN20     IFEQ '0'
     C           BTSKJY    IFEQ 'D'
     C           BTSKHZ    ANDLE*DATE
     C                     ELSE
     C           BTKEYM    IFGE WYM
      *
     C                     Z-ADDAHYMD     WKYMD
     C                     Z-ADDAHBIN     WKBIN
     C                     MOVELBTSHN1    WSHN1
     C                     MOVELBTSHN2    WSHN2
     C                     MOVELBTSHN3    WSHN3
     C                     Z-ADDBTTOKU    WTOKU
     C                     Z-ADDBTNONY    WNONY
     C                     MOVELBTNKOJ    WNKOJ
     C                     MOVELBTNUKE    WNUKE
     C                     MOVEL'S'       WSKKB
     C                     MOVEL'27'      WGYOM
      *
     C                     Z-ADDBTKEYM    WHYM
      *
     C                     Z-ADD1         A       20
     C           1         DO   31        A
     C           HMA,A     IFNE 0
     C           HBU,A     IFEQ 0
      *
     C                     SETON                     U207
     C                     Z-ADDA         WHDD
     C                     Z-ADDWHYMD     WNOHZ
     C                     Z-ADDWHYMD     WTEHZ
     C           HMA,A     MULT BTSYUY    WNSRY
     C                     EXCPTF02
      *
     C                     END
     C                     END
     C                     END
      *
     C                     END
     C                     END
     C                     END
     C  N20                END
     C                     CLOSEBTAPL02
      *
     C           *IN07     IFEQ '0'
     C                     SETON                     U2
     C                     MOVE AHHIN1    WSHN1
     C                     MOVE AHHIN2    WSHN2
     C                     MOVE AHHIN3    WSHN3
     C                     EXCPTF02
     C                     END
      *
