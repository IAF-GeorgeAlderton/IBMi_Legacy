     C                     ADD  WKSRY@    JRY1N
     C                     ADD  WKSRY@    JRY1N1
     C                     ADD  WKSRY@    JRY1N2
     C                     ADD  WKSRY@    JRY1N3
     C                     ADD  WKSRY@    JRY1N4
     C                     ADD  WKSRY@    JRY1N5
     C                     Z-ADDA2SOZI    W@SOZI  72
     C                     EXSR #PPD1@
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C           KEYMRH    KLIST
