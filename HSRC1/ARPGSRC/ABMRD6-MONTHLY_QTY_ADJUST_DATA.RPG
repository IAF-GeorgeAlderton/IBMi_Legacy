     C                     MOVELEASHN2    K2SHN2
     C                     MOVELEASHN3    K2SHN3
     C                     EXSR #PPD1
     C           EAZANM    IFEQ P1ZANM
     C           EAKAZI    ANDEQP1KAZI
     C*****      EAGEKN    MULT EASOZI    WKSRY  162
     C*****      WKSRY     DIV  1000      WKSRY@  90H
