     C                     MOVEL'0'       FCE     1
      *
     C           KEYFCE    CHAINFCEPL011             81
     C           *IN81     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'1'       FCE
     C                     MOVELA2BHB1    K2SHN1
     C                     MOVELA2BHB2    K2SHN2
     C                     MOVELA2BHB3    K2SHN3
     C                     EXSR #PPD1
     C           A2ZANM    IFEQ P1ZANM
     C           A2KAZI    ANDEQP1KAZI
     C*****      A2GEKN    MULT A2SOZI    WKSRY  162
     C*****      WKSRY     DIV  1000      WKSRY@  90H
     C                     Z-ADD0         WKSRY  162
