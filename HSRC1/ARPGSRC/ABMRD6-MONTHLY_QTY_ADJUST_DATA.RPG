     C                     ADD  WKSRY@    JRY1N1
     C                     ADD  WKSRY@    JRY1N2
     C                     ADD  WKSRY@    JRY1N3
     C                     ADD  WKSRY@    JRY1N4
     C                     ADD  WKSRY@    JRY1N5
     C                     Z-ADDEASOZI    W@SOZI  72
