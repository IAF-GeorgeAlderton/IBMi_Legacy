     C           KEYCN     CHAINABMPPD11             20
     C           *IN20     IFEQ '0'
     C           DDSKJY    ANDEQ'D'
     C           DDSKHZ    ANDLE*DATE
     C                     SETON                     20
     C                     ENDIF
     C           *IN20     IFEQ '0'
