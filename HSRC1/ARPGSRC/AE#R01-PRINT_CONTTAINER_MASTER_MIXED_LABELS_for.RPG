     H            Y.
      ** AE#R01 *****************************************************
      *  PRINT CONTTAINER/MASTER/MIXED LABELS FOR TBA(3324)         *
      *  JW     2022.03.16                                          *
      ***************************************************************
     FAB#PL76 IF  E           K        DISK
     FAB#PL1A IF  E           K        DISK
     FAB#PL7H IF  E           K        DISK
     FAB#PL71AIF  E           K        DISK
     FAB#NP30 UF  E           K        DISK                      A
      * OUT
     FAE#WP01CO   E                    DISK
     FAE#WP01MO   E                    DISK
     FAE#WP01IO   E                    DISK
      *
JW   FAB#XP01AO   E                    DISK
      *-----------------------------------------------------
     E                    MSG     1   5 50
     I            DS
     I                                        1  23 @@PART
     I                                        1   5 @@MHN1
     I                                        6   6 @@HP1
     I                                        7  11 @@MHN2
     I                                       12  12 @@HP2
     I                                       13  17 @@MHN3
     I                                       18  18 @@HP3
     I                                       19  23 @@MHN4
     I            DS
     I                                        1  20 MPMHIN
     I                                        1   5 MPMHN1
     I                                        6  10 MPMHN2
     I                                       11  15 MPMHN3
     I                                       16  20 MPMHN4
     I            DS
     I                                        1  12 MPSHIN
     I                                        1   5 MPSHN1
     I                                        6  10 MPSHN2
     I                                       11  12 MPSHN3
     I            DS
     I                                        1  12 BASHIN
     I                                        1   5 BASHN1
     I                                        6  10 BASHN2
     I                                       11  12 BASHN3
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   80PUNOHZ
     I                                        1   40PUNOYY
     I                                        5   60PUNOMM
     I                                        7   80PUNODD
     I            DS
     I                                        1   9 EKLOC
     I                                        1   1 EKLOC1
     I                                        2   2 EKHP1
     I                                        3   4 EKLOC2
     I                                        5   5 EKHP2
     I                                        6   7 EKLOC3
     I                                        8   8 EKHP3
     I                                        9   9 EKLOC4
     I            DS
     I                                        1   9 MPLOC
     I                                        1   1 MPLOC1
     I                                        2   2 MPHP1
     I                                        3   4 MPLOC2
     I                                        5   5 MPHP2
     I                                        6   7 MPLOC3
     I                                        8   8 MPHP3
     I                                        9   9 MPLOC4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------------
      * MAIN ROUTINE
      *-----------------------------------------------------
     C                     EXSR #INIT
      * EXIT
     C           OKFLG     IFEQ 'N'
     C                     GOTO PEND
     C                     ENDIF
      *
     C                     EXSR #CONT
      *
     C                     EXSR #MAST
      *
     C                     EXSR #MIX
      *
     C           PEND      TAG
     C                     MOVEL*ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
      * WRITE CONTAINER LABEL
      *-----------------------------------------------------
     C           #CONT     BEGSR
      *
     C                     MOVELPUNOHZ    KANOHZ
     C                     MOVELPUBINN    KANOBN
     C                     MOVELPUNONY    KANONY
     C                     MOVELPUNKOJ    KANKOJ
     C                     MOVELPUNUKE    KANUKE
     C                     MOVELPUODRN    KAODRN
     C           K#PL1A    SETLLAB#PL1A
     C                     DO   *HIVAL
     C           K#PL1B    READEAB#PL1A                  98
     C   98                LEAVE
      * IGNORE
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * IGNORE
     C           PUODRN    IFNE *BLANK
     C           PUODRN    ANDNEBAODRN
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #PP70
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
      * READ AB#PP70 AND OUTPUT AE#WP01C
      *-----------------------------------------------------
     C           #PP70     BEGSR
      * SET KEY
     C                     MOVELBANONY    XANONY
     C                     MOVELBANOBN    XANOBN
     C           K#PL7H    SETLLAB#PL7H
     C                     DO   *HIVAL
     C           K#PL7H    READEAB#PL7H                  98
     C   98                LEAVE
      * IGNORE
     C           EKSKJY    IFEQ 'D'
     C           EKSERL    ORLT $SERL
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #WRTC
     C                     ENDDO
      *
      *
     C                     ENDSR
      *-----------------------------------------------------
      * WRITE CONTAINER LABEL (AE#WP01C)
      *-----------------------------------------------------
     C           #WRTC     BEGSR
      *
     C                     CLEARAE#WP1C1
      *
     C                     MOVELMSG,1     C1TYPE
     C                     MOVELBAMHIN    C1PART
      *
     C                     MOVELBASHIN    $SHIN
     C                     CALL 'UTLR31C'
     C                     PARM           $SHIN  12
     C                     PARM           $NAME  15
     C                     MOVEL$NAME     C1PNAM
      *
     C**                   Z-ADDEKSRYO    NUM5    50
     C                     MOVELEKSYOS    NUM5    50
     C                     MOVELNUM5      C1QTY
      * SUPPLIER
     C           BAPGID    IFEQ *BLANK
     C                     MOVEL'318239'  C1SIRE
     C                     ELSE
     C                     MOVELBAPGID    C1SIRE
     C                     ENDIF
     C           SVSIRE    IFEQ *BLANK
     C                     MOVELC1SIRE    SVSIRE
     C                     ENDIF
      *
     C                     MOVELEKSERL    C1SERL
     C                     MOVELBANOHZ    C1SHDT
     C                     MOVEL'USA'     C1CORG           COUNTRY OF ORGIN
     C                     MOVE *BLANK    C1LOT#           LOT#
     C                     MOVE *BLANK    C1ECHG           ENG CHG LVL
      * GET SHIP TO/FROM ADDRESS (X1XAD1/2/3)
     C                     MOVELEKNONY    $DLV
     C                     EXSR #GETAD
     C                     MOVELX1TAD1    C1TAD1
     C                     MOVELX1TAD2    C1TAD2
     C                     MOVELX1TAD3    C1TAD3
     C                     MOVELX1FAD1    C1FAD1
     C                     MOVELX1FAD2    C1FAD2
     C                     MOVELX1FAD3    C1FAD3
      * BANGTAIL
     C                     MOVEL'   '     C1REF1
     C                     MOVELEKLOC     C1LOC
     C                     MOVELEKNONY    C1NONY
     C                     MOVELEKNKOJ    C1NKOJ
     C                     MOVELEKNUKE    C1NUKE
     C                     MOVELEKNOBN    C1NOBN
     C                     MOVELEKTOKU    C1TOKU
      * OTHER INFORMATION
     C                     MOVELBASHIN    C1IPAR
     C                     MOVELEKZETI    C1ZETI
     C                     Z-ADDBASYOS    NUM6    60
     C                     MOVELNUM6      C1SYOS
     C                     MOVELBAINVN    C1INVN
      *
     C                     WRITEAE#WP1C1
JW   C*
 .   C                     MOVEL'AE#WP1C 'IXWRKF    P
 .   C                     EXSR #XP01                      =>AB#XP01
JW   C*
      *
     C                     ENDSR
      *-----------------------------------------------------
      * GET SHIP TO/FROM ADDRESS
      *-----------------------------------------------------
     C           #GETAD    BEGSR
      * TO ADDRESS
     C                     CALL 'UTLR59'
     C                     PARM           $DLV    4
     C                     PARM           X1TAD1 50
     C                     PARM           X1TAD2 50
     C                     PARM           X1TAD3 50
     C                     PARM           X1TAD4 50
     C                     PARM           X1TAD5 50
     C                     PARM           X1TAD6 50
      * FROM ADDRESS
     C                     MOVEL'0111'    $DLV
     C                     CALL 'UTLR59'
     C                     PARM           $DLV
     C                     PARM           X1FAD1 50
     C                     PARM           X1FAD2 50
     C                     PARM           X1FAD3 50
     C                     PARM           X1FAD4 50
     C                     PARM           X1FAD5 50
     C                     PARM           X1FAD6 50
      *
     C                     ENDSR
      *-----------------------------------------------------
      * WRITE MASTER LABEL
      *-----------------------------------------------------
     C           #MAST     BEGSR
      *
     C           $PL#      SETLLAB#PL71A
     C                     DO   *HIVAL
     C           $PL#      READEAB#PL71A                 98
     C   98                LEAVE
      *
     C                     CLEARAE#WP1M1
     C                     MOVELMSG,2     M1TYPE
     C                     MOVELMPMHIN    M1PART
      * GET PART NAME
     C                     MOVELMPSHIN    $SHIN
     C                     CALL 'UTLR31C'
     C                     PARM           $SHIN  12
     C                     PARM           $NAME  15
     C                     MOVEL$NAME     M1PNAM
      *
     C                     MOVELMPSRYO    M1QTY
     C                     MOVELSVSIRE    M1SIRE
      * GET SERIAL NO.
     C                     EXSR #GETS1
     C                     MOVELN3NMBR    M1SERL
     C                     MOVELMPNONY    M1SERL
      *
     C                     MOVELMPNOHZ    M1SHDT
     C                     MOVEL'USA'     M1CORG
     C                     MOVE *BLANK    M1LOT#
     C                     MOVE *BLANK    M1ECHG
      * TO ADDRESS
      * GET SHIP TO/FROM ADDRESS (X1XAD1/2/3)
     C                     MOVELMPNONY    $DLV
     C                     EXSR #GETAD
     C                     MOVELX1TAD1    M1TAD1
     C                     MOVELX1TAD2    M1TAD2
     C                     MOVELX1TAD3    M1TAD3
     C                     MOVELX1FAD1    M1FAD1
     C                     MOVELX1FAD2    M1FAD2
     C                     MOVELX1FAD3    M1FAD3
      * OTHERS
     C                     MOVEL'   '     M1REF1
     C                     MOVELMPLOC     M1LOC
     C                     MOVELMPNONY    M1NONY
     C                     MOVELMPNKOJ    M1NKOJ
     C                     MOVELMPNUKE    M1NUKE
     C                     MOVELMPNOBN    M1NOBN
     C                     MOVELMPTOKU    M1TOKU
      *
     C                     MOVELMPSHIN    M1IPAR
     C                     MOVELMPSYOS    M1SYOS
     C                     MOVELMPODRN    M1INVN
      *
     C                     WRITEAE#WP1M1
JW   C*
 .   C                     MOVEL'AE#WP1M 'IXWRKF    P
 .   C                     EXSR #XP01                      =>AB#XP01
JW   C*
      * SAVE SERIAL#
     C           SVSERL    IFEQ *BLANK
     C                     MOVELM1SERL    SVSERL
     C                     MOVELM1NONY    SVNONY
     C                     MOVELM1NKOJ    SVNKOJ
     C                     MOVELM1NUKE    SVNUKE
     C                     MOVELM1NOBN    SVNOBN
     C                     MOVELM1TOKU    SVTOKU
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
      * GET SERIAL# FOR MASTER LABEL
      *-----------------------------------------------------
     C           #GETS1    BEGSR
      *
     C                     MOVE *ALL'9'   @@14   140
     C           MPNONY    CHAINAB#NP30              97
     C                     Z-ADDTODAY     N3UDAT
     C                     Z-ADDNOW       N3UTIM
     C                     MOVEL#PGM      N3UPGM
     C                     MOVEL#USER     N3UUSR
     C                     MOVEL#WSID     N3UWIS
     C                     Z-ADDMPNONY    N3NONY
     C           *IN97     IFEQ *ON
     C                     Z-ADD1         N3NMBR
     C                     WRITEAB#NP301
     C                     ELSE
     C                     ADD  1         N3NMBR
     C           N3NMBR    IFEQ @@14
     C                     Z-ADD1         N3NMBR
     C                     ENDIF
     C                     UPDATAB#NP301
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
      * WRITE MIX LABEL
      *-----------------------------------------------------
     C           #MIX      BEGSR
      *
     C                     CLEARAE#WP1I1
      *
     C                     MOVELMSG,3     I1TYPE
     C                     MOVELSVSIRE    I1SIRE
     C                     MOVELSVSERL    I1SERL
     C                     MOVELX1TAD1    I1TAD1
     C                     MOVELX1TAD2    I1TAD2
     C                     MOVELX1TAD3    I1TAD3
     C                     MOVELX1FAD1    I1FAD1
     C                     MOVELX1FAD2    I1FAD2
     C                     MOVELX1FAD3    I1FAD3
      * OTHERS
     C                     MOVE '  '      I1REF1
     C                     MOVELSVNONY    I1NONY
     C                     MOVELSVNKOJ    I1NKOJ
     C                     MOVELSVNUKE    I1NUKE
     C                     MOVELSVNOBN    I1NOBN
     C                     MOVELSVTOKU    I1TOKU
      *
     C                     WRITEAE#WP1I1
JW   C*
 .   C                     MOVEL'AE#WP1I 'IXWRKF    P
 .   C                     EXSR #XP01                      =>AB#XP01
JW   C*
      *
     C                     ENDSR
      *================================================================
JW    *  ..LABEL DATA ISSUE LOG                            *
 .    *================================================================
 .   C           #XP01     BEGSR
 .    *
     C                     Z-ADDTODAY     IXKOHZ           TODAY
     C                     Z-ADDNOW       IXKOTM           NOW
     C                     MOVELBATOKU    IXTOKU           CUSTOMER
     C                     MOVELBANONY    IXNONY           DELIVERY
     C                     MOVELBANKOJ    IXNKOJ           FACTORY
     C                     MOVELBANUKE    IXNUKE           DOCK
     C                     MOVELBAODRN    IXODRN           ORDER #
      * SERIAL#
     C                     SELEC
     C           IXWRKF    WHEQ 'AE#WP1C'
     C                     MOVELC1SERL    IXSERL
     C           IXWRKF    WHEQ 'AE#WP1M'
     C                     MOVELM1SERL    IXSERL
     C           IXWRKF    WHEQ 'AE#WP1I'
     C                     MOVELI1SERL    IXSERL
     C                     ENDSL
      *
     C                     Z-ADDBANOHZ    IXDEDT           INVOICE DATE
     C                     MOVE BANOBN    IXNOBN           INVOICE BIN
      *
     C                     MOVEL$PL#      IXPL#
     C                     MOVEL#USER     IXKOUS
     C                     MOVEL#WSID     IXKOWS
     C                     MOVEL#PGM      IXKOPG
      *
     C                     MOVELBAMHIN    IXMHIN
     C                     MOVELBASHIN    IXSHIN
     C                     MOVELBAINVN    IXINVN
     C                     MOVELBAHPOS    IXHPOS
     C                     MOVELBAROUT    IXROUT
     C                     Z-ADDBASRYO    IXSRYO
     C                     Z-ADDBASYOS    IXSYOS
     C                     Z-ADDBAUSYS    IXUSYS
      *
     C           $PL#      IFNE *BLANK
     C                     MOVEL'0'       IXFIL1    P
     C                     ELSE
     C                     MOVE *BLANK    IXFIL1
     C                     ENDIF
      *
 .   C                     WRITEAB#XP1A1
 .    *
JW   C                     ENDSR
      *-----------------------------------------------------
      * INITIAL SETTING
      *-----------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $PL#    9
     C                     PARM           $SERL  19
      *
     C           K#PL1A    KLIST
     C                     KFLD           KANOHZ  80
     C                     KFLD           KANOBN  20
     C                     KFLD           KANONY  40
     C                     KFLD           KANKOJ  1
     C                     KFLD           KANUKE  4
     C                     KFLD           KAODRN 10
      *
      *
     C           K#PL1B    KLIST
     C                     KFLD           KANOHZ
     C                     KFLD           KANOBN
     C                     KFLD           KANONY
     C                     KFLD           KANKOJ
     C                     KFLD           KANUKE
      *
     C           K#PL7H    KLIST
     C                     KFLD           XANONY  4
     C                     KFLD           BAODRN
     C                     KFLD           BANKOJ
     C                     KFLD           BANUKE
     C                     KFLD           BANOYY
     C                     KFLD           BANOMM
     C                     KFLD           BANODD
     C                     KFLD           XANOBN  2
     C                     KFLD           BAMHN1
     C                     KFLD           BAMHN2
     C                     KFLD           BAMHN3
     C                     KFLD           BAMHN4
      *
     C                     TIME           SDATE
     C                     MOVE '-'       EKHP1
     C                     MOVE '-'       EKHP2
     C                     MOVE '-'       EKHP3
     C                     MOVE '-'       MPHP1
     C                     MOVE '-'       MPHP2
     C                     MOVE '-'       MPHP3
     C                     MOVE *BLANK    SVSERL 20
     C                     MOVE *BLANK    SVNONY  4
     C                     MOVE *BLANK    SVNKOJ  1
     C                     MOVE *BLANK    SVNUKE  4
     C                     MOVE *BLANK    SVNOBN  2
     C                     MOVE *BLANK    SVTOKU  4
     C                     MOVE *BLANK    SVSIRE  6
      * GET P/L DATA
     C                     MOVE 'N'       OKFLG   1
     C           $PL#      CHAINAB#PL76              99
     C           *IN99     IFEQ *OFF
     C           PUSKJY    ANDEQ*BLANK
     C                     MOVE 'Y'       OKFLG
     C                     ENDIF
      *
     C                     ENDSR
** MSG ..1.........2.........3.........4..........5
CONTAINER LABEL                                      01
MASTER LABEL                                         02
MIXED LABEL                                          03
                                                     04
                                                     05
