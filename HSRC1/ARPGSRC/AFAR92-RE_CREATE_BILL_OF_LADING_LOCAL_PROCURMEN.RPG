      * CMD-5 *
      *-------*
     C           *INKE     IFEQ '0'
     C                     GOTO @STP1
     C                     END
      *
     C                     MOVEL*BLANK    #NOP
     C                     MOVEL*BLANK    #DSC
     C                     MOVEL*BLANK    #QTY
     C                     MOVEL*BLANK    #LOC
     C                     MOVEL*BLANK    #WEI
     C                     MOVEL*BLANK    #QTN
     C                     MOVEL*BLANK    #PTN
     C                     MOVEL*BLANK    #WTN
     C                     Z-ADD0         Y       30
     C                     Z-ADD0         Z       30
     C                     Z-ADD0         @NOP   100
     C                     Z-ADD0         THAKO   50
     C                     Z-ADD0         TWEIT  102
     C                     Z-ADD0         W9HAKO  40
     C                     Z-ADD0         W9SYOS  50
     C                     Z-ADD0         W9WEIT  52
     C                     MOVEL'-'       WHN1
     C                     MOVEL'-'       WHN2
     C                     MOVEL'('       WKKO1
     C                     MOVEL'PC'      WPC1
     C                     MOVEL'*'       WKAK
     C                     MOVEL'BOX'     WBOX
