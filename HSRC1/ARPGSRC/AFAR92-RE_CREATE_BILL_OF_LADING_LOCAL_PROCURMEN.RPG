     C                     MOVEL'PALLETS' WPALET
     C                     MOVEL':'       WCOLON
     C*--------------*
     C* READ AFAPP90 *
     C*--------------*
     C                     SETOF                     20
     C           KEY1      SETLLAFAPL921
     C                     DO   *HIVAL
     C           KEY1      READEAFAPL921                 20
     C           *IN20     IFEQ '0'
     C           A9SKJY    IFEQ 'D'
     C           A9SKHZ    ANDLE*DATE
     C                     ELSE
     C           *IN90     IFEQ '0'
     C                     MOVEL'*'       WDATA
     C                     Z-ADDA9NYHZ    WNOKI
     C                     Z-ADDA9ODNO    WWODNO
     C                     EXSR #ADDR
     C   80                EXCPT#HD1
     C                     SETON                     90
     C                     ELSE
     C           A9PAR     IFNE W9PAR
     C                     EXSR #DATA
     C                     END
     C                     END
     C                     MOVELA9PAR1    @@PAR1  5
     C                     MOVELA9PAR2    @@PAR2  5
     C                     MOVELA9PAR3    @@PAR3  2
     C                     MOVELA9PAR1    WWPAR1  5
     C                     MOVELA9PAR2    WWPAR2  5
     C                     MOVELA9PAR3    WWPAR3  2
     C                     MOVELA9PAR1    W9PAR1  5
     C                     MOVELA9PAR2    W9PAR2  5
     C                     MOVELA9PAR3    W9PAR3  2
     C                     EXSR #MEM
     C   80                EXSR #LIST
     C*//BILL OF LADING//
     C           Y         IFEQ 16
     C                     EXSR #MOVE3
     C                     END
     C*//PURCHASE REQUISITION//
     C           Z         IFEQ 5
     C                     EXSR #MOVE4
     C                     END
     C                     END
     C                     END
     C  N20                ENDDO
     C*
     C           WDATA     IFEQ *BLANK
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVELER,7      MSG
     C                     GOTO @STP1
     C                     END
     C*
     C                     SETON                     72
     C                     EXSR #DATA
     C*//BILL OF LADING//
     C                     EXSR #MOVE3
     C*//PURCHASE REQUISITION//
     C                     EXSR #MOVE4
     C*// TOTAL WEITGT //
     C                     EXSR #TOTAL
     C*// AFAPP70 AND AFAPP75 LAST RECORD UPDAT //
     C                     EXSR #LAST
     C*// PICKUP LIST//
     C   80                EXSR #LIST
     C*
     C                     SETON                     LR
     C                     RETRN
     C**************************************************************************
     C           #ADDR     BEGSR
     C**************************************************************************
     C                     SETOF                     21
     C           A9SUPP    CHAINEDIPL401             21
     C           *IN21     IFEQ '0'
     C           E4SKJY    IFEQ 'D'
     C           E4SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELE4ADD1    WTONM  40
     C                     MOVELE4ADD2    WSH01  40
     C                     MOVELE4ADD3    WSH02  40
     C                     MOVELE4ADD4    WSH03  40
     C                     END
     C                     END
     C*
     C                     MOVEL'0111'    WWSUPP  4
     C                     SETOF                     21
     C           WWSUPP    CHAINEDIPL401             21
     C           *IN21     IFEQ '0'
     C           E4SKJY    IFEQ 'D'
     C           E4SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVELE4ADD1    WFRNM  40
     C                     MOVELE4ADD2    WFR01  40
     C                     MOVELE4ADD3    WFR02  40
     C                     END
     C                     END
     C*
     C           EADDR     ENDSR
     C**************************************************************************
     C           #DATA     BEGSR
     C**************************************************************************
     C*//BILL OF LADING AND PURCHASE REQUISITION//
     C                     ADD  1         Y
     C                     ADD  1         Z
     C                     ADD  1         @NOP
     C*NO
     C                     Z-ADD@NOP      PIN
     C                     MOVEL*BLANK    POUT
     C                     Z-ADD0         PLEN
     C                     CALL 'AB#R2N'
     C                     PARM           PIN    305
     C                     PARM           POUT   30
     C                     PARM           PLEN    20
     C                     MOVE POUT      #NOP,Z
     C*BOX
     C                     ADD  W9HAKO    THAKO
     C                     Z-ADDW9HAKO    PIN
     C                     MOVEL*BLANK    POUT
     C                     Z-ADD0         PLEN
     C                     CALL 'AB#R2N'
     C                     PARM           PIN    305
     C                     PARM           POUT   30
     C                     PARM           PLEN    20
     C                     MOVE POUT      #QTN,Y
     C                     MOVE POUT      WHAKO
     C*QTY/BOX
     C                     Z-ADDW9SYOS    PIN
     C                     MOVEL*BLANK    POUT
     C                     Z-ADD0         PLEN
     C                     CALL 'AB#R2N'
     C                     PARM           PIN    305
     C                     PARM           POUT   30
     C                     PARM           PLEN    20
     C                     MOVE POUT      WSYOS1
     C                     MOVE POUT      WSYOS2
     C                     MOVE @PTN      #PTN,Y
     C                     MOVE @DSC      #DSC,Z
     C*WEIGNT
     C           W9SYOS    MULT W9HAKO    @SRYO   80
     C           @SRYO     MULT W9WEIT    @WEIT1 112       G
     C           @WEIT1    DIV  1000      @WEIT2  82       G --> KG
     C           @WEIT2    MULT 2.2046    @WEIT3  82H      KG --> LB
     C                     ADD  @WEIT3    TWEIT  102       TOTAL
     C*
     C                     Z-ADD@WEIT3    PIN
     C                     MOVEL*BLANK    POUT
     C                     Z-ADD2         PLEN
     C                     CALL 'AB#R2N'
     C                     PARM           PIN    305
     C                     PARM           POUT   30
     C                     PARM           PLEN    20
     C                     MOVE POUT      #WTN,Y
     C                     MOVE POUT      WWEIT
     C                     MOVE @WEI      #WEI,Z
     C*QTY.
     C                     Z-ADD@SRYO     PIN
     C                     MOVEL*BLANK    POUT
     C                     Z-ADD0         PLEN
     C                     CALL 'AB#R2N'
     C                     PARM           PIN    305
     C                     PARM           POUT   30
     C                     PARM           PLEN    20
     C                     MOVE POUT      #QTY,Z
     C*
     C           @@LOC     IFNE *BLANK
     C                     MOVE '-'       W@L11
     C                     MOVE '-'       W@L22
     C                     MOVE '-'       W@L33
     C                     MOVE @@L1      W@L1
     C                     MOVE @@L2      W@L2
     C                     MOVE @@L3      W@L3
     C                     MOVE @@L4      W@L4
     C                     ELSE
     C                     MOVE *BLANK    W@LOC
     C                     ENDIF
     C                     MOVE W@LOC     #LOC,Z
     C*
     C                     Z-ADD0         W9HAKO
     C                     Z-ADD0         W9SYOS
     C                     Z-ADD0         W9WEIT
     C*
     C           EDATA     ENDSR
     C**************************************************************************
     C           #LIST     BEGSR
     C**************************************************************************
     C           A9HAKO    MULT A9SYOS    A9SRYO  80
     C           A9SRYO    MULT A9WEIT    WWEIT1 112       G
     C           WWEIT1    DIV  1000      WWEIT2  82       G --> KG
     C           WWEIT2    MULT 2.2046    A9GROS  82H      KG --> LB
     C           *IN72     IFEQ '0'
     C           *IN71     IFEQ '1'
     C************         EXCPT#TO1
     C                     EXCPT#HD1
     C                     SETOF                     71
     C                     END
      *
     C                     MOVE *BLANK    @@LOC
     C           KEY5      CHAINAAMPL11              95
     C           *IN95     IFEQ *OFF
     C                     Z-ADD1         X       20
     C                     MOVE A9SUPP    @@SUPP  40
     C           @@SUPP    LOKUPDPT,X                    96
     C           *IN96     IFEQ *ON
     C                     MOVE LOC,X     @@LOC   6
     C                     ELSE
     C           KEY5      CHAINFCEPL01              95
     C           *IN95     IFEQ *OFF
     C                     MOVE A2STRK    @@L1
     C                     MOVE A2STRT    @@L2
     C                     MOVE A2STRR    @@L3
     C                     MOVE A2STRD    @@L4
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C*
     C                     EXCPT#DT1
     C*
     C                     ELSE
     C                     EXCPT#TO1
     C                     END
     C*
     C           ELIST     ENDSR
     C**************************************************************************
     C           #MEM      BEGSR
     C**************************************************************************
     C                     ADD  A9HAKO    W9HAKO
     C           A9SYOS    IFNE *ZERO
     C                     Z-ADDA9SYOS    W9SYOS
     C                     ENDIF
     C           A9WEIT    IFNE *ZERO
     C                     Z-ADDA9WEIT    W9WEIT
     C                     ENDIF
      *
     C           EMEM      ENDSR
     C**************************************************************************
     C           #MOVE3    BEGSR
     C**************************************************************************
     C                     MOVELWTONM     BFTONM
     C                     MOVELWSH01     BFSH01
     C                     MOVELWSH02     BFSH02
     C                     MOVELWSH03     BFSH03
     C                     MOVELWFRNM     BFFRNM
     C                     MOVELWFR01     BFFR01
     C                     MOVELWFR02     BFFR02
     C                     MOVE WWODNO    BFVHNO
     C                     WRITEAFAPP70R
     C                     MOVEL*BLANK    #QTN
     C                     MOVEL*BLANK    #PTN
     C                     MOVEL*BLANK    #WTN
     C                     Z-ADD0         Y
     C           EMOVE3    ENDSR
     C**************************************************************************
     C           #MOVE4    BEGSR
     C**************************************************************************
     C*                    MOVEL*DATE     PFDATE           ORDER DATE
     C*                    MOVELWNOKI     PFDTDU           RECEIVE DATE
     C                     MOVELWVDNM     PFVDNM           VENDER NAME
     C                     MOVELWWODNO    PFCTNM           CONTACT NAME
     C                     WRITEAFAPP75R
     C                     MOVEL*BLANK    #NOP
     C                     MOVEL*BLANK    #DSC
     C                     MOVEL*BLANK    #LOC
     C                     MOVEL*BLANK    #QTY
     C                     MOVEL*BLANK    #WEI
     C                     Z-ADD0         Z
     C           EMOVE4    ENDSR
     C**************************************************************************
     C           #TOTAL    BEGSR
     C**************************************************************************
     C* TOTAL BOX WEIGT
     C                     Z-ADDTHAKO     @EBOX   50
     C           THAKO     ADD  @EBOX     @BOXT   50
     C           @BOXT     DIV  12        @BOXT
     C                     MVR            @MVR    50
     C           @MVR      IFNE *ZERO
     C                     ADD  1         @BOXT
     C                     ENDIF
     C           @BOXT     MULT 12        @BOXT
      *
     C           @BOXT     SUB  THAKO     @EBOX
     C*******    1.554     MULT THAKO     HWEIT   82
