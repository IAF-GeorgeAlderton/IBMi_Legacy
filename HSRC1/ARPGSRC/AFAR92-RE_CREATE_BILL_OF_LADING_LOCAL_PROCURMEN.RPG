     C           @STP1     TAG
     C                     EXFMTAFAPW921
     C                     SETOF                     010203
     C                     SETOF                     99
      *-------*
      * CMD-1 *
      *-------*
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           ISIRE     IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVELER,1      MSG
     C                     GOTO @STP1
     C                     END
      *
     C                     Z-ADD0         OSIRE   40
     C                     MOVELISIRE     OSIRE
      *
     C                     SETOF                     20
     C           OSIRE     CHAINFGBPL011             20
      *
     C           *IN20     IFEQ '0'
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     20
     C                     ELSE
     C                     MOVELB2SMEI    WVDNM  20
     C                     END
     C                     END
      *
     C           *IN20     IFEQ '1'
     C                     SETON                     0199
     C                     MOVELER,2      MSG
     C                     GOTO @STP1
     C                     END
      *
     C           IODHZ     IFEQ 0
     C                     SETON                     0299
     C                     MOVELER,3      MSG
     C                     GOTO @STP1
     C                     END
      *
     C           IODYY     IFLT 2000
     C                     SETON                     0299
     C                     MOVELER,4      MSG
     C                     GOTO @STP1
     C                     END
      *
     C           IODMM     IFLT 1
     C           IODMM     ORGT 12
     C                     SETON                     0299
     C                     MOVELER,4      MSG
     C                     GOTO @STP1
     C                     END
      *
     C           IODDD     IFLT 1
     C           IODDD     ORGT 31
     C                     SETON                     0299
     C                     MOVELER,4      MSG
     C                     GOTO @STP1
     C                     END
      *
     C           ICODE     IFEQ *BLANK
     C                     SETON                     0399
     C                     MOVELER,5      MSG
     C                     GOTO @STP1
     C                     END
      *
     C           ICODE     IFEQ '1'
     C           ICODE     OREQ '2'
     C           ICODE     OREQ '3'
     C           ICODE     OREQ '4'
     C                     ELSE
     C                     SETON                     0399
     C                     MOVELER,6      MSG
     C                     GOTO @STP1
     C                     END
     C           ICODE     IFEQ '3'
     C           ICODE     OREQ '4'
     C                     SETON                     80
     C                     END
