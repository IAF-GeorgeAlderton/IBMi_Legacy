     H            Y.
     F**AB#RAO1 **************************************
     F* ADJUST AB#WPAO                               *
     F* J.WATANABE  2021.03.05                       *
     F************************************************
     FAB#WLAO IF  E           K        DISK
     FAB#WLAO2UF  E           K        DISK
     F            AB#WPAO1                          KRENAMEAB#WLA04
     F************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *----------------------------------------------------*
      *  MAIN ROUTINE
      *----------------------------------------------------*
     C                     MOVE 'Y'       FIRST   1
     C                     MOVE *BLANK    SVWSID 10
     C                     MOVE *BLANK    SVSIZE  3
     C                     Z-ADD0         SVSEQ   20
     C                     MOVE *BLANK    SVMCN   3
     C                     Z-ADD0         @QTY   110
      *
     C           #WSID     SETLLAB#WLAO
     C                     DO   *HIVAL
     C           #WSID     READEAB#WLAO                  99
     C   99                LEAVE
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELW#WSID    SVWSID
     C                     MOVELW#SIZE    SVSIZE
     C                     Z-ADDW#SEQ     SVSEQ
     C                     MOVELW#MCN     SVMCN
     C                     ENDIF
      * BRAEK
     C           W#WSID    IFNE SVWSID
     C**         W#SIZE    ORNE SVSIZE
     C           W#SEQ     ORNE SVSEQ
     C           W#MCN     ORNE SVMCN
     C                     EXSR #BRK1
     C                     ENDIF
      * DETAIL
     C                     ADD  W#QTY     @QTY
     C                     ENDDO
      * LAST BREAK
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK1
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------------*
      *  BREAK
      *----------------------------------------------------*
     C           #BRK1     BEGSR
      * SAVE KEY
     C                     MOVELW#WSID    S2WSID 10
     C                     MOVELW#SIZE    S2SIZE  3
     C                     Z-ADDW#SEQ     S2SEQ   20
     C                     MOVELW#MCN     S2MCN   3
     C                     Z-ADDW#QTY     S2QTY  110
      *
     C           @QTY      IFEQ 0
     C                     EXSR #DLT
     C                     ENDIF
      * RESET
     C                     MOVELS2WSID    SVWSID
     C                     MOVELS2SIZE    SVSIZE
     C                     Z-ADDS2SEQ     SVSEQ
     C                     MOVELS2MCN     SVMCN
     C                     Z-ADDS2QTY     W#QTY
     C                     Z-ADD0         @QTY
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  DELETE AB#WPAO
      *----------------------------------------------------*
     C           #DLT      BEGSR
      *
     C           K#WL2     KLIST
     C                     KFLD           SVWSID
     C                     KFLD           SVSEQ
     C                     KFLD           SVMCN
      *
     C           K#WL2     SETLLAB#WLAO2
     C                     DO   *HIVAL
     C           K#WL2     READEAB#WLAO2                 99
     C   99                LEAVE
     C                     DELETAB#WLA04
     C                     ENDDO
      *
     C                     ENDSR
