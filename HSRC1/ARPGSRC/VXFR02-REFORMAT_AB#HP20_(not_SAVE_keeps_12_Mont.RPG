     F*  * ADD VXFR02   TO UTLC20                                  *
     F*  * ADD AB#HP20  BY OPT#1 (FILE REFORMATION MASTER UPDATE)  *
     F*  * ADD AB#HP20  BY OPT#3 (UPDATE FILE NAME              )  *
     F**************************************************************
     FAB#HL20AUF  E           K        DISK         KINFDS INF1
      ***************************************************
     IINF1        DS
     I                                    B 156 1590RCNT
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   80AHNOHZ
     I                                        1   40AHNOYY
     I                                        5   60AHNOMM
     I                                        7   80AHNODD
     C           *ENTRY    PLIST
     C                     PARM           PDATE   8
     C                     PARM           PREC1   9
     C                     PARM           PREC2   9
     C                     MOVE PDATE     XDATE   80
     C                     TIME           SDATE
      *
     C           *LOVAL    SETLLAB#HL20A
      * LOOP
     C           *IN90     DOWEQ*OFF
     C                     READ AB#HL20A                 90
     C           *IN90     IFEQ *OFF
      *
     C           AHNOHZ    IFGT XDATE
     C                     LEAVE
     C                     ELSE
     C                     ADD  1         WDEL    90
     C                     DELETAB#HP201
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      * FOOT
     C                     Z-ADDRCNT      WREC1   90
     C                     MOVE WREC1     PREC1
     C           WREC1     SUB  WDEL      WREC2   90
     C                     MOVE WREC2     PREC2
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
