     H            Y.                                    1
      ** AFAR96 **************************
      *  PRINT MATERIAL SUPPLY ORDER LIST*
      *  BY ORDER NO.
      *  K.KASHIWAGI 2000.12.05          *
      *  COPY FROM AFAR95                *
      ******************* AFAR96 *********
     FALDPL34 IF  E           K        DISK
     FAFAPL82 IF  E           K        DISK
     FAFAPL80 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *
     C           K#KEY     KLIST
     C                     KFLD           A3KANS
     C                     KFLD           A3ZETI
     C                     KFLD           A3TEHI
     C                     KFLD           A3PAGE
      *-----*
     C           K#KEY0    KLIST
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C           K#KEY1    KLIST
     C                     KFLD           K@SUPP  4
     C                     KFLD           A3SHN1
     C                     KFLD           A3SHN2
     C                     KFLD           A3SHN3
      *
     C                     Z-ADD2001      K@YY
     C                     Z-ADD08        K@MM
     C                     MOVE '2255'    K@SUPP
      *
     C           K#KEY0    SETLLALDPL34
     C           *IN90     DOUEQ*ON
     C                     READ ALDPL34                  90
     C           *IN90     IFEQ *OFF
     C           K#KEY1    CHAINAFAPL80              99
     C           *IN99     IFEQ *ON
     C                     ITER
     C                     ENDIF
      *
     C           K#KEY     CHAINAFAPL82              91
     C           *IN91     IFEQ *ON
     C                     EXSR #ERR
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
     C           #ERR      BEGSR
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
      *
     C                     EXCPT@DTL
      *
     C                     ENDSR
      *------------------------------------------------------
     OQPRINT  E   02           @HED
     O                                   50 'UNMACH LIST'
      *
     O        E   04           @HED
     O                                    6 'DATE'
     O                                   16 'PART#'
     O                                   30 'LOT'
     O                                   35 'PAGE'
     O                                   40 'QTY'
      *
     O        E 1              @DTL
     O                         A3SYYY     4
     O                                    5 '/'
     O                         A3SYMM     7
     O                                    8 '/'
     O                         A3SYDD    10
     O                         A3SHN1    17
     O                                   18 '-'
     O                         A3SHN2    23
     O                                   24 '-'
     O                         A3SHN3    26
     O                         A3TEHI    30
     O                         A3PAGE    33
     O                         A3SSYS1   40
