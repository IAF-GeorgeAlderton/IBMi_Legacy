     H            Y.
     F** MRAR55 *********************************************
     A* RECEIVE DATA FROM ASJ                              *
     F*     TRANCOM ITS.           2012.09.12               *
     F*******************************************************
     FMRAPW50 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL
     FMRAPL50 IF  E           K        DISK
      *
     E                    ER      1  11 60
      *
     I            DS
     I                                        1  14 S1SHN
     I                                        1   5 S1SHN1
     I                                        6   6 S1SF1
     I                                        7  11 S1SHN2
     I                                       12  12 S1SF2
     I                                       13  14 S1SHN3
      *
     I            DS
     I                                        1  17 S1MHN
     I                                        1   5 S1MHN1
     I                                        6   6 S1MF1
     I                                        7  11 S1MHN2
     I                                       12  12 S1MF2
     I                                       13  17 S1MHN3
      *
     I            DS
     I                                        1  10 M5KEN
     I                                        1   9 M5KENO
     I                                       10  10 M5KENA
      *
     I            DS
     I                                        1   80M5STDT
     I                                        1   40M5STYY
     I                                        5   60M5STMM
     I                                        7   80M5STDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTITM
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------------------
      * PARAMETER TRANCFER
      *----------------------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           P0KYM   6
      *
     C           MRAR51    PLIST
     C                     PARM           P1KEN  10
     C                     PARM           P1STAT  2
     C                     PARM           P1GTDT  80
     C                     PARM           P1IPDT  80
     C                     PARM           P1CRAT 10
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1SEKB  1
     C                     PARM           P1PRKB  1
     C                     PARM           P1CMD   1
     C                     PARM           P1KYM   6
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      *  メインルーチン                                  *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      *   初期処理                                       *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      *   主処理                                         *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *データ検索                                        *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     C                     SETOF                     8166
     C           *LOVAL    SETLLMRAPL501
     C                     READ MRAPL501                 81
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ MRAPL501                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     MOVE '02'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      *   第二画面処理                                   *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C           CTRX      IFEQ 0
     C                     SETON                     72
     C                     SETON                     99
     C                     MOVELER,1      @ERR
     C                     ELSE
     C                     SETON                     7273
     C                     ENDIF
      *
     C                     WRITEMRAPW509
     C                     EXFMTSFLCTL
     C                     SETOF                     3199
     C                     MOVEL*BLANK    @ERR
      * F1
     C           *IN01     IFEQ '1'
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           CTRX      IFEQ 0
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
      * ROLLDOWN/PAGEUP *
      *-----------------*
     C           *IN52     IFEQ '1'
     C*                    ADD  1         CTRX
      * 1ST. PAGE
     C           WKPAGE    IFEQ 1
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
     C           *IN81     IFEQ '1'
     C                     SETOF                     81
     C           *HIVAL    SETGTMRAPL501
     C                     READPMRAPL501                 81
     C                     SUB  1         CTRX
     C                     ENDIF
      *
     C                     ADD  14        CTRX
      *                         L--表示行数
     C                     SETOF                     6627
      *
     C                     DO   *HIVAL
     C                     EXSR #READP
     C                     READPMRAPL501                 81
     C  N81N27             ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C                     EXSR #NEXTP
     C  N81N66             ENDDO
      *
     C                     Z-ADD0         CTRX    40
      *
     C           *IN81     IFEQ '1'
     C           *LOVAL    SETLLMRAPL501
     C                     READ MRAPL501                 81
     C                     ENDIF
      *
     C                     EXSR #CLR
     C                     SETOF                     8166
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ MRAPL501                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C                     EXSR #NEXT
     C  N81N66             ENDDO
      *
     C                     SUB  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      *--------------------*
      * ROLL-UP            *
      *--------------------*
     C           *IN51     IFEQ '1'
     C           *IN81     ANDEQ'0'
      *
     C                     EXSR #CLR
      *
     C                     SETOF                     6681
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ MRAPL501                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C                     EXSR #NEXT
     C  N81N66             ENDDO
      *
     C                     ADD  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      * CHECK
     C                     SETOF                     3199
     C                     Z-ADD1         X       20
     C                     Z-ADD0         WKSEL   20
     C           X         DOWLE14
     C           X         CHAINSFL                  25
     C           *IN25     IFEQ '0'
     C           *IN99     ANDEQ'0'
     C                     SETOF                     31
     C                     EXSR #SB221
     C                     UPDATSFL
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
     C           *IN99     IFEQ '1'
     C                     GOTO ESB220
     C                     ENDIF
      *
     C                     Z-ADD1         X       20
     C           X         DOWLE14
     C           X         CHAINSFL                  25
     C           *IN25     IFEQ '0'
     C                     EXSR #SB222
     C                     UPDATSFL
     C                     ENDIF
     C                     ADD  1         X
     C  N99                ENDDO
     C           *IN99     IFEQ '1'
     C                     GOTO ESB220
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * CHECK SFL                                          *
      *----------------------------------------------------*
     CSR         #SB221    BEGSR
      *
     C                     SELEC
     C           S1SEL     WHEQ ' '
     C           S1SEL     WHEQ 'S'
     C           H1STAT    IFEQ '08'
     C                     SETON                     3199
     C                     MOVELER,4      @ERR
     C                     END
     C                     ADD  1         WKSEL
      *
     C                     OTHER
     C                     MOVELER,2      @ERR
     C                     SETON                     3199
     C                     ENDSL
      *
     C           WKSEL     IFGE 2
     C                     MOVELER,3      @ERR
     C                     SETON                     3199
     C                     ENDIF
      *
     CSR         ESB221    ENDSR
      *----------------------------------------------------*
      * CALL UPDATE PGM                                    *
      *----------------------------------------------------*
     CSR         #SB222    BEGSR
      *
     C                     SELEC
     C           S1SEL     WHEQ 'S'
     C                     EXSR #SB223
     C                     MOVEL*BLANK    S1SEL
     C  N99      P1CMD     IFEQ '5'
     C                     MOVE '08'      H1STAT
     C                     END
     C                     ENDSL
      *
     CSR         ESB222    ENDSR
      *----------------------------------------------------*
      * CALL UPDATE PGM                                    *
      *----------------------------------------------------*
     CSR         #SB223    BEGSR
     C                     MOVE P0KYM     P1KYM
     C                     MOVE H1KEN     P1KEN
     C                     MOVE H1STAT    P1STAT
     C                     MOVE H1GTDT    P1GTDT
     C                     MOVE H1IPDT    P1IPDT
     C                     MOVE H1CRAT    P1CRAT
     C                     MOVE H1SHN1    P1SHN1
     C                     MOVE H1SHN2    P1SHN2
     C                     MOVE H1SHN3    P1SHN3
     C                     MOVE H1SEKB    P1SEKB
     C                     MOVE H1PRKB    P1PRKB
     C                     MOVE *BLANK    P1CMD
      *
     C                     CALL 'MRAR51'  MRAR51
     C           P1CMD     IFEQ '9'
     C                     SETON                     3199
     C                     MOVELER,5      @ERR
     C                     END
      *
     CSR         ESB223    ENDSR
      *----------------------------------------------------*
      *   終了処理                                       *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      *   照会データ検索                                 *
      *----------------------------------------------------*
     CSR         #READ     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREAD
     C                     ENDIF
      *
     C                     EXSR #EDIT
     C                     ADD  1         RRN
     C                     ADD  1         @RRN
     C                     ADD  1         CTRX
     C                     WRITESFL
      *
     C           CTRX      IFEQ 14
     C                     SETON                       66
     C                     ENDIF
      *
     CSR         EREAD     ENDSR
      *----------------------------------------------------*
      *   検索ファイル逆読み                             *
      *----------------------------------------------------*
     CSR         #READP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREADP
     C                     ENDIF
      *
     C                     SUB  1         CTRX           27
      *
     CSR         EREADP    ENDSR
      *----------------------------------------------------*
      *   検索条件判定                                   *
      *----------------------------------------------------*
     CSR         #SELEC    BEGSR
      *
     C           M5SKJY    IFEQ 'D'
     C                     GOTO ESELEC
     C                     ENDIF
     C           M5STAT    IFNE '07'
     C                     GOTO ESELEC
     C                     ENDIF
      *
     C                     MOVEL'1'       WKGET
      *
     CSR         ESELEC    ENDSR
      *----------------------------------------------------*
      *   表示項目＆サブファイルクリアー                 *
      *----------------------------------------------------*
     CSR         #CLR      BEGSR
      *
     C                     SETON                     71
     C                     WRITESFLCTL
     C                     SETOF                     7166
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN    40
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         @SFRC1
      *
     CSR         ECLR      ENDSR
      *----------------------------------------------------*
      *   編集処理                                       *
      *----------------------------------------------------*
     CSR         #EDIT     BEGSR
      *
     C                     MOVEL*BLANK    S1SEL
      *
     C                     CLEARS1SHN
     C                     MOVE M5SHN1    S1SHN1
     C                     MOVE '-'       S1SF1
     C                     MOVE M5SHN2    S1SHN2
     C                     MOVE '-'       S1SF2
     C                     MOVE M5SHN3    S1SHN3
     C           S1SHN3    IFEQ *BLANK
     C                     MOVE *BLANK    S1SF2
     C                     END
      *
     C                     MOVEL*BLANK    S1MHN
     C                     MOVELM5MHN1    S1MHN1
     C                     MOVEL'-'       S1MF1
     C                     MOVELM5MHN2    S1MHN2
     C                     MOVEL'-'       S1MF2
     C                     MOVELM5MHN3    S1MHN3
     C           S1MHN3    IFEQ *BLANK
     C                     MOVEL*BLANK    S1MF2
     C                     ENDIF
     C           S1MHN2    IFEQ *BLANK
     C                     MOVEL*BLANK    S1MF1
     C                     ENDIF
      *
     C                     MOVE M5GTDT    S1GTDT
     C                     Z-ADDM5IPDT    S1IPDT
     C                     MOVELM5SYKI    S1SYKI
     C                     Z-ADDM5STDT    S1STDT
     C                     MOVELM5TMEI    S1TMEI
      *
     C                     MOVELM5KEN     H1KEN
     C                     MOVELM5SHN1    H1SHN1
     C                     MOVELM5SHN2    H1SHN2
     C                     MOVELM5SHN3    H1SHN3
     C                     MOVELM5SENO    H1SEQ
     C                     MOVELM5SEKB    H1SEKB
     C                     MOVELM5PRKB    H1PRKB
     C                     MOVELM5CHID    H1CHID
     C                     MOVE M5STAT    H1STAT
     C                     MOVE M5GTDT    H1GTDT
     C                     MOVE M5IPDT    H1IPDT
     C                     MOVE M5CRAT    H1CRAT
      *
     CSR         EEDIT     ENDSR
      *----------------------------------------------------*
      *   次データ                                       *
      *----------------------------------------------------*
     CSR         #NEXT     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXT
     C                     ENDIF
      *
     C                     READ MRAPL501                 81
      *
     CSR         ENEXT     ENDSR
      *----------------------------------------------------*
      *   前データ                                       *
      *----------------------------------------------------*
     CSR         #NEXTP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXTP
     C                     ENDIF
      *
     C                     READPMRAPL501                 81
      *
     CSR         ENEXTP    ENDSR
     C*----------------------------------------------------------------
**
ER-1 THERE ARE NO DATA.
ER-2 INPUT S
ER-3 CAN'T CHOOSE MORE THAN TWO RECORDS.
ER-4 FINISHING OF RECEIPT
ER-5 NOT FOUND DETAIL DATA.
ER-6
ER-7
ER-8
