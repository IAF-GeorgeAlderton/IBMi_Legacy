     I            DS
     I                                        1   80FCSKHZ
     I                                        1   40FCSKYY
     I                                        5   60FCSKMM
     I                                        7   80FCSKDD
      *
     I            DS
     I                                        1  140WDATE
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1DATE  80
     C                     PARM           P9GEKN 120
      *
     C                     TIME           WDATE
     C                     Z-ADD0         P9GEKN
     C           KEYSHN    KLIST
     C                     KFLD           P1SHN1
     C                     KFLD           P1SHN2
     C                     KFLD           P1SHN3
     C           KEYSHN    CHAINFCEPL111             22
     C           *IN22     IFEQ '0'
     C           FCSKJY    ANDEQ'D'
     C           FCSKHZ    ANDLE*DATE
     C                     SETON                     22
     C                     ENDIF
     C           *IN22     IFEQ '0'
     C                     EXSR #SB400
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------*
      *月間必要数切替日がパラメータ日以前       *
      *-----------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     Z-ADD1         X       30
     C                     MOVEL'0'       GET     1
     C           X         DOWLE10
     C           GET       ANDEQ'0'
     C           FGH,X     IFNE 0
     C           FGH,X     ANDLEP1DATE
     C                     EXSR #SB401
     C                     MOVEL'1'       GET     1
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *-----------------------------------*
      *月間必要数　２０日稼働           *
      *-----------------------------------*
     CSR         #SB401    BEGSR
      *
     C                     Z-ADD0         XXGEKN 120
     C                     Z-ADD0         XXCD    31
     C                     Z-ADD0         YYHIKN 120
     C                     Z-ADDFGK,X     XXGEKN 120
     C                     Z-ADDFCD,X     XXCD    31
     C                     Z-ADDXXGEKN    P9GEKN
     C******     XXCD      IFNE 0
     C******     XXGEKN    DIV  XXCD      YYHIKN 120
     C******     YYHIKN    MULT 20        P9GEKN
     C******               ENDIF
      *
     CSR         ESB401    ENDSR
