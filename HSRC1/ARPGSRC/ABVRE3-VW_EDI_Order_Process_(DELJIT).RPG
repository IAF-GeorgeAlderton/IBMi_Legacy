      * CUSTOMER PART#
     C                     MOVEAAEMHIN    MH1       P
     C                     MOVEL*BLANK    MH2
     C                     Z-ADD*ZERO     Y       20
     C           1         DO   22        X       20
     C           MH1,X     IFNE '-'
     C           MH1,X     ANDNE'/'
     C           MH1,X     ANDNE'.'
     C           MH1,X     ANDNE*BLANK
     C                     ADD  1         Y
     C           Y         IFGT 20
     C                     LEAVE
     C                     ENDIF
     C                     MOVE MH1,X     MH2,Y
     C                     ENDIF
     C                     ENDDO
