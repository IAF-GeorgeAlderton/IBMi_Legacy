     H            Y.
     F** ANZR06 *********************************************
     F*安全在庫箱数の取得                                 *
     F*       T.SAKAHSITA          2011.04.26               *
     F********************************************* ANZR01 **
     FAAFPL03 IF  E           K        DISK
     FAAHPL03 IF  E           K        DISK
     FAAPPL03 IF  E           K        DISK
     FAANPL03 IF  E           K        DISK
     FANZWP05 IF  E           K        DISK
      *
     I           SDS
     I                                        1  10 PGMNM
     I                                       91 170 MSGTXT
     I                                      244 253 WSID
     I                                      254 263 USID
     I                                      264 269 JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P@ATK1  1
     C                     PARM           P@ATK2  2
     C                     PARM           P@ATK3  2
     C                     PARM           P@ATK4  1
     C                     PARM           P@UKYY  40
     C                     PARM           P@UKMM  20
     C                     PARM           P@UKDD  20
     C                     PARM           P@UBIN  20
     C                     PARM           P@MAXH  40
      *
     C           K@KKEY    KLIST
     C                     KFLD           K@ATK1  1
     C                     KFLD           K@ATK2  2
     C                     KFLD           K@ATK3  2
     C                     KFLD           K@ATK4  1
     C                     KFLD           K@UKYY  40
     C                     KFLD           K@UKMM  20
     C                     KFLD           K@UKDD  20
     C                     KFLD           K@UBIN  20
     C                     MOVE P@ATK1    K@ATK1
     C                     MOVE P@ATK2    K@ATK2
     C                     MOVE P@ATK3    K@ATK3
     C                     MOVE P@ATK4    K@ATK4
     C                     Z-ADDP@UKYY    K@UKYY
     C                     Z-ADDP@UKMM    K@UKMM
     C                     Z-ADDP@UKDD    K@UKDD
     C                     Z-ADDP@UBIN    K@UBIN
      *
     C           K@KKEY    CHAINAAFPL031             55
     C           *IN55     IFEQ '0'
     C                     Z-ADDA3AMXH    P@MAXH
     C                     GOTO @JUMP
     C                     END
      *
     C           K@KKEY    CHAINAAHPL031             55
     C           *IN55     IFEQ '0'
     C                     Z-ADDL6AMXH    P@MAXH
     C                     GOTO @JUMP
     C                     END
      *
     C           K@KKEY    CHAINAAPPL031             55
     C           *IN55     IFEQ '0'
     C                     Z-ADDL5AMXH    P@MAXH
     C                     GOTO @JUMP
     C                     END
      *
     C           K@KKEY    CHAINAANPL031             55
     C           *IN55     IFEQ '0'
     C                     Z-ADDL7AMXH    P@MAXH
     C                     GOTO @JUMP
     C                     END
      *
     C           @JUMP     TAG
      *
     C           ANZKEY    KLIST
     C                     KFLD           K@ATK1
     C                     KFLD           K@ATK2
     C                     KFLD           K@ATK3
     C                     KFLD           K@ATK4
     C                     KFLD           K@UKYY
     C                     KFLD           K@UKMM
     C                     KFLD           K@UKDD
     C                     KFLD           K@UBIN
     C                     KFLD           E@JOBM 10
     C                     KFLD           E@USER 10
     C                     KFLD           E@WNBR  6
     C                     KFLD           E@DATE  80
      *
     C                     MOVE P@ATK1    K@ATK1
     C                     MOVE P@ATK2    K@ATK2
     C                     MOVE P@ATK3    K@ATK3
     C                     MOVE P@ATK4    K@ATK4
     C                     Z-ADDP@UKYY    K@UKYY
     C                     Z-ADDP@UKMM    K@UKMM
     C                     Z-ADDP@UKDD    K@UKDD
     C                     Z-ADDP@UBIN    K@UBIN
     C                     MOVE WSID      E@JOBM 10
     C                     MOVE USID      E@USER 10
     C                     MOVE JBNO      E@WNBR  6
     C                     Z-ADD*DATE     E@DATE  80
      *
     C           ANZKEY    CHAINANZWP051             55
     C           *IN55     IFEQ '0'
     C                     Z-ADDZ1MAXH    P@MAXH
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *
