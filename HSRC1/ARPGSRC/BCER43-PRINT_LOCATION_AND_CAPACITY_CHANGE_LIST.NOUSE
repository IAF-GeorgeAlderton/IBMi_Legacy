     FFCEPL03 IF  E           K        DISK
     FHEN     O   F     128            DISK
     I            DS
     I                                        1   80A2SYHZ
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
     I                                        9  160A2TRHZ
     I                                        9  120A2TRYY
     I                                       13  140A2TRMM
     I                                       15  160A2TRDD
     I                                       17  240UHIZK
     I                                       25  320A2GSHZ
     I                                       25  280A2GSYY
     I                                       29  300A2GSMM
     I                                       31  320A2GSDD
      *
     I            DS
     I                                        1   6 A2TKR
     I                                        1   1 A2STRK
     I                                        2   3 A2STRT
     I                                        4   5 A2STRR
     I                                        6   6 A2STRD
      *
     I            DS
     I                                        1   6 WTKRA
     I                                        1   1 WTKR1
     I                                        2   3 WTKR2
     I                                        4   5 WTKR3
     I                                        6   6 WTKR4
      *
     I            DS
     I                                        1   6 WTKRB
     I                                        1   1 WTKR5
     I                                        2   3 WTKR6
     I                                        4   5 WTKR7
     I                                        6   6 WTKR8
     C           KEY1      KLIST
     C                     KFLD           WTKR1   1
     C                     KFLD           WTKR2   2
     C                     KFLD           WTKR3   2
     C                     KFLD           WTKR4   1
     C                     SETOF                     01
     C                     Z-ADD0         RECD    20
     C   02                GOTO STP2
     C                     SETON                     02
     C           *ENTRY    PLIST
     C                     PARM           PDAY    8
     C                     PARM FLIST     PLIST   1
     C                     PARM           PTKST   1
     C                     PARM           PTKRA   6
     C                     PARM           PTKRB   6
     C                     MOVE PTKST     WTKST   1
     C                     MOVE PDAY      UHIZK
     C                     MOVE PTKRA     WTKRA   6
     C                     MOVE PTKRB     WTKRB   6
     C           STP2      TAG
     C           WTKST     IFEQ 'Y'
     C           KEY1      SETLLFCEPL031
     C                     END
     C                     DO   *HIVAL
     C                     READ FCEPL03                  50
     C           *IN50     IFEQ '1'
     C                     GOTO END
     C                     END
     C           WTKST     IFEQ 'Y'
     C           A2TKR     IFGT WTKRB
     C                     SETON                     50
     C                     GOTO END
     C                     END
     C                     END
     C           A2GSKD    CABNE'D'       STP3
     C           A2GSHZ    CABGT*DATE     STP3
     C                     GOTO END
     C           STP3      TAG
     C           A2TRHZ    CABNEUHIZK     END
     C                     SETON                     01U4U2
     C                     MOVE '*'       FLIST   1
     C           STP1      TAG
     C*          A2SYHZ    CABNEUHIZK     END
     C*                    SETON                     U4U1
     C           *IN01     IFEQ '1'
     C                     EXCPTDAT
     C                     END
     C           END       TAG
     C  N50                ENDDO
     C                     SETON                     LR
     C                     RETRN
     OHEN     E                DAT
     O                         A2BHB1     5
