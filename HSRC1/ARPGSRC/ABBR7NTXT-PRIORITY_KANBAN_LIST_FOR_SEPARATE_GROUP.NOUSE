JW1   *===============================================
 |    * PRINT KANBAN TOTAL (TYPE:ALL)
 |    *===============================================
 |   C           #KAN@A    BEGSR
 .    * CREATE ABBWP7J
 .   C                     OPEN ABBWP7J
      * READ ABHPP01
     C                     EXSR #ABH
      * READ ADHPP01
     C                     EXSR #ADH
      * READ AAFPP01
     C                     EXSR #AAF
      * READ AAHPP01
     C                     EXSR #AAH
      *
     C                     CLOSEABBWP7J
      *
      * SET KANBAN TABLE
     C                     EXSR #SETK
      *
      * PRINT KANBAN TOTAL (ALL)
     C           1         DO   SQK       IX
     C           IX        IFEQ 1
     C                     MOVE *OFF      *IN49
     C                     ELSE
     C                     MOVE *ON       *IN49
     C                     ENDIF
     C*>>>>>>>>>>>>>>>>>>  EXCPT@TT3
     C                     SETOF                     11
     C                     EXSR ##TT3
     C*
     C                     ADD  TQ1,IX    TQ1,12
     C                     ADD  TC1,IX    TC1,12
     C                     ADD  TQ2,IX    TQ2,12
     C                     ADD  TC2,IX    TC2,12
     C                     ADD  TQ3,IX    TQ3,12
     C                     ADD  TC3,IX    TC3,12
     C                     ADD  TQ4,IX    TQ4,12
     C                     ADD  TC4,IX    TC4,12
 .   C                     ENDDO
 .    * PRINT KANBAN TOTAL (TYPE:ALL)
 |   C                     Z-ADD12        IX
 |   C                     MOVELTT1,1     TSZ,12
 |   C                     MOVE *OFF      *IN49
 |   C*>>>>>>>>>>>>>>>>>>> EXCPT@TT3
     C                     SETON                     11
     C                     EXSR ##TT3
 |    *
JW1  C                     ENDSR
      *================================================================
     C           ##TT3     BEGSR
     C                     MOVELTSZ,IX    S1TT
     C*
     C                     Z-ADDTQ1,IX    W$Q
     C                     EXSR #EDT1
     C                     MOVE W@Q       S1Q1
     C                     Z-ADDTC1,IX    W$Q
     C                     EXSR #EDT2
     C                     MOVE W@C       S1C1
     C*
     C                     Z-ADDTQ2,IX    W$Q
     C                     EXSR #EDT1
     C                     MOVE W@Q       S1Q2
     C                     Z-ADDTC2,IX    W$Q
     C                     EXSR #EDT2
     C                     MOVE W@C       S1C2
     C*
     C                     Z-ADDTQ3,IX    W$Q
     C                     EXSR #EDT1
     C                     MOVE W@Q       S1Q3
     C                     Z-ADDTC3,IX    W$Q
     C                     EXSR #EDT2
     C                     MOVE W@C       S1C3
     C*
     C                     Z-ADDTQ4,IX    W$Q
     C                     EXSR #EDT1
     C                     MOVE W@Q       S1Q4
     C                     Z-ADDTC4,IX    W$Q
     C                     EXSR #EDT2
     C                     MOVE W@C       S1C4
     C*
     C                     ADD  1         RRN1
     C                     WRITESFREC1
     C                     ENDSR
      *================================================================
JW1   *-(1)-------------------------------------------
 |    *          READ ABH AND CREATE ABBWP7J
 |    *-----------------------------------------------
 .   C           #ABH      BEGSR
 .   C                     MOVE *OFF      *IN93
     C           *LOVAL    SETLLABHPL02
     C           *IN93     DOWEQ*OFF
     C                     READ ABHPL02                  93
     C           *IN93     IFEQ *OFF
      * IGNORE DELETE FLAG
     C           M6SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * EXP DATE=9999?
     C           M6STYY    IFNE 9999
     C                     ITER
     C                     ENDIF
      * DEEPT=111
     C           M6BMON    IFNE 111
     C                     ITER
     C                     ENDIF
      * GET MACHINE CODE
     C                     SELEC
     C           M6KBN4    WHNE *BLANK
     C                     MOVELM6KBN4    @MCN
     C           M6KBN3    WHNE *BLANK
     C                     MOVELM6KBN3    @MCN
     C           M6KBN2    WHNE *BLANK
     C                     MOVELM6KBN2    @MCN
     C           M6KBN1    WHNE *BLANK
     C                     MOVELM6KBN1    @MCN
     C                     OTHER
     C                     MOVE *BLANK    @MCN    3
     C                     ENDSL
      *
     C           @MCN      IFNE *BLANK
      * GET @SIZ, @POS
     C                     MOVELM6JBN     PLOC    6
     C                     MOVELM6JBN2    @LCT    4
     C                     MOVE M6JBN3    @LCT
     C                     MOVEL'ABH'     PFIL    3
     C                     EXSR #PP7G
      *
     C                     CLEARABBWP7J1
     C                     Z-ADD*DATE     WADATE
     C                     MOVEL@MCN      WAMCHN
     C                     MOVEL@SIZ      WASIZE
     C                     MOVEL@SIZ9     WASIZ9
     C                     MOVEL@POS      WALCID
     C                     MOVEL@LCT      WALOC4
     C                     MOVELM6HIN1    WAPRT1
     C                     MOVELM6HIN2    WAPRT2
     C                     MOVELM6HIN3    WAPRT3
     C                     Z-ADDM6KMAX    WAKQTY
     C                     MOVE *BLANK    WAKNID
     C                     Z-ADD0         WAISDT
     C                     Z-ADDM6LOTK    WALOTS
      *
     C                     MOVEL'ABHPP01' WAFILE
     C                     WRITEABBWP7J1
      *
 .   C                     ENDIF
 .   C                     ENDIF
 |   C                     ENDDO
 |    *
JW1  C                     ENDSR
JW1   *-(2)-------------------------------------------
 |    *          READ ADH AND CREATE ABBWP7J
 |    *-----------------------------------------------
 .   C           #ADH      BEGSR
 .   C                     MOVE *OFF      *IN93
     C           *LOVAL    SETLLADHPL03
     C           *IN93     DOWEQ*OFF
     C                     READ ADHPL03                  93
     C           *IN93     IFEQ *OFF
      * IGNORE DELETE FLAG
     C           J6SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * EXP DATE=9999?
     C           J6STYY    IFNE 9999
     C                     ITER
     C                     ENDIF
      * DEEPT=111
     C           J6ATOB    IFNE 111
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELJ6RONO    @MCN    3
      *
     C           @MCN      IFNE *BLANK
      * GET @SIZ, @POS
     C                     MOVELJ6ATK     PLOC    6
     C                     MOVELJ6ATK2    @LCT    4
     C                     MOVE J6ATK3    @LCT
     C                     MOVEL'ADH'     PFIL
     C                     EXSR #PP7G
      *
     C                     CLEARABBWP7J1
     C                     Z-ADD*DATE     WADATE
     C                     MOVEL@MCN      WAMCHN
     C                     MOVEL@SIZ      WASIZE
     C                     MOVEL@SIZ9     WASIZ9
     C                     MOVEL@POS      WALCID
     C                     MOVEL@LCT      WALOC4
     C                     MOVELJ6SHN1    WAPRT1
     C                     MOVELJ6SHN2    WAPRT2
     C                     MOVELJ6SHN3    WAPRT3
     C                     Z-ADDJ6KMAX    WAKQTY
     C                     MOVE *BLANK    WAKNID
     C                     Z-ADD0         WAISDT
     C                     Z-ADDJ6LOTO    WALOTS
     C                     MOVEL'ADHPP01' WAFILE
     C                     WRITEABBWP7J1
      *
 .   C                     ENDIF
 .   C                     ENDIF
 |   C                     ENDDO
 |    *
JW1  C                     ENDSR
JW1   *-(3)-------------------------------------------
 |    *          READ AAF AND CREATE ABBWP7J
 |    *-----------------------------------------------
 .   C           #AAF      BEGSR
 .    *
     C                     MOVE *OFF      *IN93
     C           *LOVAL    SETLLAAFPL03
     C           *IN93     DOWEQ*OFF
     C                     READ AAFPL03                  93
     C           *IN93     IFEQ *OFF
      * IGNORE DELETE FLAG
     C           A3SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * EXP DATE=9999?
     C           A3STYY    IFNE 9999
     C                     ITER
     C                     ENDIF
      * SECTION=111
     C           A3ATOB    IFNE 111
     C                     ITER
     C                     ENDIF
      * IF APICS ONLY, A3ATK1=0
     C           D@TYPE    IFEQ '1'
     C           A3ATK1    ANDNE'0'
     C                     ITER
     C                     ENDIF
      *
      * GET @MCN, @SIZ, @POS, @LCT
     C           D@TYPE    IFEQ '1'
      * GET MACHINE CODE FROM MTK
     C                     CALL 'UTLR15'
     C                     PARM           A31HB5
     C                     PARM           A32HB5
     C                     PARM           A33HB2
     C                     PARM           A3MTK
     C                     PARM           @MCNM   3
     C                     PARM           @MCN1   3        FIRST PROC MACHINE
     C                     PARM           @RTN    1
     C                     MOVEL@MCN1     @MCN
     C                     MOVELA3MTK2    @LCT    4
     C                     MOVE A3MTK3    @LCT
     C                     MOVELA3MTK     PLOC
     C                     ELSE
      * GET MACHINE CODE FROM ATOK
     C                     CALL 'UTLR14'
     C                     PARM           A31HB5
     C                     PARM           A32HB5
     C                     PARM           A33HB2
     C                     PARM           A3ATOK
     C                     PARM           PMPRCP  3
     C                     PARM           PMMCNC  3
     C                     PARM           PMMCNP  3
     C                     PARM           @MCN1   3        FIRST PROC MACHINE
     C                     PARM           @RTN    1
     C                     MOVELPMMCNC    @MCN
     C                     MOVELA3ATK2    @LCT    4
     C                     MOVE A3ATK3    @LCT
     C                     MOVELA3ATK     PLOC
     C                     ENDIF
      * GET @SIZ, @POS
     C           @MCN      IFNE *BLANK
     C                     MOVEL'AAF'     PFIL
     C                     EXSR #PP7G
      *
     C           D@TYPE    IFEQ '1'
     C           @SIZ9     ANDEQ'999'
     C                     ITER
     C                     ENDIF
      *
     C                     CLEARABBWP7J1
     C                     Z-ADD*DATE     WADATE
     C                     MOVEL@MCN      WAMCHN
     C                     MOVEL@SIZ      WASIZE
     C                     MOVEL@SIZ9     WASIZ9
     C                     MOVEL@POS      WALCID
     C                     MOVEL@LCT      WALOC4
     C                     MOVELA31HB5    WAPRT1
     C                     MOVELA32HB5    WAPRT2
     C                     MOVELA33HB2    WAPRT3
     C                     Z-ADDA3KMAX    WAKQTY
     C                     MOVE *BLANK    WAKNID
     C                     Z-ADD0         WAISDT
     C                     Z-ADD1         WALOTS
     C                     MOVEL@MCN1     WAMCN1
     C                     MOVEL'AAFPP01' WAFILE
      * GET FIRST PROC SIZE
     C           WASIZE    IFEQ 'CV '
     C           WASIZE    OREQ 'ST '
     C                     MOVEL@MCN1     K@MCHN
     C                     MOVEL*BLANK    K@LOCT
     C           K#PP7G    CHAINABBPP7G              91
     C           *IN91     IFEQ *OFF
     C           A#SKJY    ANDEQ' '
     C                     MOVELA#SIZE    WASIZ1
     C                     ENDIF
     C                     ENDIF
      *
     C           WASIZ1    IFEQ *BLANK
     C                     MOVELWASIZE    WASIZ1
     C                     ENDIF
      *
     C           WASIZ1    IFEQ 'CV '
     C           WASIZ1    OREQ 'ST '
     C           WASIZ1    OREQ 'OQ '
     C                     MOVE *BLANK    WASIZ1
     C                     ENDIF
      * BOX/DAY
     C           A3SSYS    IFNE 0
     C           A3KSSU    DIV  A3SSYS    @BPD    61
     C                     ELSE
     C                     Z-ADD1         @BPD
     C                     ENDIF
      *
     C                     Z-ADD@BPD      WABPD
     C                     WRITEABBWP7J1
     C                     ENDIF
      *
 .   C                     ENDIF
 |   C                     ENDDO
 |    *
JW1  C                     ENDSR
JW1   *--(4)------------------------------------------
 |    *          READ AAH AND CREATE ABBWP7J
 |    *-----------------------------------------------
 .   C           #AAH      BEGSR
 .    *
     C                     MOVE *OFF      *IN93
     C           *LOVAL    SETLLAAHPL03
     C           *IN93     DOWEQ*OFF
     C                     READ AAHPL03                  93
     C           *IN93     IFEQ *OFF
      * IGNORE DELETE FLAG
     C           L6SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * EXP DATE=9999?
     C           L6STYY    MULT 100       L6STYM  60
     C                     ADD  L6STMM    L6STYM
     C           L6STYY    IFEQ 9999
     C                     ELSE
     C           L6STYM    IFGE ST@DT6
     C           L6DTHE    ANDEQ*BLANK
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      * SECTION=111
     C           L6ATOB    IFNE 111
     C                     ITER
     C                     ENDIF
      *
      * GET @MCN, @SIZ, @POS, @LCT
     C           D@TYPE    IFEQ '1'
      * GET MACHINE CODE FROM MTK
     C                     CALL 'UTLR15'
     C                     PARM           L6SHN1
     C                     PARM           L6SHN2
     C                     PARM           L6SHN3
     C                     PARM           L6MTK
     C                     PARM           @MCNM   3
     C                     PARM           @MCN1            FIRST PROC MACHINE
     C                     PARM           @RTN    1
     C                     MOVEL@MCN1     @MCN
     C                     MOVELL6MTK2    @LCT    4
     C                     MOVE L6MTK3    @LCT
     C                     MOVELL6MTK     PLOC
     C                     ELSE
      * GET MACHINE CODE FROM ATOK
     C                     CALL 'UTLR14'
     C                     PARM           L6SHN1
     C                     PARM           L6SHN2
     C                     PARM           L6SHN3
     C                     PARM           L6ATOK
     C                     PARM           PMPRCP  3
     C                     PARM           PMMCNC  3
     C                     PARM           PMMCNP  3
     C                     PARM           @MCN1   3        FIRST PROC MACHINE
     C                     PARM           @RTN    1
     C                     MOVELPMMCNC    @MCN
     C                     MOVELL6ATK2    @LCT    4
     C                     MOVE L6ATK3    @LCT
     C                     MOVELL6ATK     PLOC
     C                     ENDIF
      *
     C           @MCN      IFNE *BLANK
      * GET @SIZ, @POS
     C                     MOVEL'AAH'     PFIL
     C                     EXSR #PP7G
      *
     C           D@TYPE    IFEQ '1'
     C           @SIZ9     ANDEQ'999'
     C                     ITER
     C                     ENDIF
      *
     C                     CLEARABBWP7J1
     C                     Z-ADD*DATE     WADATE
     C                     MOVEL@MCN      WAMCHN
     C                     MOVEL@SIZ      WASIZE
     C                     MOVEL@SIZ9     WASIZ9
     C                     MOVEL@POS      WALCID
     C                     MOVEL@LCT      WALOC4
     C                     MOVELL6SHN1    WAPRT1
     C                     MOVELL6SHN2    WAPRT2
     C                     MOVELL6SHN3    WAPRT3
     C                     Z-ADDL6KMAX    WAKQTY
     C                     MOVE *BLANK    WAKNID
     C                     Z-ADD0         WAISDT
     C                     Z-ADD1         WALOTS
     C                     MOVEL@MCN1     WAMCN1
     C                     MOVEL'AAHPP01' WAFILE
      * GET FIRST PROC SIZE
     C           WASIZE    IFEQ 'CV '
     C           WASIZE    OREQ 'ST '
     C                     MOVEL@MCN1     K@MCHN
     C                     MOVEL*BLANK    K@LOCT
     C           K#PP7G    CHAINABBPP7G              91
     C           *IN91     IFEQ *OFF
     C           A#SKJY    ANDEQ' '
     C                     MOVELA#SIZE    WASIZ1
     C                     ENDIF
     C                     ENDIF
      *
     C           WASIZ1    IFEQ *BLANK
     C                     MOVELWASIZE    WASIZ1
     C                     ENDIF
      *
     C           WASIZ1    IFEQ 'CV '
     C           WASIZ1    OREQ 'ST '
     C           WASIZ1    OREQ 'OQ '
     C                     MOVE *BLANK    WASIZ1
     C                     ENDIF
      * BOX/DAY
     C           L6SYOS    IFNE 0
     C           L6KSSU    DIV  L6SYOS    @BPD    61
     C                     ELSE
     C                     Z-ADD1         @BPD
     C                     ENDIF
     C                     Z-ADD@BPD      WABPD
      *
     C                     WRITEABBWP7J1
     C                     ENDIF
      *
 .   C                     ENDIF
 |   C                     ENDDO
 |    *
JW1  C                     ENDSR
JW1   *-----------------------------------------------
 |    *   SET @SIZ & @POS BY @MCN & @LCT
 |    *-----------------------------------------------
 .   C           #PP7G     BEGSR
 .    *
     C                     MOVE *BLANK    @SIZ    3
     C                     MOVE *BLANK    @POS    2
     C                     MOVEL@LCT      #LOC1   1
     C                     MOVEL@LCT      #LOC2   2
     C                     MOVE *BLANK    @SIZ9   3
      *
     C           D@TYPE    IFEQ *BLANK
     C                     SELEC
     C           #LOC1     WHEQ 'J'
     C           #LOC1     OREQ 'Z'
     C           #LOC2     OREQ 'G7'
     C           #LOC2     OREQ 'G8'
     C                     MOVEL'CV '     @SIZ
     C                     MOVEL'999'     @SIZ9
     C           #LOC1     WHEQ 'X'
     C           #LOC1     OREQ 'G'
     C                     MOVEL'ST '     @SIZ
     C                     MOVEL'999'     @SIZ9
     C           #LOC1     WHEQ 'V'
     C                     MOVEL'NUT'     @SIZ
     C                     MOVEL'999'     @SIZ9
     C                     ENDSL
     C                     ENDIF
      *
     C           @SIZ      IFEQ *BLANK
      * CHECK MACHINE MASTER
     C                     MOVEL@MCN      K@MCHN
     C                     MOVE *BLANK    K@LOCT
     C           K#PP7G    CHAINABBPP7G              99
     C           *IN99     IFEQ *OFF
     C           A#SKJY    ANDEQ' '
     C                     MOVELA#SIZE    @SIZ
     C                     ELSE
     C                     MOVEL*BLANK    K@MCHN
     C                     MOVELPLOC      K@LOCT
     C           K#PP7G    CHAINABBPP7G              99
     C           *IN99     IFEQ *OFF
     C           A#SKJY    ANDEQ' '
     C                     MOVELA#SIZE    @SIZ
     C                     ELSE
     C                     MOVEL'999'     @SIZ
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
      * ADJUST SIZE (ADD GROUP)
     C           @SIZ      IFEQ '999'
     C                     MOVEL'OQ '     @SIZ
     C                     MOVEL'999'     @SIZ9
     C                     ENDIF
      * POSITION 10, 20 OR 30
     C                     SELEC
     C           #LOC1     WHEQ 'H'
     C           #LOC1     OREQ 'D'
     C                     MOVEL'10'      @POS
     C           #LOC1     WHEQ 'T'
     C           #LOC1     OREQ 'M'
     C           #LOC1     OREQ 'N'
     C                     MOVEL'20'      @POS
 .   C                     OTHER
 .   C                     MOVEL'30'      @POS
 |   C                     ENDSL
 |    *
JW1  C                     ENDSR
      *-----------------------------------------------
JW1   *          SET KANBAN TOTAL TABLE
 |    *-----------------------------------------------
 |   C           #SETK     BEGSR
 .    *
 .   C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         IX
     C                     OPEN ABBWP7J
      *
     C           *LOVAL    SETLLABBWP7J
     C                     MOVE *OFF      *IN94
     C           *IN94     DOWEQ*OFF
     C                     READ ABBWP7J                  94
     C           *IN94     IFEQ *OFF
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELWASIZE    SVSIZE  3
     C                     Z-ADD1         IX
     C                     ENDIF
      * BREAK?
     C           WASIZE    IFNE SVSIZE
     C                     EXSR #BRK1
     C                     ENDIF
      * DETAIL PROCESS
     C           WAKQTY    MULT WALOTS    @QTY    60
     C                     SELEC
     C           WALCID    WHEQ '10'
     C                     ADD  @QTY      TQ1,IX
     C                     ADD  1         TC1,IX
     C           WALCID    WHEQ '20'
     C                     ADD  @QTY      TQ2,IX
     C                     ADD  1         TC2,IX
     C                     OTHER
     C                     ADD  @QTY      TQ3,IX
     C                     ADD  1         TC3,IX
     C                     ENDSL
      *
     C                     ENDIF
     C                     ENDDO
      * LAST BREAK?
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK1
 .   C                     ENDIF
 .    *
 |   C                     CLOSEABBWP7J
 |    *
JW1  C                     ENDSR
      *-----------------------------------------------
JW1   * ABBWP7J BREAK PROCESS
 |    *-----------------------------------------------
 |   C           #BRK1     BEGSR
 .   C                     MOVELSVSIZE    TSZ,IX
 .   C           TQ1,IX    ADD  TQ2,IX    TQ4,IX
     C                     ADD  TQ3,IX    TQ4,IX
     C           TC1,IX    ADD  TC2,IX    TC4,IX
     C                     ADD  TC3,IX    TC4,IX
      *
 .   C                     MOVELWASIZE    SVSIZE
 .   C                     Z-ADDIX        SQK
 |   C                     ADD  1         IX
 |    *
JW1  C                     ENDSR
      *-----------------------------------------------
JW1   * ABBWP7J BREAK PROCESS
 |    *-----------------------------------------------
 |   C           #BRK2     BEGSR
 .   C                     ADD  1         IX
 .   C                     MOVELSVSIZ1    NSZ    21
     C           IX        IFEQ 1
     C                     MOVE *ON       *IN49
     C                     MOVE *ON       *IN50
     C                     ELSE
     C                     MOVE *OFF      *IN49
     C                     MOVE *OFF      *IN50
     C                     ENDIF
     C           NQ2       IFNE 0
     C           NQ1       MULT 100       NUM91   91
     C           NUM91     DIV  NQ2       NQ3     51
     C                     ELSE
     C                     Z-ADD0         NQ3
     C                     ENDIF
      *
     C*******************  EXCPT@TT5
      *
 .   C                     MOVELWKSIZ1    SVSIZ1
 .   C                     Z-ADD0         NQ1     60
 .   C                     Z-ADD0         NC1     40
 |   C                     Z-ADD0         NQ2     60
 |   C                     Z-ADD0         NC2     40
 |    *
JW1  C                     ENDSR
JW2   *===============================================
 |    * PRINT KANBAN TOTAL (APICS ONLY) OLD
 |    *===============================================
 |   C           #KAN@P    BEGSR
 .    * CREATE ABBWP7J
 .   C                     OPEN ABBWP7J
      * READ AAFPP01
     C                     EXSR #AAF
      * READ AAHPP01
     C                     EXSR #AAH
      *
     C                     CLOSEABBWP7J
      *
      * SET KANBAN TABLE
     C                     EXSR #SETK
      *
      * PRINT KANBAN GROUP TOTAL
     C           1         DO   SQK       IX
     C           IX        IFEQ 1
     C                     MOVE *OFF      *IN49
     C                     ELSE
     C                     MOVE *ON       *IN49
     C                     ENDIF
     C                     MOVE *OFF      *IN51
     C*>>>>>>>>>>>>>>>>>>  EXCPT@TT4
     C                     ADD  TQ1,IX    TQ1,12
     C                     ADD  TC1,IX    TC1,12
     C                     ADD  TQ2,IX    TQ2,12
     C                     ADD  TC2,IX    TC2,12
     C                     ADD  TQ3,IX    TQ3,12
     C                     ADD  TC3,IX    TC3,12
     C                     ADD  TQ4,IX    TQ4,12
     C                     ADD  TC4,IX    TC4,12
 .   C                     ENDDO
 .    * PRINT KANBAN TOTAL (TYPE:APICS) OLD
 |   C                     Z-ADD12        IX
 |   C                     MOVELTT1,5     TSZ,12
 |   C                     MOVE *OFF      *IN49
 |   C                     MOVE *OFF      *IN51
 |   C*>>>>>>>>>>>>>>>>>>> EXCPT@TT4
 |    *
JW2  C                     ENDSR
JW2   *===============================================
 |    * PRINT KANBAN TOTAL (APICS ONLY)  NEW
 |    *===============================================
 |   C           #KAN@N    BEGSR
      *
     C                     OPEN ABBWP7J
     C                     OPEN ABBWP7K
      *
      * SET SHORTAGE --------------------------------------
     C           *LOVAL    SETLLABBWP72
     C                     DO   *HIVAL
     C                     READ ABBWP72                  95
     C   95                LEAVE
      *
     C           W7SIZE    IFEQ 'CV '
     C           W7SIZE    OREQ 'OQ '
     C           W7SIZE    OREQ 'ST '
     C           W7FIL5    IFEQ *BLANK
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      *
      *
     C           W7SIZE    IFEQ 'NUT'
     C           W7FIL2    IFEQ *BLANK
     C           W7FIL5    OREQ 'NUT'
     C           W7FIL2    ANDEQ'99'
     C                     ELSE
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      *
      * MOVE ABBWP72 TO ABBWP7K
     C                     CLEARABBWP7K1
     C                     Z-ADDW7DATE    WKDATE
     C                     MOVELW7SIZE    WKSIZ3
     C           W7FIL2    IFEQ '99'
     C                     MOVEL'999'     WKSIZ9
     C                     ELSE
     C                     MOVE *BLANK    WKSIZ9
     C                     ENDIF
      *
     C           W7SIZE    IFEQ 'CV '
     C           W7SIZE    OREQ 'OQ '
     C           W7SIZE    OREQ 'ST '
     C                     MOVELW7FIL5    WKSIZ1
     C                     ELSE
     C                     MOVELW7SIZE    WKSIZ1
     C                     ENDIF
      *
     C                     MOVEL'S'       WKSA
     C                     Z-ADDW7KQTY    WKSQTY
     C                     Z-ADD0         WKBPD
     C                     Z-ADDW7KQTY    WKKQTY
     C                     MOVELW7LCID    WKLCID
     C                     MOVELW7LOC4    WKLOC4
     C                     MOVELW7PRT1    WKPRT1
     C                     MOVELW7PRT2    WKPRT2
     C                     MOVELW7PRT3    WKPRT3
     C                     MOVELW7KNID    WKKNID
     C                     Z-ADDW7ISDT    WKISDT
     C                     MOVELW7MCHN    WKMCHN
     C                     Z-ADDW7LOTS    WKLOTS
     C                     MOVEL'ABBWP72 'WKFILE
     C                     WRITEABBWP7K1
     C                     ENDDO
      * SET BOX/DAY ---------------------------------------
     C                     DO   *HIVAL
     C                     READ ABBWP7J                  95
     C   95                LEAVE
      * MOVE ABBWP7J TO ABBWP7K
     C                     MOVE *BLANK    @SIZ1   3        1ST PROC SIZE
     C                     MOVELWAMCN1    K@MCHN
     C                     MOVEL*BLANK    K@LOCT
     C           K#PP7G    CHAINABBPP7G              91
     C           *IN91     IFEQ *OFF
     C           A#SKJY    ANDEQ' '
     C                     MOVELA#SIZE    @SIZ1
     C                     ENDIF
      *
     C           @SIZ1     IFNE *BLANK
     C                     CLEARABBWP7K1
     C                     MOVELWADATE    WKDATE
     C                     MOVELWASIZE    WKSIZ3
     C                     MOVELWASIZ9    WKSIZ9
     C                     MOVEL'A'       WKSA
     C                     Z-ADD0         WKSQTY
     C                     Z-ADDWABPD     WKBPD
     C                     Z-ADDWAKQTY    WKKQTY
     C                     MOVELWALCID    WKLCID
     C                     MOVELWALOC4    WKLOC4
     C                     MOVELWAPRT1    WKPRT1
     C                     MOVELWAPRT2    WKPRT2
     C                     MOVELWAPRT3    WKPRT3
     C                     MOVELWAKNID    WKKNID
     C                     MOVELWAISDT    WKISDT
     C                     MOVELWAMCHN    WKMCHN
     C                     Z-ADDWALOTS    WKLOTS
     C                     MOVEL@SIZ1     WKSIZ1
     C                     MOVEL@SIZ1     WKMCN1
     C                     MOVELWAFILE    WKFILE
     C                     WRITEABBWP7K1
     C                     ENDIF
     C                     ENDDO
      *
      * READ ABBWP7K AND PRINT KANBAN TOTAL (APICS)
     C                     MOVE 'Y'       FIRST
     C           *LOVAL    SETLLABBWP7K
     C                     MOVE *OFF      *IN94
     C           *IN94     DOWEQ*OFF
     C                     READ ABBWP7K                  94
     C           *IN94     IFEQ *OFF
     C           WKSIZ1    ANDNE*BLANK
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELWKSIZ1    SVSIZ1  3
     C                     Z-ADD0         IX
     C                     ENDIF
      * BREAK?
     C           WKSIZ1    IFNE SVSIZ1
     C                     EXSR #BRK2
     C                     ENDIF
      * DETAIL PROCESS
     C                     ADD  WKSQTY    NQ1
     C                     ADD  WKSQTY    NQ1G    60
     C                     ADD  WKBPD     NQ2
     C                     ADD  WKBPD     NQ2G    60
     C           WKSA      IFEQ 'S'
     C                     ADD  1         NC1
     C                     ADD  1         NC1G    40
     C                     ENDIF
     C           WKSA      IFEQ 'A'
     C                     ADD  1         NC2
     C                     ADD  1         NC2G    40
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      * LAST BREAK?
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK2
 .   C                     ENDIF
      * PRINT KANBAN TTL ( LIST)
 |   C                     MOVELTT1,5     NSZG   23
 |   C******************** EXCPT@TT5G
 |    *
JW2  C                     ENDSR
      ************************************************
     C           *INZSR    BEGSR
      ************************************************
     C**         *ENTRY    PLIST
     C**                   PARM           MAIS    3
     C**                   PARM           PDAT    8
TCHK3C**                   PARM           PMPRNT 10
TCHK3C**                   MOVEL*BLANK    PMPRNT
      *
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      *
     C           K#ADG     KLIST
     C                     KFLD           W@YY
     C                     KFLD           W@MM
     C                     KFLD           W@DD
      *
     C           K#ADGX    KLIST
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C                     KFLD           K@DD    20
      *
     C           K#FCC     KLIST
     C                     KFLD           W7PRT1
     C                     KFLD           W7PRT2
     C                     KFLD           W7PRT3
      *
     C           K#FCX     KLIST
     C                     KFLD           W7PRT1
     C                     KFLD           W7PRT2
     C                     KFLD           W7PRT3
     C                     KFLD           W7PRC
      *
     C           K#AAM     KLIST
     C                     KFLD           A7PRT1
     C                     KFLD           A7PRT2
     C                     KFLD           A7PRT3
      *
     C           K#LOC     KLIST
     C                     KFLD           W7L1
     C                     KFLD           W7L2
     C                     KFLD           W7L3
     C                     KFLD           W7L4
      *
     C           K#AB18    KLIST
     C                     KFLD           @@JHN1
     C                     KFLD           @@JHN2
     C                     KFLD           @@JHN3
     C                     KFLD           K@NOYY  40
     C                     KFLD           K@NOMM  20
     C                     KFLD           K@NODD  20
      *
     C           K#ABAB    KLIST
     C                     KFLD           @@JHN1  5
     C                     KFLD           @@JHN2  5
     C                     KFLD           @@JHN3  2
      *
     C           K#AM      KLIST
     C                     KFLD           @PRT1
     C                     KFLD           @PRT2
     C                     KFLD           @PRT3
      *
     C           K#71      KLIST
     C                     KFLD           W@YMD
     C                     KFLD           D@SHFT
      *
     C                     MOVE '01'      @@ID    2
      *
     C                     TIME           ST@DAT
     C                     Z-ADD*DATE     D@YMD
     C                     Z-ADD1         D@CPY
TCHK6C*                    Z-ADD1         D@CPY2
     C                     MOVE '3'       D@SHFT
JW1  C                     Z-ADD0         SQ2     20
JW1  C                     Z-ADD0         SQK     20
JW1  C                     Z-ADD0         IX      20
JW2  C                     MOVELMSG,1     JW      1
      * SWITCH FOR NEW/OLD KANBAN TOTAL (Y=NEW)
JW2  C                     MOVE 'Y'       SWN     1
      *
     C                     ENDSR
