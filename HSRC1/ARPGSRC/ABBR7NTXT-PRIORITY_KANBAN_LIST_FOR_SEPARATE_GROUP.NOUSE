      ***************************************************
      *          MAIN ROUTINE                           *
      ***************************************************
     C           *ENTRY    PLIST
     C                     PARM           P$CMD   1
     C                     MOVE ' '       P$CMD
     C*
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C**                   MOVE *BLANK    MAIS
TCHK3C**                   MOVEL@OUTQ     PMPRNT    P
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
     C           #SCRN1    BEGSR
      *-----------------------------------------------
      *
     C                     EXFMTDSP01
     C                     MOVE *BLANK    XMSG
     C                     MOVEA'00000'   *IN,61
      *
S1   C           *INKA     IFEQ *ON
     C                     MOVE '1'       P$CMD
     C                     MOVE '99'      @@ID
X1   C                     ELSE
     C                     EXSR #CHK1
 S2  C           *IN85     IFEQ *OFF
     C************INKE     ANDEQ*ON
     C                     WRITEABBWP711
     C                     EXSR #WRT
      *
  S3 C           D@CPY     IFNE *ZERO
     C                     EXSR #RED
TCHK C                     EXSR #PMTCH
TCHK5C                     OPEN ABBWP72
     C                     EXSR #PRT
  E3 C                     ENDIF
      *
     C                     MOVE '3'       P$CMD
     C                     MOVE '99'      @@ID
 E2  C                     ENDIF
E1   C                     ENDIF
      *
     C           @SCRN9    ENDSR
      *-----------------------------------------------
      * CHECK INPUT FIELD
      *-----------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     SETOF                     85
     C           D@YMD     IFEQ 0
     C                     MOVELMSG,1     XMSG
     C                     SETON                     6185
     C                     GOTO #CHK1X
     C                     ENDIF
      *
     C           D@YMD     ADD  20000000  W@YMD
     C           K#ADG     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C  N85                MOVELMSG,2     XMSG
     C                     SETON                     6185
     C                     GOTO #CHK1X
     C                     ELSE
     C                     Z-ADDF8YOBI    Q       10
     C                     MOVE WD,Q      @WDD    3
     C                     ENDIF
      *
     C           W@YMD     CHAINABBPL71              90
     C           *IN90     IFEQ *ON
     C  N85                MOVELMSG,3     XMSG
     C                     SETON                     6185
     C                     GOTO #CHK1X
     C                     ENDIF
      * SHIFT SHOULD BE 1/2/3
     C           D@SHFT    IFLT '1'
     C           D@SHFT    ORGT '3'
     C  N85                MOVELMSG,4     XMSG
     C                     SETON                     6385
     C                     GOTO #CHK1X
     C                     ENDIF
      * COPY
     C                     Z-ADD1         D@CPY   20
      * LIST TYPE
     C                     MOVE ' '       D@TYPE  1
      *
     C**                   MOVE W@YMD     PDAT
      * IF NO ERROR
     C           *IN85     IFEQ *OFF
     C                     MOVELMSG,8     XMSG
     C                     ENDIF
      *
     C           #CHK1X    ENDSR
      *-----------------------------------------------
      *
      *-----------------------------------------------
     C           #WRT      BEGSR
      *
      * 10 DAYS
     C                     Z-ADD0         @W10    31
     C                     Z-ADD*DATE     K@YMD
     C                     Z-ADD*ZERO     QQ
     C           K#ADGX    SETGTAGDPL121
S1   C                     DO   *HIVAL
     C                     READPAGDPL121                 90
 S2  C           *IN90     IFEQ *OFF
      *
  S3 C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ITER
  E3 C                     ENDIF
      *
     C                     Z-ADDF8YMD     @10DT   80
  S3 C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         @W10
  X3 C                     ELSE
     C                     ADD  0.5       @W10
  E3 C                     ENDIF
     C                     ADD  1         QQ
  S3 C           QQ        IFEQ 10
     C                     LEAVE
  E3 C                     ENDIF
      *
 E2  C                     ENDIF
E1   C                     ENDDO
      *
     C                     OPEN ABBWP71
%3   C                     OPEN ABBWL71
      *
     C                     CLEARABBWP711
     C                     MOVE *BLANK    WLOCT   6
      * BIG LOOP
      * PRIORITY KANBAN FILE    *
     C           K#71      SETLLABBPL71
      ***************************
S1   C           *IN80     DOUEQ*ON
     C           K#71      READEABBPL71                  80
 S2  C           *IN80     IFEQ *OFF
     C           A7KQTY    ANDNE*ZERO
JW2   *
 |    * CHECK LIST TYPE
  S3 C           D@TYPE    IFEQ '1'
 |   C           A7ISDT    ANDEQ0
 |   C                     ITER
  E3 C                     ENDIF
      *
     C                     MOVE *BLANK    APKUBN  1
  S3 C           A7KNID    IFNE 'A'
     C                     MOVE '9'       APKUBN
  E3 C                     END
      *
%0001 *
  S3 C           W7PART    IFNE *BLANK
  S4 C           W7PART    IFNE A7PART
     C           WLOCT     ORNE A7LOCT
     C           W7KNID    ORNE A7KNID
     C                     EXSR #OUT
  E4 C                     ENDIF
