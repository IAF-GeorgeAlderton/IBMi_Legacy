 |   C           K#PP7G    CHAINABBPP7G              99
 |   C           *IN99     IFEQ *OFF
 |   C           A#SKJY    ANDEQ' '
 |   C                     MOVELA#SIZE    @DUP,2
 |   C                     MOVELA#SIZE    @SIZ2
 |   C                     ENDIF
 |   C                     ENDIF
 |    * "30" -----------------------------------------
 |   C                     MOVEL@HMCN3    LTR3    3
 |   C           LTR3      IFNE *BLANK
 |   C           @DUP,3    ANDEQ*BLANK
 |   C                     MOVELLTR3      K@MCHN
 |   C                     MOVEL*BLANK    K@LOCT
 |   C           K#PP7G    CHAINABBPP7G              99
 |   C           *IN99     IFEQ *OFF
 |   C           A#SKJY    ANDEQ' '
 |   C                     MOVELA#SIZE    @DUP,3
 |   C                     MOVELA#SIZE    @SIZ2
 |   C                     ENDIF
 |   C                     ENDIF
 |    *
 |   C                     ENDIF
JW2  C                     ENDIF
      *
     C*******************  EXCPT@DTL
      *
     C                     ADD  @QX       @QTT
     C                     Z-ADD*ZERO     @QX
     C                     MOVE *BLANK    PRT
     C                     MOVE *BLANK    LOC
     C                     MOVE *BLANK    KID
     C                     Z-ADD*ZERO     @QT
     C                     Z-ADD*ZERO     @SD8
     C                     MOVE *BLANK    CMT
     C                     MOVE *BLANK    MCN
     C                     Z-ADD*ZERO     LOT
     C                     Z-ADD*ZERO     @SET
     C                     Z-ADD*ZERO     @ACT
TCHK C                     MOVE *BLANK    @DUP
      *
     C                     ENDSR
      *--------------------------------------------------
      *  PRINT DETAIL LINE
      *--------------------------------------------------
     C           #DTL2     BEGSR
      *
     C                     Z-ADD@SD8      @SD4
      *
     C           LOT,1     COMP 0                    0101
     C           LOT,2     COMP 0                    0202
     C           LOT,3     COMP 0                    0303
     C           @SET,1    COMP 0                    1111
     C           @SET,2    COMP 0                    1212
     C           @SET,3    COMP 0                    1313
      *
TCHK7C                     MOVE *BLANK    MRK1    1
TCHK7C           PRT,1     IFNE *BLANK
TCHK7C                     MOVE PRT,1     @PART
TCHK7C           @PRT1     CAT  @PRT2:0   @P12   12 P
TCHK7C           @P12      CAT  @PRT3:0   @P12      P
TCHK7 *
TCHK7C           K#AM      CHAINAAMPL11              26
TCHK7C           *IN26     IFEQ *OFF
TCHK7C           1         DO   15        Z       20
TCHK7C                     MOVE *BLANK    @NEW    1
TCHK7C           CHG,Z     IFNE *ZERO
TCHK7C                     Z-ADDCHG,W     @CHG
TCHK7C           @CHGDT    IFGT *DATE
TCHK7C                     MOVE '1'       @NEW
TCHK7C                     ENDIF
TCHK7C                     ENDIF
TCHK7C           NTKR,Z    IFEQ *BLANK
TCHK7C           @NEW      ANDEQ*BLANK
TCHK7C                     LEAVE
TCHK7C                     ENDIF
TCHK7C           OTKR,Z    IFEQ *BLANK
TCHK7C           @NEW      ANDEQ'1'
TCHK7C                     LEAVE
TCHK7C                     ENDIF
TCHK7 *
TCHK7C           @NEW      IFEQ *BLANK
TCHK7C           NDPT,Z    IFNE *ZERO
TCHK7C           NDPT,Z    ANDNE0111
TCHK7C                     MOVEL'$'       MRK1
TCHK7C                     LEAVE
TCHK7C                     END
TCHK7C                     ELSE
TCHK7C           ODPT,Z    IFNE *ZERO
TCHK7C           ODPT,Z    ANDNE0111
TCHK7C                     MOVEL'$'       MRK1
TCHK7C                     LEAVE
TCHK7C                     END
TCHK7C                     END
TCHK7 *
TCHK7C                     ENDDO
TCHK7C                     ENDIF
TCHK7C                     ENDIF
TCHK7 *
     C                     MOVE ':'       @CP     1
     C                     MOVE *BLANK    @28    28
TCHK7C                     MOVE *BLANK    MRK2    1
     C           PRT,2     IFNE *BLANK
     C                     MOVE LOC,2     @LOCT
     C           @LOC1     CAT  @LOC2:0   @LOC4   4
     C                     MOVE PRT,2     @PART
     C           @PRT1     CAT  @PRT2:0   @P12   12 P
     C           @P12      CAT  @PRT3:0   @P12      P
      *
     C           K#AM      CHAINFCEPL01              26
      *
     C           K#AM      CHAINAAMPL11              26
     C           *IN26     IFEQ *OFF
     C                     MOVE *OFF      *IN27
     C           1         DO   15        Z       20
     C                     MOVE *BLANK    @NEW    1
     C           CHG,Z     IFNE *ZERO
     C                     Z-ADDCHG,W     @CHG
     C           @CHGDT    IFGT *DATE
     C                     MOVE '1'       @NEW
     C                     ENDIF
     C                     ENDIF
     C           NTKR,Z    IFEQ *BLANK
     C           @NEW      ANDEQ*BLANK
     C                     LEAVE
     C                     ENDIF
     C           OTKR,Z    IFEQ *BLANK
     C           @NEW      ANDEQ'1'
     C                     LEAVE
     C                     ENDIF
TCHK7 *
TCHK7C           @NEW      IFEQ *BLANK
TCHK7C           NDPT,Z    IFNE *ZERO
TCHK7C           NDPT,Z    ANDNE0111
TCHK7C                     MOVEL'$'       MRK2
TCHK7C                     END
TCHK7C                     ELSE
TCHK7C           ODPT,Z    IFNE *ZERO
TCHK7C           ODPT,Z    ANDNE0111
TCHK7C                     MOVEL'$'       MRK2
TCHK7C                     END
TCHK7C                     END
      *
      *
     C           @NEW      IFEQ *BLANK
     C                     MOVE NTKR,Z    @6
     C                     MOVE NMCN,Z    @MCN    3
     C                     ELSE
     C                     MOVE OTKR,Z    @6
     C                     MOVE OMCN,Z    @MCN    3
     C                     ENDIF
      *
     C           @4        IFEQ @LOC4
     C           SSU,Z     ANDNEA2GEKN
     C                     MOVE '*'       @CP
     C                     ENDIF
      *
     C                     SELEC
     C           @1        WHEQ 'H'
     C           @1        OREQ 'N'
     C           @1        OREQ 'S'
TCHKAC           @1        OREQ 'D'
     C           @4        CAT  '-':0     @28       P
     C           @28       CAT  @MCN:0    @28       P
      *
     C           @1        WHEQ 'T'
     C           MCN,2     ANDEQ'LN1'
     C           @1        OREQ 'T'
     C           MCN,2     ANDEQ'AOQ'
     C           *IN27     IFEQ *ON
     C           @28       CAT  ',':0     @28       P
     C                     ENDIF
     C           @28       CAT  @4:0      @28       P
     C           @28       CAT  '-':0     @28       P
     C           @28       CAT  @MCN:0    @28       P
TCHKAC*
TCHKAC           @1        WHEQ 'M'
TCHKAC           MCN,2     ANDEQ'LN1'
TCHKAC           @1        OREQ 'M'
TCHKAC           MCN,2     ANDEQ'AOQ'
TCHKAC           *IN27     IFEQ *ON
TCHKAC           @28       CAT  ',':0     @28       P
TCHKAC                     ENDIF
TCHKAC           @28       CAT  @4:0      @28       P
TCHKAC           @28       CAT  '-':0     @28       P
TCHKAC           @28       CAT  @MCN:0    @28       P
      *
     C                     OTHER
     C           *IN27     IFEQ *ON
     C           @28       CAT  ',':0     @28       P
     C                     ENDIF
     C           @28       CAT  @4:0      @28       P
      *
     C                     ENDSL
     C                     MOVE *ON       *IN27
      *
     C                     ENDDO
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVE *BLANK    @HMCN3  4
     C                     MOVE *BLANK    @RMCN3  4
     C           PRT,3     IFNE *BLANK
     C                     MOVE LOC,3     @LOCT
     C           @LOC1     CAT  @LOC2:0   @LOC4   4
     C                     MOVELPRT,3     @PART     P
     C           K#AM      CHAINAAMPL11              26
     C           *IN26     IFEQ *OFF
     C           1         DO   15        Z       20
     C                     MOVE *BLANK    @NEW    1
     C           CHG,Z     IFNE *ZERO
     C                     Z-ADDCHG,Z     @CHG
     C           @CHGDT    IFGT *DATE
     C                     MOVE '1'       @NEW
     C                     ENDIF
     C                     ENDIF
     C           NTKR,Z    IFEQ *BLANK
     C           @NEW      ANDEQ*BLANK
     C                     LEAVE
     C                     ENDIF
     C           OTKR,Z    IFEQ *BLANK
     C           @NEW      ANDEQ'1'
     C                     LEAVE
     C                     ENDIF
      *
     C           @HMCN3    IFEQ *BLANK
     C           @NEW      IFEQ *BLANK
     C           1         SUBSTNTKR,Z:2  @H      1
     C                     ELSE
     C           1         SUBSTOTKR,Z:2  @H      1
     C                     ENDIF
     C           @H        IFEQ 'H'
     C           @H        OREQ 'N'
TCHKAC           @H        OREQ 'D'
JW2  C           @H        OREQ '-'
JW2  C           @H        OREQ '+'
     C           @NEW      IFEQ *BLANK
     C           NMCN,Z    CAT  '/'       @HMCN3  4
     C                     ELSE
     C           OMCN,Z    CAT  '/'       @HMCN3  4
     C                     ENDIF
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      *
     C           @RMCN3    IFEQ *BLANK
     C           1         SUBSTNTKR,Z:2  @H      1
     C           @H        IFEQ 'T'
TCHKAC           @H        OREQ 'M'
     C           @H        OREQ 'L'
     C           @H        OREQ 'J'
TCHKBC           @H        OREQ 'K'
     C           @NEW      IFEQ *BLANK
     C           NMCN,Z    CAT  '/'       @RMCN3  4
     C                     ELSE
     C           OMCN,Z    CAT  '/'       @RMCN3  4
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
     C                     ENDIF
     C                     ENDIF
TCHK7 *
TCHK7C                     MOVE *BLANK    MRK3    1
TCHK7C           PRT,3     IFNE *BLANK
TCHK7C                     MOVE PRT,3     @PART
TCHK7 *
TCHK7C           K#AM      CHAINAAMPL11              26
TCHK7C           *IN26     IFEQ *OFF
TCHK7C           1         DO   15        Z       20
TCHK7C                     MOVE *BLANK    @NEW    1
TCHK7C           CHG,Z     IFNE *ZERO
TCHK7C                     Z-ADDCHG,W     @CHG
TCHK7C           @CHGDT    IFGT *DATE
TCHK7C                     MOVE '1'       @NEW
TCHK7C                     ENDIF
TCHK7C                     ENDIF
TCHK7C           NTKR,Z    IFEQ *BLANK
TCHK7C           @NEW      ANDEQ*BLANK
TCHK7C                     LEAVE
TCHK7C                     ENDIF
TCHK7C           OTKR,Z    IFEQ *BLANK
TCHK7C           @NEW      ANDEQ'1'
TCHK7C                     LEAVE
TCHK7C                     ENDIF
TCHK7 *
TCHK7C           @NEW      IFEQ *BLANK
TCHK7C           NDPT,Z    IFNE *ZERO
TCHK7C           NDPT,Z    ANDNE0111
TCHK7C                     MOVEL'$'       MRK3
TCHK7C                     LEAVE
TCHK7C                     END
TCHK7C                     ELSE
TCHK7C           ODPT,Z    IFNE *ZERO
TCHK7C           ODPT,Z    ANDNE0111
TCHK7C                     MOVEL'$'       MRK3
TCHK7C                     LEAVE
TCHK7C                     END
TCHK7C                     END
TCHK7 *
TCHK7C                     ENDDO
TCHK7C                     ENDIF
TCHK7C                     ENDIF
