      *
     C           *ENTRY    PLIST
     C                     PARM           PID     1
      *
     C                     MOVEADAT1      AY,1
      *
      * ------
      * HEADER
      * ------
     C                     Z-ADD1         X       30
     C           'FORECAST'SCAN DAT1      X              10
     C  N10      'Forecast'SCAN DAT1      X              10
     C  N10                GOTO @END
      *
      * ------
      * DETAIL
      * ------
      *
      * PART#
     C                     Z-ADD1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
      *
     C                     MOVEL*BLANK    MHN
     C                     Z-ADDX         Y
     C                     Z-ADD*ZERO     Z
      *
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C           AY,Y      IFEQ ','
     C           AY,Y      OREQ ' '
     C                     LEAVE
     C                     END
     C           AY,Y      IFEQ '-'
     C                     ITER
     C                     END
     C                     ADD  1         Z
     C                     MOVELAY,Y      MHN,Z
     C                     ENDDO
      *
     C                     MOVEAMHN       W@MHNX    P
      *
      * Quantity
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
      *
     C                     Z-ADDX         Y       30
     C                     Z-ADD*ZERO     Z       30
     C                     MOVEL*BLANK    A9
      *
     C                     DO   *HIVAL
     C                     ADD  1         Y
     C           AY,Y      IFEQ ','
     C           AY,Y      OREQ ' '
     C                     LEAVE
     C                     END
     C                     ADD  1         Z
     C                     MOVELAY,Y      A9,Z
     C                     ENDDO
      *
     C                     MOVEL*ZERO     A9X
     C                     Z-ADD9         Y
     C                     Z-ADD9         Z
     C                     DO   9
     C           A9,Y      IFNE *BLANK
     C                     MOVELA9,Y      A9X,Z
     C                     SUB  1         Z
     C                     END
     C                     SUB  1         Y
     C           Y         IFEQ *ZERO
     C                     LEAVE
     C                     END
     C                     ENDDO
      *
     C                     MOVEAA9X       @9C     9
     C                     MOVE @9C       @9      90
     C                     Z-ADD@9        W@SRYO  90
      *
      * DATE
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
     C  N10                GOTO @END
      *
     C                     Z-ADDX         Y
     C                     Z-ADD*ZERO     Z
     C                     MOVEL*ZERO     YMD
      * MM
     C                     ADD  1         Y
     C                     MOVEAAY,Y      DT2
     C           DT2,2     IFGE '0'
     C           DT2,2     ANDLE'9'
     C                     MOVEADT2       MM
     C                     ELSE
     C                     MOVE '00'      MM
     C                     MOVE DT2,1     MM
     C                     END
      * DD
     C           '/'       LOKUPAY,Y                     10
     C  N10                GOTO @END
     C                     ADD  1         Y
     C                     MOVEAAY,Y      DT2
     C           DT2,2     IFGE '0'
     C           DT2,2     ANDLE'9'
     C                     MOVEADT2       DD
     C                     ELSE
     C                     MOVE '00'      DD
     C                     MOVE DT2,1     DD
     C                     END
      * YY
     C           '/'       LOKUPAY,Y                     10
     C  N10                GOTO @END
     C                     ADD  1         Y
     C                     MOVEAAY,Y      YY2
     C                     MOVEL20        YY1
     C                     MOVELYMD       W@SHDT
      *
      * UPDATE
     C           KEY1      KLIST
     C                     KFLD           W@SHYM
     C                     KFLD           K@TOKU
     C                     KFLD           K@NONY
     C                     KFLD           K@NKOJ
     C                     KFLD           K@NUKE
     C                     KFLD           K@SEBN
     C                     KFLD           W@MHN1
     C                     KFLD           W@MHN2
     C                     KFLD           W@MHN3
     C                     KFLD           W@MHN4
      *
     C                     Z-ADD1431      K@TOKU  40
     C                     Z-ADD1431      K@NONY  40
     C                     MOVEL'0'       K@NKOJ  1
     C                     MOVEL'00  '    K@NUKE  4
     C                     MOVEL'0000'    K@SEBN  4
      *
     C           KEY1      CHAINABBPL601             61
      *
     C                     CLEARABBPL601
      *
     C                     Z-ADD*DATE     ABKOHZ
     C                     TIME           ABKOHS
     C                     MOVEL#USER     ABKOME
      *
     C                     CALL 'BBHR50'
     C                     PARM '1431'    P@TOKU  4
     C                     PARM '1431'    P@NONY  4
     C                     PARM '0'       P@NKOJ  1
     C                     PARM '00  '    P@NUKE  4
     C                     PARM W@MHNX    P@MHIN 20
     C                     PARM *BLANK    W@SHNX
     C                     PARM *BLANK    P@FLG   1
      *
     C                     Z-ADD1431      ABTOKU
     C                     Z-ADD1431      ABNONY
     C                     MOVEL'0'       ABNKOJ
     C                     MOVEL'00  '    ABNUKE
     C                     MOVEL'0000'    ABSEBN
     C                     MOVELW@MHN1    ABMHN1
     C                     MOVELW@MHN2    ABMHN2
     C                     MOVELW@MHN3    ABMHN3
     C                     MOVELW@MHN4    ABMHN4
     C                     MOVELW@SHN1    ABSHN1
     C                     MOVELW@SHN2    ABSHN2
     C                     MOVELW@SHN3    ABSHN3
     C                     MOVEL'B'       ABKUBN
     C                     Z-ADDW@SHYM    ABDATE
     C                     Z-ADDW@SRYO    ABGEKN
      *
     C                     Z-ADD0         W@RECD  30
     C           KEY3      KLIST
     C                     KFLD           W@SHYY
     C                     KFLD           W@SHMM
     C           KEY3      SETLLAGDPL121
     C                     DO   *HIVAL
     C           KEY3      READEAGDPL121                 70
     C           *IN70     IFEQ *ON
     C                     LEAVE
     C                     END
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         W@RECD
     C                     END
     C                     ENDDO
      *
     C           W@SRYO    DIV  W@RECD    W@NISU  90H
      *
     C           KEY3      SETLLAGDPL121
     C                     DO   *HIVAL
     C           KEY3      READEAGDPL121                 70
     C           *IN70     IFEQ *ON
     C                     LEAVE
     C                     END
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     Z-ADDF8KADD    B       30
     C                     Z-ADDW@NISU    HSU,B
     C                     END
     C                     ENDDO
      *
     C           *IN61     IFEQ *OFF
     C                     UPDATABBPL601
     C                     ELSE
     C                     WRITEABBPL601
     C                     END
      *
     C                     MOVE '1'       PID
      *
     C           @END      TAG
      ******************************************************
     C           *INZSR    BEGSR
      ******************************************************
      *
     C                     TIME           W@TIME
      *
     C                     ENDSR
