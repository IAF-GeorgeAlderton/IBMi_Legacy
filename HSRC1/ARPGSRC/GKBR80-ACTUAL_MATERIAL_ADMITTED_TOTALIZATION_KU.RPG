     F*** GKBR80 ****************************************
     F* ACTUAL MATERIAL ADMITTED TOTALIZATION KUMAMOTO FACTORY
     F* PROGRAM-ID. : GKBR80 <RPG>                      *
     F* CREATE DATE. : SEP.28.'1994.                    *
     F* AUTHOR.           : SHINICHIRO.OHTAKE           *
     F* USER SECTION. : KUMAMOTO FACTORY                *
     F**************************************** GKBR80 ***
     FGK#PL31 IF  E           K        DISK
     FGKBPL21 IF  E           K        DISK
     FGKBPR80 O   E             80     PRINTER                        UC
     E                    TBL1    1  10  4 0 TBL2   14   ﾃcﾆﾞｭcxb
     I            DS
     I                                        1   80X9SYHZ
     I                                        1   40X9SYYY
     I                                        5   60X9SYMM
     I                                        7   80X9SYDD
     C           *ENTRY    PLIST
     C                     PARM           PARM1   4        r]
     C                     PARM           PARM2   2        lg
     C                     PARM           PARM3   2        fnﾞcﾍﾞ
     C                     PARM           PARM4   4        ﾎﾞy]
     C                     PARM           PARM5   1        hﾎﾞ]
     C                     MOVE PARM1     @PARM1  40
     C                     MOVE PARM2     @PARM2  20
     C                     MOVE PARM3     @PARM3  20
     C                     MOVE PARM4     @PARM4  40
     C                     MOVE PARM5     @PARM5  1
     C*
     C           KEY1      KLIST
     C                     KFLD           X9BMON
     C                     KFLD           X9KUBN
     C                     KFLD           X9ZANM
     C                     KFLD           X9ZAIK
     C*
     C           *IN90     IFEQ '0'
     C                     TIME           @TIME
     C                     Z-ADD*DATE     @DATE
     C                     Z-ADD0         @PAGE
     C                     MOVE *BLANK    PSW     1
     C                     Z-ADD0         K1      40
     C                     MOVE *BLANK    K2     15
     C                     Z-ADD0         K3      52
     C                     MOVE *BLANK    K4      3
     C                     MOVEA'11'      *IN,70
     C                     MOVEL'1'       *IN80
     C                     MOVEL'1'       *IN90
     C                     MOVEL'1'       *IN69
     C                     END
     C*
     C                     SETOF                     50
     C           @PARM4    IFNE 9999
     C           @PARM4    SETLLGK#PL311
     C                     END
     C*
     C                     DO   *HIVAL
     C           @PARM4    IFNE 9999
     C           @PARM4    READEGK#PL311                 50
     C                     ELSE
     C                     READ GK#PL311                 50
     C                     END
     C*
     C           *IN,50    IFEQ '0'
     C           @PARM1    ANDEQX9SYYY
     C           @PARM2    ANDEQX9SYMM
     C           @PARM5    ANDEQX9KUBN
     C*
     C           X9SKJY    IFNE 'D'
      **************************************
      *      ライン合計を出力する        *
      *     1994.09.28     S.OHTAKE        *
      **************************************
     C           K4        IFNE X9RAIN
     C           K3        ORNE X9ZAIK
     C           K2        ORNE X9ZANM
     C           K1        ORNE X9BMON
     C           PSW       IFNE *BLANK
     C           *IN80     IFEQ '1'
     C                     ADD  1         @PAGE
     C                     WRITEGKBPR801
     C                     MOVEL'0'       *IN80
     C                     END
     C                     WRITEGKBPR806
     C                     SETON                     53
     C                     END
     C                     MOVEA'1'       *IN,69
     C                     Z-ADD0         SJRYO
     C                     Z-ADD0         SCOIL
     C                     Z-ADD0         S1COIL
     C                     MOVE *BLANK    K4
     C                     MOVELX9RAIN    K4
     C                     END
     C*
     C           K3        IFNE X9ZAIK
     C           K2        ORNE X9ZANM
     C           K1        ORNE X9BMON
     C           PSW       IFNE *BLANK
     C           *IN80     IFEQ '1'
     C                     ADD  1         @PAGE
     C                     WRITEGKBPR801
     C                     MOVEL'0'       *IN80
     C                     END
     C                     MOVEL'0'       *IN30
     C           KEY1      CHAINGKBPL211             30
     C           *IN30     IFEQ '1'
     C                     Z-ADD1000      X8JRYO
     C                     END
     C           WJRYO     DIV  @PARM3    XJRYO   60H
     C           XJRYO     DIV  X8JRYO    HJRYO     H
     C                     WRITEGKBPR803
     C                     SETON                     51
     C                     END
     C                     MOVEA'1'       *IN,70
     C                     Z-ADD0         HJRYO
     C                     Z-ADD0         WJRYO
     C                     Z-ADD0         K3
     C                     Z-ADDX9ZAIK    K3
     C                     END
     C*
     C           K2        IFNE X9ZANM
     C           K1        ORNE X9BMON
     C           PSW       IFNE *BLANK
     C           *IN80     IFEQ '1'
     C                     ADD  1         @PAGE
     C                     WRITEGKBPR801
     C                     MOVEL'0'       *IN80
     C                     END
     C                     WRITEGKBPR804
     C                     SETON                     52
     C                     END
     C                     MOVEA'1'       *IN,71
     C                     Z-ADD0         @JRYO
     C                     MOVE *BLANK    K2
     C                     MOVE X9ZANM    K2
     C                     END
     C*
     C           K1        IFNE X9BMON
     C           PSW       IFNE *BLANK
     C           *IN80     IFEQ '1'
     C                     ADD  1         @PAGE
     C                     WRITEGKBPR801
     C                     MOVEL'0'       *IN80
     C                     END
     C                     WRITEGKBPR805
     C                     END
     C                     Z-ADD0         $JRYO
     C                     MOVEA'11'      *IN,70
     C                     MOVEA'1'       *IN,69
     C           @PARM4    IFEQ 9999
     C                     MOVEL'1'       *IN80
     C                     END
     C                     MOVE *BLANK    @BMEI
     C                     Z-ADD1         A       10
     C                     MOVEL'0'       *IN30
     C           X9BMON    LOKUPTBL1,A                   30
     C   30                MOVELTBL2,A    @BMEI
     C                     Z-ADD0         K1
     C                     Z-ADDX9BMON    K1
     C                     END
     C*
     C           PSW       IFEQ *BLANK
     C                     OPEN GKBPR80
     C                     MOVEL'1'       *IN80
     C                     MOVEL'*'       PSW
     C                     END
     C*
     C           *IN80     IFEQ '1'
     C                     ADD  1         @PAGE
     C                     WRITEGKBPR801
     C                     MOVEL'0'       *IN80
     C                     END
     C*
     C                     ADD  X9COIL    SCOIL
     C                     ADD  X9CJRY    S1COIL
     C                     ADD  X9JRYO    SJRYO
     C                     ADD  X9JRYO    WJRYO
     C                     ADD  X9JRYO    @JRYO
     C                     ADD  X9JRYO    $JRYO
     C                     WRITEGKBPR802
     C                     SETOF                     515253
     C                     MOVEA'00'      *IN,70
     C                     MOVEA'0'       *IN,69
     C*
     C                     END
     C                     END
     C  N50                END
     C* END ﾆｭﾒ *
     C           PSW       IFNE *BLANK
     C           *IN80     IFEQ '1'
     C                     ADD  1         @PAGE
     C                     WRITEGKBPR801
     C                     END
     C  N53                WRITEGKBPR806
     C           *IN,51    IFEQ '0'
     C                     MOVEL'0'       *IN30
     C           KEY1      CHAINGKBPL211             30
     C           *IN30     IFEQ '1'
     C                     Z-ADD1000      X8JRYO
     C                     END
     C           WJRYO     DIV  @PARM3    XJRYO   60H
     C           XJRYO     DIV  X8JRYO    HJRYO     H
     C                     WRITEGKBPR803
     C                     END
     C  N52                WRITEGKBPR804
     C                     WRITEGKBPR805
     C                     END
     C*
     C                     SETON                     LR
     C                     RETRN
**  TBL1/TBL2 (FACTORY /NAME)
8990 HEAD OFFICE F
8982 GIFU FACTORY
8974 ENA FACTORY
9032 KANI F THE 1ST
9040 KANI F THE 2ND
9245 KANI F THE 3RD
9253 KANI F THE 4TH
9431 KUMAMOTO F
8907 SUPPLIER POINT
0111 IAF
