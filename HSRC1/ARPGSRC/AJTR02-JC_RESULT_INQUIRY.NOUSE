     FAJTPW02 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FAJTPL01 IF  E           K        DISK
     FAJTPL02 IF  E           K        DISK
     F            AJTPP011                          KRENAMEAJT02R
      *------------------------------------------------------------
     E                    LOT         5  8
     E                    CMD     1   2 78
     E                    ER      1   1 78
     I**************************************************************************
     I@INFDS      DS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I            DS
     I                                        1  40 LOT
     I                                        1   8 S@LOT1
     I                                        9  16 S@LOT2
     I                                       17  24 S@LOT3
     I                                       25  32 S@LOT4
     I                                       33  40 S@LOT5
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C           @@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------
     C           K#KEY     KLIST
     C                     KFLD           D@PRT1           INTERNAL PART
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C           K#KEY1    KLIST
     C                     KFLD           D@PRT1           INTERNAL PART
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C                     KFLD           D@LOT
     C           K#KEY2    KLIST
     C                     KFLD           D@PRT1           INTERNAL PART
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C                     KFLD           D@DATE
     C           K#KEY3    KLIST
     C                     KFLD           D@PRT1           INTERNAL PART
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C                     KFLD           K@TEHI  3
     C                     KFLD           K@PAGE  2
     C                     KFLD           K@DATE  80
     C                     KFLD           K@TIME  60
     C                     KFLD           K@KOME 10
     C           K#KEY4    KLIST
     C                     KFLD           D@PRT1           INTERNAL PART
     C                     KFLD           D@PRT2
     C                     KFLD           D@PRT3
     C                     KFLD           K@DATE  80
     C                     KFLD           K@TIME  60
     C                     KFLD           K@TEHI  3
     C                     KFLD           K@PAGE  2
     C                     KFLD           K@KOME 10
      *
     C                     MOVE '01'      @@ID    2
      *
     C                     ENDSR
     C**************************************************************************
     C*    1ST SCREEN
     C**************************************************************************
     C           #SCRN1    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
B02  C           *INKA     WHEQ '1'
     C                     MOVEL'99'      @@ID    2
      *
     C                     OTHER
     C                     EXSR #CHK1
     C*
B04  C           *IN99     IFEQ *OFF
     C                     EXSR #SET
     C           RRN1      IFGT *ZERO
     C                     MOVE '02'      @@ID
     C                     ELSE
     C                     MOVE ER,1      D@MSG
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSL
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK1
     C**************************************************************************
     C           #CHK1     BEGSR
     C*
     C                     EXSR #CLR
     C*
     C           K#KEY     CHAINAJTPL01              90
     C           *IN90     IFEQ *ON
     C                     MOVE ER,1      D@MSG
     C                     SETON                     9961
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*   CLEAR
     C**************************************************************************
     C           #CLR      BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *OFF      *IN99
      *
     C                     ENDSR
     C**************************************************************************
     C*  SET DATA
     C**************************************************************************
     C           #SET      BEGSR
     C*
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
     C                     MOVE *OFF      *IN80
     C           D@LOT     IFNE *BLANK
     C           K#KEY1    SETLLAJTPL01
     C                     ELSE
     C           K#KEY2    SETLLAJTPL02
     C                     ENDIF
      *
     C                     EXSR #SET1
     C*
     C                     ENDSR
     C**************************************************************************
     C*  SET DATA
     C**************************************************************************
     C           #SET1     BEGSR
     C*
     C                     Z-ADD*ZERO     @P      20
     C           *IN80     DOWEQ*OFF
     C           D@LOT     IFNE *BLANK
     C           K#KEY1    READEAJTPL01                  80
     C                     ELSE
     C           K#KEY     READEAJTPL02                  80
     C                     ENDIF
      *
     C           *IN80     IFEQ *OFF
     C           AJSKJY    ANDEQ*BLANK
     C                     CLEARSFL01
      *
     C                     MOVE AJTEHI    K@TEHI
     C                     MOVE AJPAGE    K@PAGE
     C                     MOVE AJKODT    K@DATE
     C                     MOVE AJKOTM    K@TIME
     C                     MOVE AJKOME    K@KOME
     C                     Z-ADD*ZERO     X       20
     C           K#KEY3    SETLLAJTPL01
     C           *IN81     DOUEQ*ON
     C           K#KEY3    READEAJTPL01                  81
     C           *IN81     IFEQ *OFF
     C           AJSKJY    ANDEQ*BLANK
     C                     ADD  1         X
     C                     MOVE AJLTNO    LOT,X
     C                     ENDIF
     C                     ENDDO
     C                     MOVE AJTEHI    S@LOT
     C                     MOVE AJPAGE    S@PAGE
     C                     Z-ADDAJKODT    S@DATE
     C                     Z-ADDAJKOTM    S@TIME
     C                     MOVELAJKOME    S@MCN
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C           D@LOT     IFNE *BLANK
     C           K#KEY3    SETGTAJTPL01
     C                     ELSE
     C           K#KEY4    SETGTAJTPL02
     C                     ENDIF
      *
     C                     ADD  1         @P
     C           @P        IFEQ 17
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C**************************************************************************
     C*   2ND SCREEN
     C**************************************************************************
     C           #SCRN2    BEGSR
     C*
