     H            Y.
     F** AJNR02 **********************************
     F* ON-TIME DELIVERY RATE CSV DATA D/L       *
     F*     SAKAKI.        2019.10.30            *
     F********************************************
     FAJNWP01 IF  E           K        DISK
     FAJNWP02 O   F     256            DISK
      *
     I            DS
     I                                        1  12 W1SHIN
     I                                        1   5 W1HIN1
     I                                        6  10 W1HIN2
     I                                       11  12 W1HIN3
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
      *********************************************
      * MAIN
      *********************************************
     C                     TIME           SDATE
      *
     C                     EXCPTOHED
      *
     C                     READ AJNWP01                  80
     C           *IN80     DOWEQ'0'
      *
     C                     MOVEL*BLANK    W2RGE  12
     C           W1RGE     IFEQ 9999
     C                     MOVEL'OTHERS'  W2RGE
     C                     ELSE
     C                     MOVELW1RGE     W2RGE
     C                     MOVE 'MINUTES' W2RGE
     C                     ENDIF
      ***
     C                     Z-ADDWDATE     W1DATE
     C                     Z-ADD1         W1BIN
      *  GET
     C                     CALL 'UTLR14A'
     C                     PARM           W1HIN1
     C                     PARM           W1HIN2
     C                     PARM           W1HIN3
     C                     PARM           W1DATE  80
     C                     PARM           W1BIN   20
     C                     PARM           W1LOCA  6
     C                     PARM           W1KIND  1
     C                     PARM           W1PRCN  3
     C                     PARM           W1PRCR  3
     C                     PARM           W1MCNN  3
     C                     PARM           W1MCNR  3
     C                     PARM           W1DPTN  40
     C                     PARM           W1DPTR  40
     C                     PARM           W1PLOC  6
     C                     PARM           W1PKIN  1
     C                     PARM           W1PPRC  3
     C                     PARM           W1PMCN  3
     C                     PARM           W1PDPT  40
     C                     PARM           W1RTN   1
      *
     C                     MOVEL*BLANK    W1MCN1
     C                     MOVEL*BLANK    W1MCN2
      *
     C           W1RTN     IFEQ ' '
     C                     SELEC
     C           W1DATA    WHEQ '1'
     C           W1DATA    OREQ '2'
     C           W1DATA    OREQ '3'
     C           W1DATA    OREQ '4'
     C                     MOVELW1MCNR    W1MCN1 10
     C           W1DATA    WHEQ '6'
     C                     MOVELW1MCNR    W1MCN1
     C                     ENDSL
     C                     ENDIF
      *
     C           W1DATA    IFEQ '5'
     C           W1DATA    OREQ '6'
     C                     CALL 'UTLR57'
     C                     PARM           W1SHIN
     C                     PARM           W1SRTN 20
     C                     PARM           W1SRT# 20
     C                     PARM           W1RTN   1
     C*
     C                     MOVEL*BLANK    W1L     5
     C                     MOVEL*BLANK    W1R     5
     C           W1RTN     IFEQ ' '
     C           W1DATA    IFEQ '5'
     C                     MOVELW1SRTN    W1L
     C                     MOVELW1L       W1MCN1
     C                     MOVELW1SRT#    W1R
     C                     MOVE W1R       W1MCN1
     C                     ELSE
     C                     MOVEL*BLANK    W1MCN2 10
     C                     MOVELW1SRTN    W1L
     C                     MOVELW1L       W1MCN2
     C                     MOVELW1SRT#    W1R
     C                     MOVE W1R       W1MCN2
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
      *
     C                     EXCPTODAT
     C                     READ AJNWP01                  80
     C                     ENDDO
      *
      *
     C                     SETON                     LR
     C                     RETRN
      ******************************************************
     OAJNWP02 E                OHED
     O                                      'TYPE,'
     O                                      'FIRST MACHINE #,'
     O                                      'LAST  MACHINE #,'
     O                                      'PART #,'
     O                                      'ABSO #,'
     O                                      'LOT #,'
     O                                      'PAGE #,'
     O                                      '# OF BOX,'
     O                                      'FROM DATE,'
     O                                      'FROM TIME,'
     O                                      'TO DATE,'
     O                                      'TO TIME,'
     O                                      'DIFFERENCE(MINUTE),'
     O                                      'RANGE'
     O                                      ','
      *
     OAJNWP02 E                ODAT
      *
     O                         W1DATA
     O                                      ','
     O                         W1MCN1
     O                                      ','
     O                         W1MCN2
     O                                      ',="'
     O                         W1HIN1
     O                                      '-'
     O                         W1HIN2
     O                                      '-'
     O                         W1HIN3
     O                                      '",="'
     O                         W1ZENO
     O                                      '",="'
     O                         W1THNO
     O                                      '",="'
     O                         W1PAGE
     O                                      '",'
     O                         W1BOX
     O                                      ','
     O                         W1DAT1
     O                                      ','
     O                         W1TIM1       '0  :  :  '
     O                                      ','
     O                         W1DAT2
     O                                      ','
     O                         W1TIM2       '0  :  :  '
     O                                      ','
     O                         W1TDF
     O                                      ','
     O                         W2RGE
     O                                      ','
