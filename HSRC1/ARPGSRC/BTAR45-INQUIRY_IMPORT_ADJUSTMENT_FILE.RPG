     C                     MOVEL*OFF      *IN42
     C                     Z-ADD*ZERO     RRN1    40
     C*
     C                     MOVEL*ON       *IN43
     C                     MOVEL*ON       N#MODE
     C*
     C           *LOVAL    SETLLBTAPP41
     C*
     C                     DO   *HIVAL
     C*
     C                     READ BTAPP41                  94
     C   94                LEAVE
     C           B4SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C* CREATE SUB-FILE
     C                     CLEARSFL010
     C*
     C                     MOVEL*BLANK    W@SHIN
     C                     MOVELB4SHN1    W@SHN1
     C           B4SHN2    IFNE *BLANK
     C                     MOVEL'-'       W@SHNA
     C                     END
     C                     MOVELB4SHN2    W@SHN2
     C           B4SHN3    IFNE *BLANK
     C                     MOVEL'-'       W@SHNB
     C                     END
     C                     MOVELB4SHN3    W@SHN3
     C                     MOVELW@SHIN    S1SHIN
     C*
     C                     Z-ADDB4MAIS    S1MAIS
TCHK1C                     Z-ADDB4KODT    S1UPDT
     C*
     C                     ADD  1         RRN1
