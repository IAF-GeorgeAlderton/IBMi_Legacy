     C******************************************************
     C*  FMT010
     C******************************************************
     C           @F1RTN    BEGSR
     C*
     C                     EXSR @F1SET
     C                     Z-ADD1         W#RNP1  40
     C*
     C                     DO   *HIVAL
     C*
     C                     WRITEFMT099
     C                     Z-ADDW#RNP1    #RCN01
     C                     EXFMTCTL010
     C   KA                LEAVE
     C*
     C* NKJ                MOVELN#MODE    *IN43
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP1
     C                     END
     C*
     C                     ENDDO
