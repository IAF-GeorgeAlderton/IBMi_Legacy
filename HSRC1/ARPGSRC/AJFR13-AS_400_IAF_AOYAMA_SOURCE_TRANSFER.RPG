     C                     SETOF                     50
     C                     Z-ADD1         A       20
      *
     C           WKUBN     IFEQ 'N'
     C           WO6       LOKUPTBC,A                    50
     C                     ELSE
     C           WO4       LOKUPTB1,A                    50
     C                     END
      *
 S1  C           *IN50     IFEQ '1'
      *
     C           WKUBN     IFEQ 'N'
     C                     MOVELTBD,A     WSRC
     C                     ELSE
     C           TB1,A     IFEQ 'S'
     C                     MOVELTB2,A     WSRC    7
     C                     ELSE
     C**                   MOVELWO1       WSRC
JW1  C                     MOVEL'A'       WSRC
     C                     MOVE TB2,A     WSRC
     C                     END
     C                     END
      *
 E1  C                     END
      *
X0   C                     ELSE
      *
     C                     MOVEL'N'       WKUBN   1
     C                     SETOF                     88
     C           WO45      LOKUPTB3                      88
     C           *IN88     IFEQ '1'
     C                     MOVEL'O'       WKUBN   1
     C                     END
      *
     C                     SETOF                     50
     C                     Z-ADD1         A
      *
     C           WKUBN     IFEQ 'N'
      *
     C           WO6       LOKUPTBA,A                    50
     C           *IN50     IFEQ '1'
     C                     MOVELTBB,A     WSRC
     C                     END
      *
     C                     ELSE
      *
     C           WO45      LOKUPTB3,A                    50
     C           *IN50     IFEQ '1'
     C**                   MOVELWO1       WSRC
JW1  C                     MOVEL'A'       WSRC
     C                     MOVE TB4,A     WSRC
     C                     END
      *
     C                     END
      *
R0   C                     END
