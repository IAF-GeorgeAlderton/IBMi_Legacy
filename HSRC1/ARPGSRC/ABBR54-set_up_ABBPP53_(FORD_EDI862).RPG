     H            Y.
     F** ABBR54  ************************************************
     F*  SET UP ABBPP53 (FORD EDI862)                           *
     F*  JW     2024.11.04                                      *
     F*=================================                        *
     F*  CALLING SEQ.                                           *
     F*                    CALL 'ABBR54'                        *
     F*                    PARM           $RCVDT  8             *
     F*   IN  $RCVDT  8A EDI862 RECEIVED DATE (YYYYMMDD)        *
     F***********************************************************
     FAB#PLF1EIF  E           K        DISK
     FABBPL53BIF  E           K        DISK
     F            ABBPP531                          KRENAMEABBPP53B
     FABBPP53 O   E                    DISK
      ****************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ****************************************************
      * MAIN ROUTINE
      ****************************************************
     C                     EXSR #INIT
      *
     C           @RCVDT    SETLLAB#PLF1E
     C                     DO   *HIVAL
     C           @RCVDT    READEAB#PLF1E                 98
     C   98                LEAVE
      * IGNORE
     C           F5QTY     IFEQ 0
     C                     ITER
     C                     ENDIF
      * CHECK
     C                     EXSR #CHK1
      *
     C           *IN85     IFEQ *ON
     C                     EXSR #OUT1
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------------*
      *  CHECK EXIST DATA                                  *
      *----------------------------------------------------*
     C           #CHK1     BEGSR
      *
     C                     Z-ADDF5NONY    K#NONY
     C                     MOVELF5MHN1    K#MHN1
     C                     MOVELF5MHN2    K#MHN2
     C                     MOVELF5MHN3    K#MHN3
     C                     MOVELF5MHN4    K#MHN4
     C                     MOVELF5NUKE    K#NUKE
     C                     Z-ADDF5CRDT    K#RCDT
     C                     Z-ADDF5NOHZ    K#SDAT
     C           K#        SETLLABBPL53B
     C                     DO   *HIVAL
     C           K#        READEABBPL53B                 85
     C   85                LEAVE
      *
     C           BBSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE *OFF      *IN85
     C                     LEAVE
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  OUTPUT ABBPP53                                    *
      *----------------------------------------------------*
     C           #OUT1     BEGSR
      *
     C                     CLEARABBPP531
     C                     Z-ADDF5CRDT    BBRCDT
     C                     Z-ADDF5TOKU    BBTOKU
     C                     Z-ADDF5NONY    BBNONY
     C                     MOVELF5NUKE    BBNUKE
      *                                   BBSEBN
     C                     MOVELF5MHN1    BBMHN1
     C                     MOVELF5MHN2    BBMHN2
     C                     MOVELF5MHN3    BBMHN3
     C                     MOVELF5MHN4    BBMHN4
      *                                   BBSHN1           BBIPAR
     C                     Z-ADDF5NOHZ    BBSDAT
     C                     Z-ADDF5QTY     BBSQTY
     C                     MOVE 'E'       BBEDIK
      *                                   BBBFLG
     C                     MOVELF5STID    BBPLNT
     C                     MOVELF5NUKE    BBDOCK
     C                     MOVELF5STFC    BBICCD
      * ADD
     C                     Z-ADDF5QTY2    BBQTY2
     C                     Z-ADDF5YSQY    BBYSQY
     C                     Z-ADDF5LSDT    BBLSDT
     C                     Z-ADDF5LSQY    BBLSQY
     C                     MOVELF5TSID    BBTSID
     C                     MOVELF5PART    BBPART
     C                     MOVELF5ODRN    BBODRN
     C                     MOVELF5INVN    BBINVN
     C                     MOVELF5TPCD    BBTPCD
     C                     MOVELF5SPCD    BBSPCD
     C                     MOVELF5REF#    BBREF#
     C                     MOVELF5POR#    BBPOR#
     C                     Z-ADDF5SIDT    BBSIDT
     C                     Z-ADDF5HSDT    BBHSDT
     C                     Z-ADDF5HEDT    BBHEDT
     C                     MOVELF5STIQ    BBSTIQ
     C                     MOVELF5IDCD    BBIDCD
     C                     MOVELF5ALFL    BBALFL
     C                     MOVELF5RALF    BBRALF
     C                     MOVELF5UBM1    BBUBM1
     C                     MOVELF5IPAR    BBIPAR
     C                     MOVELF5PONO    BBPONO
      *
     C                     Z-ADDTODAY     BBCRHZ
     C                     Z-ADDNOW       BBCRTM
     C                     MOVEL#USER     BBCRUS
     C                     MOVEL#PGM      BBCRPG
      *
     C                     WRITEABBPP531
      *
     C                     ENDSR
      *--------------------------------------------------
      * INITIALIZE
      *--------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RCVDT  8        RECEIVED DATE
      *
     C           K#        KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#MHN1  5
     C                     KFLD           K#MHN2  5
     C                     KFLD           K#MHN3  5
     C                     KFLD           K#MHN4  5
     C                     KFLD           K#NUKE  4
     C                     KFLD           K#RCDT  80
     C                     KFLD           K#SDAT  80
      *
     C                     TIME           SDATE
     C           $RCVDT    IFEQ *BLANK
     C           $RCVDT    OREQ *ZERO
     C                     Z-ADDTODAY     @RCVDT  80
     C                     ELSE
     C                     MOVEL$RCVDT    @RCVDT
     C                     ENDIF
      *
     C                     ENDSR
