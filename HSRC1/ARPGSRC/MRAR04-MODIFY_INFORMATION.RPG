     C           M1STDT    IFGT D1STD2
     C                     GOTO ESB400
     C                     ENDIF
     C                     ENDIF
      *
     C           D1SYKI    IFNE *BLANK
     C           D1SYKI    IFNE M1SYKI
     C                     GOTO ESB400
     C                     ENDIF
     C                     ENDIF
      *
     C           D1CRAT    IFNE *BLANK
     C           D1CRAT    IFNE M1CRAT
     C                     GOTO ESB400
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVEL'1'       GET
