     C           KEYMA1    REDPEMRAPL111                 80
     C                     ENDDO
      * P1TYPE = '1':MODIFY
      * P1TYPE = '2':QUERY
      * P1TYPE = '3':TRANSMIT TO ASJ
     C           P1TYPE    IFEQ '1'
     C           WKSTAT    IFEQ '01'
     C           WKSTAT    OREQ '03'
     C                     ELSE
     C                     GOTO ESB400
     C                     ENDIF
     C                     ENDIF
      *
     C           P1TYPE    IFEQ '3'
     C           WKSTAT    IFEQ '01'
     C           WKSTAT    OREQ '03'
     C                     ELSE
     C                     GOTO ESB400
     C                     ENDIF
     C                     ENDIF
      *
     C           D1KEN     IFNE *BLANK
     C           D1KEN     IFNE M1KEN
     C                     GOTO ESB400
     C                     ENDIF
     C                     ENDIF
      *
     C           D1SHN     IFNE *BLANK
     C           D1SHN     IFNE M1SHN
     C                     GOTO ESB400
     C                     ENDIF
