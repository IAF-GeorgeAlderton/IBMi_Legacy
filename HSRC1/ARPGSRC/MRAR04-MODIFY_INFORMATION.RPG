     C           *IN80     DOWEQ'0'
     C           GET11     ANDEQ'0'
     C           MASKJY    IFEQ 'D'
     C           MASKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'1'       GET11
     C                     MOVELMASTAT    WKSTAT
     C                     Z-ADDMASNDT    WKSNDT
