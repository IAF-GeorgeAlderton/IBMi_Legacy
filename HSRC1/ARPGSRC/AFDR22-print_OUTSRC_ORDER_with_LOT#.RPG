     H            Y.                                    1
     H** AFDR22 ********************************************
     H*  PRINT OUTSRC ORDER WITH LOT#                      *
     H*  JW   2018.08.14                                   *
     H******************************************************
     FAFDPL20 IF  E           K        DISK
     FAFDPL16 IF  E           K        DISK
     FAFDWP22 O   E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *-----------------------------------------------------
     E                    LOT         8  8
     I            DS
     I                                        1  64 AWLOT
     I                                        1   8 AWLOT1
     I                                        9  16 AWLOT2
     I                                       17  24 AWLOT3
     I                                       25  32 AWLOT4
     I                                       33  40 AWLOT5
     I                                       41  48 AWLOT6
     I                                       49  56 AWLOT7
     I                                       57  64 AWLOT8
     I            DS
     I                                        1   80#ODYMD
     I                                        1   40#ODYY
     I                                        5   60#ODMM
     I                                        7   80#ODDD
     I            DS
     I                                        1   80AFODHZ
     I                                        1   40AFODYY
     I                                        5   60AFODMM
     I                                        7   80AFODDD
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------------
      *  MAIN ROUTINE
     C*-----------------------------------------------------
     C                     EXSR #INIT
      *
     C           K#20      SETLLAFDPL20
     C                     DO   *HIVAL
     C                     READ AFDPL20                  91
     C   91                LEAVE
      * END?
     C           AFSUPP    IFNE #SUPP
     C                     LEAVE
     C                     ENDIF
      *
     C           AFSKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C           AFZETI    IFNE $ZETI
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #LOT
      *
     C                     EXSR #PRINT
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C*-----------------------------------------------------
     C*  SET LOT
     C*-----------------------------------------------------
     C           #LOT      BEGSR
      *
     C                     MOVEA*BLANK    LOT
     C                     Z-ADD0         IX      20
     C                     Z-ADDAFODYY    #ODY1
     C                     Z-ADDAFODMM    #ODM1
     C                     Z-ADDAFODDD    #ODD1
     C                     Z-ADDAFODNO    #ODR1
     C                     MOVELAFBINN    #BIN1
      *
     C           K#16      SETLLAFDPL16
     C                     DO   *HIVAL
     C           K#16      READEAFDPL16                  92
     C   92                LEAVE
      *
      *
     C           A5SKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C           A5ZETI    IFNE $ZETI
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELA5LTNO    LTR7    7
     C           LTR7      IFNE *BLANK
     C                     ADD  1         IX
     C                     MOVELLTR7      LOT,IX
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*-----------------------------------------------------
     C*  PRINT
     C*-----------------------------------------------------
     C           #PRINT    BEGSR
      * PRINT HEADER
     C           LIN#      IFGE 64
     C                     EXCPT@HDR1
     C                     Z-ADD4         LIN#
     C                     ENDIF
      * PRINT DETAIL
     C                     EXCPT@DTL1
     C                     ADD  1         LIN#
      * OUTPUT DATA
     C                     CLEARAFDWP221
     C                     Z-ADDAFODHZ    AWODHZ
     C                     MOVELAFBINN    AWBINN
     C                     MOVELAFPAR1    AWSHN1
     C                     MOVELAFPAR2    AWSHN2
     C                     MOVELAFPAR3    AWSHN3
     C                     Z-ADDAFHAKO    AWHAKO
     C                     MOVELAFSUPP    AWSUPP
     C                     Z-ADDAFODNO    AWODNO
     C                     MOVEALOT       AWLOT
     C                     WRITEAFDWP221
      *
     C                     ENDSR
     C*-----------------------------------------------------
     C* INITIAL SET
     C*-----------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SUPP   4
     C                     PARM           $DATE   8
     C                     PARM           $ZETI   4
      *
     C           K#20      KLIST
     C                     KFLD           #SUPP   4
     C                     KFLD           #ODYY   40
     C                     KFLD           #ODMM   20
     C                     KFLD           #ODDD   20
      *
     C           K#16      KLIST
     C                     KFLD           #SUPP   4
     C                     KFLD           #ODY1   40
     C                     KFLD           #ODM1   20
     C                     KFLD           #ODD1   20
     C                     KFLD           #ODR1   60
     C                     KFLD           #BIN1   3
      *
     C                     TIME           WSDT
     C                     MOVEL$SUPP     #SUPP
     C                     MOVEL$DATE     #ODYMD
     C                     Z-ADD80        LIN#    30
      *
     C                     ENDSR
      *-----------------------------------------------------
     OQPRINT  E   01           @HDR1
     O                         #PGM       9
     O                                   45 '** OUTSRC ORDER WITH'
     O                                   65 ' LOCATUON **        '
     O                                   99 'DATE'
     O                         TODAY    102 '    .  .  '
     O                         NOW      112 '  :  :  '
     O                                  115 'P.'
     O                         PAGE  Z  119
     O        E   03           @HDR1
     O                                    9 'ORD_DATE'
     O                                   14 'BIN#'
     O                                   21 'PART1'
     O                                   28 'PART2'
     O                                   32 'P3'
     O                                   37 'BOX'
     O                                   43 'SUPP'
     O                                   51 'ORDER#'
     O                                   57 'LOT1'
     O                                   66 'LOT2'
     O                                   75 'LOT3'
     O                                   84 'LOT4'
     O                                   93 'LOT5'
     O                                  102 'LOT6'
     O                                  111 'LOT7'
     O                                  120 'LOT8'
     O        E 1              @DTL1
     O                         AFODHZ  + 01
     O                         AFBINN  + 02
     O                         AFPAR1  + 02
     O                         AFPAR2  + 02
     O                         AFPAR3  + 02
     O                         AFHAKO  + 02
     O                         AFSUPP  + 02
     O                         AFODNO  + 02
     O                         LOT,1   + 02
     O                         LOT,2   + 02
     O                         LOT,3   + 02
     O                         LOT,4   + 02
     O                         LOT,5   + 02
     O                         LOT,6   + 02
     O                         LOT,7   + 02
     O                         LOT,8   + 02
      *-----------------------------------------------------
