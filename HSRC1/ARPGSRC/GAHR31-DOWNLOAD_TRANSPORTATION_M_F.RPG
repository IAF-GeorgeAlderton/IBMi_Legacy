     H            Y.
      ** GAHR31 *******************************************************
      *  DOWNLOAD OF TRANSPORTATION M/F
      *  KIRI                                            2017.06.28
      *****************************************************************
      * TRANSPORTATION M/F
     FGAHPL30 IF  E           K        DISK
      *
      * CARRIER M/F  LF1
     FGAHPL35 IF  E           K        DISK
      * ROUTE M/F  LF1
     FGAHPL37 IF  E           K        DISK
      *
     FGAHWP31 O   F     512            DISK
      *===============================================================
      *===============================================================
     I****************************
      *プログラム状況データ構造*
     I****************************
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *===============================================================
      *===============================================================
     C                     MOVEA*ALL'0'   *IN
     C                     TIME           @TIME
     C                     EXCPT$HED
      *----------------------*
     C                     DO   *HIVAL
     C                     READ GAHPL30                  90
     C   90                LEAVE
     C           G3SKJY    IFEQ 'D'
     C           G3SKHZ    ANDLE@SYSHZ
     C                     ITER
     C                     ENDIF
     C** FREQUENCY
     C                     MOVEL*BLANK    W3FREQ  6                     1
     C           G3FREQ    IFEQ '1'
     C                     MOVEL'DAILY'   W3FREQ                        1
     C                     ENDIF
     C           G3FREQ    IFEQ '2'
     C                     MOVEL'OTHER'   W3FREQ                        1
     C                     ENDIF
     C**       **
     C* CARRIER M/F                                *
     C           G3CARR    CHAINGAHPL35              91
     C  N91      G5SKJY    IFEQ 'D'
     C           G5SKHZ    ANDLE@SYSHZ
     C                     SETON                     91
     C                     ENDIF
     C   91                MOVE *BLANK    G5CRN1           CARRIER NAME 1
     C   91                MOVE *BLANK    G5CRN2           CARRIER NAME 2
     C   91                MOVE *BLANK    G5CRN3           CARRIER NAME 3
     C* ROUTE M/F                                  *
     C           G3ROUT    CHAINGAHPL37              91
     C  N91      G7SKJY    IFEQ 'D'
     C           G7SKHZ    ANDLE@SYSHZ
     C                     SETON                     91
     C                     ENDIF
     C   91                MOVE *BLANK    G7RTN1           ROUTE NAME 1
     C   91                MOVE *BLANK    G7RTN2           ROUTE NAME 1
     C   91                MOVE *BLANK    G7RTN3           ROUTE NAME 1
     C**       **
     C                     EXCPT$DATA
     C**
     C                     ENDDO
      *----------------------*
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      *===============================================================
      *================================================================
     OGAHWP31 E                $HED
     O                                      'UPDATE DATE,'
     O                                      'UPDATE TIME,'
     O                                      'UPDATE PERSON,'
     O                                      'CARRIER,'
     O                                      'ROUTE,'
     O                                      'BIN #,'
     O                                      'FREQUENCY OF '
     O                                      'SHIPMENT,'
     O                                      'OLD SHIPMENT START '
     O                                      'TIME,'
     O                                      'NEW SHIPMENT START '
     O                                      'TIME,'
     O                                      'CHANGE OVER DATE,'
     O                                      'CARRIER NAME,'
     O                                      'ROUTE NAME'
      *************************
     O        E                $DATA
     O                         G3KOHZ
     O                                      ','
     O                         G3KOTM       '0 :  :  '
     O                                      ','
     O                         G3KONM
     O                                      ',="'
     O                         G3CARR
     O                                      '",="'
     O                         G3ROUT
     O                                      '",'
     O                         G3BIN#
     O                                      ','
     O                         W3FREQ
     O                                      ','
     O                                      '"'
     O                         G3OSTM       '0  :  '
     O                                      '","'
     O                         G3NSTM       '0  :  '
     O                                      '",'
     O                         G3CHDT
     O                                      ',"'
     O                         G5CRN1
     O                         G5CRN2
     O                         G5CRN3
     O                                      '","'
     O                         G7RTN1
     O                         G7RTN2
     O                         G7RTN3
     O                                      '"'
      *================================================================
