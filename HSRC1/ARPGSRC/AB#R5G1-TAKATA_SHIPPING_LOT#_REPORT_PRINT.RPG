     H            Y.
      ** AB#R5G1 *******************************************
      *  SHIPPING LOT# REPORT PRINT                        *
      *                                                    *
TCHK1 * TCHK1  02/04/06 CREATE                             *
      ******************************************************
     FAB#PL7B IF  E           K        DISK
     FAB#PL1A IF  E           K        DISK
     FEDIPL40 IF  E           K        DISK
     FQPRINT  O   F      80     OF     PRINTER
      *--------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I            DS
     I                                        1  140W@TIME
     I                                        1   20W@TH
     I                                        3   40W@TM
     I                                        5   60W@TS
     I                                        7  100W@DY
     I                                       11  120W@DM
     I                                       13  140W@DD
     I            DS
     I                                        1   80W@NOHZ
     I                                        1   40W@NOYY
     I                                        5   60W@NOMM
     I                                        7   80W@NODD
     I            DS
     I                                        1  30 O@KEY
     I                                        1  10 O@ODRN
     I                                       11  15 O@MHN1
     I                                       16  20 O@MHN2
     I                                       21  25 O@MHN3
     I                                       26  30 O@MHN4
     I            DS
     I                                        1  30 N@KEY
     I                                        1  10 EKODRN
     I                                       11  15 EKMHN1
     I                                       16  20 EKMHN2
     I                                       21  25 EKMHN3
     I                                       26  30 EKMHN4
     I            DS
     I                                        1   7 W@BOXS
     I                                        1   1 W@BOX1
     I                                        2   2 W@BOX2
     I                                        3   3 W@BOX3
     I                                        4   4 W@BOX4
     I                                        5   5 W@BOX5
     I                                        6   6 W@BOX6
     I                                        7   7 W@BOX7
     C******************************************************
     C* MAIN                                               *
     C******************************************************
     C                     MOVEL*BLANK    O@KEY
     C                     MOVEL*OFF      *IN81
     C           K#PP7B    KLIST
     C                     KFLD           PMSIRE
     C                     KFLD           PMSIRK
     C                     KFLD           PMDOCK
     C                     KFLD           W@NOYY
     C                     KFLD           W@NOMM
     C                     KFLD           W@NODD
     C                     KFLD           W@NOBI
     C           K#PP7B    SETLLAB#PL7B
     C*
     C                     DO   *HIVAL
     C*
     C           K#PP7B    READEAB#PL7B                  91
     C   91                LEAVE
     C*
     C           N@KEY     IFNE O@KEY
     C                     MOVELEKODRN    PRODRN
     C                     MOVELEKMHN1    PRMHN1
     C                     MOVELEKMHN2    PRMHN2
     C                     MOVELEKMHN3    PRMHN3
     C           EKMHN2    IFNE *BLANK
     C                     MOVEL'-'       PRMHP1
     C                     END
     C           EKMHN3    IFNE *BLANK
     C                     MOVEL'-'       PRMHP2
     C                     END
     C                     MOVEL*BLANK    W@BOXS
     C                     EXSR @GETBX
     C                     MOVELW@BOXS    PRBOXS
     C                     END
     C*
     C                     MOVELEKLTNO    PRLOT1
     C                     MOVEL'-'       PRLOT2
     C                     MOVELEKISNO    PRLOT3
     C                     MOVELEKSERL    PRSERL
     C*
     C           *IN81     IFEQ *OFF
     C           *INOF     OREQ *ON
     C  N81                MOVEL*ON       *IN81
     C                     EXCPT@HED
     C           N@KEY     IFEQ O@KEY
     C                     MOVELEKODRN    PRODRN
     C                     MOVELEKMHN1    PRMHN1
     C                     MOVELEKMHN2    PRMHN2
     C                     MOVELEKMHN3    PRMHN3
     C           EKMHN2    IFNE *BLANK
     C                     MOVEL'-'       PRMHP1
     C                     END
     C           EKMHN3    IFNE *BLANK
     C                     MOVEL'-'       PRMHP2
     C                     END
     C                     MOVELW@BOXS    PRBOXS
     C                     END
     C                     ELSE
     C           N@KEY     IFNE O@KEY
     C                     EXCPT@SPACE
     C                     END
     C                     END
     C                     EXCPT@DTL
     C*
     C                     MOVEL*BLANK    PRODRN
     C                     MOVEL*BLANK    PRMHN1
     C                     MOVEL*BLANK    PRMHN2
     C                     MOVEL*BLANK    PRMHN3
     C                     MOVEL*BLANK    PRBOXS
     C                     MOVEL*BLANK    PRMHP1
     C                     MOVEL*BLANK    PRMHP2
     C*
     C                     MOVELN@KEY     O@KEY
     C*
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *
     C******************************************************
     C* INITIALIZE                                         *
     C******************************************************
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           PMSIRE  4
     C                     PARM           PMSIRK  1
     C                     PARM           PMDOCK  4
     C                     PARM           PMNOHZ  80
     C                     PARM           PMNOBI  20
     C                     Z-ADDPMNOHZ    W@NOHZ
     C                     MOVELPMNOBI    W@NOBI  2
     C                     MOVELPMSIRE    W@SIRE  40
     C*
     C                     TIME           W@TIME
     C                     MOVEL*ALL'-'   @@LIN  80
     C*
     C           *LIKE     DEFN EKODRN    PRODRN
     C           *LIKE     DEFN EKMHN1    PRMHN1
     C           *LIKE     DEFN EKMHN2    PRMHN2
     C           *LIKE     DEFN EKMHN3    PRMHN3
     C           *LIKE     DEFN EKLTNO    PRLOT1
     C           *LIKE     DEFN EKISNO    PRLOT3
     C           *LIKE     DEFN EKSERL    PRSERL
     C*
     C                     MOVEL*BLANK    PRODRN
     C                     MOVEL*BLANK    PRMHN1
     C                     MOVEL*BLANK    PRMHN2
     C                     MOVEL*BLANK    PRMHN3
     C                     MOVEL*BLANK    PRLOT1
     C                     MOVEL*BLANK    PRLOT3
     C                     MOVEL*BLANK    PRSERL
     C                     MOVEL*BLANK    PRBOXS  7
     C                     MOVEL*BLANK    PRMHP1  1
     C                     MOVEL*BLANK    PRMHP2  1
     C                     MOVEL*BLANK    PRLOT2  1
     C*
     C           PMSIRE    CHAINEDIPL40              93
     C   93                MOVEL*BLANK    W@DLNM 40
     C  N93                MOVELE4ADD1    W@DLNM
     C*
     C                     ENDSR
     C******************************************************
     C* GET # OF BOXS                                      *
     C******************************************************
     C           @GETBX    BEGSR
     C*
     C                     Z-ADD*ZERO     W@SYOS  90
     C*
     C           K#PL1A    KLIST
     C                     KFLD           W@NOHZ
     C                     KFLD           PMNOBI
     C                     KFLD           W@SIRE
     C                     KFLD           PMSIRK
     C                     KFLD           PMDOCK
     C                     KFLD           EKODRN
     C           K#PL1A    SETLLAB#PL1A
     C*
     C                     DO   *HIVAL
     C           K#PL1A    READEAB#PL1A                  92
     C   92                LEAVE
     C           BASKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           BAMHN1    IFEQ EKMHN1
     C           BAMHN2    ANDEQEKMHN2
     C           BAMHN3    ANDEQEKMHN3
     C           BAMHN4    ANDEQEKMHN4
     C                     LEAVE
     C                     END
     C                     ENDDO
     C*
     C           *IN92     IFEQ *OFF
     C           BAUSYS    IFEQ *ZERO
     C           BASYOS    IFEQ *ZERO
     C                     Z-ADDBASRYO    W@SYOS
     C                     ELSE
     C                     Z-ADDBASYOS    W@SYOS
     C                     END
     C                     ELSE
     C                     Z-ADDBAUSYS    W@SYOS
     C                     END
     C           W@SYOS    IFNE *ZERO
     C           BASRYO    DIV  W@SYOS    W@ANS   70
     C                     MVR            W@MVR   70
     C           W@MVR     IFNE *ZERO
     C                     ADD  1         W@ANS
     C                     END
     C                     MOVELW@ANS     W@BOXS
     C                     END
     C                     DO
     C           W@BOX1    IFNE *ZERO
     C                     LEAVE
     C                     END
     C                     MOVEL*BLANK    W@BOX1
     C           W@BOX2    IFNE *ZERO
     C                     LEAVE
     C                     END
     C                     MOVEL*BLANK    W@BOX2
     C           W@BOX3    IFNE *ZERO
     C                     LEAVE
     C                     END
     C                     MOVEL*BLANK    W@BOX3
     C           W@BOX4    IFNE *ZERO
     C                     LEAVE
     C                     END
     C                     MOVEL*BLANK    W@BOX4
     C           W@BOX5    IFNE *ZERO
     C                     LEAVE
     C                     END
     C                     MOVEL*BLANK    W@BOX5
     C           W@BOX6    IFNE *ZERO
     C                     LEAVE
     C                     END
     C                     MOVEL*BLANK    W@BOX6
     C           W@BOX7    IFNE *ZERO
     C                     LEAVE
     C                     END
     C                     MOVEL*BLANK    W@BOX7
     C                     ENDDO
     C                     END
     C*
     C                     ENDSR
      *----------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                         UDATE Y   69
     O                                   72 'P.'
     O                         PAGE  Z   76
     O        E   03           @HED
     O                                   30 'LOT # REPORT FOR '
     O                         W@DLNM    70
     O        E   05           @HED
     O                                    5 'SHIP:'
     O                         W@NOYY    10
     O                                   11 '-'
     O                         W@NOMM    13
     O                                   14 '-'
     O                         W@NODD    16
     O                         W@NOBI    19
     O                         PMSIRE    24
     O                         PMSIRK    26
     O                         PMDOCK    31
     O        E   07           @HED
     O                                   10 'ORDER#    '
     O                                   26 'PART#          '
     O                                   41 '# OF BOXS'
     O                                   55 'LOT#   '
     O                                   78 'SERIAL#           '
     O        E   08           @HED
     O                         @@LIN     80
     O        E 1              @DTL
     O                         PRODRN    10
     O                         PRMHN1    16
     O                         PRMHP1    17
     O                         PRMHN2    22
     O                         PRMHP2    23
     O                         PRMHN3    28
     O                         PRBOXS    41
     O                         PRLOT1    51
     O                         PRLOT2    52
     O                         PRLOT3    55
     O                         PRSERL    78
     O        E 1              @SPACE
     O                                    2 ' '
