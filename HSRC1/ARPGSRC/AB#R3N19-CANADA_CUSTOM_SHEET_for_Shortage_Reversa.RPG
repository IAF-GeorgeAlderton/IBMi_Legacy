     H            Y.
     F*******************************************************
     FAM#WP19 IF  E           K        DISK
     FAB#WP38 O   F     110            DISK
     I            DS
     I                                        1   80@NOHZ
     I                                        1   40@NOYY
     I                                        5   60@NOMM
     I                                        7   80@NODD
     I            DS
     I                                        1  20 $MHIN
     I                                        1   5 $MHN1
     I                                        6  10 $MHN2
     I                                       11  15 $MHN3
     I                                       16  20 $MHN4
      *
     C           *ENTRY    PLIST
     C                     PARM           PFLG    1
      *
     C                     DO   *HIVAL
      *
     C                     READ AM#WP191                 50
     C           *IN50     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C           W1NONY    IFEQ 3503
     C                     EXSR #OUT
     C                     MOVE '1'       PFLG
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *************************************************************
      *  OUTPUT TO WORKFILE.
      *
     C           #OUT      BEGSR
      *
     C                     Z-ADD3411      TOKU    40
     C                     MOVE 'B'       NKOJ    1
      *
     C                     Z-ADD*ZERO     WTANK  135
     C                     Z-ADD*ZERO     @@TANK 115
     C                     Z-ADD*ZERO     $$TANK 135
      *
     C           WTANK     IFEQ 0
      *
     C                     MOVELTOKU      $TOKU   4
     C                     MOVELW1NONY    $NONY   4
     C                     MOVELNKOJ      $NKOJ   1
     C                     MOVELW1NUKE    $NUKE   4
     C                     MOVELW1MHN     $MHIN  20
     C                     MOVEL*BLANK    $SHIN  12
     C                     MOVEL*BLANK    $FLG    1
      *
     C                     CALL 'BBHR50'
     C                     PARM           $TOKU
     C                     PARM           $NONY
     C                     PARM           $NKOJ
     C                     PARM           $NUKE
     C                     PARM           $MHIN
     C                     PARM           $SHIN
     C                     PARM           $FLG
      *
     C                     MOVELTOKU      @TOKU   4
     C                     MOVELW1NONY    @NONY   4
     C                     MOVELNKOJ      @NKOJ   1
     C                     MOVELW1NUKE    @NUKE   4
     C                     MOVEL$MHIN     @MHIN  20
     C                     MOVELW1SHID    @HIZK   8
     C                     Z-ADD0         @TANK  105
     C                     MOVE *BLANK    @CHEK   1
      *
     C                     CALL 'FBCR10'
     C                     PARM           @TOKU
     C                     PARM           @NONY
     C                     PARM           @NKOJ
     C                     PARM           @NUKE
     C                     PARM           @MHIN
     C                     PARM           @HIZK
     C                     PARM           @TANK
     C                     PARM           @CHEK
      *
     C                     Z-ADD@TANK     WTANK
     C                     Z-ADD@TANK     @@TANK
     C                     Z-ADD@TANK     $$TANK
      *
     C                     ENDIF
      *
     C                     Z-ADDW1QPC     WSYS    60
     C                     Z-ADDW1QPC     WSRYO  100
      *
     C           WSYS      IFEQ *ZERO
     C                     Z-ADD1         WSYS
     C                     END
      *
     C                     MOVEL'EXPEDITE'ODRN   10 P
      *
     C                     EXCPTDT1
      *
     C                     ENDSR
      *************************************************************
