     C                     PARM           PCOS2   2
     C                     PARM           PCOS3   2
     C                     MOVE PKOJY     BMON    40
     C                     MOVE PKOJY     KOJY    40
     C                     SETOF                     05
     C                     MOVE *BLANK    KMEI   16
     C           BMON      CHAINFGBPL011             05
     C           *IN05     IFEQ '0'
     C                     MOVE B2KEMI    KMEI   16
     C                     END
     C                     MOVE '-'       F1
     C                     MOVE '-'       F2
     C                     MOVE '-'       F3
     C                     MOVE '-'       F4
