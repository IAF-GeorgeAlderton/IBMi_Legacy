     C                     MOVE *BLANK    WKBN2
      * UﾇJｰ READ *
     C           STEP00    TAG
     C                     Z-ADD1         X       30
     C                     SETOF                     04
     C           SKEY      SETLLMZAPL231
     C           1         DO   *HIVAL    X
     C           STEP01    TAG
     C           SKEYR     READEMZAPL231                 04
     C           *IN04     CABEQ'1'       STEP02
     C           MXSAKJ    CABEQ'D'       STEP01
     C           MXSBKB    CABNE'1'       STEP01
     C           MXJTKB    CABNE'1'       STEP01
     C           MXOKKB    CABNE'A'       STEP01
     C           MXKBCD    CABEQ*BLANK    STEP01
     C           MXSIHZ    CABNE99999999  STEP01
      *
     C           *DATE     IFGE MXKAHZ
     C           *DATE     ANDLEMXSIHZ
     C                     ELSE
     C                     GOTO STEP01
     C                     END
      *
     C           X         CABGT340       STEP02
     C                     MOVE KIBN      KBM,X
     C                     MOVE MXKGCD    KGM,X
     C                     MOVELMXKOTE    KTM,X
     C                     MOVE MXKKNO    KEM,X
     C                     MOVE COST      CSM,X
     C                     MOVE SISN      KSM,X
     C                     END
     C           STEP02    TAG
     C                     Z-ADD0         D       30
     C           STEP03    TAG
     C                     Z-ADD1         X       30
     C                     Z-ADD1         Y       30
     C           1         DO   17        X
