     H            Y/
      ** ALDR57 *************************************************
      * SCANNED PARTS LIST                                      *
      *               JUL/01/2003                               *
      *                                                         *
      *                                                         *
      *
      ************************************************* ALDR57 **
     FALDWP56 IP  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *------------------------------------------------------------
     IALDWP561
     I                                              D5PRT1L1
     I                                              D5PRT2L1
     I                                              D5PRT3L1
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
      *   MAIN ROUTINE
      *--------------------------------------------------------
     C                     ADD  D5QTY     @@QTY  150
     C                     ADD  D5BOX     @@BOX  110
      *
     CL1                   EXSR #PRT
      *--------------------------------------------------------
      * INITIALIZE
      *--------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@DATE  8
     C                     MOVE *ALL'-'   L@LINE 70
      *
     C                     MOVE P@DATE    L@YMD   80
     C                     TIME           L@TIM   60
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  OUTPUT
      *--------------------------------------------------------
     C           #PRT      BEGSR
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
     C                     EXCPT@DTL
      *
     C                     Z-ADD*ZERO     @@QTY
     C                     Z-ADD*ZERO     @@BOX
      *
     C                     ENDSR
      *-------------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                         UDATE Y  106
     O                         L@TIM    115 '  :  :  '
     O                                  118 'P.'
     O                         PAGE  Z  122
     O        E   02           @HED
     O                                   30 '** SCANNED PARTS LIST **'
     O                                   41 'SHIP DATE:'
     O                         L@YMD     51 '    /  /  '
     O        E   04           @HED
     O                                    5 'PART'
     O                                   33 'QTY'
     O                                   53 '# OF CONTAINERS'
     O        E   05           @HED
     O                         L@LINE    70
     O        E 1              @DTL
     O                         D5PRT1     5
     O                         D5PRT2    11
     O                         D5PRT3    14
     O                         @@QTY 1   33
     O                         @@BOX 1   51
      *-------------------------------------------------------
