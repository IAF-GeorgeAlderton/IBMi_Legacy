      *
     C                     READ ADHPL03                  80
     C           *IN80     DOWEQ'0'
     C           J6SKJY    IFEQ 'D'
     C           J6SKHZ    ANDLE*DATE
     C                     ELSE
     C           J6UKHZ    IFLE *DATE
     C           J6STHZ    ANDGT*DATE
