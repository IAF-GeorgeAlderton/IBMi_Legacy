     C                     MOVEL'0'       KFAPCS
     C                     MOVEL'A'       KFKCD1
     C                     MOVELNAMEPR    WKNAME 15
     C           M6KSSU    DIV  M6SYUY    WKHAK1  91
     C           WKHAK1    DIV  20        WKHAK2  91
     C           WKHAK2    ADD  0.9       WKMAIS  50
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     READ ABHPL03                  80
