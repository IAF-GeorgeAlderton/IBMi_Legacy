      *
     C                     TIME           SDATE
      *
     C                     READ ABHPL03                  80
     C           *IN80     DOWEQ'0'
     C           M6SKJY    IFEQ 'D'
     C           M6SKHZ    ANDLE*DATE
     C                     ELSE
     C           M6UKHZ    IFLE *DATE
     C           M6STHZ    ANDGT*DATE
     C           M6JB21    IFEQ 'Z'
     C           M6JB21    OREQ 'G'
     C           M6JB21    OREQ 'X'
     C           M6JB21    OREQ 'K'
     C                     MOVELM6MTK1    KKBLK
