     C                     MOVELJ6MTK2    KKBLK2
     C                     EXSR #SB450
     C                     MOVEL'0'       KFAPCS
     C                     MOVEL'B'       KFKCD1
     C                     MOVELNAMEHT    WKNAME 15
      *
     C**JW1      J6KSSU    DIV  J6SYOS    WKHAK1  91
JW1  C           J6SYOS    IFEQ 0
 .   C                     Z-ADD0         WKHAK1
 .   C                     ELSE
 .   C           J6KSSU    DIV  J6SYOS    WKHAK1  91
JW1  C                     ENDIF
      *
     C           WKHAK1    DIV  20        WKHAK2  91
