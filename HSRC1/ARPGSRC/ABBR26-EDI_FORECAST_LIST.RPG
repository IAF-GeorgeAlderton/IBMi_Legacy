TCHK1C           D@PRNT    WHEQ '6'
TCHK1C                     MOVEL'LANPRT09'@PRT
TCHK1C           D@PRNT    WHEQ '7'
TCHK1C                     MOVEL'LANPRT10'@PRT
TCHK1C           D@PRNT    WHEQ '8'
TCHK1C                     MOVEL'LANPRT05'@PRT
TCHK1C                     OTHER
TCHK1C                     MOVEL'QDKT    '@PRT
TCHK1C                     ENDSL
