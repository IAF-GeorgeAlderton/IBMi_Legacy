     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#AB1     KLIST
     C                     KFLD           D@NONY
     C                     KFLD           D@FACT
     C                     KFLD           D@DOCK
     C           K#AB2     KLIST
     C                     KFLD           D@NONY
     C                     KFLD           D@FACT
     C           K#F10     KLIST
     C                     KFLD           K@PLNT  5
     C                     KFLD           K@SIDT  60
     C           K#52      KLIST
     C                     KFLD           D@NONY
     C                     KFLD           K@RCDT
     C           K#50      KLIST
     C                     KFLD           K@RCDT  80
     C                     KFLD           D@CUST
     C                     KFLD           D@NONY
     C                     KFLD           D@FACT
     C                     KFLD           D@DOCK
     C           K#50X     KLIST
     C                     KFLD           K@RCDT  80
     C                     KFLD           D@CUST
     C                     KFLD           D@NONY
     C                     KFLD           D@FACT
     C           K#FCE     KLIST
     C                     KFLD           K@SHN1  5
     C                     KFLD           K@SHN2  5
     C                     KFLD           K@SHN3  2
      *
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      *
     C                     MOVEL'01'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #PRT
     C                     MOVE '99'      W@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
     C                     MOVE *OFF      *IN99
     C                     MOVE D@NONY    @@NONY  4
      *
     C           D@CUST    IFNE 5149
     C           D@DOCK    IFEQ *BLANK
     C           K#AB2     CHAINABBPL53              90
     C                     ELSE
     C           K#AB1     CHAINABBPL53              90
     C                     ENDIF
     C                     ELSE
     C           @@NONY    SETLLABF9L01
     C           *IN90     DOUEQ*ON
     C           @@NONY    READEABF9L01                  90
     C           *IN90     IFEQ *OFF
     C           F9SKJY    ANDEQ*BLANK
     C                     MOVELF9DOCK    K@PLNT
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *OFF
     C           K@PLNT    CHAINABFPL15              90
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN90     IFEQ *ON
     C                     MOVE ERR,1     D@MSG
     C                     MOVEA'1111'    *IN,61
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C           D@PRNT    IFEQ *BLANK
     C  N99                MOVE ERR,2     D@MSG
     C                     MOVE *ON       *IN65
     C                     MOVE *ON       *IN99
     C                     ELSE
TCHK1C*          D@PRNT    IFGT '8'
TCHK1C           D@PRNT    IFLT '1'
TCHK1C           D@PRNT    ORGT '9'
     C  N99                MOVE ERR,2     D@MSG
     C                     MOVE *ON       *IN65
     C                     MOVE *ON       *IN99
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   PRINT
      *------------------------------------------------------
     C           #PRT      BEGSR
      *
     C                     SELEC
TCHK1C           D@PRNT    WHEQ '1'
TCHK1C                     MOVEL'LANPRT02'@PRT    8
TCHK1C           D@PRNT    WHEQ '2'
TCHK1C                     MOVEL'LANPRT07'@PRT
TCHK1C           D@PRNT    WHEQ '3'
TCHK1C                     MOVEL'LANPRT08'@PRT
TCHK1C           D@PRNT    WHEQ '4'
TCHK1C                     MOVEL'LANPRT03'@PRT
TCHK1C           D@PRNT    WHEQ '5'
