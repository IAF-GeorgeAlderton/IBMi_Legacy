     H            Y/                                    1
     H* EDIR50 ********************************************************
     H* CUSTOMER GROUP CODE MAINTENANCE                               *
     H*
     H* J.WATANABE  2017.09.06                                        *
     H*****************************************************************
     FEDIPW50 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     FEDIPP43 UF  E           K        DISK                      A
      *================================================================
     E                    MSG     1  20 60
      *================================================================
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *
     I           SDS
     I                                     *PROGRAM W@PGM
     I                                      244 253 W@WSID
     I                                      254 263 W@USER
     I                                      264 269 W@JBNO
      *===============================================================
      *  START  PROGRAM
      *===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C           @STEP     CASEQ'#CHK2 F5'#CHK2
     C           @STEP     CASEQ'#UPDAT  '#UPDAT
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      *   << INIT >>
      *===============================================================
     C           #INIT     BEGSR
     C           *ENTRY    PLIST
     C                     PARM           $TYP    1
      *
     C                     TIME           @TIME
     C                     MOVEA*ALL'0'   *IN
     C                     MOVE *BLANK    D1KBN
     C                     MOVE *BLANK    D1GRP
     C                     MOVE *BLANK    D1ERR            エラー
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
      *===============================================================
      *  DISPLAY SCREEN 1
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     EXFMTDSP01
     C                     MOVEA'00000000'*IN,21
     C                     SETOF                     99
     C                     MOVE *BLANK    D1ERR            エラー
     C*
     C                     MOVE '#CHK1   '@STEP
     C*  < F1 >  END JOB
     C           *INKA     IFEQ *ON
     C                     MOVE '#END    '@STEP
     C                     ENDIF
      *
     C*  < F9  >  GROUP INQUIRY
     C           *INKI     IFEQ *ON
     C                     MOVELD1GRP     P@GRP
     C                     CALL 'EDIR51'
     C                     PARM           P@GRP   3
     C           P@GRP     IFNE *BLANK
     C                     MOVELP@GRP     D1GRP
     C                     ENDIF
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
      *
     C*  < F12 >  GROUP-DELIVERY INQUIRY
     C           *INKL     IFEQ *ON
     C                     MOVELD1GRP     P@GRP
     C                     MOVEL$TYP      P@TYP
     C                     CALL 'EDIR52'
     C                     PARM           P@GRP   3
     C                     PARM           P@TYP   1
     C           P@GRP     IFNE *BLANK
     C                     MOVELP@GRP     D1GRP
     C                     ENDIF
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      * CHECK SCREEN 1
      *===============================================================
     C           #CHK1     BEGSR
     C*--------------------
     C* D1KBN (21)
     C*--------------------
     C                     SELEC
     C           D1KBN     WHEQ '0'
     C                     MOVEL'0-CANCEL'D2KBN
     C                     SETON                     30
     C           D1KBN     WHEQ '1'
     C                     MOVEL'1-CHANGE'D2KBN
     C                     SETOF                     30
     C           D1KBN     WHEQ '2'
     C                     MOVEL'2-ADD   'D2KBN
     C                     SETOF                     30
     C                     OTHER
     C                     SETON                     2199
     C                     MOVELMSG,1     D1ERR
     C                     GOTO @CHK1Z
     C                     ENDSL
     C*--------------------
     C* D1GRP  (22)
     C*--------------------
     C           D1GRP     IFEQ *BLANK
     C                     SETON                     2299
     C                     MOVELMSG,2     D1ERR
     C                     GOTO @CHK1Z
     C                     ENDIF
     C*
     C           D1GRP     CHAINEDIPP43             N90
     C  N90      E3SKJY    IFEQ 'D'                        DELETE CODE
     C           E3SKHZ    ANDLE@SYSHZ                     DELETE DATE
     C                     SETON                     90
     C                     ENDIF
     C*
S1   C           *IN90     IFEQ *OFF
     C           D1KBN     IFEQ '2'                        2-ADD
     C                     SETON                     212223
     C                     SETON                         99
     C                     MOVELMSG,5     D1ERR
     C                     GOTO @CHK1Z
     C                     ENDIF
     C                     MOVELE3GPNM    D2NAME
     C                     ELSE
     C           D1KBN     IFNE '2'                        NE 2-ADD
     C                     SETON                     212223
     C                     SETON                         99
     C                     MOVELMSG,4     D1ERR
     C                     GOTO @CHK1Z
     C                     ENDIF
     C                     MOVE *BLANK    D2NAME
     C                     ENDIF
     C*-------------------------
     C           @CHK1Z    TAG
     C*-------------------------
     C*
S1   C           *IN99     IFEQ *ON
     C                     MOVE '#DSP1   '@STEP
X1   C                     ELSE
     C                     MOVEA'00000000'*IN,31
     C                     MOVEL*BLANK    D2ERR
     C                     MOVE '#DSP2   '@STEP
E1   C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  DISPLAY SCREEN 2
      *===============================================================
     C           #DSP2     BEGSR
     C*
     C                     EXFMTDSP02
     C                     SETOF                     99
     C                     MOVEA'00000000'*IN,31
     C                     MOVE *BLANK    D2ERR
     C*
     C                     MOVE '#CHK2   '@STEP
     C*  < F3 >  BACK
     C           *INKC     IFEQ *ON
     C                     MOVEA'00000000'*IN,21
     C                     MOVE *BLANK    D1ERR
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C*  < F5 >  UPDAT
     C           *INKE     IFEQ *ON
     C                     MOVE '#CHK2 F5'@STEP
     C           D1KBN     IFEQ '0'                        0-CANCEL
     C                     MOVE '#UPDAT  '@STEP
     C                     ENDIF
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  CHECK SCREEN 2
      *===============================================================
     C           #CHK2     BEGSR
      *
     C           D2NAME    IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVELMSG,6     D2ERR
     C                     GOTO @CHK2Z
     C                     ENDIF
     C*
     C*-------------------------
     C           @CHK2Z    TAG
     C*-------------------------
     C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK2 F5'
     C                     MOVEL'#UPDAT  '@STEP
     C                     ELSE
     C                     MOVEL'#DSP2   '@STEP
     C                     ENDIF
     C                     ENDSR
      *===============================================================
      *  UPDATE PROCESS
      *===============================================================
     C           #UPDAT    BEGSR
     C*
     C           D1GRP     CHAINEDIPP43              90
     C*
     C           D1KBN     IFEQ '0'                        0-CANCEL
     C                     MOVE 'D'       E3SKJY           DELETE CODE
     C                     Z-ADD@SYSHZ    E3SKHZ           DELETE DATE
     C                     MOVELW@USER    E3SKME           DELETE NAME
     C  N90                UPDATEDIPP431
     C                     ELSE
      *
     C           E3SKJY    IFEQ 'D'
     C                     MOVE *BLANK    E3SKJY           DELETE CODE
     C                     Z-ADD0         E3SKHZ           DELETE DATE
     C                     MOVE *BLANK    E3SKME           DELETE NAME
     C                     Z-ADD@SYSHZ    E3CRHZ           CREATE DATE
     C                     MOVELW@USER    E3CRME           CREATE USER
     C                     ENDIF
      *
     C                     Z-ADD@SYSHZ    E3KOHZ           UPDATE DATE
     C                     MOVELW@USER    E3KOME           UPDATE USER
     C                     MOVELD1GRP     E3GRP
     C                     MOVELD2NAME    E3GPNM
      *
     C           *IN90     IFEQ *ON
     C                     Z-ADD@SYSHZ    E3CRHZ           CREATE DATE
     C                     MOVELW@USER    E3CRME           CREATE USER
     C                     ENDIF
      *
     C   90                WRITEEDIPP431
     C  N90                UPDATEDIPP431
     C                     ENDIF
      *
     C                     MOVE *BLANK    D1KBN
     C                     MOVE *BLANK    D1GRP
     C                     MOVE *BLANK    D1ERR
     C                     MOVEA'00000000'*IN,21
     C                     MOVE '#DSP1   '@STEP
      *
     C                     ENDSR
      *===============================================================
**  MSG
 ENTER 0, 1 OR 2 FOR UPDATING GROUP CODE!
 ENTER GROUP CODE!

 GROUP CODE NOT FOUND!
 GROUP CODE EXISTS ALREADY!T
 ENTER GROUP NAME!




