     H            Y.
     F** AB#R7Z ********************
     F*  ASN CHECK LIST            *
     F*      11/22                 *
     F******************** AB#R44 **
     FAB#PL75 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FAB#PL1A IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *----------------------------------------------------------
     I            DS
     I                                        1   80W@DATE
     I                                        1   40K@NOYY
     I                                        5   60K@NOMM
     I                                        7   80K@NODD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *----------------------------------------------------------
     C           K#KEY     KLIST
     C                     KFLD           K@NOYY                       E
     C                     KFLD           K@NOMM                       E
     C                     KFLD           K@NODD                       E
     C                     KFLD           K@CUST  40                   E
     C           K#AGD     KLIST
     C                     KFLD           K@NOYY                       E
     C                     KFLD           K@NOMM                       E
     C                     KFLD           K@NODD                       E
     C           K#1A      KLIST
     C                     KFLD           W@DATE
     C                     KFLD           PUBINN
     C                     KFLD           PUNONY
     C                     KFLD           PUNKOJ
     C                     KFLD           PUNUKE
      *
     C                     TIME           @@TIME  60
     C                     Z-ADD*DATE     W@DATE
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8YOBI    IFGE 6
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADDF8KAYY    K@NOYY
     C                     Z-ADDF8KAMM    K@NOMM
     C                     Z-ADDF8KADD    K@NODD
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD3411      K@CUST
     C           K#KEY     SETLLAB#PL75
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAB#PL75                  90
     C           *IN90     IFEQ *OFF
JW   C           PUSKJY    ANDNE'D'
     C           PUSKJY    ANDEQ*BLANK
     C           PUASDT    ANDEQ*ZERO
     C           PUNONY    ANDNE3503
     C           PUNONY    ANDNE3504
     C           PUNONY    ANDNE3557
     C           PUNONY    ANDNE3560
     C           PUNONY    ANDNE3555
      *
     C           K#1A      SETLLAB#PL1A
     C           *IN95     DOUEQ*ON
     C           K#1A      READEAB#PL1A                  95
     C           *IN95     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           PUODRN    IFNE *BLANK
     C           PUODRN    ANDNEBAODRN
     C                     ITER
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN95     IFEQ *ON
     C                     ITER
     C                     ENDIF
      *
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
     C                     EXCPT@DTL
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                         UDATE Y  110
     O                         @@TIME   119 '  :  :  '
     O                                  121 'P.'
     O                         PAGE  Z  125
     O        E   02           @HED
     O                                   25 '** TOYOTA ASN CHECK LIST'
     O                                   47 '-- NOT SENDING YET **'
     O        E   04           @HED
     O                                    7 'SHIP TO'
     O                                   12 'DOCK'
     O                                   21 'ORDER#'
     O                                   35 'SHIP DATE'
     O                                   42 'BIN'
     O        E 1              @DTL
     O                         PUNONY     6
     O                         PUNUKE    12
     O                         PUODRN    25
     O                         PUNOYY    30
     O                                   31 '/'
     O                         PUNOMM    33
     O                                   34 '/'
     O                         PUNODD    36
     O                         PUBINN    42
