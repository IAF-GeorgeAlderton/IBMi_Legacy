      *----------------------------------------------------*
      * MAIN ROUTINE
      *----------------------------------------------------*
     C                     EXSR #INIT
      *
     C           K#PL11    CHAINAAMPL11              99
     C           *IN99     IFEQ *OFF
     C           CKSKJY    ANDNE'D'
     C                     EXSR #PROC
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------------*
      * MAIN PROCESS
      *----------------------------------------------------*
     C           #PROC     BEGSR
      * CHECK OLD
     C           1         DO   15        IX      20
     C                     MOVELKHZ,IX    @KHZ
     C           @KHZ      IFLE @DATE
     C           @DEPT     ANDEQQB,IX
     C                     MOVELIX        O@##
     C                     MOVELQS,IX     O@TYP
     C**                   LEAVE
     C                     ENDIF
     C                     ENDDO
      * CHECK NEW  XXX
     C           1         DO   15        IX      20
     C                     MOVELKHZ,IX    @KHZ
     C           @KHZ      IFLE @DATE
     C           @DEPT     ANDEQBM,IX
     C                     MOVELIX        O@##
     C                     MOVELTY,IX     O@TYP
     C**                   LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      * INITIAL PROCESS
      *----------------------------------------------------*
     C           #INIT     BEGSR
      * PARAMETER
     C           *ENTRY    PLIST
     C                     PARM           P@SHN  12
     C                     PARM           P@DPT   4
     C                     PARM           P@DAT   8
     C                     PARM           O@##    2
     C                     PARM           O@TYP   1
      * KEY LIST
     C           K#PL11    KLIST
     C                     KFLD           K1SHN1
     C                     KFLD           K1SHN2
     C                     KFLD           K1SHN3
      *
     C                     TIME           SDATE
     C                     MOVELP@SHN     K1SHIN
     C                     MOVE '00'      O@##
     C                     MOVE *BLANK    O@TYP
     C                     MOVELP@DPT     @DEPT   40
     C           P@DAT     IFEQ *BLANK
     C           P@DAT     OREQ *ZERO
     C                     Z-ADDTODAY     @DATE   80
     C                     ELSE
     C                     MOVELP@DAT     @DATE
     C                     ENDIF
      * INITIALIZE
     C                     MOVE *BLANK    KO
     C                     MOVE *ZERO     BM
     C                     MOVE *BLANK    KB
     C                     MOVE *BLANK    NB
     C                     MOVE *BLANK    TY
     C                     MOVE *ZERO     KHZ
     C                     MOVE *BLANK    QK
     C                     MOVE *ZERO     QB
     C                     MOVE *BLANK    QN
     C                     MOVE *BLANK    QT
     C                     MOVE *BLANK    QS
     C                     MOVE *BLANK    QH
     C                     Z-ADD0         @KHZ    80
      *
     C                     ENDSR
