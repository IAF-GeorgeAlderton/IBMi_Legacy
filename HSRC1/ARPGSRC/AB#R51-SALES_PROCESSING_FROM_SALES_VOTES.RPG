     H            Y.
      ** AB#R51 ***********************************
      *  SALES PROCESSINGS FROM SALES VOTES       *
      *  PROGRAM ID.    :  AB#R51.      <RPG>     *
      *  CREATE DATE.   :  JUL/08/1997.           *
      *  AUTHOR.        :  S.OHTAKE               *
      *********************************** AB#R51 **
     FAB#PP50 IP  E           K        DISK
     FDA#PL12 UF  E           K        DISK
     FKFAPL11 IF  E           K        DISK
     FRATPL01 IF  E           K        DISK
     FAB#WP10 O   E                    DISK                      A
      *-------------*
      * DELETE DATE *
      *-------------*
     I            DS
     I                                        1   80D1SKHZ
     I                                        1   40D1SKYY
     I                                        5   60D1SKMM
     I                                        7   80D1SKDD
     I            DS
     I                                        1   80B8UKHZ
     I                                        1   40B8UKYY
     I                                        5   60B8UKMM
     I                                        7   80B8UKDD
      *
     C           KEY1      KLIST
     C                     KFLD           ABJYMM
     C                     KFLD           ABJYNO
     C           KEY2      KLIST
     C                     KFLD           B8TOKU
     C           KEYA      KLIST
     C                     KFLD           NOYY
     C                     KFLD           NOMM
     C                     KFLD           TUKA
      *----------------------------*
      *  START  PROGRAM  <AB#R51>  *
      *----------------------------*
     C                     SETOF                     10
     C           KEY1      CHAINDA#PL12              10
     C           *IN10     IFEQ '0'
     C           B8SKBN    IFEQ 'D'
     C           B8SKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     ENDIF
     C                     ENDIF
     C           *IN10     IFEQ '1'
     C                     SETON                     U2
     C*****>>              EXCPTDAT
     C                     GOTO EXT
     C                     ENDIF
     C           B8UKHZ    IFNE 0
     C                     GOTO EXT
     C                     END
      *
     C                     Z-ADD*DATE     B8UKHZ
     C                     UPDATDA#PL121
      *========*
      * OUTPUT *
      *========*
     C                     MOVE 'U'       W1USRI
     C                     MOVE 'S'       W1ODKE
     C                     MOVE *BLANK    W1TEIS
     C                     Z-ADDB8TOKU    W1TOKU
     C                     MOVE B8TKOJ    W1TKOJ
     C                     MOVE B8TUKE    W1TUKE
     C                     Z-ADDB8NONY    W1NONY
     C                     MOVE B8NKOJ    W1NKOJ
     C                     MOVE B8NUKE    W1NUKE
     C                     MOVE B8MHN1    W1UHN1
     C                     MOVE B8MHN2    W1UHN2
     C                     MOVE B8MHN3    W1UHN3
     C                     MOVE B8MHN4    W1UHN4
     C                     MOVE B8MHIN    W1UHIN
     C                     MOVE B8SHN1    W1SHN1
     C                     MOVE B8SHN2    W1SHN2
     C                     MOVE B8SHN3    W1SHN3
     C                     MOVE *BLANK    W1KANR
     C                     MOVELB8ODNO    W1ODNO
     C                     MOVE B8ODED    W1ODED
     C                     MOVELB8NBAN    W1NOBN
     C                     MOVE B8NSYO    W1NOKB
     C                     Z-ADDB8MEYY    W1NOYY
     C                     Z-ADDB8MEMM    W1NOMM
     C                     Z-ADDB8MEDD    W1NODD
     C                     Z-ADD0         W1NOBI
     C                     Z-ADDB8TANK    W1TANK
     C                     MOVE B8TKBN    W1TAKB
     C                     MOVE B8TTAI    W1TATN
     C                     Z-ADDB8SRYO    W1NOSU
     C                     MOVE B8TANI    W1SUTN
      *
     C                     Z-ADD0         W1KING
     C                     Z-ADD0         W1JYRY
     C                     Z-ADD0         W1JYRM
     C                     Z-ADD0         W1JYRD
     C                     MOVE *BLANK    W1JKKB
     C                     MOVE *BLANK    W1KENS
     C                     Z-ADD0         W1SEIY
     C                     Z-ADD0         W1SEIM
     C                     Z-ADD0         W1SEID
     C                     Z-ADD0         W1SIMY
     C                     Z-ADD0         W1SIMM
     C                     Z-ADD0         W1SIMD
     C                     MOVE *BLANK    W1JUNJ
     C                     MOVE *BLANK    W1MACH
     C                     Z-ADD0         W1MACY
     C                     Z-ADD0         W1MACM
     C                     Z-ADD0         W1MACD
     C                     Z-ADD0         W1GETU
     C                     MOVE *BLANK    W1KURK
     C                     MOVE *BLANK    W1SEBN
      *
     C           B8SYUY    IFEQ 0
     C                     Z-ADD0         W1HAKO
     C                     ELSE
     C                     Z-ADD0         HAKO    30
     C           B8SRYO    DIV  B8SYUY    HAKO
     C                     MVR            HASU    50
     C                     Z-ADDHAKO      W1HAKO
     C           HASU      IFNE 0
     C           W1HAKO    ADD  1         W1HAKO
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADDB8SYUY    W1SYUY
     C                     Z-ADD0         W1LTNO
     C                     Z-ADD0         W1PANO
     C                     MOVE *BLANK    W1MIKB
     C                     Z-ADD0         W1MIHK
     C                     Z-ADD0         W1MISU
     C                     MOVE B8STBN    W1STKB
     C                     Z-ADD0         W1RECN
     C                     Z-ADD*YEAR     W1URIY
     C                     Z-ADD*MONTH    W1URIM
     C                     Z-ADD*DAY      W1URID
      *
     C                     SETOF                     20
     C           KEY2      CHAINKFAPL11              20
     C           *IN20     IFEQ '0'
     C           D1SKJY    IFEQ 'D'
     C           D1SKHZ    ANDLE*DATE
     C                     SETON                     20
     C                     ENDIF
     C                     ENDIF
     C           *IN20     IFEQ '0'
     C                     MOVE *BLANK    W1TKKB
     C                     MOVE D1TUKA    W1TUKA
     C                     Z-ADDD1RATE    W1RATE
     C                     MOVE D1BANK    W1BANK
     C                     MOVE D1BACC    W1KOZN
     C                     ELSE
     C                     MOVE *BLANK    W1TKKB
     C                     MOVE *BLANK    W1TUKA
     C                     Z-ADD0         W1RATE
     C                     MOVE *BLANK    W1BANK
     C                     MOVE *BLANK    W1KOZN
     C                     ENDIF
     C                     Z-ADD0         W1PAYY
     C                     Z-ADD0         W1PAYM
     C                     Z-ADD0         W1PAYD
     C                     Z-ADD0         W1PKIN
     C                     Z-ADD0         W1SAGK
     C                     MOVE 'F'       W1SYBT
     C                     MOVE '4'       W1SOBT
     C                     MOVE '06'      W1GYOM
     C                     MOVE D1TUKA    TUKA    3
     C                     Z-ADDB8MEYY    NOYY    40
     C                     Z-ADDB8MEMM    NOMM    20
     C                     SETOF                     45
     C           KEYA      CHAINRATPL01              45
     C           *IN45     IFEQ '0'
     C           RASKJY    IFEQ 'D'
     C           RASKHZ    ANDLE*DATE
     C                     SETON                     45
     C                     ENDIF
     C                     ENDIF
     C           *IN45     IFEQ '0'
     C                     Z-ADDRARATE    W1ATNK
     C                     ELSE
     C                     Z-ADD0         W1ATNK
     C                     ENDIF
     C                     WRITEAB#WP101
     C           EXT       TAG
