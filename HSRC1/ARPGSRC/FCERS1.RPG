     H            Y.
     FFCEPL03 IF  E           K        DISK
     FFCEPL06 IF  E           K        DISK
      *
     I            DS
     I                                        1   80A2TRDT
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
      *
     C           *ENTRY    PLIST
     C                     PARM           P@BAN1  1
     C                     PARM           P@BAN2  2
     C                     PARM           P@BAN3  2
     C                     PARM           P@BAN4  1
     C                     PARM           P@DATE  8
     C                     PARM           P@ZETI  4
     C                     PARM           P@FLG   1
      *
     C           P@DATE    IFEQ *BLANK
     C                     Z-ADD*DATE     W@DATE  80
     C                     ELSE
     C                     MOVE P@DATE    W@DATE  80
     C                     END
      *
     C                     MOVE *BLANK    P@FLG
     C                     MOVE *BLANK    P@ZETI
      *
     C                     MOVE P@BAN1    K@BAN1
     C                     MOVE P@BAN2    K@BAN2
     C                     MOVE P@BAN3    K@BAN3
     C                     MOVE P@BAN4    K@BAN4
      *
     C           BANKEY    KLIST
     C                     KFLD           K@BAN1  1
     C                     KFLD           K@BAN2  2
     C                     KFLD           K@BAN3  2
     C                     KFLD           K@BAN4  1
      *
     C                     EXSR #NBAN
     C   88                EXSR #QBAN
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
     C           #NBAN     BEGSR
      *
     C           BANKEY    SETLLFCEPL03
      *
     C                     DO   *HIVAL
     C           BANKEY    READEFCEPL03                  88
     C   88                LEAVE
      *
     C           A2GSKD    IFEQ 'D'
     C                     ITER
     C                     END
      *
     C           W@DATE    IFLT A2TRDT
     C                     ITER
     C                     END
      *
     C                     MOVE A2ZETI    P@ZETI
     C                     MOVE 'N'       P@FLG
     C                     LEAVE
      *
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #QBAN     BEGSR
      *
     C           BANKEY    SETLLFCEPL06
      *
     C                     DO   *HIVAL
      *
     C           BANKEY    READEFCEPL06                  88
     C   88                LEAVE
      *
     C           A2GSKD    IFEQ 'D'
     C                     ITER
     C                     END
      *
     C           W@DATE    IFGE A2TRDT
     C                     ITER
     C                     END
      *
     C                     MOVE A2ZETI    P@ZETI
     C                     MOVE 'Q'       P@FLG
     C                     LEAVE
      *
     C                     ENDDO
      *
     C                     ENDSR
      *
