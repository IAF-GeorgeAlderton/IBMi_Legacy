     F** ABAR1A ***************************************
     F*   EDI(830)FORECAST DATA - GENTRAN STANDARD    *
     F*     H-AMANO                      04.04.16     *
     F*
     F*
     F*
     F*
     F*************************************** ABAR1A **
     FAB#EPA1 IF  E           K        DISK
     FAB#EPB1 IF  E           K        DISK
     FAB#EPC1 IF  E           K        DISK
     FAB#EPD1 IF  E           K        DISK
     FAB#EPE1 IF  E           K        DISK
     FAB#EPF1 IF  E           K        DISK
     FAB#EPG1 IF  E           K        DISK
     FAB#EPH1 IF  E           K        DISK
     FAB#EPI1 IF  E           K        DISK
     FAB#EPJ1 IF  E           K        DISK
     FAB#EPK1 IF  E           K        DISK
     FAB#EPL1 IF  E           K        DISK
     FABAEP20 O   E                    DISK
      *-------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-------------------------------------------------------
      * MAIN ROUTINE
      *-------------------------------------------------------
     C                     MOVEL'830'     K@ID    3
     C           K@ID      SETLLAB#EPA1
     C           *IN80     DOUEQ*ON
     C           K@ID      READEAB#EPA1                  80
     C           *IN80     IFEQ *OFF
     C                     EXSR #WRT
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-------------------------------------------------------
     C           #WRT      BEGSR
      *-------------------------------------------------------
     C                     CLEARABAEP201
     C                     MOVELAPRTNR    AEPRTR
     C                     Z-ADD*DATE     AERCVT
     C                     MOVEA'00'      *IN,97
      *
     C                     MOVE *BLANK    @N      1
      * SHIP TO
     C                     MOVELAEPRTR    K@KWD1    P
     C                     MOVEL'ENONY'   K@KWD2    P
     C           K#KEY     CHAINAB#EP00              90
     C           *IN90     IFEQ *ON
     C                     MOVELAEPRTR    @@5     5 P
     C                     MOVEL@@5       K@KWD1    P
     C           K#KEY     CHAINAB#EP00              90
     C                     ENDIF
      *
     C           *IN90     IFEQ *OFF
     C                     MOVELEPVAL1    @VAL1   1
     C                     MOVE @VAL1     @N      1
     C                     SELEC
     C           @VAL1     WHEQ 'A'
     C                     EXSR #NONY
     C           @VAL1     WHEQ 'B'
     C                     EXSR #HONDA
     C                     ENDSL
     C                     ENDIF
      *
     C                     MOVELAETOKU    WTOKU   40
      * TIMING OF OUTPUT
     C                     MOVE *BLANK    @@L     1
     C                     MOVELAEPRTR    K@KWD1    P
     C                     MOVEL'AB#WP10' K@KWD2    P
     C           K#KEY     CHAINAB#EP00              90
     C           *IN90     IFEQ *OFF
     C                     MOVELEPVAL1    @@L     1
     C                     ENDIF
      *
     C                     MOVELAENONY    WNONY   40
     C                     MOVELAENKOJ    WNKOJ   1
      ** COUNT SCHEDULE DATES
     C                     MOVEL'SCHDT'   K@KWD2    P
     C           K#KEY     CHAINAB#EP00              90
     C           *IN90     IFEQ *OFF
     C                     MOVELEPVAL1    @@SHD   1
     C                     ELSE
     C                     MOVE *BLANK    @@SHD
     C                     ENDIF
      *
     C                     ELSE
     C           @N        IFEQ 'A'
     C           AEFLR1    ANDNE@@FLR1
     C                     EXSR #NONY
     C                     MOVELAENONY    WNONY   40
     C                     SETON                     30
     C                     ENDIF
     C                     ENDIF
      *
     C           @@L       IFEQ 'A'
     C           *INL1     ANDEQ*ON
     C                     Z-ADD*ZERO     WYM
     C                     Z-ADD*ZERO     @A      30
     C                     Z-ADD*ZERO     @@QTY   81
     C                     ENDIF
      *
     C           AEUPID    CABNE*BLANK    @@JUMP
      *
     C                     MOVE '1'       AEUPID
     C                     UPDATABAEP201
      * PROCESS OR NOT
     C                     MOVEL'AEORID'  K@KWD2    P
     C           K#KEY     CHAINAB#EP00              90
     C           *IN90     IFEQ *OFF
     C                     MOVELEPVAL1    @@1     1
     C                     MOVELEPVAL2    @@X     1
     C           @@X       IFEQ 'N'
     C           @@1       CABEQAEORID    @@JUMP
     C                     ELSE
     C           @@1       CABNEAEORID    @@JUMP
     C                     ENDIF
     C                     ENDIF
      *
     C   L3                SETON                     30
      * RECIEVED DATE
     C           AERCVT    IFEQ *ZERO
     C                     Z-ADD*DATE     WDAT8
     C                     ELSE
     C                     Z-ADDAERCVT    WDAT8   80
     C                     ENDIF
      *
      *
      * CUSTOMER PART#
     C                     MOVEAAEMHIN    MH1       P
     C                     MOVE *BLANK    MH2
     C                     Z-ADD*ZERO     Y       20
     C           1         DO   30        X       20
     C           MH1,X     IFNE '-'
     C           MH1,X     ANDNE'/'
     C           MH1,X     ANDNE'.'
     C           MH1,X     ANDNE*BLANK
     C                     ADD  1         Y
     C                     MOVE MH1,X     MH2,Y
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAMH2       WMHIN     P
      *
     C                     MOVE 'C'       WNOKN   1
      * DOCK
     C                     MOVELAENUKE    WNUKE   4
     C           AENUKE    IFEQ *BLANK
     C           AENUKE    OREQ '0   '
     C                     MOVEL'00  '    WNUKE
     C                     ENDIF
      * QTY
     C                     Z-ADDAEEQTY    WSURY   81
     C                     ADD  AEEQTY    @@QTY
      * SCHEDULE DATE
     C                     MOVELAEDAT1    @DATC     P
     C           @DATS     IFEQ *BLANK
     C                     MOVE @DAT6     WDAT6   60
     C           WDAT6     ADD  20000000  WNYMD
     C                     ELSE
     C                     MOVE AEDAT1    WNYMD
     C                     ENDIF
      *
     C           AESBAN    IFEQ *BLANK
     C           K#FCC     CHAINFCCTL13              90
     C           *IN90     IFEQ *OFF
     C                     MOVELB4SBAN    AESBAN
     C                     ELSE
     C                     MOVE '0000'    AESBAN
     C                     ENDIF
     C                     ENDIF
      *
     C           AEDAT2    IFNE *ZERO
     C                     MOVE AEDAT2    @DATC     P
     C           @DATS     IFEQ *BLANK
     C                     MOVE @DAT6     WDAT6   60
     C           WDAT6     ADD  20000000  @@EDAT  80
     C                     ELSE
     C                     MOVE AEDAT2    @@EDAT
     C                     ENDIF
     C                     ELSE
     C                     Z-ADD*ZERO     @@EDAT
     C                     ENDIF
      *
     C           WNYMD     CABEQ0         @@JUMP
      *
     C           @@L       IFEQ 'A'
     C           WNYMD     LOKUPWYM                      55
     C           *IN55     IFEQ *OFF
     C                     ADD  1         @A
     C                     Z-ADDWNYMD     WYM,@A
     C                     MOVE '1'       @UP     1
     C                     ELSE
     C                     MOVE *BLANK    @UP
     C                     ENDIF
     C                     ENDIF
      *
     C           P@REC     IFEQ *BLANK
     C                     MOVE '1'       P@REC
     C                     ENDIF
      *
     C  N31                SETON                     3031
     C                     SETON                     20
      *
     C           KEY5      CHAINGADPL111             10
     C           *IN10     IFEQ '0'
     C           B5SKJY    ANDEQ'D'
     C           B5SKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '1'
     C  N32                SETON                     4032
     C                     SETON                     05
      *
     C           *IN97     IFEQ *OFF
     C           *INOA     OREQ *ON
     C                     EXCPT@HED1
     C                     ENDIF
     C  N97                MOVE *ON       *IN97
     C                     EXCPT@DTL1
      *
     C                     ELSE
      *
     C           *IN98     IFEQ *OFF
     C           *INOB     OREQ *ON
     C                     EXCPT@HED2
     C                     ENDIF
     C  N98                MOVE *ON       *IN98
     C                     EXCPT@DTL2
      *
     C                     Z-ADD0         B       20
     C                     Z-ADD0         HYM
     C                     Z-ADD0         WKAD    20
      *
     C                     SELEC
     C           @@SHD     WHEQ *BLANK
     C           KEY4      SETLLAGDPL121
      *
     C           @@SHD     WHEQ 'A'
     C                     MOVEL@@PDAT    @DATC     P
     C           @DATS     IFEQ *BLANK
     C                     MOVE @DAT6     WDAT6   60
     C           WDAT6     ADD  20000000  @@YMD
     C                     ELSE
     C                     MOVE @@PDAT    @@YMD
     C                     ENDIF
     C           K#SHD     SETLLAGDPL121
     C                     ENDSL
      *
     C                     Z-ADD*ZERO     A       20
     C           *IN10     DOUEQ*ON
     C                     READ AGDPL121                 10
     C           *IN10     IFEQ '0'
     C           @@SHD     IFEQ *BLANK
     C           @@EDAT    ANDEQ*ZERO
     C                     ADD  1         A
     C           A         IFGT 7
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C           @@SHD     IFEQ 'A'
     C           F8KAHZ    ANDGEWNYMD
     C                     LEAVE
     C                     ENDIF
      *
     C           @@EDAT    IFNE *ZERO
     C           F8KAHZ    ANDGT@@EDAT
     C                     LEAVE
     C                     ENDIF
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         B
     C                     ADD  1         WKAD
     C                     Z-ADDF8KAHZ    HYM,B
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           WKAD      IFNE *ZERO
     C           WSURY     DIV  WKAD      WKSUR   70H
      *
     C                     Z-ADD*ZERO     A
     C           1         DO   *HIVAL
     C                     ADD  1         A
     C           HYM,A     IFEQ 0
     C                     LEAVE
     C                     ENDIF
      *
     C                     Z-ADDHYM,A     @NYMD
      *
     C           KEY2      CHAINABAWP101             11
     C           *IN11     IFEQ '1'
     C                     CLEARABAWP101
     C                     Z-ADDWTOKU     ABTOKU
     C                     Z-ADDWNONY     ABNONY
     C                     MOVE WNKOJ     ABNKOJ
     C                     MOVE WNUKE     ABNUKE
     C                     MOVE AESBAN    ABSBAN
     C                     MOVELWMHIN     ABMHIN
     C                     Z-ADD@NYM      ABDATE
     C                     Z-ADD0         HSU
     C                     Z-ADDWKSUR     HSU,D
     C                     XFOOTHSU       ABNNSU
     C                     MOVE WNOKN     ABNOKN
     C                     WRITEABAWP101
     C                     ELSE
      *
     C           @@L       IFEQ *BLANK
     C           @@L       OREQ 'A'
     C           *INL1     ANDEQ*ON
     C                     Z-ADDWKSUR     HSU,D
     C                     ELSE
     C                     ADD  WKSUR     HSU,D
     C                     ENDIF
      *
     C                     XFOOTHSU       ABNNSU
     C                     MOVE WNOKN     ABNOKN
      *
     C                     UPDATABAWP101
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDIF
      * HISTORY FILE
      *
     C           *IN99     IFEQ *OFF
     C           K#P50     CHAINABBPL50              90
     C           *IN90     IFEQ *ON
     C                     MOVE '1'       @@UPD   1
     C                     ENDIF
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C           K#P5X     CHAINABBPL50              90
     C***        @@UPD     IFEQ '1'
     C           *IN90     IFEQ *ON
     C                     CLEARABBPP501
     C                     ENDIF
     C                     Z-ADDWDAT8     BBRCDT
     C                     Z-ADDWTOKU     BBTOKU
     C                     Z-ADDWNONY     BBNONY
     C                     MOVE WNKOJ     BBNKOJ
     C                     MOVE WNUKE     BBNUKE
     C                     MOVELWMHN1     BBMHN1
     C                     MOVELWMHN2     BBMHN2
     C                     MOVELWMHN3     BBMHN3
     C                     MOVELWMHN4     BBMHN4
     C                     Z-ADDWNYMD     BBSDAT
     C           @@L       IFEQ 'A'
     C                     Z-ADD@@QTY     BBSQTY
     C                     ELSE
     C                     Z-ADDWSURY     BBSQTY
     C                     ENDIF
      *
     C                     MOVE AESBAN    BBSEBN
      * IAF PART#
     C                     MOVE WTOKU     PTOKU
     C                     MOVE WNONY     PNONY
     C                     MOVE WNKOJ     PNKOJ
     C                     MOVE WNUKE     PNUKE
     C                     MOVE WMHIN     PMHIN
     C                     MOVE *BLANK    PSHIN
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           PMHIN  20
     C                     PARM           PSHIN  12
     C                     PARM           PFLAG   1
      *
     C                     MOVELPSHN1     BBSHN1
     C                     MOVELPSHN2     BBSHN2
     C                     MOVELPSHN3     BBSHN3
      *
     C   90                WRITEABBPP501
     C  N90                UPDATABBPP501
     C******               ENDIF
      *
     C           WTOKU     IFNE @@TOKU
     C           WNONY     ORNE @@NONY
     C           K#25      CHAINABAEP25              90
     C           *IN90     IFEQ *ON
     C                     Z-ADDWTOKU     AACUST
     C                     Z-ADDWNONY     AASHTO
     C                     WRITEABAEP251
     C                     ENDIF
     C                     ENDIF
      *
     C           *INL2     IFEQ *ON
     C           K#FCE     CHAINFCEPL01              90
     C           *IN90     IFEQ *OFF
     C           AECQTY    ANDNEA2SSYS
     C           AECQTY    ANDNE*ZERO
      *
     C                     MOVE '3'       P@ERR
     C           *IN96     IFEQ *OFF
     C           *INOC     OREQ *ON
     C                     EXCPT@HED3
     C                     ENDIF
     C  N96                MOVE *ON       *IN96
     C                     EXCPT@DTL3
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVE AEDAT2    @@PDAT  8
     C                     MOVE AEFLR1    @@FLR1 10
     C                     Z-ADDWNONY     @@NONY  40
     C                     Z-ADDWTOKU     @@TOKU  40
     C           @@JUMP    TAG
%0001 *--------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@REC   1
     C                     PARM           P@ERR   1
      *
     C           K#KEY     KLIST
     C                     KFLD           K@KWD1 10
     C                     KFLD           K@KWD2 10
      *
     C           KEY2      KLIST
     C                     KFLD           WTOKU
     C                     KFLD           WNONY
     C                     KFLD           WNKOJ
     C                     KFLD           WNUKE
     C                     KFLD           WMHN1
     C                     KFLD           WMHN2
     C                     KFLD           WMHN3
     C                     KFLD           WMHN4
     C                     KFLD           @NYM
      *
     C           KEY4      KLIST
     C                     KFLD           WNYY
     C                     KFLD           WNMM
     C                     KFLD           WNDD
     C           K#SHD     KLIST
     C                     KFLD           @@YY
     C                     KFLD           @@MM
     C                     KFLD           @@DD
      *
     C           K#FCC     KLIST
     C                     KFLD           K@M     20
     C                     KFLD           WNONY
     C                     KFLD           WNKOJ
     C                     KFLD           WNUKE
     C                     KFLD           WMHN1
     C                     KFLD           WMHN2
     C                     KFLD           WMHN3
      *
     C           KEY5      KLIST
     C                     KFLD           WTOKU
     C                     KFLD           WNONY
     C                     KFLD           WNKOJ
     C                     KFLD           WNUKE
      *
     C           K#P50     KLIST
     C                     KFLD           WDAT8   80
     C                     KFLD           WTOKU
     C                     KFLD           WNONY
     C                     KFLD           WNKOJ
     C                     KFLD           WNUKE
     C           K#25      KLIST
     C                     KFLD           WTOKU
     C                     KFLD           WNONY
     C           K#P5X     KLIST
     C                     KFLD           WDAT8
     C                     KFLD           WTOKU
     C                     KFLD           WNONY
     C                     KFLD           WNKOJ
     C                     KFLD           WNUKE
     C                     KFLD           WMHN1
     C                     KFLD           WMHN2
     C                     KFLD           WMHN3
     C                     KFLD           WMHN4
     C                     KFLD           WNYMD
     C           K#FCE     KLIST
     C                     KFLD           BBSHN1
     C                     KFLD           BBSHN2
     C                     KFLD           BBSHN3
      *
     C           K#10      KLIST
     C                     KFLD           K@TOKU  40
     C                     KFLD           K@NONY  40
      *
     C                     TIME           WTIME   60
     C                     MOVE *BLANK    P@REC
     C                     MOVEA'000'     *IN,96
      *
     C                     Z-ADD*MONTH    K@M
      *
     C                     OPEN QPRINT
     C                     OPEN QPRINT2
     C                     OPEN QPRINTS
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  SHIP TO
      *--------------------------------------------------------
     C           #NONY     BEGSR
      *
     C                     SELEC
     C           AEFLR1    WHEQ 'MADISON'
     C                     MOVE 0873      AENONY
     C           AEFLR1    WHEQ 'MERCED'
     C                     MOVE 0870      AENONY
     C           AEFLR1    WHEQ 'DMAX'
     C                     MOVE 0590      AENONY
     C           AEFLR1    WHEQ 'SIA'
     C                     MOVE 0437      AENONY
     C                     ENDSL
      *
     C                     ENDSR
      *--------------------------------------------------------
     C           #HONDA    BEGSR
      *
     C                     MOVE '0'       AENKOJ
      *
     C                     SELEC
     C           AETOKU    WHEQ 'HMA'
     C           AETOKU    OREQ 'V  '
     C                     MOVE '0294'    AETOKU
     C                     MOVE '0294'    AENONY
     C           AETOKU    WHEQ 'AEP'
     C           AETOKU    OREQ 'N  '
     C                     MOVE '0390'    AETOKU
     C                     MOVE '2418'    AENONY
     C           AETOKU    WHEQ 'HTM'
     C                     MOVE '0296'    AETOKU
     C                     MOVE '0296'    AENONY
     C           AETOKU    WHEQ 'AHM'
     C                     MOVE '0400'    AETOKU
     C                     MOVE '0411'    AENONY
     C           AETOKU    WHEQ '200'
     C           AETOKU    OREQ 'AP9'
     C           AETOKU    OREQ 'A  '
     C                     MOVE '0390'    AETOKU
     C                     MOVE '4126'    AENONY
     C           AETOKU    WHEQ '210'
     C           AETOKU    OREQ 'TP9'
     C           AETOKU    OREQ 'T  '
     C                     MOVE '0390'    AETOKU
     C                     MOVE '3128'    AENONY
     C           AETOKU    WHEQ '240'
     C                     MOVE '5379'    AETOKU
     C                     MOVE '5379'    AENONY
     C           AETOKU    WHEQ '260'
     C           AETOKU    OREQ 'QP9'
     C           AETOKU    OREQ 'Q  '
     C                     MOVE '0390'    AETOKU
     C                     MOVE '0402'    AENONY
     C           AETOKU    WHEQ 'HCM'
     C           AETOKU    OREQ 'C  '
     C                     MOVE '0295'    AETOKU
     C                     SELEC
     C           AENONY    WHEQ 'SPS1'
     C           AENONY    OREQ 'HCM1'
     C                     MOVE '2021'    AENONY
     C           AENONY    WHEQ 'SPS2'
     C           AENONY    OREQ 'HCM2'
     C                     MOVE '2022'    AENONY
     C           AENONY    WHEQ 'NIS2'
     C                     MOVE '0295'    AENONY
     C                     OTHER
     C                     MOVE '2020'    AENONY
     C                     ENDSL
      *
     C                     ENDSL
      *
     C           AEFLR2    IFNE *BLANK
     C                     MOVE AENONY    K@NONY
     C                     MOVE AETOKU    K@TOKU
     C           K#10      CHAINABAPP10              90
     C                     MOVELAEFLR2    A1RLNO
     C                     MOVE AENONY    A1NONY
     C                     MOVE AETOKU    A1CUST
     C                     Z-ADD*DATE     A1DATE
     C   90                WRITEABAPP101
     C  N90                UPDATABAPP101
     C                     ENDIF
