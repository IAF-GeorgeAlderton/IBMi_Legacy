     H            Y.
     F** VVVR12 ****************************
     F*  SET USRPRF DATA IN VVVPPB0        *
     F**************************************
     FUSRWP10 IF  E                    DISK
     FVVVPPB0 IF  E           K        DISK                      A
      *
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ USRWP10                  97
     C   97                LEAVE
      *
     C                     MOVELUPUPRF    K#PNAM
     C                     MOVELUPINPG    K#FNAM
     C           K#PPB0    CHAINVVVPPB0              99
     C  N99                ITER
      * IGNORE
     C           UPINPG    IFEQ 'DGAC90'
     C           UPINPG    OREQ 'DGAC91'
     C           UPINPG    OREQ '*NONE '
     C                     ITER
     C                     ENDIF
      * IGNORE
     C                     MOVELUPUPRF    LTR4    4
     C                     MOVE LTR4      LTR1    1
     C           LTR1      IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C                     CLEARVVVPPB01
     C                     MOVELUPUPRF    VWPNAM
     C                     MOVELUPINPG    VWFNAM
     C                     MOVELUPTEXT    VWTEXT
     C                     WRITEVVVPPB01
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *===========================================================
      * INITIAL SETTING
      *===========================================================
     C           #INIT     BEGSR
      *
     C           K#PPB0    KLIST
     C                     KFLD           K#PNAM 10
     C                     KFLD           K#FNAM 11
      *
     C                     ENDSR
