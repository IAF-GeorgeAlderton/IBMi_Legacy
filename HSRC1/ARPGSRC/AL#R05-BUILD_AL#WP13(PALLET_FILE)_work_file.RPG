     H            Y.
     F** AL#R05  *******************************************
     F*  AL#WP13ＩＡＦ便＃にパレットを割り振る           *
     F*      ITS.        2015.05.20                        *
     F******************************************************
     FAL#WP11 IF  E           K        DISK
     FAL#WP12 IF  E           K        DISK
     FAL#WP13 O   E                    DISK                      A
     E                    ER      1  11 65
     E                    IB        999  3
     E                    CT        999  8 0
     E                    PU        999  8 0
     E                    PUH       999  8 0
      *
     I            DS
     I                                        1  12 W1SHN
     I                                        1   5 W1SHN1
     I                                        6  10 W1SHN2
     I                                       11  12 W1SHN3
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      *
     C           *HIVAL    SETGTAL#WP111
     C                     READPAL#WP111                 81
     C           *IN81     DOWEQ'0'
     C                     EXSR #SB399
     C                     EXSR #SB400
     C**********           READPAL#WP111                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *ＩＡＦ便＃をテーブルに格納
      *-----------------------------------------------------
     CSR         #SB399    BEGSR
      *
     C           KEYW2     KLIST
     C                     KFLD           W1TRKB
     C                     KFLD           W1SURT
     C****                 KFLD           W1SHID
     C                     CLEARIB
     C                     CLEARCT
     C                     CLEARPU
     C                     CLEARPUH
     C                     Z-ADD0         X       40
      *ＩＡＦ便＃の大きいものを配列の先頭にセット
     C           KEYW2     SETGTAL#WP121
     C           KEYW2     REDPEAL#WP121                 82
     C           *IN82     DOWEQ'0'
     C                     ADD  1         X
     C                     MOVELW2IAFB    IB,X             ＩＡＦ便
     C                     Z-ADDW2KPLT    CT,X             種類の数
     C           KEYW2     REDPEAL#WP121                 82
     C                     ENDDO
      *ＩＡＦ便＃の数
     C                     Z-ADDX         MAX     40
      *パレットプーリングのパレット数
     C                     Z-ADD0         P1KENS
     C                     Z-ADD0         P1KENH
     C                     CALL 'AL#R11'
     C                     PARM           W1TRKB  2
     C                     PARM           W1SURT  9
     C                     PARM           P1KENS  30
     C                     PARM           P1KENH  30
      *品番ありのパレットプーリング
     C                     Z-ADD1         A       40
     C                     Z-ADDMAX       B       40
     C           A         DOWLEP1KENH
     C           CT,B      IFGT 0
     C                     ADD  1         PUH,B
     C                     ADD  1         A
     C                     ENDIF
     C           PUH,B     IFEQ CT,B
     C                     SUB  1         B
     C                     ENDIF
     C                     ENDDO
      *品番なしのパレットプーリング
     C                     Z-ADD1         A       40
     C                     Z-ADDMAX       B       40
     C           A         DOWLEP1KENS
     C           CT,B      SUB  PUH,B     C       40
     C                     SUB  PU,B      C
     C***        CT,B      IFGT 0
     C           C         IFGT 0
     C                     ADD  1         PU,B
     C                     ADD  1         A
     C                     ENDIF
     C                     SUB  1         B
     C           B         IFEQ 0
     C                     Z-ADDMAX       B
     C                     ENDIF
     C                     ENDDO
      *
     CSR         ESB399    ENDSR
      *-----------------------------------------------------
      *ＩＡＦ便＃をセットしてワーク作成
      *-----------------------------------------------------
     CSR         #SB400    BEGSR
      * PALLET PULLING以外で使用する値
     C                     Z-ADD0         X
     C                     MOVEL'ADD'     COND    3
     C                     Z-ADD1         X2      40
      * PALLET PULLINGで使用する値
     C****                 Z-ADD1         Y       40
     C                     Z-ADDMAX       Y       40
     C                     ADD  1         Y
     C                     Z-ADD1         Y2      40
     C                     Z-ADDMAX       Y3      40
      *
     C                     MOVELW1SHID    SVSHID  8
     C                     MOVELW1SHIT    SVSHIT  6
     C                     MOVELW1NONY    SVNONY  40
     C                     MOVELW1NKOJ    SVNKOJ  1
     C                     MOVELW1NUKE    SVNUKE  4
     C                     MOVELW1ORD#    SVORD# 12
     C                     MOVELW1TRKB    SVTRKB  2
     C                     MOVELW1SURT    SVSURT  9
      *
     C           *IN81     DOWEQ'0'
     C****       W1SHID    ANDEQSVSHID
     C****       W1SHIT    ANDEQSVSHIT
     C           W1TRKB    ANDEQSVTRKB
     C           W1SURT    ANDEQSVSURT
     C           W1PPUL    IFEQ *BLANK
     C                     EXSR #SB510
     C                     ELSE
     C           W1SHN     IFEQ *BLANK
     C                     EXSR #SB520                     PALLET PULLING
     C                     ELSE
     C                     EXSR #SB530                     PALLET PULLING
     C                     ENDIF
     C                     ENDIF
     C                     EXSR #SB500
     C                     READPAL#WP111                 81
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *-----------------------------------------------------
      * AL#WP13
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C           WKIAFB    IFEQ *BLANK
     C                     MOVELER,1      PMSG
     C                     CALL 'APLR90'
     C                     PARM           PMSG  256
     C                     PARM           PKINP   5
     C                     PARM           PWSNO  10
     C                     PARM           PKOUT   1
     C                     ENDIF
      *
     C                     CLEARAL#WP131
     C                     MOVELW1SHID    W3SHID
     C                     MOVELW1SHIT    W3SHIT
     C                     MOVELW1NONY    W3NONY
     C                     MOVELW1NKOJ    W3NKOJ
     C                     MOVELW1NUKE    W3NUKE
     C                     MOVELW1ORD#    W3ORD#
     C                     MOVELW1SURT    W3SURT
     C                     Z-ADDW1EXTR    W3EXTR
     C                     Z-ADDW1FIXD    W3FIXD
     C                     Z-ADDW1FIXT    W3FIXT
     C                     MOVELW1PALT    W3PALT
     C                     Z-ADDW1BOX     W3BOX
     C                     MOVELW1TRKB    W3TRKB
     C                     MOVELWKIAFB    W3IAFB
     C                     Z-ADDW1PRT     W3PRT
     C                     MOVELW1PPUL    W3PPUL
     C                     MOVELW1SAT     W3SAT
     C                     MOVELW1SHN1    W3SHN1
     C                     MOVELW1SHN2    W3SHN2
     C                     MOVELW1SHN3    W3SHN3
     C                     MOVELW1PPUL    W3PPU2
     C           W1SHN     IFNE *BLANK
     C                     MOVEL'2'       W3PPU2
     C                     ENDIF
     C                     WRITEAL#WP131
      *
     CSR         ESB500    ENDSR
      *-----------------------------------------------------
      *ＩＡＦ便＃のセット PALLET PULLING以外
      *-----------------------------------------------------
     CSR         #SB510    BEGSR
      *
     C                     Z-ADD0         LOOP    50
     C                     MOVEL*BLANK    WKIAFB  3
     C           WKIAFB    DOWEQ*BLANK
     C           LOOP      ANDLE999
     C****                 EXSR #SB511
     C                     EXSR #SB512
     C                     ADD  1         LOOP
     C                     ENDDO
      *
     C           WKIAFB    IFEQ *BLANK
     C                     ENDIF
      *
     CSR         ESB510    ENDSR
      *-----------------------------------------------------
      *ＩＡＦ便＃を決める PALLET PULLING以外
      *ＩＡＦ便＃　大→小→大→小・・・→大→小　を繰り返す
      *-----------------------------------------------------
     CSR         #SB511    BEGSR
      *
     C                     SELEC
      *
     C           COND      WHEQ 'SUB'
     C           X         IFEQ 1
     C                     MOVEL'ADD'     COND
     C                     ELSE
     C                     SUB  1         X
     C                     ENDIF
      *
     C           COND      WHEQ 'ADD'
     C           X         IFEQ MAX
     C                     MOVEL'SUB'     COND
     C                     ELSE
     C                     ADD  1         X
     C                     ENDIF
      *
     C                     ENDSL
      *
     C           CT,X      IFGT 0
     C                     MOVELIB,X      WKIAFB  3
     C                     SUB  1         CT,X
     C                     ENDIF
      *
     CSR         ESB511    ENDSR
      *-----------------------------------------------------
      *ＩＡＦ便＃を決める PALLET PULLING以外
      *-----------------------------------------------------
     CSR         #SB512    BEGSR
      *
     C           CT,X2     IFGT 0
     C                     MOVELIB,X2     WKIAFB  3
     C                     SUB  1         CT,X2
     C                     ELSE
     C                     ADD  1         X2
     C                     ENDIF
      *
     CSR         ESB512    ENDSR
      *-----------------------------------------------------
      *ＩＡＦ便＃のセット PALLET PULLING
      *-----------------------------------------------------
     CSR         #SB520    BEGSR
      *
     C                     Z-ADD0         LOOP    50
     C                     MOVEL*BLANK    WKIAFB  3
     C           WKIAFB    DOWEQ*BLANK
     C           LOOP      ANDLE999
     C****                 EXSR #SB521
     C                     EXSR #SB522
     C                     ADD  1         LOOP
     C                     ENDDO
      *
     C           WKIAFB    IFEQ *BLANK
     C                     ENDIF
      *
     CSR         ESB520    ENDSR
      *-----------------------------------------------------
      *ＩＡＦ便＃を決める PALLET PULLING
      *ＩＡＦ便＃　小→大　小→大　を繰り返す
      *-----------------------------------------------------
     CSR         #SB521    BEGSR
      *
     C           Y         IFEQ 1
     C                     Z-ADDMAX       Y
     C                     ELSE
     C                     SUB  1         Y
     C                     ENDIF
      *
     C           CT,Y      IFGT 0
     C                     MOVELIB,Y      WKIAFB  3
     C                     SUB  1         CT,Y
     C                     ENDIF
      *
     CSR         ESB521    ENDSR
      *-----------------------------------------------------
      *ＩＡＦ便＃を決める PALLET PULLING
      *-----------------------------------------------------
     CSR         #SB522    BEGSR
      *
     C           PU,Y2     IFGT 0
     C                     MOVELIB,Y2     WKIAFB  3
     C                     SUB  1         CT,Y2
     C                     SUB  1         PU,Y2
     C                     ELSE
     C                     ADD  1         Y2
     C           Y2        IFGT MAX
     C                     Z-ADD1         Y2
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB522    ENDSR
      *-----------------------------------------------------
      *ＩＡＦ便＃のセット PALLET PULLING品番あり
      *-----------------------------------------------------
     CSR         #SB530    BEGSR
      *
     C                     Z-ADD0         LOOP    50
     C                     MOVEL*BLANK    WKIAFB  3
     C           WKIAFB    DOWEQ*BLANK
     C           LOOP      ANDLE999
     C                     EXSR #SB532
     C                     ADD  1         LOOP
     C                     ENDDO
      *
     C           WKIAFB    IFEQ *BLANK
     C                     ENDIF
      *
     CSR         ESB530    ENDSR
      *-----------------------------------------------------
      *ＩＡＦ便＃を決める PALLET PULLING品番あり
      *-----------------------------------------------------
     CSR         #SB532    BEGSR
      *
     C           PUH,Y3    IFGT 0
     C                     MOVELIB,Y3     WKIAFB  3
     C                     SUB  1         CT,Y3
     C                     SUB  1         PUH,Y3
     C                     ELSE
     C                     SUB  1         Y3
     C                     ENDIF
      *
     CSR         ESB532    ENDSR
**
CAN NOT SET IAF BIN#. PLEASE CALL ATSU.
