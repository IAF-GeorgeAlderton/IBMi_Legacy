     H            Y.
     F** AB#REC *************************************************************
     F*  ..AMBRAKE PROCESS CHECK                                            *
     F*                                                                     *
     F****************************************** AB#REC *********************
     FAB#EP40 UP  E                    DISK
     FABAEP20 US  E                    DISK
     FAB#PL48 IF  E           K        DISK
      *****************************************************************
     IAB#EP401    01
     IABAEP201    02
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------------------
      * MAIN
      *-----------------------------------------------------------
     C           *IN01     IFEQ *ON
     C           EPRTNR    CABNE'AMBRAKE' @END
      *
     C           EFLR2     CHAINAB#PL48              90
     C           *IN90     IFEQ *OFF
     C                     MOVE '1'       EUPID
     C                     UPDATAB#EP401
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN02     IFEQ *ON
     C           AEPRTR    CABNE'AMBRAKE' @END
     C           AEFLR2    CHAINAB#PL48              90
     C           *IN90     IFEQ *OFF
     C                     MOVE '1'       AEUPID
     C                     UPDATABAEP201
     C                     ENDIF
     C                     ENDIF
      *
     C           @END      TAG
