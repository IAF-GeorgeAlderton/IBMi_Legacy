     H            Y.
     F** AC#R20 *******************************************************
     F*  (HONDA) CREATE WORK FILE OF CONSOLIDATED ORDER               *
     F*  J.WATANABE   2017.03.31                                      *
     F************************************************(AB#R4D)*********
     FAC#PL10 IF  E           K        DISK
     FAC#PP32 O   E                    DISK
      ****************************************************
     I            DS
     I                                        1  12 BCSHN
     I                                        1   5 BCSHN1
     I                                        6  10 BCSHN2
     I                                       11  12 BCSHN3
      ****************************************************
      * MAIN ROUTINE
      ****************************************************
     C           *ENTRY    PLIST
     C                     PARM           P@BAR   9
      *
     C           P@BAR     SETLLAC#PL10
     C           *IN98     DOWEQ*OFF
     C           P@BAR     READEAC#PL10                  98
     C           *IN98     IFEQ *OFF
     C                     EXSR #WRT
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *===================================================
      * WRITE AC#PP32
      *===================================================
     C           #WRT      BEGSR
      * MOVE FIELD
     C                     Z-ADDBCNOHZ    INOHZ
     C                     Z-ADDBCNOBN    INOTM
     C                     MOVELBCSIRE    ISIRE
     C                     MOVELBCSIRK    ISIRK
     C                     MOVELBCNUKE    INUKE
     C                     MOVELBCODRN    IODRN
     C                     MOVELBCSBAN    ISBAN
     C                     MOVELBCMHN     IMHN
     C                     Z-ADDBCSRYO    ISRYO
     C                     Z-ADDBCSYOS    ISYOS
     C                     MOVELBCSHN     ISHN
     C                     Z-ADDBCTOKU    ITOKU
     C                     Z-ADDBCNONY    INONY
     C                     MOVELBCNKOJ    INKOJ
     C                     MOVELBCALFL    BAALFL
     C                     MOVELBCINVN    IINV#
     C                     MOVELBCLOC1    FCLOC1
     C                     MOVELBCLOC2    FCLOC2
     C                     MOVELBCLOC3    FCLOC3
     C                     MOVELBCLOC4    FCLOC4
     C                     Z-ADDBCTWGT    FCWEGH
     C                     Z-ADDBCBOX#    FC#BOX
      *
     C**                   Z-ADDBCTANK    ITANK
J     * RETRIEVE UNIT PRICE ---------------------
J    C                     MOVE BCTOKU    @TOKU   4
J    C                     MOVE BCNONY    @NONY   4
J    C                     MOVE BCNKOJ    @NKOJ   1
J    C                     MOVE BCNUKE    @NUKE   4
J    C                     MOVELBCMHN     @MHIN  20
J    C                     MOVE BCNOHZ    @HIZK   8
J    C                     Z-ADD0         @TANK  105
J    C                     MOVE *BLANK    @CHEK   1
J     *
J    C                     CALL 'FBCR10'
J    C                     PARM           @TOKU
J    C                     PARM           @NONY
J    C                     PARM           @NKOJ
J    C                     PARM           @NUKE
J    C                     PARM           @MHIN
J    C                     PARM           @HIZK
J    C                     PARM           @TANK
J    C                     PARM           @CHEK
J     *
J    C                     Z-ADD@TANK     ITANK
      *
     C                     WRITEAC#PP321
      *
     C                     ENDSR
      *===================================================
