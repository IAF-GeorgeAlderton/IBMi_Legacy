     F********************************* AB#R7C **
     FAB#WP65 IP  F     128            DISK
     IAB#WP65 AA  01
     I                                       56  610ISYOS
     I                                       62  710ISURY
      *
     C           *ENTRY    PLIST
     C                     PARM           PPALT   6
      *
     C                     Z-ADD0         IHAK    60
     C                     Z-ADD0         IHAS    60
      *
     C           ISURY     DIV  ISYOS     IHAK
     C                     MVR            IHAS
      *
     C           IHAS      IFNE 0
     C                     ADD  1         IHAK
     C                     END
      *
     CLR                   Z-ADD0         IPALT   60
     CLR         IHAK      DIV  120       IPALT   60
     CLR                   MVR            IHAS
      *
     CLR         IHAS      IFNE 0
     CLR                   ADD  1         IPALT
     CLR                   END
     CLR                   MOVE IPALT     PPALT
