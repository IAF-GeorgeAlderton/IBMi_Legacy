     F** GCQR81 ***********************************
     F*пј’жЎҒж–Үеӯ—вҶ’пј“жЎҒж•°еҖӨеӨүжҸӣ          гҖҖгҖҖ   *
     F*        MSK          2004.12.01            *
     F********************************** GCQR81  **
     E                    CD1    36  36  1
     E                    CD2    26  26  1
      *------------------------------------------------------*
      * PARAMETER                                            *
      *------------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           PICHR   2
     C                     PARM           PONUM   3
      *
      *---------*
      * MAIN    *
      *---------*
     C                     MOVELPICHR     WKCHR1  1
     C                     MOVE PICHR     WKCHR2  1
      *
     C           WKCHR1    IFLT '0'
     C           WKCHR1    ORGT '9'
     C           WKCHR2    ORLT '0'
     C           WKCHR2    ORGT '9'
     C                     ELSE
     C                     MOVE PICHR     PONUM
     C                     GOTO @LAST
     C                     ENDIF
      *
     C                     MOVELPICHR     WKCHR1  1
     C                     MOVE PICHR     WKCHR2  1
     C                     SETOF                     20
     C                     Z-ADD1         X       30
     C           WKCHR1    LOKUPCD1,X                    20
     C           *IN20     IFEQ '1'
     C                     SUB  1         X
     C           X         MULT 26        X
     C                     ENDIF
     C                     SETOF                     21
     C                     Z-ADD1         Y       30
     C           WKCHR2    LOKUPCD2,Y                    21
     C           *IN21     IFEQ '1'
     C                     SUB  1         Y
     C                     ENDIF
      *
     C           X         ADD  Y         WKNUM   30
     C                     ADD  100       WKNUM
     C                     MOVELWKNUM     PONUM
      *
     C           @LAST     TAG
     C                     SETON                     LR
     C                     RETRN
      *
** CD1
0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ
** CD2
ABCDEFGHIJKLMNOPQRSTUVWXYZ
