      *--------------------------------------------------------
      *   MAIN ROUTINE
      *--------------------------------------------------------
     C                     EXSR #OUT
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *--------------------------------------------------------
      * INITIALIZE
      *--------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#GAD     KLIST
     C                     KFLD           EKTOKU
     C                     KFLD           K@NONY  40
      *
     C                     TIME           @@TIM   60
     C                     Z-ADD*DATE     K@DATE
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     Z-ADDF8KDAT    K@DATE
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *ALL'-'   W@LINE190
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  OUTPUT
      *--------------------------------------------------------
     C           #OUT      BEGSR
      *
     C                     MOVE *OFF      *IN98
     C           K@DATE    SETLLALDPL50
     C           *IN80     DOUEQ*ON
     C                     READ ALDPL50                  80
     C           *IN80     IFEQ *OFF
     C           A5KSDT    IFGE *DATE
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVE A5OPER    K@OPER  60
     C           K@OPER    CHAINALBPL30              90
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
     C           A5ERID    IFEQ *BLANK
     C                     MOVE '01'      A5ERID
     C                     ENDIF
     C                     MOVE A5ERID    @2      20
     C                     MOVELERR,@2    W@MSG  15
TCHK2C*
TCHK2C                     MOVEL*OFF      *IN95
TCHK2C           A5SERL    IFNE *BLANK
     C           A5SERL    CHAINAB#PL71              95
TCHK2C                     ELSE
TCHK2C                     EXSR #PL70
TCHK2C                     END
TCHK2C*
     C           *IN95     IFEQ *OFF
     C                     MOVE EKNONY    K@NONY
     C                     MOVEL*BLANK    W5KMEI 15
TCHK2C           K#GAD     CHAINGADPL11              96
     C  N96                MOVELB5KMEI    W5KMEI
      *
     C                     MOVE *BLANK    WSC
     C           EKDATE    IFNE *ZERO
     C                     MOVE '*'       W@5
     C                     ENDIF
     C           A5ERID    IFEQ *BLANK
     C                     MOVE '01'      A5ERID
     C                     ENDIF
      *
     C           A5ERPS    IFEQ ' '
     C           A5ERPS    OREQ '11'
     C                     MOVE '01'      A5ERPS
     C                     ENDIF
      *
     C                     MOVE A5ERPS    @2
     C                     MOVE '*'       WSC,@2
      *
TCHK2C                     MOVELEKSERL    W@SERL 18
TCHK2C*
     C                     EXCPT@DTL
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
