     H            Y.
     F** ECQR30 **********************************
     F* HIGHEST USAGE TOOLS BY CATEGORY
     F*    FEB/06/03   TCH
     F*                                          *
     F*                                          *
     F*
     F********************************** ECQR30 **
     FECQPW30 CF  E                    WORKSTN
     F                                              KINFDS @INFDS
     FECSPL05 IF  E           K        DISK
     FECSPL10 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FGCQPL12 IF  E           K        DISK
     FECQPP01 IF  E           K        DISK
     FGDIPL27 IF  E           K        DISK
     F*GKGDDM  IF  E           K        DISK
     FECQWP30 IF  E           K        DISK                      A
     FQPRINT  O   F     132     OF     PRINTER
      *-----------------------------------------------------------
     E                    TTL     1   1 32
     E                    YM          6  6 0
      *-----------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   60D@YYMM
     I                                        1   40D@YY
     I                                        5   60D@MM
     I            DS
     I                                        1   60W@YYMM
     I                                        1   40W@Y
     I                                        5   60W@M
     I            DS
     I                                        1   60F8YYMM
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I            DS
     I                                        1   9 T6LOCT
     I                                        1   1 T6TKR1
     I I            '-'                       2   2 #AA
     I                                        3   4 T6TKR2
     I I            '-'                       5   5 #BB
     I                                        6   7 T6TKR3
     I I            '-'                       8   8 #CC
     I                                        9   9 T6TKR4
     I            DS
     I                                        1   80WTO3
     I                                        1   40GKEDYY
     I                                        5   60GKEDMM
     I                                        7   80GKEDDD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------
      *  MAIN ROUTINE
      *--------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *------------------------------------------------------
      *
     C           K#KEYY    KLIST
     C                     KFLD           K@KAT1  2
     C                     KFLD           K@KAT2  4
     C                     KFLD           K@KAT3  1
     C           K#KEY     KLIST
     C                     KFLD           T6KAT1
     C                     KFLD           T6KAT2
     C           K#KEYX    KLIST
     C                     KFLD           T6KAT1
     C                     KFLD           T6KAT2
     C                     KFLD           T6KAT3
     C                     KFLD           W@Y
     C                     KFLD           W@M
      *
     C           K#AGD     KLIST
     C                     KFLD           W@Y
     C                     KFLD           W@M
      *
     C                     MOVE '01'      W@ID    2
     C                     TIME           @@TIM   60
     C                     MOVE *ALL'-'   @@LIN  85
     C                     Z-ADD*ZERO     D@YYMM
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SCRN1    BEGSR
      *-----------------------------------------------------
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C           *INKJ     WHEQ *ON
     C                     MOVE *ON       *IN10
     C                     WRITEDSP01
     C                     CALL 'ECQR35'
     C                     MOVE *OFF      *IN10
     C                     OTHER
     C                     EXSR #CHK1
     C           *INKE     IFEQ *ON
     C           *IN99     ANDEQ*OFF
     C                     MOVE *ON       *IN10
     C                     WRITEDSP01
      *
     C                     EXSR #YM
     C                     EXSR #WRT
     C                     EXSR #OUT
     C                     MOVE '99'      W@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #CHK1     BEGSR
      *-----------------------------------------------------
     C                     SETOF                     616299
     C           D@CATG    IFEQ *BLANK
     C                     SETON                     6199
     C                     ELSE
     C           D@CATG    CHAINGCQPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ENDIF
     C                     ENDIF
      *
     C           D@YYMM    IFEQ *ZERO
     C                     SETON                     6299
     C                     ELSE
     C                     Z-ADDD@YYMM    W@YYMM
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6299
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #YM       BEGSR
      *-----------------------------------------------------
     C                     Z-ADD*ZERO     YM
     C                     Z-ADDD@YYMM    W@YYMM
     C                     SUB  5         W@M
     C           W@M       IFLE *ZERO
     C                     ADD  12        W@M
     C                     SUB  1         W@Y
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     X       30
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READ AGDPL12                  90
     C           *IN90     IFEQ *OFF
     C                     ADD  1         X
     C                     Z-ADDF8YYMM    YM,X
     C           X         IFEQ 6
     C                     LEAVE
     C                     ENDIF
     C                     Z-ADDF8YYMM    W@YYMM
     C           K#AGD     SETGTAGDPL12
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #WRT      BEGSR
      *-----------------------------------------------------
     C           D@CATG    SETLLGCQPL12
     C           *IN80     DOUEQ*ON
     C           D@CATG    READEGCQPL12                  80
     C           *IN80     IFEQ *OFF
     C           T6SKJY    ANDEQ*BLANK
      *
     C                     MOVE T6KAT1    K@KAT1
     C                     MOVE T6KAT2    K@KAT2
     C                     MOVE T6KAT3    K@KAT3
     C           K#KEYY    SETGTGCQPL12
     C           *IN82     DOUEQ*ON
     C           K#KEYY    REDPEGCQPL12                  82
     C           *IN82     IFEQ *OFF
     C           T6SKJY    ANDEQ*BLANK
      *
     C                     CLEARECQWP301
      *
     C                     MOVE T6KAT1    EQDIE1
     C                     MOVE T6KAT2    EQDIE2
     C                     Z-ADDT6KMAX    EQKAB#
     C                     Z-ADDT6SRYO    EQMONQ
     C                     MOVE T6LOCT    EQLOCT
      * INVENTORY
     C           K#KEY     SETLLECSPL10
     C           *IN81     DOUEQ*ON
     C           K#KEY     READEECSPL10                  81
     C           *IN81     IFEQ *OFF
     C           E1SKJY    ANDEQ*BLANK
     C                     ADD  E1SQTY    EQINVQ
     C                     ENDIF
     C                     ENDDO
      *
     C                     EXSR #UPR
     C                     EXSR #USG
     C                     WRITEECQWP301
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C           K#KEYY    SETGTGCQPL12
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #UPR      BEGSR
      *-----------------------------------------------------
      * UNIT PRICE
      *
     C*          K#KEYY    SETGTGKGDDM
     C*          *IN20     DOUEQ*ON
     C*          K#KEYY    REDPEGKGDDM                   20
     C*          *IN20     IFEQ *OFF
     C*          GKSKJY    ANDEQ*BLANK
     C*          WTO3      ANDGE*DATE
     C*                    Z-ADDGKNHTN    EQUPRC
     C*                    LEAVE
     C*                    ENDIF
     C*                    ENDDO
      *
     C***        *IN20     IFEQ *ON
     C           K#KEYY    SETGTECQPP01
     C           *IN20     DOUEQ*ON
     C           K#KEYY    REDPEECQPP01                  20
     C           *IN20     IFEQ *OFF
     C           ECVALD    ANDLE*DATE
     C                     Z-ADDECUPRC    EQUPRC
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C**                   ENDIF
      *
     C           *IN20     IFEQ *ON
     C           K#KEYY    SETGTGDIPL27
     C           *IN20     DOUEQ*ON
     C           K#KEYY    REDPEGDIPL27                  20
     C           *IN20     IFEQ *OFF
     C           IKSKJY    ANDEQ*BLANK
     C           IKTANK    ANDNE*ZERO
      *
     C********             Z-ADDIKTANK    EQUPRC
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #USG      BEGSR
      *-----------------------------------------------------
      * SETTING USAGE
     C                     Z-ADD*ZERO     W@USE   50
     C           1         DO   6         X
     C                     Z-ADDYM,X      W@YYMM
     C           K#KEYX    SETLLECSPL05
     C           *IN20     DOUEQ*ON
     C           K#KEYX    READEECSPL05                  20
     C           *IN20     IFEQ *OFF
     C           EQSKJY    ANDEQ*BLANK
     C           EQBMON    ANDEQ0111
      *
     C                     ADD  EQKOSU    W@USE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDDO
      *
     C           W@USE     DIV  6         EQUSAG    H
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #OUT      BEGSR
      *-----------------------------------------------------
     C                     CLOSEECQWP30
     C                     OPEN ECQWP30
     C                     MOVE *OFF      *IN98
     C                     Z-ADD*ZERO     @@RANK  30
     C                     Z-ADD*ZERO     @@USAG  51
     C           *HIVAL    SETGTECQWP30
     C           *IN80     DOUEQ*ON
     C                     READ ECQWP30                  80
     C           *IN80     IFEQ *OFF
      *
     C           EQUSAG    IFNE @@USAG
     C                     ADD  1         @@RANK
     C                     MOVE *OFF      *IN50
     C                     ELSE
     C                     MOVE *ON       *IN50
     C                     ENDIF
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C   50                MOVE *OFF      *IN50
     C                     EXCPT@HED
     C                     ENDIF
     C  N98                MOVE *ON       *IN98
      *
     C                     Z-ADDEQUSAG    @@USAG
     C                     EXCPT@DTL
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                                  110 'P.'
     O                         PAGE  Z  114
     O                         UDATE Y  123
     O                         @@TIM    132 '  :  :  '
     O        E   02           @HED
     O                         TTL,1     50
     O        E   03           @HED
     O                                   47 'AVERAGE'
     O                                   57 'CURRENT'
     O                                   67 '# OF'
     O                                   82 'MONTHLY'
     O        E   04           @HED
     O                                    4 'RANK'
     O                                   12 'TOOL#'
     O                                   24 'LOCATION'
     O                                   39 'U/PRICE(YEN)'
     O                                   47 'USAGE'
     O                                   59 'INVENTORY'
     O                                   69 'KANBANS'
     O                                   82 'SETTING'
     O        E   05           @HED
     O                         @@LIN     85
     O        E 1              @DTL
     O                      N50@@RANK1    3
     O                         EQDIE1     9
     O                                   10 '-'
     O                         EQDIE2    14
     O                         EQLOCT    25
     O                         EQUPRC1   39
     O                         EQUSAG1   47
     O                         EQINVQ1   59
     O                         EQKAB#1   69
     O                         EQMONQ1   82
**
HIGHEST USAGE TOOLS BY CATEGORY
