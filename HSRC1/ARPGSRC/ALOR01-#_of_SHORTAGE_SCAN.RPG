     C                     ENDSL
     C*
     C                     ENDSR
      *----------------------------------------------
     C           @CHK2     BEGSR
      *----------------------------------------------
     C                     SETOF                     30
     C                     MOVE *BLANK    F2ERR
      *
     C                     DO
      *
     C           B2D       IFEQ *BLANK
     C                     SETON                     30
     C                     MOVE ERR,3     F2ERR
     C                     LEAVE
     C                     END
      *
     C                     MOVELB2D       W2D
     C                     MOVELB2D       WWBRCD 18
      *
B0   C           FILR      IFEQ *BLANK
     C                     EXSR @CHK21
     C                     MOVE '1'       @D      1
     C                     ELSE
     C                     EXSR @CHK22
     C                     MOVE '2'       @D      1
E0   C                     ENDIF
      *
     C                     ENDDO
