     C                     MOVE *BLANK    F1ERR
      *
     C           F1SHFT    IFEQ '1'
     C           F1SHFT    OREQ '2'
     C           F1SHFT    OREQ '3'
     C                     ELSE
     C                     SETON                     6230
     C           F1ERR     IFEQ *BLANK
     C                     MOVELERR,1     F1ERR
     C                     END
     C                     END
     C* TM-CODE CHECK
     C           F1USRC    CHAINALBPL301             90
     C           *IN90     IFEQ *OFF
     C           ALSKJY    ANDEQ*BLANK
     C                     ELSE
     C                     SETON                     6130
     C           F1ERR     IFEQ *BLANK
     C                     MOVELERR,2     F1ERR
     C                     END
     C                     END
      *
     C                     ENDSR
     C**************************************************************************
     C           #FMT20    BEGSR
