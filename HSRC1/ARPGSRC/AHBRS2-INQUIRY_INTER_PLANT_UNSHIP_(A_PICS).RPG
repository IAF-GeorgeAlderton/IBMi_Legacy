     C           *INKH     WHEQ *ON
      *
     C                     MOVE *DATE     P#DATE  8
     C                     MOVE '-'       P#PORM  1        + OR -
     C                     MOVE '0003'    P#DAYS  4
     C                     MOVE *BLANK    P#RDAT  8
     C                     MOVE *BLANK    P#RTN   1
     C                     CALL 'DATR1A'
     C                     PARM           P#DATE
     C                     PARM           P#PORM  1        + OR -
     C                     PARM           P#DAYS  4
     C                     PARM           P#RDAT  8
     C                     PARM           P#RTN   1
      *
     C                     MOVE '1'       PQMODE
     C                     MOVE D1DATE    P#RDAT
     C                     CALL 'AJHR26'
     C                     PARM           PQMODE  1
     C                     PARM D1HIN1    PQKHN1
     C                     PARM D1HIN2    PQKHN2
     C                     PARM D1HIN3    PQKHN3
     C                     PARM           P#RDAT  8
     C* F9 *
     C           *INKI     WHEQ *ON
     C                     CALL 'AFDRS1'
     C                     PARM           D1HIN1
     C                     PARM           D1HIN2
     C                     PARM           D1HIN3
     C                     MOVE '#DSP2   '@STEP
      *
     C* F10 *
     C           *INKJ     WHEQ *ON
     C                     MOVE '2'       PXMODE
     C                     CALL 'ALDR95'
     C                     PARM           PXMODE  1
     C                     PARM           D1HIN1
     C                     PARM           D1HIN2
     C                     PARM           D1HIN3
     C                     PARM           PXUCNT  5
     C                     MOVE '#DSP2   '@STEP
      *
     C* F11 *
     C           *INKK     WHEQ *ON
     C                     EXSR ##AKAR
     C                     MOVE '#DSP2   '@STEP
     C* F12 *
     C           *INKL     WHEQ *ON
     C                     MOVE '4'       PPMODE
     C                     CALL 'AKAC31'
     C                     PARM           PPMODE  1
     C                     PARM           D1HIN1
     C                     PARM           D1HIN2
     C                     PARM           D1HIN3
     C                     MOVE '#DSP2   '@STEP
     C* F13 *
     C           *INKM     WHEQ *ON
     C                     CALL 'MBER71'
     C                     PARM           D1HIN1
     C                     PARM           D1HIN2
     C                     PARM           D1HIN3
     C                     PARM           PYYYYY  4
     C                     MOVE '#DSP2   '@STEP
     C* 73 *(ROLL UP)
     C           *IN73     WHEQ *ON
     C  N90                EXSR #SFSET
     C                     MOVE '#DSP2   '@STEP
     C           *IN74     WHEQ *ON
     C                     MOVE '#DSP2   '@STEP
     C******
     C                     OTHER
     C                     MOVE '#CHK2   '@STEP
     C                     ENDSL
      *----*
      *
     C                     ENDSR
      *===============================================================
      *画面２チェック
      *===============================================================
     C           #CHK2     BEGSR
     C                     MOVE '#DSP2   '@STEP
     C*-------------------------
S1   C                     DO   ENDRRN    RRN
     C           RRN       CHAINSFREC1               91
     C   91                LEAVE
     C                     MOVE *BLANK    P$FLG   1        1=F1,3=F3
     C           S1SEL     IFEQ '1'
     C                     CALL 'AHBR03'
     C                     PARM           S1ZENO
     C                     PARM           S1THNO
     C                     PARM           P$FLG            1=F1,3=F3
     C                     ENDIF
     C                     MOVE ' '       S1SEL
     C           S1CHYU    COMP 'R'                      41発注区分
     C                     SETOF                     9293
     C           S1IN92    IFEQ '1'
     C                     SETON                     92
     C                     END
     C           S1IN93    IFEQ '1'
     C                     SETON                     93
     C                     END
     C           S1IN94    IFEQ '1'
     C                     SETON                     94
     C                     END
     C                     UPDATSFREC1
     C           P$FLG     IFEQ '1'                        1=F1,3=F3
     C                     MOVE '#END    '@STEP
     C                     LEAVE
     C                     ENDIF
E1   C  N99                ENDDO
     C*-------------------------
     C                     ENDSR
      *===============================================================
      *          日付・時刻の編集
      *===============================================================
     C           ##EDIT    BEGSR
     C                     MOVEL*BLANK    $$DAY   5
     C                     MOVEL*BLANK    $$TIME  5
     C*
     C           W$DATE    IFNE 0
     C                     Z-ADDW$MM      $$HBMM
     C                     MOVE '.'       $$HB1
     C                     Z-ADDW$DD      $$HBDD
     C                     MOVEL$$HB      $$DAY
     C                     Z-ADDW$JJ      $$HBMM
     C                     MOVE ':'       $$HB1
     C                     Z-ADDW$FF      $$HBDD
     C                     MOVEL$$HB      $$TIME
     C                     ENDIF
     C*
     C                     MOVE '.'       $$HB1
     C                     ENDSR
      *===============================================================
      *     ...製造工程情報　の　照会...
      *===============================================================
     C           ##AKAR    BEGSR
      *
     C                     MOVE 'X'       P$SNO   1
     C                     MOVE *BLANK    P$F3    1
     C                     MOVE *BLANK    P$ERR   1
      *-------------------------
     C                     DO   *HIVAL
     C                     MOVE P$SNO     P$NO
     C                     CALL 'AKAR27'
     C                     PARM           P$F3    1
     C                     PARM           P$ERR   1
     C                     PARM D1HIN     P$HIN  12
     C                     PARM           P$NO    1
     C*
     C           P$F3      IFEQ '1'
     C           P$ERR     ORNE *BLANK
     C                     LEAVE
     C                     ENDIF
      *
     C                     CALL 'AKAR28'
     C                     PARM           P$F3
     C                     PARM           P$SNO   1
     C                     PARM           P$ERR   1
     C                     PARM D1HIN1    P$SHN1  5
     C                     PARM D1HIN2    P$SHN2  5
     C                     PARM D1HIN3    P$SHN3  2
     C*
     C           P$F3      IFEQ '1'
     C           P$ERR     ORNE *BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *-------------------------
      *
     C           P$ERR     IFEQ 'E'
     C                     SETON                       99
     C                     MOVELER,8      D2ERR
     C                     ENDIF
      *
     C           P$ERR     IFEQ '9'
     C                     SETON                       99
     C                     MOVELER,9      D2ERR
     C                     ENDIF
     C*
     C                     ENDSR
      *-----------------------------------------------------
     C           #OQ       BEGSR
      *
     C                     MOVE *BLANK    W@OQ    3
      *
     C                     MOVEL*BLANK    PQBAN1  1
     C                     MOVEL*BLANK    PQBAN2  2
     C                     MOVEL*BLANK    PQBAN3  2
     C                     MOVEL*BLANK    PQBAN4  1
     C                     MOVEL*BLANK    PQBMON  4
     C                     MOVEL'OQ '     PQKOTE  3
     C                     MOVEL*BLANK    PQKIBN  3
     C                     MOVEL*BLANK    PQKHIN 12
      *
     C                     CALL 'AAMRS9'  AAMRS9
     C           AAMRS9    PLIST
     C                     PARM           D1HIN1
     C                     PARM           D1HIN2
     C                     PARM           D1HIN3
     C                     PARM           PQBAN1  1
     C                     PARM           PQBAN2  2
     C                     PARM           PQBAN3  2
     C                     PARM           PQBAN4  1
     C                     PARM           PQBMON  4
     C                     PARM           PQKOTE  3
     C                     PARM           PQKIBN  3
     C                     PARM           PQKHIN 12
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'OQ '     W@OQ
     C                     GOTO EOQ
     C                     END
      *
     C                     MOVEL'LOQ'     PQKOTE  3
     C                     CALL 'AAMRS9'  AAMRS9
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'LOQ'     W@OQ
     C                     GOTO EOQ
     C                     END
      *
     C           EOQ       ENDSR
      *-----------------------------------------------------
     C           #LAN      BEGSR
      *
     C                     MOVE *BLANK    W@LAN   3
      *
     C                     MOVEL*BLANK    PQBAN1  1
     C                     MOVEL*BLANK    PQBAN2  2
     C                     MOVEL*BLANK    PQBAN3  2
     C                     MOVEL*BLANK    PQBAN4  1
     C                     MOVEL*BLANK    PQBMON  4
     C                     MOVEL'LAN'     PQKOTE  3
     C                     MOVEL*BLANK    PQKIBN  3
     C                     MOVEL*BLANK    PQKHIN 12
      *
     C                     CALL 'AAMRS9'  AAMRS9
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'LAN'     W@LAN
     C                     GOTO ELAN
     C                     END
      *
     C                     MOVEL'AOQ'     PQKOTE  3
     C                     CALL 'AAMRS9'  AAMRS9
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'AOQ'     W@LAN
     C                     GOTO ELAN
     C                     END
      *
     C           ELAN      ENDSR
      *-----------------------------------------------------
     C           #SB       BEGSR
      *
     C                     MOVE *BLANK    W@SB    3
      *
     C                     MOVEL*BLANK    PQBAN1  1
     C                     MOVEL*BLANK    PQBAN2  2
     C                     MOVEL*BLANK    PQBAN3  2
     C                     MOVEL*BLANK    PQBAN4  1
     C                     MOVEL*BLANK    PQBMON  4
     C                     MOVEL'SB '     PQKOTE  3
     C                     MOVEL*BLANK    PQKIBN  3
     C                     MOVEL*BLANK    PQKHIN 12
      *
     C                     CALL 'AAMRS9'  AAMRS9
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'SB '     W@SB
     C                     GOTO ESB
     C                     END
      *
     C                     MOVEL'KRO'     PQKOTE  3
     C                     CALL 'AAMRS9'  AAMRS9
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'KRO'     W@SB
     C                     GOTO ESB
     C                     END
      *
     C           ESB       ENDSR
      *===============================================================
     C           #ST       BEGSR
      *
     C                     MOVE *BLANK    W@ST    3
      *
     C                     MOVEL*BLANK    PQBAN1  1
     C                     MOVEL*BLANK    PQBAN2  2
     C                     MOVEL*BLANK    PQBAN3  2
     C                     MOVEL*BLANK    PQBAN4  1
     C                     MOVEL*BLANK    PQBMON  4
     C                     MOVEL'BZ '     PQKOTE  3
     C                     MOVEL*BLANK    PQKIBN  3
     C                     MOVEL*BLANK    PQKHIN 12
      *
     C                     CALL 'AAMRS9'  AAMRS9
     C           PQKHIN    IFNE *BLANK
     C                     MOVEL'BZ '     W@ST
