      *             'XXXXXXXXXXXXXXXXXXXX'C         $$SIW2
     C           *ENTRY    PLIST
     C                     PARM           P@MODE  1
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
      *================================================================
     C           KEY01     KLIST
     C                     KFLD           D1HIN1
     C                     KFLD           D1HIN2
     C                     KFLD           D1HIN3
     C*
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#D2SET  '#D2SET
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      * 初期ﾈｮmb
      *===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
      *
     C           P@MODE    IFEQ '1'
     C                     SETON                     35
     C                     END
      *
     C                     CLEARDSP01
     C                     TIME           @TIME
     C                     Z-ADD@SYSHZ    $$YMD
     C                     Z-ADD1         $$DD
     C                     Z-ADD$$YMD     D1DATE
     C                     Z-ADD1         D1BIN
     C*
     C                     MOVE D1DATE    QQDATE  8
     C                     MOVE '-'       QQPORM  1        + OR -
     C                     MOVE '0010'    QQDAYS  4
     C                     MOVE *BLANK    QQRDAT  8
     C                     MOVE *BLANK    QQRTN   1
     C                     CALL 'DATR1A'
     C                     PARM           QQDATE  8
     C                     PARM           QQPORM  1        + OR -
     C                     PARM           QQDAYS  4
     C                     PARM           QQRDAT  8
     C                     PARM           QQRTN   1
     C*
     C                     MOVE QQRDAT    D1DATE
     C*
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
     C*===============================================================
      *画面１*
     C*===============================================================
     C           #DSP1     BEGSR
     C                     EXFMTDSP01
     C                     MOVEA'00'      *IN,01
     C                     MOVEA'0'       *IN,99
      *----*
     C                     SELEC
     C* F1 *
     C           *INKA     WHEQ *ON
     C                     MOVE '#END    '@STEP
     C******
     C                     OTHER
     C                     MOVE '#CHK1   '@STEP
     C                     ENDSL
      *----*
     C                     ENDSR
     C*===============================================================
      *画面１チェック
     C*===============================================================
     C           #CHK1     BEGSR
      *...社内品番(01)
     C           D1HIN1    IFEQ *BLANK
     C           D1HIN2    ANDEQ*BLANK
     C           D1HIN3    ANDEQ*BLANK
     C                     SETON                     0199
     C                     MOVELER,1      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
     C*
     C           KEY01     CHAINFCEPL01              91
     C  N91      A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     91
     C                     ENDIF
     C           *IN91     IFEQ *ON
     C                     SETON                     0199
     C                     MOVELER,2      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
      *
      *...日付・便(02)
     C                     MOVELD1DATE    P$DATE
     C                     CALL 'DATR10'
     C                     PARM           P$DATE  8
     C                     PARM           P$RTN   1
     C           P$RTN     IFEQ '1'
     C                     SETON                     0299
     C                     MOVELER,3      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
     C*
     C           D1BIN     IFLT 01
     C           D1BIN     ORGT 24
     C                     SETON                     0299
     C                     MOVELER,4      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
     C*********************
     C                     SETOF                     59     (BL)
     C*********************
      *
      *社内かんばん切り替えマスタ
     C           KEY01     CHAINAAMPL11              91
     C  N91      CKSKJY    IFEQ 'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     91
     C                     ENDIF
     C           *IN91     IFEQ *ON
     **   E-03工程切替えマスターが存在しない
     C                     SETON                     0199
     C                     MOVELER,5      D1ERR
     C                     GOTO @CHK1
     C                     ENDIF
      *
     C           @CHK1     TAG
     C           *IN99     IFEQ *OFF
     C                     MOVE '#D2SET  '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C                     ENDSR
      *===============================================================
      *===============================================================
     C           #D2SET    BEGSR
     C*         手配名称
     C                     MOVEL*BLANK    D2TEHM
     C                     SELEC
     C           A2TEHI    WHEQ 'Z'
     C                     MOVEL'LIMIT '  D2TEHM           限定
     C           A2TEHI    WHEQ 'S'
     C                     MOVEL'TRIAL '  D2TEHM           試作
     C           A2TEHI    WHEQ 'G'
     C                     MOVEL'VOLUM '  D2TEHM           号口
     C                     ENDSL
      *収容数切替日
     C           A2SYHZ    IFLE *DATE
     C                     Z-ADDA2SSYS    D2SYSU  50       新収容数
     C                     ELSE
     C                     Z-ADDA2KSYS    D2SYSU           旧収容数
     C                     ENDIF
      *日当箱数
     C           A2GEKN    DIV  20        W$HIS   90       日当数量
     C           W$HIS     DIV  D2SYSU    HAKO      H      日当数量
     C*
     C                     MOVEL*BLANK    @KT              旧製造工程
     C                     Z-ADD0         @BM              旧製造部門
     C                     MOVEL*BLANK    @HN              旧工程内品番
     C                     MOVEL*BLANK    @KB              旧引当機番
     C                     MOVEL*BLANK    @BN              旧所番地
     C                     MOVEL*BLANK    @KS              旧かんばん種類
     C                     Z-ADD0         @HZ              切替日・便
     C*
S1   C           1         DO   15        A       20
     C           KHZ,A     IFNE 0
     C                     MOVELKHZ,A     $CHKDT  80       1
     C                     MOVELKQK,A     @KT,A            旧製造工程
     C                     MOVELKQB,A     @BM,A            旧製造部門
     C                     MOVELKQH,A     @HN,A            旧工程内品番
     C                     MOVELKQN,A     @KB,A            旧引当機番
     C                     MOVELKQT,A     @BN,A            旧所番地
     C                     MOVELKQS,A     @KS,A            旧かんばん種類
     C                     MOVELKHZ,A     @HZ,A            切替日・便
     C           *DATE     IFGE $CHKDT
     C                     MOVELKKO,A     @KT,A            製造工程
     C                     MOVELKBM,A     @BM,A            製造部門
     C                     MOVELKHB,A     @HN,A            工程内品番
     C                     MOVELKKB,A     @KB,A            引当機番
     C                     MOVELKNB,A     @BN,A            所番地
     C                     MOVELKTY,A     @KS,A            かんばん種類
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
      *最終工程から前の６工程と表示
      *
     C                     MOVE *BLANK    DKT              工程
     C                     Z-ADD0         DBM              部門
     C                     MOVEL*BLANK    DNM
     C                     MOVEL*BLANK    DKB              機番
     C                     MOVEL*BLANK    DBN              番地
     C                     MOVEL*BLANK    DHN              品番
     C                     Z-ADD0         DHZ              切替日
     C                     Z-ADD6         B       20
     C                     Z-ADD15        C       20
     C                     MOVE *BLANK    LAST
     C*-------------------------
S1   C           1         DO   15        A       20
