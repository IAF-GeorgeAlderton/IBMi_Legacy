     H            Y.
     F***CHKR61K ***************************************************************
     F*  PROGRAM    : CHECK FORD DELIVERY CODE = 0000 REPORT                   *
     F*  WRITTEN    : 2023.02.03                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#PLF1 IF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
     E                    MSG     1   1 60
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        7  100@YEAR
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           @FROM     SETLLAB#PLF1
      *
     C                     DO   *HIVAL
     C                     READ AB#PLF1                  98
     C   98                LEAVE
      * IGNORE
     C           F5QTY     IFEQ 0
     C           F5NONY    ORNE 0
     C                     ITER
     C                     ENDIF
      * PRINT
     C                     EXSR #PRINT
     C                     ENDDO
      *
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ELSE
     C                     EXCPT@MSG
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      * GET CUSTOMER NAME
     C                     MOVELF5NONY    $DLV
     C                     CALL 'UTLR62'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTNX   1
     C                     MOVEL$NAME1    XNAME  15
      *
     C                     MOVELF5IPAR    XMHIN  15
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
      *
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     MOVE ' '       $RTN
      * FROM = TODAY - 8
     C                     MOVELTODAY     $DT8
     C                     MOVE '-'       $SIGN
     C                     MOVE '0002'    $DAYS
     C                     MOVE 'N'       $IAF
     C                     CALL 'UTLR10'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN    1
     C                     MOVEL$TGT8     @FROM   80
      *
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** FORD DELIVERY COD'
     O                                   60 'E=0000 ERROR REPORT '
     O                                   80 '**                  '
     O                                   78 'DATE'
     O                         TODAY     81 '    .  .  '
     O                         NOW       91 '  :  :  '
     O                                   95 'P.'
     O                         PAGE  Z   99
     O        E   02           @HDR
     O                                   40 '   (PLAESE CHECK THE'
     O                                   60 ' FORD ROUTE MASTER) '
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   15 'RCV_DATE'
     O                                   23 'TIME'
     O                                   33 'PLANT'
     O                                   39 'DLV#'
     O                                   45 'NAME'
     O                                   62 'DOCK'
     O                                   69 'IC_CD'
     O                                   76 'PART#'
     O                                   97 'SHIP_DATE'
     O                                  110 'QTY'
      *
     O        E 1              @DTL
     O                         SEQ#  1 +000
     O                         F5DATE  +002 '    /  /  '
     O                         F5TIME  +001 '0 :  :  '
     O                         F5STID  +002
     O                         F5NONY  +002
     O                         XNAME   +002
     O                         F5NUKE  +002
     O                         F5STFC  +002
     O                         XMHIN   +002
     O                         F5NOHZ  +001 '     /  /  '
     O                         F5QTY 1 +002
      *
     O        E 1              @MSG
     O                                 +001 '.'
     O        E 1              @MSG
     O                         MSG,1   +001
      *
** MSG(60A)
 ** THERE IS NO ERROR **
