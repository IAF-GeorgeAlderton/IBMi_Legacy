     C           *ENTRY    PLIST
     C                     PARM           PYYYY   40
     C                     PARM           PMM     20
     C                     PARM           PUSR   10
     C                     PARM           PPDAY   20
     C                     PARM           PNDAY   20
      *
     C                     SETOF                     50
      *
     C           *IN51     IFEQ '0'
     C                     SETON                     5051
     C                     TIME           WTIME   60
     C*
     C* GET SYSTEM MONTH NAME
     C                     Z-ADD1         A       20
     C                     TIME           WWTIME
     C           WPMM      LOKUPTB1,A                    20
     C           *IN20     IFEQ '1'
     C                     MOVELTB2,A     WPNAM   3
     C                     END
     C*
     C* GET ISSUE MONTH NAME
     C                     Z-ADD1         B       20
     C           PMM       LOKUPTB1,B                    20
     C           *IN20     IFEQ '1'
     C                     MOVELTB2,B     WNNAM   3
     C                     END
     C*
     C                     END
      *
     C                     ADD  W6PQTY    TPQTY   90
     C                     ADD  W6AQTY    TAQTY   90
     C                     ADD  W6SIZE    TSIZE   70
     C                     ADD  W6SYOS    TSYOS   50
     C                     ADD  W6PLOT    TPLOT   30
     C                     ADD  W6#KAN    T#KAN   50
      *
     C                     ADD  W6PQTY    LPQTY   90
     C                     ADD  W6AQTY    LAQTY   90
     C                     ADD  W6SIZE    LSIZE   70
     C                     ADD  W6SYOS    LSYOS   50
     C                     ADD  W6PLOT    LPLOT   30
     C                     ADD  W6#KAN    L#KAN   50
