     H            Y.
     F** UTLR78E **********************************************
     F*  PROGRAM: UTILITY- GET DAILY SHIP VOLUME (BY ABHPP01) *
     F*  V03 : ADD $MSET2, $DSV2, $DSVQ2
     F*  V04 : ADD $FLOC1, $FLOC2
     F*  ABHPP01: INTRA-PROCESS KANBAN M/F (KOTEINAI)         *
     F*  WRITTEN: JW (SRA) 2021.07.16                         *
     F*-------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR78D'
     F*                    PARM           $SHIN  12
     F*                    PARM           $ZETI   4
     F*                    PARM           $FPRC   3
JW   F*                    PARM           $FDPT   40
     F*                    PARM           $FMCN   3
     F*                    PARM           $FLOC1  6
     F*                    PARM           $FLOC2  6
     F*                    PARM           $FSIZE  3
     F*                    PARM           $LLOC   6
     F*                    PARM           $QPC    60
     F*                    PARM           $MSET   90
     F*                    PARM           $DSVB   61
     F*                    PARM           $DSVQ   80
V03  F*                    PARM           $MSET2  90
 .   F*                    PARM           $DSVB2  61
V03  F*                    PARM           $DSVQ2  80
     F*                    PARM           $RTN    1
     F*  IN  $SHIN : 12A  IAF PART
     F*  OUT $ZETI :  4A  PERT ID
     F*      $FPRC :  3A  FIRST PROCESS
JW   F*      $FDPT :  4,0 FIRST DEPT
     F*      $FMCN :  3A  FIRSTLMACHINE
V04  F*      $FLOC1:  6A  FIRST LOCATION11(PHYSICAL)
V04  F*      $FLOC2:  6A  FIRST LOCATION2 (IGNORE ----)
     F*      $FSIZE:  3A  FIRST MACHINE SIZE
     F*      $LLOC :  6A  LAST LOCATION
     F*      $QPC  :  6,0 Q/C
     F*      $MSET :  9,0 MONTHLY SET QTY
     F*      $DSVB :  6,1 DAILY SHIP VOLUME (BOX)
     F*      $DSVQ :  8,0 DAILY SHIP VOLUME (QTY)
V03  F*      $MSET2:  9,0 (FIRST SET) MONTHLY SET QTY
V03  F*      $DSVB2:  6,1 (FIRST SET) DAILY SHIP VOLUME (BOX)
V03  F*      $DSVQ2:  8,0 (FIRST SET) DAILY SHIP VOLUME (QTY)
     F*      $RTN  :  1A  RETURN CODE (BLANK/*)
     F******************************************************
     FAAMPL11 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FABBPP7G IF  E           K        DISK
V03  FGHCPL29 IF  E           K        DISK
      *===================================================
     E                    LOC         8  6
      * LOCATION
     I            DS
     I                                        1  48 LOC
     I                                        1   6 $LOC1
     I                                        7  12 $LOC2
     I                                       13  18 $LOC3
     I                                       19  24 $LOC4
     I                                       25  30 $LOC5
     I                                       31  36 $LOC6
     I                                       37  42 $LOC7
     I                                       43  48 $LOC8
      * SYSTEM DATE
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      * KEY FIELDS
     I            DS
     I                                        1  12 K#SHN
     I                                        1   5 K#SHN1
     I                                        6  10 K#SHN2
     I                                       11  12 K#SHN3
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      * READ AAMPL11
     C           K#PL01    CHAINAAMPL11              99
     C           *IN99     IFEQ *ON
     C                     MOVE '*'       $RTN
     C                     GOTO ENDP
     C                     ENDIF
      * READ FCEPP01
     C           K#PL01    CHAINFCEPL01              99
     C           *IN99     IFEQ *ON
     C                     MOVE '*'       $RTN
     C                     GOTO ENDP
     C                     ENDIF
      *
     C                     MOVELCKKO01    $FPRC
JW   C                     Z-ADDCKBM01    $FDPT
     C                     MOVELCKKB01    $FMCN
     C                     Z-ADDA2GEKN    $MSET
     C                     MOVELA2ZETI    $ZETI
      * GET FINAL LOCATION
     C                     MOVEL$SHIN     P@SHIN
     C                     CALL 'UTLR21'
     C                     PARM           P@SHIN 12
     C                     PARM           $LLOC   6
     C                     PARM           $LQC    50
     C                     PARM           $LPRC   3
     C                     PARM           $LDPT   40
     C                     PARM           $ZETI   4
     C                     PARM           $RTNX   1
     C                     MOVEL$LLOC     $LLOC
     C                     Z-ADD$LQC      $QPC
      * CHECK QPC
     C           $LLOC     IFEQ *BLANK
     C           $QPC      OREQ 0
     C                     MOVE '*'       $RTN
     C                     GOTO ENDP
     C                     ENDIF
      * GET SIZE
     C           $FMCN     SETLLABBPP7G
     C                     DO   *HIVAL
     C           $FMCN     READEABBPP7G                  98
     C   98                LEAVE
      *
     C           A#SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELA#SIZE    $FSIZE
     C                     LEAVE
     C                     ENDDO
      * GET LOCATION
V04  C                     MOVELTODAY     $DATE
     C                     CALL 'UTLR21L'
     C                     PARM           $SHIN  12
     C                     PARM           $DATE   8
     C                     PARM           $LOC1   6
     C                     PARM           $LOC2   6
     C                     PARM           $LOC3   6
     C                     PARM           $LOC4   6
     C                     PARM           $LOC5   6
     C                     PARM           $LOC6   6
     C                     PARM           $LOC7   6
     C                     PARM           $LOC8   6
     C                     PARM           $RTNX   1
      *
     C           1         DO   8         IX      20
     C                     MOVELLOC,IX    LTR1    1
     C           LTR1      IFEQ ' '
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVELLOC,IX    $FLOC1
     C           LTR1      IFNE '-'
     C                     MOVELLOC,IX    $FLOC2
     C                     ENDIF
     C                     ENDDO
      * CHECK LOCATION
     C           $FMCN     IFEQ *BLANK
     C           $FLOC2    IFEQ '1N6610'
     C                     MOVEL'NUT'     $FSIZE
     C                     ELSE
     C                     MOVE *BLANK    $FSIZE
     C                     ENDIF
     C                     ENDIF
      *
     C**         $FSIZE    IFEQ *BLANK
     C**                   MOVE '*'       $RTN
     C**                   GOTO ENDP
     C**                   ENDIF
      * GET DAILY SHIPPING VOLUME
     C           $MSET     DIV  20        $DSVQ     H
     C           $DSVQ     DIV  $QPC      $DSVB     H
V03   * READ GHCPL29
     C                     Z-ADD01        K#SEQ
     C           K#PL29    CHAINGHCPL29              99
     C           *IN99     IFEQ *ON
     C                     MOVE '*'       $RTN
     C                     GOTO ENDP
     C                     ENDIF
      *
     C                     Z-ADDM7SRYO    $MSET2
V03   * GET DAILY SHIPPING VOLUME
 .   C           $MSET2    DIV  20        $DSVQ2    H
V03  C           $DSVQ2    DIV  $QPC      $DSVB2    H
      *
     C           ENDP      TAG
     C                     SETON                     LR
     C                     RETRN
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SHIN  12
     C                     PARM           $ZETI   4
     C                     PARM           $FPRC   3
JW   C                     PARM           $FDPT   40
     C                     PARM           $FMCN   3
     C                     PARM           $FLOC1  6
     C                     PARM           $FLOC2  6
     C                     PARM           $FSIZE  3
     C                     PARM           $LLOC   6
     C                     PARM           $QPC    60
     C                     PARM           $MSET   90
     C                     PARM           $DSVB   61
     C                     PARM           $DSVQ   80
V03  C                     PARM           $MSET2  90
V03  C                     PARM           $DSVB2  61
V03  C                     PARM           $DSVQ2  80
     C                     PARM           $RTN    1
      *
      *
     C           K#PL01    KLIST
     C                     KFLD           K#SHN1  5
     C                     KFLD           K#SHN2  5
     C                     KFLD           K#SHN3  2
      *
     C           K#PL29    KLIST
     C                     KFLD           K#SHN1
     C                     KFLD           K#SHN2
     C                     KFLD           K#SHN3
     C                     KFLD           K#SEQ   20
      * SYSTEM DATE
     C                     TIME           SDATE
     C                     MOVEL$SHIN     K#SHN
     C                     MOVE *BLANK    $ZETI
     C                     MOVE *BLANK    $FPRC
     C                     Z-ADD0         $FDPT
     C                     MOVE *BLANK    $FMCN
V04  C                     MOVE *BLANK    $FLOC1
V04  C                     MOVE *BLANK    $FLOC2
     C                     MOVE *BLANK    $FSIZE
     C                     MOVE *BLANK    $LLOC
     C                     Z-ADD0         $QPC
     C                     Z-ADD0         $MSET
     C                     Z-ADD0         $DSVB
     C                     Z-ADD0         $DSVQ
     C                     Z-ADD0         $MSET2
V03  C                     Z-ADD0         $DSVB2
V03  C                     Z-ADD0         $DSVQ2
     C                     MOVE *BLANK    $RTN
      *
     C                     ENDSR
