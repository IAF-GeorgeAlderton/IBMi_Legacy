     H            Y.
     F* TMPR02C ************************************************
     F* ASSIGN IAF# BY UPD_DATE IN PP10                        *
     F* JW   2022.11.14                                        *
     F**********************************************************
     FAB#PL1U UF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *
     I            DS
     I                                        1   80BAKOHZ
     I                                        1   40BAKOYY
     I                                        5   60BAKOMM
     I                                        7   80BAKODD
     I            DS
     I                                        1   40BAKOTM
     I                                        1   20BAKOHH
     I                                        3   40BAKOSS
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ****************
      * MAIN ROUTINE *
      ****************
     C                     EXSR #INIT
      *
     C           *LOVAL    SETLLAB#PL1U
      *
     C                     DO   *HIVAL
     C                     READ AB#PL1U                  98
     C   98                LEAVE
      *
     C           BAIAF#    IFNE 0
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVELBAKOHZ    ¥DATE
     C                     MOVE 'Y'       ¥UPD
     C                     CALL 'UTLR56C'
     C                     PARM           ¥DATE   8
     C                     PARM           ¥UPD    1
     C                     PARM           ¥IAF#  10
     C                     MOVEL¥IAF#     BAIAF#
      *
     C                     UPDATAB#PP101
     C**                   MOVEL'UPDATED' XMSG    8
     C**                   EXSR #PRINT
      *
     C                     ENDDO
      *
     C           SEQ#      IFEQ 0
     C                     EXCPT@FOOT
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      * DETAIL
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      **************
      * INIT
      **************
     C           #INIT     BEGSR
      *
     C                     TIME           SDATE
      *
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     MOVE *BLANK    XMSG    8
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   14 'UPD='
     O                         ¥UPD      15
     O                                   45 '** ASSIGN IAF PO# BY'
     O                                   65 ' UPD_DATE IN PP10 **'
     O                                   85 '                    '
     O                                  106 'DATE'
     O                         TODAY    109 '    .  .  '
     O                         NOW      119 '  :  :  '
     O                                  122 'P.'
     O                         PAGE  Z  126
     O        E   02           @HDR
     O                                    1 '.'
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   15 'CRT_DATE'
     O                                   25 'CRT_TIME'
     O                                   30 'CUST'
     O                                   35 'DELV'
     O                                   47 'MHIN'
     O                                   70 'PO#'
     O                                   87 'SHIP_DATE'
     O                                  100 'DELV_DATE'
     O                                  110 'IAF_PO#'
     O        E 1              @HDR
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O        E 1              @DTL
     O                         SEQ#    +001
     O                         BAKOHZ  +001 '    /  /  '
     O                         BAKOTM  +001 '0 :  '
     O                         BATOKU  +004
     O                         BANONY  +001
     O                         BANKOJ  +001
     O                         BANUKE  +001
     O                         BAMHN1  +001
     O                         BAMHN2  +001
     O                         BAMHN3  +001
     O                         BAMHN4  +001
     O                         BAODRN  +001
     O                         BANOYY  +001
     O                         BANOMM  +001
     O                         BANODD  +001
     O                         BANOBN  +001
     O                         BADEYY  +001
     O                         BADEMM  +001
     O                         BADEDD  +001
     O                         BAIAF#  +001
     O                         XMSG    +001
      *
     O        E 1              @FOOT
     O                                 +001 '*NO DATA TO BE UPDATED*'
