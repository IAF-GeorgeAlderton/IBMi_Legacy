     H            Y/                                    1
     **** AB#R9Y5 *****************************************************
     **  PC USER ASSIGHNED CUSTOMER MAINTENANCE                       *
     **  JW    2019.10.21                                             *
     ******************************************************************
     FAB#PW9Y5CF  E                    WORKSTN
     F                                              KINFDS WSDS
     FAB#PLY9 UF  E           K        DISK                      A
     **==============================================================**
     E                    @SL     1   3  6                SELECT
     E                    @MS     1   6 53                ERR MSG
     **==============================================================**
     I            DS
     I                                        1  140S@TIME
     I                                        1   60S@HMS
     I                                        1   20S@TMHH
     I                                        3   40S@TMMM
     I                                        5   60S@TMSS
     I                                        7  140S@YYMD
     I                                        7  100S@DYYY
     I                                       11  120S@DYMM
     I                                       13  140S@DYDD
     IWSDS        DS
     I                                    B 370 3710S@CUR
     I                                      370 370 S@LIN
     I                                      371 371 S@COL
     I                                    B 378 3790S@POS
     I            DS
     I                                        1   8 W@SEL
     I                                        1   1 W@SEL1
     I                                        2   2 W@HF
     I                                        3   8 W@SEL2
     I           SDS
     I                                     *PROGRAM S@PGID
     I                                      244 253 S@WSID
     I                                      254 263 S@USID
     I                                      264 269 S@JBID
     **==============================================================**
     **                    MAIN ROUTINE                              **
     **==============================================================**
      *
     C                     EXSR #INIT
      *
     C           W@NEXT    DOUEQ'END  '
      * SCREEN1
     C           W@NEXT    CASEQ'SET10'   #SET10
     C           W@NEXT    CASEQ'PNL10'   #PNL10
     C           W@NEXT    CASEQ'CHK10'   #CHK10
      * SCREEN2
     C           W@NEXT    CASEQ'SET20'   #SET20
     C           W@NEXT    CASEQ'PNL20'   #PNL20
     C           W@NEXT    CASEQ'CHK20'   #CHK20
      *
     C           W@NEXT    CASEQ'DBOUT'   #DBOUT
     C                     END
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-------------------------------------------------------------------------
      * SET INITIAL VALUE FOR SCREEN1
      *-------------------------------------------------------------------------
     C           #SET10    BEGSR
      *
     C                     SETOF                     909192
     C                     SETOF                     4142
     C                     SETOF                     99
      *
     C                     MOVEL*BLANK    D1SEL
     C                     MOVEL*BLANK    D1NONY
     C                     MOVEL*BLANK    D1MSG
      *
      * NEXT-CONTROL
     C                     MOVEL'PNL10'   W@NEXT           G1-PNL
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      * SCREEN1 PROCESS
      *-------------------------------------------------------------------------
     C           #PNL10    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SETOF                     909192
     C                     SETOF                     4142
     C                     SETOF                     99
     C                     MOVEL*BLANK    D1MSG            * ERR MSG
      *
      * F03: END
     C           *INKA     IFEQ *ON
     C                     MOVEL'END  '   W@NEXT
     C                     GOTO XPNL10
     C                     ENDIF
      * F12: INQ
     C           *INKL     IFEQ *ON
     C                     CALL 'AB#R9Y6'
     C                     MOVEL'PNL10'   W@NEXT
     C                     GOTO XPNL10
     C                     ENDIF
      * ENTER
     C                     MOVEL'CHK10'   W@NEXT
      *
     C           XPNL10    ENDSR
      *-------------------------------------------------------------------------
      *  CHECK FIELDS OF SCREEN1
      *-------------------------------------------------------------------------
     C           #CHK10    BEGSR
      *
     C           D1SEL     IFNE '0'
     C           D1SEL     ANDNE'1'
     C           D1SEL     ANDNE'2'
     C  N99                MOVEL@MS,01    D1MSG     P
     C  N99                SETON                     4199
     C                     GOTO XCHK10
     C                     ENDIF
      *
     C                     SELEC
     C           D1SEL     WHEQ '0'
     C                     SETON                     90
     C           D1SEL     WHEQ '1'
     C                     SETON                     91
     C           D1SEL     WHEQ '2'
     C                     SETON                     92
     C                     ENDSL
      *
     C           D1NONY    IFEQ *ZERO
     C  N99                MOVEL@MS,02    D1MSG     P
     C  N99                SETON                     4299
     C                     GOTO XCHK10
     C                     ENDIF
      *
     C           D1NONY    CHAINAB#PLY9             N80
      *
      * DELETE, UPDATE
     C           *IN80     IFEQ *ON
     C           D1SEL     IFEQ '0'
     C           D1SEL     OREQ '1'
     C                     MOVEL@MS,03    D1MSG     P
     C                     SETON                     4299
     C                     GOTO XCHK10
     C                     ENDIF
     C                     ENDIF
      *
      * ADD
     C           *IN80     IFEQ *OFF
     C           D1SEL     ANDEQ'2'
     C                     MOVEL@MS,04    D1MSG     P
     C                     SETON                     4299
     C                     GOTO XCHK10
     C                     ENDIF
      *
      * NEXT-CONTROL
     C           XCHK10    TAG
     C           *IN99     IFEQ *ON
     C                     MOVEL'PNL10'   W@NEXT
     C                     ELSE
     C                     MOVEL'SET20'   W@NEXT
     C                     ENDIF
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      * SET INITIAL VALUE OF SCREEN2
      *-------------------------------------------------------------------------
     C           #SET20    BEGSR
      *
     C                     SETOF                     5499
      *
     C                     MOVEL*BLANK    D2MSG
     C                     MOVEL*BLANK    D2USER
      * SET UPD TITLE
     C                     MOVELD1SEL     W@SEL1
     C                     MOVEL'-'       W@HF
     C                     SELEC
     C           D1SEL     WHEQ '0'
     C                     MOVEL@SL,01    W@SEL2
     C           D1SEL     WHEQ '1'
     C                     MOVEL@SL,02    W@SEL2
     C           D1SEL     WHEQ '2'
     C                     MOVEL@SL,03    W@SEL2
     C                     ENDSL
     C                     MOVELW@SEL     D2SEL
      * IF UPD=CHANGE/DELETE
     C           D1SEL     IFEQ '0'
     C           D1SEL     OREQ '1'
     C                     MOVELUAUSER    D2USER
     C                     ENDIF
      *
      * NEXT-CONTROL
     C                     MOVEL'PNL20'   W@NEXT
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *  SCREEN2 PROCESS
      *-------------------------------------------------------------------------
     C           #PNL20    BEGSR
      *
     C                     EXFMTDSP02
      *
     C                     SETOF                     5499
     C                     MOVEL*BLANK    D2MSG            * ERR MSG
      *
      * NEXT-CONTROL
     C                     MOVEL'CHK20'   W@NEXT
      * IF F3
     C           *INKC     IFEQ *ON
     C           *INKL     OREQ *ON
     C                     MOVEL'PNL10'   W@NEXT
     C                     ENDIF
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *  CHECK FILEDS OF SCREEN2
      *-------------------------------------------------------------------------
     C           #CHK20    BEGSR
      *
      *    CHECK USER ID
     C           D2USER    IFEQ *BLANK
     C  N99                MOVEL@MS,5     D2MSG     P
     C  N99                SETON                     5499
     C                     GOTO SKIP2
     C                     ENDIF
      *
      * NEXT-CONTROL
     C           SKIP2     TAG
     C                     MOVEL'PNL20'   W@NEXT
      * IF F5
     C           *IN05     IFEQ '1'
     C           *IN99     ANDEQ'0'
     C                     MOVEL'DBOUT'   W@NEXT
     C                     ENDIF
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *  UPDATE RECORD
      *-------------------------------------------------------------------------
     C           #DBOUT    BEGSR
      *
     C                     TIME           S@TIME
      *
     C           D1NONY    CHAINAB#PLY9              80
      *
      * DELETE
     C           D1SEL     IFEQ '0'
      *
     C           *IN80     IFEQ *OFF
     C                     EXSR #DEL10
     C                     ENDIF
      *
     C                     ELSE
      * ADD / CHANGE
     C           *IN80     IFEQ *OFF
      * ADD(UPDAT)
     C           D1SEL     IFEQ '2'
     C                     EXSR #WRT11
     C                     ENDIF
      * CHANGE
     C           D1SEL     IFEQ '1'
     C                     EXSR #UPD10
     C                     ENDIF
      *
     C                     ELSE
      * ADD(WRITE)
     C                     EXSR #WRT10
     C                     ENDIF
     C                     ENDIF
      *
      * NEXT-CONTROL
     C                     MOVEL'SET10'   W@NEXT
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      * WRITE RECORD
      *-------------------------------------------------------------------------
     C           #WRT10    BEGSR
      *
     C                     CLEARAB#PPY91
      *
     C                     Z-ADDS@YYMD    UAKODT
     C                     Z-ADDS@HMS     UAKOTM
     C                     MOVELS@USID    UAKOME
     C                     MOVELD1NONY    UANONY
     C                     MOVELD2USER    UAUSER
      *
     C                     WRITEAB#PPY91
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *  WRITE(UPDATE) RECORD
      *-------------------------------------------------------------------------
     C           #WRT11    BEGSR
      *
     C                     Z-ADDS@YYMD    UAKODT
     C                     Z-ADDS@HMS     UAKOTM
     C                     MOVELS@USID    UAKOME
     C                     MOVELD1NONY    UANONY
     C                     MOVELD2USER    UAUSER
      *
     C                     UPDATAB#PPY91
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      * UPDATE RECORD
      *-------------------------------------------------------------------------
     C           #UPD10    BEGSR
      *
     C                     Z-ADDS@YYMD    UAKODT
     C                     Z-ADDS@HMS     UAKOTM
     C                     MOVELS@USID    UAKOME
     C                     MOVELD1NONY    UANONY
     C                     MOVELD2USER    UAUSER
      *
     C                     UPDATAB#PPY91
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      * DELETE(UPDATE) RECORD
      *-------------------------------------------------------------------------
     C           #DEL10    BEGSR
      *
     C                     DELETAB#PPY91
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *  INITIAL PROCESS
      *-------------------------------------------------------------------------
     C           #INIT     BEGSR
      *
      * NEXT-CONTROL
     C                     MOVEL'SET10'   W@NEXT  5
     C                     MOVELS@PGID    D1PGM
      *
     C                     ENDSR
      *----------------------------------------------------------------
**  @SL  ( SELECT )
DELETE
CHANGE
ADD
**  @MS  ( ERR MSG )
ER01 SELECT 0, 1 OR 2
ER02 ENTER DELIVERY CODE
ER03 DELIVERY CODE NOT ASSIGNED IN M/F
ER04 DELIVERY CODE ALREADY ASSIGNED IN M/F
ER05 ENTER TM USER ID
ER06
