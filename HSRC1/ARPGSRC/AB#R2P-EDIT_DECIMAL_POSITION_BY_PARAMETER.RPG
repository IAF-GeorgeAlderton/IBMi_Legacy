     H            Y.
     F** AB#R2P ***********************************************************
     F*  EDIT DECIMAL POINT BY PARAMETER                                  *
     F*  TCH 2000.11.30                                                   *
     F*                                                                   *
     F******************************************************* AB#R2P ******
     E                    IN         30  1
     E                    OUT        21  1
     E                    OUT2        9  1
     F******************************************************************
     I*
     I            DS
     I                                        1  309WOUT
     I                                        1  21 OUT
     I                                       22  30 OUT2
      *
     C           *ENTRY    PLIST
     C                     PARM           PDEC    10
     C                     PARM           PIN    30
     C                     PARM           POUT   309
      *
     C                     MOVEAPIN       IN
     C                     Z-ADDPDEC      R       20
     C                     MOVE *BLANK    WOUT
     C                     Z-ADD*ZERO     I       20
     C                     Z-ADD*ZERO     M       20
     C                     Z-ADD*ZERO     U       20
     C                     Z-ADD*ZERO     L       20
     C                     MOVE *ZERO     OUT
     C                     MOVE *ZERO     OUT2
     C*
     C* INPUT = ZERO
     C           PIN       IFEQ *BLANK
     C           PIN       OREQ *ZERO
     C                     Z-ADD*ZERO     POUT
     C                     GOTO #END
     C                     END
     C* DECIMAL DENGTH=0
     C           PDEC      IFEQ *ZERO
     C                     Z-ADD30        I
     C                     GOTO #INTE
     C                     END
     C* SET DECIMAL
     C           30        SUB  R         I
     C           I         ADD  1         M
     C                     DO   R         L
     C                     MOVEAIN,M      OUT2,L
     C                     ADD  1         M
     C                     END
     C* SET INTEGER
     C           #INTE     TAG
     C                     Z-ADD21        U
     C                     DO   21
     C                     MOVEAIN,I      OUT,U
     C                     SUB  1         U
     C                     SUB  1         I
     C                     END
      *
     C                     Z-ADDWOUT      POUT
      *
     C           #END      TAG
      *
     C                     SETON                     LR
     C                     RETRN
