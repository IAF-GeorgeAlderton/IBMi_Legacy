      *
     C*- PARM'S INFORMATION ------------------------*
     C*      '18'の時==>受注データＴＶ入力      *
     C*      '19'の時==>受注データバッチ入力    *
     C*---------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           PGYOM   2
     C                     PARM           PLIST   1
      *
     C*------------------------------------*
     C*         １回のみの処理。         *
     C*------------------------------------*
     C           *IN03     IFEQ '0'
     C                     SETON                     03
     C                     TIME           JIKAN
     C                     Z-ADD*DATE     SYSHZ
     C                     Z-ADD*DATE     URIDAY
     C                     END
      *
     C*----------------------------------------------------------*
     C* ..鈴木自工　湖西工場　受注データ　の　ディスケット..   *
     C* ..  レコード区分＇１１Ｂ＇　読み飛ばし..               *
     C*----------------------------------------------------------*
     C           IRECD     IFEQ '11B'
     C           IHUSK     ANDEQ'R '
     C           IKKOJ     ANDEQ'R'
     C                     GOTO END
     C                     END
      *
     C**********************************************************
     C* M-NO      平準化確定ファイル、有無のチェック         *
     C**********************************************************
     C           KEY0      KLIST
     C                     KFLD           SHIN1
     C                     KFLD           SHIN2
     C                     KFLD           SHIN3
     C                     SETOF                     05
     C           KEY0      CHAINAGAPL311             05
     C           *IN05     IFEQ '0'
     C           CBSKJY    ANDEQ'D'
     C                     SETON                     05
     C                     END
     C           *IN05     IFEQ '1'
     C                     GOTO END
     C                     END
      *
     C*------------------------------------*
     C*      不要データの読み飛し。      *
     C*------------------------------------*
     C           STEHKB    CABNE'G'       END
      *
     C           SYKKJN    CABEQ'2'       END              A-PISCﾎﾟｰﾓ
      *
     C*------------------------------------*
     C*      出荷マスターから読む。      *
     C*------------------------------------*
     C*=== ﾅbhﾓ INPUT ===*
     C           KEY1      KLIST
     C                     KFLD           TOKCOD
     C                     KFLD           NOUCOD
     C                     KFLD           NOUKOJ
     C                     KFLD           NOUUKE
     C           KEY1      CHAINGADPL111             01
     C           *IN01     IFEQ '1'
     C                     Z-ADD1         CQCIC1
     C                     Z-ADD1         CQCIC2
     C                     Z-ADD1         CQCIC3
     C                     Z-ADDSYSJI     CQTHJI
     C                     Z-ADDSYSPN     CQTHPN
     C                     Z-ADDSYSJI     CQURJI
     C                     Z-ADDSYSPN     CQURPN
     C                     ELSE
     C           B5SKJY    IFEQ 'D'
     C                     Z-ADD1         CQCIC1
     C                     Z-ADD1         CQCIC2
     C                     Z-ADD1         CQCIC3
     C                     Z-ADDSYSJI     CQTHJI
     C                     Z-ADDSYSPN     CQTHPN
     C                     Z-ADDSYSJI     CQURJI
     C                     Z-ADDSYSPN     CQURPN
     C                     ELSE
     C                     Z-ADDB51SCH    UCHDAY  20
     C                     Z-ADDB5HIZK    CQCIC1
     C                     Z-ADDB5KAIS    CQCIC2
     C                     Z-ADDB5NBIN    CQCIC3
     C                     Z-ADDB51SJI    CQTHJI
     C                     Z-ADDB51SFN    CQTHPN
     C                     Z-ADDB51UJI    CQURJI
     C                     Z-ADDB51UFN    CQURPN
     C                     END
     C                     END
      *
     C*-------------------------------------*
     C*  出荷手配・売上計上時間が零の時   *
     C*-------------------------------------*
     C           CQTHJI    IFEQ 0
     C                     Z-ADDSYSJI     CQTHJI
     C                     END
     C           CQTHPN    IFEQ 0
     C                     Z-ADDSYSPN     CQTHPN
     C                     END
     C           CQURJI    IFEQ 0
     C                     Z-ADDSYSJI     CQURJI
     C                     END
     C           CQURPN    IFEQ 0
     C                     Z-ADDSYSPN     CQURPN
     C                     END
      *
     C*------------------------------------*
     C*      部品マスターから読む。      *
     C*------------------------------------*
     C*===所番地INPUT ===*
     C           KEY2      KLIST
     C                     KFLD           SHIN1
     C                     KFLD           SHIN2
     C                     KFLD           SHIN3
     C           KEY2      CHAINFCEPL011             02
     C           *IN02     IFEQ '1'
     C                     MOVE *BLANK    CQSBKJ
     C                     MOVE *BLANK    CQSBRO
     C                     MOVE *BLANK    CQSBRT
     C                     MOVE *BLANK    CQSBDN
     C                     Z-ADD0         CQSYUY
     C                     Z-ADD0         CQHAKO
     C                     ELSE
     C           A2GSKD    IFEQ 'D'
     C                     MOVE *BLANK    CQSBKJ
     C                     MOVE *BLANK    CQSBRO
     C                     MOVE *BLANK    CQSBRT
     C                     MOVE *BLANK    CQSBDN
     C                     Z-ADD0         CQSYUY
     C                     Z-ADD0         CQHAKO
     C                     ELSE
     C           SYKAHZ    IFLT A2TRHZ
     C                     MOVE A2KTRK    CQSBKJ
     C                     MOVE A2KTRT    CQSBRO
     C                     MOVE A2KTRR    CQSBRT
     C                     MOVE A2KTRD    CQSBDN
     C                     ELSE
     C                     MOVE A2STRK    CQSBKJ
     C                     MOVE A2STRT    CQSBRO
     C                     MOVE A2STRR    CQSBRT
     C                     MOVE A2STRD    CQSBDN
     C                     END
      *
     C*===収容数INPUT ===*
     C           SYKAHZ    IFLT A2SYHZ
     C                     Z-ADDA2KSYS    CQSYUY
     C                     ELSE
     C                     Z-ADDA2SSYS    CQSYUY
     C                     END
      *
     C*===箱数の計算===*
     C           NOUSUU    DIV  CQSYUY    CQHAKO
     C                     MVR            DAMY    30
     C           DAMY      IFGT 0
     C           CQHAKO    ADD  1         CQHAKO
     C                     END
     C                     END
     C                     END
      *
     C*------------------------------------*
     C*        売上・受注№入力。        *
     C*------------------------------------*
     C           RRN       IFGE 1
     C           RRN       ADD  8000000   CQJTNO
     C                     ELSE
     C           1         CHAINAUDPPNO1             04
      *
     C*===読めない時===*
     C           *IN04     IFEQ '1'
     C                     Z-ADDUMONTH    ACTUKI
     C                     Z-ADD8500001   ACRENO
     C                     Z-ADD8500001   CQJTNO
     C                     WRITEAUDPPNO1
     C                     ELSE
      *
     C*===読めた時===*
     C           ACTUKI    IFNE UMONTH
     C                     Z-ADDUMONTH    ACTUKI
     C                     Z-ADD8500001   ACRENO
     C                     Z-ADD8500001   CQJTNO
     C                     UPDATAUDPPNO1
     C                     ELSE
     C           ACRENO    ADD  1         ACRENO
     C                     Z-ADDACRENO    CQJTNO
     C                     UPDATAUDPPNO1
     C                     END
     C                     END
     C                     END
      *
     C*---------------------------------*
     C*        出荷手配日の決定       *
     C*---------------------------------*
     C           KKEY      KLIST
     C                     KFLD           NOUKIY
     C                     KFLD           NOUKIM
     C                     KFLD           NOUKID
     C                     SETOF                     74
     C           KKEY      SETLLAGDPL111
     C                     MLLZO'0'       UCHDAY
     C           UCHDAY    IFGE 1
     C           1         DO   UCHDAY
     C                     READPAGDPL11                  74
     C           *IN74     CABEQ'1'       STEP03
     C                     END
     C                     Z-ADDF8KAYY    CQTHYY
     C                     Z-ADDF8KAMM    CQTHMM
     C                     Z-ADDF8KADD    CQTHDD
     C                     GOTO STEP04
     C                     ELSE
     C                     Z-ADDNOUKIY    CQTHYY
     C                     Z-ADDNOUKIM    CQTHMM
     C                     Z-ADDNOUKID    CQTHDD
     C                     GOTO STEP04
     C                     END
     C           STEP03    TAG
     C                     Z-ADDSYSYY     CQTHYY
     C                     Z-ADDSYSMM     CQTHMM
     C                     Z-ADDSYSDD     CQTHDD
     C           STEP04    TAG
      *
     C*----------------------------------------------------*
     C* Ａ－ＰＩＣＳ計画発行管理マスターをチェックする。 *
     C* 未登録＝通常のＡ－ＰＩＣＳ処理を行う。           *
     C* 登録済＝Ａ－ＰＩＣＳ処理は行わず、リスト発行。   *
     C*----------------------------------------------------*
     C           KEY3      KLIST
     C                     KFLD           SHIN1
     C                     KFLD           SHIN2
     C                     KFLD           SHIN3
     C                     KFLD           TOKCOD
     C                     KFLD           NOUCOD
     C                     KFLD           NOUKOJ
     C                     KFLD           NOUUKE
     C                     SETOF                     05
     C           KEY3      CHAINBTAPL111             05
      *
     C*削除チェック
     C           *IN05     IFEQ '0'
     C           BUSKJY    IFEQ 'D'
     C           BUSKHZ    ANDLECQTHHZ
     C                     ELSE
      *
     C*開始日・終了日　チェック
     C           *DATE     IFGE BUSTHZ
     C           *DATE     ANDLEBUENHZ
      *
     C                     MOVE '*'       PLIST
     C                     EXCPTOUT
     C                     GOTO END
      *
     C                     END
     C                     END
     C                     END
      *
     C*==== A-PICS立上日過ぎか？=====
     C           CBSTHZ    IFGT 0
     C           CBSTHZ    CABGTCQTHHZ    END
     C                     END
      *
     C*--------------------------------------*
     C*     出力フィールドへコピーする。   *
     C*--------------------------------------*
     C                     Z-ADDTOKCOD    CQTOKU
     C                     MOVE TOKKOJ    CQTKOJ
     C                     MOVE TOKUKE    CQTUKE
     C                     Z-ADDNOUCOD    CQNONY
