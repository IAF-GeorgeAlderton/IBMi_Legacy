      *メッキかんばんマスターの読込み*
      **********************************
     C           1         SETLLAJHWP40
     C                     SETOF                     30
     C           MELOOP    TAG
     C                     READ AJHWP40                  30
S1   C           *IN30     IFEQ '1'
     C                     GOTO MEKEND
     C                     ELSE
 S2  C           L6SKJY    IFEQ 'D'
  S3 C           L6SKHZ    IFLE *DATE
     C                     GOTO MELOOP
  E3 C                     END
 E2  C                     END
