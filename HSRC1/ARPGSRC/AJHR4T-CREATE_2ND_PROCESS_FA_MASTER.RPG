     C                     MOVE L6SHN2    BUHK2   5
     C                     MOVE L6SHN3    BUHK3   2
     C                     SETOF                     99
     C                     Z-ADD0         ER      10
     C                     EXSR BUHIN
     C           *IN99     IFEQ '1'
     C                     MOVELMSG,ER    PMSG   42
     C           ER        IFEQ 1                          1=BUHIN NOT
