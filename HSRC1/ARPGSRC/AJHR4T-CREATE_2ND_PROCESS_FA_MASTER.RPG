     C******************************
      *
     C           UPKBN     IFEQ '0'
     C                     WRITEAJHPL011
     C           OUTKEN    ADD  1         OUTKEN  70
     C                     EXCPTCHG
     C*
     C                     ELSE
     C                     Z-ADDJISEN     JHMKJI
     C                     MOVE SYKBN     JHMKSK
     C                     MOVE '1'       JHMENT
     C                     UPDATAJHPL011
     C           UPKEN     ADD  1         UPKEN   70
