     C                     END
     C*
E1   C                     END
     C*件数のカウント*
     C           ALLKEN    ADD  1         ALLKEN  70
     C*ＦＡマスターＵＰＤＡＴの為のみのＣＨＡＩＮ(SUB) *
     C                     SETOF                     95
     C           UPKBN     IFEQ '1'
     C                     MOVE '*'       UP      1
     C                     MOVE L6SHN1    CHKEY1  5        社内品番１
     C                     MOVE L6SHN2    CHKEY2  5        社内品番２
     C                     MOVE L6SHN3    CHKEY3  2        社内品番３
     C                     MOVE L6SHN1    JHSHN1
     C                     MOVE L6SHN2    JHSHN2
     C                     MOVE L6SHN3    JHSHN3
     C                     EXSR CHSUB
     C           *IN95     IFEQ '1'
     C                     MOVELMSG,7     PMSG
     C                     GOTO MELOOP
     C                     END
     C                     ELSE
     C                     MOVE ' '       UP
     C                     END
     C*ＦＡＭフィールドクリアーと旧変数格納(SUB) *
     C                     EXSR CLRSUB
