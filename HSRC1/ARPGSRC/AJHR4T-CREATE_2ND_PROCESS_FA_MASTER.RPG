     C                     Z-ADDUMONTH    JHKOMM
     C                     Z-ADDUDAY      JHKODD
     C                     Z-ADDUJI       JHKOHH
     C                     Z-ADDUFUN      JHKOSS
     C                     MOVEL'AJHR4T'  JHKOME
