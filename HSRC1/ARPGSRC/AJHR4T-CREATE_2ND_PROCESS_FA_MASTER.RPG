     C*メッキ係数の計算(SUB)*
     C*************************
     C                     SETOF                     96
     C                     EXSR MEKKI
     C*
     C           *IN96     IFEQ '1'
     C                     Z-ADD0         JHMKRI           理論値
     C                     ELSE
     C                     Z-ADDK         JHMKRI           理論値
     C                     END
      *-----------------------------------------------------------*
      *  めっき係数理論値が変更された時使用区分を‘１’にする   *
      *                    UPDATE   :  SEP/25/1997.  S.OHTAKE     *
      *-----------------------------------------------------------*
      ****************************
      *メッキ係数使用区分の入力*
      * ０＝無　１＝理　２＝実 *
      ****************************
     C           JHMKRI    IFEQ 0
     C                     MOVE '0'       JHMKSK           使用区分
     C                     ELSE
     C           JHMKRI    IFNE ODMKRI
     C                     SETON                     55
     C                     MOVE '1'       JHMKSK
     C                     ENDIF
     C                     END
     C************************************
     C*その他の内容をＦＡマスターに入力*
     C************************************
