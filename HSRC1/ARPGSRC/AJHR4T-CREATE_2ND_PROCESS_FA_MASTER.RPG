     C** MEKKI *********************************
     C*   メッキ係数を計算するサブルーチン   *
     C******************************************
     C           MEKKI     BEGSR
     C*変数のクリア*
     C                     Z-ADD0         A
     C                     Z-ADD0         B
     C                     Z-ADD0         C
     C                     Z-ADD0         D
     C                     Z-ADD0         E
     C                     Z-ADD0         K
     C*首下係数Ａの算出*
     C           A2KUBI    IFLE 0
     C                     SETON                     96
     C                     GOTO SREX2
     C                     END
     C*
     C           A2KUBI    MULT A2KUBI    KUBI2   93
     C           -0.064    MULT KUBI2     A1      93
     C           15.9      MULT A2KUBI    A2      93
     C                     Z-ADD55.37     A3      93
     C           A1        ADD  A2        A       93
     C           A3        ADD  A         A
     C*膜厚係数Ｂの算出*
     C           JHMSMA    IFLE 0
     C                     SETON                     96
     C                     GOTO SREX2
     C                     END
     C*
     C           JHMSMA    ADD  3         B1      93
     C           B1        DIV  1.6       B       93
     C*熱処理係数Ｃの算出*
     C           JHMSNT    IFNE 0
%0001C* * *                Z-ADD1.1       C       93
%0001C                     Z-ADD1.05      C       93
     C                     ELSE
     C                     Z-ADD1         C
     C                     END
     C*形状係数Ｄの算出*
     C*六角ボルト*
     C           JHMSKJ    IFEQ '13'
     C                     Z-ADD0.8       D       93
     C                     GOTO EXIT2
     C                     END
     C*座金組込六角ボルト・セレイションボルト*
     C           JHMSKJ    IFEQ '24'
     C           JHMSKJ    OREQ '35'
     C*
     C           JHMSWS    IFEQ 0
     C                     Z-ADD0.8       D
     C                     GOTO EXIT2
     C                     END
     C           JHMSWS    IFEQ 1
     C                     Z-ADD0.9       D
     C                     GOTO EXIT2
     C                     END
     C           JHMSWS    IFGE 2
     C                     Z-ADD1         D
     C                     GOTO EXIT2
     C                     END
     C*
     C                     END
     C*つば付座六角ボルト*
     C           JHMSKJ    IFEQ '19'
     C*
     C           JHMSWS    IFEQ 0
     C                     Z-ADD0.9       D
     C                     GOTO EXIT2
     C                     ELSE
     C                     Z-ADD1.2       D
     C                     GOTO EXIT2
     C                     END
     C*
     C                     END
     C*熔接ボルト*
     C           JHMSKJ    IFEQ '20'
     C                     Z-ADD0.8       D
     C                     GOTO EXIT2
     C                     END
     C*タッピングネジ・十字穴付小ネジ・すり割付小ネジ*
     C*セルフドリングタッピングネジ*
     C*座金組込小ネジ・テックス／Ｗ*
     C           JHMSKJ    IFEQ '01'
     C           JHMSKJ    OREQ '04'
     C           JHMSKJ    OREQ '05'
     C           JHMSKJ    OREQ '29'
     C           JHMSKJ    OREQ '25'
     C           JHMSKJ    OREQ '39'
     C*
     C           JHMSWS    IFEQ 0
     C                     Z-ADD0.8       D
     C                     GOTO EXIT2
     C                     END
     C           JHMSWS    IFEQ 1
     C                     Z-ADD0.9       D
     C                     GOTO EXIT2
     C                     END
     C           JHMSWS    IFGE 2
     C                     Z-ADD1         D
     C                     GOTO EXIT2
     C                     END
     C*
     C                     END
     C*該当無しは、ハンド入力*
     C                     Z-ADD0         D
     C*
     C           EXIT2     TAG
     C*色係数Ｅの算出*
     C           JHMSCK    IFEQ 'O'
     C           JHMSCK    OREQ 'B'
%0001C*                    Z-ADD1.2       E       93
%0001C                     Z-ADD1.15      E       93
     C                     ELSE
     C                     Z-ADD1         E
     C                     END
     C*φ係数Ｏの算出*
     C           A2TUSZ    IFLE 0
     C                     SETON                     96
     C                     GOTO SREX2
     C                     END
     C*
     C           A2TUSZ    DIV  2         O11     93
     C           O11       MULT O11       O1      93
     C           O1        MULT 3.14      O2      93
     C           O2        ADD  30        O3      93
     C           O3        DIV  10        O       93
     C*電流係数Ｋの算出*
     C           A         MULT B         K1      93
     C           C         MULT D         K2      93
     C           K1        MULT K2        K3      93
     C           K3        MULT E         K4      93
     C           O         MULT A2KUBI    K5      93
     C           K5        IFNE 0
     C           K4        DIV  K5        K       31
     C                     ELSE
     C                     Z-ADD0         K
     C                     END
