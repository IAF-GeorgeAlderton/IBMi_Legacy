     C******************************************************
     C*  START PROGRAM  <MFAR07>                           *
     C******************************************************
     C           *ENTRY    PLIST
     C                     PARM           PKJ     4
     C                     PARM           PKBN    1
     C                     PARM           PLST    1
     C****                 MOVELPKJ       KOJO    40
     C*
     C  N01                GOTO @END
     C*
B001 C           *IN90     IFEQ '0'
     C                     MOVEL'1'       *INOF
     C                     MOVEA'1'       *IN,90
     C                     Z-ADD0         CNT     40
E001 C                     END
     C******************************************************
     C*  LET'S  PRINT-OUT                                  *
     C******************************************************
B001 C           *INOF     IFEQ '1'
     C                     MOVE *BLANK    KJNM   16
     C           KOJO      CHAINFGBPL011             10
     C           *IN,10    IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,10
     C                     END
     C*
     C  N10                MOVELB2SMEI    KJNM
     C*
     C                     MOVE *BLANK    SNM     8
B002 C           PKBN      IFEQ '1'
     C                     MOVEL'LUMP-SUM'SNM
X002 C                     ELSE
B003 C           PKBN      IFEQ '2'
     C                     MOVEL'ALLOCATE'SNM
E003 C                     END
E002 C                     END
     C*
     C                     TIME           TIME    60
     C                     Z-ADDUDATE     DAY     60
     C                     ADD  1         CNT
     C                     EXCPTHED
     C                     MOVEL'0'       *INOF
E001 C                     END
     C*
     C                     MOVE *BLANK    AA01    1
     C                     MOVE *BLANK    AA02    1
     C                     MOVE *BLANK    AA03    3
B001 C           KBN2      IFNE *BLANK
     C                     MOVEL'-'       AA01
E001 C                     END
     C*
B001 C           OKB2      IFNE *BLANK
     C                     MOVEL'-'       AA02
E001 C                     END
     C*
     C           RPMH      IFNE 0
     C                     MOVEL'RPH'     AA03
     C                     END
     C*
     C                     EXCPTDET
     C*
     C           @END      TAG
     C*
     CL1                   MOVEL'1'       *INOF
     C*
     C*
     OQPRINT  E   02           HED
