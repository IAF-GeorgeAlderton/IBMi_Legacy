     C                     MOVELWSSTM6    R4KOTU
      *
     C                     WRITEAM#PP321
      *
  |  C                     ENDSR
 LC5 C**************************************************************************
      * Save Kanban barcode with the last 4 scanned.      *
     C**************************************************************************
     C           SAVKBN    BEGSR
      *
     C           IX        IFEQ 4
     C                     Z-ADD1         IX      20
     C                     ELSE
     C                     ADD  1         IX
     C                     ENDIF
      *
     C                     MOVELF4KNBN    KBN,IX    P
      *
     C                     ENDSR
      *
     C**************************************************************************
      * Save Screen3 Kanban barcode with the last 32 scanned.                  *
     C**************************************************************************
     C           #SVKB3    BEGSR
      *
     C           I3        IFEQ 32
     C                     Z-ADD1         I3      20
     C                     ELSE
     C                     ADD  1         I3
     C                     ENDIF
      *
     C                     MOVELF3KNBN    KB3,I3    P
      *
     C                     ENDSR
      *
     C**************************************************************************
