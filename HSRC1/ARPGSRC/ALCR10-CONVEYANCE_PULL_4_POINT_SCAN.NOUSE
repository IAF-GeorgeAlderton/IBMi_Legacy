     C*************************************************************************
     C*     1ST SCREEN(TM-CODE ENTRY)
     C**************************************************************************
     C           #FMT10    BEGSR
      *
      * if worker code was passed in, then use that code
      * if not, then display format to enter worker code.
     C           WORKER    IFEQ *BLANKS
     C                     EXFMTFMT100
     C                     ELSE
     C                     MOVELWORKER    F1USRC
     C                     ENDIF
      *
     C                     MOVEL*BLANK    F1ERR
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK10
     C           *IN99     IFEQ *OFF
     C                     MOVE '20'      @@ID
TCHK3C                     MOVELF1USRC    W@TMCD  6
TCHK3C           W@TMCD    LOKUPTM                       98
TCHK3C           *IN98     IFEQ *OFF
TCHK3C                     MOVEL*ON       W@CONV
TCHK3C                     ELSE
TCHK3C                     MOVEL*OFF      W@CONV
TCHK3C                     END
     C                     END
     C                     ENDSL
      *
     C                     ENDSR
