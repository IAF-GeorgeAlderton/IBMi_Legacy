     C           K#11A     CHAINJCMPL11A             99
     C   99                GOTO XDTL
      * RETRIEVE USER NAME
     C                     MOVELJ1NONY    X1NONY
     C                     MOVELJ1CTEL    X1CTEL
     C                     MOVELJ1BIN     X1BIN
     C                     MOVELJ1BLN#    X1BLN#
     C                     Z-ADDJ1BOX     X1BOX
     C                     Z-ADDJ1REHZ    XNOHZ
     C                     MOVELJ1CRME    X1CRME
     C                     MOVELJ1CRME    $USER
     C                     CALL 'UTLR31'
     C                     PARM           $USER  10
     C                     PARM           $NAME  15
     C                     MOVEL$NAME     X1CRNM
      * GET PACKING LIST#
     C**                   MOVELJ1NOHZ    $NOHZ
     C                     MOVELJ1REHZ    $NOHZ
     C                     MOVEL'5149'    $CUST
     C                     MOVELJ1NONY    $NONY
     C                     MOVELJ1NKOJ    $NKOJ
     C                     MOVELJ1NUKE    $NUKE
     C                     MOVELJ1BIN     $BINN
     C                     MOVELJ1REHZ    $RLHZ
     C                     MOVEL'11111'   $ODRN
     C                     CALL 'UTLR51'
     C                     PARM           $NOHZ   8
     C                     PARM           $CUST   4
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $BINN   2
     C                     PARM           $RLHZ   8
     C                     PARM           $ODRN  10
     C                     PARM           $PICK#  9
     C                     PARM           $RTN    1
     C           $PICK#    IFNE *BLANK
     C                     MOVEL$PICK#    X1PICK
     C                     ELSE
     C                     EXSR #PICK2
     C                     MOVEL$PICK#    X1PICK
     C                     ENDIF
      * PART#
     C           1         DO   12        IX      20
     C                     MOVELMSG,18    MHN,IX
     C                     ENDDO
      *
     C                     MOVE '0'       RFLG
     C                     Z-ADD0         QTY
     C                     Z-ADD0         CUM
     C                     Z-ADD0         BOX
     C                     MOVE *BLANK    XMORE
     C           J1SHID    SETLLJCMPP12
     C           1         DO   13        IX
     C           J1SHID    READEJCMPP12                  97
     C   97                LEAVE
      *
     C           IX        IFEQ 13
     C                     MOVEL'(+MORE)' XMORE
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVELJ2MHIN    MHN,IX
     C                     Z-ADDJ2SRYO    QTY,IX
     C                     Z-ADDJ2CUMQ    CUM,IX
     C                     Z-ADDJ2BOX#    BOX,IX
      * CHECK RETURNABLE
     C           RFLG      IFNE 'Y'
     C           'ST8'     SCAN J2MHIN                   10
     C           *IN10     IFEQ *ON
     C                     MOVE 'Y'       RFLG
     C                     ELSE
     C                     MOVE 'N'       RFLG
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
JW1  C           LFLG      IFEQ 'Y'
 .   C                     MOVEL@@LID     X1PACK           PLT90
 .   C                     ELSE
 .   C                     MOVEL@@PLT     X1PACK           BOX90
 .   C                     ENDIF
 .    *
     C                     SELEC
 .   C           RFLG      WHEQ 'Y'
 .   C                     MOVEL@@RET     X1CONT           RETURNABLE
 .   C           RFLG      WHEQ 'N'
 .   C                     MOVEL@@BOX     X1CONT           FORD BOX
 .   C                     OTHER
 .   C                     MOVEL@@NOT     X1CONT           NOT FOUND
JW1  C                     ENDSL
      * REVERSE GROSS WGT
     C           J1WHT     IFEQ 0
     C                     MOVE *ON       *IN31
     C                     ELSE
     C                     MOVE *OFF      *IN31
     C                     ENDIF
      * REVERSE CONTAINE
     C           RFLG      IFEQ '0'
     C                     MOVE *ON       *IN32
     C                     ELSE
     C                     MOVE *OFF      *IN32
     C                     ENDIF
      * NOTE
     C           J1SKJY    IFEQ 'D'
     C                     MOVEL'CANCELED'XNOTE1
     C                     ELSE
     C                     MOVE *BLANK    XNOTE1
     C                     ENDIF
      *
     C                     EXFMTDSP02
      *
     C           XDTL      ENDSR
      *-----------------------------------------------------------
      * GET PACKING LIST# (2)
      *-----------------------------------------------------------
     C           #PICK2    BEGSR
      *
     C                     MOVELJ1REHZ    $NOHZ            RELEASE DATE
     C                     MOVEL'5149'    $CUST
     C                     MOVELJ1NONY    $NONY
     C                     MOVELJ1NKOJ    $NKOJ
     C                     MOVELJ1NUKE    $NUKE
     C                     MOVELJ1BIN     $BINN
     C                     MOVELJ1REHZ    $RLHZ
     C                     MOVE *BLANK    $ODRN
     C                     CALL 'UTLR51'
     C                     PARM           $NOHZ   8
     C                     PARM           $CUST   4
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $BINN   2
     C                     PARM           $RLHZ   8
     C                     PARM           $ODRN  10
     C                     PARM           $PICK#  9
     C                     PARM           $RTN    1
      *
     C                     ENDSR
      *-----------------------------------------------------------
      *          INITIALIZE
      *-----------------------------------------------------------
     C           #INIT     BEGSR
      *
     C           K#11A     KLIST
     C                     KFLD           S@ASN
     C                     KFLD           S@SHID
      *
     C                     Z-ADD0         RRN     50
     C                     MOVE '01'      W@ID    2
     C                     TIME           @TIME
      *
     C                     MOVELTODAY     XFROM3
     C                     MOVELTODAY     XTO3
     C                     MOVE 'N'       RFLG    1        RET FLG
     C                     MOVE 'N'       LFLG    1        LID FLG
      *
     C                     ENDSR
** MSG(50A)........2.........3.........4.........5
ENTER DATE(FROM)!                                   01
DATE(FROM) NOT FOND IN CALENDAR MASTER!             02
CHOOSE ONE CONDITION!                               03
DATE(TO) NOT FOND IN CALENDAR MASTER!               04
PRESS F5 TO GO TO INQUIRY SCREEN...                 05
DATE(TO) SHOULD BE GREATER THAN DATE(FROM)!         06
9999/99/99                                          07
NO RECORD!                                          08
ENTER "X" FOR ASN DETAIL...                         09
                                                    10
                                                    11
                                                    12
9999/99/99                                          13
ENTER ISSUE DATE, SHIP DATE OR ASN#!                14
ASN(TO) SHOULD BE GREATER THAN ASN(FROM)!           15
(BY SHIP DATE)                                      16
  (BY ASN)                                          17
- - - - - - - - - - -                               18
(BY ISSUE DATE)                                     19
                                                    20
