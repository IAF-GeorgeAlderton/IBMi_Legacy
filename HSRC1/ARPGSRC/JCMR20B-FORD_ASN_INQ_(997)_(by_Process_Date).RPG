     C                     MOVELJ1NONY    S@NONY
     C                     MOVELJ1BIN     S@BIN
     C                     MOVELJ1ASN#    S@ASN
     C                     MOVE J1ASN#    S@ASN6
     C***                  MOVELJ1NKOJ    S@FACT
