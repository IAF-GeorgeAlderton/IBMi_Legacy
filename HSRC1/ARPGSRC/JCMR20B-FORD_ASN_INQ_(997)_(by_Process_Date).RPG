     C                     GOTO START
      *
      * F10 PRINT
     C**         *INKJ     WHEQ *ON
     C**                   EXSR #CHK2
     C**         *IN86     IFEQ *ON
     C**                   MOVELMSG,9     XMSG
     C**                   ELSE
     C**                   EXSR #DTL
     C**                   ENDIF
      * F12
     C           *INKA     WHEQ *ON
     C           *INKL     OREQ *ON
     C                     LEAVE
