     C                     LEAVE
     C                     ENDIF
      * BREAK LINE
     C           SVREHZ    IFNE 0
     C           J1REHZ    IFNE SVREHZ
     C           J1BIN     ORNE SVBIN
     C                     CLEARSFL01
     C                     ADD  1         RRN
     C                     SETON                     47
     C                     WRITESFL01
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADDJ1REHZ    SVREHZ
     C                     Z-ADDJ1BIN     SVBIN
      *
     C                     ADD  1         RRN
     C                     SETOF                     47
     C                     MOVE *OFF      *IN51
     C                     MOVE *BLANK    H@SEL
     C                     MOVE *BLANK    S@SEL
     C                     Z-ADDJ1DATE    S@ISSU
     C                     Z-ADDJ1TIME    S@TIME
     C                     Z-ADDJ1REHZ    S@SHDT
     C                     MOVELJ1NONY    S@NONY
     C                     MOVELJ1BIN     S@BIN
     C                     MOVELJ1ASN#    S@ASN
     C                     MOVE J1ASN#    S@ASN6
     C                     MOVELJ1NUKE    S@DOCK
     C                     MOVELJ1PSCC    S@SCAC
     C                     MOVELJ1SMEI    S@NAME
     C                     MOVELJ1SHID    S@SHID
     C                     Z-ADDJ1BOX     S@BOX
     C                     EXSR #PICK2
     C                     MOVEL$PICK#    S@PL
      * GET STATUS
     C                     EXSR #STS
     C                     MOVE @STS      S@STS
      * 997
     C           S@STS     IFEQ ' '
     C                     MOVE J1CRME    AFLG    1
     C                     SELEC
     C           J1KOHZ    WHEQ 0
     C                     MOVE '-'       S@997
     C                     Z-ADD0         S@997T
     C           AFLG      WHEQ 'A'
     C                     MOVE 'Y'       S@997
     C                     MOVELJ1KOTM    S@997T
     C                     OTHER
     C                     MOVE 'X'       S@997
     C                     MOVELJ1KOTM    S@997T
     C                     ENDSL
     C                     ELSE
     C                     MOVE *BLANK    S@997
     C                     Z-ADD0         S@997T
     C                     ENDIF
      * CANCELLED
