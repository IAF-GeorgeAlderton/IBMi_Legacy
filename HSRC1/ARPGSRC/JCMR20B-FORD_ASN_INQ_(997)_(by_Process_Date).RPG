     C                     EXSR #INIT
      * DISPLAY
     C           W@ID      DOWEQ'01'
     C                     EXFMTDSP01
     C                     MOVEL*BLANKS   XMSG
     C                     MOVE *OFF      *IN85
     C                     SETOF                     41  42
     C                     SETOF                     43  44
     C                     SETOF                     45  46
      * F1/3 END
     C           *INKA     IFEQ *ON
     C           *INKC     OREQ *ON
     C           *INKL     OREQ *ON
     C                     MOVE '99'      W@ID
     C                     LEAVE
     C                     ENDIF
      *
     C                     EXSR #CHK1
      * NO ERROR & F5
     C           *IN85     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #INQ
     C           RC@CNT    IFEQ 0
     C                     MOVELMSG,8     XMSG
     C                     ENDIF
     C                     ENDIF
      * NO ERROR & NOT F5
     C           *IN85     IFEQ *OFF
     C           *INKE     ANDEQ*OFF
     C                     MOVELMSG,5     XMSG
     C                     ENDIF
      *
     C                     ENDDO
      * FOOT
     C           XASN      IFNE *BLANK
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------------------
      *          CHECK DATA
      *-----------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     MOVE *OFF      *IN85
     C                     MOVE *BLANK    ETYPE   1
      * CHECK ENTRY
     C           XFROM3    IFNE *BLANK
     C           XTO3      ORNE *BLANK
     C                     MOVE 'I'       ETYPE            BY ISSUE DATE
     C                     ENDIF
      *
     C           XFROM1    IFNE *BLANK
     C           XTO1      ORNE *BLANK
     C           ETYPE     IFEQ *BLANK
     C                     MOVE 'S'       ETYPE            BY SHI DATE
     C                     ELSE
     C                     MOVE 'X'       ETYPE
     C                     SETON                     41  42
     C                     ENDIF
     C                     ENDIF
      *
     C           XAFROM    IFNE 0
     C           XATO      ORNE 0
     C           ETYPE     IFEQ *BLANK
     C                     MOVE 'A'       ETYPE            BY ASN#
     C                     ELSE
     C                     MOVE 'X'       ETYPE
     C                     SETON                     43  44
     C                     ENDIF
     C                     ENDIF
      *
     C           ETYPE     IFEQ *BLANK
     C                     SETON                     45  85
     C                     MOVELMSG,1     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           ETYPE     IFEQ 'X'
     C                     SETON                         85
     C                     MOVELMSG,3     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      * CHECK ENTRY DATA
     C                     SELEC
     C           ETYPE     WHEQ 'I'
     C                     EXSR #CKISS
     C           ETYPE     WHEQ 'S'
     C                     EXSR #CKSHP
     C           ETYPE     WHEQ 'A'
     C                     EXSR #CKASN
     C                     ENDSL
      *
     C           XCHK1     ENDSR
      *-----------------------------------------------------------
      * CHECK ISSUE DATE
      *-----------------------------------------------------------
     C           #CKISS    BEGSR
      * VALIDATE DATE FROM
     C                     MOVELXFROM3    $SRC
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$TRUE2    XFROM3
     C                     MOVEL$TRUE1    #FROM3  80
     C                     ELSE
     C                     MOVE *ON       *IN45
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,2     XMSG
     C                     GOTO XCKISS
     C                     ENDIF
      *
     C           XTO3      IFEQ *BLANK
     C                     MOVELXFROM3    XTO3
     C                     ENDIF
      * VALIDATE DATE TO
     C           XTO3      IFEQ '99999999'
     C           XTO3      OREQ MSG,13
     C                     MOVELMSG,7     XTO3
     C                     Z-ADD99999999  #TO3
     C                     ELSE
     C                     MOVELXTO3      $SRC
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$TRUE2    XTO3
     C                     MOVEL$TRUE1    #TO3    80
     C                     ELSE
     C                     MOVE *ON       *IN46
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,4     XMSG
     C                     GOTO XCKISS
     C                     ENDIF
     C                     ENDIF
      * COMPARE
     C           XFROM3    IFGT XTO3
     C                     MOVE *ON       *IN45
     C                     MOVE *ON       *IN46
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,6     XMSG
     C                     GOTO XCKISS
     C                     ENDIF
      * IF NO ERROR..
     C                     MOVELMSG,19    XBY
     C                     MOVE *ON       *IN49            YLW
     C                     MOVE *ON       *IN50
      *
     C           XCKISS    ENDSR
      *-----------------------------------------------------------
      * CHECK SHIP DATE
      *-----------------------------------------------------------
     C           #CKSHP    BEGSR
      * VALIDATE DATE FROM
     C                     MOVELXFROM1    $SRC
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$TRUE2    XFROM1
     C                     MOVEL$TRUE1    #FROM1  80
     C                     ELSE
     C                     MOVE *ON       *IN41
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,2     XMSG
     C                     GOTO XCKSHP
     C                     ENDIF
      *
     C           XTO1      IFEQ *BLANK
     C                     MOVELXFROM1    XTO1
     C                     ENDIF
      * VALIDATE DATE TO
     C           XTO1      IFEQ '99999999'
     C           XTO1      OREQ MSG,13
     C                     MOVELMSG,7     XTO1
     C                     Z-ADD99999999  #TO1
     C                     ELSE
     C                     MOVELXTO1      $SRC
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$TRUE2    XTO1
     C                     MOVEL$TRUE1    #TO1    80
     C                     ELSE
     C                     MOVE *ON       *IN42
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,4     XMSG
     C                     GOTO XCKSHP
     C                     ENDIF
     C                     ENDIF
      * COMPARE
     C           XFROM1    IFGT XTO1
     C                     MOVE *ON       *IN41
     C                     MOVE *ON       *IN42
     C                     MOVE *ON       *IN85
     C                     MOVELMSG,6     XMSG
     C                     GOTO XCKSHP
     C                     ENDIF
      * IF NO ERROR..
     C                     MOVELMSG,16    XBY
     C                     MOVE *OFF      *IN49            TRQ
     C                     MOVE *OFF      *IN50
