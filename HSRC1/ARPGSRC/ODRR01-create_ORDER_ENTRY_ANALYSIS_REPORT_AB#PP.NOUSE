     H            Y.
     F** ODRR01 ****************************************************************
     F*  PROGRAM    : ORDER ENTRY ANALYSIS REPORT                              *
     F*  WRITTEN    : 2019.08.06                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#PLAB IF  E           K        DISK
     FODRPP01 UF  E           K        DISK                      A
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   80BACRHZ
     I                                        1   60BACR6
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C                     EXSR #DLT
      *
     C           @YYMM1    SETLLAB#PLAB
     C                     DO   *HIVAL
     C                     READ AB#PLAB                  98
     C   98                LEAVE
      * END ?
     C           BACR6     IFNE @YYMM
     C                     LEAVE
     C                     ENDIF
      * IGNORE
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * FIRST ?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     MOVELBAEDIK    SVEDIK  1
     C                     MOVELBACRME    SVCRME 10
     C                     Z-ADDBATOKU    SVTOKU  40
     C                     Z-ADDBANONY    SVNONY  40
     C                     ENDIF
      * BREAK
     C           BAEDIK    IFNE SVEDIK
     C           BACRME    ORNE SVCRME
     C           BATOKU    ORNE SVTOKU
     C           BANONY    ORNE SVNONY
     C                     EXSR #BRK
     C                     ENDIF
      * DETAIL PROCESS
     C                     ADD  1         @REC
     C                     ENDDO
      * LAST BREAK
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * DELETE EXISTING RECORD                             *
      *----------------------------------------------------*
     C           #DLT      BEGSR
      *
     C           @YYMM     SETLLODRPP01
     C                     DO   *HIVAL
     C           @YYMM     READEODRPP01                  98
     C   98                LEAVE
     C                     DELETODRPP011
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  BREAK                                             *
      *----------------------------------------------------*
     C           #BRK      BEGSR
      * WRITE ODRPP01
     C                     Z-ADD@REC      O1REC
     C                     Z-ADDTODAY     O1CRHZ
     C                     Z-ADDNOW       O1CRTM
     C                     MOVEL#USER     O1CRUS
     C                     Z-ADD@YYMM     O1ODHZ
     C                     MOVELSVEDIK    O1TYPE
     C                     MOVELSVCRME    O1ODUS
     C                     Z-ADDSVTOKU    O1TOKU
     C                     Z-ADDSVNONY    O1NONY
     C                     WRITEODRPP011
      *
     C                     MOVELBAEDIK    SVEDIK
     C                     MOVELBACRME    SVCRME
     C                     Z-ADDBATOKU    SVTOKU
     C                     Z-ADDBANONY    SVNONY
     C                     Z-ADD0         @REC
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $YYMM   6
     C                     PARM           $RTN    1
      *
     C                     MOVEL$YYMM     @YYMM   60
     C                     Z-ADD0         @YYMM1  80
     C                     MOVEL$YYMM     @YYMM1
     C                     MOVE *BLANK    $RTN
     C                     TIME           SDATE
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         @REC    50
      *
     C                     ENDSR
