 |   C****       PNONY     OREQ '5129'
 |   C****       PNONY     OREQ '5130'
 |   C****       PNONY     OREQ '5135'
 |   C****       PNONY     OREQ '5138'
 |   C****       PNONY     OREQ '5140'
 |   C****       PNONY     OREQ '5141'
 |   C****       PNONY     OREQ '5166'
 |   C****       PNONY     OREQ '5167'
 |   C****       PNONY     OREQ '5221'
 |   C****       PNONY     OREQ '5222'
 |   C****       PNONY     OREQ '5223'
JW1  C****       PNONY     OREQ '5224'
JW2  C****       PNONY     OREQ '5165'
JW3  C****       PNONY     OREQ '5228'
JW3  C****       PNONY     OREQ '5230'
JW4  C****       PNONY     OREQ '5108'
     C****                 MOVE '1'       @@NXT
     C****                 ENDIF
JW4   * USE PART/PALLET FLAG
 |   C           PNONY     CHAINEDIPP42              98
 |   C           *IN98     IFEQ *OFF
 |   C           E4FLG1    ANDEQ'Y'
 |   C                     MOVE '1'       @@NXT
 |   C                     ELSE
 |   C                     MOVE *BLANK    @@NXT
JW4  C                     ENDIF
      *
     C           BASRYO    SUB  WKRQTY    WKSA
     C           WKSA      DIV  WKSYOS    WKMISU
     C                     MVR            @@MVR   30
     C           @@MVR     IFGT 0
     C                     ADD  1         WKMISU
     C                     ENDIF
     C                     Z-ADD*ZERO     WK#CON
     C*
     C* ADD # OF BOXES TO ABF6P01,ABF4P01
     C                     ADD  WKMISU    FC#CON
     C                     ADD  WKMISU    YBCONT
     C* CALUCULATE ONE PART TOTAL NET WEIGHT
     C* (UNIT WEIGHT * QTY)/1000*2.22
     C           WKSA      MULT WKASI     WKOT1  102       NET
     C           WKOT1     DIV  1000      WKOT2   72       G --> KG
     C           WKOT2     MULT 2.2046    WKOT3   92H      KG --> LB
     C                     ADD  WKOT3     TEIGH
     C*
     C* CALUCULATE TARE WEIGHT
     C           WKMISU    MULT 0.7       WKWBOX  72
     C                     ADD  WKWBOX    YBTARE
     C*
     C           KEY4      SETLLABF6L0A
     C           KEY4      READEABF6L0A                  95
     C           *IN95     DOWEQ'0'
     C*
     C           FCSKJY    IFEQ 'D'
     C                     GOTO #READ5
     C                     END
     C*
     C*          FCPBCD    IFEQ 'S'
     C*                    Z-ADDWWYY      FCKOYY           UPDATE YEAR
     C*                    Z-ADDWWMM      FCKOMM                  MONTH
     C*                    Z-ADDWWDD      FCKODD                  DAY
     C*                    Z-ADDWWHH      FCKOHH                  HOUR
     C*                    Z-ADDWWNN      FCKONN                  MINUTE
     C*                    MOVEL'AB#RFA'  FCKOME                  USER
     C*                    Z-ADDBASRYO    FCRQTY
     C*                    UPDATABF6L0A
     C*                    GOTO #READ5
     C*                    END
     C*
     C* CALUCULATE # OF CONTAINERS ON LAST PALLETE
     C                     ADD  FC#CON    WK#CON
     C*
     C*
     C           #READ5    TAG
     C           KEY4      READEABF6L0A                  95
     C                     END
     C*
     C           WK#CON    IFEQ 45
     C           @@NXT     OREQ '1'
     C                     Z-ADD*ZERO     WK#CON
     C                     ADD  1         W##PLT
     C                     END
     C*
     C                     Z-ADD*ZERO     @@BOX   40
     C* CREATE ABF6P01
     C* SET CONTAINER LABEL DATA
     C                     DO   WKMISU
     C*
     C                     CLEARABF6L0A
     C************         CLEARABF6P011
     C*
     C                     Z-ADDWWYY      FCKOYY           UPDATE YEAR
     C                     Z-ADDWWMM      FCKOMM                  MONTH
     C                     Z-ADDWWDD      FCKODD                  DAY
     C                     Z-ADDWWHH      FCKOHH                  HOUR
     C                     Z-ADDWWNN      FCKONN                  MINUTE
     C                     MOVEL'AB#RFA'  FCKOME                  USER
     C*
     C                     Z-ADDPNOHZ     FCSHDT           SHIP DATE
     C                     Z-ADDPNOBI     FCSHTM                TIME
     C                     MOVE BASIRE    FCSUPP           SUPPLIER
     C                     MOVE BASIRK    FCSFCT           FACTORY
     C                     MOVE BANUKE    FCDOCK           DOCK
     C                     MOVE BAODRN    FCORD#           OTDER#
     C                     MOVE BASBAN    FC####           KANBAN #
     C                     Z-ADDBASRYO    FCRQTY           REQ. QTY.
     C                     Z-ADDWKSYOS    FCUQTY           QTY/CONT.
     C                     MOVELBASHIN    FCIPAR           INTERNAL PART
      *
     C* EDITE PART NUMBER
     C                     MOVE *BLANK    FCCPAR
   B1C           WNO1      IFEQ 'W'
     C           WNO1      OREQ 'N'
     C                     MOVE WNO2      WCNO2
     C                     MOVELWNO3      WCNO4
     C                     ELSE
     C                     MOVE WNO4      WCNO5
     C                     MOVE WNO5      WCNO7
     C                     MOVELWNO6      WCNO9
   E1C                     END
     C*
     C                     Z-ADDBATOKU    FCCUST           CUSTOMER CODE
     C                     Z-ADDBANONY    FCDELY           DELIVERY CODE
     C********             Z-ADDWKMISU    FC#CON           # OF HAKO
     C                     Z-ADD*ZERO     FC#CON
     C                     MOVE 'S'       FCPBCD           IND. PALET/BOX
     C                     MOVE ' '       FCPRNT           ASN FLAG
     C                     EXSR @SEQ                       SET SEQ NUMBER
     C                     Z-ADDW##PLT    FC#PLT           PALET #
     C                     MOVELYBMANI    FCASN#           BILL OF LADING#
     C                     Z-ADDBADEYY    FCRYYY           RELEASED YY
     C                     Z-ADDBADEMM    FCRMMM                    MM
     C                     Z-ADDBADEDD    FCRDDD                    DD
     C*
     C                     ADD  WKSYOS    WK#QTY
     C                     ADD  1         WK#CON
     C                     ADD  1         @@BOX
JW5   * ADJUST FCCPAR
 "   C                     EXSR #ADJP
      *
     C                     WRITEABF6L0A
      *
     C           FC#PLT    IFNE *ZERO
     C           K#FW      CHAINABF6PW1              96
     C           *IN96     IFEQ *ON
     C                     Z-ADDFCSHDT    WCSHDT
     C                     Z-ADDFCSHTM    WCSHTM
     C                     MOVE FCDOCK    WCDOCK
     C                     Z-ADDFCCUST    WCCUST
     C                     Z-ADDFCDELY    WCDELY
     C                     Z-ADDFC#PLT    WC#PLT
     C                     MOVE *BLANK    WCPRNT
     C                     Z-ADDFCRYYY    WCRYYY
     C                     Z-ADDFCRMMM    WCRMMM
     C                     Z-ADDFCRDDD    WCRDDD
     C                     WRITEABF6PW11
     C                     ELSE
     C                     MOVE *BLANK    WCPRNT
     C                     UPDATABF6PW11
     C                     ENDIF
     C                     ENDIF
      *
     C*
     C* SET MASTER LABEL DATA
     C           WK#CON    IFEQ 45
     C                     Z-ADD@@BOX     FC#CON           # OF HAKO
     C                     MOVE 'M'       FCPBCD
     C                     MOVE *BLANK    FCSERL
     C                     EXSR @SEQ
     C                     Z-ADDWK#QTY    FCRQTY
     C                     Z-ADD*ZERO     WK#QTY
     C                     Z-ADD*ZERO     @@BOX
JW5   * ADJUST FCCPAR
 "   C                     EXSR #ADJP
      *
     C                     WRITEABF6L0A
     C*
     C* PALLETE NUMBER
     C                     ADD  1         W##PLT
     C                     Z-ADD*ZERO     WK#CON
      *
     C                     Z-ADDW##PLT    @@PLT   20
     C           @@PLT     LOKUPPLT                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         @P
     C                     Z-ADD@@PLT     PLT,@P
     C                     ENDIF
      *
     C                     END
     C                     END
     C*
     C* SET MASTER LABEL DATA
     C           WK#CON    IFNE *ZERO
     C                     Z-ADD@@BOX     FC#CON           # OF HAKO
     C                     MOVE 'M'       FCPBCD
     C                     MOVE *BLANK    FCSERL
     C                     EXSR @SEQ
     C                     Z-ADDWK#QTY    FCRQTY
     C                     Z-ADD*ZERO     WK#QTY
JW5   * ADJUST FCCPAR
 "   C                     EXSR #ADJP
      *
     C                     WRITEABF6L0A
     C                     END
     C                     Z-ADDW##PLT    WB#PAL
     C*
     C                     CLOSEABF6L06
     C*
      * set flag that an item qty increased on a pallet...
     C                     MOVE '1'       @@INCR  1
      *
     C                     ENDSR
     C**************************************************************************
JW5  C*  #ADJP : ADJUST FCCPAR (REMOVE FIRST CHARACTER IF IT IS BLANK)
 .   C**************************************************************************
 .   C           #ADJP     BEGSR
 .    *
 .   C                     MOVELFCCPAR    LTR2    2
 .   C           LTR2      IFEQ ' W'
 .   C                     MOVE FCCPAR    LTR19  19
 .   C                     MOVELLTR19     FCCPAR    P
 .   C                     ENDIF
 .    *
JW5  C                     ENDSR
     C**************************************************************************
     C*  @SEQ  : SET SEQ #
     C**************************************************************************
     C           @SEQ      BEGSR
     C*
     C* GET THE SEQUENCE NUMBER
     C           WSEQ#     IFEQ 999999
     C                     Z-ADD1         WSEQ#
     C                     ELSE
     C                     ADD  1         WSEQ#
     C                     END
     C                     Z-ADDWSEQ#     FCSEQ#
     C*
     C                     ENDSR
     C***********************************************************
     C* END
     C***********************************************************
     C           @END      BEGSR
     C*
     C                     OPEN ABF6L06
     C                     Z-ADD*ZERO     @P
     C                     Z-ADD*ZERO     @@PLT   20
     C           KEY44     SETLLABF6L0A
     C           *IN95     DOUEQ*ON
     C           KEY44     READEABF6L0A             N    95
     C           *IN95     IFEQ *OFF
     C           FC#PLT    IFNE @@PLT
     C                     ADD  1         @P
     C                     Z-ADDFC#PLT    WB#PAL
     C           KEY4      SETGTABF6L0A
     C                     ITER
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C* UPDATE ABF4P01(# OF BOX,WEIGHT,# OF PALLETE)
     C           *IN94     IFEQ '0'
     C*                    Z-ADD*ZERO     YB#PAL
     C*          1         DO   100       @P
     C*          PLT,@P    IFEQ *ZERO
     C*                    LEAVE
     C*                    ELSE
     C*                    ADD  1         YB#PAL
     C*                    ENDIF
     C*                    ENDDO
      *
     C                     Z-ADD@P        YB#PAL
      *
     C                     ADD  TEIGH     YBWEIT
     C                     UPDATABF4P011
     C                     END
     C*
TCHK3C                     Z-ADDWSEQ#     CTNBR1
TCHK3C                     UPDATAB#PPCT1
TCHK3C*
      *
      *
      * if 1 part per pallet flag is set off (mixed pallet customer) AND
      *    an increase has been made to an item on a pallet,
      *    then check pallets to make sure it only has 1 master pallet label.
     C           @@NXT     IFEQ *BLANK
     C           @@INCR    ANDEQ'1'
     C           PNONY     ANDEQ'5165'
     C                     EXSR INCRSE
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
     C*
     C                     ENDSR
     C***********************************************************
      * qty for a part on a pallet increased
      * so check each pallet to make sure each part only has one master pallet
      *  label and make sure the container qty is correct.
      *
     C           INCRSE    BEGSR
      *
     C                     Z-ADD*ZERO     NP      30
      *
     C                     DO   YB#PAL    NP
     C                     Z-ADDNP        WB#PAL
     C                     EXSR CHKPLT
     C                     ENDDO
      *
     C                     ENDSR
     C***********************************************************
      * check this pallet....
      * since this is a mixed pallet customer and qty increased,
      *  make sure there's only one master label per part# and the container
      *  total for it is correct.
      *
     C           CHKPLT    BEGSR
      *
     C                     MOVE *OFF      *IN50
     C                     Z-ADD*ZERO     T#CQTY 100       totl container qty
     C                     Z-ADD*ZERO     T#MSTR  30       totl master labels
     C                     MOVE *BLANKS   SAVPRT 12        save part number
      *
     C           KEY4      SETLLABF6L0A
     C           *IN50     DOUEQ*ON
     C           KEY4      READEABF6L0A             N    50
     C           *IN50     IFEQ *OFF
      *
     C           FCIPAR    IFNE SAVPRT
     C           SAVPRT    ANDNE*BLANKS
      *
      * if more than 1 master label was found for this part/pallet,
      *    then update this part/pallet master labels.
     C           T#MSTR    IFGT 1
     C                     EXSR UPDMST
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     T#CQTY
     C                     Z-ADD*ZERO     T#MSTR
     C                     ENDIF
      *
     C                     MOVE FCIPAR    SAVPRT
      *
     C           FCPBCD    IFEQ 'M'
     C                     ADD  1         T#MSTR
     C                     ADD  FCRQTY    T#CQTY
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDDO
      *
      *   if more than 1 master label was found for this pallet, delete all
      *   but last master label and update container total for that master.
     C           T#MSTR    IFGT 1
     C                     EXSR UPDMST
     C                     ENDIF
      *
     C                     ENDSR
     C***********************************************************
      * update this part number on this pallet...
      * since there were multiple master labels found for this part, pallet,
      * go back through them and delete all but the last one and update the
      * total piece count in required qty (fcrqty).
      *
     C           UPDMST    BEGSR
      *
     C                     MOVE *OFF      *IN50
     C                     Z-ADD*ZERO     #MCNT   30       master label count
      *
     C           KEY4B     SETLLABF6L0A
     C           *IN50     DOUEQ*ON
     C           KEY4B     READEABF6L0A                  50
     C           *IN50     IFEQ *OFF
      *
     C           FCPBCD    IFEQ 'M'
     C                     ADD  1         #MCNT
      *
     C           #MCNT     IFLT T#MSTR
     C                     MOVE 'D'       FCSKJY
     C                     UPDATABF6L0A
     C                     ELSE
     C           #MCNT     IFEQ T#MSTR
     C                     Z-ADDT#CQTY    FCRQTY
     C                     UPDATABF6L0A
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
     C***********************************************************
