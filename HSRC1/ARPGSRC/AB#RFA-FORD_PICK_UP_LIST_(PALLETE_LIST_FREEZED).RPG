     C***********************************************************
     C*
     C                     EXSR @INZ
     C                     EXSR @MAIN
     C                     EXSR @END
     C***********************************************************
     C* INITIALIZE WORK AREA
     C***********************************************************
     C           @INZ      BEGSR
     C*
     C                     TIME           WTMDT
     C                     MOVE PNONY     WNONY   40
     C                     Z-ADDPNOHZ     WKSHDT
     C                     Z-ADDPREDT     WKREDT
     C*
     C                     Z-ADD5149      K14     40
     C                     Z-ADD0         WTARE   82
     C                     Z-ADD0         TEIGH   92
     C                     Z-ADD*ZERO     WKSYOS  70
     C                     Z-ADD*ZERO     WK#QTY  90
     C                     Z-ADD*ZERO     WKRQTY  90
     C                     Z-ADD*ZERO     WKSA   100
     C                     Z-ADD*ZERO     WKMISU  30
     C                     Z-ADD*ZERO     WK#CON  30
     C                     Z-ADD*ZERO     I       30
     C                     Z-ADD*ZERO     M       30
      *
     C                     Z-ADD*ZERO     PLT
     C                     Z-ADD*ZERO     @P      30
     C*
     C* GET SERIAL NUMBER
TCHK3C*                    OPEN ABF6L01
TCHK3C*                    MOVE *BLANK    @@IPAR 12
TCHK3C*          *HIVAL    SETGTABF6L0X
TCHK3C*                    READPABF6L0X                  92
TCHK3C*
TCHK3C*          *IN92     IFEQ '0'
TCHK3C*                    Z-ADDFCSEQ#    WSEQ#   90
TCHK3C*                    MOVE FCIPAR    @@IPAR 12
TCHK3C*                    ELSE
TCHK3C*                    Z-ADD*ZERO     WSEQ#
TCHK3C*                    END
TCHK3C*
TCHK3C*                    CLOSEABF6L01
TCHK3C*
TCHK3C           K#PPCT    KLIST
TCHK3C                     KFLD           K@KEY1  8
TCHK3C                     KFLD           K@KEY2  8
TCHK3C                     MOVEL'FORD'    K@KEY1    P
TCHK3C                     MOVEL'SEQ#'    K@KEY2    P
TCHK3C           K#PPCT    CHAINAB#PPCT              92
TCHK3C           *IN92     IFEQ *OFF
TCHK3C                     Z-ADDCTNBR1    WSEQ#   90
TCHK3C                     ELSE
TCHK3C                     MOVEL*ON       *INLR
TCHK3C                     RETRN
TCHK3C                     END
TCHK3C*
     C*
     C*
     C* GET MAX NUMBER OF PALLETE
     C           KEY3      CHAINABF4P011             94
     C           *IN94     IFEQ '0'
     C                     Z-ADDYB#PAL    W##PLT  30
     C                     Z-ADDYB#PAL    WB#PAL  20
     C                     END
     C*
     C                     ENDSR
     C***********************************************************
     C* MAIN
     C***********************************************************
     C           @MAIN     BEGSR
     C*
     C           KEY1      SETLLAB#PL121
     C           KEY1      READEAB#PL121                 90
     C*
     C           *IN90     DOWEQ'0'
     C*
     C           BASKJY    IFEQ 'D'
     C                     Z-ADD*ZERO     BASRYO
     C                     GOTO #READ1
     C                     END
     C*
     C           BANOBN    IFNE PNOBI
     C                     GOTO #READ1
     C                     END
     C*
     C           BARLDT    IFNE PREDT
     C           PREDT     ANDNE*ZERO
     C                     GOTO #READ1
     C                     END
     C*
     C* GET SYU-YO-SU
     C           BAUSYS    IFNE *ZERO
     C                     Z-ADDBAUSYS    WKSYOS
     C*
     C                     ELSE
     C           BASYOS    IFNE *ZERO
     C                     Z-ADDBASYOS    WKSYOS
     C*
     C                     ELSE
     C                     Z-ADD1         WKSYOS
     C                     END
     C                     END
     C*
     C* GET WEIGHT PER ONE PIECE
     C           KEY5      CHAINFCEPL011             93
   B1C           *IN93     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     93
   E1C                     END
     C*
   B1C           *IN93     IFEQ '0'
     C                     Z-ADDA2KASI    WKASI            FINISHED WEIGHT
     C*
     C                     ELSE
     C                     Z-ADD0         WKASI   72
   E1C                     END
      *
     C                     Z-ADDBASRYO    WSRYO   60
      *
     C*
     C                     Z-ADD*ZERO     WKRQTY
     C                     Z-ADD*ZERO     SEQ
     C                     Z-ADD*ZERO     MNO
     C                     Z-ADD*ZERO     I
     C                     Z-ADD*ZERO     M
     C* SUMMARY ABF6P01
     C                     OPEN ABF6L02
     C           KEY2      SETLLABF6P011
     C           KEY2      READEABF6P011                 91
     C           *IN91     DOWEQ'0'
     C*
     C           FCSKJY    IFNE ' '
     C                     GOTO #READ2
     C                     END
     C*
     C* IF CONTAINER LABEL, SAVE SEQ NUMBER TO TABLE
     C           FCPBCD    IFEQ 'S'
     C                     ADD  1         I
     C                     Z-ADDFCSEQ#    SEQ,I
     C           FCRQTY    IFNE BASRYO
     C                     Z-ADDBASRYO    FCRQTY
     C                     UPDATABF6P011
     C                     ENDIF
     C                     GOTO #READ2
     C                     END
      *
     C           BASRYO    IFNE *ZERO
     C           FC#PLT    LOKUPPLT                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         @P
     C                     Z-ADDFC#PLT    PLT,@P
     C                     ENDIF
     C                     ENDIF
     C*
     C                     ADD  1         M
     C                     Z-ADDFCSEQ#    MNO,M            MASTER LABEL
     C                     ADD  FCRQTY    WKRQTY
     C*
     C           #READ2    TAG
     C           KEY2      READEABF6P011                 91
     C                     END
     C*
     C                     CLOSEABF6L02
     C*
     C           BASRYO    IFLT WKRQTY
     C                     EXSR @DEC
     C*
     C                     ELSE
     C           BASRYO    IFGT WKRQTY
     C                     EXSR @INC
     C                     END
     C*
     C                     END
     C*
     C           #READ1    TAG
     C           KEY1      READEAB#PL121                 90
     C*
     C                     END
     C*
     C                     ENDSR
     C***********************************************************
     C* DECREASE
     C***********************************************************
     C           @DEC      BEGSR
     C*
TCHK1C*                    OPEN ABF6L01
TCHK1C                     OPEN ABF6L02
      * ONLY ONE S LABEL
     C           I         IFEQ 1
     C                     MOVE '1'       @1      1
     C                     ELSE
     C                     MOVE *BLANK    @1
     C                     ENDIF
     C*
     C           WKRQTY    SUB  BASRYO    WKSA
     C           WKSA      DIV  WKSYOS    WKMISU
     C                     MVR            @@MVR   30
     C           @@MVR     IFGT 0
     C                     ADD  1         WKMISU
     C                     ENDIF
     C*
     C* MINUS # OF BOXES FROM ABF6P01,ABF4P01
     C                     SUB  WKMISU    FC#CON
     C                     SUB  WKMISU    YBCONT
     C*
     C* CALUCULATE ONE PART TOTAL NET WEIGHT
     C* (UNIT WEIGHT * QTY)/1000*2.22
     C           WKSA      MULT WKASI     WKOT1  102       NET
     C           WKOT1     DIV  1000      WKOT2   72       G --> KG
     C           WKOT2     MULT 2.2046    WKOT3   92H      KG --> LB
     C                     SUB  WKOT3     TEIGH
     C*
     C* CALUCULATE TARE WEIGHT
     C           WKMISU    MULT 0.7       WKWBOX  72
     C                     SUB  WKWBOX    YBTARE
     C*
     C* DELETE CONTAINER LABEL FROM THE LAST SEQ#
B01  C                     DO   WKMISU
     C           I         IFLE 0
     C                     LEAVE
     C                     ENDIF
TCHK1C*          SEQ,I     SETLLABF6L0X
TCHK1C*          SEQ,I     READEABF6L0X                  92
TCHK1C                     Z-ADDSEQ,I     W@SEQ#
TCHK1C           KEY2A@    SETLLABF6P011
TCHK1C           KEY2A@    READEABF6P011                 92
B02  C           *IN92     DOWEQ'0'
B03  C           FCSKJY    IFEQ ' '
      *
     C           @1        IFEQ *BLANK
     C                     MOVE 'D'       FCSKJY
      *
     C           FC#PLT    IFNE *ZERO
     C           K#FW      CHAINABF6PW1              96
     C           *IN96     IFEQ *ON
     C                     Z-ADDFCSHDT    WCSHDT
     C                     Z-ADDFCSHTM    WCSHTM
     C                     MOVE FCDOCK    WCDOCK
     C                     Z-ADDFCCUST    WCCUST
     C                     Z-ADDFCDELY    WCDELY
     C                     Z-ADDFC#PLT    WC#PLT
     C                     MOVE *BLANK    WCPRNT
     C                     Z-ADDFCRYYY    WCRYYY
     C                     Z-ADDFCRMMM    WCRMMM
     C                     Z-ADDFCRDDD    WCRDDD
     C                     WRITEABF6PW11
     C                     ELSE
     C                     MOVE *BLANK    WCPRNT
     C                     UPDATABF6PW11
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     Z-ADDWWYY      FCSKYY
     C                     Z-ADDWWMM      FCSKMM
     C                     Z-ADDWWDD      FCSKDD
     C                     MOVEL'AB#RFA'  FCKOME
     C                     Z-ADDBASRYO    FCRQTY
     C           BAUSYS    IFNE *ZERO
     C           BAUSYS    ANDNEFCUQTY
     C                     Z-ADDBAUSYS    FCUQTY
     C                     ENDIF
      *
TCHK1C*                    UPDATABF6L0X
TCHK1C                     UPDATABF6P011
E03  C                     END
     C*
TCHK1C*          SEQ,I     READEABF6L0X                  92
TCHK1C           KEY2A@    READEABF6P011                 92
E02  C                     END
     C*
     C                     SUB  1         I
E01  C                     END
     C*
     C* UPDATE REQUESTED QTY
     C           I         DOWNE0
TCHK1C*          SEQ,I     SETLLABF6L0X
TCHK1C*          SEQ,I     READEABF6L0X                  92
TCHK1C                     Z-ADDSEQ,I     W@SEQ#
TCHK1C           KEY2A@    SETLLABF6P011
TCHK1C           KEY2A@    READEABF6P011                 92
B02  C           *IN92     DOWEQ'0'
B03  C           FCSKJY    IFEQ ' '
     C                     Z-ADDBASRYO    FCRQTY
TCHK1C*                    UPDATABF6L0X
TCHK1C                     UPDATABF6P011
E02  C                     END
TCHK1C*          SEQ,I     READEABF6L0X                  92
TCHK1C           KEY2A@    READEABF6P011                 92
     C*
     C                     END
     C                     SUB  1         I
     C                     END
     C*
     C* DELETE MASTER LABEL
     C                     SETOF                     88
B01  C           *IN88     DOWEQ'0'
     C*
TCHK1C*          MNO,M     SETLLABF6L0X
TCHK1C*          MNO,M     READEABF6L0X                  92
TCHK1C                     Z-ADDMNO,M     W@SEQ#
TCHK1C           KEY2A@    SETLLABF6P011
TCHK1C           KEY2A@    READEABF6P011                 92
B02  C           *IN92     DOWEQ'0'
B03  C           FCSKJY    IFEQ 'D'
     C                     GOTO #READ3
E03  C                     END
     C*
B03  C           WKSA      IFLT FCRQTY
     C                     SETON                     88
     C                     SUB  WKSA      FCRQTY
     C                     Z-ADDWWYY      FCKOYY
     C                     Z-ADDWWMM      FCKOMM
     C                     Z-ADDWWDD      FCKODD
     C                     MOVEL'AB#RFA'  FCKOME
     C                     MOVE ' '       FCPRNT
TCHK1C*                    UPDATABF6L0X
TCHK1C                     UPDATABF6P011
     C                     GOTO #READ3
     C*
E03  C                     END
     C*
B03  C           WKSA      IFEQ FCRQTY
     C                     SETON                     88
     C                     MOVE 'D'       FCSKJY
     C                     Z-ADDWWYY      FCSKYY
     C                     Z-ADDWWMM      FCSKMM
     C                     Z-ADDWWDD      FCSKDD
     C                     MOVEL'AB#RFA'  FCKOME
TCHK1C*                    UPDATABF6L0X
TCHK1C                     UPDATABF6P011
     C                     GOTO #READ3
E03  C                     END
     C*
B03  C           WKSA      IFGT FCRQTY
     C                     MOVE 'D'       FCSKJY
     C                     Z-ADDWWYY      FCSKYY
     C                     Z-ADDWWMM      FCSKMM
     C                     Z-ADDWWDD      FCSKDD
     C                     MOVEL'AB#RFA'  FCKOME
TCHK1C*                    UPDATABF6L0X
TCHK1C                     UPDATABF6P011
     C*
     C                     SUB  FCRQTY    WKSA
E03  C                     END
     C*
     C           #READ3    TAG
TCHK1C*          MNO,M     READEABF6L0X                  92
TCHK1C           KEY2A@    READEABF6P011                 92
E02  C                     END
     C*
     C                     SUB  1         M
     C*
E01  C                     END
TCHK1C*                    CLOSEABF6L01
TCHK1C                     CLOSEABF6L02
     C*
     C                     ENDSR
     C***********************************************************
     C* INCREASE
     C***********************************************************
     C           @INC      BEGSR
     C*
     C                     OPEN ABF6L06
      * NEXT PALLET
     C           WNONY     CHAINABFDL01              94
     C           *IN94     IFEQ *OFF
     C                     MOVE *BLANK    @@NXT
     C                     ELSE
     C                     MOVE *BLANK    @@NXT   1
     C                     ENDIF
      *
      * PART/PALLET (ONE PART PER PALLET)
     C**JW3      PNONY     IFEQ '5156'
     C****       PNONY     OREQ '5148'
     C****       PNONY     OREQ '5151'
     C****       PNONY     OREQ '5172'
     C****       PNONY     OREQ '5191'
     C****       PNONY     OREQ '5196'
     C****       PNONY     OREQ '5197'
TCHK1C****       PNONY     OREQ '5192'
TCHK1C****       PNONY     OREQ '5161'
TCHK1C****       PNONY     OREQ '5193'
TCHK2C****       PNONY     OREQ '5152'
TCHK1C****       PNONY     OREQ '5153'
TCHK1C****       PNONY     OREQ '5189'
TCHK1C****       PNONY     OREQ '5143'
TCHK1C****       PNONY     OREQ '5188'
TCHK1C****       PNONY     OREQ '5105'
TCHK4C****       PNONY     OREQ '5106'
TCHK1C****       PNONY     OREQ '5144'
TCHK1C****       PNONY     OREQ '5159'
TCHK1C****       PNONY     OREQ '5162'
TCHK1C****       PNONY     OREQ '5199'
TCHK1C****       PNONY     OREQ '5146'
