      * FCEPL01
     C           KEY5      KLIST
     C                     KFLD           BASHN1           INTERNAL PART1
     C                     KFLD           BASHN2                        2
     C                     KFLD           BASHN3                        3
      *
     C           K#FW      KLIST
     C                     KFLD           FCDELY
     C                     KFLD           FCDOCK
     C                     KFLD           FCSHDT
     C                     KFLD           FCSHTM
     C                     KFLD           FCRYYY
     C                     KFLD           FCRMMM
