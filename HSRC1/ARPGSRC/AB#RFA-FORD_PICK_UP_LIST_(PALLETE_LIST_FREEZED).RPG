     C           *ENTRY    PLIST
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           PNOHZ   80
     C                     PARM           PNOBI   20
     C                     PARM           PREDT   80
      * AB#PL12
     C           KEY1      KLIST
