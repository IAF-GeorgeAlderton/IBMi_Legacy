     H            Y.
     F***CHKR74*****************************************************************
     F*  PROGRAM    : PRINT SUBARU QUICK SHIP ORDER REPORT                     *
     F*  WRITTEN    : 7/24/2019                                                *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#PLA1 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      **************************************************************************
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           TODAY     SETLLAB#PLA1
     C                     DO   *HIVAL
     C           TODAY     READEAB#PLA1                  98
     C   98                LEAVE
      *
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C           BANONY    IFNE 3611
     C                     ITER
     C                     ENDIF
      * SHIP DATE
     C           BANOHZ    IFLE @NEXT
     C                     EXSR #PRINT
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           SEQ#      IFGE 1
     C                     MOVE '*'       $RTN
     C                     ELSE
     C                     MOVE ' '       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      * PRINT HEADER
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD4         LIN#
     C                     ENDIF
      * PRINT DETAIL
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C                     TIME           @SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
      * GET NEST BUSINESS DATE
     C                     MOVELTODAY     $DT8
     C                     MOVEL'+'       $SIGN
     C                     MOVEL'0001'    $DAYS
     C                     MOVE 'Y'       $IAF
     C                     CALL 'UTLR10'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN    1
     C                     MOVEL$TGT8     @NEXT   80
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** SUBARU QUICK SHIP'
     O                                   60 ' ORDER REPORT **    '
     O                                   99 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                         PAGE  Z  109
     O                                  106 'P.'
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   11 'CUST'
     O                                   17 'DELV'
     O                                   27 'SHP_DATE'
     O                                   33 'BIN'
     O                                   44 'USER_PART'
     O                                   58 'ORDER#'
     O                                   76 'QTY'
     O                                   81 'TYPE'
     O                                   90 'CRT_DATE'
     O                                   98 'TIME'
     O        E   04           @HDR
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O                                  120 '--------------------'
     O                                  130 '----------'
     O        E 1              @DTL
     O                         SEQ#  Z +001
     O                         BATOKU  +002
     O                         BANONY  +002
     O                         BANOHZ  +002 '    /  /  '
     O                         BANOBN  +002
     O                         BAMHN1  +002
     O                         BAMHN2  +001
     O                         BAMHN3  +001
     O                         BAODRN  +000
     O                         BASRYO1 +001
     O                         BAEDIK  +003
     O                         BACRHZ  +002 '    /  /  '
     O                         BACRTM  +002 '0 :  :  '
