     C* M-NO BF.6.2        PARM ﾉ cinﾒ                     *
     C******************************************************
     C           *ENTRY    PLIST
     C                     PARM           PTOKU   4
     C                     PARM           PLKBN   1
     C                     PARM           PTKOJ   1
     C                     PARM           PYKBN   1
     C                     PARM           PSRKB   1
     C           *IN01     IFEQ '0'
     C                     SETON                     01
     C                     Z-ADD*DATE     YYMD
     C                     Z-ADDSYY       DYY
     C                     Z-ADDSMD       DMD
     C                     MOVE *BLANK    MS
     C                     MOVE *BLANK    KTMEI
     C           PYKBN     IFEQ '1'
     C                     MOVE 'QCH PART'KTMEI   8
     C                     ELSE
     C           PYKBN     IFEQ '2'
     C                     MOVE 'NOT QCH 'KTMEI
     C                     ELSE
     C                     MOVE 'NO APPO 'KTMEI
     C                     END
     C                     END
     C                     MOVE *BLANK    SRMEI
     C           PSRKB     IFEQ 'A'
     C                     MOVE ' PLAN A 'SRMEI   8
     C                     ELSE
     C           PSRKB     IFEQ 'B'
     C                     MOVE 'RESULT B'SRMEI
     C                     ELSE
     C           PSRKB     IFEQ 'C'
     C                     MOVE ' PLAN C 'SRMEI
     C                     ELSE
     C                     MOVE 'ABNML OP'SRMEI
     C                     END
     C                     END
     C                     END
     C                     END
     C                     MOVE PTOKU     UTOKU   40
     C                     MOVE MD,1      HD
     C                     MOVE *BLANK    TMEIG
     C                     MOVE '-'       F1
     C                     MOVE '-'       F2
     C                     MOVE '-'       F3
     C                     SETOF                     02
     C           UTOKU     CHAINFGBPL011             02
     C           *IN02     IFEQ '0'
     C                     MOVELB2SMEI    TMEIG
     C                     END
     C******************************************************
     C* M-NO BF.6.3.1      mﾞ-j ﾉ ﾑvﾃv                     *
     C******************************************************
     C           IBTOKU    IFNE UTOKU
     C                     SETON                     LR
     C                     GOTO END
     C                     END
     C           *INL3     IFEQ '1'
     C                     WRITEGBFPR721
     C                     Z-ADD0         L       20
     C                     END
     C******************************************************
     C* M-NO BF.6.3.2      mﾞ-j xbﾅb m]c                  *
     C******************************************************
     C                     Z-ADDIBMTAN    TANK
     C           SSRYO     ADD  IBSRYO    SSRYO  110
     C           IBSRYO    MULT IBMTAN    KING   112H
     C           SKING     ADD  KING      SKING  112
     C           IBSRYO    MULT IBSZAJ    JRYO    91
     C           SJRYO     ADD  JRYO      SJRYO  111
     C           SKENS     ADD  1         SKENS   50
     C                     WRITEGBFPR722
     C           L         ADD  1         L
     C           P         ADD  1         P       30
     C           *INL1     IFEQ '0'
     C           L         IFGE 53
     C                     WRITEGBFPR721
     C                     Z-ADD0         L
     C                     END
     C                     END
     C           END       TAG
     CL1         ZSRYO     ADD  SSRYO     ZSRYO  110
     CL1         ZJRYO     ADD  SJRYO     ZJRYO  111
     CL1         ZKING     ADD  SKING     ZKING  112
     CL1         ZKENS     ADD  SKENS     ZKENS   50
     CL1         P         IFGT 1
     CL1                   WRITEGBFPR723
     CL1         L         ADD  1         L
     CL1                   END
     CL1                   Z-ADD0         P
     CL1                   Z-ADD0         SSRYO
     CL1                   Z-ADD0         SJRYO
     CL1                   Z-ADD0         SKING
     CL1                   Z-ADD0         SKENS
     CL1         *INL2     IFEQ '0'
     CL1                   WRITEGBFPR726
     CL1         L         ADD  1         L
     CL1         L         IFGE 53
     CL1                   WRITEGBFPR721
     CL1                   Z-ADD0         L
     CL1                   END
     CL1                   END
     CL2                   Z-ADD1         X       20
     CL2         1         DO   50        X
     CL2         MS,X      IFNE *BLANK
     CL2         IBMSYO    CABEQMS,X      STEP21
     CL2                   ELSE
     CL2                   MOVE IBMSYO    MS,X
     CL2                   GOTO STEP21
     CL2                   END
     CL2                   END
     CL2         STEP21    TAG
     CL2         FSRYO     ADD  ZSRYO     FSRYO  110
     CL2         FJRYO     ADD  ZJRYO     FJRYO  111
     CL2         FKING     ADD  ZKING     FKING  112
     CL2         FKENS     ADD  ZKENS     FKENS   50
     CL2                   WRITEGBFPR724
     CL2         L         ADD  1         L
     CL2                   Z-ADD0         ZSRYO
     CL2                   Z-ADD0         ZJRYO
     CL2                   Z-ADD0         ZKING
     CL2                   Z-ADD0         ZKENS
     CL2         *INL3     IFEQ '0'
     CL2                   WRITEGBFPR726
     CL2         L         ADD  1         L
     CL2         L         IFGE 53
     CL2                   WRITEGBFPR721
     CL2                   Z-ADD0         L
     CL2                   END
     CL2                   END
     CL3                   WRITEGBFPR725
     CL3                   Z-ADD0         FSRYO
     CL3                   Z-ADD0         FJRYO
     CL3                   Z-ADD0         FKING
     CL3                   Z-ADD0         FKENS
     CLR                   WRITEGBFPR727
     CLR         MS30      IFNE *BLANK
