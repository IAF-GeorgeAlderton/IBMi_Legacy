      *@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@*
      *社内かんばん切り替えuﾇjｰ         *
      *工程情報のセット（最新データ）   *
      *@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@*
     CSR         #SB011    BEGSR
      *
     C                     CLEARHKT
     C                     CLEARHBM
     C                     CLEARHKI
     C                     CLEARHMB
     C                     CLEARHDH
     C                     CLEARHSU
     C                     CLEARHKD
      *
     C                     SETOF                     11
     C           KEY1      CHAINAAMPL111             11
     C           *IN11     IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     11
     C                     END
     C           *IN11     IFEQ '0'
      *
     C                     Z-ADD1         X       20
     C                     Z-ADD0         Y       20
     C           1         DO   15        X
     C                     MOVELSUK,X     WUKH    80
     C           WUKH      IFGT *DATE
     C           OKT,X     IFNE *BLANK
     C                     ADD  1         Y
     C                     MOVELOKT,X     HKT,Y
     C                     Z-ADDOBM,X     HBM,Y
     C                     MOVELOKI,X     HKI,Y
     C                     MOVELOMB,X     HMB,Y
     C                     MOVELODH,X     HDH,Y
     C                     MOVELOKD,X     HKD,Y
     C                     Z-ADDSSU,X     HSU,Y
     C                     END
     C                     ELSE
      *
     C           SKT,X     IFNE *BLANK
     C                     ADD  1         Y
     C                     MOVELSKT,X     HKT,Y
     C                     Z-ADDSBM,X     HBM,Y
     C                     MOVELSKI,X     HKI,Y
     C                     MOVELSMB,X     HMB,Y
     C                     MOVELSDH,X     HDH,Y
     C                     MOVELSKD,X     HKD,Y
     C                     Z-ADDSSU,X     HSU,Y
     C                     END
     C                     END
     C                     END
      *
     C                     END
      *
     CSR                   ENDSR
