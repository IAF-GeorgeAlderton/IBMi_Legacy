     C           $SBSYK    BEGSR
      *
      *--------------------------------*
      *構成品かんばんマスター        *
      *--------------------------------*
    AC           WKACD     IFEQ '3'
      *
     C           TKRKEY    SETLLAKBPL031
     C                     DO   *HIVAL
     C                     SETOF                     21
     C           TKRKEY    READEAKBPL031                 21
   21C           *IN21     IFEQ '0'
    DC           L1SKJY    IFEQ 'D'
     C           L1SKHZ    ANDLE*DATE
    DC                     ELSE
      *
    9C           L1STHZ    IFEQ *ALL'9'
     C                     Z-ADDL1SYOS    SYSS
    9C                     ELSE
      *
    *C           *DATE     IFGE L1UKHZ
     C           *DATE     ANDLTL1STHZ
     C                     SETON                     21
     C                     Z-ADDL1SYOS    SYSS
    *C                     END
    9C                     END
      *
    DC                     END
   21C                     END
     C  N21                ENDDO
    AC                     END
      *
      *--------------------------------*
      *構成品メッキかんばんマスター  *
      *--------------------------------*
    AC           WKACD     IFEQ 'P'
      *
     C           TKRKEY    SETLLAKGPL031
     C                     DO   *HIVAL
     C                     SETOF                     21
     C           TKRKEY    READEAKGPL031                 21
   21C           *IN21     IFEQ '0'
    DC           E1SKJY    IFEQ 'D'
     C           E1SKHZ    ANDLE*DATE
    DC                     ELSE
      *
    9C           E1STHZ    IFEQ *ALL'9'
     C                     Z-ADDE1SSYS    SYSS
     C                     Z-ADDE1CBKO    CBKO
     C           W@KBN     IFEQ ' '
     C                     MOVELE1RAIN    W@KBN
     C                     END
     C           CBKO      IFEQ 0
     C                     ADD  1         CBKO
     C                     END
     C                     Z-ADDE1BARA    BARA
     C                     Z-ADDE1BARB    BARB
    9C                     ELSE
      *
    *C           *DATE     IFGE E1UKHZ
     C           *DATE     ANDLTE1STHZ
     C                     SETON                     21
     C                     Z-ADDE1SSYS    SYSS
     C                     Z-ADDE1CBKO    CBKO
     C           W@KBN     IFEQ ' '
     C                     MOVELE1RAIN    W@KBN
     C                     END
     C           CBKO      IFEQ 0
     C                     ADD  1         CBKO
     C                     END
     C                     Z-ADDE1BARA    BARA
     C                     Z-ADDE1BARB    BARB
    *C                     END
    9C                     END
      *
    DC                     END
   21C                     END
     C  N21                ENDDO
    AC                     END
      *
      *--------------------------------*
      *構成品トンネルかんばんマスター*
      *--------------------------------*
