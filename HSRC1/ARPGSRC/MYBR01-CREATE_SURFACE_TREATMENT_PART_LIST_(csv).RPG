     C           CBKO      ANDNE0
     C           SYSS      ANDNE0
     C           BARB      ANDNE0
     C           W@ZSNA    DIV  W@KDOA    KAI12
     C           KAI12     DIV  CBKO      KAI13
     C           KAI13     DIV  SYSS      KAI14
     C           KAI14     DIV  BARB      W@BARA 152H
     C                     END
      *Ｎ月分
     C           W@SNNM    IFNE 0
     C           PHOSEI    ANDNE0
     C           W@KDO0    ANDNE0
     C           CBKO      ANDNE0
     C           SYSS      ANDNE0
     C           BARB      ANDNE0
     C           W@SNNM    MULT PHOSEI    KAI21
     C           KAI21     DIV  W@KDO0    KAI22
     C           KAI22     DIV  CBKO      KAI23
     C           KAI23     DIV  SYSS      KAI24
     C           KAI24     DIV  BARB      KAI25
     C           KAI25     DIV  100       W@BAR0 152H
     C                     END
      *Ｎ＋１月分
     C           W@S1NM    IFNE 0
     C           PHOSEI    ANDNE0
     C           W@KDO1    ANDNE0
     C           CBKO      ANDNE0
     C           SYSS      ANDNE0
     C           BARB      ANDNE0
     C           W@S1NM    MULT PHOSEI    KAI31
     C           KAI31     DIV  W@KDO1    KAI32
     C           KAI32     DIV  CBKO      KAI33
     C           KAI33     DIV  SYSS      KAI34
     C           KAI34     DIV  BARB      KAI35
     C           KAI35     DIV  100       W@BAR1 152H
     C                     END
      *Ｎ＋２月分
     C           W@S2NM    IFNE 0
     C           PHOSEI    ANDNE0
     C           W@KDO2    ANDNE0
     C           CBKO      ANDNE0
     C           SYSS      ANDNE0
     C           BARB      ANDNE0
     C           W@S2NM    MULT PHOSEI    KAI41
     C           KAI41     DIV  W@KDO2    KAI42
     C           KAI42     DIV  CBKO      KAI43
     C           KAI43     DIV  SYSS      KAI44
     C           KAI44     DIV  BARB      KAI45
     C           KAI45     DIV  100       W@BAR2 152H
     C                     END
      ***
      **発行種類
     C                     MOVEL'2'       E@SYU   1
      **
     C                     EXCPTDAT
      *
     C                     END
      *
     C                     ENDSR
