     C*@@@@@@@@*
     C           $SB910    BEGSR
      **
     C                     CALL 'MYBR03'
     C                     PARM           P@T     6
     C                     PARM           P@A     6
     C                     PARM           P@B     6
     C                     PARM           P@C     6
     C                     PARM           P@D     6
     C                     PARM           P@E     6
     C                     MOVE P@T       Q@T     60
     C                     MOVE P@A       Q@A     60
     C                     MOVE P@B       Q@B     60
     C                     MOVE P@C       Q@C     60
     C                     MOVE P@D       Q@D     60
     C                     MOVE P@E       Q@E     60
      **
     C           HINKEY    SETLLMBDPL011
     C                     DO   *HIVAL
     C           HINKEY    READEMBDPL011                 21
     C         21          LEAVE
      ***海外は読み飛ばし
     C*          F3NONY    IFEQ 0111
     C*          F3NONY    OREQ 0094
     C*          F3NONY    OREQ 0200
     C*          F3NONY    OREQ 0170
     C*          F3NONY    OREQ 0755
     C*          F3NONY    OREQ 0831
     C*                    ITER
     C*                    END
      ***
     C           W@UYMA    IFEQ Q@T
     C                     ADD  F3TNSU    W@ZSNA
     C                     END
     C           W@UYMA    IFEQ Q@A
     C                     ADD  F3ANSU    W@ZSNA
     C                     END
     C           W@UYMA    IFEQ Q@B
     C                     ADD  F3BNSU    W@ZSNA
     C                     END
     C           W@UYMA    IFEQ Q@C
     C                     ADD  F3CNSU    W@ZSNA
     C                     END
     C           W@UYMA    IFEQ Q@D
     C                     ADD  F3DNSU    W@ZSNA
     C                     END
     C           W@UYMA    IFEQ Q@E
     C                     ADD  F3ENSU    W@ZSNA
     C                     END
      *
     C                     ENDDO
      **
     C           $S910E    ENDSR
      *
      *@@@@@@@@@@@@@@@@@@*
      * 実績（構成品） *
      *@@@@@@@@@@@@@@@@@@*
     C           $SB911    BEGSR
     C                     Z-ADD*ZERO     WKZSNA 100
      **
     C                     CALL 'MYBR03'
     C                     PARM           P@T
     C                     PARM           P@A
