      *@@@@@@@@@@@@@@@@@@@@@@@@@*
     C           $SB920    BEGSR
     C                     MOVEL*BLANK    W@KBN   3
      *
      *構成品工程別月間必要数ファイル
     C                     MOVELM1KHN1    #GKHN1
     C                     MOVELM1KHN2    #GKHN2
     C                     MOVELM1KHN3    #GKHN3
     C           KEYAG1    SETLLAEBPL12
     C                     DO   *HIVAL
     C           KEYAG1    READEAEBPL12                  94
     C         94          LEAVE
      **構成品番工程　所番地登録マスター
     C                     MOVELAGKHN1    #MKHN1
     C                     MOVELAGKHN2    #MKHN2
     C                     MOVELAGKHN3    #MKHN3
     C                     MOVELAGKBMN    #MKBMJ
     C                     MOVELAGUKER    #MUKRJ
     C                     MOVELWKACD     #MKDAI
     C           KEYM51    SETLLAKHPL05
     C                     DO   *HIVAL
     C           KEYM51    READEAKHPL05                  95
     C         95          LEAVE
      **削除
     C           M5SKJY    IFEQ 'D'
     C           M5SKHZ    ANDLE*DATE
     C                     ITER
     C                     END
      **所番地セット
     C                     MOVELM5NTK1    WTR21
     C                     MOVELM5NTK2    WTR22
     C                     MOVELM5NTK3    WTR23
     C                     MOVELM5NTK4    WTR24
      *
      *--------------------------------*
      *構成品メッキかんばんマスター  *
      *--------------------------------*
    AC           WKACD     IFEQ 'P'
      *
     C           TR2KEY    SETLLAKGPL031
     C                     DO   *HIVAL
     C                     SETOF                     21
     C           TR2KEY    READEAKGPL031                 21
   21C           *IN21     IFEQ '0'
    DC           E1SKJY    IFEQ 'D'
     C           E1SKHZ    ANDLE*DATE
    DC                     ELSE
      *
    9C           E1STHZ    IFEQ *ALL'9'
     C                     MOVELE1RAIN    W@KBN
     C                     GOTO $S920E
    9C                     ELSE
      *
    *C           *DATE     IFGE E1UKHZ
     C           *DATE     ANDLTE1STHZ
     C                     SETON                     21
     C                     MOVELE1RAIN    W@KBN
     C                     GOTO $S920E
    *C                     END
    9C                     END
      *
    DC                     END
   21C                     END
     C  N21                ENDDO
    AC                     END
      *
      *--------------------------------*
      *構成品トンネルかんばんマスター*
      *--------------------------------*
    AC           WKACD     IFEQ 'Q'
      *
     C           TR2KEY    SETLLAKIPL031
     C                     DO   *HIVAL
     C                     SETOF                     21
     C           TR2KEY    READEAKIPL031                 21
   21C           *IN21     IFEQ '0'
    DC           E2SKJY    IFEQ 'D'
     C           E2SKHZ    ANDLE*DATE
    DC                     ELSE
      *
    9C           E2STHZ    IFEQ *ALL'9'
     C                     MOVELE2RAIN    W@KBN
     C                     GOTO $S920E
    9C                     ELSE
      *
    *C           *DATE     IFGE E2UKHZ
     C           *DATE     ANDLTE2STHZ
     C                     SETON                     21
     C                     MOVELE2RAIN    W@KBN
     C                     GOTO $S920E
    *C                     END
    9C                     END
      *
    DC                     END
   21C                     END
     C  N21                ENDDO
    AC                     END
     C*--------------------------------*
   95C                     ENDDO
   94C                     ENDDO
