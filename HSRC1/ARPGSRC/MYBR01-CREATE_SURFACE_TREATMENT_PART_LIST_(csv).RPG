     C           M3SKHZ    ANDLE*DATE
     C                     SETON                     11
     C                     END
     C           *IN11     IFEQ '0'
      *
     C                     Z-ADD1         X
     C                     Z-ADD0         Y
     C           1         DO   15        X
     C                     MOVELNUK,X     WUKH
     C           WUKH      IFGT *DATE
     C           QKT,X     IFNE *BLANK
     C                     ADD  1         Y
     C                     MOVELQKT,X     HKT,Y
     C                     Z-ADDQBM,X     HBM,Y
     C                     MOVELQMB,X     HMB,Y
     C                     MOVELQDH,X     HDH,Y
     C                     MOVELQKD,X     HKD,Y
     C                     Z-ADDNSU,X     HSU,Y
