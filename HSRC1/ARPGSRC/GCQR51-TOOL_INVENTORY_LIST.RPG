     H            Y/
     F***************************************************
     F*  TOOL INVENTORY LIST                            *
     F*                                                 *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FGCQPW51 CF  E                    WORKSTN
     F                                              KINFDS @INFDS
     FECSPL10 IF  E           K        DISK
     FGDIPL19 IF  E           K        DISK
     FGDIPL27 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *------------------------------------------------------------
     E                    SBT     1   1 40
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   80W@YMD
     I                                        1   40W@YY
     I                                        5   60W@MM
     I                                        7   80W@DD
     I            DS
     I                                        1   80@@YMD
     I                                        1   40@@YY
     I                                        5   60@@MM
     I                                        7   80@@DD
     I            DS
     I                                        1   80@OYMD
     I                                        1   40@OYY
     I                                        5   60@OMM
     I                                        7   80@ODD
     I            DS
     I                                        1   80IKYMD
     I                                        1   40IKTOYY
     I                                        5   60IKTOYM
     I                                        7   80IKTOYD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#GDI     KLIST
     C                     KFLD           E1KAT1
     C                     KFLD           E1KAT2
     C                     KFLD           E1KAT3
     C                     KFLD           W@YY
     C                     KFLD           W@MM
     C           K#GDIX    KLIST
     C                     KFLD           E1KAT1
     C                     KFLD           E1KAT2
     C                     KFLD           E1KAT3
     C           K#27      KLIST
     C                     KFLD           IIKAT1
     C                     KFLD           IIKAT2
     C                     KFLD           IIKAT3
     C                     KFLD           IIODER
      *
     C                     MOVEL'01'      W@ID    2
     C                     Z-ADD*DATE     W@YMD
     C                     SUB  2         W@MM
     C           W@MM      IFLE *ZERO
     C                     ADD  12        W@MM
     C                     SUB  1         W@YY
     C                     ENDIF
      *
     C                     MOVE *ALL'-'   @@LINE 80
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #WRT
     C                     MOVEL'99'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     SETOF                     6199
     C           D@QTY     IFEQ *ZERO
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   OUTPUT
      *------------------------------------------------------
     C           #WRT      BEGSR
      *
     C                     TIME           @@TIME  60
      *
     C           *LOVAL    SETLLECSPL10
     C           *IN80     DOUEQ*ON
     C                     READ ECSPL10                  80
     C           *IN80     IFEQ *OFF
     C           E1SKJY    ANDEQ*BLANK
     C           E1SQTY    ANDLED@QTY
      *
     C                     EXSR #OUT
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   OUTPUT
      *------------------------------------------------------
     C           #OUT      BEGSR
      *
     C                     MOVE *OFF      *IN55
     C           *IN98     IFEQ *OFF
     C                     EXCPT@HED
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
      *
     C                     Z-ADD*ZERO     @@QTY   50
      *
     C           K#GDI     SETLLGDIPL19
     C           *IN90     DOUEQ*ON
     C           K#GDIX    READEGDIPL19                  90
     C           *IN90     IFEQ *OFF
     C           IISKJY    ANDEQ*BLANK
     C           IIODHZ    ANDNE*ZERO
      *
     C                     MOVEA'00'      *IN,50
     C                     Z-ADDIIODRY    @OYY
     C                     Z-ADDIIODRM    @OMM
     C                     Z-ADDIIODRD    @ODD
     C           K#27      SETLLGDIPL27
     C           *IN95     DOUEQ*ON
     C           K#27      READEGDIPL27                  95
     C           *IN95     IFEQ *OFF
     C           IKSKJY    ANDEQ*BLANK
     C           IKNYUK    IFEQ *BLANK
     C           IKYMD     ANDGE*DATE
     C                     Z-ADDIKSURY    @@QTY   50
     C                     Z-ADDIKTOYY    @@YY
     C                     Z-ADDIKTOYM    @@MM
     C                     Z-ADDIKTOYD    @@DD
     C                     MOVE IKINVO    @@INV   6
     C           *INOF     IFEQ *ON
     C                     EXCPT@HED
     C                     EXCPT@DLIN
     C                     ELSE
     C           *IN55     IFEQ *OFF
     C                     EXCPT@DLIN
     C                     ENDIF
     C                     ENDIF
      *
     C                     EXCPT@DTL
     C  N55                MOVE *ON       *IN55
     C  N50                MOVE *ON       *IN50
     C                     ENDIF
     C                     MOVE *ON       *IN51
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN51     IFEQ *OFF
     C                     Z-ADD*ZERO     @@YMD
     C                     Z-ADDIISURY    @@QTY   50
     C                     MOVE *BLANK    @@INV   6
     C           *INOF     IFEQ *ON
     C                     EXCPT@HED
     C                     EXCPT@DLIN
     C                     ELSE
     C           *IN55     IFEQ *OFF
     C                     EXCPT@DLIN
     C                     ENDIF
     C                     ENDIF
      *
     C                     EXCPT@DTL
     C  N55                MOVE *ON       *IN55
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                         UDATE Y  110
     O                         @@TIME   119 '  :  :  '
     O                                  123 'P.'
     O                         PAGE  Z  127
     O        E   02           @HED
     O                                   40 'TOOL INVENTORY LIST'
     O                         D@QTY Z   46
     O                                   55 'OR UNDER'
     O        E   04           @HED
     O                         SBT       77
     O        E   05           @HED
     O                                    5 'TOOL#'
     O                                   19 'LOCATION'
     O                                   29 'INVENTORY'
     O                                   38 'ORDER#'
     O                                   50 'ORDER DATE'
     O                                   59 'QTY'
     O                                   69 'ETA'
     O                                   79 'INVOICE#'
     O        E 1              @DLIN
     O                         @@LINE    80
     O        E 1              @DTL
     O                      N55E1KAT1     2
     O                      N55           3 '-'
     O                      N55E1KAT2     7
     O                      N55E1KAT3     8
     O                      N55E1KAT4     9
     O                      N55E1LOC1    12
     O                      N55          13 '-'
     O                      N55E1LOC2    15
     O                      N55          16 '-'
     O                      N55E1LOC3    18
     O                      N55          19 '-'
     O                      N55E1LOC4    20
     O                      N55E1SQTY1   29
     O                      N50IIODER    38
     O                      N50@OYMD     50 '    /  /  '
     O                         @@QTY 1   59
     O                         @@YMD     71 '    /  /  '
     O                         @@INV     78
