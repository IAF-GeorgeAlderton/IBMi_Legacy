     H            Y.
     F***CHKR56G****************************************************************
     F*  PROGRAM    : CHECK HONDA SHIPPER# CONFLICTION                         *
     F*  WRITTEN    : 2020.06.08                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'CHKR56G'
     F*                    PARM           $ASN    8
     F*                    PARM           $NONY   4
     F*                    PARM           $SHDT   8
     F*                    PARM           $BIN    2
     F*                    PARM           $RTN    1
     F*   IN  $ASN :  8A ASN#
     F*       $NONY:  4A DELIVERY CODE
     F*       $SHDT:  8A SHIP DATE
     F*       $BIN :  2A BIN#
     F*   OUT $RTN :  1A RETURN FLAG (Y=AVAILABLE, N=NOT AVAILABLE)
     F**************************************************************************
     FAB#PL2F3IF  E           K        DISK
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
      * READ PAST SHIPPER#
     C                     MOVE '*'       $RTN
     C           $ASN      SETLLAB#PL2F3
     C                     DO   *HIVAL
     C           $ASN      READEAB#PL2F3                 98
     C   98                LEAVE
      *
     C           AFNONY    IFNE @NONY
     C           AFSHDT    ORNE @SHDT
     C           AFBIN     ORNE @BIN
     C                     MOVE 'N'       $RTN
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           $RTN      IFEQ '*'
     C                     MOVE 'Y'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $ASN    8
     C                     PARM           $NONY   4
     C                     PARM           $SHDT   8
     C                     PARM           $BIN    2
     C                     PARM           $RTN    1
      *
     C                     MOVEL$NONY     @NONY   40
     C                     MOVEL$SHDT     @SHDT   80
     C                     MOVEL$BIN      @BIN    20
     C                     TIME           SDATE
      *
     C                     ENDSR
