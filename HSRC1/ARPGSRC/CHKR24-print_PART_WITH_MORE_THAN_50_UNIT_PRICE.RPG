     H            Y.
     F***CHKR24*****************************************************************
     F*  PRINT PART WITH MORE THAN $50 UNIT PRICE                              *
     F*  (RUN IN FCKC00 (10:10AM BY JOBSCDE)                                   *
     F*  WRITTEN BY JW (SRA)  2022.03.11                                       *
     F**************************************************************************
     FFBCPL01 IF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ FBCPL01                  91
     C   91                LEAVE
      * IGNORE
     C           FBSKJY    IFEQ 'D'
     C           FBNTAN    ORLT 50
     C           FBTSHZ    ORLT TODAY
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #PRINT
     C                     ENDDO
      *
     C                     MOVELSEQ#      $CNT
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD4         LIN#
     C                     ENDIF
      * DETAIL
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $CNT    4
      *
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     MOVEL'0000'    $CNT
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   45 '** PART WITH UNIT PR'
     O                                   65 'ICE MORE THAN $50 **'
     O                                  106 'DATE'
     O                         TODAY    109 '    .  .  '
     O                         NOW      119 '0 :  :  '
     O                                  122 'P.'
     O                         PAGE  Z  126
     O        E   02           @HDR
     O                                    1 '.'
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   11 'CUST'
     O                                   16 'DELV'
     O                                   18 'F'
     O                                   23 'DOCK'
     O                                   33 'USER PART'
     O                                   53 'UNIT PRICE'
     O                                   63 'EFF_DATE'
     O                                   75 'EXP_DATE'
     O                                   87 'UPD_DATE'
     O                                   97 'TIME'
     O                                  103 'USER'
     O                                  117 'IAF PART'
     O        E   04           @HDR
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O                                  120 '--------------------'
     O        E 1              @DTL
     O                         SEQ#    +001
     O                         FBTOKU  +002
     O                         FBNONY  +001
     O                         FBNKOJ  +001
     O                         FBNUKE  +001
     O                         FBMHN1  +001
     O                         FBMHN2  +001
     O                         FBMHN3  +001
     O                         FBNTAN1 +000
     O                         FBTKHZ  +002 '    /  /  '
     O                         FBTSHZ  +002 '    /  /  '
     O                         FBKOHZ  +002 '    /  /  '
     O                         FBKOHS  +004 '0 :  '
     O                         FBKOME  +001
     O                         FBSHIN  +000
