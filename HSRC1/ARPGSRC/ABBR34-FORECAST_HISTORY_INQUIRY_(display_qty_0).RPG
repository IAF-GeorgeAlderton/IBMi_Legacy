     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C                     EXSR #INIT
      * DATA EXIST?
     C           P@RTN     IFEQ *ON
     C                     GOTO ENDP
     C                     ENDIF
      *
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C           ENDP      TAG
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVELCMD1,1    D1CMD1
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     MOVE *BLANK    D1MSG
     C                     SETOF                     414243
     C                     SETOF                     4445
     C                     SETOF                     85
      *
     C                     SELEC
      * F1: END
     C           *INKA     WHEQ *ON
     C           *INKC     OREQ *ON
     C                     MOVE '99'      W@ID
      *
     C                     OTHER
      * ENTR KEY
     C                     EXSR #CHK1
     C           *IN85     IFEQ *OFF
     C                     MOVE '02'      W@ID
     C                     ENDIF
     C                     ENDSL
     C*
     C                     ENDSR
     C*------------------------------------------------------
     C*  CHECK 1ST SCREEN
     C*------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     MOVE *OFF      *IN85
      * CUST#
     C           D1TOKU    IFEQ 0
     C                     MOVELERR,1     D1MSG            ENTER CUST
     C                     SETON                     41  85
     C                     GOTO XCHK1
     C                     ENDIF
      * DELV#
     C           D1NONY    IFEQ 0
     C                     MOVELERR,2     D1MSG            ENTER DELV
     C                     SETON                     42  85
     C                     GOTO XCHK1
     C                     ENDIF
      * FACTORY
     C**         D1NKOJ    IFEQ *BLANK
     C**                   MOVELERR,3     D1MSG            ENTER FACTORY
     C**                   SETON                     43  85
     C**                   GOTO XCHK1
     C**                   ENDIF
      * DOCK
     C**         D1NUKE    IFEQ *BLANK
     C**                   MOVELERR,4     D1MSG            ENTER DOCK
     C**                   SETON                     44  85
     C**                   GOTO XCHK1
     C**                   ENDIF
      * PART#
     C           D1MHIN    IFEQ *BLANK
     C                     MOVELERR,5     D1MSG            ENTER PART#
     C                     SETON                     45  85
     C                     GOTO XCHK1
     C                     ENDIF
      * FORD FLAG
     C                     MOVELD1NONY    $DLV
     C                     CALL 'UTLR62B'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTN    1
     C           $GRP      IFEQ 'FRD'
     C                     MOVE 'Y'       @FORD   1
     C                     ELSE
     C                     MOVE 'N'       @FORD
     C                     ENDIF
     C                     MOVEL$NAME1    D1NAM
      * GET FORD PLANT CODE
     C           @FORD     IFEQ 'Y'
     C                     MOVELD1NONY    $NONY
     C                     MOVE *BLANK    $NUKE
     C                     CALL 'UTLR34D'
     C                     PARM           $NONY   4
     C                     PARM           $NUKE   4
     C                     PARM           $PLNT   5
     C                     PARM           $RTN    1
     C                     MOVEL$PLNT     D1NUKE
     C                     ENDIF
      * SET FORECAST DATA
     C           @FORD     IFEQ 'N'
     C                     EXSR #SET1
     C                     ELSE
     C                     EXSR #SFRD
     C                     ENDIF
      *
     C           RRN1      IFEQ 0
     C                     MOVELERR,6     D1MSG            NO DATA
     C                     SETON                     45  85
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           XCHK1     ENDSR
      *------------------------------------------------------
      * SET FORECAST DATA TO SFL01
      *------------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     Z-ADD0         DAT
     C                     Z-ADD0         @P      20
     C                     MOVELD1MHN1    K@MHN1
     C                     MOVELD1MHN2    K@MHN2
     C                     MOVELD1MHN3    K@MHN3
     C                     MOVELD1MHN4    K@MHN4
     C                     MOVELD1NONY    K@NONY
     C                     MOVELD1NKOJ    K@NKOJ
     C                     MOVELD1NUKE    K@NUKE
      * RECEIVED DATE
     C                     Z-ADDTODAY     K@RCDT
      *
     C                     Z-ADD1         @PAGE   20
     C                     Z-ADD0         XXRRN1  40
     C                     EXSR #SET12
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #SET12    BEGSR
      *------------------------------------------------------
     C                     Z-ADD0         RRN1    40
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD0         DT1
     C                     Z-ADD0         DTE
     C                     Z-ADD99999999  DT2
     C                     Z-ADD0         X       30
     C                     Z-ADD0         Y       30
     C                     Z-ADD0         @PDAT   80
      *
     C           K#KEY     SETGTABBPL51
     C           *IN90     DOUEQ*ON
     C           K#KEYX    REDPEABBPL51                  90
      *
     C           *IN90     IFEQ *OFF
     C           BBFLG1    ANDEQ*BLANK
      * RCV DATE
     C           BBRCDT    LOKUPDT1                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         X
      *
     C           X         IFEQ 8
     C                     Z-ADDBBRCDT    @PDAT   80
     C                     LEAVE
     C                     ENDIF
      *
     C           X         IFEQ 1
     C           BBRCDT    LOKUPDAT                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         @P
      *
     C                     Z-ADDBBRCDT    DAT,@P
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADDBBRCDT    DT1,X
     C                     Z-ADDBBRCDT    DTE,X
     C                     ENDIF
      * SHP DATE
     C           BBSDAT    LOKUPDT2                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         Y
     C           Y         IFLE 100
     C                     Z-ADDBBSDAT    DT2,Y
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     SORTADT2
      *
JW4  C           1         DO   99        Y
     C           DT2,Y     IFEQ 99999999
     C                     LEAVE
     C                     ENDIF
      *
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     Z-ADDDT2,Y     S@DATE
     C                     Z-ADDDT2,Y     H@DATE
     C           H@DATE    IFLE TODAY
     C                     Z-ADDRRN1      XXRRN1  40
     C                     ENDIF
      *
     C           D1SHIN    IFEQ *BLANK
     C                     MOVELBBSHIN    D1SHIN
     C                     ENDIF
      *
     C                     WRITESFL01
     C                     ENDDO
      *
     C           1         DO   7         X
     C           DT1,X     IFEQ 0
     C                     LEAVE
     C                     ENDIF
      *
     C                     Z-ADDDT1,X     K@RCDT
     C           K#KEY     SETLLABBPL51
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEABBPL51                  90
     C           *IN90     IFEQ *OFF
     C           BBFLG1    ANDEQ*BLANK
      *
     C                     Z-ADD1         Y
     C           BBSDAT    LOKUPDT2,Y                    10
     C           *IN10     IFEQ *ON
     C           Y         ANDLE100
     C           Y         CHAINSFL01                90
      *
ｼﾗ   C           *IN90     IFEQ *OFF
     C                     ADD  BBSQTY    QTY,X
      * EDIT QTY
     C                     MOVELQTY,X     $IN       P
     C                     CALL 'EDTR05C'
     C                     PARM           $IN     9
     C                     PARM           $OUT   11
     C                     MOVE $OUT      XTY,X
      *
     C                     UPDATSFL01
     C                     ENDIF
ｼﾗ    *
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDDO
      *
     C                     Z-ADDXXRRN1    W@RCN1  40
     C           W@RCN1    IFEQ 0
     C                     ADD  1         W@RCN1
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ND SCREEN
      *------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C           @PAGE     IFEQ 1
     C                     MOVELCMD1,2    D1CMD1
     C                     ELSE
     C                     MOVELCMD1,3    D1CMD1
     C                     ENDIF
      *
     C                     Z-ADDW@RCN1    #RCNO1
     C*
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C*                    Z-ADD@@REC     #RCNO1
     C           @@REC     IFNE 0
     C                     Z-ADD@@REC     W@RCN1
     C                     END
      *
     C                     SELEC
      * F1: END
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * F3: 1ST SCREEN
     C           *INKC     WHEQ *ON
     C           P@MHIN    IFEQ *BLANK
     C                     MOVEL'01'      W@ID
     C                     ELSE
     C                     MOVEL'99'      W@ID
     C                     ENDIF
      * F12: 1ST SCREEN
     C           *INKL     WHEQ *ON
     C           P@MHIN    IFEQ *BLANK
     C                     MOVEL'01'      W@ID
     C                     ELSE
     C                     MOVEL'99'      W@ID
     C                     ENDIF
      * F8: NEXT
     C           *INKH     WHEQ *ON
     C           @PAGE     ANDNE1
     C           @FORD     IFEQ 'N'
     C                     EXSR #NXT
     C                     ELSE
     C                     EXSR #FNXT
     C                     ENDIF
      * F9: BACK
     C           *INKI     WHEQ *ON
     C           @FORD     IFEQ 'N'
     C                     EXSR #PRV
     C                     ELSE
     C                     EXSR #FPRV
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      * PREVIOUS SCREEN
      *------------------------------------------------------
     C           #PRV      BEGSR
      *
     C                     ADD  1         @PAGE
     C                     Z-ADD@PDAT     K@RCDT
     C                     EXSR #SET12
     C           RRN1      IFEQ 0
     C                     EXSR #NXT
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      * NEXT SCREEN
      *------------------------------------------------------
     C           #NXT      BEGSR
      *
     C                     SUB  1         @PAGE
     C           @PAGE     IFEQ 0
     C                     Z-ADD1         @PAGE
     C                     ELSE
     C                     Z-ADD@PAGE     X
     C                     Z-ADDDAT,X     K@RCDT
     C                     EXSR #SET12
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      * NEXT SCREEN (FORD)
      *------------------------------------------------------
     C           #SFRD     BEGSR
      *
     C                     Z-ADD0         DAT
     C                     Z-ADD0         @P
     C                     Z-ADDTODAY     K@ISDT
      *
     C                     Z-ADD1         @PAGE   20
     C                     EXSR #SFRD2
      *
     C                     ENDSR
      *------------------------------------------------------
      * NEXT SCREEN (FORD) PART2
      *------------------------------------------------------
     C           #SFRD2    BEGSR
      *
     C                     Z-ADD0         RRN1    40
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD0         QTY
      *
     C                     MOVELD1MHIN    K@PART
     C                     MOVELD1NUKE    F9DOCK
     C                     Z-ADD0         @PDAT
      * RECEIVED DATE
     C                     Z-ADD0         DT1
     C                     Z-ADD0         DTE
     C                     Z-ADD99999999  DT2
     C                     Z-ADD0         X       30
     C                     Z-ADD0         Y       30
     C           K#F14     SETGTABFPL14
      *
     C           *IN90     DOUEQ*ON
     C           K#F14X    REDPEABFPL14                  90
      *
     C           *IN90     IFEQ *OFF
      * SHP DATE
     C           FBCEDT    ADD  20000000  W@DT8   80
      *
     C           W@DT8     LOKUPDT2                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         Y
     C           Y         IFLE 99
     C                     Z-ADDW@DT8     DT2,Y
     C                     ENDIF
     C                     ENDIF
      * RCV DATE
     C           FBSIDT    ADD  20000000  W@DT8   80
     C           W@DT8     LOKUPDT1                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         X
     C           X         IFEQ 8
     C                     Z-ADDW@DT8     @PDAT   80
     C                     LEAVE
     C                     ENDIF
     C           X         IFEQ 1
     C           W@DT8     LOKUPDAT                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         @P
     C                     Z-ADDW@DT8     DAT,@P
     C                     ENDIF
      *
     C                     ENDIF
     C                     Z-ADDW@DT8     DT1,X
     C                     Z-ADDW@DT8     DTE,X
     C                     Z-ADDW@DT8     @PDAT   80
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     SORTADT2
      *
     C           1         DO   99        Y
     C           DT2,Y     IFEQ 99999999
     C                     LEAVE
     C                     ENDIF
      *
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     Z-ADDDT2,Y     S@DATE
     C                     Z-ADDDT2,Y     H@DATE
     C           H@DATE    IFLE TODAY
     C                     Z-ADDRRN1      XXRRN1  40
     C                     ENDIF
      *
     C           D1SHIN    IFEQ *BLANK
     C                     MOVELFBIPAR    D1SHIN
     C                     ENDIF
      *
     C                     WRITESFL01
     C                     ENDDO
      *
     C           1         DO   99        X
     C           DT2,X     IFEQ 99999999
     C                     LEAVE
     C                     ENDIF
      * FORD
     C                     Z-ADDDT2,X     K@CEDT
     C           K#FD1X    SETLLABFPL16
     C           *IN90     DOUEQ*ON
     C           K#FD1X    READEABFPL16                  90
     C           *IN90     IFEQ *OFF
      *
     C                     Z-ADD1         Y
     C           FBSIDT    ADD  20000000  W@DT8   80
     C           W@DT8     LOKUPDT1,Y                    10
     C           *IN10     IFEQ *ON
     C           X         CHAINSFL01                90
     C                     Z-ADDFBQTY2    QTY,Y
      * EDIT QTY
     C                     MOVELQTY,Y     $IN       P
     C                     CALL 'EDTR05C'
     C                     PARM           $IN     9
     C                     PARM           $OUT   11
     C                     MOVE $OUT      XTY,Y
      *
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDDO
      *
     C                     Z-ADDXXRRN1    W@RCN1
     C           W@RCN1    IFEQ 0
     C                     ADD  1         W@RCN1
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
     C           #FPRV     BEGSR
      *------------------------------------------------------
     C                     ADD  1         @PAGE
     C                     Z-ADD@PDAT     K@ISDT
     C                     EXSR #SFRD2
      *
     C                     ENDSR
      *------------------------------------------------------
      *
      *------------------------------------------------------
     C           #FNXT     BEGSR
      *
     C                     SUB  1         @PAGE
     C           @PAGE     IFEQ 0
     C                     Z-ADD1         @PAGE
     C                     ELSE
     C                     Z-ADD@PAGE     X
     C                     Z-ADDDAT,X     K@ISDT
     C                     EXSR #SFRD2
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@TOKU  4
     C                     PARM           P@NONY  4
     C                     PARM           P@NKOJ  1
     C                     PARM           P@NUKE  5
     C                     PARM           P@MHIN 20
     C                     PARM           P@RTN   1
      *
     C           K#KEY     KLIST
     C                     KFLD           K@NONY  40
     C                     KFLD           K@NKOJ  1
     C                     KFLD           K@NUKE  4
     C                     KFLD           K@MHN1  5
     C                     KFLD           K@MHN2  5
     C                     KFLD           K@MHN3  5
     C                     KFLD           K@MHN4  5
     C                     KFLD           K@RCDT  80
      *
     C           K#KEYX    KLIST
     C                     KFLD           K@NONY  40
     C                     KFLD           K@NKOJ  1
     C                     KFLD           K@NUKE  4
     C                     KFLD           K@MHN1  5
     C                     KFLD           K@MHN2  5
     C                     KFLD           K@MHN3  5
     C                     KFLD           K@MHN4  5
      *
     C           K#FD1X    KLIST
     C                     KFLD           F9DOCK  5
     C                     KFLD           K@PART 12
     C                     KFLD           K@CEDT  60
      *
     C           K#F14     KLIST
     C                     KFLD           K@PART 12
     C                     KFLD           F9DOCK
     C                     KFLD           K@ISDT  60
      *
     C           K#F14X    KLIST
     C                     KFLD           K@PART 12
     C                     KFLD           F9DOCK
      *
     C                     TIME           SDATE
     C                     MOVE *OFF      P@RTN
     C                     MOVELP@TOKU    D1TOKU
     C                     MOVELP@NONY    D1NONY
     C                     MOVELP@NKOJ    D1NKOJ
     C                     MOVELP@NUKE    D1NUKE
     C                     MOVELP@MHIN    D1MHIN
      *
     C                     MOVEL'01'      W@ID    2
     C                     Z-ADD0         DTE
     C                     Z-ADDTODAY     WYMD
     C                     SUB  1         WMM
     C           WMM       IFEQ 0
     C                     Z-ADD12        WMM
     C                     SUB  1         WYY
     C                     ENDIF
      *
     C                     Z-ADD1         W@SHFT  20
      * CHECK DATA
     C           P@MHIN    IFNE *BLANK
     C                     EXSR #CHK1
     C           *IN85     IFEQ *OFF
     C                     MOVE '02'      W@ID
     C                     ELSE
     C                     MOVE *ON       P@RTN
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
