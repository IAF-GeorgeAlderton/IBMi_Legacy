     H            Y.
     F** ECSR99 *******************************************
     F*  FILE CONVERSION OF DIE OUTGOING DATA             *
     F*          2017.09.27  ITS.  T.MITSUI               *
     F*****************************************************
     F*          FILE DEFINITION                          *
     F*****************************************************
     F*==< DIE OUTGOING DATA ACCUMULATION FILE >==*
     FECSPL05 IF  E           K        DISK
     F*
     F*==< DIE KANBAN M/F >==*
     FGCQPL14 IF  E           K        DISK
     F*
     F*==< DIE STORE IN/OUT RESULT FILE >==*
     FECSPP80 O   E                    DISK
     F*
     C*****************************************************
     C*          KEY LIST                                 *
     C*****************************************************
     C*==< GCQPL14 : DIE KANBAN M/F >==*
     C           K@G11A    KLIST
     C                     KFLD           K@KAT1  2
     C                     KFLD           K@KAT2  4
     C                     KFLD           K@KAT3  1
     C                     KFLD           K@KIHZ  80
     C           K@G11B    KLIST
     C                     KFLD           K@KAT1
     C                     KFLD           K@KAT2
     C                     KFLD           K@KAT3
     C*
     C*****************************************************
     C*          MAIN ROUTINE                             *
     C*****************************************************
     C*==< INITIAL PROCESSING >==*
     C*                    ____________
     C           *LOVAL    SETLLECSPL05
     C                     EXSR #EC01
     C*                    ~~~~~~~~~~~~
     C*==< MAIN PROCESSING >==*
D----C           *IN91     DOWEQ'0'
|    C                     MOVELEQKAT1    K@KAT1
|    C                     MOVELEQKAT2    K@KAT2
|    C                     MOVELEQKAT3    K@KAT3
|    C                     Z-ADDEQYOHZ    K@KIHZ
|    C*                    ____________
|    C           K@G11A    SETGTGCQPL14
|    C                     EXSR #GC11
|    C*                    ~~~~~~~~~~~~
|D---C           *IN91     DOWEQ'0'
||   C           EQKAT1    ANDEQK@KAT1
||   C           EQKAT2    ANDEQK@KAT2
||   C           EQKAT3    ANDEQK@KAT3
||   C           EQYOHZ    ANDEQK@KIHZ
||   C*
||   C                     MOVELEQSKJY    E8SKJY
||   C                     Z-ADDEQSKHZ    E8SKHZ
||   C                     Z-ADDEQBMON    E8BMON
||   C                     MOVELEQKINO    E8KIBN
||   C                     MOVELEQHSON    E8RIYU
||   C                     MOVELEQKAT1    E8KAT1
||   C                     MOVELEQKAT2    E8KAT2
||   C                     MOVELEQKAT3    E8KAT3
||   C                     MOVEL*BLANK    E8KAT4
||I--C           *IN92     IFEQ '0'
|||  C                     MOVELT6TKR1    E8TKR1
|||  C                     MOVELT6TKR2    E8TKR2
|||  C                     MOVELT6TKR3    E8TKR3
|||  C                     MOVELT6TKR4    E8TKR4
|||  C                     MOVELT6TKR5    E8TKR5
||+--C                     ELSE
|||  C                     MOVEL*BLANK    E8TKR1
|||  C                     MOVEL*BLANK    E8TKR2
|||  C                     MOVEL*BLANK    E8TKR3
|||  C                     MOVEL*BLANK    E8TKR4
|||  C                     MOVEL*BLANK    E8TKR5
||E--C                     ENDIF
||   C                     Z-ADDEQKOSU    E8KOSU
||   C                     MOVEL'O'       E8IOKB
||   C                     MOVEL'H'       E8GSKB
||   C                     Z-ADDEQYOHZ    E8IOHZ
||   C           EQKOTI    MULT 100       E8IOJK
||   C                     MOVEL'ECSPP01' E8IOME    P
||   C                     MOVELEQKOME    E8OREQ
||   C                     MOVEL'OK'      E8HNTE
||   C                     MOVEL*BLANK    E8EMSG
||   C                     MOVEL*BLANK    E8PBAR
||   C                     MOVEL*BLANK    E8SBAR
||   C                     MOVEL*BLANK    E8LBAR
||   C                     MOVEL*BLANK    E8DBAR
||   C*                    _____________
||   C                     WRITEECSPP801
||   C                     EXSR #EC01
||   C*                    ~~~~~~~~~~~~~
|E---C                     ENDDO
E----C                     ENDDO
     C*
     C*==< FINAL PROCESSING >==*
     C                     SETON                     LR
     C                     RETRN
     C*
     C*****************************************************
     C*  #EC01   ECSPP01 READ                             *
     C*****************************************************
     C           #EC01     BEGSR
     C*
     C           #EC011    TAG
     C*                    ____________
     C                     READ ECSPL05                  91
     C*                    ~~~~~~~~~~~~
     C           *IN91     CABEQ'1'       #EC01E
     C*
I----C           EQSKJY    IFEQ 'D'
|    C           EQSKHZ    ANDLE*DATE
|    C                     GOTO #EC011
E----C                     ENDIF
     C*
     C           #EC01E    ENDSR
     C*****************************************************
     C*  #GC11   GCQPL14 REDPE                            *
     C*****************************************************
     C           #GC11     BEGSR
     C*
     C           #GC111    TAG
     C*                    ____________
     C           K@G11B    REDPEGCQPL14                  92
     C*                    ~~~~~~~~~~~~
     C*****      *IN92     CABEQ'1'       #GC11E
     C*
I----C*****      T6SKJY    IFEQ 'D'
|    C*****      T6SKHZ    ANDLE*DATE
|    C*****                GOTO #GC111
E----C*****                ENDIF
     C*
     C           #GC11E    ENDSR
     C*
