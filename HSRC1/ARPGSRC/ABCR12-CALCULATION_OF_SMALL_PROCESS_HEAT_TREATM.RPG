     H            Y.
     F*** ABCR12 ***********************************
     F* CALCULATION  OF SMALL PROCESS HEAT TREATMENT KANBAN SHEETS *
     F*         H.ITO           1990.12.15         *
     F*********************************** ABCR12 ***
     I            DS
     I                                        1   2 @KCDE
     I                                        1   1 @KCD1
     I                                        2   2 @KCD2
      *
     C           *ENTRY    PLIST
     C                     PARM           PARM1   2        LRﾆﾍｭc
     C                     PARM           PARM2   90       fhmbﾈｮmbﾇc
     C                     PARM           PARM3   50       ﾆｬcﾑcﾇc
     C                     PARM           PARM4   31       ﾆbﾛﾅg L.T
     C                     PARM           PARM5   31       a]ﾈﾞ] L.T
     C                     PARM           PARM6   31       udﾃcmb L.T
     C                     PARM           PARM7   3        ﾍgnﾒﾇc
     C                     PARM           PARM8   3        ﾍgnﾒﾜｮn
     C                     PARM           PARM9   1        f]ﾌﾞ] jﾞb
     C                     PARM           PARM10  1              ﾆｭc
     C                     PARM           PARM11  30       a]ﾈﾞ]ubﾇc
     C                     PARM           PARM12  40       f]ﾌﾞ]ubﾇc
     C                     PARM           PARM13  20       ﾌﾃﾇc ﾜｮn
     C                     PARM           PARM14  6        ﾆｭﾒﾍﾇﾞi
     C                     MOVE PARM7     @HITO   30
     C                     MOVE PARM8     #HITO   30
     C                     MOVE PARM9     @KCD1
     C                     MOVE PARM10    @KCD2
     C                     Z-ADDPARM4     @SLT    52
     C                     Z-ADDPARM5     @ALT    52
      *
     C           PARM1     IFEQ 'LR'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C* ibﾅ]ﾆg
     C*
     C                     SETOF                     01
     C           PARM2     DIV  20        @HSU    90       ﾍajﾒ ﾈｮmbﾇc
      *
     C                     Z-ADD0         @SYS   100       ﾜｮnﾆｬcﾑcﾇc
     C           PARM13    IFGT 1
     C           PARM3     MULT PARM13    @SYS
     C                     ELSE
     C                     Z-ADDPARM3     @SYS
     C                     END
      *
     C                     Z-ADD0         @HHK    72       ﾍajﾒﾈｮmbﾌﾃﾇc
     C           20        MULT @SYS      @GSY   110H      iﾞｮf]ﾆｬcﾑcﾇc
     C           @GSY      IFNE 0
     C           PARM2     DIV  @GSY      @HHK      H
     C                     END
      *
     C* a]ﾈﾞ] L.T ﾉ ibﾅ]
     C*
     C           @HHK      IFLT 0.25
     C           @SLT      IFLE 5
     C                     Z-ADD1         @ALT
     C                     ELSE
     C                     Z-ADD2         @ALT
     C                     END
     C                     END
     C           @HHK      IFGE 0.25
     C           @HHK      IFLT 5
     C           @SLT      IFLE 5
     C                     Z-ADD1         @ALT
     C                     ELSE
     C                     Z-ADD1.5       @ALT
     C                     END
     C                     END
     C                     END
     C           @HHK      IFGE 5
     C           @HHK      IFLT 20
     C           @SLT      IFLE 5
     C                     Z-ADD0.5       @ALT
     C                     ELSE
     C                     Z-ADD1.0       @ALT
     C                     END
     C                     END
     C                     END
     C           @HHK      IFGE 20
     C           @SLT      IFLE 5
     C                     Z-ADD0.25      @ALT
     C                     ELSE
     C                     Z-ADD0.5       @ALT
     C                     END
     C                     END
      *
     C* ﾆｭcﾒｭcﾎﾞﾍ] ﾆﾞｭcﾇc
     C*
     C           @SLT      ADD  @ALT      @TLT    42       nｰjﾓ L.T
     C           PARM6     ADD  @TLT      @ZLT    72       ﾈﾞ]jb L.T
     C           @HSU      MULT @ZLT      @BNS   112       ibﾅ]ﾆg ﾎﾞ]ﾆ
     C                     Z-ADD@SYS      @BNB    90              ﾎﾞ]tﾞ
     C                     Z-ADD0         @KTE    50
     C           @BNB      IFNE 0
     C           @BNS      DIV  @BNB      @WA    110
     C                     MVR            @KRI   110
     C           @KRI      IFNE 0
     C                     ADD  1         @WA
     C                     END
     C                     Z-ADD@WA       @KTE
     C                     END
     C                     Z-ADD0         @JYO    50       ﾆﾞｭcﾇc
     C           @KTE      IFGT 0
     C           @KTE      IFLE 1
     C                     Z-ADD1         @JYO
     C                     END
     C                     END
      *
     C* lcﾆﾞｭcf]ﾌﾞ]ibﾅ]ﾆg
     C*
     C           @KCDE     IFEQ '2A'
     C           PARM6     ADD  @TLT      @ZLT
     C           @HSU      MULT @ZLT      @BNS
     C                     Z-ADD@SYS      @BNB
     C                     Z-ADD0         @KTE
     C           @BNB      IFNE 0
     C           @BNS      DIV  @BNB      @KTE
     C                     MVR            @KRI
     C           @KRI      IFNE 0
     C                     ADD  1         @KTE
     C                     END
     C                     END
     C                     ELSE
      *
     C* 5ncﾎﾞ]f]ﾌﾞ]ibﾅ]ﾆg
     C*
     C           PARM6     ADD  @TLT      @ZLT
     C           @HSU      MULT @ZLT      @BNS
     C                     Z-ADD@SYS      @BNB
     C                     MULT 5         @BNB
     C                     Z-ADD0         @KTE
     C           @BNB      IFNE 0
     C           @BNS      DIV  @BNB      @KTE
     C                     MVR            @KRI
     C           @KRI      IFNE 0
     C                     ADD  1         @KTE
     C                     END
     C                     END
     C                     END
      *
     C                     Z-ADD@KTE      PARM12
     C                     ADD  @JYO      PARM12
     C                     ADD  PARM11    PARM12
      *
     C           @KCD2     IFEQ 'B'
     C           #HITO     IFEQ 0
     C                     Z-ADD@SYS      @BNB
     C           @HSU      DIV  @BNB      @KTE
     C                     MVR            @KRI
     C           @KRI      IFNE 0
     C                     ADD  1         @KTE
     C                     END
     C                     Z-ADD@KTE      @MAIS   40
     C           @MAIS     IFGT PARM12
     C                     Z-ADD@MAIS     PARM12
     C                     END
     C                     END
     C                     END
      *
     C           PARM12    IFLT @HITO
     C           PARM13    IFEQ 0
     C                     Z-ADD@HITO     PARM12
     C                     END
     C                     END
      *
     C                     RETRN
