     H            Y.
      ** AFDR25 ********************************************************
      *  OUTSOURCE BIN NUMBER ASSIGNMENT/LABEL PRINT                   *
      *    LEC      2021/08/11     CREATE
      ******************************************************************
     FAFDPWBN CF  E                    WORKSTN
     FAB#PPCT UF  E           K        DISK
     FAFDPP25 UF  E           K        DISK                      A
      *---------------------------------------------------
     E                    BIN        60  3
     E                    ERR     1  11 60
     E                    PFX    36  36  1
      *---------------------------------------------------
      * SYSTEM DATE AND TIME
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
     I            DS
     I                                        1 180 BIN
     I                                        1   3 BIN#01
     I                                        4   6 BIN#02
     I                                        7   9 BIN#03
     I                                       10  12 BIN#04
     I                                       13  15 BIN#05
     I                                       16  18 BIN#06
     I                                       19  21 BIN#07
     I                                       22  24 BIN#08
     I                                       25  27 BIN#09
     I                                       28  30 BIN#10
     I                                       31  33 BIN#11
     I                                       34  36 BIN#12
     I                                       37  39 BIN#13
     I                                       40  42 BIN#14
     I                                       43  45 BIN#15
     I                                       46  48 BIN#16
     I                                       49  51 BIN#17
     I                                       52  54 BIN#18
     I                                       55  57 BIN#19
     I                                       58  60 BIN#20
     I                                       61  63 BIN#21
     I                                       64  66 BIN#22
     I                                       67  69 BIN#23
     I                                       70  72 BIN#24
     I                                       73  75 BIN#25
     I                                       76  78 BIN#26
     I                                       79  81 BIN#27
     I                                       82  84 BIN#28
     I                                       85  87 BIN#29
     I                                       88  90 BIN#30
     I                                       91  93 BIN#31
     I                                       94  96 BIN#32
     I                                       97  99 BIN#33
     I                                      100 102 BIN#34
     I                                      103 105 BIN#35
     I                                      106 108 BIN#36
     I                                      109 111 BIN#37
     I                                      112 114 BIN#38
     I                                      115 117 BIN#39
     I                                      118 120 BIN#40
     I                                      121 123 BIN#41
     I                                      124 126 BIN#42
     I                                      127 129 BIN#43
     I                                      130 132 BIN#44
     I                                      133 135 BIN#45
     I                                      136 138 BIN#46
     I                                      139 141 BIN#47
     I                                      142 144 BIN#48
     I                                      145 147 BIN#49
     I                                      148 150 BIN#50
     I                                      151 153 BIN#51
     I                                      154 156 BIN#52
     I                                      157 159 BIN#53
     I                                      160 162 BIN#54
     I                                      163 165 BIN#55
     I                                      166 168 BIN#56
     I                                      169 171 BIN#57
     I                                      172 174 BIN#58
     I                                      175 177 BIN#59
     I                                      178 180 BIN#60
     I            DS
     I                                        1   3 BINNO
     I                                        1   1 @@CHR
     I                                        2   30@@NBR
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************
      *  MAIN
      *************************************************************
      *
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'00'      #SCRN0
     C           W@ID      CASEQ'01'      #SCRN1
     C           W@ID      CASEQ'02'      #SCRN2
     C           W@ID      CASEQ'03'      #SCRN3
     C           W@ID      CASEQ'04'      #SCRN4
     C           W@ID      CASEQ'05'      #SCRN5
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *
      *-----------------------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------------------
      * get label name and outq name for printing labels...
     C           K#PCT     KLIST
     C                     KFLD           K@KWD1  8
     C                     KFLD           K@KWD2  8
      *
     C                     MOVEL'OUTSRC  'K@KWD1
     C                     MOVEL'BINOUT  'K@KWD2
      *
     C           K#PCT     CHAINAB#PPCT             N51
     C           *IN51     IFEQ *OFF
     C                     MOVELCTCHR1    ##LBNM
     C                     MOVELCTCHR2    ##OUTQ
     C                     ENDIF
      *
     C                     MOVE '00'      W@ID    2
     C                     TIME           WTIME
      *
      *  get team member name.....
     C                     CALL 'UTLR31'
     C                     PARM           #USER
     C                     PARM           TMNAME 15
      *
     C                     ENDSR
      *
      *---------------------------------------------------
      *  Outsource Bin Menu
      *---------------------------------------------------
     C           #SCRN0    BEGSR
     C                     Z-ADD*ZERO     D@SEL#
      *
     C                     EXFMTDSP00
      *
     C                     MOVE *BLANKS   MSG
     C                     MOVE *OFF      *IN99
      *
     C                     DO
      *
      * F3
     C           *INKC     IFEQ *ON
     C                     MOVE '99'      W@ID
     C                     LEAVE
     C                     ENDIF
      *
      * check menu selection...
     C                     EXSR #CHK0
      *
     C           *IN99     IFEQ *OFF
     C                     SELEC
     C           D@SEL#    WHEQ 1
     C                     MOVE '01'      W@ID
     C           D@SEL#    WHEQ 2
     C                     MOVE '02'      W@ID
     C           D@SEL#    WHEQ 3
     C                     MOVE '03'      W@ID
     C           D@SEL#    WHEQ 4
     C                     MOVE '04'      W@ID
     C           D@SEL#    WHEQ 5
     C                     MOVE '05'      W@ID
     C                     ENDSL
     C                     ELSE
     C                     Z-ADD*ZERO     D@SEL#
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *
      *---------------------------------------------------
      * Check Menu selection
      *---------------------------------------------------
     C           #CHK0     BEGSR
      *
     C           D@SEL#    IFLE *ZERO
     C           D@SEL#    ORGT 5
     C                     MOVELERR,5     MSG
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     ENDSR
      *
      *---------------------------------------------------
      * Print new labels
      *---------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     MOVE *BLANKS   MSG
     C                     MOVE *OFF      *IN31
     C                     MOVE *OFF      *IN32
     C                     MOVE *OFF      *IN99
      *
     C                     DO
      * F12
     C           *INKL     IFEQ *ON
     C                     MOVE '00'      W@ID
     C                     Z-ADD*ZERO     D@SEL#
     C                     Z-ADD*ZERO     D@#NEW
     C                     Z-ADD*ZERO     D@#PER
     C                     LEAVE
     C                     ENDIF
      *
     C                     EXSR #CHK1
      *
      *  F5, no error
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #WRT1
     C                     MOVELERR,6     MSG
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *
      *---------------------------------------------------
      * check input for new label print
      *---------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     DO
      *
     C           D@#NEW    IFEQ *ZERO
     C                     MOVELERR,7     MSG
     C                     MOVE *ON       *IN31
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C           D@#PER    IFLE *ZERO
     C           D@#PER    ORGT 4
     C                     MOVELERR,3     MSG
     C                     MOVE *ON       *IN32
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *
      *---------------------------------------------------
      * Reprint bin labels
      *---------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     EXFMTDSP02
     C                     MOVE *BLANKS   MSG
     C                     MOVE *OFF      *IN41
     C                     MOVE *OFF      *IN99
      *
     C                     DO
      * F12
     C           *INKL     IFEQ *ON
     C                     MOVE *BLANKS   D@BIN
     C                     MOVE *BLANKS   BIN
     C                     Z-ADD*ZERO     B
     C                     Z-ADD*ZERO     D@SEL#
     C                     MOVE '00'      W@ID
     C                     LEAVE
     C                     ENDIF
      *
     C                     EXSR #CHK2
      *
     C           *IN99     IFEQ *OFF
     C           D@BIN     ANDNE*BLANKS
     C                     ADD  1         B       20
     C                     MOVELD@BIN     BIN,B
     C                     MOVEL*BLANKS   D@BIN
     C                     ENDIF
      *
      *   if no error and 60 bin #s entered, print them...
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*OFF
     C           B         ANDEQ60
     C                     EXSR #WRT2
     C                     MOVELERR,8     MSG
     C                     ENDIF
      *
      *  F5, no error
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #WRT2
     C                     MOVELERR,8     MSG
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *
      *---------------------------------------------------
      * check input for reprint bin labels
      *---------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     DO
      *
     C           D@BIN     IFEQ *BLANK
     C           *INKE     IFEQ *OFF
     C                     MOVELERR,1     MSG
     C                     MOVE *ON       *IN41
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C           D@BIN     CHAINAFDPP25             N51
     C           *IN51     IFEQ *ON
     C                     MOVELERR,1     MSG
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C           *IN51     IFEQ *OFF
     C           BNSKJY    ANDEQ'D'
     C                     MOVELERR,9     MSG
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C           D@BIN     LOKUPBIN                      51
     C           *IN51     IFEQ *ON
     C                     MOVELERR,2     MSG
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *
      *---------------------------------------------------
      * deactivate bin numbers screen
      *---------------------------------------------------
     C           #SCRN3    BEGSR
      *
     C                     EXFMTDSP03
     C                     MOVE *BLANKS   MSG
     C                     MOVE *OFF      *IN41
     C                     MOVE *OFF      *IN99
      *
     C                     DO
      * F12
     C           *INKL     IFEQ *ON
     C                     MOVE *BLANKS   D@BIN
     C                     MOVE *BLANKS   BIN
     C                     Z-ADD*ZERO     B
     C                     Z-ADD*ZERO     D@SEL#
     C                     MOVE '00'      W@ID
     C                     LEAVE
     C                     ENDIF
      *
     C                     EXSR #CHK3
      *
     C           *IN99     IFEQ *OFF
     C           D@BIN     ANDNE*BLANKS
     C                     ADD  1         B       20
     C                     MOVELD@BIN     BIN,B
     C                     MOVEL*BLANKS   D@BIN
     C                     ENDIF
      *
      *   if no error and 60 bin #s entered, update them...
     C           *IN99     IFEQ *OFF
     C           *INKJ     ANDEQ*OFF
     C           B         ANDEQ60
     C                     EXSR #UPD1
     C                     MOVELERR,10    MSG
     C                     ENDIF
      *
      *  F10, no error
     C           *IN99     IFEQ *OFF
     C           *INKJ     ANDEQ*ON
     C                     EXSR #UPD1
     C                     MOVELERR,10    MSG
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *
      *---------------------------------------------------
      * check input for deactivate bin numbers screen
      *---------------------------------------------------
     C           #CHK3     BEGSR
      *
     C                     DO
      *
     C           D@BIN     IFEQ *BLANK
     C           *INKJ     IFEQ *OFF
     C                     MOVELERR,1     MSG
     C                     MOVE *ON       *IN41
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C           D@BIN     CHAINAFDPP25             N51
     C           *IN51     IFEQ *ON
     C                     MOVELERR,1     MSG
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C           *IN51     IFEQ *OFF
     C           BNSKJY    ANDEQ'D'
     C                     MOVELERR,9     MSG
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C           D@BIN     LOKUPBIN                      51
     C           *IN51     IFEQ *ON
     C                     MOVELERR,2     MSG
     C                     MOVE *ON       *IN99
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *
      *---------------------------------------------------
      * call program to download bin data to csv file
      *---------------------------------------------------
     C           #SCRN4    BEGSR
     C                     CALL 'AFDC25X'
     C                     MOVELERR,11    MSG
     C                     MOVE '00'      W@ID
     C                     ENDSR
      *
      *---------------------------------------------------
      * call program for bin inquiry
      *---------------------------------------------------
     C           #SCRN5    BEGSR
     C                     CALL 'AFDR25I'
     C                     MOVE '00'      W@ID
     C                     ENDSR
      *
      *---------------------------------------------------
      *  write new bin assignment records, print labels
      *---------------------------------------------------
     C           #WRT1     BEGSR
      *
     C                     TIME           WTIME
     C                     Z-ADDD@#NEW    NUMLAB  30
     C                     Z-ADDD@#PER    ##QTY
     C                     MOVE 'N'       ##DMND
      *
     C                     DO   NUMLAB
      *
      * check bin file for deactivated bin #, if found then reuse...
     C                     EXSR #CHKBF
      * if not get new #
     C           BF#FLG    IFEQ 'N'
     C                     EXSR #NBR
     C                     ENDIF
      *
     C                     MOVELBINNO     ##BIN
      *
     C                     CLEARAFDPP251
     C                     MOVELBINNO     BNNOBN
     C                     Z-ADDSDATE     BNISDT
     C                     Z-ADDSTIME     BNISTM
     C                     MOVELTMNAME    BNISME
     C                     Z-ADDSDATE     BNLBDT
     C                     Z-ADDSTIME     BNLBTM
     C                     MOVELTMNAME    BNLBME
     C                     WRITEAFDPP251
      *
      * *******          Call Pgm to Print Label,  Demand = N
     C                     EXSR #LABEL
      *
     C                     ENDDO
      *
      *
      * *******          Release Spool File,  Demand = Y  LblQty = 0
     C                     Z-ADD*ZERO     ##QTY
     C                     MOVE 'Y'       ##DMND
     C                     EXSR #LABEL
      *
     C                     CLEARDSP01
     C                     MOVE '00'      W@ID
     C                     Z-ADD*ZERO     D@SEL#
      *
     C                     ENDSR
      *
      *---------------------------------------------------
      *  update bin assignment records, reprint labels
      *---------------------------------------------------
     C           #WRT2     BEGSR
      *
     C                     TIME           WTIME
     C                     Z-ADDB         NUMLAB  30
     C                     Z-ADD2         ##QTY
     C                     MOVE 'N'       ##DMND
      *
     C                     DO   NUMLAB    B
      *
      * *******          Call Pgm to Print Label,  Demand = N
     C                     MOVELBIN,B     BINNO
     C                     MOVELBINNO     ##BIN
     C                     EXSR #LABEL
      *
     C           BINNO     CHAINAFDPP25              51
     C           *IN51     IFEQ *OFF
     C                     Z-ADDSDATE     BNLBDT
     C                     Z-ADDSTIME     BNLBTM
     C                     MOVELTMNAME    BNLBME
     C                     UPDATAFDPP251
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVE *BLANKS   BIN
     C                     Z-ADD*ZERO     B
      *
      * *******          Release Spool File,  Demand = Y  LblQty = 0
     C                     Z-ADD*ZERO     ##QTY
     C                     MOVE 'Y'       ##DMND
     C                     EXSR #LABEL
      *
     C                     CLEARDSP02
     C                     MOVE '00'      W@ID
     C                     Z-ADD*ZERO     D@SEL#
      *
     C                     ENDSR
      *
      *---------------------------------------------------
      * check bin MF for deactivated bin# that can be reused
      *-----------------------------------------------------
     C           #CHKBF    BEGSR
      *
     C                     MOVE 'N'       BF#FLG  1
      *
     C           *LOVAL    SETLLAFDPP25
      *
     C           *IN55     DOWEQ*OFF
     C                     READ AFDPP25                  55
      *
     C           *IN55     IFEQ *OFF
     C           BNSKJY    IFEQ 'D'
     C                     MOVE 'Y'       BF#FLG
     C                     MOVELBNNOBN    BINNO
     C                     DELETAFDPP251
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *
      *-----------------------------------------------------
      * get next bin number for assignment
      *-----------------------------------------------------
     C           #NBR      BEGSR
      *
     C                     MOVEL'BIN#    'K@KWD2
      *
     C           K#PCT     CHAINAB#PPCT              95
     C           *IN95     IFEQ *OFF
     C                     ADD  1         CTNBR1
     C           CTNBR1    IFEQ 100
     C                     MOVELCTCHR1    @@CHR   1
     C                     Z-ADD1         P       30
     C           @@CHR     LOKUPPFX,P                    61
     C           *IN61     IFEQ *ON
     C                     ADD  1         P
     C                     MOVE PFX,P     @@CHR
     C                     MOVEL@@CHR     CTCHR1
     C                     Z-ADD*ZERO     CTNBR1
     C                     ENDIF
     C                     ENDIF
      *
     C                     UPDATAB#PPCT1
     C                     ENDIF
      *
     C                     MOVELCTCHR1    @@CHR
     C                     Z-ADDCTNBR1    @@NBR   20
      *
     C                     ENDSR
      *
      *----------------------------------------------------
      * call program to print bin label
      *-----------------------------------------------------
     C           #LABEL    BEGSR
      *
     C                     CALL 'AFDR25PR'
     C                     PARM           ##BIN   3
     C                     PARM           ##LBNM 15
     C                     PARM           ##OUTQ 10
     C                     PARM           ##QTY   30
     C                     PARM           ##DMND  1
      *
     C                     ENDSR
      *
      *----------------------------------------------------
      *  deactivate bin numbers in bin assignment file
      *---------------------------------------------------
     C           #UPD1     BEGSR
      *
     C                     TIME           WTIME
     C                     Z-ADDB         NUMBIN  30
      *
     C                     DO   NUMBIN    B
      *
     C                     MOVELBIN,B     BINNO
     C                     MOVELBINNO     ##BIN
      *
     C           BINNO     CHAINAFDPP25              51
     C           *IN51     IFEQ *OFF
     C                     MOVE 'D'       BNSKJY
     C                     Z-ADDSDATE     BNKODT
     C                     Z-ADDSTIME     BNKOTM
     C                     MOVELTMNAME    BNKOME
     C                     UPDATAFDPP251
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     CLEARDSP03
     C                     MOVE '00'      W@ID
     C                     Z-ADD*ZERO     D@SEL#
      *
     C                     ENDSR
      *
      *---------------------------------------------------
** ERR
INVALID BIN NUMBER.                                              01
BIN NUMBER ALREADY ENTERED.                                      02
ENTER # OF LABELS 1 - 4.                                         03
WE ARE OUT OF BIN NUMBERS.                                       04
INVALID SELECTION.                                               05
NEW BINS HAVE BEEN ASSIGNED AND LABELS PRINTED.                  06
NUMBER OF NEW BINS IS INVALID.                                   07
BIN LABELS HAVE BEEN PRINTED.                                    08
BIN NUMBER IS DEACTIVATED.                                       09
BIN NUMBERS HAVE BEEN DEACTIVATED.                               10
BIN DATA HAS BEEN DOWNLOADED SUCCESSFULLY.                       11
** PFX
0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ
