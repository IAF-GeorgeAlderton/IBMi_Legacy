     H            Y.
     F** UEXR34B ********************************************
     F*  PROGRAM: EXSUB- GET MATERIAL INFO FROM PART#       *
     F*  WRITTEN: J.WATANABE    2021.06.30                  *
     F*-----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UEXR34B'
     F*                    PARM           $SHIN  12
     F*                    PARM           $ZAIS  15
     F*                    PARM           $ZAIK   52
     F*                    PARM           $KIKI   31
     F*                    PARM           $RTN    1
     F*  IN  $SHIN : 12A  IAF PART#
     F*  OUT $ZAIK : 15A  MATERIAL NAME
     F*      $ZAIS :  5,2 WIRE DIAMETER     (5,2)
     F*      $KIKI :  3,1 MATERIAL PROPERTY (3,1)
     F*      $RTN  :  1A  RETURN CODE (BLANK=NO ERR, '*'=ERROR )
     F******************************************************
     FMRHPL21 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     I            DS
     I                                        1  12 KSHIN
     I                                        1   5 KSHN1
     I                                        6  10 KSHN2
     I                                       11  12 KSHN3
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      * GET FROM MRHPP21
     C           K#KEY     SETGTMRHPL21
     C                     DO   *HIVAL
     C           K#KEY     REDPEMRHPL21                  98
     C   98                LEAVE
      *
     C           EAGSJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELEAZANM    $ZAIS
     C                     Z-ADDEAKAZI    $ZAIK
     C                     Z-ADDEAKIKI    $KIKI
     C                     LEAVE
     C                     ENDDO
      * GET FROM FCEPP01
     C           $KIKI     IFEQ 0
     C           K#KEY     SETLLFCEPL01
     C                     DO   *HIVAL
     C           K#KEY     READEFCEPL01                  97
     C   97                LEAVE
      *
     C           A2GSKD    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELA2ZANM    $ZAIS
     C                     Z-ADDA2KAZI    $ZAIK
     C                     MOVELA2KIKI    NUM20   20
     C                     Z-ADDNUM20     $KIKI
     C                     LEAVE
     C                     ENDDO
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *======================================================
      * INITIAL SET
      *======================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SHIN  12
     C                     PARM           $ZAIS  15
     C                     PARM           $ZAIK   52
     C                     PARM           $KIKI   31
     C                     PARM           $RTN    1
      *
     C           K#KEY     KLIST
     C                     KFLD           KSHN1
     C                     KFLD           KSHN2
     C                     KFLD           KSHN3
      *
     C                     MOVEL$SHIN     KSHIN
     C                     MOVE *BLANK    $ZAIS
     C                     Z-ADD0         $ZAIK
     C                     Z-ADD0         $KIKI
     C                     MOVE *BLANK    $RTN
      *
     C                     ENDSR
