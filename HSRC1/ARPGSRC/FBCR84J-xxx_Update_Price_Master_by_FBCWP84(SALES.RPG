     H            Y.
     F****************************************************************
     F*  PROGRAM    : FBCR84                                         *
     F*  WRITTEN    : 04/04/2016                                     *
     F*  WRITTEN BY : JW (SRA)                                       *
     F*  FUNCTION   : READ FBCWP84 AND UPDATE SALES MASTER           *
     F****************************************************************
     FFBCWP84 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FFBCPL03 UF  E           K        DISK                      A
     FFBCWP85 O   E                    DISK
     FQPRINT  O   F     132     OF     PRINTER
      *---------------------------------------------------------------
     E                    TBL     1   1 40
      *
     I            DS
     I                                        1   80FBTKHZ
     I                                        1   40FBTKYY
     I                                        5   60FBTKMM
     I                                        7   80FBTKDD
     I            DS
     I                                        1   80F4EFDT
     I                                        1   40F4EFYY
     I                                        5   60F4EFMM
     I                                        7   80F4EFDD
     I            DS
     I                                        1   80F4KODT
     I                                        1   40F4KOYY
     I                                        5   60F4KOMM
     I                                        7   80F4KODD
     I            DS
     I                                        1   80F4KOTM
     I                                        1   20F4KOHH
     I                                        3   40F4KOSS
     I                                        5   60F4KOCC
     I            DS
     I                                        1   80@DATE
     I                                        1   40@DTYY
     I                                        5   60@DTMM
     I                                        7   80@DTDD
     I            DS
     I                                        1   60@TIME
     I                                        1   20@TMHH
     I                                        3   40@TMMN
     I                                        5   60@TMSS
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ******************************************************
      *                    MAIN PROCESS
      ******************************************************
      * Initial Process
     C                     EXSR @INIT
      *
      * UPADTE PRICE MASTER ---------------
     C           *LOVAL    SETLLFBCWP84
     C                     MOVE *OFF      *IN82
     C           *IN82     DOUEQ*ON
     C                     READ FBCWP84                  82
     C           *IN82     IFEQ *OFF
     C                     EXSR @UPD1
     C                     ENDIF
     C                     ENDDO
      *
      * Print Footer------------------------------
     C           UPD#      ADD  ADD#      TTL#
     C           TTL#      IFNE 0
     C                     EXCPTFOT1
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ******************************************************
      *                  UPDATE MASTER
      ******************************************************
     C           @UPD1     BEGSR
      * SET KEY FOR PRICE MASTER
     C                     Z-ADDF4TOKU    FBTOKU
     C                     Z-ADDF4NONY    FBNONY
     C                     MOVELF4MHN1    FBMHN1
     C                     MOVELF4FACT    FBNKOJ
     C                     MOVELF4DOCK    FBNUKE
     C                     MOVELF4MHN2    FBMHN2
     C                     MOVELF4MHN3    FBMHN3
     C                     MOVELF4MHN4    FBMHN4
     C                     Z-ADDF4EFYY    FBTKYY
     C                     Z-ADDF4EFMM    FBTKMM
     C                     Z-ADDF4EFDD    FBTKDD
     C           K#PL03    CHAINFBCPL03              98
      * ----------------------------------------
     C           *IN98     IFEQ *ON
     C                     EXSR @ADD1
     C                     ENDIF
      *
     C           *IN98     IFEQ *OFF
     C           F4UP1     ANDNEFBNTAN
     C           F4EFDT    ANDEQFBTKHZ
     C                     MOVEL' '       FBSKJY
     C                     Z-ADD@DTYY     FBKOYY
     C                     Z-ADD@DTMM     FBKOMM
     C                     Z-ADD@DTDD     FBKODD
     C                     Z-ADD@TMHH     FBKOHH
     C                     Z-ADD@TMMN     FBKOSS
     C                     MOVEL'FBCR84  'FBKOME
     C                     Z-ADDF4UP1     FBNTAN
     C                     Z-ADDF4EXDT    FBTSHZ
     C                     UPDATFBCPL031
      * OUTPUT PROOF FILE
     C                     MOVEL'UP1'     MESS01
     C                     MOVEL'UPD'     XACT    3
     C                     WRITEFBCWP851
      *
     C                     ADD  1         UPD#
     C                     EXSR @PRINT
     C                     ENDIF
      *
     C                     ENDSR
      ******************************************************
      *          @ADD:  ADD RECORD
      ******************************************************
     C           @ADD1     BEGSR
      *
     C                     CLEARFBCPL031
     C                     MOVE *BLANK    FBSKJY
     C                     Z-ADD0         FBSKYY
     C                     Z-ADD0         FBSKMM
     C                     Z-ADD0         FBSKDD
     C                     Z-ADD@DTYY     FBKOYY
     C                     Z-ADD@DTMM     FBKOMM
     C                     Z-ADD@DTDD     FBKODD
     C                     Z-ADD@TMHH     FBKOHH
     C                     Z-ADD@TMMN     FBKOSS
     C                     Z-ADDF4TOKU    FBTOKU
     C                     Z-ADDF4NONY    FBNONY
     C                     MOVELF4FACT    FBNKOJ
     C                     MOVELF4DOCK    FBNUKE
     C                     MOVELF4MHN1    FBMHN1
     C                     MOVELF4MHN2    FBMHN2
     C                     MOVELF4MHN3    FBMHN3
     C                     MOVELF4MHN4    FBMHN4
     C                     MOVELF4SHN1    FBSHN1
     C                     MOVELF4SHN2    FBSHN2
     C                     MOVELF4SHN3    FBSHN3
     C                     Z-ADD0         FBOTAN
     C                     Z-ADDF4UP1     FBNTAN
     C                     Z-ADDF4EFYY    FBTKYY
     C                     Z-ADDF4EFMM    FBTKMM
     C                     Z-ADDF4EFDD    FBTKDD
     C                     Z-ADD9999      FBTSYY
     C                     Z-ADD99        FBTSMM
     C                     Z-ADD99        FBTSDD
     C                     MOVEL'FBCR84  'FBKOME    P
     C                     WRITEFBCPL031
      * OUTPUT PROOF FILE
     C                     MOVEL'AD1'     MESS01
     C                     MOVEL'ADD'     XACT
     C                     WRITEFBCWP851
      *
     C                     ADD  1         ADD#
     C                     EXSR @PRINT
      *
     C                     ENDSR
      ******************************************************
      *          @PRINT: PRINT ERROR REPORT
      ******************************************************
     C           @PRINT    BEGSR
      *
     C   OF                EXCPTHDR1
     C   OF                SETOF                     OF
     C                     ADD  1         SEQ#
     C                     EXCPTDTL1
      *
     C                     ENDSR
      ******************************************************
      *                  INITIAL ROUTINE
      ******************************************************
     C           @INIT     BEGSR
      *
     C           K#PL03    KLIST
     C                     KFLD           FBTOKU
     C                     KFLD           FBNONY
     C                     KFLD           FBNKOJ
     C                     KFLD           FBNUKE
     C                     KFLD           FBMHN1
     C                     KFLD           FBMHN2
     C                     KFLD           FBMHN3
     C                     KFLD           FBMHN4
     C                     KFLD           FBTKYY
     C                     KFLD           FBTKMM
     C                     KFLD           FBTKDD
      *
     C                     Z-ADD*DATE     @DATE
     C                     TIME           @TIME
     C                     Z-ADD0         ADD#    50
     C                     Z-ADD0         UPD#    50
     C                     Z-ADD0         TTL#    50
     C                     Z-ADD0         SEQ#    50
     C                     MOVE *ON       *INOF
     C                     MOVELTBL,1     #TITLE 38
      *
     C                     ENDSR
      *************************************************************
      *                    OUTPUT                                 *
      *************************************************************
     OQPRINT  E  102           HDR1
     O                                    8 'PROGRAM:'
     O                                   15 'FBCR84'
     O                         #TITLE    70
     O                                  100 'DATE'
     O                         @DATE    111 '    .  .  '
     O                         @TIME    120 '  :  :  '
     O                         PAGE  Z  130
     O                                  126 'PAGE'
     O        E  1             HDR1
     O                                    5 'SEQ'
     O                                   23 'CUSTOMER_PART'
     O                                   39 'CUST'
     O                                   45 'DELV'
     O                                   48 'F'
     O                                   54 'DOCK'
     O                                   64 'EFCT_DATE'
     O                                   74 'EXP_DATE'
     O                                   85 'UNIT_PRICE'
     O                                   97 'INTRA_PART'
     O        E  1             HDR1
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O                                  120 '--------------------'
      *
     O        E  1             DTL1
     O                         SEQ#  Z    5
     O                         XACT       9
     O                         F4MHN1  +001
     O                         F4MHN2  +001
     O                         F4MHN3  +001
     O                         F4MHN4  +001
     O                         F4TOKU3 +002
     O                         F4NONY3 +002
     O                         F4FACT  +002
     O                         F4DOCK  +002
     O                         F4EFDT  +002
     O                         F4EXDT  +002
     O                         F4UP1 3 +001
     O                         F4SHN1  +003
     O                         F4SHN2  +001
     O                         F4SHN3  +001
      *
     O        E  1             FOT1
     O                                   20 '--------------------'
     O                                   40 '--------------------'
     O                                   60 '--------------------'
     O                                   80 '--------------------'
     O                                  100 '--------------------'
     O                                  120 '--------------------'
      *
     O        E  1             FOT1
     O                                   17 '** TOTAL RECORDS:'
     O                         TTL#  J   24
     O                                   33 '(UPDATE:'
     O                         UPD#  J   40
     O                                   46 ', ADD:'
     O                         ADD#  J   53
     O                                   54 ')'
** TBL
<< SALES UNIT PRICE UPDATE LOG LIST >>
