     FABMPW01 CF  E                    WORKSTN
     FABMPP01 UF  E           K        DISK                      A
     FGADPL11 IF  E           K        DISK
     E                    ER      1  19 65
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
     I              '0123456789'          C         WKCKSU
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
     C           KEYB51    KLIST
     C                     KFLD           #BTOKU  40
     C                     KFLD           #BNONY  40
     C                     KFLD           #BNKOJ  1
      *
     C           KEYB52    KLIST
     C                     KFLD           #BTOKU  40
     C                     KFLD           #BNONY  40
     C                     KFLD           #BNKOJ  1
     C                     KFLD           #BNUKE  4
      *
     C           KEYB53    KLIST
     C                     KFLD           #BTOKU  40
     C                     KFLD           #BNONY  40
     C                     KFLD           #BNKOJ  1
      *
     C           KEYB54    KLIST
     C                     KFLD           #BTOKU  40
     C                     KFLD           #BNONY  40
      *
      *----------------------------------------------------*
      *  メインルーチン                                  *
      *----------------------------------------------------*
     C                     EXSR $SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR $SB200
     C                     ENDDO
     C                     EXSR $SB300
      *----------------------------------------------------*
      *   初期処理                                       *
      *----------------------------------------------------*
     CSR         $SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVE '01'      DSPSW   2
      *
     C                     MOVEL*BLANK    D1KOSN
     C                     Z-ADD0         D1TOKU
     C                     Z-ADD0         D1NONY
     C                     MOVEL*BLANK    D1NKOJ
     C                     MOVEL*BLANK    D1NUKE
      *
     CSR         $S100E    ENDSR
      *----------------------------------------------------*
      *   主処理                                         *
      *----------------------------------------------------*
     CSR         $SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR $SB210
     C                     ENDDO
      *
     C           DSPSW     DOWEQ'02'
     C                     EXSR $SB220
     C                     ENDDO
      *
     CSR         $S200E    ENDSR
      *----------------------------------------------------*
      *   終了処理                                       *
      *----------------------------------------------------*
     CSR         $SB300    BEGSR
      *
     C                     SETON                     LR
     C                     RETRN
      *
     CSR         $S300E    ENDSR
      *----------------------------------------------------*
      *   第一画面表示                                   *
      *----------------------------------------------------*
     CSR         $SB210    BEGSR
      *
     C                     EXFMTABMPW011
     C                     SETOF                     313233
     C                     SETOF                     343536
     C                     SETOF                     99
     C                     MOVEL*BLANK    D1ERR
      * F1
     C           *IN01     IFEQ '1'
     C                     MOVE '99'      DSPSW
     C                     GOTO $S210E
     C                     ENDIF
      * F12
     C           *IN12     IFEQ '1'
     C                     CALL 'ABMR02'
     C                     GOTO $S210E
     C                     ENDIF
      *
     C           D1KOSN    IFEQ *BLANK
     C                     MOVELER,1      D1ERR
     C                     SETON                     3199
     C                     GOTO $S210E
     C                     ENDIF
      *
     C           D1KOSN    IFEQ '0'
     C           D1KOSN    OREQ '2'
     C                     ELSE
     C                     MOVELER,2      D1ERR
     C                     SETON                     3199
     C                     GOTO $S210E
     C                     ENDIF
      *得意先
     C           D1TOKU    IFEQ 0
     C                     MOVELER,1      D1ERR
     C                     SETON                     3299
     C                     GOTO $S210E
     C                     ENDIF
      *納入先
     C           D1NONY    IFEQ 0
     C                     MOVELER,1      D1ERR
     C                     SETON                     3399
     C                     GOTO $S210E
     C                     ENDIF
      *工場
     C******     D1NKOJ    IFEQ *BLANK
     C******               MOVELER,1      D1ERR
     C******               SETON                     3499
     C******               GOTO $S210E
     C******               ENDIF
      *出荷マスター
     C                     MOVELD1TOKU    #BTOKU
     C                     MOVELD1NONY    #BNONY
     C*****                MOVELD1NKOJ    #BNKOJ
     C                     MOVEL'0'       GET     1
     C           KEYB54    SETLLGADPL111
     C           KEYB54    READEGADPL111                 21
     C           *IN21     DOWEQ'0'
     C           B5SKJY    IFEQ 'D'
     C           B5SKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR $SB222
     C                     ENDIF
     C           KEYB54    READEGADPL111                 21
     C                     ENDDO
     C           GET       IFEQ '0'
     C                     MOVELER,3      D1ERR
     C                     SETON                     323334
     C                     SETON                     3599
     C                     GOTO $S210E
     C                     ENDIF
      *マスター
     C                     MOVELD1TOKU    #BTOKU
     C                     MOVELD1NONY    #BNONY
     C                     MOVELD1NKOJ    #BNKOJ
     C                     MOVELD1NUKE    #BNUKE
     C           KEYB52    CHAINABMPP011             21
     C           *IN21     IFEQ '0'
     C           S2SKJY    ANDEQ'D'
     C           S2SKHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ENDIF
      *
     C           *IN21     IFEQ '1'
     C           D1KOSN    IFEQ '0'
     C           D1KOSN    OREQ '1'
     C                     MOVELER,5      D1ERR
     C                     SETON                     3199
     C                     GOTO $S210E
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN21     IFEQ '0'
     C           D1KOSN    IFEQ '2'
     C                     MOVELER,6      D1ERR
     C                     SETON                     3199
     C                     GOTO $S210E
     C                     ENDIF
     C                     ENDIF
      *
     C                     SETOF                     19
     C                     SELEC
     C           D1KOSN    WHEQ '0'
     C                     SETON                     19
     C           D1KOSN    WHEQ '1'
     C           D1KOSN    WHEQ '2'
     C                     ENDSL
      *
     C                     MOVE '02'      DSPSW   2
      *
     CSR         $S210E    ENDSR
      *----------------------------------------------------*
      *   第二画面表示                                   *
      *----------------------------------------------------*
     CSR         $SB222    BEGSR
      *
     C                     MOVEL'0'       GETK    1
     C           D1NKOJ    IFEQ *BLANK
     C                     MOVEL'1'       GETK
     C                     ELSE
     C           B5NKOJ    IFEQ D1NKOJ
     C                     MOVEL'1'       GETK
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVEL'0'       GETU    1
     C           D1NUKE    IFEQ *BLANK
     C                     MOVEL'1'       GETU
     C                     ELSE
     C           B5NUKE    IFEQ D1NUKE
     C                     MOVEL'1'       GETU
     C                     ENDIF
     C                     ENDIF
      *
     C           GETK      IFEQ '1'
     C           GETU      ANDEQ'1'
     C                     MOVEL'1'       GET
     C                     ENDIF
      *
     CSR         $S222E    ENDSR
      *----------------------------------------------------*
      *   第二画面表示                                   *
      *----------------------------------------------------*
     CSR         $SB220    BEGSR
      *
     C                     EXFMTABMPW012
     C                     SETOF                     313233
     C                     SETOF                     99
     C                     MOVEL*BLANK    D2ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVEL*BLANK    D1KOSN
     C                     Z-ADD0         D1TOKU
     C                     Z-ADD0         D1NONY
     C                     MOVEL*BLANK    D1NKOJ
     C                     MOVEL*BLANK    D1NUKE
     C                     MOVE '01'      DSPSW
     C                     GOTO $S220E
     C                     ENDIF
      *
     C           *IN05     IFEQ '0'
     C                     GOTO $S220E
     C                     ENDIF
      *
     C           KEYB52    CHAINABMPP011             21
     C                     SELEC
     C           D1KOSN    WHEQ '0'
     C                     EXSR #DLT
     C           D1KOSN    WHEQ '2'
     C                     EXSR #WRT
     C                     ENDSL
      *
     C                     MOVEL*BLANK    D1KOSN
     C                     Z-ADD0         D1TOKU
     C                     Z-ADD0         D1NONY
     C                     MOVEL*BLANK    D1NKOJ
     C                     MOVEL*BLANK    D1NUKE
     C                     MOVE '01'      DSPSW   2
      *
     CSR         $S220E    ENDSR
      *----------------------------------------------------*
      *削除                                              *
      *----------------------------------------------------*
     CSR         #DLT      BEGSR
      *
     C           *IN21     IFEQ '0'
     C                     MOVEL'D'       S2SKJY
     C                     Z-ADD*DATE     S2SKHZ
     C                     UPDATABMPP011
     C                     ENDIF
      *
     CSR         EDLT      ENDSR
      *----------------------------------------------------*
      *追加                                              *
      *----------------------------------------------------*
     CSR         #WRT      BEGSR
      *
     C                     CLEARABMPP011
     C                     Z-ADD*DATE     S2KOHZ
     C                     TIME           S2KOTI
     C                     MOVEL@@USER    S2KOME
     C                     Z-ADDD1TOKU    S2TOKU
     C                     Z-ADDD1NONY    S2NONY
     C                     MOVELD1NKOJ    S2NKOJ
     C                     MOVELD1NUKE    S2NUKE
     C           *IN21     IFEQ '0'
     C                     UPDATABMPP011
     C                     ELSE
     C                     WRITEABMPP011
     C                     ENDIF
      *
     CSR         EWRT      ENDSR
      *
