     H** AFAR67 *******************************************************
     H* COMBINED PARTIAL CONTAINER(CTREATE PLATING KANBAN DATA)       *
     H*                                                               *
     H* TCH 2001.02.05                                                *
     H* TCH 2001.04.09                                                *
     H* TCH 2001.08.28                                                *
     H* TCH 2001.09.07  ADD COPIES                                    *
     H* TCH 2002.01.31  WHEN NO ERROR, NO ERROR LIST.                 *
     H* TCH 2002.05.20  ADD "Z" AT 512
     H* TCH 2002.05.21  ELIMINATE "Z" AT 512
     H* TCH 2003.11.21  DEPARTMENT NAME
     H* TCH 2004.08.27  SEE SRART DATE
     H**************************************************************************
     FAFAPL64 UF  E           K        DISK
     FAATPL01 IF  E           K        DISK
     FAAFTL06 IF  E           K        DISK
     FAAAPL01 IF  E           K        DISK
     FAAFT0111O   F     512            DISK
     FQPRINT  O   F     132     OF     PRINTER
     I**************************************************************************
     I*ZETI AND TAI-SYO-KUBUN,SYUKO-YUKO-KUBUN,HAKO-SYU OF AFAPP60
     I* TIME
     I            DS
     I                                        1  120WTMDT
     I                                        1   60WTIME
     I                                        7  120WDATE
     I            DS
     I                                        1  14 AAKAN1
     I                                        2   5 ZETI
     I                                       12  12 TASYO
     I                                       13  13 YUKO
     I                                       14  14 HAKO
     I*DATE OF AFAPP60
     I            DS
     I                                        1   80AADATE
     I                                        1   40AAYYYY
     I                                        5   60AAMMMM
     I                                        7   80AADDDD
     I*CHANGE DATE OF FCEPP01
     I            DS
     I                                        1   80A2DATE
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
     I* EFECTIVE DATE(AAHPL03)
     I            DS
     I                                        1   80W3DATE
     I                                        1   40A3STYY
     I                                        5   60A3STMM
     I                                        7   80A3STDD
     I            DS
     I                                        1   80A3UYMD
     I                                        1   40A3UKYY
     I                                        5   60A3UKMM
     I                                        7   80A3UKDD
     I            DS
     I                                        1  12 AAPART
     I                                        1   5 APAR1
     I                                        6  10 APAR2
     I                                       11  12 APAR3
     I**************************************************************************
     C*
     C           *ENTRY    PLIST
     C                     PARM           PRCD    1        1:NO RECORD
     C*
     C           P1        PLIST
     C                     PARM           P30    30
     C*
     C           KEY1      KLIST
     C                     KFLD           KATK1   1
     C                     KFLD           KATK2   2
     C                     KFLD           KATK3   2
     C                     KFLD           KATK4   1
     C*
     C           KEY2      KLIST
     C                     KFLD           APAR1   5
     C                     KFLD           APAR2   5
     C                     KFLD           APAR3   2
     C*
     C           KEY3      KLIST
     C                     KFLD           A5JOKN  2
     C                     KFLD           A5KANB  1
     C*
     C           KEY4      KLIST
     C                     KFLD           DCBMON  40
     C                     KFLD           DCTAIP  1
     C**************************************************************************
     C*                    MAIN ROUTINE
     C**************************************************************************
     C                     EXSR @INT
     C                     EXSR @MAIN
     C                     EXSR @END
     C**************************************************************************
     C*                    @INT
     C**************************************************************************
     C           @INT      BEGSR
     C*
     C                     TIME           WTMDT
     C*************        EXCPTHD
     C*
     C                     Z-ADD*ZERO     OSEQ#1  40
     C                     Z-ADD*ZERO     OSEQ#2  40
     C                     MOVE *BLANK    PRCD
     C                     MOVE '0'       WAPFG   1        APICS KANBAN
     C*
     C                     READ AFAPL64                  90
     C           *IN90     IFEQ '1'
     C                     MOVE '1'       PRCD
     C*
     C* WRITE HEADER & BLOCK RECORD
     C                     ELSE
     C*
     C                     EXCPTHED
     C*
     C                     EXCPTBLK
     C                     ADD  1         OSEQ#2
     C                     MOVE AAKCD     WAKCD   1
     C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @MAIN
     C**************************************************************************
     C           @MAIN     BEGSR
     C*
B1   C           *IN90     DOWEQ'0'
      *
     C                     MOVE '000'     @COPY   3
B2   C           AACOPY    IFEQ *ZERO
     C                     MOVE '1'       @COPY
     C                     ELSE
     C                     MOVE AACOPY    @COPY
E2   C                     ENDIF
      *
     C                     MOVEL*BLANKS   W3ATK1  1
     C                     MOVEL*BLANKS   W3ATK2  2
     C                     MOVEL*BLANKS   W3ATK3  2
     C                     MOVEL*BLANKS   W3ATK4  1
     C                     MOVEL*BLANKS   W3MTK1  1
     C                     MOVEL*BLANKS   W3MTK2  2
     C                     MOVEL*BLANKS   W3MTK3  2
     C                     MOVEL*BLANKS   W3MTK4  1
     C                     MOVEL*BLANKS   W3MEKI  7
     C                     MOVEL*BLANKS   W3RAIN  1
     C                     Z-ADD0         W3BARA  20
     C                     Z-ADD0         W3BARB  21
     C                     Z-ADD0         W3CBKO  20
     C                     Z-ADD0         W3SSYS  50
     C                     MOVEL*BLANKS   W3KCD1  1
     C                     MOVEL*BLANKS   W3ATOK  3
     C                     Z-ADD*ZERO     DCBMON  40
     C                     MOVEL*BLANK    DCTAIP  1
     C* KANBAN CODE BREAKE?
B2   C           AAKCD     IFNE WAKCD
     C*
     C                     EXCPTBLK
     C                     ADD  1         OSEQ#2
     C                     Z-ADD1         OSEQ#1
     C                     MOVE AAKCD     WAKCD
      *
     C                     MOVEL*BLANKS   ERRFLG  1
     C           KEY2      SETGTAAFTL06
     C                     SETOF                     92
     C*
     C           KEY2      REDPEAAFTL06                  92
B3   C           *IN92     DOWEQ'0'
B4   C           *IN92     IFEQ '0'
B5   C*******    W3DATE    ANDEQ99999999
     C           *DATE     ANDGEA3UYMD
B6   C           A3KCD2    ANDNE'Z'
     C                     MOVELA3ATK1    W3ATK1  1
     C                     MOVELA3ATK2    W3ATK2  2
     C                     MOVELA3ATK3    W3ATK3  2
     C                     MOVELA3ATK4    W3ATK4  1
     C                     MOVELA3MTK1    W3MTK1  1
     C                     MOVELA3MTK2    W3MTK2  2
     C                     MOVELA3MTK3    W3MTK3  2
     C                     MOVELA3MTK4    W3MTK4  1
     C                     MOVELA3MEKI    W3MEKI  7
     C                     MOVELA3RAIN    W3RAIN  1
     C                     Z-ADDA3BARA    W3BARA  20
     C                     Z-ADDA3BARB    W3BARB  21
     C                     Z-ADDA3CBKO    W3CBKO  20
     C                     Z-ADDA3SSYS    W3SSYS  50
     C                     MOVELA3MAKB    DCBMON  40
     C                     MOVELA3MTYP    DCTAIP  1
     C                     MOVELA3MAKB    W3MAKB  40
     C                     MOVELA3MTYP    W3MTYP  1
     C                     MOVELA3KCD1    W3KCD1  1
     C*                    MOVELA3KCD2    W3KCD2  1
     C                     MOVELA3ATOK    W3ATOK  3
     C                     MOVE A3ATOB    W3ATOB  40
     C                     MOVE A3ATYP    W3ATYP  1
     C                     LEAVE
     C*
 E4  C                     ENDIF
     C*
     C           KEY2      REDPEAAFTL06                  92
 E3  C                     ENDDO
     C*
     C                     MOVEL*BLANKS   W5JOK1 12
     C                     MOVEL*BLANKS   W5JOK2 12
     C                     MOVEL*BLANKS   W5JOK3 20
     C                     MOVEL*BLANKS   W5JOK4 20
     C                     MOVEL*BLANKS   W5JOK5 20
     C*
 B3  C           ERRFLG    IFEQ *BLANKS
     C*
 B4  C           A3JOK1    IFNE *BLANK
     C                     MOVELA3KCD1    A5KANB
     C                     MOVELA3JOK1    A5JOKN
     C                     SETOF                     80
     C           KEY3      CHAINAAAPL01              80
 B5  C           *IN80     IFEQ '0'
     C                     MOVELA5JOKM    W5JOK1
     C                     ELSE
     C                     MOVEL'2'       ERRFLG
     C                     MOVEL'2'       PRCD
 E5  C                     ENDIF
     C*
 E4  C                     END
     C*
 B4  C           A3JOK2    IFNE *BLANK
     C                     MOVELA3KCD1    A5KANB
     C                     MOVELA3JOK2    A5JOKN
     C                     SETOF                     80
     C           KEY3      CHAINAAAPL01              80
 B5  C           *IN80     IFEQ '0'
     C                     MOVELA5JOKM    W5JOK2
     C                     ELSE
     C                     MOVEL'2'       ERRFLG
     C                     MOVEL'2'       PRCD
 E5  C                     ENDIF
     C*
 E4  C                     END
     C*
 B4  C           A3JOK3    IFNE *BLANK
     C                     MOVELA3KCD1    A5KANB
     C                     MOVELA3JOK3    A5JOKN
     C                     SETOF                     80
     C           KEY3      CHAINAAAPL01              80
 B5  C           *IN80     IFEQ '0'
     C                     MOVELA5JOKM    W5JOK3
     C                     ELSE
     C                     MOVEL'2'       ERRFLG
     C                     MOVEL'2'       PRCD
 E5  C                     ENDIF
     C*
 E4  C                     END
     C*
 B4  C           A3JOK4    IFNE *BLANK
     C                     MOVELA3KCD1    A5KANB
     C                     MOVELA3JOK4    A5JOKN
     C                     SETOF                     80
     C           KEY3      CHAINAAAPL01              80
 B5  C           *IN80     IFEQ '0'
     C                     MOVELA5JOKM    W5JOK4
     C                     ELSE
     C                     MOVEL'2'       ERRFLG
     C                     MOVEL'2'       PRCD
 E5  C                     ENDIF
     C*
 E4  C                     END
     C*
 B4  C           A3JOK5    IFNE *BLANK
     C                     MOVELA3KCD1    A5KANB
     C                     MOVELA3JOK5    A5JOKN
     C                     SETOF                     80
     C           KEY3      CHAINAAAPL01              80
 B5  C           *IN80     IFEQ '0'
     C                     MOVELA5JOKM    W5JOK5
     C                     ELSE
     C                     MOVEL'2'       ERRFLG
     C                     MOVEL'2'       PRCD
 E5  C                     ENDIF
     C*
 E4  C                     END
     C*
     C                     MOVEL*BLANKS   WCNAMN
     C                     MOVEL*BLANKS   WCNAMX
     C                     MOVELW3MAKB    DCBMON  40
     C                     MOVELW3MTYP    DCTAIP  1
     C           KEY4      CHAINAATPL01              75
B4   C           *IN75     IFEQ '0'
     C                     MOVELDCNAMN    WCNAMN 16
E4   C                     ENDIF
      *
     C                     MOVELW3ATOB    DCBMON  40
     C                     MOVELW3ATYP    DCTAIP  1
     C           KEY4      CHAINAATPL01              75
B4   C           *IN75     IFEQ '0'
     C                     MOVELDCNAMN    WCNAMX 16
E4   C                     ENDIF
     C*
E3   C                     END
     C*
     C                     EXCPTDT
     C                     ADD  1         OSEQ#2
B3   C           ERRFLG    IFEQ '2'
B4   C           *INOF     IFEQ '1'
     C           *IN98     OREQ '0'
     C                     EXCPTHD
     C                     SETOF                     OF
     C  N98                SETON                     98
E4   C                     ENDIF
     C                     EXCPTDT1
     C                     EXCPTDT2
E3   C                     ENDIF
     C*
     C* WRITE SAME KANBAN CODE DATA
     C*
     C                     ELSE
     C                     ADD  1         OSEQ#1
     C                     MOVEL*BLANKS   ERRFLG  1
     C           KEY2      SETGTAAFTL06
     C                     SETOF                     92
     C*
     C           KEY2      REDPEAAFTL06                  92
B3   C           *IN92     DOWEQ'0'
B4   C           *IN92     IFEQ '0'
B5   C******     W3DATE    ANDEQ99999999
     C           *DATE     ANDGEA3UYMD
B6   C           A3KCD2    ANDNE'Z'
     C                     MOVELA3ATK1    W3ATK1  1
     C                     MOVELA3ATK2    W3ATK2  2
     C                     MOVELA3ATK3    W3ATK3  2
     C                     MOVELA3ATK4    W3ATK4  1
     C                     MOVELA3MTK1    W3MTK1  1
     C                     MOVELA3MTK2    W3MTK2  2
     C                     MOVELA3MTK3    W3MTK3  2
     C                     MOVELA3MTK4    W3MTK4  1
     C                     MOVELA3MEKI    W3MEKI  7
     C                     MOVELA3RAIN    W3RAIN  1
     C                     Z-ADDA3BARA    W3BARA  20
     C                     Z-ADDA3BARB    W3BARB  21
     C                     Z-ADDA3CBKO    W3CBKO  20
     C                     Z-ADDA3SSYS    W3SSYS  50
     C                     MOVELA3MAKB    DCBMON  40
     C                     MOVELA3MTYP    DCTAIP  1
     C                     MOVELA3MAKB    W3MAKB  40
     C                     MOVELA3MTYP    W3MTYP  1
     C                     MOVELA3KCD1    W3KCD1  1
     C                     MOVELA3ATOK    W3ATOK  3
     C                     MOVE A3ATOB    W3ATOB  40
     C                     MOVE A3ATYP    W3ATYP  1
     C                     LEAVE
     C*
E6   C                     ENDIF
     C*
     C           KEY2      REDPEAAFTL06                  92
 E3  C                     ENDDO
     C*
     C                     MOVEL*BLANKS   W5JOK1 12
     C                     MOVEL*BLANKS   W5JOK2 12
     C                     MOVEL*BLANKS   W5JOK3 20
     C                     MOVEL*BLANKS   W5JOK4 20
     C                     MOVEL*BLANKS   W5JOK5 20
B3   C*
     C           ERRFLG    IFEQ *BLANKS
     C*
B4   C           A3JOK1    IFNE *BLANK
     C                     MOVELA3KCD1    A5KANB
     C                     MOVELA3JOK1    A5JOKN
     C                     SETOF                     80
     C           KEY3      CHAINAAAPL01              80
B5   C           *IN80     IFEQ '0'
     C                     MOVELA5JOKM    W5JOK1
     C                     ELSE
     C                     MOVEL'2'       ERRFLG
E5   C                     ENDIF
     C*
E4   C                     END
     C*
B4   C           A3JOK2    IFNE *BLANK
     C                     MOVELA3KCD1    A5KANB
     C                     MOVELA3JOK2    A5JOKN
     C                     SETOF                     80
     C           KEY3      CHAINAAAPL01              80
 B5  C           *IN80     IFEQ '0'
     C                     MOVELA5JOKM    W5JOK2
     C                     ELSE
     C                     MOVEL'2'       ERRFLG
 E5  C                     ENDIF
     C*
 E4  C                     END
     C*
 B4  C           A3JOK3    IFNE *BLANK
     C                     MOVELA3KCD1    A5KANB
     C                     MOVELA3JOK3    A5JOKN
     C                     SETOF                     80
     C           KEY3      CHAINAAAPL01              80
 B5  C           *IN80     IFEQ '0'
     C                     MOVELA5JOKM    W5JOK3
     C                     ELSE
     C                     MOVEL'2'       ERRFLG
 E5  C                     ENDIF
     C*
 E4  C                     END
     C*
 B4  C           A3JOK4    IFNE *BLANK
     C                     MOVELA3KCD1    A5KANB
     C                     MOVELA3JOK4    A5JOKN
     C                     SETOF                     80
     C           KEY3      CHAINAAAPL01              80
 B5  C           *IN80     IFEQ '0'
     C                     MOVELA5JOKM    W5JOK4
     C                     ELSE
     C                     MOVEL'2'       ERRFLG
E5   C                     ENDIF
     C*
E4   C                     END
     C*
B4   C           A3JOK5    IFNE *BLANK
     C                     MOVELA3KCD1    A5KANB
     C                     MOVELA3JOK5    A5JOKN
     C                     SETOF                     80
     C           KEY3      CHAINAAAPL01              80
B5   C           *IN80     IFEQ '0'
     C                     MOVELA5JOKM    W5JOK5
     C                     ELSE
     C                     MOVEL'2'       ERRFLG
E5   C                     ENDIF
     C*
E4   C                     END
     C*
     C                     MOVEL*BLANKS   WCNAMN 16
     C                     MOVEL*BLANKS   WCNAMN 16
     C                     MOVELW3MAKB    DCBMON
     C                     MOVELW3MTYP    DCTAIP
     C           KEY4      CHAINAATPL01              75
B4   C           *IN75     IFEQ '0'
     C                     MOVELDCNAMN    WCNAMN
E4   C                     ENDIF
      *
     C                     MOVELW3ATOB    DCBMON  40
     C                     MOVELW3ATYP    DCTAIP  1
     C           KEY4      CHAINAATPL01              75
B4   C           *IN75     IFEQ '0'
     C                     MOVELDCNAMN    WCNAMX 16
E4   C                     ENDIF
     C*
E3   C                     END
     C                     EXCPTDT
 B3  C           ERRFLG    IFEQ '2'
 B4  C           *INOF     IFEQ '1'
     C           *IN98     OREQ '0'
     C                     EXCPTHD
     C                     SETOF                     OF
     C  N98                SETON                     98
 E4  C                     ENDIF
     C                     EXCPTDT1
     C                     EXCPTDT2
     C                     ADD  1         OSEQ#2
 E3  C                     END
 E2  C                     END
     C*
     C                     MOVE 1         AAFLAG
     C                     UPDATAFAPP601
     C*
     C                     READ AFAPL64                  90
 E1  C                     END
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @END
     C**************************************************************************
