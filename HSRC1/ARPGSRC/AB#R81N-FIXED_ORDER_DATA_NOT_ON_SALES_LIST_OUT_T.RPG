     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ AB#WP81                  98
     C   98                LEAVE
      *
     C                     CLEARAB#WP821
     C                     EXSR #SET1
     C                     WRITEAB#WP821
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *********************
      * SET DATA          *
      *********************
     C           #SET1     BEGSR
      *
     C                     MOVELITOKU     $IN       P
     C                     MOVE '04'      $LONG
     C                     CALL 'UTLR32A'
     C                     PARM           $IN    10
     C                     PARM           $LONG   2
     C                     PARM           $OUT   11
     C                     MOVEL$OUT      W2TOKU
      *
     C                     MOVELINONY     $IN       P
     C                     MOVE '04'      $LONG
     C                     CALL 'UTLR32A'
     C                     PARM           $IN
     C                     PARM           $LONG
     C                     PARM           $OUT
     C                     MOVEL$OUT      W2NONY
      *
     C                     MOVELINKOJ     $IN       P
     C                     MOVE '01'      $LONG
     C                     CALL 'UTLR32A'
     C                     PARM           $IN
     C                     PARM           $LONG
     C                     PARM           $OUT
     C                     MOVEL$OUT      W2NKOJ
      *
     C                     MOVELINUKE     $IN       P
     C                     MOVE '04'      $LONG
     C                     CALL 'UTLR32A'
     C                     PARM           $IN
     C                     PARM           $LONG
     C                     PARM           $OUT
     C                     MOVEL$OUT      W2NUKE
      *
     C                     MOVELISBAN     $IN       P
     C                     MOVE '04'      $LONG
     C                     CALL 'UTLR32A'
     C                     PARM           $IN
     C                     PARM           $LONG
     C                     PARM           $OUT
     C                     MOVEL$OUT      W2SBAN
      *
     C                     MOVELIMHIN     $MHIN     P
     C                     CALL 'UUUR03'
     C                     PARM           $MHIN  20
     C                     PARM           $MHIN2 23
     C                     MOVEL$MHIN2    W2MHIN
      *
     C                     MOVELIODRN     $IN       P
     C                     MOVE '10'      $LONG
     C                     CALL 'UTLR32A'
     C                     PARM           $IN
     C                     PARM           $LONG
     C                     PARM           $OUT
     C                     MOVEL$OUT      W2ODRN
      *
     C                     MOVELINOYY     XYY
     C                     MOVELINOMM     XMM
     C                     MOVELINODD     XDD
     C                     MOVELXDATE     W2NOHZ
     C                     MOVELINOBN     W2NOBN
     C                     MOVELISRYO     W2SRYO
      *
     C                     MOVELISHIN     $SHIN     P
     C                     CALL 'UUUR02'
     C                     PARM           $SHIN  12
     C                     PARM           $SHIN2 14
     C                     MOVEL$SHIN2    W2SHIN
      *
     C                     ENDSR
      *********************
      * INITIAL SETTING   *
      *********************
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $FROM   8
     C                     PARM           $TO     8
      *
     C                     TIME           SDATE
     C                     MOVE '/'       XP1
     C                     MOVE '/'       XP2
     C                     MOVE ':'       XC1
     C                     MOVE ':'       XC2
      * HEADER1
     C                     CLEARAB#WP821
     C                     MOVELTXT,1     W2TOKU
      * DATE FROM
     C                     MOVELTXT,2     LTR16  16
     C                     MOVEL$FROM     WDATE
     C                     MOVELWYY       XYY
     C                     MOVELWMM       XMM
     C                     MOVELWDD       XDD
     C                     MOVE XDATE     LTR16
     C                     MOVELLTR16     W2NONY
      * DATE TO
     C                     MOVELTXT,3     LTR14  14
     C                     MOVEL$TO       WDATE
     C                     MOVELWYY       XYY
     C                     MOVELWMM       XMM
     C                     MOVELWDD       XDD
     C                     MOVE XDATE     LTR14
     C                     MOVELLTR14     W2NKOJ
      * AS OF DATE
     C                     MOVELTXT,4     LTR16
     C                     MOVELTOYY      XYY
     C                     MOVELTOMM      XMM
     C                     MOVELTODD      XDD
     C                     MOVE XDATE     LTR16
     C                     MOVELLTR16     W2SRYO
      * AS OF TIME
     C                     MOVELNOHH      XHH
     C                     MOVELNOMM      XMN
     C                     MOVELNOSS      XSS
     C                     MOVELXTIME     W2SHIN
      * PGM
     C                     MOVELTXT,6     W2INVN
     C                     WRITEAB#WP821
      * HEADER2
     C                     CLEARAB#WP821
     C                     MOVEL'CUST#'   W2TOKU
     C                     MOVEL'DELIV#'  W2NONY
     C                     MOVEL'FACTORY' W2NKOJ
     C                     MOVEL'DOCK'    W2NUKE
     C                     MOVEL'KANBAN#' W2SBAN
     C                     MOVEL'USR-PART'W2MHIN
     C                     MOVEL'ORDER#'  W2ODRN
     C                     MOVEL'SHP-DATE'W2NOHZ
     C                     MOVEL'BIN#'    W2NOBN
     C                     MOVEL'ORD-QTY 'W2SRYO
     C                     MOVEL'IAF-PART'W2SHIN
     C**                   MOVEL'INVOICE#'W2INVN
     C                     WRITEAB#WP821
