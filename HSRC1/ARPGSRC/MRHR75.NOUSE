     H            Y.
     FMRHPW75 CF  E                    WORKSTN
     E                    ER      1   2 20
      *
     C           *ENTRY    PLIST
     C                     PARM           P@USRC  6
      *
     C           @DSP01    TAG
      *
     C                     EXFMTFMT100
      *
     C                     MOVEL*BLANK    F1ERR
      *
     C           *INKC     IFEQ '1'
     C                     MOVE *BLANK    P@USRC
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           F1USRC    IFEQ 0
     C                     MOVELER,01     F1ERR
     C                     GOTO @DSP01
     C                     END
      *
     C                     MOVE F1USRC    P@USRC  6
      *
     C                     CALL 'MRHR79'
     C                     PARM           P@USRC  6
     C                     PARM           P@OPNM 20
      *
     C           P@OPNM    IFEQ *BLANK
     C                     MOVELER,02     F1ERR
     C                     GOTO @DSP01
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *
** ER
INPUT USER
USER NOT FOUND
