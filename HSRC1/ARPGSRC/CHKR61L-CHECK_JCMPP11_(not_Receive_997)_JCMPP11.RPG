     H            Y.
     F***CHKR61L ***************************************************************
     F*  PROGRAM    : CHECK JCMPP11 (NOT RECEIVE 997)                          *
     F*  WRITTEN    : JW    2025.04.16                                         *
     F**************************************************************************
     FJCMPL11CIF  E           K        DISK
     FQPRINT  O   F     198     OF     PRINTER
     E                    MSG     1   1 60
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        7  100@YEAR
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           @FROM     SETLLJCMPL11C
      *
     C                     DO   *HIVAL
     C                     READ JCMPL11C                 98
     C   98                LEAVE
      * IGNORE
     C           J1KOHZ    IFNE 0                          997 RECEIVED
     C                     ITER
     C                     ENDIF
      * PRINT
     C                     EXSR #PRINT
     C                     ENDDO
      *
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ELSE
     C                     EXCPT@MSG
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
      *
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     MOVE ' '       $RTN
      * FROM = TODAY - 1
     C                     MOVELTODAY     $DT8
     C                     MOVE '-'       $SIGN
     C                     MOVE '0001'    $DAYS
     C                     MOVE 'Y'       $IAF
     C                     CALL 'UTLR10'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN    1
     C                     MOVEL$TGT8     @FROM   80
      *
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                                   40 '** FORD 997 NOT RECE'
     O                                   60 'IVED CHECK LIST **  '
     O                                   78 'DATE'
     O                         TODAY     81 '    .  .  '
     O                         NOW       91 '  :  :  '
     O                                   95 'P.'
     O                         PAGE  Z   99
     O        E   02           @HDR
     O                                   40 '   (PLAESE CHECK THE'
     O                                   60 ' ASN CONTROL# )     '
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   15 'RCV_DATE'
     O                                   23 'TIME'
     O                                   33 'ASN#'
     O                                   44 'CTL#'
     O                                   51 'DLV#'
     O                                   57 'NAME'
     O                                   80 'PLANT'
     O                                   85 'DOCK'
     O                                   90 'BN'
     O                                   97 'SHID#'
      *
     O        E 1              @DTL
     O                         SEQ#  1 +000
     O                         J1DATE  +002 '    /  /  '
     O                         J1TIME  +001 '0 :  '
     O                         J1ASN#  +002
     O                         J1KOME  +002
     O                         J1NONY  +002
     O                         J1SMEI  +002
     O                         J1SHPC  +002
     O                         J1NUKE  +002
     O                         J1BIN   +002
     O                         J1SHID  +002
      *
     O        E 1              @MSG
     O                                 +001 '.'
     O        E 1              @MSG
     O                         MSG,1   +001
      *
** MSG(60A)
 ** THERE IS NO ERROR **
