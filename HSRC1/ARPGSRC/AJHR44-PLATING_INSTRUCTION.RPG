     FAJHPL01 IP  E           K        DISK
     FAAHTL06 IF  E           K        DISK
     FAJHWP42 O   F      13            DISK                      A
     C           KEY1      KLIST
     C                     KFLD           JHSHN1
     C                     KFLD           JHSHN2
     C                     KFLD           JHSHN3
      *
     C                     TIME           WTIME   60
      *
     C           JHSKJY    IFEQ 'D'
     C                     GOTO END
     C                     END
     C**********************************************************
     C*引き取りかんばんからＦＡマスターの未使用品番をチェック*
     C**********************************************************
     C           KEY1      SETLLAAHTL061
     C                     SETOF                     10
     C           MELOOP    TAG
     C           KEY1      READEAAHTL061                 10
     C           *IN10     IFEQ '1'
     C                     GOTO MEEND
     C                     ELSE
     C           L6SKJY    IFEQ 'D'
     C           L6SKHZ    IFLE *DATE
     C                     GOTO MELOOP
     C                     END
     C                     END
     C                     END
     C*有効日・失効日のチェック*
      *
JW1   * TEMP1 - IF JBD, THEN GOTO MELOOP
 |   C           L6JOK1    IFEQ 'JB'
 |   C           *DATE     ANDEQ20180618
 |   C                     GOTO MELOOP
JW1  C                     ENDIF
      *
JW1   * TEMP2 - IF PART=U1219-B4031, THEN GOTO MELOOP
 |   C           L6SHN1    IFEQ 'U1219'
 |   C           L6SHN2    ANDEQ'B4031'
 |   C           *DATE     ANDEQ20180618
 |   C                     GOTO MELOOP
JW1  C                     ENDIF
      *
     C           L6UKHZ    IFLE *DATE
     C           L6STHZ    ANDGT*DATE
     C                     ELSE
     C                     GOTO MELOOP
     C                     END
     C*引き取りかんばんマスターに有りの時終了*
     C                     GOTO END
      *
     C           MEEND     TAG
     C                     ADD  1         KENSUU  50
     C                     EXCPTDAT
      *
