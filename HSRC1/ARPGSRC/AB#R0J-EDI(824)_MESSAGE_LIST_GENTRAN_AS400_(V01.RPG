     C**JW9      *ENTRY    PLIST
     C**                   PARM           @HND    1
     C**                   PARM           @GEN    1
     C**                   PARM           @TMS    1
JW6  C**                   PARM           @DENSO  1
JW5  C**                   PARM           @ERRH   1
JW7  C**                   PARM           @ERRD   1
JW7  C**                   PARM           @ERRT   1
      *
JW9  C           *ENTRY    PLIST
 |   C                     PARM           @GEN    1
 |   C                     PARM           @ERRG   1
 |   C                     PARM           @HND    1
 |   C                     PARM           @ERRH   1
 |   C                     PARM           @TMS    1
 |   C                     PARM           @ERRT   1
 |   C                     PARM           @DENSO  1
JW9  C                     PARM           @ERRD   1
      *
      * IGNORE DENSO / SUBARU / PISTON
JW8  C                     MOVELM6PTRN    @PTR6   6
 |   C           @PTR6     IFEQ 'DMMIM1'
 |   C           @PTR6     OREQ 'GNC_N1'
 |   C           @PTR6     OREQ 'DNMXT1'
 |   C           @PTR6     OREQ 'DNMXS1'
 |   C           @PTR6     OREQ 'DNMXM1'
 |   C           @PTR6     OREQ 'DMARA1'
 |   C           @PTR6     OREQ 'DMCNP1'
 |   C           @PTR6     OREQ 'DMNCN1'
 |   C           @PTR6     OREQ 'DMTNA1'
 |   C           @PTR6     OREQ 'SUBARU'
 |   C           @PTR6     OREQ 'PA1   '
 |   C           @PTR6     OREQ 'PA4   '
 |   C           @PTR6     OREQ 'PA6   '
 |   C           @PTR6     OREQ 'PA7   '
 |   C                     GOTO @@END
JW8  C                     ENDIF
      * IGNORE DUP ERROR
JWA  C                     MOVELM6FSER    LTR4    4
 .   C           M6PTRN    IFEQ 'TMMI  '
 .   C           M6PTRN    OREQ 'TMMK  '
 .   C           M6PTRN    OREQ 'TMMAL '
 .   C           M6PTRN    OREQ 'TMMWV '
 .   C           M6PTRN    OREQ 'TMMMS '
 .   C           M6PTRN    OREQ 'TMMBC '
 .   C           M6PTRN    OREQ 'TMMTX '
 .   C           M6PTRN    OREQ 'TMMNK '
 .   C           M6PTRN    OREQ 'TMMGT '
 .   C           M6PTRN    OREQ 'MTM   '
 .   C           M6PTRN    OREQ 'TABC  '
 .   C           LTR4      IFEQ 'DUP '
 .   C                     GOTO @@END
 .   C                     ENDIF
 .   C                     ENDIF
 .    * SET CONT LEVEL
 .   C           M6PTRN    IFEQ SVPTRN
 .   C                     MOVE *OFF      *INL2
 .   C                     ELSE
 .   C                     MOVE *ON       *INL2
 .   C                     ENDIF
 .   C           M6REFN    IFEQ SVREFN
 .   C                     MOVE *OFF      *INL1
 .   C                     ELSE
 .   C                     MOVE *ON       *INL1
JWA  C                     ENDIF
      *
     C           *INL2     IFEQ *ON
     C                     MOVE *OFF      *IN98
     C                     ENDIF
      *
     C                     MOVEA'000'     *IN,1
     C                     MOVELM6PTRN    @PTR3   3
     C                     MOVELM6PTRN    @PTR5   5
      *
     C                     SELEC
      * HONDA
     C           @PTR5     WHEQ 'HONDA'
     C                     MOVE '1'       @HND
     C                     MOVELM6REFN    W@REFN 15
     C                     MOVELM6SHPT    @@SHP   4
     C                     MOVE *ON       *IN02            QPRINT2
JW6   * DENSO
 |   C           M6PTRN    WHEQ 'DMMIM1'                   MI
 |   C           M6PTRN    OREQ 'DNMXT1'                   MX,T1
 |   C           M6PTRN    OREQ 'DNMXS1'                   MX,S1
 |   C           M6PTRN    OREQ 'DNMXM1'                   MX,M1
 |   C           M6PTRN    OREQ 'DMARA1'                   AR
 |   C           M6PTRN    OREQ 'DMCNP1'                   CANADA
 |   C           M6PTRN    OREQ 'DMNCN1'                   GNC_
 |   C           M6PTRN    OREQ 'DMTNA1'                   TN
 |   C                     MOVE '1'       @DENSO
 |   C                     MOVELM6REFN    W@REFN 15
 |   C                     MOVELM6SHPT    @@SHP   4
JW6  C                     MOVE *ON       *IN04            QPRINT6
      * TOYOTA
     C**         M6PTRN    WHEQ 'TMS'
     C           @PTR3     WHEQ 'TMS'
     C                     MOVE '1'       @TMS
     C                     MOVE *ON       *IN03            QPRINT5
     C                     OTHER
     C                     MOVE *ON       *IN01            QPRINT
     C                     MOVE '1'       @GEN             GENERAL
     C                     ENDSL
JW5   * SET ERROR FLAG
 |   C**JW7      M6ACKC    IFEQ 'TR'
 |   C**                   MOVE '*'       @ERR
JW5  C**                   ENDIF
      * GENERAL PROCESS
     C           *IN01     IFEQ *ON
     C                     EXSR #GEN
JW7  C           M6ACKC    IFEQ 'IR'
JW7  C           M6ACKC    OREQ 'TR'
 |   C                     MOVE '*'       @ERRG
JW7  C                     ENDIF
     C                     ENDIF
      * HONDA PROCESS
     C           *IN02     IFEQ *ON
     C                     EXSR #HONDA
JW7  C           M6ACKC    IFEQ 'TR'
 |   C                     MOVE '*'       @ERRH
JW7  C                     ENDIF
     C                     ENDIF
     C* TMS PROCESS
     C           *IN03     IFEQ *ON
     C                     EXSR #TMS
JW7  C           M6ACKC    IFEQ 'IR'
 |   C                     MOVE '*'       @ERRT
JW7  C                     ENDIF
     C                     ENDIF
JW6  C* DENSO PROCESS
 |   C           *IN04     IFEQ *ON
 |   C                     EXSR #DENSO
JW7  C           M6ACKC    IFEQ 'TR'
 |   C                     MOVE '*'       @ERRD
JW7  C                     ENDIF
JW6  C                     ENDIF
