     C                     MOVEL*BLANK    @KTEI
     C                     MOVELW@CHN1    CKHIN1
     C                     MOVELW@CHN2    CKHIN2
     C                     MOVELW@CHN3    CKHIN3
     C                     Z-ADD*ZERO     @NNNM
     C                     Z-ADD*ZERO     @N1NM
     C                     Z-ADD*ZERO     @N2NM
     C                     Z-ADD*ZERO     @SRYO
     C                     END
     C*
     C           A2AK11    IFEQ *BLANK
