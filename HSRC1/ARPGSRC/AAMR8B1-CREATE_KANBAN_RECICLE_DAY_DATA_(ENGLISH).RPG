     H            Y.
     F** AAMR8B1 *******************************************
     F*かんばん回転日数データ作成                        *
     F*   CREATE KANABAN RECICLE DAY DATA                  *
     F*   MSK.                            2011.02.16       *
     F* -------------------------------------------------- *
     F* 2021.01.20 DCS. T.MITSUI
     F*   CHANGE WITH THE NUMBER OF FIGURES EXPANSION OF THE "KANBAN"
     F*   JW     2025.02.10 CHG HEADER IN ENGLISH
     F******************************************************
     FAAMWP81 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FAAMWP82 O   F     512            DISK                      A
      *
     IW1K         DS
     I                                        1  10 W1K001
     I                                       11  20 W1K002
      *
     ISVK         DS
     I                                        1  10 SVK001
     I                                       11  20 SVK002
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------*
      *   PLIST                                            *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           POUT    1
      *----------------------------------------------------*
      *   MAIN ROUTINE                                     *
      *----------------------------------------------------*
     C                     TIME           WTIME
     C                     EXSR #CLEAR
      *
     C                     SELEC
     C           POUT      WHEQ '1'
     C           POUT      OREQ '2'
     C                     EXCPTHD
     C           POUT      WHEQ '3'
     C                     EXCPTHD3
     C                     ENDSL
      *
     C                     READ AAMWP811                 81
      *
     C           *IN81     DOWEQ'0'
     C                     MOVELW1K       SVK
      *
     C                     EXSR #OUT1
      *
     C                     EXSR #ADD1
      *
     C                     READ AAMWP811                 81
     C           W1K       IFNE SVK
     C                     EXSR #TOTAL
     C                     EXSR #CLEAR
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     EXSR #TOTAL
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------*
      *集計項目クリア             *
      * CLEAR TOTAL FIELD           *
      *-----------------------------*
     CSR         #CLEAR    BEGSR
      *
     C                     Z-ADD0         T@KHSU 122
     C                     Z-ADD0         T@LOTK  50
     C                     Z-ADD0         T@KMAX  70
     C                     Z-ADD0         T@ALL   70
     C                     Z-ADD0         T@CICL  82
     C                     Z-ADD0         T@CNT   50
      *
     CSR         ECLEAR    ENDSR
      *-----------------------------*
      *データ出力                 *
      * OUTPUT DATA                 *
      *-----------------------------*
     CSR         #OUT1     BEGSR
      *
     C                     MOVELW1BMON    KCODE   40
     C                     MOVEL*BLANK    O@BMNM 22
     C           KCODE     CHAINFGBPL01              21
     C           *IN21     IFEQ '0'
     C                     MOVELB2SMEI    O@BMNM
     C                     ENDIF
      *
     C                     MOVEL*BLANK    O@SHN  14
     C           W1SHN1    CAT  '-':0     O@SHN
     C           O@SHN     CAT  W1SHN2:0  O@SHN
     C           W1SHN3    IFNE *BLANK
     C           O@SHN     CAT  '-':0     O@SHN
     C           O@SHN     CAT  W1SHN3:0  O@SHN
     C                     ENDIF
     C                     MOVELW1KOTE    O@KOTE  3
     C                     MOVEL*BLANK    O@TKR   9
     C           W1TKR1    CAT  '-':0     O@TKR
     C           O@TKR     CAT  W1TKR2:0  O@TKR
     C           O@TKR     CAT  '-':0     O@TKR
     C           O@TKR     CAT  W1TKR3:0  O@TKR
     C           O@TKR     CAT  '-':0     O@TKR
     C           O@TKR     CAT  W1TKR4:0  O@TKR
     C                     Z-ADDW1KTSU    O@KTSU  90
     C                     Z-ADDW1KSSU    O@KSSU  90
     C                     Z-ADDW1SYUY    O@SYUY  70
     C                     Z-ADDW1KHSU    O@KHSU  92
     C                     Z-ADDW1LOTK    O@LOTK  30
     C                     Z-ADDW1KJNK    O@KJNK  30
     C                     Z-ADDW1SETO    O@SETO  30
     C                     Z-ADDW1KMAX    O@KMAX  50
     C                     SELEC
     C           W1KCD1    WHEQ 'C'
     C           W1KCD1    OREQ 'D'
     C           W1KCD1    OREQ 'E'
     C           W1KCD1    OREQ 'F'
     C                     Z-ADDW1KMAX    O@ALL   70
     C                     OTHER
     C           W1LOTK    MULT W1KMAX    O@ALL   70
     C                     ENDSL
     C           W1KHSU    IFEQ 0
     C                     Z-ADD0         O@CICL
     C                     ELSE
     C           O@ALL     DIV  W1KHSU    O@CICL  82
     C                     ENDIF
     C                     MOVELW1KCD1    O@KCD   3
     C           W1KCD2    IFNE *BLANK
     C           O@KCD     CAT  '-':0     O@KCD
     C           O@KCD     CAT  W1KCD2:0  O@KCD
     C                     ENDIF
      *
     C           POUT      IFEQ '1'
     C           POUT      OREQ '2'
     C                     EXCPTDT
     C                     ENDIF
      *
     CSR         EOUT1     ENDSR
      *-----------------------------*
      *集計項目                   *
      * ADD FIELD                   *
      *-----------------------------*
     CSR         #ADD1     BEGSR
      *
     C                     ADD  O@KHSU    T@KHSU 122
     C                     ADD  O@LOTK    T@LOTK  50
     C                     ADD  O@KMAX    T@KMAX  70
     C                     ADD  O@ALL     T@ALL   70
     C                     ADD  O@CICL    T@CICL  82
     C                     ADD  1         T@CNT
      *
     CSR         EADD1     ENDSR
      *-----------------------------*
      *合計                       *
      * OUTPUT TOTAL                *
      *-----------------------------*
     CSR         #TOTAL    BEGSR
      *
     C**         T@CNT     IFEQ 0
     C**                   Z-ADD0         T@CICL
     C**                   ELSE
     C**         T@CICL    DIV  T@CNT     T@CICL
     C**                   ENDIF
     C                     SELEC
     C           POUT      WHEQ '1'
     C           POUT      OREQ '2'
     C                     EXCPTTO
     C           POUT      WHEQ '3'
     C                     EXCPTTO3
     C                     ENDSL
      *
     CSR         ETOTAL    ENDSR
      *
     OAAMWP82 EADD             HD
     O                                      ','
