     C                     KFLD           K@BIN   20
     C                     KFLD           EKRLYY
     C                     KFLD           EKRLMM
     C                     KFLD           EKRLDD
     C                     KFLD           K@DELY  40
     C                     KFLD           EKNUKE
     C                     KFLD           K@IPAR
      *
     C                     MOVE '01'      @@ID    2
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @@RRN   40
     C                     Z-ADD*ZERO     BH
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  1ST SCREEN
      *--------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C           *INKA     IFEQ *ON
     C                     MOVE '99'      @@ID
     C                     ELSE
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           SERL      IFEQ *BLANK
     C                     EXSR #SET1
     C           RRN1      IFEQ *ZERO
     C                     SETON                     0199
     C                     MOVE ER,6      D@MSG
     C                     ELSE
     C                     MOVE '02'      @@ID
     C                     ENDIF
     C                     ELSE
     C                     EXSR #SET2
     C                     MOVE '03'      @@ID
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  CHECK
      *--------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C           SERL      IFEQ *BLANK
     C           HIN       IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      D@MSG
     C                     ENDIF
      *-----------------*
      *  CHECK OF DATE  *
      *-----------------*
     C           BEHZ      IFEQ 0
     C  N99                MOVE ER,2      D@MSG
     C                     SETON                     0299
     C                     ENDIF
     C           YY        IFEQ 0
     C  N99                MOVE ER,3      D@MSG
     C                     SETON                     0299
     C                     ENDIF
     C           MM        IFEQ 0
     C  N99                MOVE ER,4      D@MSG
     C                     SETON                     0399
     C                     ENDIF
     C           MM        IFGT 12
     C  N99                MOVE ER,10     D@MSG
     C                     SETON                     0399
     C                     ENDIF
     C           DD        IFEQ 0
     C  N99                MOVE ER,5      D@MSG
     C                     SETON                     0499
     C                     ENDIF
     C           DD        IFGT 31
     C  N99                MOVE ER,11     D@MSG
     C                     SETON                     0499
     C                     ENDIF
      *--------------------*
      *  SET OF CHECK KEY  *
      *--------------------*
     C                     MOVE *BLANK    FLG     1
     C           BETM      IFEQ 0
     C                     MOVE '*'       FLG
     C                     ELSE
     C                     MOVE *BLANK    FLG
     C                     ENDIF
      *
     C                     MOVE *BLANK    @ASJ    1
     C           KEYD      SETLLALDPL31
     C           KEYF      READEALDPL31                  90
     C           *IN90     IFEQ *OFF
