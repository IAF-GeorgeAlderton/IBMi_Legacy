      *--------------------------------------------------------
      *   MAIN ROUTINE
      *--------------------------------------------------------
     C           @@ID      DOUEQ'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C           @@ID      CASEQ'02'      #SCRN2
     C           @@ID      CASEQ'03'      #SCRN3
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *--------------------------------------------------------
      * INITIALIZE
      *--------------------------------------------------------
     C           *INZSR    BEGSR
      *
      *<<DATA CHECK>>
     C           KEYD      KLIST
     C                     KFLD           SHN1
     C                     KFLD           SHN2
     C                     KFLD           SHN3
     C                     KFLD           YY
     C                     KFLD           MM
     C                     KFLD           DD
     C                     KFLD           JI
     C                     KFLD           FN
      *<<READ EQUAL>>
     C           KEYF      KLIST
