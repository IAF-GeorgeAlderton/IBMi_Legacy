     C                     MOVE A1SHN3    @@SHN3
     C                     MOVE A1TKR1    @@TKR1
     C                     MOVE A1TKR2    @@TKR2
     C                     MOVE A1TKR3    @@TKR3
     C                     MOVE A1TKR4    @@TKR4
     C                     ENDIF
      *
     C           *IN90     IFEQ *ON
     C  N99                MOVE ER,6      D@MSG
     C                     SETON                     0199
     C                     ENDIF
      *
     C                     ELSE
     C           SERL      CHAINALDPL35              90
     C           *IN90     IFEQ *OFF
     C                     MOVE A3SHN1    @@SHN1
     C                     MOVE A3SHN2    @@SHN2
     C                     MOVE A3SHN3    @@SHN3
     C                     MOVE A3TKR1    @@TKR1
     C                     MOVE A3TKR2    @@TKR2
     C                     MOVE A3TKR3    @@TKR3
     C                     MOVE A3TKR4    @@TKR4
     C                     MOVE A3KANS    S@TYP
     C                     MOVE A3SALE    S@TY1
     C                     MOVE A3ZETI    S@ZETI
     C                     MOVE A3TEHI    S@THI
     C                     MOVE A3PAGE    S@PAG
     C                     MOVE A3OPER    S@USR
     C                     MOVE WTKR      S@LOC
     C                     MOVE A3TASY    H@TASY
     C                     MOVE A32KAK    H@2KAK
     C                     MOVE A3HASY    H@HASY
     C                     MOVE A3MHN1    H@MHN1
     C                     MOVE A3MHN2    H@MHN2
     C                     MOVE A3MHN3    H@MHN3
     C                     MOVE A3MHN4    H@MHN4
     C                     Z-ADDA3SSYS    H@SSYS
     C                     Z-ADDA3USYS    H@USYS
     C                     Z-ADDA3NONY    H@NONY
     C                     MOVE A3NKOJ    H@NKOJ
     C                     MOVE A3NUKE    H@NUKE
     C                     MOVE A3TOPX    H@TOPX
     C                     MOVE A3SERL    S@SQNO
     C                     Z-ADDA3SYYY    CYY
     C                     Z-ADDA3SYMM    CMM
     C                     Z-ADDA3SYDD    CDD
     C                     Z-ADDA3SYJI    CJI
     C                     Z-ADDA3SYFN    CFN
     C                     ELSE
     C           SERL      CHAINALDPL25              90
     C           *IN90     IFEQ *OFF
     C                     MOVE A1SHN1    @@SHN1
     C                     MOVE A1SHN2    @@SHN2
     C                     MOVE A1SHN3    @@SHN3
     C                     MOVE A1TKR1    @@TKR1
     C                     MOVE A1TKR2    @@TKR2
     C                     MOVE A1TKR3    @@TKR3
     C                     MOVE A1TKR4    @@TKR4
     C                     MOVE A1KANS    S@TYP
     C                     MOVE A1SALE    S@TY1
     C                     MOVE A1ZETI    S@ZETI
     C                     MOVE A1OPER    S@USR
     C                     MOVE WTKR      S@LOC
     C                     MOVE A1MHN1    H@MHN1
     C                     MOVE A1MHN2    H@MHN2
     C                     MOVE A1MHN3    H@MHN3
     C                     MOVE A1MHN4    H@MHN4
     C                     Z-ADDA1SSYS    H@SSYS
     C                     Z-ADDA1USYS    H@USYS
     C                     Z-ADDA1NONY    H@NONY
     C                     MOVE A1NKOJ    H@NKOJ
     C                     MOVE A1NUKE    H@NUKE
     C                     MOVE A1TOPX    H@TOPX
     C                     MOVE A1SERL    S@SQNO
     C                     Z-ADDA1SYYY    CYY
     C                     Z-ADDA1SYMM    CMM
     C                     Z-ADDA1SYDD    CDD
     C                     Z-ADDA1SYJI    CJI
     C                     Z-ADDA1SYFN    CFN
     C                     ENDIF
     C                     ENDIF
     C           *IN90     IFEQ *ON
     C  N99                MOVE ER,6      D@MSG
     C                     SETON                     0599
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  CLEAR
      *--------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *BLANK    D@MSG
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,01
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  SET DATA
      *--------------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     MOVE *ON       *IN51
     C                     WRITECTL01
     C                     MOVE *OFF      *IN51
     C                     Z-ADD*ZERO     RRN1
     C                     Z-ADD*ZERO     @@RRN
      *
     C           @ASJ      IFEQ *BLANK
     C           KEYD      SETLLALDPL31
     C                     ELSE
     C           KEYD      SETLLALDPL21
     C                     ENDIF
      *
     C                     EXSR #SET11
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  SET DATA
      *--------------------------------------------------------
     C           #SET11    BEGSR
      *
     C                     Z-ADD@@RRN     RRN1
     C                     Z-ADD*ZERO     X       20
     C           *IN80     DOUEQ*ON
     C           @ASJ      IFEQ *BLANK
     C           KEYF      READEALDPL31                  80
     C                     ELSE
     C           KEYF      READEALDPL21                  80
     C                     ENDIF
     C           *IN80     IFEQ *OFF
     C                     CLEARSFL01
     C           @ASJ      IFEQ *BLANK
     C                     MOVE A3KANS    S@TYP
     C                     MOVE A3SALE    S@TY1
     C                     MOVE A3ZETI    S@ZETI
     C                     MOVE A3TEHI    S@THI
     C                     MOVE A3PAGE    S@PAG
     C                     MOVE A3SYHZ    S@DAT
     C                     MOVE A3SYTM    S@TIM
     C                     MOVE A3OPER    S@USR
     C                     MOVE WTKR      S@LOC
     C                     MOVE A3TASY    H@TASY
     C                     MOVE A32KAK    H@2KAK
     C                     MOVE A3HASY    H@HASY
     C                     MOVE A3MHN1    H@MHN1
     C                     MOVE A3MHN2    H@MHN2
     C                     MOVE A3MHN3    H@MHN3
     C                     MOVE A3MHN4    H@MHN4
     C                     Z-ADDA3SSYS    H@SSYS
     C                     Z-ADDA3USYS    H@USYS
     C                     Z-ADDA3NONY    H@NONY
     C                     MOVE A3NKOJ    H@NKOJ
     C                     MOVE A3NUKE    H@NUKE
     C                     MOVE A3TOPX    H@TOPX
     C                     MOVE A3SERL    S@SQNO
     C                     ELSE
     C                     MOVE A1KANS    S@TYP
     C                     MOVE A1SALE    S@TY1
     C                     MOVE A1ZETI    S@ZETI
     C                     MOVE A1SYHZ    S@DAT
     C                     MOVE A1SYTM    S@TIM
     C                     MOVE A1OPER    S@USR
     C                     MOVE WTKR      S@LOC
     C                     MOVE A1MHN1    H@MHN1
     C                     MOVE A1MHN2    H@MHN2
     C                     MOVE A1MHN3    H@MHN3
     C                     MOVE A1MHN4    H@MHN4
     C                     Z-ADDA1SSYS    H@SSYS
     C                     Z-ADDA1USYS    H@USYS
     C                     Z-ADDA1NONY    H@NONY
     C                     MOVE A1NKOJ    H@NKOJ
     C                     MOVE A1NUKE    H@NUKE
     C                     MOVE A1TOPX    H@TOPX
     C                     MOVE A1SERL    S@SQNO
     C                     ENDIF
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     ADD  1         X
     C           X         IFEQ 16
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADDRRN1      @@RRN
     C                     Z-ADDRRN1      #RCNO1
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  2ND SCREEN
      *--------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN52
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN52
      *
     C                     Z-ADD@@REC     #RCNO1
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      @@ID
     C           *IN38     WHEQ *ON
     C           *IN80     ANDEQ*OFF
     C                     EXSR #SET11
      *
     C                     OTHER
     C                     EXSR #CHK2
     C                     ENDSL
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  CHEK
      *--------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     MOVE '02'      @@ID
     C                     Z-ADD*ZERO     WRRN    40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           S@SLC     IFNE *BLANK
     C                     MOVE *BLANK    S@SLC
     C                     UPDATSFL01
     C                     EXSR #SET2
     C                     MOVE '03'      @@ID
     C                     Z-ADDWRRN      WRRN2   40
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *--------------------------------------------------------
      *  SET DATA FOR 3RD SCREEN
      *--------------------------------------------------------
     C           #SET2     BEGSR
      *
     C                     MOVE S@LOC     ADR
     C           S@TYP     IFEQ 'A'
     C                     MOVE 'I'       KAN     1
     C                     GOTO JUMP
     C                     ENDIF
     C           S@TYP     IFEQ 'A'
     C           S@TYP     OREQ 'S'
     C           S@TYP     OREQ 'R'
     C           S@TYP     OREQ 'M'
     C           S@TYP     OREQ 'Y'
     C                     MOVE 'A'       KAN
     C                     GOTO JUMP
     C                     ENDIF
     C                     MOVE '1'       KAN
     C           JUMP      TAG
     C                     SETOF                     95
     C                     MOVE *BLANK    KANB
     C           KAN       LOKUPTAB1      TAB2           95
     C   95                MOVELTAB2      KANB
     C                     SETOF                     95
     C                     MOVE *BLANK    TYP
     C           S@TY1     LOKUPTAB3      TAB4           95
     C   95                MOVELTAB4      TYP
     C                     MOVE S@ZETI    IDNO
     C                     MOVE S@THI     LOTN
     C                     MOVE S@PAG     PAGN
     C                     MOVE S@TYP     CONT
     C                     MOVE H@TASY    OBJE
     C                     MOVE H@2KAK    SECN
     C                     MOVE H@HASY    CNTY
     C                     MOVE WUSR      UHN
     C                     Z-ADDS@DAT     CMHZ
     C                     Z-ADDS@TIM     CMTM
     C                     MOVE S@USR     OPER    60
     C                     SETOF                     70
     C           KEY2      CHAINALBPL30              70
     C           *IN70     IFEQ '0'
     C           ALSKJY    IFEQ 'D'
     C           ALSKHZ    ANDLE*DATE
     C                     SETON                     70
     C                     ENDIF
     C                     ENDIF
     C                     MOVE *BLANK    OPEN
     C           *IN70     IFEQ '0'
     C                     MOVE ALWKNM    OPEN
     C                     ENDIF
     C                     Z-ADDH@SSYS    SSYS
     C                     Z-ADDH@USYS    USYS
     C                     Z-ADDH@NONY    NONY
     C                     MOVE H@NKOJ    PLNT
