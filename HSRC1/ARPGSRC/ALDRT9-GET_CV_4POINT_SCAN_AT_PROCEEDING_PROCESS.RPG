     H            Y
     F** ALDRT9 *******************************************************
     F*  GET CV 4POINT SCAN AT PROCEEDING PROCESS  ALCPP01            *
     F*  SAKAKI.          2019.09.18                                  *
     F*****************************************************************
     FALCPL06 IF  E           K        DISK                           UC
%0001FALRPL08 IF  E           K        DISK                           UC
      *
     C           *ENTRY    PLIST
     C*                                IN ------
     C                     PARM           P@CHYU  1
     C                     PARM           P@ZETI  4
     C                     PARM           P@THNO  3
     C                     PARM           P@PAGE  2
     C                     PARM           P@HTHZ  80       KANBAN PUBLICATION
     C*                               OUT ------
     C                     PARM           P@DATE  80       PICKING DATE
     C                     PARM           P@TIME  60       PICKING TIME
     C                     PARM           P#OPN   1
     C           P#OPN     IFEQ '9'
     C           OPNFL     IFEQ '1'
     C                     CLOSEALCPL06
     C                     CLOSEALRPL08
     C                     ENDIF
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
     C           OPNFL     IFEQ *BLANK
     C                     MOVEL'1'       OPNFL   1
     C                     OPEN ALCPL06
     C                     OPEN ALRPL08
     C                     ENDIF
     C*
     C                     MOVE P@CHYU    K@CHYU
     C                     MOVE P@ZETI    K@ZETI
     C                     MOVE P@THNO    K@THNO
     C*
     C                     Z-ADD0         P@DATE
     C                     Z-ADD0         P@TIME
     C*
     C           ALCKEY    KLIST
     C                     KFLD           K@CHYU  1
     C                     KFLD           K@ZETI  4
     C                     KFLD           K@THNO  3
     C*
     C           ALRKEY    KLIST
     C                     KFLD           K@ZETI  4
     C                     KFLD           K@THNO  3
     C*
     C           ALCKEY    SETGTALCPL06
     C                     DO   *HIVAL
     C           ALCKEY    REDPEALCPL06                  88
     C   88                LEAVE
     C           A8B2LZ    IFEQ *BLANK
     C                     ITER
     C                     END
     C           A8BRCD    IFNE P@PAGE
     C                     ITER
     C                     END
     C           A8BRC3    IFEQ *BLANK
     C                     ITER
     C                     END
     C           A8DATE    IFLT P@HTHZ
     C                     ITER
     C                     END
     C           A8ERR     IFEQ 'E'
     C                     ITER
     C                     END
     C                     Z-ADDA8DATE    P@DATE
     C                     Z-ADDA8TIME    P@TIME
     C                     LEAVE
     C                     ENDDO
     C*
     C           *IN88     IFEQ *ON
     C           ALRKEY    SETGTALRPL08
     C                     DO   *HIVAL
     C           ALRKEY    REDPEALRPL08                  88
     C   88                LEAVE
     C           PTKODT    IFLT P@HTHZ
     C                     ITER
     C                     END
     C           PTOKNG    IFEQ 'NG'
     C                     ITER
     C                     END
     C           PTPAGE    IFNE P@PAGE
     C                     ITER
     C                     END
     C                     Z-ADDPTCODT    P@DATE
     C                     Z-ADDPTCOTM    P@TIME
     C                     LEAVE
     C                     ENDDO
     C                     ENDIF
     C*
     C                     SETON                     LR
     C                     RETRN
