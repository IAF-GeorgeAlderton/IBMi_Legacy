     C           *ENTRY    PLIST
     C                     PARM           PBMON   4
     C                     PARM           PYYMM   6
     C                     PARM           PUS    10
     C                     MOVE PBMON     WBMON   40
     C                     MOVE PYYMM     WYYMM
      *
     C                     Z-ADD0         KHIZ    20
     C                     Z-ADD0         HEKN
     C                     Z-ADD0         HEMI
     C                     Z-ADD0         GOKN
     C                     Z-ADD0         GOMI
     C                     Z-ADD0         WHKN
     C                     Z-ADD0         WHMI
     C                     Z-ADD0         WGKN
     C                     Z-ADD0         WGMI
     C                     MOVE *ALL'~'   W196  196
      *
     C                     SETOF                     02
     C                     MOVEL'INF SECT'WUS     8
     C           PUS       CHAINRGAPL111             02
     C           *IN02     IFEQ '0'
     C           J8SKJY    ANDEQ*BLANK
     C                     MOVELJ8NAME    WUS
     C                     END
      *
     C                     SETOF                     02
     C                     MOVEL'XXXXXXXX'WNAM   16
     C           WBMON     CHAINFGBPL011             02
     C           *IN02     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     02
     C                     END
     C           *IN02     IFEQ '0'
     C                     MOVELB2SMEI    WNAM
     C                     END
      *
     C                     WRITEAH#PR101
     C                     Z-ADD0         HKEN
     C                     Z-ADD0         HMAI
      *
     C                     EXSR SUB3
      *
     C                     SETOF                     0304
     C                     Z-ADD0         B       20
      *
     C                     DO   *HIVAL
     C                     SETOF                     02
     C                     READ AH#WP10                  02
     C           *IN02     IFEQ '0'
      *
     C                     SETON                     03
     C           *IN04     IFEQ '0'
     C                     SETON                     04
     C                     Z-ADDCFHTDD    WHTDD
     C                     END
      *
     C           CFHTDD    IFNE WHTDD
     C                     XFOOTHKEN      WKEN
     C                     XFOOTHMAI      WMAI
     C                     ADD  1         B
     C           B         IFGT 25
     C                     Z-ADD1         B
     C                     WRITEAH#PR101
     C                     END
     C                     WRITEAH#PR102
      *
     C                     EXSR SUB1
     C                     Z-ADDCFHTDD    WHTDD
     C                     Z-ADD0         HKEN
     C                     Z-ADD0         HMAI
     C                     END
      *
     C                     Z-ADDCFHTBB    A       20
     C                     ADD  1         HKEN,A
     C                     ADD  CFMAIS    HMAI,A
      *
     C                     END
     C  N02                END
      *
     C           *IN03     IFEQ '1'
     C                     XFOOTHKEN      WKEN
     C                     XFOOTHMAI      WMAI
     C                     WRITEAH#PR102
      *
     C                     EXSR SUB1
     C                     EXSR SUB2
     C                     XFOOTGOKN      WGKN
     C                     XFOOTGOMI      WGMI
     C                     WRITEAH#PR103
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *
      ******************************************************
      *              便単位のカウント
      ******************************************************
     C           SUB1      BEGSR
      *
     C                     Z-ADD1         C       20
     C                     DO   10        C
     C                     ADD  HKEN,C    GOKN,C
     C                     ADD  HMAI,C    GOMI,C
     C                     END
      *
     C                     ENDSR
      ******************************************************
      *                便単位の平均
      ******************************************************
     C           SUB2      BEGSR
      *
     C                     Z-ADD1         E       20
     C                     DO   10        E
     C           GOKN,E    DIV  KHIZ      HEKN,E    H
     C           GOMI,E    DIV  KHIZ      HEMI,E    H
     C                     END
      *
     C                     XFOOTHEKN      WHKN
     C                     XFOOTHEMI      WHMI
      *
     C                     ENDSR
      *
     C******************************************************
     C*                 稼働日計算
     C******************************************************
     C           SUB3      BEGSR
      *
     C                     Z-ADD0         KHIZ
     C                     Z-ADD1         B       20
     C                     SETOF                     55
     C           WYM       KLIST
     C                     KFLD           WYY
     C                     KFLD           WMM
      *
     C           WYM       SETLLAGDPL111
     C                     SETOF                         55
     C                     DO   *HIVAL
     C           WYM       READEAGDPL111                 55
     C           *IN55     IFEQ '0'
     C                     ADD  1         KHIZ
     C                     END
     C  N55                ENDDO
      *
     C                     ENDSR
