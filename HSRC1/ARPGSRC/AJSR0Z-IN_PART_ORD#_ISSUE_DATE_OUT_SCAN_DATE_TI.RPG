     H            Y
     F** AJSR0Z *******************************************
     F*  <IN> 品番＋手配番号＋発行日                    *
     F*        PART +ORD#     +ISSUE DATE                 *
     F*  <OUT>投入日＋投入時刻                          *
     F*        SCAN DATE/TIME                             *
     F*                                                   *
     F*          2021.01.12  DCS.  T.MITSUI               *
     F*****************************************************
     F*    < F > SPECIFICATION                            *
     F*****************************************************
     F*==< PLATING  ADMIT RESULTS FILES. >==*
     FAJSPL16 IF  E           K        DISK
     F*
     F*==< DACRODIZING PLATING ADMIT RESULTS FILES. >==*
     FAJSPL56 IF  E           K        DISK
     F*
     F*==< SB INPROCESS SCAN RESULT FILE >==*
     FALMPL01 IF  E           K        DISK
     F*
     F*==< LOQ INPROCESS SCAN RESULT FILE >==*
     FALHPL04 IF  E           K        DISK
     F*
     E*****************************************************
     E*    < E > SPECIFICATION                            *
     E*****************************************************
     E                    @FIL        5  7
     E*
     I*****************************************************
     I*    < I > SPECIFICATION                            *
     I*****************************************************
     I*==< AJSPL16 >==*
     I*         ( WORK ADMITTABLE DATE )
     I            DS
     I                                        1   80J1WIH8
     I                                        1   40J1WINY
     I                                        5   60J1WINM
     I                                        7   80J1WIND
     I*         ( WORK ADMITTABLE TIME )
     I            DS
     I                                        1   60J1WIT6
     I                                        1   20J1WINJ
     I                                        3   40J1WINF
     I*==< AJSPL56 >==*
     I*         ( WORK ADMITTABLE DATE )
     I            DS
     I                                        1   80J5WIH8
     I                                        1   40J5WINY
     I                                        5   60J5WINM
     I                                        7   80J5WIND
     I*         ( WORK ADMITTABLE TIME )
     I            DS
     I                                        1   60J5WIT6
     I                                        1   20J5WINJ
     I                                        3   40J5WINF
     I*==< ALMPL01 , ALHPL04 >==*
     I*         ( DELETE DATE )
     I            DS
     I                                        1   80A1SKH8
     I                                        1   40A1SKYY
     I                                        5   60A1SKMM
     I                                        7   80A1SKDD
     I*         ( SCAN DATE )
     I            DS
     I                                        1   80A1SCH8
     I                                        1   40A1SCYY
     I                                        5   60A1SCMM
     I                                        7   80A1SCDD
     I*==< WORK >==*
     I            DS
     I                                        1   80W@DATE
     I                                        1   40W@DTYY
     I                                        5   60W@DTMM
     I                                        7   80W@DTDD
     I            DS
     I                                        1   60W@TIME
     I                                        1   20W@TMHH
     I                                        3   40W@TMMM
     I                                        5   60W@TMSS
     I*
     C*****************************************************
     C*          PARAMETER DEFINITION                     *
     C*****************************************************
     C           *ENTRY    PLIST
     C*                   ( IN )
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THAI  3        PRODUCTION ORDER NO.
     C                     PARM           P@PAGE  2        PRODUCTION ORDER NO.
     C                     PARM           P@DATE  80       SERCH START DATE
     C                     PARM           P@TIME  60       SERCH START TIME
     C                     PARM           P@JS10  10       SERCH SEQ. OF AJSPP10
     C                     PARM           P@JS50  10       SERCH SEQ. OF AJSPP50
     C                     PARM           P@LM01  10       SERCH SEQ. OF ALMPP01
     C                     PARM           P@LH01  10       SERCH SEQ. OF ALHPP01
     C*                   ( OUT )
     C                     PARM           P@WIHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@WITM  60       WORK ADMITTABLE TIME
     C*
     C*****************************************************
     C*          DATABASE SEARCH KEY DEFINITION           *
     C*****************************************************
     C*==< AJSPL16 : PLATING  ADMIT RESULTS FILES. >==*
     C*==< AJSPL56 : DACRODIZING PLATING ADMIT RESULTS FILES. >==*
     C           K@SET1    KLIST
     C                     KFLD           K@HIN1  5         PART NO.1
     C                     KFLD           K@HIN2  5         PART NO.2
     C                     KFLD           K@HIN3  2         PART NO.3
     C                     KFLD           K@THAI  3         PRODUCTION ORDER
     C                     KFLD           K@DTYY  40        DATE YEAR
     C                     KFLD           K@DTMM  20        DATE MONTH
     C                     KFLD           K@DTDD  20        DATE DAY
     C                     KFLD           K@TMHH  20        TIME HOUR
     C                     KFLD           K@TMMM  20        TIME MINUTS
     C           K@RED1    KLIST
     C                     KFLD           K@HIN1            PART NO.1
     C                     KFLD           K@HIN2            PART NO.2
     C                     KFLD           K@HIN3            PART NO.3
     C                     KFLD           K@THAI            PRODUCTION ORDER
     C*
     C*==< ALMPL01 : SB INPROCESS SCAN RESULT FILE >==*
     C           K@SET2    KLIST
     C                     KFLD           K@HIN1            PART NO.1
     C                     KFLD           K@HIN2            PART NO.2
     C                     KFLD           K@HIN3            PART NO.3
     C                     KFLD           K@DTYY            DATE YEAR
     C                     KFLD           K@DTMM            DATE MONTH
     C                     KFLD           K@DTDD            DATE DAY
     C                     KFLD           K@TIME  60        TIME
     C           K@RED2    KLIST
     C                     KFLD           K@HIN1            PART NO.1
     C                     KFLD           K@HIN2            PART NO.2
     C                     KFLD           K@HIN3            PART NO.3
     C*
     C*==< ALHPL04 : LOQ INPROCESS SCAN RESULT FILE >==*
     C           K@SET3    KLIST
     C                     KFLD           K@HIN1            PART NO.1
     C                     KFLD           K@HIN2            PART NO.2
     C                     KFLD           K@HIN3            PART NO.3
     C                     KFLD           K@THAI            PRODUCTION ORDER
     C                     KFLD           K@DTYY            DATE YEAR
     C                     KFLD           K@DTMM            DATE MONTH
     C                     KFLD           K@DTDD            DATE DAY
     C                     KFLD           K@TIME            TIME
     C           K@RED3    KLIST
     C                     KFLD           K@HIN1            PART NO.1
     C                     KFLD           K@HIN2            PART NO.2
     C                     KFLD           K@HIN3            PART NO.3
     C                     KFLD           K@THAI            PRODUCTION ORDER
     C*
     C*****************************************************
     C*          WORKING ITEM DEFINITION                  *
     C*****************************************************
     C                     Z-ADD*ZERO     J       10
     C*
     C*****************************************************
     C*          M A I N   R O U T I N E                  *
     C*****************************************************
     C*
     C                     EXSR #INIT
     C*
     C                     Z-ADD1         J
D----C           J         DOWLE5
|    C           P@WIHZ    ANDEQ*ZERO
|    C*
|S---C                     SELEC
|+---C           @FIL,J    WHEQ 'AJSPP10'
||   C                     EXSR #JS10
||   C*
|+---C           @FIL,J    WHEQ 'AJSPP50'
||   C                     EXSR #JS50
||   C*
|+---C           @FIL,J    WHEQ 'ALMPP01'
||   C                     EXSR #LM01
||   C*
|+---C           @FIL,J    WHEQ 'ALHPP01'
||   C                     EXSR #LH01
|E---C                     ENDSL
|    C*
|    C                     ADD  1         J
E----C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C*****************************************************
     C*  #INIT   INITIAL PROCESS                          *
     C*****************************************************
     C           #INIT     BEGSR
     C*
     C*===< PARAMETER INITIALIZE >==*
     C                     Z-ADD*ZERO     P@WIHZ            WORK ADMITTABLE DATE
     C                     Z-ADD*ZERO     P@WITM            WORK ADMITTABLE TIME
     C*
     C*===< SERCH FILE SETTING >==*
     C                     MOVEL*BLANK    @FIL
I----C           P@JS10    IFNE *ZERO
|    C                     Z-ADDP@JS10    J
|    C                     MOVEL'AJSPP10' @FIL,J
E----C                     ENDIF
I----C           P@JS50    IFNE *ZERO
|    C                     Z-ADDP@JS50    J
|    C                     MOVEL'AJSPP50' @FIL,J
E----C                     ENDIF
I----C           P@LM01    IFNE *ZERO
|    C                     Z-ADDP@LM01    J
|    C                     MOVEL'ALMPP01' @FIL,J
E----C                     ENDIF
I----C           P@LH01    IFNE *ZERO
|    C                     Z-ADDP@LH01    J
|    C                     MOVEL'ALHPP01' @FIL,J
E----C                     ENDIF
     C*
     C*===< SERCH KEY SETTING >==*
     C                     MOVELP@HIN1    K@HIN1            PART NO.1
     C                     MOVELP@HIN2    K@HIN2            PART NO.2
     C                     MOVELP@HIN3    K@HIN3            PART NO.3
     C                     MOVELP@THAI    K@THAI            PRODUCTION ORDER
     C                     Z-ADDP@DATE    W@DATE
     C                     Z-ADDP@TIME    W@TIME
     C                     Z-ADDW@DTYY    K@DTYY            DATE YEAR
     C                     Z-ADDW@DTMM    K@DTMM            DATE MONTH
     C                     Z-ADDW@DTDD    K@DTDD            DATE DAY
     C                     Z-ADDW@TMHH    K@TMHH            TIME HOUR
     C                     Z-ADDW@TMMM    K@TMMM            TIME MINUTS
     C                     Z-ADDP@TIME    K@TIME            TIME
     C*
     C           #INITE    ENDSR
     C*****************************************************
     C*  #JS10   AJSPP10 SERCH                            *
     C*****************************************************
     C           #JS10     BEGSR
     C*
     C                     Z-ADD*ZERO     J1WIT6
     C                     SETOF                     91
     C*                    ____________
     C           K@SET1    SETGTAJSPL16
     C                     DO   *HIVAL
     C           K@RED1    READEAJSPL16                  91
     C*                    ~~~~~~~~~~~~
     C   91                LEAVE
I2---C           J1PAG1    IFNE P@PAGE
|    C           J1PAG2    ANDNEP@PAGE
|    C           J1PAG3    ANDNEP@PAGE
|    C           J1PAG4    ANDNEP@PAGE
     C                     ITER
E----C                     ENDIF
     C                     Z-ADDJ1WIH8    P@WIHZ            WORK ADMITTABLE DATE
     C                     Z-ADDJ1WIT6    P@WITM            WORK ADMITTABLE TIME
     C                     LEAVE
     C                     ENDDO
     C*
     C           #JS10E    ENDSR
     C*****************************************************
     C*  #JS50   AJSPP50 SERCH                            *
     C*****************************************************
     C           #JS50     BEGSR
     C*
     C                     Z-ADD*ZERO     J5WIT6
     C                     SETOF                     92
     C*                    ____________
     C           K@SET1    SETGTAJSPL56
     C                     DO   *HIVAL
     C           K@RED1    READEAJSPL56                  92
     C*                    ~~~~~~~~~~~~
     C   92                LEAVE
I2---C           J5PAG1    IFNE P@PAGE
|    C           J5PAG2    ANDNEP@PAGE
|    C           J5PAG3    ANDNEP@PAGE
|    C           J5PAG4    ANDNEP@PAGE
|    C                     ITER
E----C                     ENDIF
     C                     Z-ADDJ5WIH8    P@WIHZ            WORK ADMITTABLE DATE
     C                     Z-ADDJ5WIT6    P@WITM            WORK ADMITTABLE TIME
     C                     LEAVE
     C                     ENDDO
     C*
     C           #JS50E    ENDSR
     C*****************************************************
     C*  #LM01   ALMPP01 SERCH                            *
     C*****************************************************
     C           #LM01     BEGSR
     C*                    ____________
     C           K@SET2    SETGTALMPL01
     C                     EXSR #M01R
     C*                    ~~~~~~~~~~~~
I----C           *IN93     IFEQ '0'
|    C                     Z-ADDA1SCH8    P@WIHZ            WORK ADMITTABLE DATE
|    C                     Z-ADDA1SCTM    P@WITM            WORK ADMITTABLE TIME
E----C                     ENDIF
     C*
     C           #LM01E    ENDSR
     C*===================================================*
     C*  #M01R   ALMPL01 READ                             *
     C*===================================================*
     C           #M01R     BEGSR
     C*
     C           #M01R1    TAG
     C*                    ____________
     C           K@RED2    READEALMPL01                  93
     C*                    ~~~~~~~~~~~~
     C           *IN93     CABEQ'1'       #M01RE
     C*
I----C           A1SKJY    IFEQ 'D'
|    C           A1SKH8    ANDLE*DATE
|    C                     GOTO #M01R1
E----C                     ENDIF
     C*
     C           #M01RE    ENDSR
     C*****************************************************
     C*  #LH01   ALHPP01 SERCH                            *
     C*****************************************************
     C           #LH01     BEGSR
     C*                    ____________
     C           K@SET3    SETGTALHPL04
     C                     EXSR #H01R
     C*                    ~~~~~~~~~~~~
I----C           *IN94     IFEQ '0'
|    C                     Z-ADDA1SCH8    P@WIHZ            WORK ADMITTABLE DATE
|    C                     Z-ADDA1SCTM    P@WITM            WORK ADMITTABLE TIME
E----C                     ENDIF
     C*
     C           #LH01E    ENDSR
     C*===================================================*
     C*  #H01R   ALHPL04 READ                             *
     C*===================================================*
     C           #H01R     BEGSR
     C*
     C           #H01R1    TAG
     C*                    ____________
     C           K@RED3    READEALHPL04                  94
     C*                    ~~~~~~~~~~~~
     C           *IN94     CABEQ'1'       #H01RE
     C*
I----C           A1SKJY    IFEQ 'D'
|    C           A1SKH8    ANDLE*DATE
|    C                     GOTO #H01R1
E----C                     ENDIF
     C*
     C           #H01RE    ENDSR
     C*
