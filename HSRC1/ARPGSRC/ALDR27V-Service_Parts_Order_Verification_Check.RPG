     H            Y.                                    1
      ** ALDR27V  **************************************************************
      *  SERVICE PARTS ORDER VERIFICATION                                      *
      *
      **************************************************************************
     FALDPW27VCF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL010
     F                                              KINFDS @INFDS
     FAB#PL76 IF  E           K        DISK
     FAB#PL1L IF  E           K        DISK
     FAB#PL66AIF  E           K        DISK
      **************************************************************************
     E                    ERR     1  10 70
      **************************************************************************
     I@INFDS      DS
     I                                     *STATUS  @STTS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60WSSTM6
     I                                        1   40WSSTM4
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  140WSSDAT
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
      * SHIP DATE
     I            DS
     I                                        1   80F1SHDT
     I                                        1   40F1SHYY
     I                                        5   60F1SHMM
     I                                        7   80F1SHDD
     I            DS
     I                                        1   80W1SHDT
     I                                        1   40W1SHYY
     I                                        5   60W1SHMM
     I                                        7   80W1SHDD
     I            DS
     I                                        1   80BANYMD
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'10'      #FMT10
     C           @@ID      CASEQ'15'      #FMT15
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      **************************************************************************
      *         INITIALIZE
      **************************************************************************
     C           *INZSR    BEGSR
      *
     C                     TIME           WSDT
      *
     C                     MOVEL*BLANKS   F1SERL
     C                     MOVEL*BLANKS   MSG
      *
     C                     MOVEL'10'      @@ID    2
     C                     MOVEL*OFF      *IN49
      *
     C           K#76      KLIST
     C                     KFLD           F1SERL
      *
     C           K#1L      KLIST
     C                     KFLD           PUNONY
     C                     KFLD           PUNOYY
     C                     KFLD           PUNOMM
     C                     KFLD           PUNODD
     C                     KFLD           PUNUKE
      ******               KFLD           PUODRN
      *
     C           K#66A     KLIST
     C                     KFLD           BANONY
     C                     KFLD           BAODRN
     C                     KFLD           BANUKE
     C                     KFLD           BANYMD
     C                     KFLD           BAMHN1
     C                     KFLD           BAMHN2
     C                     KFLD           BAMHN3
     C                     KFLD           BAMHN4
      *
     C                     ENDSR
      *************************************************************************
      *     1ST SCREEN(PACKING LIST SERIAL NUMBER)
      **************************************************************************
     C           #FMT10    BEGSR
      *
     C                     SETOF                     4748
     C                     WRITEFMT099
     C                     EXFMTFMT010
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK10
     C           *IN49     IFEQ *OFF
     C                     EXSR #SET15
     C                     MOVEL'15'      @@ID
     C                     ENDIF
     C           *IN49     IFEQ *ON
     C                     MOVEL'10'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************************
      *     1ST SCREEN CHECK
      **************************************************************************
     C           #CHK10    BEGSR
      *
     C                     SETOF                     3149
     C                     TIME           WSDT
      *
     C           F1SERL    IFEQ *BLANKS
     C                     SETON                     3149
     C                     MOVELERR,1     MSG
     C                     ENDIF
      *
     C           K#76      CHAINAB#PL76              98
     C           *IN98     IFEQ *ON
     C                     SETON                     3149
     C                     MOVELERR,2     MSG
     C                     GOTO #EF10
     C                     ENDIF
      *
     C           K#1L      CHAINAB#PL1L              98
     C           *IN98     IFEQ *ON
     C                     SETON                     3149
     C                     MOVELERR,3     MSG
     C                     GOTO #EF10
     C                     ENDIF
      *
     C           #EF10     ENDSR
      *************************************************************************
      *     2ND SCREEN SET
      **************************************************************************
     C           #SET15    BEGSR
      *
     C                     MOVEL*ON       *IN61
     C                     WRITECTL010
     C                     MOVEL*OFF      *IN61
     C                     MOVEL*OFF      *IN62
     C                     Z-ADD*ZERO     RRN1    40
      *
      * now read this order in the order file and check to see if line items
      *  are in the service parts case information file...if not, display part#
      *
     C           K#1L      SETLLAB#PL1L
      *
     C                     DO   *HIVAL
      *
     C           K#1L      READEAB#PL1L                  94
     C   94                LEAVE
      *
     C           BASKJY    IFNE *BLANKS
     C                     ITER
     C                     ENDIF
      *
     C           K#66A     CHAINAB#PL66A             95
      *
     C           *IN95     IFEQ *ON
      *
     C                     CLEARSFL010
     C                     MOVELBAODRN    F1ODRN
     C                     MOVELBANUKE    F1HOME
     C                     Z-ADDBANYMD    F1NYMD
     C                     MOVELBAMHN1    S1MHN1
     C                     MOVELBAMHN2    S1MHN2
     C                     MOVELBAMHN3    S1MHN3
     C                     MOVELBAMHN4    S1MHN4
     C                     MOVELBAHPOS    S1HPOS
      *
     C                     ADD  1         RRN1
     C                     WRITESFL010
      *
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           RRN1      IFEQ *ZERO
     C                     SETON                     3149
     C                     MOVELERR,4     MSG
     C                     ENDIF
      *
     C                     ENDSR
      *************************************************************************
      *     2ND SCREEN DISPLAY
      **************************************************************************
     C           #FMT15    BEGSR
      *
     C                     Z-ADD1         W#RNP1  40
     C                     MOVEL*OFF      *IN49
      *
     C                     DO   *HIVAL
      *
     C                     MOVEL*OFF      *IN47
     C                     MOVEL*ON       *IN48
     C                     WRITEFMT099
     C                     Z-ADDW#RNP1    #RCN01
     C                     EXFMTCTL010
      *
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP1
     C                     ENDIF
      *
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      @@ID
     C                     LEAVE
     C           *INKL     WHEQ *ON
     C                     MOVEL'10'      @@ID
     C                     LEAVE
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     ENDSR
      *
      **************************************************************************
** ERR
SCAN PACKING LIST BC.
PACKING LIST NOT FOUND.
ORDER NOT FOUND.
ALL PARTS HAVE BEEN SCANNED.






