     C*
GA   C           KEY1      KLIST
GA   C                     KFLD           KSIRE   4
GA   C                     KFLD           KSKOJ   1
GA   C                     KFLD           KSUKE   4
     C*
GA   C           KEY2      KLIST
GA   C                     KFLD           #PAR1
GA   C                     KFLD           #PAR2
GA   C                     KFLD           #PAR3
     C           K#FD      KLIST
     C                     KFLD           AFSTID
     C                     KFLD           AFDOCK
     C*
     C                     TIME           WTMDT
     C*
     C                     Z-ADD*ZERO     WFSIDT  80
     C                     Z-ADD*ZERO     WNNET   70
     C                     MOVE *BLANK    WFSTID  5
%0001C                     MOVE *BLANK    WFDOCK  4
     C                     MOVE *BLANK    WFPOR#  6
     C                     MOVE *BLANK    WFREF# 10
 GA  C                     Z-ADD*ZERO     QTYPC   50
     C                     Z-ADD*ZERO     I       20
     C                     MOVE *ZERO     IQY
     C                     MOVE *ZERO     NET
     C                     MOVE *ZERO     DAT
     C                     MOVE *ZERO     DT8
 GA  C                     MOVE *ZERO     QPC
     C                     SETON                     91
     C*
     C           *LOVAL    SETLLABF1P011
     C                     READ ABF1P011                 90
     C*
   B1C           *IN90     DOWEQ'0'
     C*
 GA  C                     Z-ADD1         X       20
 GA  C                     Z-ADD1         Y       20
 GA  C                     MOVEAAFPART    PT1
 GAB2C           1         DO   15        X
 GAB3C           PT1,X     IFNE *BLANK
 GA  C                     MOVEAPT1,X     PT2,Y
 GA  C                     ADD  1         Y
 GA  C*                    ELSE
 GAE3C                     END
 GAE2C                     END
 GA  C                     MOVEAPT2       DPART
     C*
     C* PART NUMBER BREAKE ?
   B2C           AFPART    IFNE WFPART
%0001C           AFDOCK    ORNE WFDOCK
%0001C           AFSTID    ORNE WFSTID
     C*
     C                     MOVE 'AVRT'    KSIRE
     C                     MOVE '0'       KSKOJ
     C                     MOVELAFSTID    KSUKE
     C           KEY1      CHAINEDIPL301             92
   B3C           *IN92     IFEQ '0'
     C                     MOVELE1TOKU    WTOKU   4
     C                     MOVELE1NONY    WNONY   4
     C                     ELSE
     C           K#FD      CHAINABFDP01              92
     C           *IN92     IFEQ *OFF
     C                     MOVELQANONY    WNONY   4
     C                     MOVEL'5149'    WTOKU
     C                     ENDIF
   E3C                     END
     C*
     C                     MOVELE1TOKU    PTOKU   4
     C                     MOVELE1NONY    PNONY   4
     C                     MOVELE1NKOJ    PNKOJ   1
     C                     MOVELAFDOCK    PNUKE   4
     C                     MOVELDPART     @MHIN  20
     C                     MOVEL*BLANK    @SHIN  12
     C                     MOVEL*BLANK    @FLG    1
     C*
     C*
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU
     C                     PARM           PNONY
     C                     PARM           PNKOJ
     C                     PARM           PNUKE
     C                     PARM           @MHIN
     C                     PARM           @SHIN
     C                     PARM           @FLG
     C*
     C                     SETOF                     32
 GA  C           KEY2      CHAINFCEPL011             93
 GA  C           *IN93     IFEQ '0'
 GA  C                     MOVE A2SYYY    CDAT1
 GA  C                     MOVE A2SYMM    CDAT2
 GA  C                     MOVE A2SYDD    CDAT3
%0001C                     MOVE A2TRYY    TDAT1
  |  C                     MOVE A2TRMM    TDAT2
%0001C                     MOVE A2TRDD    TDAT3
     C*
     C                     ELSE
 G   C                     MOVE *BLANK    CDAT1
 G   C                     MOVE *BLANK    CDAT2
 G   C                     MOVE *BLANK    CDAT3
     C                     END
      * KIT
     C           'KIT'     SCAN AFIPAR                   11
     C           *IN11     IFEQ *ON
     C           AFSTID    IFEQ 'TC11A'
     C                     MOVE '5195'    WNONY
     C                     ENDIF
TCH11C           AFSTID    IFEQ 'TC02A'
     C                     MOVE '5198'    WNONY
TCH11C                     ENDIF
     C                     ENDIF
     C* 1ST. RECORD ?
   B3C           *IN91     IFEQ '1'
     C                     SETOF                     913031
     C                     SETOF                     32
     C           AFDLDT    LOKUPDT8                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         I
TCHXXC           I         IFLE 14
     C                     MOVEAWWQTY2    IQY,I
     C                     MOVEAWWDLDT    DAT,I
     C                     Z-ADDAFDLDT    DT8,I
     C           AFQTY2    SUB  AFYSQY    WNNET
     C                     MOVEAWCNET     NET,I
     C*
     C                     EXSR @SYOS
TCHXXC                     ENDIF
     C                     ENDIF
     C*
     C                     ELSE
     C* IF THE CHANGE DATE OF PART MASTER IS IN
     C*    BETWEEN START-END SCHEDULE ISSUE DATE,
     C*    PRINT BOTH PREVIOU AND CURRENT UNIT QTY..
     C                     EXCPT#DTL
     C                     EXSR @CLR
     C                     MOVELAFPART    WFPART
     C*
     C           *IN93     IFEQ '1'
     C                     MOVE *ZERO     QTYPC1
     C                     MOVE *ZERO     QTYPC
%0001C                     MOVE *BLANK    WSTR
%0001C                     MOVE *BLANK    WKTR
     C*
     C                     ELSE
     C           CDATE     IFGE WFHSDT
     C           CDATE     ANDLEWFHEDT
     C                     SETON                     31
     C                     MOVE A2KSYS    QTYPC1
     C                     MOVE A2SSYS    QTYPC
     C*
     C                     ELSE
     C                     MOVE WSYOS     QTYPC
     C                     END
%0001C           TDATE     IFGE WFHSDT
  |  C           TDATE     ANDLEWFHEDT
  |  C                     SETON                     32
  |  C                     END
  |  C                     MOVE A2STR     WSTR
%0001C                     MOVE A2KTR     WKTR
     C                     END
     C*
     C*
     C                     EXSR @SYOS
     C*
E03E3C                     END
     C*
     C                     EXSR @SAVE
     C*
     C                     MOVE 'AVRT'    KSIRE
     C                     MOVE '0'       KSKOJ
     C                     MOVELAFSTID    KSUKE
     C           KEY1      CHAINEDIPL301             92
   B3C           *IN92     IFEQ '0'
     C                     MOVELE1TOKU    WTOKU   4
     C                     MOVELE1NONY    WNONY   4
     C                     ELSE
     C           K#FD      CHAINABFDP01              92
     C           *IN92     IFEQ *OFF
     C                     MOVELQANONY    WNONY   4
     C                     MOVEL'5149'    WTOKU
     C                     ENDIF
   E3C                     END
      *
     C           'KIT'     SCAN AFIPAR                   11
     C           *IN11     IFEQ *ON
     C                     MOVE '5195'    WNONY
     C                     ENDIF
     C*
     C* PAGE HEADER SET & PRINT
     C                     EXCPT#HED1
     C*
   X2C                     ELSE
     C* RELEASE NUMBER BREAKE ?
     C* SCHEDULE ISSUES DATE BREAKE ?
     C* SHIP TO ID CODE(DOCK #) BREAKE ?
     C* REFERENCE NUMBER ?
   B3C           AFPOR#    IFNE WFPOR#
     C           AFSIDT    ORNE WFSIDT
     C           AFSTID    ORNE WFSTID
%0001C           AFDOCK    ORNE WFDOCK
     C           AFREF#    ORNE WFREF#
     C*
     C* PAGE HEADER SET & PRINT
     C   OF                EXCPT#HED1
     C   OF                SETOF                     OF
     C                     EXCPT#DTL
     C*
     C                     EXSR @CLR
     C*
     C                     EXSR @SYOS
     C*
     C                     EXSR @SAVE
     C*
   X3C                     ELSE
     C           AFDLDT    LOKUPDT8                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         I
TCHXXC           I         IFLE 14
     C                     MOVEAWWQTY2    IQY,I
     C                     MOVEAWWDLDT    DAT,I
     C                     Z-ADDAFDLDT    DT8,I
     C           AFQTY2    SUB  AFYSQY    WNNET
     C                     MOVEAWCNET     NET,I
 GA  C                     MOVELAFALFL    WALFL   4
 GA  C                     MOVELAFRALF    WRALF   4
     C                     EXSR @SYOS
TCHXXC                     ENDIF
     C                     ENDIF
     C*
E03E3C                     END
     C*
   E2C                     END
     C*
     C                     READ ABF1P011                 90
   E1C                     END
     C*
     C                     EXCPT#DTL
     C*
     C                     SETON                     LR
     C                     RETRN
NH   C*****************************************************************
|    C*     @SAVE: SAVE DATA
|    C*****************************************************************
|    C           @SAVE     BEGSR
|    C* FILE KEY
|    C                     MOVELAFSTID    WFSTID
%0001C                     MOVELAFDOCK    WFDOCK
|    C                     MOVELAFPART    WFPART 20
|    C                     Z-ADDAFSIDT    WFSIDT
|    C                     MOVELAFPOR#    WFPOR#
|    C                     MOVELAFREF#    WFREF#
|    C*
|    C                     MOVELAFUBM1    WFUBM1  2
|    C                     Z-ADDAFLRDT    WLRDT   60
|    C                     Z-ADDAFLRQY    WLRQY   70
|    C                     Z-ADDAFLSDT    WLSDT   60
|    C                     Z-ADDAFLSQY    WLSQY   70
|    C                     Z-ADDAFYRDT    WYRDT   60
|    C                     Z-ADDAFYRQY    WYRQY   70
|    C                     Z-ADDAFYSDT    WYSDT   60
|    C                     Z-ADDAFYSQY    WYSQY   70
     C                     Z-ADDAFHSDT    WFHSDT  80
     C                     Z-ADDAFHEDT    WFHEDT  80
 GA  C                     MOVELAFALFL    WALFL   4
 GA  C                     MOVELAFRALF    WRALF   4
|    C*
|    C                     ENDSR
NH   C*****************************************************************
|    C*     @CLR : CLEAR WORK-AREA,TBL
|    C*****************************************************************
|    C           @CLR      BEGSR
|    C*
|    C                     MOVE *BLANK    WALFL
|    C                     MOVE *BLANK    WRALF
|    C                     Z-ADD*ZERO     QTYPC   50
|    C                     Z-ADD*ZERO     CDAT
|    C                     Z-ADD*ZERO     QTYPC1  50
|    C                     MOVE *BLANK    WSTR
|    C                     MOVE *BLANK    WKTR
|    C                     SETOF                     303132
|    C                     Z-ADD1         I
|    C                     MOVE *ZERO     IQY
|    C                     MOVE *ZERO     DAT
|    C                     MOVE *ZERO     DT8
|    C                     MOVE *ZERO     NET
|    C                     MOVE *ZERO     QPC
|    C                     MOVEAWWQTY2    IQY,I
|    C           AFQTY2    SUB  AFYSQY    WNNET
|    C                     MOVEAWCNET     NET,I
|    C                     MOVEAWWDLDT    DAT,I
|    C                     Z-ADDAFDLDT    DT8,I
NH   C*
     C                     ENDSR
     C*****************************************************************
     C*     @SYOS:CALCULATION WITH REMAINDER
     C*****************************************************************
     C           @SYOS     BEGSR
     C*
NH   C* SAVE UNIT QTY.
|    C* CALUCULATE THE NUMBER OF CONTAINER
     C           *IN93     IFEQ '1'
|    C                     MOVE *ZERO     WSYOS
|    C                     MOVE *ZERO     QTYPC1
|    C                     MOVE *ZERO     QTYPC
     C*
     C                     ELSE
|    C           AFDLDT    IFLT CDATE
|    C                     MOVE A2KSYS    WSYOS   50
|    C                     ELSE
|    C                     MOVE A2SSYS    WSYOS
|    C                     END
|    C*
|    C                     MOVE A2KSYS    QTYPC1
|    C                     MOVE A2SSYS    QTYPC
%0001C                     MOVE A2STR     WSTR
%0001C                     MOVE A2KTR     WKTR
     C                     END
|    C*
|    C           WSYOS     IFNE *ZERO
|    C           WNNET     DIV  WSYOS     QPCN    60
|    C                     MVR            P1      30
|    C                     EXSR @SUBR1
|    C*
|    C                     ELSE
|    C                     Z-ADD*ZERO     QPCN
|    C                     SETON                     30
NH   C                     END
     C*
     C                     ENDSR
     C*****************************************************************
     C*     @SUBR1:CALCULATION WITH REMAINDER
     C*****************************************************************
 GA  C           @SUBR1    BEGSR
     C*
 GA  C           P1        IFGT 0
 GA  C           QPCN      ANDGE0
 GA  C                     ADD  1         QPCN
 GA  C                     END
 GA  C           P1        IFLT 0
 GA  C           QPCN      ANDLE0
 GA  C                     SUB  1         QPCN
 GA  C                     END
     C*
     C                     MOVEAQPCN      QPC,I
     C*
     C                     ENDSR
