     H            Y.
     F** AFARN5 **********************************
     F* IAF OWK LOT# CALCULATION PROGRAM         *
     F* OWK LOT#: 0A0-9Y9                        *
     F*              C.SAKTHIP   2025.03.14      *
     F******************************** AFARN0 ****
     FAFAPPN5 IF  E           K        DISK
     FAFAPLN5 IF  E           K        DISK
     C           *ENTRY    PLIST
     C                     PARM           PILOTN  3
     C                     PARM           POLOTN  3
      *
     C                     MOVE PILOTN    K@LOTN  3
      *
 S1--C           K@LOTN    CHAINAFAPPN5              78
 |   C           *IN78     IFEQ '0'
 |   C                     EXSR #SB100
 |   C                     ELSE
 |   C                     MOVEL'0A0'     W@LOTN  3
 E1--C                     ENDIF
      *
      *RETURN LOT# TO 0A0 WHEN REACH 9Y9
      *
     C           *IN81     IFEQ '1'
     C                     MOVEL'0A0'     W@LOTN
     C                     END
      *
     C                     MOVE W@LOTN    POLOTN
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *----------------------------------------------------*
      *GET NEXT LOT# DATA FROM AFAPPN5                     *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVELWNSORT    #KSORT  6
     C                     MOVELWNLOTN    #KLOTN  3
      *
     C           KEYAF     KLIST
     C                     KFLD           #KSORT
     C                     KFLD           #KLOTN
      *
     C           KEYAF     SETLLAFAPLN51
     C           KEYAF     READEAFAPLN51                 80
     C           *IN80     IFEQ '0'
     C                     READ AFAPLN51                 81
     C                     MOVELWNLOTN    W@LOTN
     C                     ELSE
     C                     MOVEL'0A0'     W@LOTN
     C                     ENDIF
      *
     CSR         ESB100    ENDSR
