     C                     TIME           WTIME
     C           1         SETLLABMWP311
     C                     READ ABMWP311                 21
     C           *IN21     DOWEQ'0'
     C           @AKERR    IFEQ '*'
     C           @BKCD1    ANDEQ'C'
     C                     EXSR #SB200
     C                     ENDIF
     C                     READ ABMWP311                 21
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------*
      *メッキかんばん検索       *
      *---------------------------*
     CSR         #SB200    BEGSR
      *
     C           KEYA31    KLIST
     C                     KFLD           #K1HB5  5
     C                     KFLD           #K2HB5  5
     C                     KFLD           #K3HB2  2
      *
     C                     MOVEL@BJHN1    #K1HB5
     C                     MOVEL@BJHN2    #K2HB5
     C                     MOVEL@BJHN3    #K3HB2
     C           KEYA31    SETGTAAFTL061
     C           KEYA31    REDPEAAFTL061                 82
     C           *IN82     DOWEQ'0'
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLE*DATE
     C                     ELSE
     C           A3STHZ    IFEQ 99999999
     C                     Z-ADDWTIYY     A3KOYY
     C                     Z-ADDWTIMM     A3KOMM
     C                     Z-ADDWTIDD     A3KODD
     C                     Z-ADDWTITH     A3KOHH
     C                     Z-ADDWTITM     A3KOSS
     C                     MOVEL'ZIDOU'   A3KOME    P
     C                     EXSR #SB400
     C           WKSRYO    DIV  20        A3KSSU
     C                     UPDATAAFTL061
     C                     ENDIF
     C                     ENDIF
     C           KEYA31    REDPEAAFTL061                 82
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *---------------------------*
      * GHCPP21より設定数       *
      *---------------------------*
     CSR         #SB400    BEGSR
      *
     C                     SETOF                     99
     C           KEYMD1    KLIST
     C                     KFLD           #KMBN1  1
     C                     KFLD           #KMBN2  2
     C                     KFLD           #KMBN3  2
     C                     KFLD           #KMBN4  1
     C                     KFLD           #KMHN1  5
     C                     KFLD           #KMHN2  5
     C                     KFLD           #KMHN3  2
      *
     C                     MOVELA3ATK1    #KMBN1
     C                     MOVELA3ATK2    #KMBN2
     C                     MOVELA3ATK3    #KMBN3
     C                     MOVELA3ATK4    #KMBN4
     C                     MOVELA31HB5    #KMHN1
     C                     MOVELA32HB5    #KMHN2
     C                     MOVELA33HB2    #KMHN3
     C                     MOVEL'0'       FGET2   1
     C                     Z-ADD0         WKSRYO  90
     C           KEYMD1    SETLLGHCTL211
     C           KEYMD1    READEGHCTL211                 83
     C           *IN83     DOWEQ'0'
     C           FGET2     ANDEQ'0'
     C                     Z-ADDMDSRYO    WKSRYO
     C                     MOVEL'1'       FGET2
     C           KEYMD1    READEGHCTL211                 83
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
