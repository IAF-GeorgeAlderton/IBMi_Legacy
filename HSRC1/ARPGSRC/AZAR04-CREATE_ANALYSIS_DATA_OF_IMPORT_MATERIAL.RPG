     H            Y.
     F** AZAR04 **********************************************************
     F*  CREATE ANALYSIS DATA OF IMPORT MATERIAL                         *
     F*                                                                  *
     F*  TCH 2001.03.30                                                  *
     F*                                                                  *
     F*  *IN91=1(NOT READ IZAPL01:FINISHED MATERIAL MASTER)              *
     F*  *IN92=1(NOT READ GDLPL11:ORDER FILE,ORDER NUMBER+PART)          *
     F*  *IN93=1(NOT READ BTBPP41:ADJUSTMENT FILE)                       *
     F*  *IN94=1(NOT READ GKBNL22:MATERIAL RESULT)                       *
     F********************************************************************
     FIZAPL01 IF  E           K        DISK
     FGKBNL22 IF  E           K        DISK
     FBTBPP41 IF  E           K        DISK
     FGDLPL11 IF  E           K        DISK
     FAZAPP40 O   E                    DISK
     FAZAPP04 O   E                    DISK
     E********************************************************************
     E                    ODR        25  6 0             ORDER NUMBER
     E                    QTY        25  3 0             ORDER COIL
     I********************************************************************
     I* ORDER NUMBER(ORDER FILE : GDLPL11)
     I            DS
     I                                        1   60WKODR
     I                                        1   20LBODR1
     I                                        3   40LBODR2
     I                                        5   60LBODR3
     I* ORDER NUMBER(TABLE)
     I            DS
     I                                        1   60W#ODR
     I                                        1   20K12
     I                                        3   40K13
     I                                        5   60K14
     I* START ORDER NUMBER (DISPLAY)
     I            DS
     I                                        1   60WODRN
     I                                        1   20K32
     I                                        3   40K33
     I                                        5   60K34
     I* ACTUAL ORDERED QTY.(GDGPP15)
     I            DS
     I                                        1  750QTY
     I                                        1   30AZODR1
     I                                        4   60AZODR2
     I                                        7   90AZODR3
     I                                       10  120AZODR4
     I                                       13  150AZODR5
     I                                       16  180AZODR6
     I                                       19  210AZODR7
     I                                       22  240AZODR8
     I                                       25  270AZODR9
     I                                       28  300AZODRA
     I                                       31  330AZODRB
     I                                       34  360AZODRC
     I                                       37  390AZODRD
     I                                       40  420AZODRE
     I                                       43  450AZODRF
     I                                       46  480AZODRG
     I                                       49  510AZODRH
     I                                       52  540AZODRI
     I                                       55  570AZODRJ
     I                                       58  600AZODRK
     I                                       61  630AZODRL
     I                                       64  660AZODRM
     I                                       67  690AZODRN
     I                                       70  720AZODRO
     I                                       73  750AZODRP
     I********************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PUSR   10
     C                     PARM           PODRN   6
     C                     PARM           PFLAG   1
     C******************************************************************
     C* GDLPL11
     C           K1        KLIST
     C                     KFLD           K11              SUPPLIER
     C                     KFLD           K12              ORDER # 1
     C                     KFLD           K13                      2
     C                     KFLD           K14                      3
     C                     KFLD           ZCZAIS           WIRE
     C                     KFLD           ZCZAIK           DIAMETER
     C* BTBPP41
     C           K2        KLIST
     C                     KFLD           K11              SUPPLIER
     C                     KFLD           K22              RECIVING
     C                     KFLD           K21              PART CODE
     C                     KFLD           ZCZAIS           WIRE
     C                     KFLD           ZCZAIK           DIAMETER
     C* GDLPL11 (DISPLAY)
     C           K3        KLIST
     C                     KFLD           K11              SUPPLIER
     C                     KFLD           K32              ORDER # 1
     C                     KFLD           K33                      2
     C                     KFLD           K34                      3
     C* GDLPL11 (FILE)
     C           K4        KLIST
     C                     KFLD           LBSIRE           SUPPLIER
     C                     KFLD           LBODR1           ORDER # 1
     C                     KFLD           LBODR2                   2
     C                     KFLD           LBODR3                   3
     C                     KFLD           K41              ZAIS
     C                     KFLD           K42              ZAIK
     C* GKBNL22
     C           K5        KLIST
     C                     KFLD           ZCZAIS           WIRE
     C                     KFLD           ZCZAIK           DIAMETER
     C******************************************************************
     C                     MOVE PODRN     WODRN
     C                     MOVE *BLANK    PFLAG
     C                     Z-ADD*ZERO     I       20
     C                     Z-ADD*ZERO     WTOTL   50
     C                     Z-ADD*ZERO     ODR
     C                     Z-ADD*ZERO     QTY
     C                     Z-ADD*ZERO     W#KAN   52
     C                     Z-ADD*ZERO     W#AKAN  72
     C                     Z-ADD2         K11     40
     C                     MOVE 'W'       K21     1
     C                     Z-ADD111       K22     40
     C                     MOVE *HIVAL    K41    15
     C                     MOVE *HIVAL    K42     52
     C******************************************************************
     C* CREATE TABLE(ORDER NUMBER)
     C*
     C           K3        SETLLGDLPL111
     C                     READ GDLPL111                 90
     C           *IN90     DOWEQ'0'
     C*
     C                     ADD  1         I
     C                     Z-ADDWKODR     ODR,I
     C*
     C           K4        SETGTGDLPL111
     C                     READ GDLPL111                 90
     C                     END
     C*
     C******************************************************************
     C* CREATE WORK FILE
     C           *LOVAL    SETLLIZAPL011
     C                     READ IZAPL011                 91
B01  C           *IN91     DOWEQ'0'
     C*
B02  C           ZCSKJY    IFNE ' '
     C           ZCSTYY    ORNE 9999
     C           ZCKAKE    ORNE 2
     C           ZCTKJR    OREQ *ZERO
     C                     GOTO #READ
     C                     END
     C*
     C                     CLEARAZAPP041
     C*
     C* SET DATA FROM MASTER
     C                     MOVE ZCZAIS    AZZAIS           WIRE
     C                     MOVE ZCZAIK    AZZAIK           DIAMETER
     C                     MOVE ZCADR1    AZADR1           NEW LOC 1
     C                     MOVE ZCADR2    AZADR2                   2
     C                     MOVE ZCADR3    AZADR3                   3
     C                     MOVE ZCADR4    AZADR4                   4
     C                     Z-ADDZCTKJR    AZSYOS           WEIGHT/COIL
     C                     Z-ADDZCKMMX    AZCKAN           KANBAN MASTER
     C           ZCMKJR    DIV  20        AZDKAN           KAN/DAY MASTER
      *
     C* SET DATA FROM ORDER FILE
     C                     Z-ADD1         I
     C                     Z-ADD*ZERO     WTOTL
     C*
     C                     DO   25        I
     C                     MOVE ODR,I     W#ODR
     C           K1        CHAINGDLPL111             92
     C           *IN92     IFEQ '0'
     C           LBSKJY    ANDEQ' '
     C                     Z-ADDLBMAIS    QTY,I
     C*****                ADD  ICMAIS    WTOTL
     C*
     C                     ELSE
     C                     Z-ADD*ZERO     QTY,I
     C                     END
     C*
     C                     END
     C*****                Z-ADDWTOTL     AZOTOT
     C*
     C* SET DATA FROM BTBPP41(ADJUSTMENT)
     C           K2        SETLLBTBPP411
     C           K2        READEBTBPP411                 93
     C           *IN93     DOWEQ'0'
      *
     C           B4SKJY    IFEQ ' '
     C                     ADD  B4MAIS    AZADJS
     C                     END
      *
     C           K2        READEBTBPP411                 93
     C                     END
     C*
     C* SET DATA FROM GKBNL22(STATISTICS FILE)
     C                     Z-ADD*ZERO     WKBKAN
     C           K5        SETLLGKBNL221
     C           K5        READEGKBNL221                 94
     C           *IN94     DOWEQ'0'
      *
     C                     ADD  W1JRYO    WKBKAN  90
      *
     C           K5        READEGKBNL221                 94
     C                     END
     C*
     C* CAL. ACTUAL QTY. PAR DAY
     C           WKBKAN    DIV  20        AZBKAN
     C*
     C* CAL. ACTUAL # OF KANBAN PAR DAY
     C           AZBKAN    DIV  AZSYOS    W#KAN
     C           W#KAN     MULT ZCSLTM    W#AKAN
     C           W#AKAN    ADD  0.9       AZAKAN
     C                     Z-ADDZCSLTM    AZLTIM
     C*
     C* CAL. # OF KANBAN VARIANCE (BETWEEN ACT&MASTER)
     C****       AZAKAN    SUB  AZOTOT    AZACTQ
      *
     C                     WRITEAZAPP041
     C                     MOVE '1'       PFLAG
      *
     C           #READ     TAG
     C                     READ IZAPL011                 91
     C                     END
      *
     C*
     C******************************************************************
     C*
     C                     CLEARAZAPP401
     C                     MOVE ODR,1     AXODR1
     C                     MOVE ODR,2     AXODR2
     C                     MOVE ODR,3     AXODR3
     C                     MOVE ODR,4     AXODR4
     C                     MOVE ODR,5     AXODR5
     C                     MOVE ODR,6     AXODR6
     C                     MOVE ODR,7     AXODR7
     C                     MOVE ODR,8     AXODR8
     C                     MOVE ODR,9     AXODR9
     C                     MOVE ODR,10    AXODRA
     C                     MOVE ODR,11    AXODRB
     C                     MOVE ODR,12    AXODRC
     C                     MOVE ODR,13    AXODRD
     C                     MOVE ODR,14    AXODRE
     C                     MOVE ODR,15    AXODRF
     C                     MOVE ODR,16    AXODRG
     C                     MOVE ODR,17    AXODRH
     C                     MOVE ODR,18    AXODRI
     C                     MOVE ODR,19    AXODRJ
     C                     MOVE ODR,20    AXODRK
     C                     MOVE ODR,21    AXODRL
     C                     MOVE ODR,22    AXODRM
     C                     MOVE ODR,23    AXODRN
     C                     MOVE ODR,24    AXODRO
     C                     MOVE ODR,25    AXODRP
     C                     WRITEAZAPP401
     C******************************************************************
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
