     H            Y,
      *** EDIR31 ***********************************
      * USER CUSTOMER CODE DELLVERY CODE DOCK CODE *
      * TO IN-HOUSE CODE CONVERSION                *
      * CODING : K.OKACHI               98.02.10   *
      ************************************* EDIR31 *
     FEDIPW31 CF  E                    WORKSTN
     FEDIPL30 IF  E           K        DISK
     FEDIWP31 O   F     100            DISK                      A
      *
     E                    ER      1   3 60               ERROR MESSAGE
      *
     I            DS
     I                                        1   80E1SKHZ
     I                                        1   40E1SKYY
     I                                        5   60E1SKMM
     I                                        7   80E1SKDD
      *
     C                     MOVE *BLANK    FLG     1
     C           STEP1     TAG
     C                     EXFMTEDIPW311
     C                     SETOF                     010299
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
      *
     C           SIRE      IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STEP1
     C                     END
      *
     C           SIRE      IFNE 'ZZZZ'
     C           SKOJ      IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVE ER,2      MSG
     C                     GOTO STEP1
     C                     END
     C                     END
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STEP1
     C                     END
      *
     C           SIRE      IFEQ 'ZZZZ'
     C           *LOVAL    SETLLEDIPL301
     C                     DO   *HIVAL
     C                     SETOF                     50
     C                     READ EDIPL301                 50
     C           *IN50     IFEQ '1'
     C                     GOTO NDAT1
     C                     END
     C           *IN50     IFEQ '0'
     C           E1SKJY    IFEQ 'D'
     C           E1SKHZ    ANDLE*DATE
     C                     GOTO NDAT1
     C                     END
     C                     MOVE '*'       FLG
     C                     EXCPTDAT
     C                     END
     C           NDAT1     TAG
     C  N50                ENDDO
      *
     C                     ELSE
      *
     C           KEY1      KLIST
     C                     KFLD           SIRE
     C                     KFLD           SKOJ
      *
     C           KEY1      SETLLEDIPL301
     C                     DO   *HIVAL
     C                     SETOF                     50
     C           KEY1      READEEDIPL301                 50
     C           *IN50     IFEQ '1'
     C                     GOTO NDAT2
     C                     END
     C           *IN50     IFEQ '0'
     C           E1SKJY    IFEQ 'D'
     C           E1SKHZ    ANDLE*DATE
     C                     GOTO NDAT2
     C                     END
     C                     MOVE '*'       FLG
     C                     EXCPTDAT
     C                     END
     C           NDAT2     TAG
     C  N50                ENDDO
     C                     END
      *
     C           FLG       IFEQ *BLANK
     C                     SETON                     010299
     C                     MOVE ER,3      MSG
     C                     GOTO STEP1
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *
     OEDIWP31 EADD             DAT
     O                         E1SIRE     4
     O                         E1SKOJ     5
     O                         E1SUKE     9
     O                         E1TOKU    13
     O                         E1NONY    17
     O                         E1NKOJ    18
     O                         E1UKEI    22
** ER
E-01 INPUT SUPPLIER CODE
E-02 INPUT FACTORY CODE
E-03 THE PERTINENT DATA IS NOT FOUND.
