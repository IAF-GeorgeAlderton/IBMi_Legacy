     H            Y
     F********************************************
     F*UNWORKING NIGHT ATTENDANCE KANBAN MAKING CALCULATION HANDLING
     F********************************************
     FADAWL31 IP  F      32            DISK
     FAGDPL11 IF  E           K        DISK
     FAGAPL31 IF  E           K        DISK                           UC
     FADAWP32 O   F      32            DISK                      A
     IADAWL31 AA  01
     I                                        1   40NONU
     I                                        5   8 UKEI
     I                                        9  150SUU
     I                                       16  160BIN
     I                                       17  28 HIN   L1
     I                                       17  21 HIN1
     I                                       22  26 HIN2
     I                                       27  28 HIN3
     C**************************
     C*  初期値セット        *
     C**************************
     C           *ENTRY    PLIST
     C                     PARM           PARM1   1        *区分
     C                     PARM           PARM2   8        *日付１
     C                     PARM           PARM3   8        *日付２
     C                     PARM           PARM4   1        *保管
     C                     PARM           PARM5   1        *方式
     C                     PARM           PARM6   6        *番地
     C                     PARM           PARM7   8        *Ｓ日付
     C                     PARM           PARM8   8        *Ｅ日付
     C                     PARM           PARM9   1        *前夜勤区
     C                     PARM           PARM10  6        *年月
     C                     PARM           PARM11  1        *旬
     C**************************
     C* 合成キー             *
     C**************************
     C           #KEY1     KLIST
     C                     KFLD           #YY     40
     C                     KFLD           #MM     20
     C                     KFLD           #DD     20
     C           #KEY2     KLIST
     C                     KFLD           #HIN1   5
     C                     KFLD           #HIN2   5
     C                     KFLD           #HIN3   2
     C*************************
     C*  メイン処理        *
     C*************************
     C           *IN10     IFEQ '0'
     C           PARM5     IFEQ 'E'
     C           OPNSW     ANDEQ*BLANK
     C                     OPEN AGAPL31
     C                     MOVE '*'       OPNSW   1
     C                     END
     C                     EXSR $SB900
     C                     SETON                       10
     C                     END
     C                     ADD  SUU       GKEI    70
     CL1         X         IFNE *ZERO
     CL1         GKEI      DIV  X         ANSWR   70H
     CL1                   END
     CL1         ANSWR     IFNE 0
     CL1                   SETON                     20
      * 93.05.8
     CL1         PARM5     IFEQ 'E'
     CL1                   SETOF                     208521
     CL1                   MOVE HIN1      #HIN1
     CL1                   MOVE HIN2      #HIN2
     CL1                   MOVE HIN3      #HIN3
     CL1         #KEY2     CHAINAGAPL311             85
     CL1         *IN85     IFEQ '0'
     CL1         CBSKJY    ANDEQ'D'
     CL1         CBSKHZ    ANDLE*DATE
     CL1                   SETON                     85
     CL1                   SETOF                     20
     CL1                   END
     CL1         *IN85     IFEQ '0'
     CL1         CBBARL    IFEQ *ZERO
     CL1                   Z-ADD1         CBBARL
     CL1                   END
     CL1         CBBARL    MULT CBSYUY    WKSRYO  70
     CL1         CBSYUY    MULT 2         BRSRYO  70
     CL1         ANSWR     DIV  2         HANSU   70
     CL1         HANSU     IFGE BRSRYO
     CL1         HANSU     ANDGEWKSRYO
     CL1                   SETON                     20
     CL1                   END
     CL1                   END
     CL1                   END
      *
     CL1         *IN20     IFEQ '1'
     CL1                   MOVE NONU      ONONU   40
     CL1                   MOVE UKEI      OUKEI   4
     CL1                   MOVE ANSWR     OSUU    70
     CL1                   MOVE BIN       OBIN    10
     CL1                   MOVE HIN       OHIN   12
     CL1                   EXCPTFILE
     CL1                   END
     CL1                   MOVE *ZERO     ONONU
     CL1                   MOVE *ZERO     OUKEI
     CL1                   MOVE *ZERO     OSUU
     CL1                   MOVE *ZERO     OBIN
     CL1                   MOVE *ZERO     OHIN
     CL1                   MOVE *ZERO     GKEI
     CL1                   END
     C*************************
     C*  カレンダーＦ処理   *
     C*************************
     CSR         $SB900    BEGSR
     C                     Z-ADD0         X       20
     C           PARM5     IFEQ 'A'
     C           PARM5     OREQ 'B'
     C           PARM5     OREQ 'E'
     C                     MOVE PARM7     WSYMD   80
     C                     MOVE PARM8     WEYMD   80
     C                     ELSE
     C                     MOVE PARM10    WYM     60
     C                     MOVE PARM11    WHI     10
     C                     MOVELWYM       WEYMD
     C                     MOVELWYM       WSYMD
     C           WHI       IFEQ 1
     C                     MOVE 01        WSYMD
     C                     MOVE 10        WEYMD
     C                     ELSE
     C           WHI       IFEQ 2
     C                     MOVE 11        WSYMD
     C                     MOVE 20        WEYMD
     C                     ELSE
     C                     MOVE 21        WSYMD
     C                     MOVE 31        WEYMD
     C                     END
     C                     END
     C                     END
     C                     MOVE WSYMD     WWMD    40
     C                     MOVELWSYMD     #YY
     C                     MOVELWWMD      #MM
     C                     MOVE WSYMD     #DD
     C                     MOVE *ZERO     GKEI
     C           #KEY1     SETLLAGDPL111
     C           *IN31     DOWEQ'0'
     C                     READ AGDPL111                 31
     C           *IN31     CABEQ'1'       $S900E
     C                     MOVELF8KAYY    F8HYM   60
     C                     MOVE F8KAMM    F8HYM
     C                     MOVE F8KADD    F8KAHZ  80
     C                     MOVELF8HYM     F8KAHZ
     C           F8KAHZ    IFLE WEYMD
     C                     ADD  1         X
     C                     ELSE
     C                     GOTO $S900E
     C                     END
     C                     END
     C           $S900E    TAG
     C                     SETON                       10
     CSR                   ENDSR
     **
     OADAWP32 EADD             FILE
     O                         ONONU      4
     O                         OUKEI      8
     O                         OSUU      15
     O                         OBIN      16
     O                         OHIN      28
