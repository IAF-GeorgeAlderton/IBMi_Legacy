TCHK2C                     MOVELW@MHIN    K@PART
TCHK2C                     MOVELF9DOCK    K@DOCK
TCHK2C           K#ABF     SETGTABF2L03
TCHK2C           K#ABF     REDPEABF2L03                  96
TCHK2C           *IN96     IFEQ *OFF
TCHK2C                     MOVELAFALFL    F7LNFD
TCHK2C                     MOVELAFRALF    F7STAD
TCHK2C                     END
