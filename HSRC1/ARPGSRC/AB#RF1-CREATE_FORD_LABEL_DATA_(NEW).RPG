     C                     Z-ADDFCSHDT    @@SHDT
     C                     MOVE FC#PLT    F7PLT#
     C           @@KEY     LOKUPPLT                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         Y
     C                     MOVE @@KEY     PLT,Y
     C                     ENDIF
      *
     C****                 WRITEABF7P021
     C                     END
      *
     C           @MIX      IFEQ '1'
     C                     EXSR #MIX
     C                     ENDIF
      *
     C                     MOVE 'P'       FCPRNT           PRINT FLAG
     C                     UPDATABF6P011
     C                     END
     C*
TCHK7C           @UPD00    TAG
TCHK7C*
     C           KEY2      READEABF6P011                 90
     C                     ENDDO
     C                     ENDIF
      *
     C***************************
     C* PROCESS FOR 1 DELIVERY# *
     C***************************
      **                   ELSE
JW4  C           #DELY     IFNE '9999'
     C           #GRP      ANDEQ*BLANK
      *
     C           KEY1      CHAINABF6P011             91
      *
JW   C                     MOVELFCPRNT    SVPRNT
      *
     C           *IN91     DOWEQ*OFF
     C           FCSKJY    IFNE 'D'
     C           FCPRNT    ANDNE'P'                        AVOID DOUBLE PRINT
     C                     CLEARAB#PP701
      *
     C           FCDELY    IFNE @@DLY
     C           FCDELY    IFNE 5156
     C           FCDELY    ANDNE5148
     C           FCDELY    ANDNE5151
     C           FCDELY    ANDNE5172
     C           FCDELY    ANDNE5191
     C           FCDELY    ANDNE5196
     C           FCDELY    ANDNE5197
     C                     MOVE '1'       @MIX    1
     C                     ELSE
     C                     MOVE *BLANK    @MIX
     C                     ENDIF
     C                     ELSE
     C                     MOVE *BLANK    @MIX
     C                     ENDIF
     C                     Z-ADDFCDELY    @@DLY
      *
     C                     EXSR #ADR
     C                     EXSR #MOVE1
     C           FCPBCD    IFEQ 'S'                        CONTAINER LABEL
     C           FCSERL    IFEQ *BLANK
     C                     EXSR #NMBR
     C                     MOVE N3NMBR    F7SERL
     C                     MOVE N3NMBR    FCSERL
     C                     EXSR #PP70                      #2
     C                     ELSE
     C                     MOVE FCSERL    F7SERL
     C                     ENDIF
      *
TCHK C                     WRITEABF7P011
     C                     WRITEABF7P011
JW5  C                     Z-ADD12        SER3F
     C                     MOVEL'ABF7P01' IXWRKF           LABEL WF
 .   C                     EXSR #XP01                      =>AB#XP01 #1-2
     C                     END
      *
     C           FCPBCD    IFEQ 'M'                        MASTER LABEL
     C                     MOVE FC#PLT    F7PLT#
     C                     MOVE *BLANK    F7SERL
     C***                  WRITEABF7P021
      *
     C                     Z-ADDFCSHDT    @@SHDT
     C           @@KEY     LOKUPPLT                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         Y
     C                     MOVE @@KEY     PLT,Y
     C                     ENDIF
     C                     END
      *
     C           @MIX      IFEQ '1'
     C                     EXSR #MIX
     C                     ENDIF
      *
     C                     MOVE 'P'       FCPRNT           PRINT FLAG
     C                     UPDATABF6P011
     C                     END
     C*
     C           KEY1      READEABF6P011                 91
     C                     ENDDO
      *
     C                     ENDIF
      *
     C                     EXSR #PP2
      *
     C                     ENDSR
      *-------------------------------------------------
      * RETRIEVE ADDRESSES
      *-------------------------------------------------
     C           #ADR      BEGSR
      *
TCHK2C           FCDELY    CHAINGADPL13              95
TCHK2C           *IN95     IFEQ *OFF
     C                     MOVELB5KMEI    F7NAME    P
     C           'FORD'    SCAN B5KMEI                   10
     C           *IN10     IFEQ *OFF
     C           'FORD'    CAT  B5KMEI:1  F7NAME    P
     C                     ENDIF
TCHK2C                     END
      * ADDED BY JW
JW1  C           KEY9      CHAINGADPL13              95
JW1  C           *IN95     IFEQ *OFF
JW1  C                     MOVELB5KMEI    F7NAME    P
JW1  C           'FORD'    SCAN B5KMEI                   10
JW1  C           *IN10     IFEQ *OFF
JW1  C           'FORD'    CAT  B5KMEI:1  F7NAME    P
JW1  C                     ENDIF
JW1  C                     ENDIF
      *
     C                     MOVE FCDELY    WDELY
     C           KEY3      CHAINABF9P011             95
   B1C           *IN95     IFEQ '0'
     C                     MOVELF9ADD1    F7ADD1
     C                     MOVELF9ADD2    F7ADD2
     C                     MOVELF9DOCK    F7CUST
   E1C                     END
      *
      *** get container type to include in 2D barcode.
     C           F7CUST    IFNE *BLANK
     C                     CALL 'AB#RYZ'
     C                     PARM           F7CUST
     C                     PARM           F7CONT
     C                     ENDIF
      *
      *** check european label flag in EDI address file to determine
      *   foreign or domestic.  domestic=blank, foreign='Y'
     C                     MOVELFCDELY    DLVCD   4
     C           DLVCD     CHAINEDIPP42              95
     C           *IN95     IFEQ *OFF
     C           E4SKJY    ANDEQ*BLANK
     C           E4FLG2    IFEQ 'Y'                        EUROPEAN LABL FLAG
     C                     MOVE 'F'       FORD    1           FOREIGN
     C                     ELSE
     C                     MOVE 'D'       FORD                DOMESTIC
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*  #MOVE1 SUBROUTINE: MOVE DATA FROM DBFILES TO FILE ABF8P01
     C**************************************************************************
     C           #MOVE1    BEGSR
     C*
     C                     MOVE FCDELY    F7NONY
     C                     MOVE '*'       @DATA   1
      *
JW3  C                     MOVELFCCPAR    LTR1    1
 .   C           LTR1      IFEQ *BLANK
 .   C                     MOVE FCCPAR    LTR19  19
 .   C                     MOVELLTR19     FCCPAR    P
JW3  C                     ENDIF
      *
     C                     MOVELFCCPAR    F7PBAR
      *
     C                     MOVEAFCCPAR    PNO
     C                     MOVE *BLANK    NOB
     C                     Z-ADD1         X       20
     C           1         DO   20        M
     C           PNO,M     IFEQ *BLANK
     C           M         ADD  1         P
TCHK6C           P         IFGT 20
TCHK6C                     ITER
TCHK6C                     END
     C           PNO,P     IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
     C           M         IFNE 1
     C                     MOVE '-'       NOB,X
     C                     ADD  1         X
     C                     END
     C                     ELSE
     C                     MOVE PNO,M     NOB,X
     C                     ADD  1         X
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEANOB       F7PART
     C*
     C* FIND THE FIRST BLANK BEFORE THE SUFIX PART NUMBER
     C                     Z-ADD20        M       20
     C                     MOVEAFCCPAR    PNO
     C           PNO,M     DOUNE*BLANK
     C                     SUB  1         M
     C                     END
     C*
     C           PNO,M     DOUEQ*BLANK
     C                     SUB  1         M
     C                     END
     C*
     C                     Z-ADD*ZERO     W       20
     C                     MOVE *BLANK    NOB
     C           M         SUB  1         P       20
     C           1         DO   P         W
     C                     MOVE PNO,W     NOB,W
     C                     END
     C                     MOVEANOB       F7BASE
     C*
     C                     Z-ADD*ZERO     W       20
     C                     Z-ADD1         T       20
     C                     MOVE *BLANK    NOA
     C           M         ADD  1         P       20
     C           P         DO   20        W
     C                     MOVE PNO,W     NOA,T
     C           T         IFEQ 4
     C           T         ADD  1         TT      20
     C           PNO,TT    IFNE *BLANK
     C                     ADD  1         T
     C                     ENDIF
     C                     ENDIF
     C                     ADD  1         T
     C                     END
     C                     MOVEANOA       F7SUFX
     C*
%0001C                     Z-ADDFCRQTY    P11
%0001C                     MOVE *BLANK    P12
%0001C                     CALL 'AB#R2K'  P1
%0001C                     MOVELP12       WWRQTY 15
%0001C                     Z-ADDFCUQTY    P11
%0001C                     MOVE *BLANK    P12
%0001C                     CALL 'AB#R2K'  P1
%0001C                     MOVELP12       WWUQTY 15
     C                     SELEC
   B1C           FCPBCD    WHEQ 'M'                        MASTER LABEL
%0001C                     MOVELWWRQTY    F7QTY
%0001C                     MOVELLBL,1     F7LABL
   B1C           FCPBCD    WHEQ 'S'                        CONTAINER LABEL
%0001C                     MOVELWWUQTY    F7QTY
%0001C                     MOVEL*BLANK    F7LABL
   E1C                     ENDSL
      *
%0001C                     MOVEL*BLANK    F7LNFD
%0001C                     MOVEL'0'       WNKOJ   1
%0001C                     MOVE FCSHTM    WSHTM   20
%0001C                     SETOF                     20
%0001C           KEY8      SETLLAB#PL141
     C           *IN20     DOUEQ*ON
%0001C           KEY8      READEAB#PL141                 20
%0001C           *IN20     IFEQ '0'
%0001C           BASKJY    ANDEQ*BLANK
%0001C                     MOVELBAALFL    F7LNFD
     C*                    MOVELBASHIN    F7IPAR
     C*
     C                     MOVEL*BLANK    ##SHIN
     C                     MOVEL*BLANK    @@SHIN
     C                     MOVEL'-'       @@HAIF
     C                     MOVELBASHIN    ##SHIN
     C                     MOVEL##SHI1    @@SHI1
     C                     MOVEL##SHI2    @@SHI2
     C                     MOVEL@@SHIN    F7IPAR
     C*
     C                     MOVELBARESE    F7STAD
TCHK2C                     EXSR #MOVS1
     C                     MOVE BANONY    EKNONY
     C                     MOVE BANKOJ    EKNKOJ
     C                     MOVE BANUKE    EKNUKE
     C                     MOVE BASYOS    EKSYOS
     C                     MOVE BAODRN    EKODRN
      ** RECORD NUMBER
     C                     Z-ADDBATOKU    EKTOKU
     C                     MOVELBAMHN1    EKMHN1
     C                     MOVELBAMHN2    EKMHN2
     C                     MOVELBAMHN3    EKMHN3
     C                     MOVELBAMHN4    EKMHN4
     C                     MOVE BANOBN    EKNOBN
     C                     Z-ADDBADEYY    EKRLYY
     C                     Z-ADDBADEMM    EKRLMM
     C                     Z-ADDBADEDD    EKRLDD
     C                     LEAVE
%0001C                     ENDIF
%0001C                     ENDDO
     C                     MOVELFCSEQ#    F7SEQ#
     C                     MOVE FCSHYY    F7XY
     C                     MOVE FCSHDD    F7XD
     C                     Z-ADDFCSHMM    P
     C                     MOVE MON,P     F7XM
     C                     MOVE *BLANK    WDELY   4
     C                     MOVE FCDOCK    F7DOCK           DOCK CODE
     C                     MOVEL*BLANK    F7LOC
      *
     C           KEY4      CHAINFCEPL011             15
   B1C           *IN15     IFEQ '0'
   B2C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ELSE
     C                     Z-ADDA2KASI    @@WGHT  72
     C                     MOVELA2SMEI    F7DESC
     C                     MOVE A2ZETI    EKZETI
%0001C                     Z-ADDA2SSYS    P11
%0001C                     MOVE *BLANK    P12
%0001C                     CALL 'AB#R2K'  P1
%0001C                     MOVELP12       F7SPQY
TCHK5C*          A2TRHZ    IFLE *DATE
TCHK5C           A2TRHZ    IFLE BANOHZ
     C                     MOVELA2STKR    F7LOC
     C                     ELSE
     C                     MOVELA2KTKR    F7LOC
   E3C                     END
 | E2C                     END
 TTE1C                     END
      *
     C                     SELEC
   B1C           FCPBCD    WHEQ 'M'                        MASTER LABEL
     C           FCRQTY    MULT @@WGHT    @TWGHT 112
   B1C           FCPBCD    WHEQ 'S'                        CONTAINER LABEL
     C           FCUQTY    MULT @@WGHT    @TWGHT 112
     C                     ENDSL
      *
     C           @TWGHT    DIV  1000      @TWGHT
IH   C           @TWGHT    MULT 2.2046    @@LIB  112H
     C                     SELEC
   B1C           FCPBCD    WHEQ 'M'                        MASTER LABEL
     C           A2SSYS    IFNE *ZERO
     C           FCRQTY    DIV  A2SSYS    P
     C                     ELSE
     C                     Z-ADD1         P
     C                     ENDIF
     C           0.7       MULT P         @BOX   112
     C           @@LIB     ADD  @BOX      @@LIB
   B1C           FCPBCD    WHEQ 'S'                        CONTAINER LABEL
     C                     ADD  0.7       @@LIB
     C                     ENDSL
      *
     C           @@LIB     MULT 1         @LWGHT  90H
%0001C                     Z-ADD@LWGHT    P11
%0001C                     MOVE *BLANK    P12
%0001C                     CALL 'AB#R2K'  P1
%0001C                     MOVELP12       F7GWEH
      *
      *
     C           K#4P      CHAINABF4P01              95
     C           *IN95     IFEQ *OFF
     C                     Z-ADDYBPS#     @@ASN   60
     C                     ELSE
     C                     Z-ADD*ZERO     @@ASN
     C                     ENDIF
      *
     C                     MOVEL'AVRTA'   F7SUPL
      * 2D
     C                     MOVE *BLANK    @DX7
     C           'P'       CAT  F7PBAR:0  @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
     C           @DX7      CAT  'Q':0     @DX7      P
     C           @DX7      CAT  F7QTY:0   @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
     C           @DX7      CAT  'V':0     @DX7      P
     C           @DX7      CAT  F7SUPL:0  @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
     C           @DX7      CAT  'Z':0     @DX7      P      DATA IDENTIFIER
     C           @DX7      CAT  F7GWEH:0  @DX7      P       GROSS WEIGHT
     C           @DX7      CAT  @HX6:0    @DX7      P      GROUP SEPARATOR
     C           @DX7      CAT  'D':0     @DX7      P
     C                     MOVE FCSHDT    @6      6
     C           @DX7      CAT  @6:0      @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
   B1C           FCPBCD    IFEQ 'M'                        MASTER LABEL
     C           @DX7      CAT  'M':0     @DX7      P
     C                     ELSE
     C           @DX7      CAT  'S':0     @DX7      P      CONTAINER LABEL
     C                     ENDIF
     C           @DX7      CAT  F7SEQ#:0  @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
      *
     C           F7CONT    IFNE *BLANKS
     C           @DX7      CAT  'B':0     @DX7      P      DATA IDENTIFIER
     C           @DX7      CAT  F7CONT:0  @DX7      P       CONTAINER TYPE
     C           @DX7      CAT  @HX6:0    @DX7      P      GROUP SEPARATOR
     C                     ENDIF
      *
     C           F7STAD    IFNE *BLANK
     C           @DX7      CAT  'L':0     @DX7      P
     C           @DX7      CAT  F7STAD:0  @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
     C                     ENDIF
      *
     C           FORD      IFEQ 'D'                        DOMESTIC cust label
     C           @DX7      CAT  '20L':0   @DX7      P
     C           @DX7      CAT  F7LNFD:0  @DX7      P
     C           @DX7      CAT  @HX6:0    @DX7      P
     C                     ELSE
     C           FORD      IFEQ 'F'                        FOREIGN cust label
     C           @@ASN     ANDNE*ZERO
     C                     MOVEL@@ASN     F7LNFD           ... for 2D barcode
     C           @DX7      CAT  'N':0     @DX7      P      DATA IDENTIFIER
     C           @DX7      CAT  F7LNFD:0  @DX7      P       ASN NUMBER
     C           @DX7      CAT  @HX6:0    @DX7      P      GROUP SEPARATOR
     C           'ASN'     CAT  F7LNFD:0  F7LNFD    P      ...for field itself
     C                     ENDIF
     C                     ENDIF
      *
     C           F7CUST    IFNE *BLANKS
     C           @DX7      CAT  '8V':0    @DX7      P      DATA IDENTIFIER
     C           @DX7      CAT  F7CUST:0  @DX7      P       CUST PLANT CODE
     C           @DX7      CAT  @HX6:0    @DX7      P      GROUP SEPARATOR
     C                     ENDIF
      *
     C           @DX7      CAT  '1L':0    @DX7      P
     C           @DX7      CAT  F7DOCK:0  @DX7      P
     C           @DX7      CAT  @HX4:0    @DX7      P
     C           @DX7      CAT  @HX7:0    @DX7      P
     C                     MOVEL@DX       F72DBD    P
      *
     C                     ENDSR
TCHK2C*-------------------------------------------------------------------------
TCHK2C           #MOVS1    BEGSR
TCHK2C*
TCHK2C                     DO
TCHK2C*
