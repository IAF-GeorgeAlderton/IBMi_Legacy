TCHK2C                     KFLD           BANOMM
TCHK2C                     KFLD           BANODD
TCHK2C                     KFLD           BANOBN
TCHK2C                     KFLD           BATOKU
TCHK2C                     KFLD           BANONY
TCHK2C                     KFLD           BANKOJ
TCHK2C                     KFLD           BANUKE
TCHK2C                     KFLD           K@SIRE  6
TCHK2C                     KFLD           K@SIRK  2
TCHK2C                     KFLD           BAMHN1
TCHK2C                     KFLD           BAMHN2
TCHK2C                     KFLD           BAMHN3
TCHK2C                     KFLD           BAMHN4
TCHK2C                     KFLD           BAODRN
      *
