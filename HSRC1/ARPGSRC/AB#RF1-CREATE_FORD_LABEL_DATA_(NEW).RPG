     C                     EXSR #CHK1
      *
     C           *INKH     IFEQ *ON
     C           *IN60     ANDEQ*OFF
     C                     EXSR #UPD2
%0001C           @DATA     IFEQ ' '
%0001C                     SETON                     60
%0001C                     MOVELERR,8     XMSG
%0001C                     MOVEL*BLANK    @DATA
