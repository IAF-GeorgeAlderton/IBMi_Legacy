     H            Y.
     F** ABMRA1 *********************************************
     F*内示数異常リスト
     F*    HOTTA.               2018.08.27                  *
     F*******************************************************
     FABMPL21 IF  E           K        DISK
      *
     I            DS
     I                                        1   80W@DATE
     I                                        1   40W@DAYY
     I                                        5   60W@DAMM
     I                                        7   80W@DADD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
      *
     I            DS
     I                                        1   8 CTIHZ
     I                                        1   2 CTIMM
     I                                        3   4 CTIDD
     I                                        5   8 CTIYY
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
     I              'FORECAST FAULT'      C         FNAM1
     I              'FORECAST FAULT(ALL)' C         FNAM2
      *
     C           *ENTRY    PLIST
     C                     PARM           P@DTYM  60
     C                     PARM           P@PP01  1
     C                     PARM           P@FNAM 30
      *
     C                     TIME           WTIME
      *
     C                     MOVE WTIMM     CTIMM
     C                     MOVE WTIDD     CTIDD
     C                     MOVE WTIYY     CTIYY
     C                     MOVEL*BLANK    P@FNAM
     C                     SELEC
     C           P@PP01    WHEQ '1'
     C                     MOVELFNAM1     P@FNAM
     C****       FNAM1     CAT  CTIHZ:1   P@FNAM
     C                     OTHER
     C                     MOVELFNAM2     P@FNAM
     C****       FNAM2     CAT  CTIHZ:1   P@FNAM
     C                     ENDSL
      *
     C           KEY11     KLIST
     C                     KFLD           K@DTYM  60
     C                     Z-ADDP@DTYM    K@DTYM
     C           KEY11     SETLLABMPL211
     C           KEY11     READEABMPL211                 87
     C           *IN87     DOWEQ'0'
     C           S4SKJY    IFEQ 'D'
     C           S4SKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #SB400
     C                     ENDIF
     C           KEY11     READEABMPL211                 87
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------*
      *                                                  *
      *--------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEL'0'       TAISYO  1
     C                     SELEC
      *日当り１箱未満 300%  30%
     C           S4BOXD    WHLT 1
     C           S4BOXP    IFGT 3.00
     C           S4BOXP    ORLT 0.30
     C                     MOVEL'1'       TAISYO
     C                     ENDIF
      *日当り１箱以上　４箱未満 150%  50%
     C           S4BOXD    WHLT 1
     C           S4BOXP    IFGT 1.50
     C           S4BOXP    ORLT 0.50
     C                     MOVEL'1'       TAISYO
     C                     ENDIF
      *日当り４箱以上 125%  25%
     C           S4BOXD    WHLT 1
     C           S4BOXP    IFGT 1.25
     C           S4BOXP    ORLT 0.75
     C                     MOVEL'1'       TAISYO
     C                     ENDIF
      *
     C                     ENDSL
      *
     C           TAISYO    IFEQ '1'
     C                     CALL 'ABMRA2'
     C                     PARM           S4NTYM  60
     C                     PARM           S4SHN1  5
     C                     PARM           S4SHN2  5
     C                     PARM           S4SHN3  2
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
