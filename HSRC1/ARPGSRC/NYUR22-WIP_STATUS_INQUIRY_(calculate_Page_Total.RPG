     H            Y.
     F**************************************************************************
     F*  PROGRAM    : NYUR22 (CALCULATE PAGE TOTAL    )                        *
     F*  WRITTEN    : 10/27/2015                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F*  FUNCTION   :                                                          *
     F**************************************************************************
     FNZUPL02 IF  E           K        DISK
     F**************************************************************************
     I            DS
     I                                        1   80$DATE
     I                                        1   4 @HAYY
     I                                        5   6 @HAMM
     I                                        7   8 @HADD
      *----------------------------------------------------*
      *                    MAIN ROUTINE                    *
      *----------------------------------------------------*
      *
     C                     EXSR @INIT
      * SET KEY
     C                     MOVEL$HIN1     K2SHN1
     C                     MOVEL$HIN2     K2SHN2
     C                     MOVEL$HIN3     K2SHN3
     C                     MOVEL$DATE     K2HAHZ
     C                     MOVEL$HABB     K2HABB
     C                     MOVEL$TEHI     K2TEHI
     C                     SETOF                     8166
     C           KEYN11    SETLLNZUPL02
     C           *IN81     DOWEQ'0'
     C           KEYN11    READENZUPL02                  81
     C           *IN81     IFEQ '0'
     C                     MOVELN2PAGN    $PAGE
     C                     ENDIF
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           @INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $HIN1   5
     C                     PARM           $HIN2   5
     C                     PARM           $HIN3   2
     C                     PARM           $HAYY   4
     C                     PARM           $HAMM   2
     C                     PARM           $HADD   2
     C                     PARM           $HABB   2
     C                     PARM           $TEHI   3
     C                     PARM           $PAGE   2
      * KEY LIST
     C           KEYN11    KLIST
     C                     KFLD           K2SHN1  5
     C                     KFLD           K2SHN2  5
     C                     KFLD           K2SHN3  2
     C                     KFLD           K2HAHZ  80
     C                     KFLD           K2HABB  20
     C                     KFLD           K2TEHI  3
      *
     C                     MOVE *BLANK    $PAGE
     C                     MOVEL$HAYY     @HAYY
     C                     MOVEL$HAMM     @HAMM
     C                     MOVEL$HADD     @HADD
      *
     C           EINIT     ENDSR
