      ** ABHR30 *******************************************************
      * INTRA-PROCESS KANBAN ISSUE LOG FILE
      *  KIRI                                                2018.08.02
      *****************************************************************
     FABHPW30 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFREC1
     F                                              KINFDS INFDS
      *
      * INTRA-PROCESS KANBAN ISSUE LOG FILE                    *
     FABHPLC2 IF  E           K        DISK
      *
      * S/38 PASSWORD M/F LOGICAL FILE KEY=PROFILE < LF > *
     FRGAPL11 IF  E           K        DISK
      *===============================================================
     E                    ER      1  10 60
      *===============================================================
     IINFDS       DS
     I                                    B 378 3790$$RRN
     I****************************
      *プログラム状況データ構造*
     I****************************
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *
      * ISSUE DATE TIME START
     I            DS
     I                                        1  120D1STAR
     I                                        1   80D1DAT1
     I                                        9  120D1TIM1
      * ISSUE DATE TIME END
     I            DS
     I                                        1  120D1END
     I                                        1   80D1DAT2
     I                                        9  120D1TIM2
      *
      *--------------------------------------------
      * ISSUE DATE-TIME
     I            DS
     I                                        1  120A2KOHT
     I                                        1   80A2KODT
     I                                        9  140A2KOTM
      *
      * MATERIAL BARCODE 1,2
     I            DS
     I                                        1   8 J1ZBR1
     I                                        1   7 J$ZBR1
     I            DS
     I                                        1   8 J1ZBR2
     I                                        1   7 J$ZBR2
      *--------------------------------------------
     I            DS
     I                                        1   5 D2LOC
     I                                        1   2 D1LOC2
     I                                        3   3 D2LHF
     I                                        4   5 D1LOC3
      *
     I            DS
     I                                        1  14 D2HIN
     I                                        1   5 D1HIN1
     I                                        6   6 D2HF1
     I                                        7  11 D1HIN2
     I                                       12  12 D2HF2
     I                                       13  14 D1HIN3
      *
      *
     I            DS
     I                                        1  14 S1HIN
     I                                        1   5 A2HIN1
     I                                        6   6 $SHF1
     I                                        7  11 A2HIN2
     I                                       12  12 $SHF2
     I                                       13  14 A2HIN3
      *
     I            DS
     I                                        3   7 S1LOC
     I                                        1   1 A2LOC1
     I                                        2   2 $BHF1
     I                                        3   4 A2LOC2
     I                                        5   5 $BHF2
     I                                        6   7 A2LOC3
     I                                        8   8 $BHF3
     I                                        9   9 A2LOC4
      *
     I            DS
     I                                        1  10 S1PAG#
     I                                        1   3 S1PAGF
     I                                        4   7 $PAG1
     I                                        8  10 S1PAGT
      *
     I              '0123456789'          C         DIGITS
     I              'A = PRODUCTION    '  C         $KKA
     I              'B = HEAT TREATMENT'  C         $KKB
     I              '  = ALL           '  C         $KK
     I              '1 = REISSUE  '       C         $PK1
     I              '2 = TEMPORARY'       C         $PK2
     I              '  = ALL      '       C         $PK
     C*===============================================================
     C*
      *===============================================================
      *  START  PROGRAM
      *===============================================================
     C                     MOVE '#INIT   '@STEP   8
      *
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C                     ENDCS
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      * 初期ﾈｮmb
      *===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     TIME           @TIME
      *
     C                     CLEARDSP01
     C                     MOVE '#DSP1   '@STEP
      *
     C                     ENDSR
      *===============================================================
      *  指示画面
      *===============================================================
     C           #DSP1     BEGSR
      *
     C                     EXFMTDSP01
     C                     SETOF                     99
     C                     MOVEA'00000000'*IN,21           21-28
     C                     MOVEA'00000000'*IN,29           29-36
     C                     MOVE *BLANK    D1ERR
      *
     C                     SELEC
     C* < F1 >
     C           *INKA     WHEQ *ON
     C                     MOVE '#END    '@STEP
     C* <    >
     C                     OTHER
     C                     MOVE '#CHK1   '@STEP
     C                     ENDSL
      *
     C                     ENDSR
      *===============================================================
      *  指示画面チェック
      *===============================================================
     C           #CHK1     BEGSR
      *
      * ISSUE DATE TIME (21 22 23 24)
      *
     C           D1DAT1    IFEQ 0
     C                     SETON                     2199
     C                     MOVELER,1      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C*
     C                     MOVELD1DAT1    P$DATE
     C                     CALL 'DATR10'
     C                     PARM           P$DATE  8
     C                     PARM           P$RTN   1
     C*PRTN='1':NG
     C           P$RTN     IFEQ '1'
     C                     SETON                     2199
     C                     MOVELER,2      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
      *
     C           D1DAT2    IFEQ 0
     C                     SETON                     2399
     C                     MOVELER,1      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C*
     C                     MOVELD1DAT2    P$DATE
     C                     CALL 'DATR10'
     C                     PARM           P$DATE  8
     C                     PARM           P$RTN   1
     C*PRTN='1':NG
     C           P$RTN     IFEQ '1'
     C                     SETON                     2399
     C                     MOVELER,2      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
     C*
     C           D1STAR    IFGT D1END
     C                     SETON                     212223
     C                     SETON                     2499
     C                     MOVELER,3      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDIF
      *
      * KANBAN KIND (25)
      *
     C                     SELEC
     C           D1KIND    WHEQ ' '
     C***                  MOVEL$KK       D2KIND
     C           D1KIND    WHEQ 'A'
     C***                  MOVEL$KKA      D2KIND
     C           D1KIND    WHEQ 'B'
     C***                  MOVEL$KKB      D2KIND
     C                     OTHER
     C***                  MOVEL*BLANK    D2KIND
     C                     SETON                     2599
     C                     MOVELER,4      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDSL
      *
      * PUBLICATION KIND (26)
      *
     C                     SELEC
     C           D1WKBN    WHEQ ' '
     C***                  MOVEL$PK       D2WKBN
     C           D1WKBN    WHEQ '1'
     C***                  MOVEL$PK1      D2WKBN
     C           D1WKBN    WHEQ '2'
     C***                  MOVEL$PK2      D2WKBN
     C                     OTHER
     C***                  MOVEL*BLANK    D2WKBN
     C                     SETON                     2699
     C                     MOVELER,5      D1ERR
     C                     GOTO $CHK1Z
     C                     ENDSL
      ***
      * LOCATION (27 28)
      *
     C*          D1LOC2
     C*          D1LOC3
     C                     MOVE ' '       D2LHF
     C           D1LOC2    IFNE *BLANK
     C           D1LOC3    ORNE *BLANK
     C                     MOVE '-'       D2LHF
     C                     ENDIF
      *
      * PROCESS (29)
      *
     C*          D1PROC
      *
      * IAF PART# (30)
     C*          D1HIN1
     C*          D1HIN2
     C*          D1HIN3
     C                     MOVE '-'       D2HF1
     C                     MOVE '-'       D2HF2
     C           D1HIN3    IFEQ *BLANK
     C                     MOVE ' '       D2HF2
     C           D1HIN2    IFEQ *BLANK
     C                     MOVE ' '       D2HF1
     C                     ENDIF
     C                     ENDIF
      *
      *
     C           KEY01     KLIST
     C                     KFLD           D1DAT1
     C                     KFLD           K@TIM1
     C           KEY02     KLIST
     C                     KFLD           D1DAT2
     C                     KFLD           K@TIM2
     C*
     C           D1TIM1    MULT 100       K@TIM1  60
     C           D1TIM2    MULT 100       K@TIM2  60
      *
      *データ件数カウントのみ
      *
     C           KEY01     SETLLABHPLC2
     C                     Z-ADD0         D2KENS  40
     C                     MOVE '#COUNT  '@STEP
     C                     EXSR #SFSET
      *
      *サブファイル作成
      *
     C           KEY01     SETLLABHPLC2
     C                     Z-ADD14        @@MAX   40
     C                     SETON                     89
     C                     MOVE '        '@STEP
     C                     EXSR #SFSET
      *
S1   C           ENDRRN    IFEQ 0
     C                     SETON                     99
     C                     MOVEA'1111'    *IN,21           21-24
     C           D1KIND    COMP ' '                  2525
     C           D1WKBN    COMP ' '                  2626
 S2  C           D1LOC2    IFNE *BLANK
     C           D1LOC3    ORNE *BLANK
     C                     SETON                     2728
 E2  C                     ENDIF
     C           D1PROC    COMP '   '                2929
 S2  C           D1HIN1    IFNE *BLANK
     C           D1HIN2    ORNE *BLANK
     C           D1HIN3    ORNE *BLANK
     C                     SETON                     30
 E2  C                     ENDIF
     C                     MOVELER,6      D1ERR
     C                     GOTO $CHK1Z
E1   C                     ENDIF
      *-------------------------*
     C           $CHK1Z    TAG
      *-------------------------*
     C           *IN99     IFEQ *OFF
     C                     MOVE '#DSP2   '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C                     ENDSR
      *===============================================================
      *  照会画面作成(PAGE UP/DOWN)
      *===============================================================
     C           #SFSET    BEGSR
     C*
     C                     SETON                     73    SFLCLR
     C                     WRITESFCTL1
     C                     SETOF                     73
     C*
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         ENDRRN  40
     C*-------------------------
      * SHIPPING SHORTAGE FILE                         *
     C*-------------------------
S1   C                     DO   *HIVAL
     C                     READ ABHPLC2                  90
     C* ISSUE DATE-TIME
     C  N90      A2KOHT    IFGT D1END
     C                     SETON                     90
     C                     ENDIF
     C   90                LEAVE
     C*
     C           A2SKJY    IFEQ 'D'
     C           A2SKDT    ANDLE@SYSHZ
     C                     ITER
     C                     ENDIF
     C*
     C                     EXSR #SEL
     C           @NG       IFEQ '*'
     C                     ITER
     C                     ENDIF
     C*データ件数カウントのみ
 S2  C           @STEP     IFEQ '#COUNT  '
     C                     ADD  1         D2KENS
     C                     ITER
 E2  C                     ENDIF
     C*
     C                     Z-ADDA2KODT    S1KODT
     C           A2KOTM    DIV  100       S1KOTM
     C*
     C                     MOVEL*BLANK    S1USER
     C           A2USER    CHAINRGAPL11              91
     C           *IN91     IFEQ *OFF
     C           J8SKJY    ANDNE'D'
     C                     MOVELJ8NAME    S1USER
     C                     ENDIF
     C* K.K
     C                     SELEC
     C           A2KAID    WHEQ 'SN'
     C                     MOVE 'A'       S1KIND
     C           A2KAID    WHEQ 'YK'
     C                     MOVE 'B'       S1KIND
     C                     OTHER
     C                     MOVE ' '       S1KIND
     C                     ENDSL
     C* P.K
     C                     SELEC
     C           A2WKBN    WHEQ ' '
     C                     MOVE '1'       S1WKBN
     C           A2WKBN    WHEQ 'R'
     C                     MOVE '2'       S1WKBN
     C                     OTHER
     C                     MOVE ' '       S1WKBN
     C                     ENDSL
     C*   LOCATION
     C                     MOVEL'-'       $BHF2
     C*   PROCESS
     C                     MOVELA2PROC    S1PROC           PROCESS
     C*   PART#
     C                     MOVEL'-'       $SHF1
     C                     MOVEL'-'       $SHF2
     C           A2HIN3    IFEQ *BLANK
     C                     MOVEL' '       $SHF2
     C           A2HIN2    IFEQ *BLANK
     C                     MOVEL' '       $SHF1
     C                     ENDIF
     C                     ENDIF
     C*   PAGE #
     C                     MOVE A2PAGF    S1PAGF
     C                     MOVE A2PAGT    S1PAGT
     C                     MOVE ' TO '    $PAG1
     C*
     C*---------------
     C*
     C                     ADD  1         RRN1
     C                     WRITESFREC1
     C           RRN1      IFGE @@MAX
     C                     LEAVE
     C                     ENDIF
     C*---------------
E1   C                     ENDDO
     C*-------------------------
     C*-------------------------
     C                     Z-ADDRRN1      ENDRRN  40
     C*--------------------
     C                     ENDSR
      *===============================================================
      *選択
      *===============================================================
     C           #SEL      BEGSR
      *
     C                     MOVE ' '       @NG     1
      *
      * KANBAN KIND
      *
     C           A2KAID    IFEQ 'YB'
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C*
     C           D1KIND    IFEQ 'A'
     C           A2KAID    ANDNE'SN'
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C*
     C           D1KIND    IFEQ 'B'
     C           A2KAID    ANDNE'YK'
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
      *
      * PUBLICATION KIND
      *
     C           D1WKBN    IFEQ '1'
     C           A2WKBN    ANDNE' '
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C*
     C           D1WKBN    IFEQ '2'
     C           A2WKBN    ANDNE'R'
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
      *
      * LOCATION
      *
     C           D1LOC2    IFNE *BLANK
     C           D1LOC2    ANDNEA2LOC2
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C*
     C           D1LOC3    IFNE *BLANK
     C           D1LOC3    ANDNEA2LOC3
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
      *
      * PROCESS
      *
     C           D1PROC    IFNE *BLANK
     C           D1PROC    ANDNEA2PROC
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
      *
      * IAF PART#
      *
     C           D1HIN1    IFNE *BLANK
     C           D1HIN1    ANDNEA2HIN1
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C*
     C           D1HIN2    IFNE *BLANK
     C           D1HIN2    ANDNEA2HIN2
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
     C*
     C           D1HIN3    IFNE *BLANK
     C           D1HIN3    ANDNEA2HIN3
     C                     MOVE '*'       @NG
     C                     GOTO $SELZ
     C                     ENDIF
      *
     C           $SELZ     ENDSR
      *===============================================================
      *===============================================================
      *  画面２　表示
      *===============================================================
     C           #DSP2     BEGSR
     C*
     C                     WRITEDSP02
     C*
     C                     SETON                     71
     C           ENDRRN    IFNE 0
     C                     SETON                     72
     C                     ENDIF
     C                     EXFMTSFCTL1
     C                     SETOF                     717299
     C                     MOVE *BLANK    D2ERR
     C*
      *
S1   C                     SELEC
     C*
     C*  < F3 > 前画面
     C           *INKC     WHEQ *ON
     C                     MOVE '#DSP1   '@STEP
     C*
     C*  < ROLL/UP >
-1   C           *IN75     WHEQ *ON
 S2  C           *IN90     IFEQ *ON
     C                     MOVELER,08     D2ERR            エラー
     C                     SETON                     99
 X2  C                     ELSE
     C                     EXSR #SFSET
     C                     SETOF                     89
  S3 C           ENDRRN    IFEQ 0
     C                     EXSR #DOWN
     C                     SETON                     90  99
     C                     MOVELER,08     D2ERR            エラー
  E3 C                     ENDIF
 E2  C                     ENDIF
     C                     MOVE '#DSP2   '@STEP
     C*
     C*  < ROLL/DOWN >
-1   C           *IN76     WHEQ *ON
 S2  C           *IN89     IFEQ *ON
     C                     MOVELER,07     D2ERR            エラー
     C                     SETON                     99
 X2  C                     ELSE
     C                     EXSR #DOWN
     C                     MOVE '#DSP2   '@STEP
 E2  C                     ENDIF
E1   C                     ENDSL
      *
     C                     ENDSR
      *===============================================================
      *
      *===============================================================
     C           #DOWN     BEGSR
     C           ENDRRN    ADD  @@MAX     @@BACK  40
     C                     Z-ADD0         @@KEN   40
     C*
     C   90                ADD  1         @@BACK
     C   90      KEY02     SETGTABHPLC2
     C   90                SETOF                     90
      *-------------------------
      *-------------------------
S1   C           @@KEN     DOUEQ@@BACK
     C                     READPABHPLC2                  89
     C* ISSUE DATE-TIME
     C  N89      A2KOHT    IFLT D1STAR
     C                     SETON                     89
     C                     ENDIF
     C   89                LEAVE
     C*
     C           A2SKJY    IFEQ 'D'
     C           A2SKDT    ANDLE@SYSHZ
     C                     ITER
     C                     ENDIF
     C*
     C*
     C                     EXSR #SEL
     C           @NG       IFEQ '*'
     C                     ITER
     C                     ENDIF
     C*
     C*
     C                     ADD  1         @@KEN
E1   C                     ENDDO
      *-------------------------
      *-------------------------
     C   89      KEY01     SETLLABHPLC2
     C                     EXSR #SFSET
     C                     ENDSR
      *===============================================================
      *===============================================================
      *===============================================================
**  ER  (ERROR MESSAGE )
E-01 INPUT ISSUE DATE
E-02 ISSUE DATE ISN'T RIGHT
E-03 DATE TIME ERROR  START > EXIT
E-04 KANBAN KIND ERROR (BLANK , A , B )
E-05 PUBLICATION KIND ERROR (BLANK , 1 , 2 )
E-06 THERE ISN'T APPLICABLE DATA.
E-07 THE FIRST DATA.
E-08 THE LAST DATA.
