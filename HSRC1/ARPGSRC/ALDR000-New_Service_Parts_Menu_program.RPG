     H            Y.                                    1
      ** ALDR000  **************************************************************
      * SERVICE PARTS MENU PROGRAM
      * LEC           10/21/2021  COPY FROM ALDR00
      **************************************************************************
     FALDPW000CF  E                    WORKSTN
     FALBPL30 IF  E           K        DISK
     F**************************************************************************
     E                    ERR     1   2 15
     I**************************************************************************
     I            DS
     I                                        1   80WSDATE
     I                                        1   4 WSYYYY
     I                                        5   6 WSMM
     I                                        7   8 WSDD
     I            DS
     I                                        1  140XXTIME
     I                                        1   60XXHMS
     I                                        7  140XXDATE
      *
      **************************************************************************
      * ENTRY LIST
      **************************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PWKCD   6
     C                     PARM           PUSR   10
      **************************************************************************
      * PARAMETER LIST
      **************************************************************************
     C           P1        PLIST
     C                     PARM           PWKCD
     C                     PARM           PUSR
      *
     C           P2        PLIST
     C                     PARM           PWKCD
     C                     PARM           PUSR2  20
      *
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C                     EXSR @INT
     C                     EXSR @MAIN
     C                     EXSR @END
      **************************************************************************
      *                    @INT
      **************************************************************************
     C           @INT      BEGSR
      *
     C                     TIME           XXTIME
     C                     SETOF                     303132
     C                     MOVEL*BLANK    MSG
     C                     MOVELPUSR      PUSR2            NAME
     C                     MOVELPWKCD     WKCD    60
      *
     C                     ENDSR
      **************************************************************************
      *                    @MAIN
      **************************************************************************
     C           @MAIN     BEGSR
      *
     C           *IN03     DOWEQ*OFF
     C                     MOVEL*BLANK    SNO
     C                     EXFMTALDPW001
     C                     SETOF                     303132
     C                     MOVEL*BLANK    MSG
      * F3=End
     C           *IN03     IFEQ *ON
      * Enter
     C                     ELSE
      * Worker Code Check
     C           WKCD      CHAINALBPL301             90
     C           *IN90     IFEQ *OFF
     C           ALSKJY    ANDNE'D'
      *
     C                     MOVE ALWKCD    POPR    6        SET WORKER ID
     C                     MOVEL*BLANK    PUSR2
     C                     MOVELALWKNM    PUSR             SET NAME
     C                     MOVELALWKNM    PUSR2            SET NAME
      *
     C                     SELEC
      * service parts pgm
     C           SNO       WHEQ '1'
     C                     CALL 'ALDR2SB' P2
      * toyota service parts pgm
     C           SNO       WHEQ '2'
     C                     CALL 'ALDC02B' P2
      * service parts retrieval pgm
     C           SNO       WHEQ '3'
     C                     CALL 'ALSR01'  P1
      * service parts shortage scans
     C           SNO       WHEQ '4'
     C                     CALL 'ALDC27'
      ** otherwise, error
     C                     OTHER
     C                     SETON                     3032
     C                     MOVEAERR,2     MSG
     C                     ENDSL
      **
      *  NOT in worker code master file
     C                     ELSE
     C                     SETON                     3031
     C                     MOVEAERR,1     MSG
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
     C                     ENDSR
      **************************************************************************
      *                    @END
      **************************************************************************
     C           @END      BEGSR
      *
     C                     SETON                     LR
     C                     RETRN
      *
     C                     ENDSR
      **************************************************************************
** ERR
USER CODE ERROR
INPUT NO. ERROR
