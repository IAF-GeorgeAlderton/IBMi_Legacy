     H            Y.                                    1
     F** MBDRP8 ********************************************
     F*  SHIPPING RESULT FOR PC DEPT                       *
     F*  J.W.      209.05.23                               *
     F******************************************************
     FMBDPWP8 CF  E                    WORKSTN
      *-----------------------------------------------------
     E                    ERR     1  10 65
      *----------------------------------------------------*
      *  MAIN ROUTINE
      *----------------------------------------------------*
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
      *
     C                     EXFMTDSP01
     C                     SETOF                     85
     C                     SETOF                     313233
     C                     SETOF                     343536
     C                     SETOF                     37
     C                     MOVE *BLANK    MSG
      *----------------*
      * F1: EXIT
      *----------------*
     C           *INKA     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C           @TOKU     IFEQ 0
     C                     SETON                     8531
     C                     SETOF                     05
     C                     MOVELERR,05    MSG
     C                     ITER
     C                     ENDIF
      *
     C           @YYYY     IFEQ 0
     C                     SETON                     8535
     C                     SETOF                     05
     C                     MOVELERR,01    MSG
     C                     ITER
     C                     END
      *
     C           @MMMM     IFGE 1
     C           @MMMM     ANDLE12
     C                     ELSE
     C                     SETON                     8536
     C                     SETOF                     05
     C                     MOVELERR,02    MSG
     C                     ITER
     C                     ENDIF
     C*
     C           @SIZI     IFNE '1'
     C           @SIZI     ANDNE'2'
     C           @SIZI     ANDNE'3'
     C                     SETON                     8537
     C                     SETOF                     05
     C                     MOVELERR,06    MSG
     C                     ITER
     C                     ENDIF
      *----------------*
      * F05: RUN
      *----------------*
     C           *INKE     IFEQ *OFF
     C                     MOVELERR,07    MSG
     C                     ELSE
     C                     EXSR #OUT
      **
     C           P@STS     IFEQ *BLANK
     C                     LEAVE
     C                     ELSE
     C                     SETON                     85
     C                     SETON                     313233
     C                     SETON                     343536
     C                     SETON                     37
     C                     MOVELERR,04    MSG
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  OUT
      *----------------------------------------------------*
     C           #OUT      BEGSR
      *
     C                     MOVEL@TOKU     P@TOKU  4
     C                     MOVEL@NONY     P@NONY  4
     C**                   MOVEL@NKOJ     P@NKOJ  1
     C**                   MOVEL@NUKE     P@NUKE  4
     C                     MOVEL@YYYY     P@YYYY  4
     C                     MOVEL@MMMM     P@MMMM  2
     C                     MOVEL@SIZI     P@SIZI  1
     C                     MOVEL*BLANK    P@STS   1
     C                     CALL 'MBDRP8B'
     C                     PARM           P@TOKU
     C                     PARM           P@NONY
     C**                   PARM           P@NKOJ
     C**                   PARM           P@NUKE
     C                     PARM           P@YYYY
     C                     PARM           P@MMMM
     C                     PARM           P@SIZI
     C                     PARM           P@STS
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SET
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C                     MOVE '1'       DSPSW1  1
      *
     C                     ENDSR
      *----------------------------------------------------------------
** ERR ..1.........2.........3.........4.........5.........6...> (65)
ENTER CORRECT YEAR !                                              01
ENTER CORRECT MONTH !                                             02
YEAR AND MONTH ARE INVALID !                                      03
NO DATA !                                                         04
ENTER CUSTOMER CODE !                                             05
ENTER RANGE 1, 2 OR 3 !                                           06
PRESS F5 TO PROCESS...                                            07
