     F********************************** ECQR10 **
     FECQPW10 CF  E                    WORKSTN
     FECSPL05 IF  E           K        DISK
     FGCQTL31 IF  E           K        DISK
     FMBEPL05 IF  E           K        DISK
     FGCQPL13 IF  E           K        DISK
     FFCQPL31 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FECQWP10 O   E                    DISK
      *-----------------------------------------------------------
     E                    I6S        12  9 0
     E                    QTY         6  9 0
     E                    YM          6  6 0
      *-----------------------------------------------------------
     I            DS
     I                                        1 1080I6S
     I                                        1   90I6SRO1
     I                                       10  180I6SRO2
     I                                       19  270I6SRO3
     I                                       28  360I6SRO4
     I                                       37  450I6SRO5
     I                                       46  540I6SRO6
     I                                       55  630I6SRO7
     I                                       64  720I6SRO8
     I                                       73  810I6SRO9
     I                                       82  900I6SROA
     I                                       91  990I6SROB
     I                                      100 1080I6SROC
     I            DS
     I                                        1  12 DFHIN
     I                                        1   5 DFSHN1
     I                                        6  10 DFSHN2
     I                                       11  12 DFSHN3
     I            DS
     I                                        1   60WYYMM
     I                                        1   40WYY
     I                                        5   60WMM
     I            DS
     I                                        1   60EQHZ
     I                                        1   40EQYOYY
     I                                        5   60EQYOMM
     I            DS
     I                                        1   60DFHZ
     I                                        1   40DFKOYY
     I                                        5   60DFKOMM
     I            DS
     I                                        1  15 DFKATA
     I                                        1   2 #KAT1
     I                                        3   3 #AAA
     I                                        4   7 #KAT2
     I                                        8   8 #BBB
     I                                        9   9 #KAT3
     I            DS
     I                                        1  54 QTY
     I                                        1   90EQQTY1
     I                                       10  180EQQTY2
     I                                       19  270EQQTY3
     I                                       28  360EQQTY4
     I                                       37  450EQQTY5
     I                                       46  540EQQTY6
     I            DS
     I                                        1   60F8YYMM
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------
      *  MAIN ROUTINE
      *--------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *------------------------------------------------------
     C           DFKEY     KLIST
     C                     KFLD           DFSHN1
     C                     KFLD           DFSHN2
     C                     KFLD           DFSHN3
      *
     C           KATKEY    KLIST
     C                     KFLD           #KAT1
     C                     KFLD           #KAT2
     C                     KFLD           #KAT3
     C           KATKEX    KLIST
     C                     KFLD           #KAT1
     C                     KFLD           #KAT2
     C                     KFLD           #KAT3
     C                     KFLD           WYY
     C                     KFLD           WMM
      *
     C           KEY1      KLIST
     C                     KFLD           #KAT1
     C                     KFLD           #KAT2
      *
     C           KEY       KLIST
     C                     KFLD           WYY
     C                     KFLD           DFSHN1
     C                     KFLD           DFSHN2
     C                     KFLD           DFSHN3
      *
     C           K#AGD     KLIST
     C                     KFLD           WYY
     C                     KFLD           WMM
      *
     C                     MOVE '01'      W@ID    2
     C                     Z-ADD*YEAR     WYY
     C                     Z-ADD*MONTH    WMM
     C                     Z-ADDWYYMM     D@YYMM
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #DSP01    BEGSR
      *-----------------------------------------------------
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #WRT
     C                     MOVE '99'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #CHK      BEGSR
      *-----------------------------------------------------
     C                     SETOF                     6199
     C                     Z-ADDD@YYMM    WYYMM
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #WRT      BEGSR
      *-----------------------------------------------------
      * 6 MONTH
     C                     Z-ADD*ZERO     YM
     C                     SUB  5         WMM
     C           WMM       IFLE 0
     C                     ADD  12        WMM
     C                     SUB  1         WYY
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     X       20
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READ AGDPL12                  90
     C           *IN90     IFEQ *OFF
     C                     ADD  1         X
     C                     Z-ADDF8YYMM    YM,X
     C           X         IFEQ 6
     C                     LEAVE
     C                     ENDIF
      *
     C                     Z-ADDF8KAYY    WYY
     C                     Z-ADDF8KAMM    WMM
     C           K#AGD     SETGTAGDPL12
     C                     ENDIF
     C                     ENDDO
      * HEADER
     C                     CLEARECQWP101
     C                     Z-ADDYM        QTY
     C                     WRITEECQWP101
      * DETAIL
     C                     EXSR #DTL
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #DTL      BEGSR
      *-----------------------------------------------------
      *
     C                     MOVE *BLANK    @HIN   12
      *
     C           *LOVAL    SETLLGCQTL311
     C                     Z-ADD0         @CNT    30
     C                     MOVE *BLANK    @DIE   15
     C           *IN90     DOUEQ*ON
     C                     READ GCQTL311                 90
     C           *IN90     IFEQ *OFF
     C           DFSKJY    ANDEQ*BLANK
      *
     C           KEY1      CHAINFCQPL311             41
     C           *IN41     IFEQ *ON
     C           Q4SKJY    ORNE *BLANK
     C           DFKATA    SETGTGCQTL31
     C                     ITER
     C                     ENDIF
      * SUB TOTAL
     C           DFKATA    IFNE @DIE
     C           @CNT      IFNE *ZERO
     C                     EXSR #WRT1
     C                     Z-ADD*ZERO     @CNT
     C                     ENDIF
      * DIE INFORMATION
     C                     EXSR #DIE
     C                     ENDIF
      *
     C                     Z-ADD*ZERO     QTY
     C                     MOVELDFKATA    @DIE
      *
     C           DFHIN     IFNE @HIN
     C           1         DO   6         X
     C                     Z-ADDYM,X      WYYMM
     C           KEY       CHAINMBEPL051             65
     C           *IN65     IFEQ *OFF
     C                     SETON                     40
     C                     Z-ADDI6S,WMM   QTY,X
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
     C                     MOVE DFHIN     @HIN
      *
     C                     XFOOTQTY       @@QTY  110
     C           @@QTY     IFNE *ZERO
     C                     ADD  1         @CNT
     C                     MOVELDFKATA    EQDCOD
     C                     MOVE DFKOTI    EQPROC
     C                     Z-ADD*ZERO     EQPRTN
     C                     MOVELDFHIN     EQPART
     C                     Z-ADD*ZERO     EQAVCT
     C                     Z-ADD*ZERO     EQSTUS
     C                     WRITEECQWP101
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           @CNT      IFNE *ZERO
     C                     EXSR #WRT1
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #DIE      BEGSR
      *-----------------------------------------------------
      * AVERAGE DIE USAGE CONT
     C                     Z-ADD0         @@AVCT  52
     C                     Z-ADD*ZERO     @@KOCD  40
     C                     MOVE *BLANK    @@TKR1  1
     C           KATKEY    SETLLGCQPL131
     C           *IN20     DOUEQ*ON
     C           KATKEY    READEGCQPL131                 20
     C           *IN20     IFEQ *OFF
     C           T6SKJY    ANDEQ*BLANK
     C           T6KOCD    IFEQ @@KOCD
     C           T6TKR1    ANDEQ@@TKR1
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADDT6KOCD    @@KOCD
     C                     MOVE T6TKR1    @@TKR1
     C                     ADD  T6SRYO    @@AVCT
     C                     ENDIF
     C                     ENDDO
      * SETTING USAGE
     C                     Z-ADD*ZERO     @@USC   92
     C                     Z-ADDYM,1      WYYMM
      *
     C           KATKEX    SETLLECSPL05
     C           *IN20     DOUEQ*ON
     C           KATKEY    READEECSPL05                  20
     C           *IN20     IFEQ *OFF
     C           EQSKJY    ANDEQ*BLANK
     C           EQBMON    ANDEQ0111
      *
     C           EQHZ      IFGT YM,6
     C                     LEAVE
     C                     ENDIF
     C                     ADD  EQKOSU    @@USC
     C                     ENDIF
     C                     ENDDO
      *
     C           @@USC     DIV  6         @@USC     H
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #WRT1     BEGSR
      *-----------------------------------------------------
     C                     MOVE *BLANK    EQPROC
     C                     MOVE *BLANK    EQPART
     C                     Z-ADD@CNT      EQPRTN
     C                     Z-ADD*ZERO     QTY
     C                     Z-ADD@@AVCT    EQAVCT
     C                     Z-ADD@@USC     EQSTUS
     C                     WRITEECQWP101
      *
     C                     ENDSR
