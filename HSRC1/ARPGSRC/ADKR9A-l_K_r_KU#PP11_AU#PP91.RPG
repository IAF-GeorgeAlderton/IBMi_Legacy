     I                                       37  380CDBI19
     I                                       39  400CDBI20
     I                                       41  420CDBI21
     I                                       43  440CDBI22
     I                                       45  460CDBI23
     I                                       47  480CDBI24
      *
     I            DS
     I                                        1  120WKDATI
     I                                        1   80WKDATE
     I                                        9  120WKTIME
      *
     I            DS
     I                                        1  120KQDATI
     I                                        1   80KQDATE
     I                                        9  120KQTIME
     I            DS
     I                                        1   80KQTHHZ
     I                                        1   40KQTHYY
     I                                        5   60KQTHMM
     I                                        7   80KQTHDD
      *
     I            DS
     I                                        1   40KQTHTI
     I                                        1   20KQTHJI
     I                                        3   40KQTHPN
      *
     I            DS
     I                                        1  120KQSS
     I                                        1   80KQSSHZ
     I                                        9  140KQSSTI
      *
     I            DS
     I                                        1  120@@SS
     I                                        1   80@@SSHZ
     I                                        9  140@@SSTI
      *
     I            DS
     I                                        1  140WDATE
     I                                        1   60STIME
     I                                        1   20STIHH
     I                                        3   40STIMM
     I                                        5   60STISS
     I                                        7  140SDATE
     I                                        7  100SDAYY
     I                                       11  120SDAMM
     I                                       13  140SDADD
      *
     I            DS
     I                                        1   40HHMM1
     I                                        1   20HH1
     I                                        3   40MM1
      *
     I            DS
     I                                        1   80WKTOHZ
     I                                        1   40WKTOYY
     I                                        5   60WKTOMM
     I                                        7   80WKTODD
      *
     I            DS
     I                                        1   80F8KA
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
      *
     I            DS
     I                                        1  12 @HIN
     I                                        1   5 @HIN1
     I                                        6  10 @HIN2
     I                                       11  12 @HIN3
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           PHM     4
      *
     C                     CALL 'ADKR90'
     C                     PARM           PHM     4
     C                     PARM           P1APHZ  80
     C                     PARM           P1APBN  20
     C                     TIME           WDATE
     C           KEYKQ     KLIST
     C                     KFLD           K#NKHZ  80
     C                     KFLD           K#NKTI  60
     C                     Z-ADD0         K#NKHZ
     C                     Z-ADD0         K#NKTI
      *
     C                     Z-ADD0         @@SS
     C                     Z-ADD20160307  @@SSHZ
     C                     Z-ADD040000    @@SSTI
     C                     Z-ADDP1APHZ    $$HZ
     C                     Z-ADDP1APBN    $$BN
     C                     MOVE '1'       OPNCLS  1
      *
     C           KEYKQ     SETLLKU#PL111
     C           KEYKQ     READEKU#PL111                 80
      *
     C           *IN80     DOWEQ'0'
     C           KQSKJY    IFEQ 'D'
     C           KQSKHZ    ANDLE*DATE
     C                     ELSE
     C           KQSS      IFLT @@SS
     C                     ELSE
     C                     EXSR #SB100
     C                     ENDIF
     C                     ENDIF
     C           KEYKQ     READEKU#PL111                 80
     C                     ENDDO
      *
     C           OPNCLS    IFEQ '0'
     C                     MOVEL'9'       OPNCLS
     C                     EXSR #AAMRS
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------*
      *                                   *
      *-----------------------------------*
     CSR         #SB100    BEGSR
      *
      *
     C                     EXSR #SB101
     C           @TYPE     IFNE 'C'                        KANBAN KIND
     C                     GOTO ESB100
     C                     ENDIF
      *
     C                     MOVEL'0'       ###GET  1
     C                     EXSR #SB110
     C   22                GOTO ESB100
      *
     C                     EXSR #SB120
     C                     EXSR #SB130
     C           ###GET    IFEQ '1'
     C                     EXSR #SB500
     C                     Z-ADDSDATE     KQNKHZ
     C                     Z-ADDSTIME     KQNKTI
     C                     Z-ADDP1APHZ    KQAPHZ
     C                     Z-ADDP1APBN    KQAPBN
     C                     ENDIF
      *
     CSR         ESB100    ENDSR
      *-----------------------------------*
      * AAMPL11                           *
      *-----------------------------------*
     C           #SB101    BEGSR
      *
      *
     C                     EXSR #AAMRS
      *
     C                     MOVEAPSHR      @KT              KANBAN KIND
     C                     MOVEAPHBN      @HN              PART NO.
      *
      *
     C                     Z-ADD0         Y       20
     C                     MOVE *BLANK    @TYPE   1        KANBAN KIND
     C                     MOVE *BLANK    @HIN   12        PART NO.
S1   C                     DO   15        Z       20
     C           16        SUB  Z         X       20
 S2  C           @KT,X     IFNE *BLANK                     KANBAN KIND
     C                     ADD  1         Y
  S3 C           Y         IFEQ 2
     C                     MOVE @KT,X     @TYPE   1        KANBAN KIND
     C                     MOVE @HN,X     @HIN   12        PART NO.
     C                     LEAVE
  E3 C                     ENDIF
 E2  C                     ENDIF
E1   C                     ENDDO
      *
      *
     C           ESB101    ENDSR
      *-----------------------------------*
      * ACAPL11                           *
      *-----------------------------------*
     CSR         #SB110    BEGSR
      *
     C           KEYAGA    KLIST
     C                     KFLD           @HIN1
     C                     KFLD           @HIN2
     C                     KFLD           @HIN3
     C           KEYAGA    CHAINAGAPL411             22
     C           *IN22     IFEQ '0'
     C           CBSKJY    ANDEQ'D'
     C           CBSKHZ    ANDLE*DATE
     C                     SETON                     22
     C                     ENDIF
     C           *IN22     IFEQ '1'
     C                     GOTO ESB110
     C                     ENDIF
      *
     C           #KEY2     KLIST
     C                     KFLD           CBMBMN
     C                     KFLD           CBKDAI
      *
     C           #KEY3     KLIST
     C                     KFLD           CBMBMN
     C                     KFLD           CBKDAI
     C                     KFLD           CBSHN1
     C                     KFLD           CBSHN2
     C                     KFLD           CBSHN3
      *
     C                     Z-ADD0         XXBMON  40
     C                     MOVE *BLANK    XXKCD1  1
     C                     MOVE *BLANK    XXSW1   1
S1   C           CBKDAI    IFEQ '0'
     C                     Z-ADD0111      XXBMON
X1   C                     ELSE
     C*
     C* .. A-PICS TRANSMISSION POINT JUDGMENT M/F   *.
     C*
     C           #KEY2     SETLLACAPL111
 S2  C                     DO   *HIVAL
     C                     SETOF                     10
     C           #KEY2     READEACAPL111                 10
     C           *IN10     IFEQ '0'
     C           I1SKJY    IFEQ 'D'
     C           I1SKHZ    ANDLE*DATE
     C                     ELSE
     C                     SETON                     10
     C                     MOVE '*'       XXSW1
     C                     Z-ADDI1BMON    XXBMON
     C                     MOVE I1KCD1    XXKCD1
     C                     ENDIF
     C                     ENDIF
 E2  C  N10                ENDDO
      *
 S2  C           XXSW1     IFEQ *BLANK
     C                     Z-ADD0111      XXBMON
 X2  C                     ELSE
     C                     SETOF                     11
     C           #KEY3     CHAINACAPL111             11
     C           *IN11     IFEQ '0'
     C           I1SKJY    ANDEQ'D'
     C           I1SKHZ    ANDLE*DATE
     C                     SETON                     11
     C                     ENDIF
  S3 C           *IN11     IFEQ '0'
     C                     Z-ADDI1BMON    XXBMON
  E3 C                     ENDIF
 E2  C                     ENDIF
E1   C                     ENDIF
      *
     CSR         ESB110    ENDSR
      *-----------------------------------*
      * AAIPL11,AAIPL31                   *
      *-----------------------------------*
     CSR         #SB120    BEGSR
      * GET A-PICS ORDER NO.(BIN)
     C                     Z-ADD0         WKDATI 120
     C                     Z-ADD0         WKBIN   20
     C                     Z-ADD0         WKTOHZ  80
     C                     Z-ADD0         WKYOHZ  80
     C                     Z-ADD0         WKZNHZ  80
     C                     MOVELPHM       HHMM1
     C           XXBMON    CHAINAAIPL111             49
     C           *IN49     IFEQ '0'
     C                     MOVE CDBI,HH1  WKBIN
     C                     Z-ADDCDTOHZ    WKTOHZ
     C                     Z-ADDCDYOHZ    WKYOHZ
     C                     Z-ADDCDZNHZ    WKZNHZ
     C                     ENDIF
      * GET PICKUP TIME
     C           KEYG21    KLIST
     C                     KFLD           #KBMON  40
     C                     KFLD           #KBIN   20
     C                     MOVELXXBMON    #KBMON
     C                     Z-ADDWKBIN     #KBIN
     C                     MOVEL'0'       GET     1
     C                     Z-ADD0         W2TIME  40
     C                     Z-ADD0         W2ADJS  10
     C           KEYG21    SETLLAAIPL311
     C           KEYG21    READEAAIPL311                 49
     C           *IN49     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           G2SKJY    IFEQ 'D'
     C           G2SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'1'       GET
     C                     Z-ADDG2TIME    W2TIME  40
     C                     Z-ADDG2ADJS    W2ADJS
     C                     ENDIF
     C           KEYG21    READEAAIPL311                 49
     C                     ENDDO
      *前日はカレンダーから
     C                     EXSR #SB140
      *
     C                     Z-ADD0         WKDATI
     C                     Z-ADD00000000  WKDATE
     C                     Z-ADD0000      WKTIME
     C           GET       IFEQ '1'
     C           W2ADJS    IFEQ 1
     C                     Z-ADDWKZNHZ    WKDATE
     C                     Z-ADDW2TIME    WKTIME
     C                     ELSE
     C                     Z-ADDWKTOHZ    WKDATE
     C                     Z-ADDW2TIME    WKTIME
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB120    ENDSR
      *-----------------------------------*
      * PICKUP                            *
      *-----------------------------------*
     CSR         #SB130    BEGSR
      *
     C                     Z-ADD0         KQDATI
     C                     Z-ADDKQTHHZ    KQDATE
     C                     Z-ADDKQTHTI    KQTIME
     C                     MOVEL'0'       ###GET  1
     C           KQSS      IFLE WKDATI
     C                     MOVEL'1'       ###GET  1
     C                     ENDIF
      *
     CSR         ESB130    ENDSR
      *-----------------------------------------*
      *前日                                   *
      *-----------------------------------------*
     CSR         #SB140    BEGSR
      *
     C           KEYF88    KLIST
     C                     KFLD           #KYY    40
     C                     KFLD           #KMM    20
     C                     KFLD           #KDD    20
     C                     Z-ADDWKTOYY    #KYY
     C                     Z-ADDWKTOMM    #KMM
     C                     Z-ADDWKTODD    #KDD
     C           KEYF88    SETLLAGDPL121
     C                     READPAGDPL121                 41
     C           *IN41     IFEQ '0'
     C                     Z-ADDF8KA      WKZNHZ
     C                     ENDIF
      *
     CSR         ESB140    ENDSR
      *-----------------------------------------*
      * AU#PP91                                 *
      *-----------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAU#PP911
     C                     MOVEL*BLANK    CQSKJY
