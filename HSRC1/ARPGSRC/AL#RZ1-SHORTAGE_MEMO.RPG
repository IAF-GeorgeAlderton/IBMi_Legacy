     C           C@DKB     WHEQ '3'                        SIKIRI
     C                     EXSR #SB500
     C           C@DKB     WHEQ '2'
     C                     EXSR #SB510
     C           C@DKB     WHEQ '1'
     C                     MOVEL'1'       ENDSW   1
     C                     ENDSL
     C                     ENDIF
     C                     READ AL#PPA11                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-------------------*
      *ＲＲＮを取得     *
      *-------------------*
     CSR         #SB400    BEGSR
      *
     C           KEY1      KLIST
     C                     KFLD           K1DKB   1
     C                     KFLD           K1SHME 17
      *
     C                     MOVEL'3'       K1DKB
     C                     MOVELP1SHME    K1SHME
     C           KEY1      SETLLAL#PLA31
     C           KEY1      READEAL#PLA31                 23
     C           *IN23     IFEQ '0'
     C                     Z-ADDRRN43     KEYRRN 100
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *-------------------*
      *                   *
      *-------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAL#PPZ11
     C                     MOVELC@SHME    CZSHME
