TCHKZC                     KFLD           W@PRT2  5
TCHKZC                     KFLD           W@PRT3  2
TCHKZC*
TCHKZC           K#AJ12    READEAJSPL12                  91
TCHKZC   91                LEAVE
      *
     C           J1MKKB    IFEQ '22'
     C                     ITER
     C                     END
      *
     C                     MOVEL'0111'    P#BMON  4
     C                     MOVEL'BZ '     P#KOTE  3
     C                     MOVE *BLANK    P#KIBN  3
     C           J1MKKB    IFEQ '11'
