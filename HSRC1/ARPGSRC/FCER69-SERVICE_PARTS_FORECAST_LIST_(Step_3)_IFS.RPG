     H            Y.
      ** FCER68 ******************************************************
      *  SERVICE PARTS FORECAST LIST (STEP 3) - PRINT                *
      *  J.WATANABE  2019.01.31                                      *
      ****************************************************************
     FFCEWP66 IF  E           K        DISK
     FFCEWP67 O   E           K        DISK
      ********************************************************
     E                    @YM         7  6 0
     E                    XYM         7  7
      *
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        7  120TGTYM
     I                                        7  100TGTYY
     I                                       11  120TGTMM
     I            DS
     I                                        1   60#YM
     I                                        1   40#YY
     I                                        5   60#MM
     I            DS
     I                                        1   60@YM
     I                                        1   40@YY
     I                                        5   60@MM
     I            DS
     I                                        1   7 XYM
     I                                        1   4 XYY
     I                                        5   5 XX1
     I                                        6   7 XMM
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------------------*
      *     M  A  I  N  L  I  N  E                                *
      *-----------------------------------------------------------*
      *
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ FCEWP66                  98
     C   98                LEAVE
      *
     C                     EXSR #OUT
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *************************************************************
      * PRINT OPTION
      *************************************************************
     C           #OUT      BEGSR
      *
     C           LIN#      IFEQ 99
     C                     EXSR #HDR
     C                     Z-ADD0         LIN#
     C                     ENDIF
      *
     C                     EXSR #DTL
      *
     C                     ENDSR
      *************************************************************
      * OUTPUT HEADER
      *************************************************************
     C           #HDR      BEGSR
      *
     C                     MOVEL'LOC2'    F7LOC2
     C                     MOVEL'LOC3'    F7LOC3
     C                     MOVEL'IAF PART'F7SHN1
     C                     MOVE *BLANK    F7SHN2
     C                     MOVE *BLANK    F7SHN3
     C                     MOVEL'MONTHLY 'F7GEKN
     C                     MOVELXYM,1     F7QTY1
     C                     MOVELXYM,2     F7QTY2
     C                     MOVELXYM,3     F7QTY3
     C                     MOVELXYM,4     F7QTY4
     C                     MOVELXYM,5     F7QTY5
     C                     MOVELXYM,6     F7QTY6
     C                     MOVELXYM,7     F7QTY7
     C                     MOVEL'USR PART'F7MHN1
     C                     MOVE *BLANK    F7MHN2
     C                     MOVE *BLANK    F7MHN3
      *
     C                     ENDSR
      *************************************************************
      * OUTPUT DETAIL
      *************************************************************
     C           #DTL      BEGSR
      *
     C                     MOVELFWLOC2    F7LOC2
     C                     MOVELFWLOC3    F7LOC3
     C                     MOVELFWSHN1    F7SHN1
     C                     MOVELFWSHN2    F7SHN2
     C                     MOVELFWSHN3    F7SHN3
     C                     MOVELFWNOYM    F7GEKN
     C                     MOVELFWQTY1    F7QTY1
     C                     MOVELFWQTY2    F7QTY2
     C                     MOVELFWQTY3    F7QTY3
     C                     MOVELFWQTY4    F7QTY4
     C                     MOVELFWQTY5    F7QTY5
     C                     MOVELFWQTY6    F7QTY6
     C                     MOVELFWQTY7    F7QTY7
     C                     MOVELFWMHN1    F7MHN1
     C                     MOVELFWMHN2    F7MHN2
     C                     MOVELFWMHN3    F7MHN3
      *
     C                     WRITEFWMHN3    F7MHN3
      *
     C                     ENDSR
      *************************************************************
      * INITIALIZE
      *************************************************************
     C           #INIT     BEGSR
      *
     C                     Z-ADD99        LIN#    20
     C                     Z-ADD0         SEQ#    40
     C                     TIME           @SDATE
     C                     MOVE '/'       XX1
      *
     C                     Z-ADDTGTYY     #YY
     C           TGTMM     SUB  1         #MM
      * SET TABLE
     C           1         DO   7         IX      20
     C           #MM       IFLE 6
     C                     ADD  1         #MM
     C                     ELSE
     C                     ADD  1         #YY
     C                     Z-ADD1         #MM
     C                     ENDIF
     C                     Z-ADD#YM       @YM,IX
     C                     MOVEL#YY       XYY,IX
     C                     MOVEL#MM       XMM,IX
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM       8
     O                         TODAY Y   69
     O                         NOW       79 '  :  :  '
     O                                   83 'P.'
     O                         PAGE  Z   86
     O        E   02           @HDR
     O                                   41 '** SERVICE PART FORE'
     O                                   61 'CAST LIST **        '
     O        E   04           @HDR
     O                                    6 'LOC2/3'
     O                                   18 'IAF PART...'
     O                                   30 'BASE DATE'
     O                         @YM,1     40 '    /  '
     O                         @YM,2     49 '    /  '
     O                         @YM,3     58 '    /  '
     O                         @YM,4     67 '    /  '
     O                         @YM,5     76 '    /  '
     O                         @YM,6     85 '    /  '
     O                                   97 'USR PART...'
      *
     O        E 1              @DTL
     O                         FWLOC2  +  1
     O                         FWLOC3  +  1
     O                         FWSHN1  +  1
     O                         FWSHN2  +  1
     O                         FWSHN3  +  1
     O                         FWNOYM  +  1 '    /  '
     O                         FWQTY11 +  1
     O                         FWQTY21 +  0
     O                         FWQTY31 +  0
     O                         FWQTY41 +  0
     O                         FWQTY51 +  0
     O                         FWQTY61 +  0
     O                         FWMHN1  +  2
     O                         FWMHN2  +  1
     O                         FWMHN3  +  1
