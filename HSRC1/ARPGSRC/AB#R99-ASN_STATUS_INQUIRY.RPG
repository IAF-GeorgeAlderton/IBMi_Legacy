     H            Y.
      ** AB#R99 ********************************************
      * ASN STATUS INQUIRY                                 *
      *                                                    *
      * TCHK1 : 01/19/07 CREATE                            *
      ******************************************************
     FAB#PW99 CF  E                    WORKSTN
     F                                        RRN2  KSFILE SFL020
     F                                        RRN3  KSFILE SFL030
     F                                              KINFDS @INFDS
     FAB#PL75 IF  E           K        DISK
     FAB#PL1N IF  E           K        DISK
     FGADPL11 IF  E           K        DISK
     FAB#PP98 IF  E           K        DISK
      *---------------------------------------------------
     E                    ERR     1  10 78
      *---------------------------------------------------
     I@INFDS      DS
     I                                     *STATUS  @STTS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME(6) + DATE(6)
     I            DS
     I                                        1  140WWTIME
     I                                        1   60WTIME
     I                                        1   40WTIM4
     I                                        1   20WTIMHH
     I                                        3   40WTIMMM
     I                                        7  120WSDATE
     I                                        9  120@@YM4
     I                                        7  120@@YM6
     I                                        7  140@@YMD
     I                                        7  100@@YY
     I                                       11  120@@MM
     I                                       13  140@@DD
      * SHIP DATE(KEY)
     I            DS
     I                                        1   80K@SHDT
     I                                        1   40K@SHYY
     I                                        5   60K@SHMM
     I                                        7   80K@SHDD
      * SHIP DATE(AB#PL75)
     I            DS
     I                                        1   80PUNODT
     I                                        1   40PUNOYY
     I                                        5   60PUNOMM
     I                                        7   80PUNODD
      * SHIP-TO DATE(SCREEN SELECT CONDITION)
     I            DS
     I                                        1   80W@TODT
     I                                        1   40W@SHTY
     I                                        5   60W@SHTM
     I                                        7   80W@SHTD
     I            DS
     I                                        1   60W1SFDT
     I                                        1   40W1SHFY
     I                                        5   60W1SHFM
     I            DS
     I                                        1   60W1STDT
     I                                        1   40W1SHTY
     I                                        5   60W1SHTM
      *
     I            DS
     I                                        1  15 W3MHIN
     I                                        1   5 W3MHI1
     I                                        6  10 W3MHI2
     I                                       11  15 W3MHI3
     I            DS
     I                                        1  12 W3SHIN
     I                                        1   5 W3SHI1
     I                                        6  10 W3SHI2
     I                                       11  12 W3SHI3
     I            DS
     I                                        1   80W3SHDT
     I                                        1   40W3SHYY
     I                                        5   60W3SHMM
     I                                        7   80W3SHDD
     C******************************************************
     C*  MAIN
     C******************************************************
     C*
     C                     EXSR @INT
     C*
     C                     EXSR @F1RTN
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C*
     C******************************************************
     C*  INITTIAL SET
     C******************************************************
     C           @INT      BEGSR
     C*
     C                     TIME           WWTIME
     C*
     C                     Z-ADD@@YY      F1SHFY
     C                     Z-ADD@@MM      F1SHFM
     C                     Z-ADD@@DD      F1SHFD
     C                     Z-ADD*ZERO     F1SHTY
     C                     Z-ADD*ZERO     F1SHTM
     C                     Z-ADD*ZERO     F1SHTD
     C                     MOVEL*BLANK    F1NONY
     C                     MOVEL*BLANK    F1NUKE
     C                     Z-ADD*ZERO     F1BINN
     C                     MOVEL'Y'       F1STS
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
     C*
     C                     Z-ADD*ZERO     W1SHFY  40
     C                     Z-ADD*ZERO     W1SHFM  20
     C                     Z-ADD*ZERO     W1SHFD  20
     C                     Z-ADD*ZERO     W1SHTY  40
     C                     Z-ADD*ZERO     W1SHTM  20
     C                     Z-ADD*ZERO     W1SHTD  20
     C                     Z-ADD*ZERO     W1CUST  40
     C                     Z-ADD*ZERO     W1NONY  40
     C                     MOVEL*BLANK    W1NUKE  4
     C                     Z-ADD*ZERO     W1BINN  20
     C                     MOVEL*BLANK    W1STS   1
     C*
     C                     ENDSR
     C******************************************************
     C*  FMT010
     C******************************************************
     C           @F1RTN    BEGSR
     C*
     C                     DO   *HIVAL
     C*
     C                     MOVEL*OFF      *IN48
     C                     MOVEL*OFF      *IN47
     C                     WRITEFMT099
     C                     EXFMTFMT010
     C   KA                LEAVE
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
     C*
     C                     EXSR @SHCHK
     C           *IN49     IFEQ *ON
     C                     ITER
     C                     END
     C*
     C                     EXSR @F2RTN
     C   KA                LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  SHIP DATE CHECK
     C******************************************************
     C           @SHCHK    BEGSR
     C*
     C           F1SHFY    IFEQ *ZERO
     C           F1SHFM    ANDEQ*ZERO
     C           F1SHFD    ANDEQ*ZERO
     C                     MOVELERR,1     MSG
     C                     MOVEL*ON       *IN49
     C                     END
     C*
     C           F1SHFY    IFEQ *ZERO
     C           F1SHFM    OREQ *ZERO
     C                     MOVELERR,1     MSG
     C                     MOVEL*ON       *IN49
     C                     END
     C*
     C           F1SHTY    IFNE *ZERO
     C           F1SHTM    IFEQ *ZERO
     C                     MOVELERR,1     MSG
     C                     MOVEL*ON       *IN49
     C                     END
     C                     END
     C           F1SHTM    IFNE *ZERO
     C           F1SHTY    IFEQ *ZERO
     C                     MOVELERR,1     MSG
     C                     MOVEL*ON       *IN49
     C                     END
     C                     END
     C*
     C           F1SHTY    IFNE *ZERO
     C           F1SHTM    ORNE *ZERO
     C                     Z-ADDF1SHFY    W1SHFY
     C                     Z-ADDF1SHFM    W1SHFM
     C                     Z-ADDF1SHTY    W1SHTY
     C                     Z-ADDF1SHTM    W1SHTM
     C           W1SFDT    IFGT W1STDT
     C                     MOVELERR,1     MSG
     C                     MOVEL*ON       *IN49
     C                     END
     C                     END
     C*
     C                     ENDSR
     C******************************************************
     C*  @F2RTN
     C******************************************************
     C           @F2RTN    BEGSR
     C*
     C                     EXSR @F2SET
     C                     Z-ADD1         W#RNP2  40
     C*
     C                     DO   *HIVAL
     C*
     C                     MOVEL*ON       *IN48
     C                     MOVEL*ON       *IN47
     C                     WRITEFMT099
     C                     Z-ADDW#RNP2    #RCN02
     C                     EXFMTCTL020
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
     C   KA
     COR KL                LEAVE
     C*
     C  NKJ                MOVELN#MODE    *IN43
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP2
     C                     END
     C*
     C           *INKF     IFEQ *ON
     C           F1SHFY    ORNE W1SHFY
     C           F1SHFM    ORNE W1SHFM
     C           F1SHFD    ORNE W1SHFD
     C           F1SHTY    ORNE W1SHTY
     C           F1SHTM    ORNE W1SHTM
     C           F1SHTD    ORNE W1SHTD
     C           F1CUST    ORNE W1CUST
     C           F1NONY    ORNE W1NONY
     C           F1NUKE    ORNE W1NUKE
     C           F1BINN    ORNE W1BINN
     C           F1STS     ORNE W1STS
     C                     EXSR @SHCHK
     C   49                ITER
     C                     EXSR @F2SET
     C                     Z-ADD1         W#RNP2
     C                     ITER
     C                     END
     C*
     C                     EXSR @F3RTN
     C   KA                LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  SFL020 SET
     C******************************************************
     C           @F2SET    BEGSR
     C*
     C                     MOVEL*ON       *IN41
     C                     WRITECTL020
     C                     MOVEL*OFF      *IN41
     C                     MOVEL*OFF      *IN42
     C                     Z-ADD*ZERO     RRN2    40
     C*
     C                     MOVEL*ON       *IN43
     C                     MOVEL*ON       N#MODE
     C* SET SHP-TO DATE CONDITION
     C           F1SHTY    IFNE *ZERO
     C                     Z-ADDF1SHTY    W@SHTY
     C                     ELSE
     C                     Z-ADDF1SHFY    W@SHTY
     C                     END
     C           F1SHTM    IFNE *ZERO
     C                     Z-ADDF1SHTM    W@SHTM
     C                     ELSE
     C                     Z-ADDF1SHFM    W@SHTM
     C                     END
     C           F1SHTD    IFNE *ZERO
     C                     Z-ADDF1SHTD    W@SHTD
     C                     ELSE
     C                     Z-ADDF1SHFD    W@SHTD
     C           F1SHFD    IFEQ *ZERO
     C                     Z-ADD99        W@SHTD
     C                     END
     C                     END
     C*
     C           K#L75A    KLIST
     C                     KFLD           K@SHYY
     C                     KFLD           K@SHMM
     C                     KFLD           K@SHDD
     C           K#L75B    KLIST
     C                     KFLD           K@SHYY
     C                     KFLD           K@SHMM
     C                     Z-ADDF1SHFY    K@SHYY
     C                     Z-ADDF1SHFM    K@SHMM
     C                     Z-ADDF1SHFD    K@SHDD
     C           F1SHFD    IFEQ *ZERO
     C           K#L75B    SETLLAB#PL75
     C                     ELSE
     C           K#L75A    SETLLAB#PL75
     C                     END
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AB#PL75                  98
     C   98                LEAVE
     C           PUSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           PUNODT    IFGT W@TODT
     C                     LEAVE
     C                     END
     C*
     C           K#PP98    KLIST
     C                     KFLD           PUCUST
     C                     KFLD           PUNONY
     C           K#PP98    CHAINAB#PP98              97
     C   97                ITER
     C           P9SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C* CUST
     C           F1CUST    IFNE *ZERO
     C           F1CUST    IFNE PUCUST
     C                     ITER
     C                     END
     C                     END
     C* DELI
     C           F1NONY    IFNE *ZERO
     C           F1NONY    IFNE PUNONY
     C                     ITER
     C                     END
     C                     END
     C* DOCK
     C           F1NUKE    IFNE *BLANK
     C           F1NUKE    IFNE PUNUKE
     C                     ITER
     C                     END
     C                     END
     C* BIN#
     C           F1BINN    IFNE *ZERO
     C           F1BINN    IFNE PUBINN
     C                     ITER
     C                     END
     C                     END
     C* STATUS
     C           F1STS     IFEQ 'Y'
     C           PUASDT    IFNE *ZERO
     C                     ITER
     C                     END
     C                     END
     C*
     C           K#L1NA    KLIST
     C                     KFLD           PUNOYY
     C                     KFLD           PUNOMM
     C                     KFLD           PUNODD
     C                     KFLD           PUBINN
     C                     KFLD           PUCUST
     C                     KFLD           PUNONY
     C                     KFLD           PUNKOJ
     C                     KFLD           PUNUKE
     C           K#L1NA    SETLLAB#PL1N
     C                     DO   *HIVAL
     C           K#L1NA    READEAB#PL1N                  96
     C   96                LEAVE
     C           BASKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           PUODRN    IFNE *BLANK
     C           PUODRN    IFNE BAODRN
     C                     ITER
     C                     END
     C                     END
     C                     LEAVE
     C                     ENDDO
     C   96                ITER
     C*
     C* CREATE SUB-FILE
     C                     CLEARSFL020
     C*
     C                     MOVELPUCUST    S2CUST
     C                     MOVELPUNONY    S2NONY
     C                     MOVELPUNUKE    S2NUKE
     C                     Z-ADDPUBINN    S2BINN
     C                     MOVELPUSERL    S2SERL
     C                     Z-ADDPULPDT    S2LPDT
     C                     MOVELPUODRN    S2ODRN
     C                     Z-ADDPUASDT    S2ASDT
     C                     Z-ADDPUSPDT    S2SPDT
     C                     MOVELPUNKOJ    H2NKOJ
     C           K#GADP    KLIST
     C                     KFLD           PUCUST
     C                     KFLD           PUNONY
     C                     KFLD           PUNKOJ
     C                     KFLD           PUNUKE
     C           K#GADP    CHAINGADPL11              95
     C  N95                MOVELB5KMEI    S2SHNM
     C                     Z-ADDPUNODT    S2SHDT
     C*
     C           PUASDT    IFEQ *ZERO
     C                     MOVEL*ON       *IN52
     C                     ELSE
     C                     MOVEL*OFF      *IN52
     C                     END
     C*
     C                     MOVEL*ALL'-'   S2DUMY
     C*
     C                     ADD  1         RRN2
     C                     WRITESFL020
     C*
     C           RRN2      IFEQ 9999
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C           RRN2      IFEQ *ZERO
     C                     CLEARSFL020
     C                     Z-ADD1         RRN2
     C                     MOVEL*ON       *IN51
     C                     WRITESFL020
     C                     MOVEL*OFF      *IN51
     C                     MOVEL*ON       *IN49
     C                     MOVELERR,2     MSG
     C                     END
     C*
     C           RRN2      IFEQ 9999
     C                     MOVEL*ON       *IN49
     C                     MOVELERR,3     MSG
     C                     END
     C*
     C                     Z-ADDF1SHFY    W1SHFY
     C                     Z-ADDF1SHFM    W1SHFM
     C                     Z-ADDF1SHFD    W1SHFD
     C                     Z-ADDF1SHTY    W1SHTY
     C                     Z-ADDF1SHTM    W1SHTM
     C                     Z-ADDF1SHTD    W1SHTD
     C                     Z-ADDF1CUST    W1CUST
     C                     Z-ADDF1NONY    W1NONY
     C                     MOVELF1NUKE    W1NUKE
     C                     Z-ADDF1BINN    W1BINN
     C                     MOVELF1STS     W1STS
     C*
     C                     ENDSR
     C******************************************************
     C*  @F3RTN
     C******************************************************
     C           @F3RTN    BEGSR
     C*
     C                     Z-ADD*ZERO     RRN2    40
     C*
     C                     DO   *HIVAL
     C*
     C                     ADD  1         RRN2
     C           RRN2      CHAINSFL020               94
     C   94                LEAVE
     C           S2SEL     IFEQ *BLANK
     C                     ITER
     C                     END
     C*
     C                     MOVEL*BLANK    S2SEL
     C           S2ASDT    IFEQ *ZERO
     C                     MOVEL*ON       *IN52
     C                     ELSE
     C                     MOVEL*OFF      *IN52
     C                     END
     C                     UPDATSFL020
     C*
     C                     EXSR @F3SET
     C                     Z-ADD1         W#RNP3  40
     C*
     C                     DO   *HIVAL
     C*
     C                     MOVEL*ON       *IN48
     C                     MOVEL*OFF      *IN47
     C                     WRITEFMT099
     C                     Z-ADDW#RNP3    #RCN03
     C                     EXFMTCTL030
     C   KA
     COR KL                LEAVE
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP3
     C                     END
     C*
     C                     ENDDO
     C*
     C   KA                LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  SFL030 SET
     C******************************************************
     C           @F3SET    BEGSR
     C*
     C                     MOVEL*ON       *IN61
     C                     WRITECTL030
     C                     MOVEL*OFF      *IN61
     C                     MOVEL*OFF      *IN62
     C                     Z-ADD*ZERO     RRN3    40
     C*
     C                     Z-ADDS2SHDT    C3SHDT
     C                     MOVELS2CUST    C3CUST
     C                     MOVELS2NONY    C3NONY
     C                     MOVELH2NKOJ    C3NKOJ
     C                     MOVELS2NUKE    C3NUKE
     C                     Z-ADDS2BINN    C3BINN
     C                     MOVELS2SHNM    C3SHNM
     C                     MOVELS2SERL    C3SERL
     C*
     C           K#L1NB    KLIST
     C                     KFLD           W3SHYY
     C                     KFLD           W3SHMM
     C                     KFLD           W3SHDD
     C                     KFLD           S2BINN
     C                     KFLD           K@CUST
     C                     KFLD           K@NONY
     C                     KFLD           H2NKOJ
     C                     KFLD           S2NUKE
     C                     Z-ADDS2SHDT    W3SHDT
     C                     MOVELS2CUST    K@CUST  40
     C                     MOVELS2NONY    K@NONY  40
     C           K#L1NB    SETLLAB#PL1N
     C*
     C                     DO   *HIVAL
     C           K#L1NB    READEAB#PL1N                  96
     C   96                LEAVE
     C           BASKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           S2ODRN    IFNE *BLANK
     C           S2ODRN    IFNE BAODRN
     C                     ITER
     C                     END
     C                     ELSE
     C           K#L75C    KLIST
     C                     KFLD           BANOYY
     C                     KFLD           BANOMM
     C                     KFLD           BANODD
     C                     KFLD           BATOKU
     C                     KFLD           BANONY
     C                     KFLD           BANKOJ
     C                     KFLD           BANUKE
     C                     KFLD           BANOBN
     C                     KFLD           BADEYY
     C                     KFLD           BADEMM
     C                     KFLD           BADEDD
     C                     KFLD           BAODRN
     C           K#L75C    CHAINAB#PL75              90
     C           *IN90     IFEQ *OFF
     C           PUSKJY    ANDEQ' '
     C                     ITER
     C                     END
     C                     END
     C*
     C* CREATE SUB-FILE
     C                     CLEARSFL030
     C*
     C                     MOVELBAMHN1    W3MHI1
     C                     MOVELBAMHN2    W3MHI2
     C                     MOVELBAMHN3    W3MHI3
     C                     MOVELW3MHIN    S3MHIN
     C                     MOVELBASHN1    W3SHI1
     C                     MOVELBASHN2    W3SHI2
     C                     MOVELBASHN3    W3SHI3
     C                     MOVELW3SHIN    S3SHIN
     C                     MOVELBASBAN    S3SBAN
     C           BAUSYS    IFNE *ZERO
     C                     Z-ADDBAUSYS    S3SYOS
     C                     ELSE
     C                     Z-ADDBASYOS    S3SYOS
     C                     END
     C                     Z-ADDBASRYO    S3SRYO
     C                     MOVELBAINVN    S3INVN
     C                     MOVELBAODRN    S3ODRN
     C*
     C                     ADD  1         RRN3
     C                     WRITESFL030
     C*
     C           RRN3      IFEQ 9999
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C           RRN3      IFEQ *ZERO
     C                     CLEARSFL030
     C                     Z-ADD1         RRN3
     C                     WRITESFL030
     C                     MOVEL*ON       *IN49
     C                     MOVELERR,2     MSG
     C                     END
     C*
     C           RRN2      IFEQ 9999
     C                     MOVEL*ON       *IN49
     C                     MOVELERR,3     MSG
     C                     END
     C*
     C                     ENDSR
** ERR
