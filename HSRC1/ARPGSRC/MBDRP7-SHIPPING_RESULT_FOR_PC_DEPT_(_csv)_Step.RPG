     H            Y.                                    1
     F** MBDRP7 ********************************************
     F*  SHIPPING RESULT FOR PC DEPT                       *
     F*  J.W.      209.04.26                               *
     F******************************************************
     FMBDPWP7 CF  E                    WORKSTN
      *-----------------------------------------------------
     E                    ERR     1  80 65
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
     C           KEYB21    KLIST
     C                     KFLD           #KCODE  40
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     C                     EXSR #INIT
      *
     C           *IN01     DOWEQ*OFF
     C           DSPSW1    ANDEQ'1'
     C                     EXSR #MAIN
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C                     MOVE '1'       DSPSW1  1
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  MAIN ROUTINE
      *----------------------------------------------------*
     C           #MAIN     BEGSR
      *
     C                     EXFMTDSP01
     C                     SETOF                     99
     C                     SETOF                     313233
     C                     SETOF                     343536
     C                     SETOF                     3738
     C                     SETOF                     39
     C                     MOVE *BLANK    MSG
      *----------------*
      * F1: EXIT
      *----------------*
     C           *INKA     IFEQ *ON
     C                     GOTO $S210E
     C                     ENDIF
      *------------------------------*
      * F10: CUSTOMER GROUP MAINT
      *------------------------------*
     C           *INKJ     IFEQ *ON
     C                     CALL 'EDIC53'
     C                     GOTO $S210E
     C                     ENDIF
      *
     C           @TOKU     IFEQ 0
     C                     SETON                     9931
     C                     SETOF                     05
     C                     MOVELERR,05    MSG
     C                     GOTO $S210E
     C                     ENDIF
      *
     C           @YYYY     IFEQ 0
     C                     SETON                     9935
     C                     SETOF                     05
     C                     MOVELERR,01    MSG
     C                     GOTO $S210E
     C                     END
      *
     C           @MMMM     IFGE 1
     C           @MMMM     ANDLE12
     C                     ELSE
     C                     SETON                     9936
     C                     SETOF                     05
     C                     MOVELERR,02    MSG
     C                     GOTO $S210E
     C                     END
     C*
     C           @SIZI     IFNE '1'
     C           @SIZI     ANDNE'2'
     C           @SIZI     ANDNE'3'
     C                     SETON                     9937
     C                     SETOF                     05
     C                     MOVELERR,06    MSG
     C                     GOTO $S210E
     C                     END
      *
      *----------------*
      * F05: RUN
      *----------------*
     C           *IN05     IFEQ '1'
     C                     EXSR $SB500
      **
     C           P@STS     IFNE ' '
     C                     SETON                     99
     C                     SETON                     313233
     C                     SETON                     343536
     C                     SETON                     37
     C                     SETON                     39
     C                     SETON                     99
     C                     MOVELERR,04    MSG
     C                     GOTO $S210E
     C                     END
      **
     C                     SETON                     01
      **
     C                     END
      *
     C           $S210E    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     C           $SB300    BEGSR
     C           $S300E    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     C           $SB500    BEGSR
      *
      **
     C                     MOVEL@TOKU     P@TOKU  4
     C                     MOVEL@NONY     P@NONY  4
     C                     MOVEL@NKOJ     P@NKOJ  1
     C                     MOVEL@NUKE     P@NUKE  4
     C                     MOVEL@YYYY     P@YYYY  4
     C                     MOVEL@MMMM     P@MMMM  2
     C                     MOVEL@SIZI     P@SIZI  1
     C                     MOVEL*BLANK    P@STS   1
     C                     CALL 'MBDRP7B'
     C                     PARM           P@TOKU
     C                     PARM           P@NONY
     C                     PARM           P@NKOJ
     C                     PARM           P@NUKE
     C                     PARM           P@YYYY
     C                     PARM           P@MMMM
     C                     PARM           P@SIZI
     C                     PARM           P@STS
     C           $S500E    ENDSR
      *----------------------------------------------------------------
** ERR
E-01 ENTER CORRECT YEAR
E-02 ENTER CORRECT MONTH
E-03 YEAR AND MONTH ARE INVALID
E-04 NO DATA
E-05 ENTER CUSTOMER CODE
E-06 ENTER RANGE 1, 2 OR 3
E-07
