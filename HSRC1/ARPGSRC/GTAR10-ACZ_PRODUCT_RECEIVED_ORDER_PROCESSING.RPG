     C                     MOVELAWNKOJ    G1NKOJ
     C                     MOVELAWNUKE    G1NUKE
     C                     MOVELW@ODR1    G1ODKG
     C                     Z-ADDW@ODR2    G1ODR1
     C                     Z-ADDW@ODR3    G1ODR2
     C                     MOVELW@ODR4    G1ODR3
     C                     MOVELAWITMN    G1ITEM
     C                     MOVELAWMHN1    G1IHN1
     C                     MOVELAWMHN2    G1IHN2
     C                     MOVELAWMHN3    G1IHN3
     C                     MOVELAWZETI    G1IID#
     C*
     C                     Z-ADDAWSRYO    G1JCHU
     C                     MOVELAWLOC     W@LOC
     C                     MOVELW@LOC1    G1ITK1
     C                     MOVELW@LOC2    G1ITK2
     C                     MOVELW@LOC3    G1ITK3
     C                     MOVELW@LOC4    G1ITK4
