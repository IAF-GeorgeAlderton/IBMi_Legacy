     C                     Z-ADDAWSHDT    WNYMD
     C                     Z-ADDWNOYY     G1NOKY
     C                     Z-ADDWNOMM     G1NOKM
     C                     Z-ADDWNODD     G1NOKD
     C*
     C                     Z-ADDWSSYYY    G1JSKY                       )
     C                     Z-ADDWSSMMM    G1JSKM                       ')
     C                     Z-ADDWSSDDD    G1JSKD
     C*
     C                     MOVELWSHN1     G1SHN1
