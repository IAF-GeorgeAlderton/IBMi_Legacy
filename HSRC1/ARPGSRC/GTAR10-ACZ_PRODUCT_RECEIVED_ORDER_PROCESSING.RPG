     C                     Z-ADDA2SSYS    G1SSYS
     C                     Z-ADDA2KASI    G1KASI                       T')
     C                     MOVELA2KAST    G1KAST
     C                     MOVELA2ZETI    G1ZETI
     C                     MOVELA2STRK    G1STK1
     C                     MOVELA2STRT    G1STK2
     C                     MOVELA2STRR    G1STK3
     C                     MOVELA2STRD    G1STK4
     C                     END
     C*
     C                     Z-ADD01        G1BIN#
     C*
TCHK1C*                    DO   AW#BOX
TCHK1C           G1JCHU    DIV  G1SSYS    W@BOX   50
TCHK1C                     MVR            W@MVR   50
TCHK1C           W@MVR     IFNE *ZERO
TCHK1C                     ADD  1         W@BOX
TCHK1C                     END
TCHK1C*
TCHK1C                     DO   W@BOX
     C*
     C                     ADD  1         G1SHSQ
     C                     WRITEGTAPP101
     C*
     C                     ENDDO
     C*
     C                     ENDSR
