     C           1         SETLLAB#WACZ
     C*
     C                     DO   *HIVAL
     C                     READ AB#WACZ                  99
     C   99                LEAVE
     C           AWSHDT    IFEQ *ZERO
     C                     ITER
     C                     END
     C*
     C           K#GTA1    KLIST
     C                     KFLD           W@ODR1
     C                     KFLD           W@ODR2
     C                     KFLD           W@ODR3
     C                     KFLD           W@ODR4
     C                     KFLD           AWMHN1
     C                     KFLD           AWMHN2
     C                     KFLD           AWMHN3
     C                     KFLD           K@MHN4  5
     C                     KFLD           K@ITEM  50
     C                     MOVELAWORDN    W@ODR#
     C                     MOVEL*BLANK    K@MHN4
     C                     MOVELAWITMN    K@ITEM
     C           K#GTA1    CHAINGTAPL11              98
     C  N98                ITER
     C*
     C                     EXSR @OUT1
     C*
     C                     EXSR @OUT2
     C*
     C                     ENDDO
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
     C*------------------------------------------------------------
     C* INITIALIZE
     C*------------------------------------------------------------
     C           *INZSR    BEGSR
     C*
     C                     TIME           WSDT
     C*
     C                     MOVEL*OFF      W@1ST   1
     C*
     C                     ENDSR
     C*-----------------------------------------------------
     C           @OUT1     BEGSR
     C*
     C           W@1ST     IFEQ *OFF
     C                     CALL 'GTJYNO'
     C                     PARM           P@JYNO  7
     C                     MOVEL*ON       W@1ST
     C                     END
     C*
     C                     MOVELAWMHN1    WMHN1
     C                     MOVELAWMHN2    WMHN2
     C                     MOVELAWMHN3    WMHN3
     C                     MOVEL*BLANK    WMHN4
     C                     MOVELWMHIN     @MHIN  20 P
     C                     MOVEL*BLANK    @SHIN  12
     C                     MOVEL*BLANK    @FLG    1
     C                     MOVELAWTOKU    PTOKU
     C                     MOVELAWNONY    PNONY
     C                     MOVELAWNKOJ    PNKOJ
     C                     MOVELAWNUKE    PNUKE
      *
     C                     CALL 'BBHR50'
