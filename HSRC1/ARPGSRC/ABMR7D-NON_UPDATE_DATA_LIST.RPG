     H            Y.
     F** ABMR7D *********************************************
     F* NON UPDATE DATA LIST (KMAX>999)
     F*    HOTTA.               2018.08.23                  *
     F*******************************************************
     FABMWP21 IF  E           K        DISK
     FABMPL21 UF  E           K        DISK
     FABMWP70 O   E                    DISK                      A
      *
     I            DS
     I                                        1   80W@DATE
     I                                        1   40W@DAYY
     I                                        5   60W@DAMM
     I                                        7   80W@DADD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
      *
     I            DS
     I                                        1   8 CTIHZ
     I                                        1   2 CTIMM
     I                                        3   4 CTIDD
     I                                        5   8 CTIYY
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
     I              '#OF KANBAN MORE'     C         FNAM61
     I              'THAN 999 ERROR LIST' C         FNAM62
      *
     C           *ENTRY    PLIST
     C                     PARM           P@DTYM  60
     C                     PARM           P@OMIT  1
     C                     PARM           P@FNAM 30
      *
     C                     TIME           WTIME
      *
     C                     MOVE WTIMM     CTIMM
     C                     MOVE WTIDD     CTIDD
     C                     MOVE WTIYY     CTIYY
     C                     MOVEL*BLANK    P@FNAM
     C           FNAM61    CAT  FNAM62:1  P@FNAM
      *
     C           KEY21     KLIST
     C                     KFLD           K@DTYM
     C                     KFLD           W2SHN1
     C                     KFLD           W2SHN2
     C                     KFLD           W2SHN3
      *
     C                     Z-ADDP@DTYM    K@DTYM  60
     C           *LOVAL    SETLLABMWP211
     C                     READ ABMWP211                 87
     C           *IN87     DOWEQ'0'
     C           W2OMIT    IFEQ '6'
     C                     EXSR #SB001
     C           KEY21     CHAINABMPL211             21
     C           *IN21     IFEQ '0'
     C                     MOVEL'6'       S4OMIT
     C                     UPDATABMPL211
     C                     ENDIF
     C                     ENDIF
     C                     READ ABMWP211                 87
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------*
      * FCEPP01                                          *
      *--------------------------------------------------*
     CSR         #SB001    BEGSR
      *
     C                     CLEARABMWP701
     C                     Z-ADD*DATE     W0CRDT
     C                     MOVELW2SHN1    W0SHN1
     C                     MOVELW2SHN2    W0SHN2
     C                     MOVELW2SHN3    W0SHN3
     C                     Z-ADDW2NSRY    W0NSRY
     C                     Z-ADDW2NSRD    W0NSRD
     C                     Z-ADD0         W4NBXD
     C           W2SSYS    IFNE 0
     C           W2NSRD    DIV  W2SSYS    W4NBXD  72
     C                     ENDIF
     C           W4NBXD    ADD  0.09      W0NBXD
     C           W0NBXD    IFEQ 0
     C                     Z-ADD0.1       W0NBXD
     C                     ENDIF
     C                     Z-ADDW2NTYM    W0NTYM
     C                     MOVELW2OMIT    W0OMIT
     C                     Z-ADDW2FSMN    W0FSMN
     C                     Z-ADDW2FSM1    W0FSM1
     C                     Z-ADDW2USM1    W0USM1
     C                     Z-ADDW2USM2    W0USM2
     C                     Z-ADDW2USM3    W0USM3
     C                     Z-ADDW2FSDN    W0FSDN
     C                     Z-ADDW2FSD1    W0FSD1
     C                     Z-ADDW2USD1    W0USD1
     C                     Z-ADDW2USD2    W0USD2
     C                     Z-ADDW2USD3    W0USD3
     C                     Z-ADDW2NWDY    W0NWDY
     C                     Z-ADDW21WDY    W01WDY
     C                     MOVELW2PAS     W0PAS
     C                     Z-ADDW2GEKN    W0GEKN
     C                     Z-ADDW2HIKN    W0HIKN
     C                     Z-ADDW2STDY    W0STDY
     C                     Z-ADD0         W4NBXD
     C           W2SSYS    IFNE 0
     C           W2NSRD    DIV  W2SSYS    W4NBXD  72
     C                     ENDIF
     C           W4NBXD    ADD  0.09      W0NBXD
     C           W0NBXD    IFEQ 0
     C                     Z-ADD0.1       W0NBXD
     C                     ENDIF
     C           W2SSYS    IFNE 0
     C           W2HIKN    DIV  W2SSYS    W4BOXD  72
     C                     ENDIF
     C           W4BOXD    ADD  0.09      W0BOXD
     C           W0BOXD    IFEQ 0
     C                     Z-ADD0.1       W0BOXD
     C                     ENDIF
     C                     Z-ADDW2SSYS    W0SSYS
     C                     Z-ADD0         W4BOXP
     C           W0BOXD    IFNE 0
     C           W0NBXD    DIV  W0BOXD    W4BOXP  73
     C                     ENDIF
     C           W4BOXP    ADD  0.009     W0BOXP
     C           W0NBXD    SUB  W0BOXD    W0BOXS
     C                     Z-ADDW2YMD3    W0YMD3
     C                     Z-ADD0         W0RITU
     C           W0BOXP    IFGE 1
     C           W0BOXP    SUB  1         W0RITU
     C                     ELSE
     C           1         SUB  W0BOXP    W0RITU
     C                     ENDIF
     C                     WRITEABMWP701
      *
     CSR         ESB001    ENDSR
