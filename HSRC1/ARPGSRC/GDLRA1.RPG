     H            Y.
     FGDLPPA0 IF  E           K        DISK
     C           *ENTRY    PLIST
     C                     PARM           P@COIL  41
     C                     PARM           P@RATE  52
      *
     C                     Z-ADDP@COIL    N@COIL  41
     C                     Z-ADD0         P@RATE
      *
     C           *LOVAL    SETLLGDLPPA0
     C                     DO   *HIVAL
     C                     READ GDLPPA0                  88
     C   88                LEAVE
     C*
     C           AHSKJY    IFEQ 'D'
     C                     ITER
     C                     END
     C*
     C* 1 : <    LT
     C* 2 : >    GT
     C* 3 : =    EQ
     C* 4 : <=   LE
     C* 5 : >=   GE
     C* 6 : <>   NE
     C*
     C           AHFUGO    IFEQ '1'
     C           N@COIL    IFLT AHHTSU
     C                     Z-ADDAHKISU    P@RATE
     C                     LEAVE
     C                     END
     C                     END
      *
     C           AHFUGO    IFEQ '2'
     C           N@COIL    IFGT AHHTSU
     C                     Z-ADDAHKISU    P@RATE
     C                     LEAVE
     C                     END
     C                     END
      *
     C           AHFUGO    IFEQ '3'
     C           N@COIL    IFEQ AHHTSU
     C                     Z-ADDAHKISU    P@RATE
     C                     LEAVE
     C                     END
     C                     END
      *
     C           AHFUGO    IFEQ '4'
     C           N@COIL    IFLE AHHTSU
     C                     Z-ADDAHKISU    P@RATE
     C                     LEAVE
     C                     END
     C                     END
      *
     C           AHFUGO    IFEQ '5'
     C           N@COIL    IFGE AHHTSU
     C                     Z-ADDAHKISU    P@RATE
     C                     LEAVE
     C                     END
     C                     END
      *
     C           AHFUGO    IFEQ '6'
     C           N@COIL    IFNE AHHTSU
     C                     Z-ADDAHKISU    P@RATE
     C                     LEAVE
     C                     END
     C                     END
     C*
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
