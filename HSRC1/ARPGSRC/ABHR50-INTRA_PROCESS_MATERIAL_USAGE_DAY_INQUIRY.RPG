     FABHPW50 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL010
     F                                              KINFDS @INFDS
     FABHTL02 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FIZAPL01 IF  E           K        DISK
     FABHWP50 UF  E           K        DISK                      A
      *---------------------------------------------------
     E                    ERR     1   5 78
      *---------------------------------------------------
     I@INFDS      DS
     I                                     *STATUS  @STTS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME(6) + DATE(6)
     I            DS
     I                                        1  140WWTIME
     I                                        1   60WTIME
     I                                        1   40WTIM4
     I                                        1   20WTIMHH
     I                                        3   40WTIMMM
     I                                        7  120WSDATE
     I                                        9  120@@YM4
     I                                        7  120@@YM6
     I                                        7  140@@YMD
     I                                        7  100@@YY
     I                                       11  120@@MM
     I                                       13  140@@DD
     C******************************************************
     C*  MAIN
     C******************************************************
     C*
     C                     EXSR @INT
     C*
     C                     EXSR @F1RTN
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C*
     C******************************************************
     C*  INITTIAL SET
     C******************************************************
     C           @INT      BEGSR
     C*
     C                     TIME           WWTIME
     C*
     C                     ENDSR
     C******************************************************
     C*  @F1RTN
     C******************************************************
     C           @F1RTN    BEGSR
     C*
     C                     EXSR @F1SET
     C*
     C                     Z-ADD1         W#RNP1  40
     C*
     C                     DO   *HIVAL
     C*
     C                     WRITEFMT099
     C                     Z-ADDW#RNP1    #RCN01
     C                     EXFMTCTL010
     C   KA                LEAVE
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP1
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  SFL010 SET
     C******************************************************
     C           @F1SET    BEGSR
     C*
     C                     MOVEL*ON       *IN61
     C                     WRITECTL010
     C                     MOVEL*OFF      *IN61
     C                     MOVEL*OFF      *IN62
     C                     Z-ADD*ZERO     RRN1    40
     C*
     C           *LOVAL    SETLLABHTL02
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ABHTL02                  98
     C   98                LEAVE
     C           M6SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           M6STYY    IFNE 9999
     C                     ITER
     C                     END
     C           M6AKT1    IFEQ 'HD '
     C           M6AKT1    OREQ 'BM '
     C           M6AKT1    OREQ 'NF '
     C                     ELSE
     C                     ITER
     C                     END
     C*
     C           K#WP50    KLIST
     C                     KFLD           M6ZAI1
     C                     KFLD           M6ZAI2
     C                     KFLD           M6KBN1
     C           K#WP50    CHAINABHWP50              97
     C           *IN97     IFEQ *ON
     C                     CLEARABHWP50R
     C                     MOVELM6ZAI1    W5ZAI1
     C                     Z-ADDM6ZAI2    W5ZAI2
     C                     MOVELM6KBN1    W5MCH#
     C           K#IZA     KLIST
     C                     KFLD           M6ZAI1
     C                     KFLD           M6ZAI2
     C           K#IZA     SETGTIZAPL01
     C                     DO   *HIVAL
     C           K#IZA     REDPEIZAPL01                  96
     C   96                LEAVE
     C           ZCSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           ZCSTYY    IFEQ 9999
     C                     ELSE
     C                     ITER
     C                     END
     C                     Z-ADDZCTKJR    W5COIL
     C                     LEAVE
     C                     ENDDO
     C                     END
     C           K#FCE     KLIST
     C                     KFLD           M6HIN1
     C                     KFLD           M6HIN2
     C                     KFLD           M6HIN3
     C           K#FCE     CHAINFCEPL01              96
     C           *IN96     IFEQ *OFF
     C                     Z-ADDA2SOZI    W@SOZI  72
     C                     ELSE
     C                     Z-ADD*ZERO     W@SOZI
     C                     END
     C*
     C           M6KSSU    DIV  20        W@KSSU 112
     C           W@KSSU    MULT W@SOZI    W@WGHT 112
     C*
     C                     ADD  W@WGHT    W5USE
     C*
     C   97                WRITEABHWP50R
     C  N97                UPDATABHWP50R
     C*
     C                     ENDDO
     C* ----------------------------------------------------
     C           *LOVAL    SETLLABHWP50
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ABHWP50                  95
     C   95                LEAVE
     C*
     C                     MOVELW5ZAI1    S1ZAI1
     C                     Z-ADDW5ZAI2    S1ZAI2
     C                     MOVELW5MCH#    S1MCH#
     C           W5USE     DIV  1000      S1USE
     C                     Z-ADDW5COIL    S1COIL
     C           S1COIL    IFNE *ZERO
     C           S1USE     DIV  S1COIL    W@CDAY 104H
     C           W@CDAY    MULT 100       S1CDAY    H
     C                     END
     C*
     C                     ADD  1         RRN1
     C                     WRITESFL010
     C*
     C           RRN1      IFEQ 9999
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C           RRN1      IFEQ *ZERO
     C                     CLEARSFL010
     C                     Z-ADD1         RRN1
     C                     WRITESFL010
     C                     MOVEL*ON       *IN99
     C                     MOVELERR,1     MSG
     C                     END
     C*
     C           RRN1      IFEQ 9999
     C                     MOVEL*ON       *IN99
     C                     MOVELERR,2     MSG
     C                     END
     C*
     C                     ENDSR
