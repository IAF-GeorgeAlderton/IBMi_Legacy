     C****************************************************************
     C* CL.4.2.4.2  ﾆﾏlﾒﾑh ﾆﾞﾑci] n ﾒﾇn ﾅhﾈb                         *
     C****************************************************************
     C           *IN20     IFEQ '1'
     C                     SETOF                     11
     C           ZKEY      CHAINFCLNL111             11
     C           *IN11     IFEQ '1'
     C                     EXSR #EDIT
     C                     GOTO LI1
     C                     ELSE
      *
     C           P7SKJY    IFEQ 'D'
     C                     EXSR #EDIT
     C                     GOTO LI1
     C                     END
     C                     GOTO LI1
     C                     END
     C                     ELSE
      *
     C           P5SKJY    IFEQ 'D'
     C                     SETON                     20
     C                     EXSR #EDIT
     C                     GOTO LI1
     C                     END
     C                     END
      *
