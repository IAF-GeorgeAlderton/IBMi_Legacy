     C           *ENTRY    PLIST
     C                     PARM           PUS    10
      *
     C           ZKEY      KLIST
     C                     KFLD           LNO1
     C                     KFLD           LNO2
     C                     KFLD           LNO3
     C                     KFLD           LNO4
      *
     C           DAYKEY    KLIST
     C                     KFLD           UYY
     C                     KFLD           UMM
     C                     KFLD           UDD
      *
     C****************************************************************
     C* CL.4.2.1  fﾞx] ﾎb-ﾓnﾞ ﾉ hﾒa-                                 *
     C****************************************************************
     C                     SETOF                     10
     C                     Z-ADD*YEAR     UYY
     C                     Z-ADDUMONTH    UMM
     C                     Z-ADDUDAY      UDD
      *
     C           DAYKEY    SETGTAGDPL111
     C                     Z-ADD1         X       20
     C           1         DO   2         X
     C                     READPAGDPL111                 50
     C   50                GOTO NNNN
     C                     END
     C                     GOTO STEP1
      *
     C           NNNN      TAG
     C                     MOVELER,2      MSG
     C                     SETON                     1099
     C                     Z-ADD0         YYMMDD
     C                     GOTO STEP2
      *
     C           STEP1     TAG
     C                     Z-ADD0         YYMMDD
      *
     C****************************************************************
     C* CL.4.2.2  fﾞx] ﾍﾑcﾆﾞ  CMD kdlh                               *
     C****************************************************************
     C           STEP2     TAG
     C                     EXFMTFCLPW611
     C                     SETOF                     101199
      *
     C   KA                SETON                     LR
     C   KA                RETRN
      *
     C****************************************************************
     C* CL.4.2.3  fﾞx] ﾉ ﾍﾇﾞi kdlh                                   *
     C****************************************************************
     C                     MOVE *BLANK    ERSW    1
     C                     EXSR #CHE
     C           ERSW      CABEQ'*'       STEP2
      *
     C****************************************************************
     C* uﾇj- ﾃcﾆ] & ﾅhﾍﾑc                                            *
     C****************************************************************
     C                     EXSR #LIST
     C                     SETON                     LR
     C                     RETRN
      *
     C****************************************************************
     C* CL.4.2.3  ﾍﾇﾞi kdlh                                          *
     C****************************************************************
     C           #CHE      BEGSR
      *
     C           YY        IFLT 1990
     C                     MOVE '*'       ERSW
     C                     END
     C           MM        IFLT 1
     C                     MOVE '*'       ERSW
     C                     END
     C           MM        IFGT 12
     C                     MOVE '*'       ERSW
     C                     END
     C           DD        IFLT 1
     C                     MOVE '*'       ERSW
     C                     END
     C           DD        IFGT 31
     C                     MOVE '*'       ERSW
     C                     END
      *
     C           YYMMDD    IFGT F8YMD
     C                     MOVE '*'       ERSW
     C                     END
      *
     C           ERSW      COMP '*'                      10
     C   10                SETON                     99
     C   10                MOVELER,1      MSG
     C   10                GOTO STEPS1
      *
     C                     MOVE *DATE     CYMD
     C           CMM       IFEQ 01
     C           CYY       SUB  1         CYY
     C                     Z-ADD12        CMM
     C                     ELSE
     C           CMM       SUB  1         CMM
     C                     END
      *
     C           YYMM      IFGT CYM
     C                     SETON                     1099
     C   10                MOVELER,3      MSG
     C   10                GOTO STEPS1
     C                     END
     C           STEPS1    TAG
      *
     C           IKSDT     IFNE *BLANK
     C           IKSDT     IFNE '1'
     C                     SETON                     1199
     C                     MOVE ER,4      MSG
     C                     MOVE '*'       ERSW
     C                     END
     C                     END
      *
     C                     SETOF                     12
     C           IKSDT     IFEQ '1'
     C                     SETON                     12
     C                     END
      *
     C                     ENDSR
      *
     C****************************************************************
     C* CL.4.2.4  Z ﾌﾞ]k uﾇj- ﾒ-nﾞ                                   *
     C****************************************************************
     C           #LIST     BEGSR
      *
     C                     Z-ADD0         CNT1    40
     C                     Z-ADD0         CNT2    40
     C                     Z-ADD0         CNT3    40
     C                     TIME           TM      60
     C                     Z-ADDTM        TT
     C                     SETON                     OF
      *
     C           LI1       TAG
     C                     READ FCLPL211                 20
     C   20                GOTO LISTED
      *
     C****************************************************************
     C*           Z ﾌﾞ]k uﾇj- ﾑvnﾌﾞﾆ                                 *
     C****************************************************************
     C           P3SKJY    CABEQ'D'       LI1
     C           P3KSDT    CABNEIKSDT     LI1
      *
     C                     ADD  1         CNT1
     C           P3HINB    IFEQ *BLANK
     C                     ADD  1         CNT2
     C                     GOTO LI1
     C                     END
      *
     C****************************************************************
     C* CL.4.2.4.1  iﾞ]mb ﾓbﾈg ﾒ-nﾞ                                  *
     C****************************************************************
     C                     MOVE P3LNO1    LNO1
     C                     MOVE P3LNO2    LNO2
     C                     MOVE P3LNO3    LNO3
     C                     MOVE P3LNO4    LNO4
