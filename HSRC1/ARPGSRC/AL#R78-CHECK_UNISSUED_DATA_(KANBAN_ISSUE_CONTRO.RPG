     H            Y.
     F** AL#R78 **************************************
     F*発行制御ファイル　未発行データのチェック    *
     F*        ITS.         2015.05.26               *
     F************************************************
     FAL#PL71 IF  E           K        DISK
     FAL#PLD1 IF  E           K        DISK
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WKST
     I                                        1   80WKSTHZ
     I                                        9  140WKSTTI
      *
     I            DS
     I                                        1  140C7ST
     I                                        1   80C7STHZ
     I                                        9  140C7STTI
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P9FLG   1
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     MOVEL'0'       P9FLG
     C                     Z-ADD0         WKST
     C                     Z-ADDSDATE     WKSTHZ
     C                     Z-ADDSTIME     WKSTTI
     C           KEYC7     KLIST
     C                     KFLD           KKNKHZ  80
     C                     KFLD           KKNKTI  60
      *抜き出し前
      *再発行データ
     C                     Z-ADD0         KKNKHZ
     C                     Z-ADD0         KKNKTI
     C                     MOVEL'0'       GET     1
     C           KEYC7     SETLLAL#PLD11
     C           KEYC7     READEAL#PLD11                 81
     C           *IN81     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           CDSKJY    IFEQ 'D'
     C           CDSKHZ    ANDLESDATE
     C                     ELSE
     C                     MOVEL'1'       GET     1
     C                     MOVEL'1'       P9FLG
     C                     ENDIF
     C           KEYC7     READEAL#PLD11                 81
     C                     ENDDO
      *通常データ
     C                     Z-ADD0         KKNKHZ
     C                     Z-ADD0         KKNKTI
     C******               MOVEL'0'       GET     1
     C           KEYC7     SETLLAL#PL711
     C           KEYC7     READEAL#PL711                 81
     C           *IN81     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           C7SKJY    IFEQ 'D'
     C           C7SKHZ    ANDLESDATE
     C                     ELSE
     C           C7ST      IFLE WKST
     C                     MOVEL'1'       GET     1
     C                     MOVEL'1'       P9FLG
     C                     ENDIF
     C                     ENDIF
     C           KEYC7     READEAL#PL711                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
