     H            Y
     F**ALDRT4 ********************************************************
     F* GET DS UNLOADING  AJSPP60
     F*  2019.09.17      SAKAKI                                       *
     F*****************************************************************
     FAJSPL62 IF  E           K        DISK                           UC
      *===============================================================
     I****************************
     I*プログラム状況データ構造*
     I****************************
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
     **かんばん発行日
     I            DS
     I                                        1   80W$HTHZ
     I                                        1   40W$HTYY
     I                                        5   60W$HTMM
     I                                        7   80W$HTDD
     **投入日
     I            DS
     I                                        1   80J6KEHZ
     I                                        1   40J6KEIY
     I                                        5   60J6KEIM
     I                                        7   80J6KEID
     **投入時刻
     I            DS
     I                                        1   60J6KETM
     I                                        1   20J6KEIJ
     I                                        3   40J6KEIF
     I                                        5   60J6KEIB
     **
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *===============================================================
     C           *ENTRY    PLIST
     C*                                IN ------
     C                     PARM           P@HIN1  5        PART NUMBER 1
     C                     PARM           P@HIN2  5        PART NUMBER 2
     C                     PARM           P@HIN3  2        PART NUMBER 3
     C                     PARM           P@THAI  3        PRODUCTION ORDER
     C                     PARM           P@PAGE  2        PAGE
     C                     PARM           P@HTHZ  80       KANBAN PUBLICATION
     C*                               OUT ------
     C                     PARM           P@KEHZ  80       WORK ADMITTABLE DATE
     C                     PARM           P@KETM  60       WORK ADMITTABLE TIME
     C                     PARM           P#OPN   1
     C           P#OPN     IFEQ '9'
     C           OPNFL     IFEQ '1'
     C                     CLOSEAJSPL62
     C                     ENDIF
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
     C           OPNFL     IFEQ *BLANK
     C                     MOVEL'1'       OPNFL   1
     C                     OPEN AJSPL62
     C                     ENDIF
     C*------------------------*
     C*   KLIST の作成       *
     C*------------------------*
     C           #KEY1     KLIST
     C                     KFLD           P@HIN1  5        PART NUMBER 1
     C                     KFLD           P@HIN2  5        PART NUMBER 2
     C                     KFLD           P@HIN3  2        PART NUMBER 3
     C                     KFLD           P@THAI  3        PRODUCTION ORDER
     C                     KFLD           W$HTYY  40       KANBAN PUBLICATION Y
     C                     KFLD           W$HTMM  20       KANBAN PUBLICATION M
     C                     KFLD           W$HTDD  20       KANBAN PUBLICATION D
     C           #KEY11    KLIST
     C                     KFLD           P@HIN1  5        PART NUMBER 1
     C                     KFLD           P@HIN2  5        PART NUMBER 2
     C                     KFLD           P@HIN3  2        PART NUMBER 3
     C                     KFLD           P@THAI  3        PRODUCTION ORDER
      *===============================================================
     C                     Z-ADDP@HTHZ    W$HTHZ           KANBAN PUBLICATION
     C                     Z-ADD0         P@KEHZ  80       WORK ADMITTABLE DATE
     C                     Z-ADD0         P@KETM  60       WORK ADMITTABLE TIME
     C           #KEY1     SETLLAJSPL62
     C*
     C           #KEY11    READEAJSPL62                  90
     C*
     C           *IN90     DOWEQ*OFF
     C***        J6KEHZ    IFGE W$HTHZ
     C           J6PAG1    IFEQ P@PAGE
     C           J6PAG2    OREQ P@PAGE
     C           J6PAG3    OREQ P@PAGE
     C           J6PAG4    OREQ P@PAGE
     C                     Z-ADDJ6KEHZ    P@KEHZ  80       WORK ADMITTABLE DATE
     C                     Z-ADD0         J6KEIB
     C                     Z-ADDJ6KETM    P@KETM  60       WORK ADMITTABLE TIME
     C                     LEAVE
     C                     ENDIF
     C**                   ENDIF
     C           #KEY11    READEAJSPL62                  90
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
