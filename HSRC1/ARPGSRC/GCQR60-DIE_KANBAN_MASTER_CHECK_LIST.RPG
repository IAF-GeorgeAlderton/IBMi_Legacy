     H            Y/
     F***************************************************
     F*  DIE KANBAN MASTER CHECK LIST                   *
     F*                                                 *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FGCQPW60 CF  E                    WORKSTN
     FGCQPL12 IF  E           K        DISK
     FGCQTL31 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FFCQPL41 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *------------------------------------------------------------
     E                    MSG     1   1 78
      *------------------------------------------------------------
     I            DS
     I                                        1  15 DFKA
     I                                        1   2 T6KAT1
     I I            '-'                       3   3 D2
     I                                        4   7 T6KAT2
     I                                        1   2 ATM1
     I                                        4   7 ATM2
     I                                        9   9 ATM3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#KEY     KLIST
     C                     KFLD           DFSHN1
     C                     KFLD           DFSHN2
     C                     KFLD           DFSHN3
     C           K#KEYX    KLIST
     C                     KFLD           K@KAT1
     C                     KFLD           K@KAT2
     C                     KFLD           K@KAT3
      *
     C                     MOVEL'01'      W@ID    2
     C           *LIKE     DEFN T6KAT1    K@KAT1
     C           *LIKE     DEFN T6KAT2    K@KAT2
     C           *LIKE     DEFN T6KAT3    K@KAT3
      *
     C                     MOVE *ALL'-'   @@LINE 70
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #OUT
     C                     MOVEL'99'      W@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     SETOF                     6199
     C                     MOVE *BLANK    D@MSG
     C           D@PCNT    IFEQ *ZERO
     C                     SETON                     6199
     C                     MOVE MSG,1     D@MSG
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   WRITE
      *------------------------------------------------------
     C           #OUT      BEGSR
      *
     C                     TIME           @@TIME  60
     C           *IN80     DOUEQ*ON
     C                     READ GCQPL12                  80
     C           *IN80     IFEQ *OFF
     C           T6SKJY    ANDEQ*BLANK
      *
     C                     MOVE T6KAT1    K@KAT1
     C                     MOVE T6KAT2    K@KAT2
     C                     MOVE T6KAT3    K@KAT3
     C           K#KEYX    SETGTGCQPL12
     C           K#KEYX    REDPEGCQPL12                  81
     C           *IN81     IFEQ *OFF
      *
     C                     Z-ADD*ZERO     @@QTY  130
     C           DFKA      SETLLGCQTL31
     C           *IN85     DOUEQ*ON
     C           DFKA      READEGCQTL31                  85
     C           *IN85     IFEQ *OFF
     C           DFSKJY    ANDEQ*BLANK
      *
     C           K#KEY     CHAINFCEPL01              90
     C           *IN90     IFEQ *OFF
     C           A2GSKD    ANDEQ*BLANK
     C                     ADD  A2GEKN    @@QTY
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C           K#KEYX    CHAINFCQPL41              90
     C           *IN90     IFEQ *OFF
     C           @@QTY     DIV  O7MSRY    @@QTY1  92
     C           @@QTY1    DIV  10000     @@QTY2  72
      *
     C           T6SRYO    SUB  @@QTY2    @@BAL   90
     C           @@BAL     IFLT *ZERO
     C                     Z-SUB@@BAL     @@BAL
     C                     ENDIF
     C           @@BAL     DIV  T6SRYO    @@PCNT  74
     C           @@PCNT    MULT 100       L@PCNT  41
     C           L@PCNT    IFGE D@PCNT
     C                     EXSR #PRNT
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
     C           K#KEYX    SETGTGCQPL12
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      * PRINT
      *------------------------------------------------------
     C           #PRNT     BEGSR
      *
      * KANBAN SHEETS SET
     C                     Z-ADD0         WKKOSU 112
     C           @@QTY2    MULT 4         WKSRYO 110
     C           T6SYOS    IFNE 0
     C           WKSRYO    DIV  T6SYOS    WKKOSU
     C                     ADD  0.9       WKKOSU
     C                     END
     C                     Z-ADDWKKOSU    @MAIS   50
     C           @MAIS     IFLT 3
     C                     Z-ADD3         @MAIS
     C                     END
      *
     C           T6MAIS    IFNE @MAIS
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
     C  N98                MOVE *ON       *IN98
     C                     EXCPT@DTL
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                         UDATE Y  110
     O                         @@TIME   119 '  :  :  '
     O                                  123 'P.'
     O                         PAGE  Z  127
     O        E   02           @HED
     O                                   50 'DIE KANBAN MASTER CHECK'
     O                                   55 'LIST'
     O        E   04           @HED
     O                                   43 '- CURRENT -'
     O                                   68 '--- NEW ---'
     O        E   05           @HED
     O                                    6 '%'
     O                                   12 'DIE NO'
     O                                   35 'QTY'
     O                                   46 '# OF KANB'
     O                                   60 'QTY'
     O                                   71 '# OF KANB'
     O        E   06           @HED
     O                         @@LINE    71
     O        E 1              @DTL
     O                         L@PCNT4    6
     O                         DFKA      23
     O                         T6SRYO1   35
     O                         T6MAIS4   43
     O                         @@QTY21   60
     O                         @MAIS 4   68
**
 ENTER % VALUE.
