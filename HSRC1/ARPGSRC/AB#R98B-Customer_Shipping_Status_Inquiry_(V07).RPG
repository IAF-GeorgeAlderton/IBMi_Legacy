     C                     SETON                     31  49
     C                     GOTO XCHK1
     C                     END
      * CHECK SHIP FROM
     C                     MOVELF1SHFR    $SRC      P
     C                     CALL 'UTLR01'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE   8
     C                     PARM           $RTN    1
     C           $RTN      IFNE *BLANK
     C                     MOVELERR,1     XMSG             INVALID FROM
     C                     SETON                     31  49
     C                     GOTO XCHK1
     C                     END
      *
     C           F1SHTO    IFEQ 0
     C                     Z-ADDF1SHFR    F1SHTO
     C                     END
      *
     C           F1SHTY    IFNE 0
     C           F1SHTY    ANDNE9999
     C           F1SHTM    IFEQ 0
