      *
     C                     SETOF                     053020
     C                     SETOF                     40
     C                     TIME           WTIME   60
      *
     C           IKUBN     IFEQ '000'
     C           ISIRE     IFEQ 'TTAI'
     C                     Z-ADD3556      WTOKU   40
     C                     Z-ADD3556      WNONY   40
     C                     ELSE
     C                     Z-ADD3550      WTOKU   40
     C                     Z-ADD3550      WNONY   40
     C                     ENDIF
     C                     MOVE '0'       WNKOJ   1
     C                     ENDIF
      *
     C           IKUBN     IFEQ 'BFR'
     C                     MOVE IRCVD     WDAT8
     C                     ENDIF
      *
     C           IKUBN     IFEQ 'N1 '
     C           IKID      ANDEQ'SU '
     C                     MOVE ISIRE     WSIRE   4
     C                     MOVE ISIRK     WSIRK   1
     C           WSIRK     IFEQ *BLANK
     C                     MOVE '0'       WSIRK
     C                     END
      *
     C                     END
      *
     C           IKUBN     IFEQ 'LIN'
     C                     MOVEAIMHIN     MHN
     C                     MOVE *BLANK    MHX
     C                     Z-ADD*ZERO     Y       20
     C           1         DO   20        X       20
     C           MHN,X     IFNE '-'
     C                     ADD  1         Y
     C                     MOVE MHN,X     MHX,Y
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEAMHX       WMHIN
     C                     MOVELISBAN     WSBAN   4
     C                     MOVE 'C'       WNOKN   1
     C                     END
      *
     C           IKUBN     IFEQ 'REF'
     C                     MOVELINUKE     WNUKE   4
     C                     ENDIF
      *
     C           IKUBN     IFEQ 'FST'
