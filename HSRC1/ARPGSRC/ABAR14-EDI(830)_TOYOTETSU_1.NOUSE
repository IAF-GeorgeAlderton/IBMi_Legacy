     C                     MOVE IODRK     WODRK   1
     C           IBLOT     IFEQ 'F'
     C                     MOVE 'F'       WBLOT   1
     C                     ELSE
     C                     MOVE *BLANK    WBLOT
     C                     ENDIF
      *
     C                     MOVE *ALL'0'   WNYMD
     C                     MOVE IDAT1     WNYMD
     C                     MOVE IDAT2     WEYMD   80
      *
     C           WODRK     IFEQ 'D'
     C           WSURY     ANDNE0
     C  N31                SETON                     3031
     C                     SETON                     20
      *
     C                     SETOF                     10
     C           KEY5      CHAINGADPL111             10
     C           *IN10     IFEQ '0'
     C           B5SKJY    ANDEQ'D'
     C           B5SKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
      *
     C           *IN10     IFEQ '1'
     C  N32                SETON                     4032
     C                     SETON                     05
     C                     ELSE
      *
     C                     Z-ADD0         B       20
     C                     Z-ADD0         HYM
     C                     Z-ADD0         WKAD    20
      *
     C           KEY4      SETLLAGDPL121
     C           *IN90     DOUEQ*ON
     C                     SETOF                     10
     C                     READ AGDPL121                 10
     C           *IN10     IFEQ '0'
     C           F8HIRU    ANDEQ*BLANK
     C           F8YORU    ANDEQ*BLANK
     C           F8KAHZ    IFGT WEYMD
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  1         B
     C                     ADD  1         WKAD
     C                     Z-ADDF8KAHZ    HYM,B
     C                     END
     C  N10                ENDDO
      *
     C           WKAD      IFNE *ZERO
     C           WSURY     DIV  WKAD      WKSUR   70H
      *
     C                     Z-ADD1         A       20
     C           1         DO   B         A
     C           HYM,A     IFNE 0
     C                     Z-ADDHYM,A     @NYMD
      *
     C                     SETOF                     11
     C           KEY2      CHAINABAWP2R1             11
     C           *IN11     IFEQ '1'
     C                     Z-ADDWTOKU     ABTOKU
     C                     Z-ADDWNONY     ABNONY
     C                     MOVE WNKOJ     ABNKOJ
     C                     MOVE WNUKE     ABNUKE
     C                     MOVE WSBAN     ABSBAN
     C                     MOVELWMHIN     ABMHIN
     C                     Z-ADD@NYM      ABDATE
     C                     Z-ADD0         HSU
     C                     Z-ADDWKSUR     HSU,D
     C                     XFOOTHSU       ABNNSU
     C                     MOVE WNOKN     ABNOKN
     C                     WRITEABAWP2R1
     C                     ELSE
      *
     C                     Z-ADDWKSUR     HSU,D
     C                     XFOOTHSU       ABNNSU
     C           ABNOKN    IFNE 'C'
     C                     MOVE WNOKN     ABNOKN
     C                     END
      *
     C                     UPDATABAWP2R1
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
