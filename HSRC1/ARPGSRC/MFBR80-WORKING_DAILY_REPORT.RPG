     FMFBPW80 CF  E                    WORKSTN
     FFGBPL01 IF  E           K        DISK
     FMFBPL09 IF  E           K        DISK
     FMFBWP80 O   F     200            DISK                      A
     E                    ER      1  14 60               ERROR MESSAGE
     I            DS
     I                                        1   8 SDATE
     I                                        1   4 SYY
     I                                        5   6 SMM
     I                                        7   8 SDD
     I            DS
     I                                        1   8 EDATE
     I                                        1   4 EYY
     I                                        5   6 EMM
     I                                        7   8 EDD
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
     I            DS
     I                                        1   80M1SKHZ
     I                                        1   40M1SKYY
     I                                        5   60M1SKMM
     I                                        7   80M1SKDD
     I            DS
     I                                        1   80M1SAHZ
     I                                        1   40M1SAYY
     I                                        5   60M1SAMM
     I                                        7   80M1SADD
     I            DS
     I                                        1   4 KB
     I                                        1   3 KB1
     I                                        4   4 KB2
     I            DS
     I                                        1   4 M1KB
     I                                        1   3 M1KIBN
     I                                        4   4 M1KIHS
      *
     C           *ENTRY    PLIST
     C                     PARM           NO
      *
     C                     MOVE *BLANK    NO
     C                     MOVE *BLANK    KOJ
     C                     MOVE *BLANK    KB1
     C                     MOVE *BLANK    KB2
     C                     MOVE *BLANK    KOU
     C                     MOVE *BLANK    SHI
     C                     MOVE *BLANK    SDATE
     C                     MOVE *BLANK    EDATE
     C                     MOVE *BLANK    #KOJ    40
     C           STEP1     TAG
     C                     EXFMTMFBPW801
     C                     SETOF                     010203
     C                     SETOF                     040506
     C                     SETOF                     070899
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
      *
     C           NO        IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STEP1
     C                     ENDIF
      *
     C           NO        IFLT '1'
     C           NO        ORGT '6'
     C                     SETON                     0199
     C                     MOVE ER,2      MSG
     C                     GOTO STEP1
     C                     ENDIF
      *
     C           KOJ       IFEQ *BLANK
     C           KB1       ANDEQ*BLANK
     C           KB2       ANDEQ*BLANK
     C           KOU       ANDEQ*BLANK
     C           SHI       ANDEQ*BLANK
     C                     SETON                     020506
     C                     SETON                     070899
     C                     MOVE ER,2      MSG
     C                     GOTO STEP1
     C                     END
      *
     C           KOJ       IFNE *BLANK
     C                     MOVELKOJ       #KOJ
     C                     SETOF                     70
     C           #KOJ      CHAINFGBPL011             70
     C           *IN70     IFEQ '1'
     C                     SETON                     0299
     C                     MOVE ER,2      MSG
     C                     GOTO STEP1
     C                     END
     C           *IN70     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     0299
     C                     MOVE ER,2      MSG
     C                     GOTO STEP1
     C                     END
     C                     END
      *
     C           SDATE     IFEQ *BLANK
     C                     SETON                     0399
     C                     MOVE ER,4      MSG
     C                     GOTO STEP1
     C                     ENDIF
      *
     C           EDATE     IFEQ *BLANK
     C                     SETON                     0499
     C                     MOVE ER,5      MSG
     C                     GOTO STEP1
     C                     ENDIF
      *
     C           SMM       IFGT '12'
     C           SMM       ORLT '01'
     C           SDD       ORGT '31'
     C           SDD       ORLT '01'
     C                     SETON                     0399
     C                     MOVE ER,2      MSG
     C                     GOTO STEP1
     C                     ENDIF
      *
     C           EMM       IFGT '12'
     C           EMM       ORLT '01'
     C           EDD       ORGT '31'
     C           EDD       ORLT '01'
     C                     SETON                     0499
     C                     MOVE ER,2      MSG
     C                     GOTO STEP1
     C                     ENDIF
      *
     C           SDATE     IFGT EDATE
     C                     SETON                     030499
     C                     MOVE ER,2      MSG
     C                     GOTO STEP1
     C                     ENDIF
      *
     C           *INKE     IFNE '1'
     C                     GOTO STEP1
     C                     ENDIF
      *
     C                     MOVE *BLANK    DFLG    1
     C                     MOVE SYY       SDATYY  40
     C                     MOVE SMM       SDATMM  20
     C                     MOVE SDD       SDATDD  20
      *
     C           KEY1      KLIST
     C                     KFLD           SDATYY
     C                     KFLD           SDATMM
     C                     KFLD           SDATDD
      *
     C                     Z-ADD0         WEDAT   80
     C                     MOVE EDATE     WEDAT
      *
     C           KEY1      SETLLMFBPL091
     C                     DO   *HIVAL
     C                     SETOF                     70
     C                     READ MFBPL091                 70
      *
     C           *IN70     IFEQ '1'
     C                     GOTO NDAT
     C                     ENDIF
      *
     C           *IN70     IFEQ '0'
     C           M1SKJY    IFEQ 'D'
     C           M1SKHZ    ANDLE*DATE
     C                     GOTO NDAT
     C                     ENDIF
     C           WEDAT     IFLT M1SAHZ
     C                     SETON                     70
     C                     GOTO NDAT
     C                     ENDIF
      *
     C           KOJ       IFNE *BLANK
     C           #KOJ      IFNE M1KJCD
     C                     GOTO NDAT
     C                     END
     C                     END
      *
     C           KB        IFNE *BLANK
     C           KB        IFNE M1KB
     C                     GOTO NDAT
     C                     END
     C                     END
      *
     C           KOU       IFNE *BLANK
     C           KOU       IFNE M1KTCD
     C                     GOTO NDAT
     C                     END
     C                     END
      *
     C           SHI       IFNE *BLANK
     C           SHI       IFNE M1HYKU
     C                     GOTO NDAT
     C                     END
     C                     END
      *
     C                     MOVE '*'       DFLG
     C                     EXCPTDAT
      *
     C                     ENDIF
      *
     C           NDAT      TAG
     C  N70                ENDDO
      *
     C           DFLG      IFEQ *BLANK
     C                     SETON                     010203
     C                     SETON                     040506
     C                     SETON                     070899
     C                     MOVE ER,2      MSG
     C                     GOTO STEP1
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
     OMFBWP80 EADD             DAT
