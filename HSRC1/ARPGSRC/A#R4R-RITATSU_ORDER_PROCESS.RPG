     C                     CLEARPT
     C                     Z-ADD*ZERO     P1      30
     C                     Z-ADD*ZERO     P2      30
     C                     DO   *HIVAL
     C                     ADD  1         P1
     C           AY,P1     IFEQ ','
     C                     LEAVE
     C                     END
     C           AY,P1     IFEQ '-'
     C                     ITER
     C                     END
     C                     ADD  1         P2
     C                     MOVELAY,P1     PT,P2
     C                     ENDDO
     C                     MOVEAPT        W#PART 17
