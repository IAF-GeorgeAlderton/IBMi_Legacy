TCHK3C   10      ','       LOKUPAY,X                     10
TCHK3C                     ADD  1         X
TCHK3C   10      ','       LOKUPAY,X                     10
TCHK2 *
     C                     CLEARDAT
     C                     DO   5         Y       30
      *
     C                     ADD  1         X
     C           '/'       LOKUPAY,X                     10
 B1  C           *IN10     IFEQ *OFF
     C                     LEAVE
 E1  C                     END
      *
     C                     Z-ADD*ZERO     YYMD
     C           X         SUB  2         X1
     C           X         SUB  1         X2
     C           AY,X1     IFGE '0'
     C           AY,X1     ANDLE'9'
     C                     MOVELAY,X1     MM
     C                     END
     C                     MOVE AY,X2     MM
     C           MM        IFLT W@DM
     C           W@DY      ADD  1         YYYY
     C                     ELSE
     C                     Z-ADDW@DY      YYYY
     C                     END
      *
     C           X         ADD  2         X3      30
     C           X         ADD  1         X4      30
     C           AY,X3     IFGE '0'
     C           AY,X3     ANDLE'9'
     C                     MOVE AY,X3     DD
     C                     MOVELAY,X4     DD
     C                     ELSE
     C                     MOVE AY,X4     DD
     C                     END
      *
     C                     Z-ADDYYMD      DAT,Y
      *
     C                     ENDDO
      *
     C           DAT,1     IFNE *ZERO
     C           DAT,2     ORNE *ZERO
     C           DAT,3     ORNE *ZERO
     C           DAT,4     ORNE *ZERO
     C           DAT,5     ORNE *ZERO
     C                     MOVE *ON       *IN98
     C                     END
     C                     GOTO @END
      *
 E0  C                     END
      * ----------------------------------------------------
      * DETAIL
      * ----------------------------------------------------
     C           AY,1      IFEQ ','
     C           AY,1      OREQ 'F'
     C                     MOVEL*ON       *IN97
     C                     END
      *
     C           *IN97     IFEQ *ON
     C                     GOTO @END
     C                     END
