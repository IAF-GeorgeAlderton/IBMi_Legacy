      *
     C                     MOVEADAT1      AY,1
     C*                    MOVEADAT2      AY,257
     C*                    MOVEADAT3      AY,513
      * ++++++++++++
      * HEADER
      * ++++++++++++
 B0  C           *IN99     IFEQ *OFF
      *
     C                     Z-ADD1         X       30
     C           'ORDER'   SCAN DAT1      X              10
     C  N10      'Order'   SCAN DAT1      X              10
 B1  C           *IN10     IFEQ *OFF
     C                     GOTO @END
 E1  C                     END
     C           'PO#'     SCAN DAT1      X              10
     C  N10      'Po#'     SCAN DAT1      X              10
 B1  C           *IN10     IFEQ *OFF
     C                     GOTO @END
 E1  C                     END
      *
     C                     CLEAROD
     C           X         ADD  3         X1      30
     C                     Z-ADD*ZERO     X2      30
     C                     DO   *HIVAL
     C           AY,X1     IFEQ ','
     C                     LEAVE
     C                     END
     C                     ADD  1         X2
     C           X2        IFGT 10
     C                     LEAVE
     C                     END
     C                     MOVELAY,X1     OD,X2
     C                     ADD  1         X1
     C                     ENDDO
     C                     MOVEAOD        W#ODRN 10
      *
     C                     MOVE *ON       *IN99
     C                     GOTO @END
      *
 E0  C                     ENDIF
      * ++++++++++++
      * SHIP DATE
      * ++++++++++++
 B0  C           *IN98     IFEQ *OFF
      *
     C                     Z-ADD1         X       30
     C           'PART'    SCAN DAT1      X              10
     C  N10      'Part'    SCAN DAT1      X              10
 B1  C           *IN10     IFEQ *OFF
     C                     GOTO @END
 E1  C                     END
TCHK2C*          'ORDER'   SCAN DAT1      X              10
TCHK2C* N10      'Order'   SCAN DAT1      X              10
TCHK2C*          *IN10     IFEQ *OFF
TCHK2C*                    GOTO @END
TCHK2C*                    END
      *
TCHK2C                     Z-ADD1         X
TCHK2 * SKIP
TCHK2C           ','       LOKUPAY,X                     10
TCHK2C                     ADD  1         X
TCHK2C   10      ','       LOKUPAY,X                     10
TCHK2C                     ADD  1         X
TCHK2C   10      ','       LOKUPAY,X                     10
TCHK2C                     ADD  1         X
