     FMBDWP41 IP  F     100            DISK
     FFCEPL81 IF  E           K        DISK
     FMBDPL01 IF  E           K        DISK
     FFAAPL04 IF  E           K        DISK
     FMBDPL41 UF  E           K        DISK                      A
     FMBDWP441O   F     100            DISK
     FMBDWP442O   F     100            DISK
     E                    HSR         6  7 0             実績数
     E                    HYM         6  6 0             ６ケ月日付
     IMBDWP41 AA  01
     I                                        1  12 DSHIN
     I                                        1   5 DSHN1
     I                                        6  10 DSHN2
     I                                       11  12 DSHN3
     I                                       32  37 DTKRO
     I                                       32  32 DTKR1
     I                                       33  34 DTKR2
     I                                       35  36 DTKR3
     I                                       37  37 DTKR4
     I                                       38  450DTAHZ
     I                                       38  430DTAYM
     I                                       38  410DTAYY
     I                                       42  430DTAMM
     I                                       44  450DTADD
     I                                    P  46  500DGEKN
     I            DS
     I                                        1   80F3SKHZ
     I                                        1   40F3SKYY
     I                                        5   60F3SKMM
     I                                        7   80F3SKDD
     I            DS
     I                                        1  12 F3SHIN
     I                                        1   5 F3SHN1
     I                                        6  10 F3SHN2
     I                                       11  12 F3SHN3
     I            DS
     I                                        1  15 F3MHIN
     I                                        1   5 F3MHN1
     I                                        6  10 F3MHN2
