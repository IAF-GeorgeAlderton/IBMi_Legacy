     I                                        1   60WYM
     I                                        1   40WYY
     I                                        5   60WMM
      *
     C           KEY1      KLIST
     C                     KFLD           DSHN1
     C                     KFLD           DSHN2
     C                     KFLD           DSHN3
      *
     C           *IN10     IFEQ '0'
     C                     SETON                     10
      *
     C           *ENTRY    PLIST
     C                     PARM           PNO     1
     C                     PARM           PHYM    6
     C                     PARM           PHYM2   6
     C                     MOVE PHYM2     WHYM2   60
     C                     MOVE PHYM2     WYM
      *
     C                     Z-ADD1         B       10
     C                     Z-ADD6         C       10
     C                     Z-ADD0         HYM
     C                     Z-ADDWYM       HYM,6
     C           2         DO   6         B
     C                     SUB  1         C
      *
     C           WMM       IFEQ 01
     C                     SUB  1         WYY
     C                     Z-ADD12        WMM
     C                     ELSE
     C                     SUB  1         WMM
     C                     END
      *
     C                     Z-ADDWYM       HYM,C
     C                     END
      *
     C                     MOVE HYM,1     PHYM
     C                     END
      *
     C                     SETOF                     06
     C                     Z-ADD0         HSR
     C                     MOVE *BLANK    WMHIN  15
     C                     Z-ADD0         WNONY   40
      *
     C*--------------------------*
     C*  ..納入統計ファイル..  *
     C*--------------------------*
     C                     SETOF                     02
     C           KEY1      SETLLMBDPL011
      *
     C                     DO   *HIVAL
     C                     SETOF                     03
     C           KEY1      READEMBDPL011                 03
     C           *IN03     IFEQ '0'
      *
     C                     SETON                     02
      *
     C           *IN06     IFEQ '0'
     C                     SETON                     06
     C                     MOVE F3MHIN    WMHIN
     C                     Z-ADDF3NONY    WNONY
     C                     END
      *
     C           F3NONY    IFEQ WNONY
     C                     ADD  F3ENSU    HSR,1
     C                     ADD  F3DNSU    HSR,2
     C                     ADD  F3CNSU    HSR,3
     C                     ADD  F3BNSU    HSR,4
     C                     ADD  F3ANSU    HSR,5
     C                     ADD  F3TNSU    HSR,6
     C                     ELSE
      *
     C                     EXSR SUBSU
     C                     EXSR SUBDT
      *
     C                     MOVE F3MHIN    WMHIN
     C                     Z-ADDF3NONY    WNONY
     C                     Z-ADDF3ENSU    HSR,1
     C                     Z-ADDF3DNSU    HSR,2
     C                     Z-ADDF3CNSU    HSR,3
     C                     Z-ADDF3BNSU    HSR,4
     C                     Z-ADDF3ANSU    HSR,5
     C                     Z-ADDF3TNSU    HSR,6
     C                     END
      *
     C                     END
     C  N03                END
      *
      *
     C           *IN02     IFEQ '1'
     C                     EXSR SUBSU
     C                     EXSR SUBDT
     C                     ELSE
      *
      *
     C                     Z-ADD6         WNGSU   10
      *
     C                     SETOF                     04
     C                     Z-ADD1         B
     C           DTAYM     LOKUPHYM,B                    04
     C           *IN04     IFEQ '1'
      *
     C                     Z-ADD1         A       10
     C                     Z-ADD0         WNGSU
     C           B         DO   6         A
     C                     ADD  1         WNGSU
     C                     END
     C                     END
      *
     C           KEY1      SETLLFAAPL04
     C           *IN90     DOUEQ*ON
     C           KEY1      READEFAAPL04                  90
     C           *IN90     IFEQ *OFF
     C           B7SKBN    ANDEQ*BLANK
     C           B7NONY    IFNE WNONY
     C           WNONY     ANDNE0
     C                     EXSR SUBSU
     C                     EXSR SUBDT
     C                     ENDIF
     C                     MOVE B7MHIN    WMHIN
     C                     Z-ADDB7NONY    WNONY
     C                     MOVE *ON       *IN02
     C                     ENDIF
     C                     ENDDO
      *
     C                     EXSR SUBDT
     C                     END
      *
      *
     C*----------------------*
     C*  ..サブルーチン..  *
     C*----------------------*
     C           SUBSU     BEGSR
      *
     C                     Z-ADD1         B
      *
     C                     SETOF                     04
     C                     Z-ADD1         C
     C           DTAYM     LOKUPHYM,C                    04
     C           *IN04     IFEQ '1'
     C                     Z-ADDC         B
     C                     END
      *
     C                     Z-ADD1         A
     C                     Z-ADD0         WNGSU
     C           B         DO   6         A
     C           HSR,A     IFEQ 0
     C                     ADD  1         WNGSU
     C                     ELSE
     C                     Z-ADD0         WNGSU
     C                     END
     C                     END
      *
     C                     ENDSR
      *
      *
     C*----------------------*
     C*  ..サブルーチン..  *
     C*----------------------*
     C           SUBDT     BEGSR
      *
     C           WNGSU     IFEQ 6
     C           *IN02     ANDEQ'0'
      *
     C*--------------------------------------*
     C*  ..実績無しユーザーコードデータ..  *
     C*--------------------------------------*
     C                     SETOF                     05
     C           KEY1      SETLLMBDPL411
      *
     C                     DO   *HIVAL
     C                     SETOF                     04
     C           KEY1      READEMBDPL411                 04
     C           *IN04     IFEQ '0'
      *
     C           F3SKJY    IFEQ 'D'
     C           F3SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     SETON                     05
     C                     Z-ADDF3NONY    WNONY
     C                     MOVE F3MHIN    WMHIN
     C                     EXSR SUBWT
      *
     C                     END
     C                     END
     C  N04                END
      *
     C           *IN05     IFEQ '0'
     C                     MOVE *BLANK    WMHIN
     C                     Z-ADD0         WNONY
     C                     EXSR SUBWT
     C                     END
      *
     C                     ELSE
      *
     C                     EXSR SUBWT
      *
     C           WNGSU     IFEQ 5
      *
     C*--------------------------------------*
     C*  ..実績無しユーザーコードデータ..  *
     C*--------------------------------------*
     C           KEY1      SETLLMBDPL411
     C                     DO   *HIVAL
     C                     SETOF                     04
     C           KEY1      READEMBDPL411                 04
     C           *IN04     IFEQ '0'
      *
     C           F3SKJY    IFEQ 'D'
     C           F3SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     MOVE 'D'       F3SKJY
     C                     Z-ADD*DATE     F3SKHZ
     C                     UPDATMBDPL411
      *
     C                     END
     C                     END
     C  N04                END
      *
     C                     MOVE *BLANK    F3SKJY
     C                     Z-ADD0         F3SKHZ
     C                     MOVE DSHIN     F3SHIN
     C                     Z-ADDWNONY     F3NONY
     C                     MOVE WMHIN     F3MHIN
     C                     WRITEMBDPL411
      *
     C                     END
     C                     END
      *
     C                     ENDSR
      *
      *
     C*----------------------*
     C*  ..サブルーチン..  *
     C*  ..データ出力      *
     C*----------------------*
     C           SUBWT     BEGSR
      *
     C           DTAYM     IFNE WHYM2
      *
     C           PNO       IFEQ '1'
     C           PNO       OREQ '3'
     C                     SETON                     U1
     C                     EXCPTDT1
     C                     END
     C                     ELSE
      *
     C           PNO       IFEQ '2'
     C           PNO       OREQ '3'
     C                     SETON                     U2
      *
     C           WNONY     IFNE 0
     C                     EXCPTDT2
     C                     ELSE
      *
     C*--------------------------*
     C*  ..新設品番マスター..  *
     C*--------------------------*
     C                     SETOF                     08
     C           KEY1      SETLLFCEPL811
      *
     C                     DO   *HIVAL
     C                     SETOF                     07
     C           KEY1      READEFCEPL811                 07
     C           *IN07     IFEQ '0'
      *
     C           F1SKJY    IFEQ 'D'
     C           F1SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     SETON                     08
     C                     Z-ADDF1TOKU    WNONY
     C                     EXCPTDT2
      *
     C                     END
     C                     END
     C  N07                END
      *
     C           *IN08     IFEQ '0'
     C                     EXCPTDT2
     C                     END
      *
     C                     END
     C                     END
     C                     END
      *
     C                     ENDSR
