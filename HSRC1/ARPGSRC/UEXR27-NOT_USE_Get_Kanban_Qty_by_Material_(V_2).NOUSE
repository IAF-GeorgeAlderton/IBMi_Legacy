     H            Y.
     F** UEXR27 ******************************************************
     F*  PROGRAM: EXSUB - CALCULATE KANBAN QTY BY MATERIAL           *
     F*  WRITTEN: JW (SRA) 2020.04.24                                *
     F*  JW       2020.04.24 ADD MULTIPLE MACHINE# ADJ (UEXC26)      *
     F*--------------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UEXR27'
     F*                    PARM           $ZAIS  15
     F*                    PARM           $ZAIK   5 2
     F*                    PARM           $ADJM   3 0
     F*                    PARM           $KQTY   3 0
     F*                    PARM           $RTN    1
     F*  IN  $ZAIS  15    MATERIAL
     F*      $ZAIK   5 2  DIAMETER
     F*  OUT $ADJM   3 0  MULTIPLE MACJINE ADJ
     F*      $KQTY   3 0  KANBAN QTY
     F*      $RTN    1A   ETURN CODE (OK:BLANK, *:ERROR)
     F*******************************************************
     FIZAPL01AIF  E           K        DISK
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     Z-ADD0         $KQTY
     C                     MOVE *BLANK    $RTN
      *
     C           K#01A     CHAINIZAPL01A             99
      *
     C           *IN99     IFEQ *ON
     C                     MOVE '*'       $RTN
     C                     GOTO ENDP
     C                     ENDIF
      * GET KANBAN QTY
     C                     Z-ADDZCMKJR    $MSET   80
     C                     Z-ADDZCTKJR    $CWGT   50
     C                     Z-ADDZCKEIS    $SCOE   32
     C                     Z-ADDZCSLTM    $LT     30
     C                     Z-ADDZCLOTO    $LOT    20
     C                     Z-ADDZCCHOS    $ADJ    30
     C                     Z-ADD0         $KQTY1  30
     C                     MOVE *BLANK    $RTN1   1
     C                     EXSR #CALC
      *
     C           $RTN1     IFEQ '*'
     C                     MOVE '*'       $RTN
     C                     ELSE
     C                     Z-ADD$KQTY1    $KQTY
     C                     ENDIF
      *
     C           ENDP      TAG
     C                     MOVE *ON       *INLR
     C                     RETRN
      *===================================================
      * INITIAL SETTING
      *===================================================
     C           #CALC     BEGSR
      *
     C                     Z-ADD0         $KQTY1
     C                     MOVE *BLANK    $RTN
      * IF WGT=0,
     C           $CWGT     IFEQ 0
     C                     GOTO ENDP
     C                     ENDIF
      *
      * 1.GET DAYLY USAGE (WDAY)  -------------------
     C           $MSET     DIV  20        WKQTY  127H
     C           WKQTY     DIV  $CWGT     WDAY   127H
      *
      * 2.TENTATIVE KANBAN (TKQTY) ------------------
     C           WDAY      MULT $SCOE     WTQTY  127H
     C                     MULT $LT       WTQTY     H
      * KURIAGE (ROUND UP)
     C                     Z-ADDWTQTY     NUM3    30
     C           WTQTY     IFEQ NUM3
     C                     Z-ADDNUM3      TKQTY   30
     C                     ELSE
     C           NUM3      ADD  1         TKQTY
     C                     ENDIF
      *
      * 3.MULTIPLE MASHINE ADJ ----------------------
     C                     CALL 'UEXC26'
     C                     PARM           $ZAIS
     C                     PARM           $ZAIK
     C                     PARM           $ADJM   30
     C                     ADD  $ADJM     TKQTY
      *
      * 4. ADD 1 IF MSET > 100  ---------------------  XXX
     C           TKQTY     IFEQ 1
     C           $MSET     ANDGE100
     C                     ADD  1         TKQTY
     C                     ENDIF
      *
      * 5.ADJUSTMENT (WADJ) -------------------------
     C           $LOT      SUB  1         WADJ    20
     C                     ADD  $ADJ      WADJ
      *
      * 6.FINAL KANBAN QTY --------------------------
     C           TKQTY     ADD  WADJ      $KQTY1
      *
     C                     ENDSR
      *===================================================
      * INITIAL SETTING
      *===================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $ZAIS  15
     C                     PARM           $ZAIK   52
     C                     PARM           $ADJM   30
     C                     PARM           $KQTY   30
     C                     PARM           $RTN    1
      *
     C           K#01A     KLIST
     C                     KFLD           $ZAIS
     C                     KFLD           $ZAIK
      *
     C                     ENDSR
