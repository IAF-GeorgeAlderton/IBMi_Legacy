     H            Y/                                    1
      **** GDIR71 ****************************************************
      *  INQUILY OF MONTHLY ORDER DATA
      *     G.B.C                                97/04/09
      ****************************************************************
      ****************************************************************
      *画面ファイル
     FGDIPW71 CF  E                    WORKSTN
     F                                        RRN   KSFILE S1
      *月次発注ファイル
     FGDIPL20 IF  E           K        DISK
      ****************************************************************
     E                    MSG     1   2 60               d[ｰ xｮﾈｰﾆﾞ
      ****************************************************************
      *入力画面　オーダー日付
     I            DS
     I                                        1   60G1JSYM
     I                                        1   40G1JSYY
     I                                        5   60G1JSMM
      *入力画面　型番
     I            DS
     I                                        1   8 G1KATA
     I                                        1   2 G1KAT1
     I                                        3   6 G1KAT2
     I                                        7   7 G1KAT3
     I                                        8   8 G1KAT4
      *サブファイル画面　型番
     I            DS
     I                                        1  11 S1KATA
     I                                        1   2 S1KAT1
     I                                        3   3 S1HF1
     I                                        4   7 S1KAT2
     I                                        8   8 S1HF2
     I                                        9   9 S1KAT3
     I                                       10  10 S1HF3
     I                                       11  11 S1KAT4
      *月次発注ファイル　型番
     I            DS
     I                                        1   8 IJKATA
     I                                        1   2 IJKAT1
     I                                        3   6 IJKAT2
     I                                        7   7 IJKAT3
     I                                        8   8 IJKAT4
      ****************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
      ****************************************************************
      *月次発注ファイル(GDIPL20)
     C           IJKEY1    KLIST
     C                     KFLD           IJJSYY           *発注実績　年
     C                     KFLD           IJJSMM           *発注実績　月
      *月次発注ファイル(GDIPL20)
     C           IJKEY2    KLIST
     C                     KFLD           IJJSYY           *発注実績　年
     C                     KFLD           IJJSMM           *発注実績　月
     C                     KFLD           IJKATA           *型番
      ****************************************************************
      *          M  A  I  N    R  O  U  T  I  N  E
      ****************************************************************
     C                     MOVEL'SET10'   W@NEXT  5
      *
     C           W@NEXT    DOWNE'END  '
      *
     C           W@NEXT    CASEQ'SET10'   @SET10
     C           W@NEXT    CASEQ'PNL10'   @PNL10
     C           W@NEXT    CASEQ'CHK10'   @CHK10
     C           W@NEXT    CASEQ'INZ20'   @INZ20
     C           W@NEXT    CASEQ'SET20'   @SET20
     C           W@NEXT    CASEQ'PNL20'   @PNL20
     C                     ENDCS
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      ****************************************************************
      *          S  U  B    R  O  U  T  I  N  E
      ****************************************************************
      *          @SET10   初期処理
      ****************************************************************
     C           @SET10    BEGSR
      *画面ﾎｧｰﾓnﾞ hﾒa
     C                     Z-ADD*ZERO     G1JSYM           *オーダー日付
     C                     MOVEL*BLANK    G1KAT1           *型番１
     C                     MOVEL*BLANK    G1KAT2           *型番２
     C                     MOVEL*BLANK    G1KAT3           *型番３
     C                     MOVEL*BLANK    G1KAT4           *型番４
     C                     SETOF                     61    *画面標識
     C                     SETOF                     99    *代表エラー
      * NEXT-ROUTINE
     C                     MOVEL'PNL10'   W@NEXT
      *
     C                     ENDSR
      ****************************************************************
      *          @PNL10   入力画面　表示処理
      ****************************************************************
     C           @PNL10    BEGSR
      *
     C                     WRITEC1
     C                     EXFMTG1
      *
     C                     SETOF                     61    *画面標識
     C                     SETOF                     99    *代表エラー
     C                     MOVEL*BLANK    C1MSG
      * NEXT-ROUTINE
     C                     MOVEL'CHK10'   W@NEXT
      *終了
     C           *IN01     IFEQ '1'
     C                     MOVEL'END  '   W@NEXT
     C                     END
      *
     C                     ENDSR
      ****************************************************************
      *          @CHK10   入力画面　チェック処理
      ****************************************************************
     C           @CHK10    BEGSR
      *オーダー日付の入力の有無
     C           G1JSYM    IFEQ *ZERO
     C                     SETON                     61    *画面標識
     C                     SETON                     99    *代表エラー
     C                     MOVELMSG,1     C1MSG            * d[ｰ xｮﾈｰﾆﾞ
     C                     END
      *月の入力チェック
     C           *IN99     IFEQ '0'
     C           G1JSMM    IFLE *ZERO
     C           G1JSMM    ORGT 12
     C                     SETON                     61    *画面標識
     C                     SETON                     99    *代表エラー
     C                     MOVELMSG,2     C1MSG            * d[ｰ xｮﾈｰﾆﾞ
     C                     END
     C                     END
      * NEXT-ROUTINE
     C                     MOVEL'INZ20'   W@NEXT
      *エラーありの時
     C           *IN99     IFEQ '1'
     C                     MOVEL'PNL10'   W@NEXT
     C                     END
      *
     C                     ENDSR
      ****************************************************************
      *          @INZ20   サブファイル　初期処理
      ****************************************************************
     C           @INZ20    BEGSR
      *
     C                     SETON                     32    * SFLCLR
     C                     WRITES1C
     C                     SETOF                     32    * SFLCLR
      *
     C                     Z-ADD*ZERO     RRN
     C                     Z-ADD*ZERO     W1RRN   40
      *
     C                     MOVEL*BLANK    S1KATA           *型番
     C                     Z-ADD*ZERO     S1SURY           *発注数量
      *月次発注ファイルへのキーセット
     C                     Z-ADDG1JSYY    IJJSYY           *発注実績　年
     C                     Z-ADDG1JSMM    IJJSMM           *発注実績　月
     C                     MOVELG1KATA    IJKATA           *型番
      *
     C           G1KATA    IFEQ *BLANK
     C           IJKEY1    SETLLGDIPL201                   * gｰに型番を含まず
     C           IJKEY1    READEGDIPL201                 80* gｰに型番を含まず
     C                     ELSE
     C           IJKEY2    SETLLGDIPL201                   * gｰに型番を含む
     C           IJKEY2    READEGDIPL201                 80* gｰに型番を含む
     C                     END
      * NEXT-ROUTINE
     C                     MOVEL'SET20'   W@NEXT
      *
     C                     ENDSR
      ****************************************************************
      *          @SET20   サブファイル　セット処理
      ****************************************************************
     C           @SET20    BEGSR
      *
     C                     Z-ADDW1RRN     RRN
     C                     Z-ADD*ZERO     JJ      40
      *
     C           *IN80     DOWEQ'0'
     C           JJ        ANDLE12
      *
     C           IJSKJY    IFNE 'D'
      *型番のセット
     C                     MOVELIJKAT1    S1KAT1           *型番１
     C                     MOVELIJKAT2    S1KAT2           *型番２
     C                     MOVELIJKAT3    S1KAT3           *型番３
     C                     MOVELIJKAT4    S1KAT4           *型番４
      *
     C           IJKAT2    IFEQ *BLANK
     C                     MOVEL*BLANK    S1HF1            * ﾌbﾎ]
     C                     ELSE
     C                     MOVEL'-'       S1HF1            * ﾌbﾎ]
     C                     END
      *
     C           IJKAT3    IFEQ *BLANK
     C                     MOVEL*BLANK    S1HF2            * ﾌbﾎ]
     C                     ELSE
     C                     MOVEL'-'       S1HF2            * ﾌbﾎ]
     C                     END
      *
     C           IJKAT4    IFEQ *BLANK
     C                     MOVEL*BLANK    S1HF3            * ﾌbﾎ]
     C                     ELSE
     C                     MOVEL'-'       S1HF3            * ﾌbﾎ]
     C                     END
      *オーダー数のセット
     C                     Z-ADDIJSURY    S1SURY           *オーダー数量
      *
     C                     ADD  1         RRN
     C                     ADD  1         JJ
     C                     WRITES1
     C                     END
      *
     C           G1KATA    IFEQ *BLANK
     C           IJKEY1    READEGDIPL201                 80* gｰに型番を含まず
     C                     ELSE
     C           IJKEY2    READEGDIPL201                 80* gｰに型番を含む
     C                     END
      *
     C                     ENDDO
      *データが０件の時
     C           RRN       IFEQ *ZERO
     C                     MOVEL*BLANK    S1KATA
     C                     MOVEL'NONE'    S1KAT2
     C                     Z-ADD*ZERO     S1SURY           *オーダー数量
      *
     C                     ADD  1         RRN
     C                     WRITES1
     C                     END
      *
     C                     Z-ADDRRN       W1RRN
      *
     C           *IN80     IFEQ '1'
     C                     Z-ADDW1RRN     RRN
     C                     END
      * NEXT-ROUTINE
     C                     MOVEL'PNL20'   W@NEXT
      *
     C                     ENDSR
      ****************************************************************
      *          @PNL20   サブファイル　表示処理
      ****************************************************************
     C           @PNL20    BEGSR
      *
     C                     WRITEC2
     C                     SETON                     31    * SFLDSP
     C                     EXFMTS1C
     C                     SETOF                     31    * SFLDSP
      * NEXT-ROUTINE
     C                     MOVEL'PNL20'   W@NEXT
      *終了
     C           *IN01     IFEQ '1'
     C                     MOVEL'END  '   W@NEXT
     C                     END
      *前画面
     C           *IN03     IFEQ '1'
     C                     MOVEL'PNL10'   W@NEXT
     C                     END
      * ROLL-UP
     C           *IN25     IFEQ '1'
     C                     MOVEL'SET20'   W@NEXT
     C                     END
      *
     C                     ENDSR
      ****************************************************************
**  MSG (mｰﾎﾞﾓ ﾃx]n)
INPUT THE ORDER DATE.
WRONG THE ORDER DATE.
