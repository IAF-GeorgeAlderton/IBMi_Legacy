     H            Y.
     F** ADKR11 **********************************
     F*上限カット　直接入力分をＡＤＫＰＰ１１へ出力
     F*    KATOGI.         2015.12.16            *
     F********************************************
     FAGAPL31 IF  E                    DISK
     FADKPP11 O   E                    DISK                      A
     E                    CBHK       24  3 0             ﾌｮkｬc ﾌﾃﾇc (N)
      *
     I            DS
     I                                        1  72 CBHK
     I                                        1   30CBHK01
     I                                        4   60CBHK02
     I                                        7   90CBHK03
     I                                       10  120CBHK04
     I                                       13  150CBHK05
     I                                       16  180CBHK06
     I                                       19  210CBHK07
     I                                       22  240CBHK08
     I                                       25  270CBHK09
     I                                       28  300CBHK10
     I                                       31  330CBHK11
     I                                       34  360CBHK12
     I                                       37  390CBHK13
     I                                       40  420CBHK14
     I                                       43  450CBHK15
     I                                       46  480CBHK16
     I                                       49  510CBHK17
     I                                       52  540CBHK18
     I                                       55  570CBHK19
     I                                       58  600CBHK20
     I                                       61  630CBHK21
     I                                       64  660CBHK22
     I                                       67  690CBHK23
     I                                       70  720CBHK24
      *
     I            DS
     I                                        1  140WDATE
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           F04     4
      *
     C                     TIME           WDATE
     C                     CALL 'ADKR90'
     C                     PARM           F04     4
     C                     PARM           P1APHZ  80
     C                     PARM           P1APBN  20
      *
     C           P1APBN    IFNE 0
     C                     Z-ADDP1APBN    A       20
     C                     READ AGAPL311                 80
     C           *IN80     DOWEQ'0'
     C           CBSKJY    IFEQ 'D'
     C           CBSKHZ    ANDLE*DATE
     C                     ELSE
     C           CBHK,A    IFNE 0
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     READ AGAPL311                 80
     C                     ENDDO
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------*
      *                                      *
      *--------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARADKPP111
     C                     Z-ADDSDATE     D1KOHZ
     C                     Z-ADDSTIME     D1KOTI
     C                     MOVELW#PGM     D1KOME
     C                     MOVELCBSHN1    D1SHN1
     C                     MOVELCBSHN2    D1SHN2
     C                     MOVELCBSHN3    D1SHN3
     C                     MOVEL'HN'      D1TYPE
     C                     Z-ADDCBHK,A    D1MAIS
     C                     Z-ADDP1APHZ    D1APHZ
     C                     Z-ADDP1APBN    D1APBN
     C                     WRITEADKPP111
      *
     CSR         ESB500    ENDSR
