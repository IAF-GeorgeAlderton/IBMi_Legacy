     H            Y.                                    1
      ***ALFR42*****************************************************************
      *  WIRE PULL SCAN RESULT INQUIRY BY TM, DATE                             *
      *                                                                        *
      **************************************************************************
     FALFPW42 CF  E                    WORKSTN
     F                                        RRN2  KSFILE SFL020
     F                                        RRN3  KSFILE SFL030
     F                                              KINFDS @INFDS
     FALFPL41 IF  E           K        DISK
     FALFPL01 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FALBPL30 IF  E           K        DISK
     FALFWP42 UF  E           K        DISK                      A
     FALFWP4D UF  E           K        DISK                      A
      **************************************************************************
     E                    ERR     1  10 70
     E                    CMD     1   2 70
      **************************************************************************
     I@INFDS      DS
     I                                     *STATUS  @STTS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60WSSTM6
     I                                        1   40WSSTM4
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  140WSSDAT
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
      * SCANNED FROM DATE
     I            DS
     I                                        1   80F1SCFH
     I                                        1   40F1SCFY
     I                                        5   60F1SCFM
     I                                        7   80F1SCFD
     I            DS
     I                                        1   80W1SCFH
     I                                        1   40W1SCFY
     I                                        5   60W1SCFM
     I                                        7   80W1SCFD
      *         FROM DATE
     I            DS
     I                                        1   80F8KAHZ
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
      * SCANNED TO DATE
     I            DS
     I                                        1   80F1SCTH
     I                                        1   40F1SCTY
     I                                        5   60F1SCTM
     I                                        7   80F1SCTD
     I            DS
     I                                        1   80W1SCTH
     I                                        1   40W1SCTY
     I                                        5   60W1SCTM
     I                                        7   80W1SCTD
      * SCANNED RESULT DATE
     I            DS
     I                                        1   80WPKODT
     I                                        1   40WPKOYY
     I                                        5   60WPKOMM
     I                                        7   80WPKODD
      * SCANNED RESULT TIME
     I            DS
     I                                        1   5 W8TIME
     I                                        1   2 W8TIHH
     I                                        3   3 W8@DY1
     I                                        4   5 W8TIMM
      * SCREEN - FROM DATE AND TIME
     I            DS
     I                                        1  140FROMDT
     I                                        1   80FRDATE
     I                                        9  140FRTIME
      * SCREEN - TO DATE AND TIME
     I            DS
     I                                        1  140TODT
     I                                        1   80TODATE
     I                                        9  140TOTIME
      *   SCAN - TO DATE AND TIME
     I            DS
     I                                        1  140SCANDT
     I                                        1   80SCDATE
     I                                        9  140SCTIME
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'10'      #FMT10
     C           @@ID      CASEQ'20'      #FMT20
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      **************************************************************************
      *         INITIALIZE
      **************************************************************************
     C           *INZSR    BEGSR
      *
     C                     TIME           WSDT
      *
     C                     Z-ADD*ZERO     F1SCFY
     C                     Z-ADD*ZERO     F1SCFM
     C                     Z-ADD*ZERO     F1SCFD
     C                     Z-ADD*ZERO     F1SCTY
     C                     Z-ADD*ZERO     F1SCTM
     C                     Z-ADD*ZERO     F1SCTD
     C                     Z-ADD*ZERO     F1FRTM
     C                     Z-ADD*ZERO     F1TOTM
     C                     MOVEL*BLANK    MSG
      *
     C                     MOVEL'10'      @@ID    2
     C                     MOVEL*OFF      *IN49
      *
     C                     ENDSR
      *************************************************************************
      *     1ST SCREEN(SCAN DATE)
      **************************************************************************
     C           #FMT10    BEGSR
      *
     C                     SETOF                     4748
     C                     WRITEFMT099
     C                     EXFMTFMT010
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK10
     C           *IN49     IFEQ *OFF
     C                     EXSR #SET20
     C                     ENDIF
     C           *IN49     IFEQ *ON
     C                     MOVEL'10'      @@ID
     C                     ELSE
     C                     MOVEL'20'      @@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************************
      *     1ST SCREEN CHECK
      **************************************************************************
     C           #CHK10    BEGSR
      *
     C                     SETOF                     313249
     C                     SETOF                     3334
     C                     TIME           WSDT
      *
     C           F1SCFH    IFEQ *ZERO
     C           F1SCFH    ORGT WSSDAT
     C                     SETON                     3149
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,1     MSG
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADDF1SCFH    W1SCFH
      *
     C           F1SCTH    IFEQ *ZERO
     C                     Z-ADDW1SCFH    W1SCTH
     C                     ELSE
     C                     Z-ADDF1SCTH    W1SCTH
     C                     ENDIF
      *
     C           W1SCFD    IFEQ *ZERO
     C                     Z-ADD01        W1SCFD
     C                     ENDIF
     C           W1SCTD    IFEQ *ZERO
     C           K#AGDA    KLIST
     C                     KFLD           W1SCTY
     C                     KFLD           W1SCTM
     C           K#AGDA    SETGTAGDPL12
     C           K#AGDA    REDPEAGDPL12                  98
     C           *IN98     IFEQ *OFF
     C                     Z-ADDF8KADD    W1SCTD
     C                     ELSE
     C                     Z-ADD31        W1SCTD
     C                     ENDIF
     C                     ENDIF
      *
     C           W1SCFH    IFGT W1SCTH
     C                     SETON                     313249
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,2     MSG
     C                     ENDIF
     C                     ENDIF
      *
     C           F1TOTM    IFEQ *ZERO
     C                     Z-ADD2400      F1TOTM
     C                     ENDIF
      *
     C           MSG       IFEQ *BLANK
     C           F1SCFH    IFEQ F1SCTH
     C           F1TOTM    IFLT F1FRTM
     C                     MOVEA'11'      *IN,33
     C                     MOVELERR,4     MSG
     C                     MOVE *ON       *IN49
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
      *
     C                     ENDSR
      *************************************************************************
      *     2ND SCREEN SET
      **************************************************************************
     C           #SET20    BEGSR
      *
     C                     Z-ADDF1SCFH    FRDATE
     C           F1FRTM    MULT 100       FRTIME
     C                     Z-ADDF1SCTH    TODATE
     C           F1TOTM    MULT 100       TOTIME
      *
     C                     MOVEL*ON       *IN41
     C                     WRITECTL020
     C                     MOVEL*OFF      *IN41
     C                     MOVEL*OFF      *IN42
     C                     Z-ADD*ZERO     RRN2    40
      *
     C                     Z-ADD*ZERO     C2PCNT
     C                     Z-ADD*ZERO     C2WSHT
     C                     Z-ADD*ZERO     C2TOTS
      *
      * close and clear workfile before recreating.
      *
     C                     CLOSEALFWP42
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
     C                     Z-ADD70        P@LEN
     C                     MOVELCMD,1     P@CMD
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN ALFWP42
      *
      * close and clear detail workfile before recreating.
      *
     C                     CLOSEALFWP4D
      *
     C                     Z-ADD70        P@LEN
     C                     MOVELCMD,2     P@CMD
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN ALFWP4D
      *
      * start with reading and accumulating all kanbans scanned.
      *
     C           K#41      KLIST
     C                     KFLD           F1SCFH
      *
     C           K#41      SETLLALFPL41
      *
     C                     DO   *HIVAL
      *
     C                     READ ALFPL41                  97
     C   97                LEAVE
      *
     C           WPCODT    IFGT W1SCTH
     C                     LEAVE
     C                     ENDIF
      *
     C                     Z-ADDWPCODT    SCDATE
     C                     Z-ADDWPCOTM    SCTIME
      *
      * if scan date/time between from date/time and to date/time.
     C           SCANDT    IFGE FROMDT
     C           SCANDT    ANDLETODT
      *
     C           WPWKCD    CHAINALFWP42              96
     C           *IN96     IFEQ *ON
     C                     CLEARALFWP421
     C                     MOVELWPWKCD    WYWKCD
     C                     MOVELWPWKCD    W@@06N  60
     C           W@@06N    CHAINALBPL30              95
     C           *IN95     IFEQ *OFF
     C                     MOVELALWKNM    WYWKNM
     C                     ENDIF
     C                     ENDIF
      *
     C                     ADD  1         WYA#WP
      *
     C  N96                UPDATALFWP421
     C   96                WRITEALFWP421
      *
      *
      *  write to detail workfile too.
      *
     C                     CLEARALFWP4D1
     C                     MOVELWPWKCD    WDWKCD
     C                     MOVELWPCODT    WDSCDT
     C           WPCOTM    DIV  100       WDSCTM
      *
     C                     MOVELWPMATN    WDMATN
     C                     Z-ADDWPDIAM    WDDIAM
     C                     MOVELWPLOC2    WDLOC1
     C                     MOVELWPLOC3    WDLOC2
     C                     Z-ADDWPILDT    WDILDT
     C           WPILTM    DIV  100       WDILTM
      *
     C           WPM#      IFNE *BLANK
     C                     MOVELWPM#      WDM#
     C                     ELSE
     C                     MOVELWPORDT    WDM#
     C                     ENDIF
      *
     C           WPC#      IFNE *BLANK
     C                     MOVELWPC#      WDC#
     C                     ELSE
     C                     MOVELWPSEQ     WDC#
     C                     ENDIF
      *
     C                     MOVELWPZETI    WDZETI
     C                     MOVELWPSMEX    WDSUPP
      *
     C                     WRITEALFWP4D1
      *
     C                     ENDIF
      *
     C                     ENDDO
      *
      * get washer totals for same date range.
     C                     EXSR #SET22
      *
      *
      * now read workfile and write to subfile to be displayed.
      *
     C           *LOVAL    SETLLALFWP42
      *
     C                     DO   *HIVAL
      *
     C                     READ ALFWP42                  94
     C   94                LEAVE
      *
     C                     CLEARSFL020
     C                     MOVELWYWKNM    S2TMNM
     C                     Z-ADDWYA#WP    S2PCNT
     C                     Z-ADDWYA#WS    S2WSHT
     C                     MOVELWYWKCD    H2TMCD
      *
     C                     ADD  WYA#WP    C2PCNT
     C                     ADD  WYA#WS    C2WSHT
      *
     C                     ADD  1         RRN2
     C                     WRITESFL020
      *
     C                     ENDDO
      *
     C           C2PCNT    ADD  C2WSHT    C2TOTS
      *
     C           RRN2      IFEQ *ZERO
     C                     SETON                     313249
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,3     MSG
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *************************************************************************
      *     2ND SCREEN SET - PART 2    GET WASHER INFORMATION
      **************************************************************************
     C           #SET22    BEGSR
      *
      *  read and accumulate all washer kanbans scanned.
      *
      *
     C           K#41      SETLLALFPL01
      *
     C                     DO   *HIVAL
      *
     C                     READ ALFPL01                  97
     C   97                LEAVE
      *
     C           A8DATE    IFGT W1SCTH
     C                     LEAVE
     C                     ENDIF
      *
     C           A8ERR     IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADDA8DATE    SCDATE
     C                     Z-ADDA8TIME    SCTIME
      *
      * if scan date/time between from date/time and to date/time.
     C           SCANDT    IFGE FROMDT
     C           SCANDT    ANDLETODT
      *
     C                     MOVELA8TMCD    WKCD    6
     C           WKCD      CHAINALFWP42              96
     C           *IN96     IFEQ *ON
     C                     CLEARALFWP421
     C                     MOVELWKCD      WYWKCD
     C                     MOVELWKCD      W@@06N  60
     C           W@@06N    CHAINALBPL30              95
     C           *IN95     IFEQ *OFF
     C                     MOVELALWKNM    WYWKNM
     C                     ENDIF
     C                     ENDIF
      *
      * add to washer total
     C                     ADD  1         WYA#WS
      *
     C  N96                UPDATALFWP421
     C   96                WRITEALFWP421
      *
      *
      *  write to detail workfile too.
      *
     C                     CLEARALFWP4D1
     C                     MOVELA8TMCD    WDWKCD
     C                     MOVELA8DATE    WDSCDT
     C           A8TIME    DIV  100       WDSCTM
      *
     C                     MOVELA8B1LZ    WDZETI
     C                     MOVELA8B1L2    WDLOC1
     C                     MOVELA8B1L3    WDLOC2
      *
     C                     SELEC
     C           A8DKND    WHEQ 'F'
     C                     MOVEL'FRWAY'   WDSUPP
     C           A8DKND    WHEQ 'A'
     C                     MOVEL'ASJ'     WDSUPP
     C           A8DKND    WHEQ 'R'
     C                     MOVEL'RKMTL'   WDSUPP
     C                     ENDSL
      *
     C                     MOVELA8ODR2    WDM#
     C                     MOVELA8ITM2    WDC#
      *
     C                     WRITEALFWP4D1
      *
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************************
      *     2ND SCREEN
      **************************************************************************
     C           #FMT20    BEGSR
      *
     C                     Z-ADD1         W#RNP2  40
      *
     C                     DO   *HIVAL
      *
     C                     MOVEL*OFF      *IN47
     C                     MOVEL*ON       *IN48
     C                     WRITEFMT099
     C                     Z-ADDW#RNP2    #RCN02
     C                     EXFMTCTL020
      *
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP2
     C                     ENDIF
      *
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      @@ID
     C                     LEAVE
     C           *INKL     WHEQ *ON
     C                     MOVEL'10'      @@ID
     C                     LEAVE
     C                     OTHER
     C                     EXSR #CHK20
     C           *INKA     IFEQ *ON
     C                     MOVEL'99'      @@ID
     C                     LEAVE
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     ENDSR
      **************************************************************************
      *     2ND SCREEN CHECK
      **************************************************************************
     C           #CHK20    BEGSR
      *
     C                     Z-ADD*ZERO     RRN2
      *
     C                     DO   *HIVAL
      *
     C                     ADD  1         RRN2
     C           RRN2      CHAINSFL020               93
     C   93                LEAVE
      *
     C           S2SEL     IFNE *BLANK
     C                     MOVEL*ON       *IN52
     C                     MOVEL*BLANK    S2SEL
     C                     UPDATSFL020
     C                     MOVEL*OFF      *IN52
     C                     EXSR #SET30
     C                     EXSR #FMT30
     C           *INKA     IFEQ *ON
     C                     MOVEL'99'      @@ID
     C                     LEAVE
     C                     ENDIF
     C                     ELSE
     C                     MOVEL*OFF      *IN52
     C                     MOVEL*BLANK    S2SEL
     C                     UPDATSFL020
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************************
      *     3RD SCREEN SET
      **************************************************************************
     C           #SET30    BEGSR
      *
     C                     MOVEL*ON       *IN61
     C                     WRITECTL030
     C                     MOVEL*OFF      *IN61
     C                     MOVEL*OFF      *IN62
     C                     Z-ADD*ZERO     RRN3    40
      *
     C                     MOVEL*ON       *IN63
     C                     MOVEL*OFF      *IN71
      *
     C                     MOVELS2TMNM    C3TMNM
     C                     Z-ADDS2PCNT    C3PCNT
     C                     Z-ADDS2WSHT    C3WSHT
     C           C3PCNT    ADD  C3WSHT    C3TOTS
      *
     C                     MOVELH2TMCD    WKCD    6
     C           K#WD2A    KLIST
     C                     KFLD           WKCD
      *
     C           K#WD2A    SETLLALFWP4D
      *
     C                     DO   *HIVAL
      *
     C           K#WD2A    READEALFWP4D                  97
     C   97                LEAVE
      *
     C                     CLEARSFL030
     C                     Z-ADDWDSCDT    S3DATE
      *
     C                     MOVELWDSCTM    W8TIHH
     C                     MOVEL':'       W8@DY1
     C                     MOVE WDSCTM    W8TIMM
     C                     MOVELW8TIME    S3TIME
      *
     C                     MOVELWDMATN    S3MATN
     C                     MOVELWDZETI    S3ZETI
     C                     MOVELWDLOC1    S3LOC1
     C                     MOVELWDLOC2    S3LOC2
     C                     MOVELWDM#      S3M#
     C                     MOVELWDC#      S3C#
     C                     MOVELWDSUPP    S3SUPP
     C                     Z-ADDWDDIAM    S3DIAM
      *
     C                     Z-ADDWDILDT    S3ILDT
      *
     C                     MOVELWDILTM    W8TIHH
     C                     MOVEL':'       W8@DY1
     C                     MOVE WDILTM    W8TIMM
     C                     MOVELW8TIME    S3ILTM
      *
     C                     ADD  1         RRN3
     C                     WRITESFL030
      *
     C                     ENDDO
      *
     C                     ENDSR
      *
      *************************************************************************
      *     3RD SCREEN(TM,DATE DETAIL)
      **************************************************************************
     C           #FMT30    BEGSR
      *
     C                     Z-ADD1         W#RNP3  40
     C                     MOVEL*OFF      *IN49
      *
     C                     DO   *HIVAL
      *
     C                     SETON                     4748
     C                     WRITEFMT099
     C                     Z-ADDW#RNP3    #RCN03
     C                     EXFMTCTL030
     C   KA
     COR KL                LEAVE
      *
     C  NKJ                MOVELN#MOD3    *IN63
      *
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP3
     C                     END
      *
     C                     ENDDO
      *
     C                     ENDSR
      *
      **************************************************************************
** ERR
DATE ERROR
FROM DATE  >  TO DATE
NO DATA FOUND!
TIME RANGE ERROR






** CMD
CLRPFM QTEMP/ALFWP42
CLRPFM QTEMP/ALFWP4D
