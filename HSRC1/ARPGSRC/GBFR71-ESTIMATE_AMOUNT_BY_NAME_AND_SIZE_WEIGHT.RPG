     C           *ENTRY    PLIST
     C                     PARM           PTOKU   4
     C                     PARM           PLKBN   1
     C                     PARM           PTKOJ   1
     C                     PARM           PYKBN   1
     C                     PARM           PSRKB   1
     C                     SETON                     02
     C                     Z-ADD0         I       20
     C                     MOVE PTOKU     UTOKU   40
     C                     MOVE *BLANK    YKBN
     C                     MOVE 'C'       SRKB
     C           STEP01    TAG
     C                     EXFMTGBFPW711
     C           *INKA     IFEQ '1'
     C                     SETON                     U1
     C                     GOTO END
     C                     END
     C                     SETOF                     99
     C           YKBN      IFEQ '1'
     C                     MOVEL'QCH PART'YMEI
     C                     GOTO STEP02
     C                     ELSE
     C           YKBN      IFEQ '2'
     C                     MOVEL'NOT QCH 'YMEI
     C                     GOTO STEP02
     C                     ELSE
     C           YKBN      IFEQ '3'
     C                     MOVEL'ALL PROD'YMEI
     C                     GOTO STEP02
     C                     ELSE
     C                     SETON                     99
     C                     MOVE ER,1      MSG
     C                     GOTO STEP01
     C                     END
     C                     END
     C                     END
     C           SRKB      IFEQ 'A'
     C                     MOVEL' PLAN A 'SRMEI   8
     C                     GOTO STEP02
     C                     ELSE
     C           SRKB      IFEQ 'B'
     C                     MOVEL'RESULT B'SRMEI
     C                     GOTO STEP02
     C                     ELSE
     C           SRKB      IFEQ 'C'
     C                     MOVEL' PLAN C 'SRMEI
     C                     GOTO STEP02
     C                     ELSE
     C                     SETON                     99
     C                     MOVE ER,6      MSG
     C                     GOTO STEP01
     C                     END
     C                     END
     C                     END
     C           STEP02    TAG
     C                     MOVE YKBN      PYKBN
     C                     MOVE SRKB      PSRKB
     C                     WRITEGBFPW712
     C******************************************************
     C* M-NO              ﾝ-hﾇm-ﾆﾑ]f[ ibﾅ]ﾇﾓ gb- ･ pﾏcﾒﾑh  *
     C******************************************************
     C           STEP03    TAG
     C                     SETOF                     0103
     C                     EXFMTGBFPW713
     C                     SETOF                     99
     C           *INKA     IFEQ '1'
     C                     SETON                     U1
     C                     GOTO END
     C                     END
     C   KG                GOTO STEP04
     C   KC                GOTO STEP05
     C           IMEI      IFEQ *BLANK
     C                     SETON                     99
     C                     MOVE ER,2      MSG
     C                     GOTO STEP03
     C                     END
     C                     Z-ADD1         A       20
     C           IMEI      LOKUPM,A                      99
     C           *IN99     IFEQ '1'
     C                     MOVE ER,7      MSG
     C                     MOVELA         MSG
     C                     GOTO STEP03
     C                     END
     C                     MOVE IMEI      MSCOD   2
     C           MKEY      KLIST
     C                     KFLD           XTOKU
     C                     KFLD           XTKOJ
     C                     KFLD           XBKBN
     C                     KFLD           MSCOD
     C                     Z-ADD0         XTOKU   40
     C                     MOVE *BLANK    XTKOJ   1
     C                     MOVE 'B'       XBKBN   1
     C                     SETOF                     05
     C           MKEY      CHAINGBFPL311             05
     C           *IN05     IFEQ '1'
     C                     SETON                     99
     C                     MOVELER,3      MSG
     C                     GOTO STEP03
     C                     ELSE
     C           G8SKJY    IFEQ 'D'
     C                     SETON                     99
     C                     MOVE ER,4      MSG
     C                     GOTO STEP03
     C                     END
     C                     MOVELG8KMEI    MMEI   20
     C                     END
     C******************************************************
     C* M-NO               xbﾆｭcKEY ･ ﾌbﾛl p jhﾝdﾓ         *
     C******************************************************
     C           I         ADD  1         I
     C                     MOVE IMEI      M,I
     C                     MOVE MMEI      ME,I
     C                     MOVE I         CTR
     C           I         SUB  15        N       20
     C           N         IFGE 1
     C           N         ADD  1         P       20
     C           P         ADD  14        U       20
     C                     ELSE
     C                     Z-ADD1         P
     C                     Z-ADD15        U
     C                     END
     C                     Z-ADD1         Z       20
     C                     Z-ADDP         X       20
     C           P         DO   U
     C                     MOVE M,X       MM,Z
     C                     MOVE ME,X      MME,Z
     C           Z         ADD  1         Z
     C           X         ADD  1         X       20
     C                     END
     C                     WRITEGBFPW712                   pﾏcﾒﾑhmﾞ-jOUT
     C                     MOVE *BLANK    IMEI
     C           I         IFGE 499
     C                     SETON                     99
     C                     MOVE ER,5      MSG
     C                     GOTO STEP03
     C                     END
     C                     GOTO STEP03
     C******************************************************
     C* M-NO               xbﾆｭcKEY ﾉ ﾈﾞ]fbﾎﾞ] hﾒa         *
     C******************************************************
     C           STEP05    TAG
     C           I         IFGE 1
     C                     MOVE *BLANK    M,I
     C                     MOVE *BLANK    ME,I
     C           I         SUB  1         I
     C                     Z-ADDI         CTR
     C                     END
     C           I         IFLT 1
     C                     MOVE *BLANK    MMEI
     C                     MOVE *BLANK    MSYO    2
     C                     MOVE *BLANK    IMEI    2
     C                     END
     C           I         SUB  14        N       20
     C           N         IFGE 1
     C                     Z-ADDN         P       20
     C           N         ADD  14        U       20
     C                     ELSE
     C                     Z-ADD1         P
     C                     Z-ADD15        U
     C                     END
     C                     Z-ADD1         Z       20
     C                     Z-ADDP         X       20
     C           P         DO   U
     C                     MOVE M,X       MM,Z
     C                     MOVE ME,X      MME,Z
     C           Z         ADD  1         Z
     C           X         ADD  1         X       20
     C                     END
     C                     WRITEGBFPW712                   pﾏcﾒﾑhmﾞ-jOUT
     C                     GOTO STEP03
     C******************************************************
     C* M-NO              xbﾆｭcKEY mﾞ-j ﾆｬlﾒｭh             *
     C******************************************************
     C           STEP04    TAG
     C           TNKEY     KLIST
     C                     KFLD           UTOKU
     C                     KFLD           UTKOJ
     C                     KFLD           UHIN1
     C                     KFLD           UHIN2
     C                     KFLD           UHIN3
     C                     KFLD           UHIN4
     C           PLKBN     IFEQ '*'
     C                     MOVE *BLANK    UTKOJ   1
     C                     ELSE
     C                     MOVE PTKOJ     UTKOJ
     C                     END
     C                     MOVE *BLANK    UHIN1   5
     C                     MOVE *BLANK    UHIN2   5
     C                     MOVE *BLANK    UHIN3   5
     C                     MOVE *BLANK    UHIN4   5
     C           TNKEY     SETLLGBFPL511
     C           STEP06    TAG
     C                     READ GBFPL51                  04
     C           *IN04     CABEQ'1'       END
     C           G9SKJY    CABEQ'D'       STEP06
     C           UTOKU     CABNEG9TOKU    END
     C           PLKBN     IFNE '*'
     C           PTKOJ     CABNEG9TKOJ    END
     C                     END
     C******************************************************
     C* M-NO               ﾆｬcibmﾞ-j ﾉ ﾆﾞｭci] ﾌ]mb         *
     C******************************************************
     C                     SETOF                     06
     C           G9MSYO    LOKUPM                        06
     C           *IN06     IFEQ '0'
     C                     GOTO STEP06
     C                     END
     C           YKBN      IFEQ '1'
     C           G9YAKI    CABEQ'***'     STEP06
     C                     ELSE
     C           YKBN      IFEQ '2'
     C           G9YAKI    CABNE'***'     STEP06
     C                     END
     C                     END
     C                     Z-ADDG9TOKU    IBTOKU
     C           PLKBN     IFEQ '*'
     C                     MOVE *BLANK    IBKKEY
     C                     ELSE
     C                     MOVE G9TKOJ    IBKKEY
     C                     END
     C                     MOVE G9TKOJ    IBTKOJ
     C                     MOVE G9MHN1    IBMHN1
     C                     MOVE G9MHN2    IBMHN2
     C                     MOVE G9MHN3    IBMHN3
     C                     MOVE G9MHN4    IBMHN4
     C                     MOVE G9MSYO    IBMSYO
     C                     Z-ADDG9TUSZ    IBTUSZ
     C                     Z-ADDG9KUBI    IBKUBI
     C                     MOVE G9YAKI    IBYAKI
     C                     MOVE G9SKYU    IBSKYU
     C                     MOVE G9ZCOD    IBZCOD
     C                     Z-ADDG9ZKGT    IBZKGT
     C                     Z-ADDG9SZIJ    IBSZIJ
     C                     Z-ADDG9SZAJ    IBSZAJ
     C                     Z-ADDG9KANJ    IBKANJ
     C                     Z-ADDG9MTAN    IBMTAN
     C           SRKB      IFEQ 'A'
     C                     Z-ADDG9QSRY    IBSRYO
     C                     ELSE
     C           SRKB      IFEQ 'B'
     C                     Z-ADDG9JIRY    IBSRYO
     C                     ELSE
     C           SRKB      IFEQ 'C'
     C                     Z-ADDG9SRYO    IBSRYO
     C                     END
     C                     END
     C                     END
     C                     WRITEGBFWP711
     C                     GOTO STEP06
     C           END       TAG
     C                     SETON                     LR
