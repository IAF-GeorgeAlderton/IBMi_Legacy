     H            Y.
     F** AAPR02 ******************************************************
     F* DIVIDE NUMBERS OF KANBAN ISSUED INCREASE/DECREASE PORTION BY 4
     F*    I-HASADA                                 97.05.02
     F************************************************** AAPR02 ******
     FAGDPL12 IF  E           K        DISK
     FGDGNP01 UF  E                    DISK                      A
     FGDGPP01 O   E                    DISK                      A
      *
     I            DS
     I                                        1   80IAKOHZ
     I                                        1   40IAKOYY
     I                                        5   60IAKOMM
     I                                        7   80IAKODD
     I            DS
     I                                        1   60IATIME
     I                                        1   20IAKOHH
     I                                        3   40IAKOSS
     I            DS
     I                                        1   80IAHAHZ
     I                                        1   40IAHAYY
     I                                        5   60IAHAMM
     I                                        7   80IAHADD
     I            DS
     I                                        1   80F8KAHZ
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I            DS
     I                                        1  12 WSHIN
     I                                        1   5 WSHN1
     I                                        6  10 WSHN2
     I                                       11  12 WSHN3
      *
     C           KEY       KLIST
     C                     KFLD           WYY
     C                     KFLD           WMM
     C                     KFLD           WDD
      *
     C           *ENTRY    PLIST
     C                     PARM           PUS    10
     C                     PARM           PKCD1   1
     C                     PARM           PSHIN  12
     C                     PARM           PKMIN   3
     C                     PARM           PKMAX   3
     C                     PARM           PZETI   4
     C                     PARM           PSYOS   6
      *
     C                     MOVE PSHIN     WSHIN
     C                     MOVE PKMIN     WKMIN   30
     C                     MOVE PKMAX     WKMAX   30
     C                     MOVE PSYOS     WSYOS   60
      *
     C           WKMAX     SUB  WKMIN     WMAIS   30
     C           WMAIS     DIV  4         WMAS1   30
     C                     MVR            WMAS2   30
      *
     C                     Z-ADD0         WMA     30
      *
     C           WMAS1     IFNE 0
     C           WMAS2     IFNE 0
     C           WMAIS     IFGE 0
     C           WMAS1     MULT 4         WMA1    30
     C           WMAIS     SUB  WMA1      WMA
     C                     ELSE
      *
     C                     Z-SUBWMAS1     @MAS1   30
     C                     Z-SUBWMAIS     @MAIS   30
     C           @MAS1     MULT 4         @MA1    30
     C           @MAIS     SUB  @MA1      @MA     30
     C                     Z-SUB@MA       WMA
     C                     END
     C                     END
     C                     END
      *
     C                     Z-ADD*YEAR     WYY     40
     C                     Z-ADDUMONTH    WMM     20
     C                     Z-ADDUDAY      WDD     20
      *
     C           WMAS1     IFEQ 0
      *
     C           KEY       SETGTAGDPL121
     C                     DO   *HIVAL
     C                     SETOF                     10
     C                     READ AGDPL121                 10
     C           *IN10     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     ELSE
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
      *
     C                     Z-ADDWMAIS     #MAIS   30
     C                     EXSR SUBR
     C                     SETON                     LR
     C                     RETRN
      *
     C                     END
     C                     END
     C  N10                END
     C                     ELSE
      *
     C                     Z-ADD1         A       20
     C           1         DO   4         A
      *
     C           A         IFEQ 1
      *
     C           KEY       SETGTAGDPL121
     C                     DO   *HIVAL
     C                     SETOF                     10
     C                     READ AGDPL121                 10
     C           *IN10     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     ELSE
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
      *
     C                     SETON                     10
     C                     Z-ADDWMAS1     #MAIS   30
     C                     ADD  WMA       #MAIS
     C                     EXSR SUBR
      *
     C                     END
     C                     END
     C  N10                END
     C                     ELSE
      *
     C                     DO   5
     C           STP1      TAG
     C                     SETOF                     10
     C                     READ AGDPL121                 10
     C           *IN10     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C                     Z-ADDWMAS1     #MAIS   30
     C                     EXSR SUBR
      *
     C                     END
     C                     END
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *
     C*------------------------------------------------*
     C* DIVIDE NUMBERS OF KANBAN ISSUED                *
     C*            ( INCREASE/DECREASE PORTION ) BY 4  *
     C*------------------------------------------------*
     C           SUBR      BEGSR
      *
     C                     SETOF                     80
     C           1         CHAINGDGNP011             80
     C           *IN80     IFEQ '1'
     C                     Z-ADD1         IBRECD
     C                     WRITEGDGNP011
     C                     ELSE
     C           IBRECD    IFEQ 9999
     C                     Z-ADD0         IBRECD
     C                     END
     C                     ADD  1         IBRECD
     C                     UPDATGDGNP011
     C                     END
      *
     C                     Z-ADDIBRECD    IARENB
     C                     Z-ADD*DATE     IAKOHZ
     C                     TIME           IATIME
     C                     MOVEL'AAPR02'  IAKOME
     C                     MOVE WSHN1     IAHIN1
     C                     MOVE WSHN2     IAHIN2
     C                     MOVE WSHN3     IAHIN3
     C                     Z-ADD#MAIS     IAMAIS
     C                     Z-ADDF8KAHZ    IAHAHZ
     C                     MOVE PZETI     IAZETI
     C                     MOVE PKCD1     IASEIH
     C                     Z-ADDWSYOS     IASYOS
     C                     WRITEGDGPP011
      *
     C                     ENDSR
