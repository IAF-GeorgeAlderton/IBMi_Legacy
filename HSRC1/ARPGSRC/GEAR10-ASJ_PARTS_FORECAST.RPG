     C           HCG1,X    MULT W@RATE    W@MS#
     C           W@MS#6    IFNE *ZERO
     C           W@MS#     ADD  1         W@MS@D
     C                     ELSE
     C                     Z-ADDW@MS#     W@MS@D
     C                     END
     C           W@MS@D    IFEQ *ZERO
     C                     Z-ADD1         W@MS@D
     C                     END
     C*
     C           GCG1,X    IFGT W@MS@D
     C           GCG1,X    SUB  W@MS@D    W@NXMS
     C                     Z-ADDW@MS@D    GCG1,X
     C                     ELSE
     C                     Z-ADD*ZERO     W@NXMS
     C                     END
     C*
     C           W@NXMS    IFNE *ZERO
     C                     EXSR #PUBL1
     C                     END
     C*
     C                     ENDDO
     C*
     C* N+2
     C                     DO   31        X
     C*
     C           GCG2,X    IFEQ *ZERO
     C                     ITER
     C                     END
     C                     Z-ADD*ZERO     W@RATE  52
     C                     MOVEL*OFF      W@PP06  1
     C           GCG2,X    DIV  W@SYS     @DBOX# 147
     C                     Z-ADDK@YY2     W@YY
     C                     Z-ADDK@MM2     W@MM
     C                     Z-ADDX         W@DD
     C                     EXSR #RATE
     C                     Z-ADDW@RATE    WWRATE  52
     C           HCG2,X    MULT W@RATE    W@MS#
     C           W@MS#6    IFNE *ZERO
     C           W@MS#     ADD  1         W@MS@D
     C                     ELSE
     C                     Z-ADDW@MS#     W@MS@D
     C                     END
     C           W@MS@D    IFEQ *ZERO
     C                     Z-ADD1         W@MS@D
     C                     END
     C*
     C           GCG2,X    IFGT W@MS@D
     C           GCG2,X    SUB  W@MS@D    W@NXMS
     C                     Z-ADDW@MS@D    GCG2,X
     C                     ELSE
     C                     Z-ADD*ZERO     W@NXMS
     C                     END
     C*
     C           W@NXMS    IFNE *ZERO
     C                     EXSR #PUBL2
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C                     ENDSR
      *-----------------------------------------------------------
      *  GET RATE(W@RATE)
      *-----------------------------------------------------------
     C           #RATE     BEGSR
     C*
     C                     DO
     C*
     C           K#FCE     CHAINAHDPP06              88
     C           *IN88     IFEQ *OFF
     C           AISKJY    ANDEQ*BLANK
     C                     Z-ADDAIKISU    W@RATE  52
     C                     MOVEL*ON       W@PP06
     C                     LEAVE
     C                     END
     C*
     C                     Z-ADD*ZERO     I
     C                     DO   *HIVAL
     C*
     C                     ADD  1         I
     C           I         IFGT W@MAXI
     C                     LEAVE
     C                     END
     C* <
     C           @FUG,I    IFEQ '1'
     C           @DBOX#    ANDLT@HTS,I
     C                     Z-ADD@KIS,I    W@RATE
     C                     LEAVE
     C                     END
     C* >
     C           @FUG,I    IFEQ '2'
     C           @DBOX#    ANDGT@HTS,I
     C                     Z-ADD@KIS,I    W@RATE
     C                     LEAVE
     C                     END
     C* =
     C           @FUG,I    IFEQ '3'
     C           @DBOX#    ANDEQ@HTS,I
     C                     Z-ADD@KIS,I    W@RATE
     C                     LEAVE
     C                     END
     C* <=
     C           @FUG,I    IFEQ '4'
     C           @DBOX#    ANDLE@HTS,I
     C                     Z-ADD@KIS,I    W@RATE
     C                     LEAVE
     C                     END
      * >=
     C           @FUG,I    IFEQ '5'
     C           @DBOX#    ANDGE@HTS,I
     C                     Z-ADD@KIS,I    W@RATE
     C                     LEAVE
     C                     END
      * <>
     C           @FUG,I    IFEQ '6'
     C           @DBOX#    ANDNE@HTS,I
     C                     Z-ADD@KIS,I    W@RATE
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDDO
     C*
T    C           K#GP75    KLIST
T    C                     KFLD           W@YY    40
T    C                     KFLD           W@MM    20
T    C                     KFLD           W@DD    20
T    C           K#GP75    CHAINGDGPP75              90
T    C           *IN90     IFEQ *OFF
T    C           GNSKJY    ANDEQ*BLANK
T    C                     Z-ADDGNRATE    WNRATE  52
T    C                     ELSE
T    C                     Z-ADD1         WNRATE
T    C                     END
     C*
     C           W@RATE    MULT WNRATE    W@RATE
     C*
     C                     ENDSR
      *-----------------------------------------------------------
      *  UPDATE PUBLICATION
      *-----------------------------------------------------------
     C           #PUBLN    BEGSR
     C*
     C                     Z-ADDW@NXMS    W@N003  70
     C                     Z-ADDX         Y       20
     C           W@SYS     MULT 999       W@NLMT  90
     C*
     C                     DO   *HIVAL
     C*
     C                     ADD  1         Y
     C           Y         IFGT 31
     C                     LEAVE
     C                     END
     C           GHLN,Y    IFEQ *BLANK
     C                     ITER
     C                     END
***  C*          GCGN,Y    IFLE *ZERO
***  C*                    ITER
***  C*                    END
     C*
     C                     DO   *HIVAL
     C           W@N003    IFEQ *ZERO
     C           GCGN,Y    ORGE W@NLMT
     C                     LEAVE
     C                     END
     C******               ADD  W@SYS     GCGN,Y
     C                     ADD  W@N003    GCGN,Y
     C                     Z-ADD*ZERO     W@N003
     C           W@SYS     IFGT W@N003
     C                     Z-ADD*ZERO     W@N003
     C                     ELSE
     C                     SUB  W@SYS     W@N003
     C                     END
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C           W@N003    IFNE *ZERO
     C                     Z-ADD*ZERO     Y
     C*
     C                     DO   *HIVAL
     C*
     C                     ADD  1         Y
     C           Y         IFGT 31
     C                     LEAVE
     C                     END
     C           GHL1,Y    IFEQ *BLANK
     C                     ITER
     C                     END
     C*
     C                     DO   *HIVAL
     C           W@N003    IFEQ *ZERO
     C           GCG1,Y    ORGE W@NLMT
     C                     LEAVE
     C                     END
     C                     ADD  W@SYS     GCG1,Y
     C           W@SYS     IFGT W@N003
     C                     Z-ADD*ZERO     W@N003
     C                     ELSE
     C                     SUB  W@SYS     W@N003
     C                     END
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C                     END
     C*
     C           W@N003    IFNE *ZERO
     C                     Z-ADD*ZERO     Y
     C*
     C                     DO   *HIVAL
     C*
     C                     ADD  1         Y
     C           Y         IFGT 31
     C                     LEAVE
     C                     END
     C           GHL2,Y    IFEQ *BLANK
     C                     ITER
     C                     END
     C*
     C                     DO   *HIVAL
     C           W@N003    IFEQ *ZERO
     C           GCG2,Y    ORGE W@NLMT
     C                     LEAVE
     C                     END
     C                     ADD  W@SYS     GCG2,Y
     C           W@SYS     IFGT W@N003
     C                     Z-ADD*ZERO     W@N003
     C                     ELSE
     C                     SUB  W@SYS     W@N003
     C                     END
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C                     END
     C*
     C                     ENDSR
      *-----------------------------------------------------------
