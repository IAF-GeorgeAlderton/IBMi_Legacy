     H            Y.
     F** STAR00 **************************************
     F* INTRA STOCK UPDATE SUB ROUTINE               *
     F*    SAKAKI             2019.09.09             *
     F************************************************
     FSTAPL10 UF  E           K        DISK                      A
     FSTAPP20 O   E                    DISK                      A
     FSTAPL21 IF  E           K        DISK
     FSTAPL22 IF  E           K        DISK
      *
     I            DS
     I                                        1  120S2SS
     I                                        1   80S2CRHZ
     I                                        9  140S2CRTI
      *
     I            DS
     I                                        1  120P#SS
     I                                        1   80W@TIHZ
     I                                        9  140W@TITI
      *
     I            DS
     I                                        1  120@@4MAE
     I                                        1   80@@4DAT
     I                                        9  120@@4TIM
      *
     IW@QR1       DS
     I                                        1 256 W@QR11
     I                                      257 512 W@QR12
     IW@QR2       DS
     I                                        1 256 W@QR21
     I                                      257 512 W@QR22
      *
     I            DS
     I                                        1  20 W@BAR1
     I                                        1   1 W@KANR
     I                                        2   5 W@ZETI
     I                                        6   8 W@TEHI
     I                                        9  10 W@PAGE
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140SDATE
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     I              '0123456789'          C         WKCKSU
      *----------------------------------------------------*
      *   PLIST                                            *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P#TIHZ  80
     C                     PARM           P#TITI  60
     C                     PARM           P#BMON  4
     C                     PARM           P#SHN1  5
     C                     PARM           P#SHN2  5
     C                     PARM           P#SHN3  2
     C                     PARM           P#ATK1  1
     C                     PARM           P#ATK2  2
     C                     PARM           P#ATK3  2
     C                     PARM           P#ATK4  1
     C                     PARM           P#SYOR  1
     C                     PARM           P#ZAIK  1
     C                     PARM           P#HKSU  50
     C                     PARM           P#TMCD 10
     C                     PARM           P#TMNM 20
     C                     PARM           P#PGM  10
     C                     PARM           P#BAR1 20
     C                     PARM           P#QR11256
     C                     PARM           P#QR12256
     C                     PARM           P#BAR2 20
     C                     PARM           P#QR21256
     C                     PARM           P#QR22256
      *
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
      *
     C           KEYST     KLIST
     C                     KFLD           KKSHN1  5
     C                     KFLD           KKSHN2  5
     C                     KFLD           KKSHN3  2
     C                     KFLD           KKATK1  1
     C                     KFLD           KKATK2  2
     C                     KFLD           KKATK3  2
     C                     KFLD           KKATK4  1
     C                     KFLD           KKBARC 20
     C                     MOVELP#SHN1    KKSHN1
     C                     MOVELP#SHN2    KKSHN2
     C                     MOVELP#SHN3    KKSHN3
     C                     MOVELP#ATK1    KKATK1
     C                     MOVELP#ATK2    KKATK2
     C                     MOVELP#ATK3    KKATK3
     C                     MOVELP#ATK4    KKATK4
      * STORE IN
     C           P#SYOR    IFEQ '1'
     C                     MOVELP#BAR1    KKBARC
     C                     ENDIF
      * STORE OUT
     C           P#SYOR    IFEQ '2'
     C                     MOVELP#BAR2    KKBARC
     C                     ENDIF
      *
     C           KEYST     CHAINSTAPL101             81
     C                     SELEC
     C           *IN81     WHEQ '1'
     C                     CLEARSTAPL101
     C           *IN81     WHEQ '0'
     C           S1SKJY    IFEQ 'D'
     C           S1SKHZ    ANDLESDATE
     C                     CLEARSTAPL101
     C                     ENDIF
     C                     ENDSL
      *４時間前
      * 4 HOURS AGO
     C                     MOVELSDATE     IDATE
     C                     MOVELSTIME     ITIME
     C                     MOVEL'-'       FUGO
     C                     MOVEL'00240'   FUN
     C                     CALL 'DATR45'
     C                     PARM           IDATE   8
     C                     PARM           ITIME   4
     C                     PARM           ODATE   8
     C                     PARM           OTIME   4
     C                     PARM           FUGO    1
     C                     PARM           FUN     5
     C                     Z-ADD0         @@4MAE
     C                     MOVE ODATE     @@4DAT
     C                     MOVE OTIME     @@4TIM
      *４時間以内の実績
      * RESULT WITHIN LAST 4 HOURS
     C                     MOVEL'0'       GET     1
     C                     MOVEL*BLANK    WKSYOR  1
     C                     MOVEL*BLANK    WKZAIK  1
     C                     MOVEL*BLANK    WKERCD  1
     C                     MOVEL*BLANK    WKSYOZ  1
     C                     MOVEL*BLANK    WKZAIZ  1
     C           P#SYOR    IFNE 'I'                        画面入力以外
     C                     EXSR #SB100
     C           GET       IFEQ '0'
     C                     EXSR #SB101                     ４時間以内なし
     C                     ELSE
     C                     EXSR #SB111                     ４時間以内あり
     C                     ENDIF
     C                     ENDIF
      *
      * CHECK DUPLICATE SCAN
     C                     MOVELP#BAR1    W@BAR1
     C           W@KANR    IFEQ 'A'
     C           W@KANR    OREQ 'R'
     C                     EXSR #SB200
     C                     ENDIF
      *
     C           WKERCD    IFEQ *BLANK
     C                     EXSR #SB001
     C                     ENDIF
      *
     C                     EXSR #SB002
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------*
      *在庫管理  STOCK MANAGEMENT          *
      *--------------------------------------*
     CSR         #SB001    BEGSR
      *
     C                     Z-ADDP#TIHZ    S1KOHZ
     C                     Z-ADDP#TITI    S1KOTI
     C                     MOVELW#USER    S1KOME
     C                     MOVELP#PGM     S1KOPG
     C                     MOVELP#TMCD    S1TMCD
     C                     MOVELP#TMNM    S1TMNM
     C                     MOVELP#SHN1    S1SHN1
     C                     MOVELP#SHN2    S1SHN2
     C                     MOVELP#SHN3    S1SHN3
     C                     MOVELP#ATK1    S1ATK1
     C                     MOVELP#ATK2    S1ATK2
     C                     MOVELP#ATK3    S1ATK3
     C                     MOVELP#ATK4    S1ATK4
     C*
     C                     MOVELP#BAR1    S1BARC
     C           P#SYOR    IFEQ '1'
     C           P#SYOR    OREQ '2'
     C                     MOVELKKBARC    S1BARC
     C                     ENDIF
     C*
     C           P#SYOR    IFEQ 'I'
      * Z-ADD  FOR  MAUAL INPUT.
     C                     SELEC
     C           P#ZAIK    WHEQ '1'                        通常在庫増
     C           P#ZAIK    OREQ '2'                        通常在庫減
     C                     Z-ADDP#HKSU    S1TUHK
     C           P#ZAIK    WHEQ '3'                        不良在庫増
     C           P#ZAIK    OREQ '4'                        不良在庫減
     C                     Z-ADDP#HKSU    S1FRHK
     C           P#ZAIK    WHEQ '5'                        はみ出し在庫増
     C           P#ZAIK    OREQ '6'                        はみ出し在庫減
     C                     Z-ADDP#HKSU    S1HMHK
     C                     ENDSL
      *
     C                     ELSE
      * OTHERS
     C                     SELEC
     C           P#ZAIK    WHEQ '1'                        通常在庫増
     C*********            ADD  P#HKSU    S1TUHK
     C                     Z-ADDP#HKSU    S1TUHK
     C           P#ZAIK    WHEQ '2'                        通常在庫減
     C                     SUB  P#HKSU    S1TUHK
     C           S1TUHK    IFLT 0
     C                     Z-ADD0         S1TUHK
     C                     ENDIF
     C           P#ZAIK    WHEQ '3'                        不良在庫増
     C                     ADD  P#HKSU    S1FRHK
     C           P#ZAIK    WHEQ '4'                        不良在庫減
     C                     SUB  P#HKSU    S1FRHK
     C           P#ZAIK    WHEQ '5'                        はみ出し在庫増
     C                     ADD  P#HKSU    S1HMHK
     C           P#ZAIK    WHEQ '6'                        はみ出し在庫減
     C                     SUB  P#HKSU    S1HMHK
     C                     ENDSL
      *
     C                     ENDIF
      *
     C           *IN81     IFEQ '0'
     C                     UPDATSTAPL101
     C                     ELSE
     C                     WRITESTAPL101
     C                     ENDIF
      *
     CSR         ESB001    ENDSR
      *--------------------------------------*
      * UPDATE HISTORY
      *--------------------------------------*
     CSR         #SB002    BEGSR
      *
     C                     CLEARSTAPP201
     C                     Z-ADDP#TIHZ    S2KOHZ
     C                     Z-ADDP#TITI    S2KOTI
     C                     MOVELW#USER    S2KOME
     C                     MOVELP#PGM     S2KOPG
     C                     MOVELP#TMCD    S2TMCD
     C                     MOVELP#TMNM    S2TMNM
     C                     Z-ADDP#TIHZ    S2CRHZ
     C                     Z-ADDP#TITI    S2CRTI
     C                     MOVELW#USER    S2CRME
     C                     MOVELP#PGM     S2CRPG
     C                     MOVELP#SYOR    S2SYOR
     C                     MOVELP#ZAIK    S2ZAIK
     C                     MOVELWKSYOZ    S2SYOZ
     C                     MOVELWKZAIZ    S2ZAIZ
     C                     MOVELWKERCD    S2ERCD
     C                     MOVELP#BMON    S2BMON
     C                     MOVELP#SHN1    S2SHN1
     C                     MOVELP#SHN2    S2SHN2
     C                     MOVELP#SHN3    S2SHN3
     C                     MOVELP#ATK1    S2ATK1
     C                     MOVELP#ATK2    S2ATK2
     C                     MOVELP#ATK3    S2ATK3
     C                     MOVELP#ATK4    S2ATK4
     C                     Z-ADDP#HKSU    S2HKSU
     C                     MOVELP#BAR1    S2BAR1
     C                     MOVELP#QR11    W@QR11
     C                     MOVELP#QR12    W@QR12
     C                     MOVELW@QR1     S2QR1
     C                     MOVELP#BAR2    S2BAR2
     C                     MOVELP#QR21    W@QR21
     C                     MOVELP#QR22    W@QR22
     C                     MOVELW@QR2     S2QR2
     C                     WRITESTAPP201
      *
     CSR         ESB002    ENDSR
      *--------------------------------------*
      *在庫実績  STAPP20                   *
      *  CHECK SCAN RESULT WITHIN LAST 4 HOURS *
      *--------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     Z-ADDP#TIHZ    W@TIHZ
     C                     Z-ADDP#TITI    W@TITI
      *
     C           P#BAR1    SETGTSTAPL211
     C           P#BAR1    REDPESTAPL211                 89
     C           *IN89     DOWEQ'0'
     C           WKSYOR    ANDEQ*BLANK
     C           S2SKJY    IFEQ 'D'
     C           S2SKHZ    ANDLESDATE
     C                     ELSE
      *
     C           S2SS      IFNE P#SS
     C           S2ERCD    IFEQ *BLANK
     C                     MOVELS2SYOR    WKSYOR
     C                     MOVELS2ZAIK    WKZAIK
     C           S2SS      IFGT @@4MAE
     C                     MOVEL'1'       GET
     C                     MOVELS2SYOR    WKSYOZ
     C                     MOVELS2ZAIK    WKZAIZ
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
      *
     C           P#BAR1    REDPESTAPL211                 89
     C                     ENDDO
      *
     CSR         ESB100    ENDSR
      *--------------------------------------*
      *ERROR CHECK                       *
      *４時間以内に同じかんばん無し        *
      *  THERE IS NO DUPLICATE SCAN WITHIN LAST 4 HOURS,
      *--------------------------------------*
     CSR         #SB101    BEGSR
      *
     C                     SELEC
      *最終実績が通常入庫
      * LAST PROCESS TYPE : STORE IN
     C           WKSYOR    WHEQ '1'                        通常入庫
     C           P#SYOR    IFEQ '5'                        はみ出し入庫
     C           P#SYOR    OREQ '6'                        はみ出し
     C           P#SYOR    OREQ '3'                        不良入庫
     C                     MOVEL'E'       WKERCD
     C                     ENDIF
      *最終実績が通常出庫
      * LAST PROCESS TYPE : STORE OUT
     C           WKSYOR    WHEQ '2'                        通常出庫
     C           P#SYOR    IFEQ '5'                        はみ出し入庫
     C           P#SYOR    OREQ '3'                        不良入庫
     C           P#SYOR    OREQ '4'                        不良出庫
     C                     MOVEL'E'       WKERCD
     C                     ENDIF
      *最終実績が不良入庫
      * LAST PROCESS TYPE : N/C STORE IN
     C           WKSYOR    WHEQ '3'                        不良入庫
     C           P#SYOR    IFEQ '1'                        通常入庫
     C           P#SYOR    OREQ '5'                        はみ出し入庫
     C           P#SYOR    OREQ '6'                        はみ出し
     C                     MOVEL'E'       WKERCD
     C                     ENDIF
      *最終実績が不良出庫
      * LAST PROCESS TYPE : N/C STORE OUT
     C           WKSYOR    WHEQ '4'                        不良出庫
     C           P#SYOR    IFEQ '1'                        通常入庫
     C           P#SYOR    OREQ '2'                        通常出庫
     C           P#SYOR    OREQ '5'                        はみ出し入庫
     C           P#SYOR    OREQ '6'                        はみ出し
     C                     MOVEL'E'       WKERCD
     C                     ENDIF
      *最終実績がはみ出し入庫
      * LAST PROCESS TYPE : O/F STORE IN
     C           WKSYOR    WHEQ '5'                        はみ出し入庫
     C           P#SYOR    IFEQ '1'                        通常入庫
     C           P#SYOR    OREQ '6'                        はみ出し
     C           P#SYOR    OREQ '3'                        不良入庫
     C                     MOVEL'E'       WKERCD
     C                     ENDIF
      *最終実績がはみ出し
      * LAST PROCESS TYPE : OVERFLOW SCAN
     C           WKSYOR    WHEQ '6'                        はみ出し
     C           P#SYOR    IFEQ '1'                        通常入庫
     C           P#SYOR    OREQ '2'                        通常出庫
     C           P#SYOR    OREQ '3'                        不良入庫
     C           P#SYOR    OREQ '4'                        不良出庫
     C                     MOVEL'E'       WKERCD
     C                     ENDIF
      *
     C                     ENDSL
      *
     CSR         ESB101    ENDSR
      *--------------------------------------*
      *エラーの判定  ERROR CHECK         *
      *４時間以内に同じかんばん有り　　　  *
      *  THERE IS DUPLICATE SCAN WITHIN LAST 4 HOURS,
      *--------------------------------------*
     CSR         #SB111    BEGSR
      *
     C                     SELEC
      *最終実績が通常入庫
      * LAST PROCESS TYPE : STORE IN
     C           WKSYOR    WHEQ '1'                        通常入庫
     C           P#SYOR    IFEQ '1'                        通常入庫
     C                     MOVEL'D'       WKERCD
     C                     ENDIF
     C           P#SYOR    IFEQ '5'                        はみ出し入庫
     C           P#SYOR    OREQ '6'                        はみ出し
     C           P#SYOR    OREQ '3'                        不良入庫
     C                     MOVEL'E'       WKERCD
     C                     ENDIF
      *最終実績が通常出庫
      * LAST PROCESS TYPE : STORE OUT
     C           WKSYOR    WHEQ '2'                        通常出庫
     C           P#SYOR    IFEQ '2'                        通常出庫
     C                     MOVEL'D'       WKERCD
     C                     ENDIF
     C           P#SYOR    IFEQ '5'                        はみ出し入庫
     C           P#SYOR    OREQ '3'                        不良入庫
     C           P#SYOR    OREQ '4'                        不良出庫
     C                     MOVEL'E'       WKERCD
     C                     ENDIF
      *最終実績が不良入庫
      * LAST PROCESS TYPE : N/C STORE IN
     C           WKSYOR    WHEQ '3'                        不良入庫
     C           P#SYOR    IFEQ '3'                        不良入庫
     C                     MOVEL'D'       WKERCD
     C                     ENDIF
     C           P#SYOR    IFEQ '1'                        通常入庫
     C           P#SYOR    OREQ '5'                        はみ出し入庫
     C           P#SYOR    OREQ '6'                        はみ出し
     C                     MOVEL'E'       WKERCD
     C                     ENDIF
      *不良入庫時の一連セットの処理　不良在庫減→通常在庫増
      * DECREASE N/C STOCK AND THEN INCREASE NORMAL STOCK
     C           P#SYOR    IFEQ '3'                        不良入庫
     C           P#ZAIK    ANDEQ'1'                        通常在庫増
     C           WKZAIK    IFEQ '4'                        不良減
     C                     MOVEL' '       WKERCD
     C                     ENDIF
     C                     ENDIF
      *最終実績が不良出庫
      * LAST PROCESS TYPE : N/C STORE OUT
     C           WKSYOR    WHEQ '4'                        不良出庫
     C           P#SYOR    IFEQ '4'                        不良出庫
     C                     MOVEL'D'       WKERCD
     C                     ENDIF
     C           P#SYOR    IFEQ '1'                        通常入庫
     C           P#SYOR    OREQ '2'                        通常出庫
     C           P#SYOR    OREQ '5'                        はみ出し入庫
     C           P#SYOR    OREQ '6'                        はみ出し
     C                     MOVEL'E'       WKERCD
     C                     ENDIF
      *不良出庫時の一連セットの処理　不良在庫増→通常在庫減
      * INCREASE N/C STOCK AND THEN DECREASE NORMAL STOCK
     C           P#SYOR    IFEQ '4'                        不良出庫
     C           P#ZAIK    ANDEQ'2'                        通常在庫減
     C           WKZAIK    IFEQ '3'                        不良増
     C                     MOVEL' '       WKERCD
     C                     ENDIF
     C                     ENDIF
      *最終実績がはみ出し入庫
      * LAST PROCESS TYPE : O/F STORE IN
     C           WKSYOR    WHEQ '5'                        はみ出し入庫
     C           P#SYOR    IFEQ '5'                        はみ出し入庫
     C                     MOVEL'D'       WKERCD
     C                     ENDIF
     C           P#SYOR    IFEQ '1'                        通常入庫
     C           P#SYOR    OREQ '6'                        はみ出し
     C           P#SYOR    OREQ '3'                        不良入庫
     C                     MOVEL'E'       WKERCD
     C                     ENDIF
      *はみ出し入庫時の一連セットの処理　はみ出し減→通常増
      * DECREASE OVERFLOW STOCK AND THEN INCREASE NORMAL STOCK
     C           P#SYOR    IFEQ '5'                        はみ出し入庫
     C           P#ZAIK    ANDEQ'1'                        通常在庫増
     C           WKZAIK    IFEQ '6'                        はみ出し減
     C                     MOVEL' '       WKERCD
     C                     ENDIF
     C                     ENDIF
      *最終実績がはみ出し
      * LAST PROCESS TYPE : OVERFLOW SCAN
     C           WKSYOR    WHEQ '6'                        はみ出し
     C           P#SYOR    IFEQ '6'                        はみ出し
     C                     MOVEL'D'       WKERCD
     C                     ENDIF
     C           P#SYOR    IFEQ '1'                        通常入庫
     C           P#SYOR    OREQ '2'                        通常出庫
     C           P#SYOR    OREQ '3'                        不良入庫
     C           P#SYOR    OREQ '4'                        不良出庫
     C                     MOVEL'E'       WKERCD
     C                     ENDIF
      *
     C                     ENDSL
      *
     CSR         ESB111    ENDSR
      *--------------------------------------*
      *在庫実績  STAPP20                   *
      *　４時間以内の処理がないときにチェック(WKSYOR=0)
      *  THERE IS NO DUPLICATE SCAN WITHIN LAST 4 HOURS,
      *--------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           KEYL2     KLIST
     C                     KFLD           W@ZETI
     C                     KFLD           W@TEHI
     C                     KFLD           W@PAGE
     C           KEYL2     SETGTSTAPL221
     C           KEYL2     REDPESTAPL221                 89
     C           *IN89     DOWEQ'0'
     C           WKSYOR    ANDEQ*BLANK
     C           S2SKJY    IFEQ 'D'
     C           S2SKHZ    ANDLESDATE
     C                     ELSE
     C           S2ERCD    IFEQ *BLANK
     C                     MOVEL'D'       WKERCD
     C                     ENDIF
     C                     ENDIF
     C           KEYL2     REDPESTAPL221                 89
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
