     C                     EXCPTOHED1
     C                     EXCPTOHED2
      *------------------                                              *********
     C                     DO   *HIVAL
     C                     READ ALRWP10                  80
     C   80                LEAVE
      *------------------                                              *********
     C                     CLEARWNO
     C                     CLEARWDT
     C                     CLEARWBX
      *------------------                                              *********
     C           W1LOT     MULT W1KMAX    W1TMAX  70
      *------------------                                              *********
     C           W1BPLS    SUB  W1BMIN    W1PTTL  50
      *------------------                                              *********
     C                     MOVEL*BLANK    W2STDA
     C           W1STYY    IFEQ *BLANK
     C           W1STYY    OREQ 'NO D'
     C                     MOVELW1STDT    W2STDA
     C                     ELSE
     C                     MOVEL'/'       W2H1
     C                     MOVEL'/'       W2H2
     C                     MOVELW1STYY    W2STYY
     C                     MOVELW1STMM    W2STMM
     C                     MOVELW1STDD    W2STDD
     C                     ENDIF
      *------------------                                              *********
     C                     SELEC
     C           W1TYPE    WHEQ '0'
     C                     MOVEL'PT    '  W2TYPE  6
     C           W1TYPE    WHEQ '3'
     C                     MOVEL'WASHER'  W2TYPE  6
     C           W1TYPE    WHEQ '6'
     C                     MOVEL'BPT   '  W2TYPE  6
     C                     ENDSL
      *------------------                                              *********
     C**
     C           KEY01     KLIST
     C                     KFLD           W1PRT1
     C                     KFLD           W1PRT2
     C                     KFLD           W1PRT3
     C**
     C                     Z-ADD0         W1OBOX  50
     C                     Z-ADD1         X       20
     C           KEY01     SETLLALRWP11              19
     C                     DO   *HIVAL
     C           KEY01     READEALRWP11                  19
     C   19                LEAVE
      *
     C           W0INVO    IFEQ *BLANK
     C                     Z-ADDW0BOX     W1OBOX  50
     C                     ELSE
     C**
     C           X         IFGT 10
     C                     ADD  W0BOX     WBX,11
     C                     ELSE
     C                     MOVELW0INVO    WNO,X
     C                     Z-ADDW0INHZ    WDT,X
     C                     Z-ADDW0BOX     WBX,X
     C                     ADD  1         X
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     EXCPTODAT
      *------------------                                              *********
     C                     ENDDO
