     H            Y.
     F** AFAR8B *********************************************
     F* 3BOND SHIP ERROR INQUIRY                            *
     F*     ............           2017.12.14               *
     F*******************************************************
     FAFAPP86 IF  E                    DISK
     FAFAWP8A O   E                    DISK                      A
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
      *
     I            DS
     I                                        1  12 WKLHN
     I                                        1   5 WKLHN1
     I                                        6  10 WKLHN2
     I                                       11  12 WKLHN3
      *
     I            DS
     I                                        1  140A6DE
     I                                        1   80A6KSDT
     I                                        9  140A6KSTM
      *
     I            DS
     I                                        1  140WKDE1
     I                                        1   80WKCOH1
     I                                        9  14 WKDET1
      *
     I            DS
     I                                        1  140WKDE2
     I                                        1   80WKCOH2
     I                                        9  14 WKDET2
      *
     C           *ENTRY    PLIST
     C                     PARM           P1COH1  8
     C                     PARM           P1COH2  8
     C                     PARM           P1COUS  6
     C                     PARM           P1LHN  12
     C                     PARM           P1DET1  4
     C                     PARM           P1DET2  4
     C                     PARM           PCMD    2
      *
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
     C                     MOVELP1LHN     WKLHN
     C                     MOVELP1COH1    WKCOH1
     C                     MOVELP1COH2    WKCOH2
     C           WKCOH2    IFEQ 0
     C                     Z-ADD99999999  WKCOH2
     C                     ENDIF
     C                     MOVELP1DET1    WKDET1
     C                     MOVE '00'      WKDET1
     C                     MOVELP1DET2    WKDET2
     C           P1DET2    IFEQ '0000'
     C                     MOVEL'9999'    WKDET2
     C                     ENDIF
     C                     MOVE '59'      WKDET2
      *
     C           1         SETLLAFAPP861
     C                     READ AFAPP861                 80
     C           *IN80     DOWEQ'0'
     C                     MOVEL'0'       GET     1
     C                     EXSR #SB400
     C           GET       IFEQ '1'
     C                     EXSR #SB500
     C                     ENDIF
     C                     READ AFAPP861                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C           WKLHN1    IFNE *BLANKS
     C           A6BHB1    ANDNEWKLHN1
     C                     GOTO ESB400
     C                     ENDIF
      *
     C           WKLHN2    IFNE *BLANKS
     C           A6BHB2    ANDNEWKLHN2
     C                     GOTO ESB400
     C                     ENDIF
      *
     C           WKLHN3    IFNE *BLANKS
     C           A6BHB3    ANDNEWKLHN3
     C                     GOTO ESB400
     C                     ENDIF
      *
     C           A6DE      IFGE WKDE1
     C           A6DE      ANDLEWKDE2
      *                     good
     C                     ELSE
     C                     GOTO ESB400
     C                     ENDIF
      *
     C           P1COUS    IFEQ *BLANK
     C                     ELSE
     C           A6OPER    IFNE P1COUS
     C                     GOTO ESB400
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVEL'1'       GET
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAFAWP8A1
     C                     Z-ADDA6KSDT    W6KSDT
     C                     Z-ADDA6KSTM    W6KSTM
     C                     MOVELA6OPER    W6OPER
     C                     MOVELA6EMSG    W6EMSG
     C                     MOVELA6ERPS    W6ERPS
     C                     MOVELA6BRC1    W6BRC1
     C                     MOVELA6ZETI    W6ZETI
     C                     Z-ADDA6KASI    W6KASI
     C                     MOVELA6BHB1    W6BHB1
     C                     MOVELA6BHB2    W6BHB2
     C                     MOVELA6BHB3    W6BHB3
     C                     MOVELA6ATOB    W6ATOB
     C                     MOVELA6LTNO    W6LTNO
     C                     MOVELA6FIL1    W6FIL1
     C                     MOVELA6FIL2    W6FIL2
     C                     MOVELA6FIL3    W6FIL3
     C                     WRITEAFAWP8A1
      *
     CSR         ESB500    ENDSR
