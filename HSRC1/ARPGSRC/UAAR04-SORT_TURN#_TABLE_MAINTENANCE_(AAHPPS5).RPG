     H            Y/                                    1
     H**UAAR04 ********************************************************
     H* SORT TURN# TABLE MAINTENANCE (AAHPPS5)                        *
     H* JW       2019.05.09                                           *
     H*****************************************************************
     FUAAPW04 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     FAAHPPS5 UF  E           K        DISK                      A
      *================================================================
     E                    MSG     1  20 60
      *================================================================
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
      *
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *     <<
      *
     I           SDS
     I                                     *PROGRAM #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I                                      264 269 #JBNO
      *===============================================================
      *  START  PROGRAM
      *===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C           @STEP     CASEQ'#CHK2 F5'#CHK2
     C           @STEP     CASEQ'#UPDAT  '#UPDAT
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      *   << INIT >>
      *===============================================================
     C           #INIT     BEGSR
     C                     TIME           @TIME
     C                     MOVEA*ALL'0'   *IN
     C                     MOVE *BLANK    D1KBN
     C                     MOVE *BLANK    D1SRT#
     C                     MOVE *BLANK    XMSG
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
      *===============================================================
      *   DISPLAY SCREEN 1
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     EXFMTDSP01
     C                     MOVE *OFF      *IN21
     C                     MOVE *OFF      *IN22
     C                     SETOF                     85
     C                     MOVE *BLANK    XMSG
     C*
     C                     MOVE '#CHK1   '@STEP
     C*  < F1 >  END JOB
     C           *INKA     IFEQ *ON
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C*  < F12 >  INQUIRY
     C           *INKL     IFEQ *ON
     C                     MOVELD1SRT#    P@SRT#
     C                     CALL 'UAAR05'
     C                     PARM           P@SRT#  2
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  CHECK SCREEN 1
      *===============================================================
     C           #CHK1     BEGSR
     C*--------------------
     C* D1KBN (21)
     C*--------------------
     C                     SELEC
     C           D1KBN     WHEQ '0'
     C                     MOVEL'0-CANCEL'D2KBN
     C                     SETON                     30
     C           D1KBN     WHEQ '1'
     C                     MOVEL'1-CHANGE'D2KBN
     C                     SETOF                     30
     C           D1KBN     WHEQ '2'
     C                     MOVEL'2-ADD   'D2KBN
     C                     SETOF                     30
     C                     OTHER
     C                     SETON                     2185
     C                     MOVELMSG,1     XMSG
     C                     GOTO @CHK1X
     C                     ENDSL
     C*--------------------
     C* D1SRT# (22)
     C*--------------------
     C           D1SRT#    IFEQ 0
     C                     SETON                     2285
     C                     MOVELMSG,2     XMSG
     C                     GOTO @CHK1X
     C                     ENDIF
     C*--------------------
     C           KEY01     KLIST
     C                     KFLD           K@SRT#  20
     C*
     C                     MOVELD1SRT#    K@SRT#
     C           KEY01     CHAINAAHPPS5             N90
     C  N90      S5SKJY    IFEQ 'D'                        DELETE CODE
     C                     SETON                     90
     C                     ENDIF
     C*
S1   C           *IN90     IFEQ *OFF
     C           D1KBN     IFEQ '2'                        2-ADD
     C                     SETON                     2122
     C                     SETON                         85
     C                     MOVELMSG,5     XMSG
     C                     GOTO @CHK1X
     C                     ENDIF
X1   C                     ELSE
     C           D1KBN     IFNE '2'                        NE 2-ADD
     C                     SETON                     212223
     C                     SETON                         85
     C                     MOVELMSG,4     XMSG
     C                     GOTO @CHK1X
     C                     ENDIF
E1   C                     ENDIF
     C*-------------------------
     C           @CHK1X    TAG
     C*-------------------------
     C*
S1   C           *IN85     IFEQ *ON
     C                     MOVE '#DSP1   '@STEP
X1   C                     ELSE
     C                     Z-ADDS5TRN#    D2TRN#
     C                     MOVE *BLANK    XMSG
     C                     MOVE '#DSP2   '@STEP
      * PROTECT FLAG (30)
     C           D1KBN     IFEQ '0'
     C                     MOVE *ON       *IN30
     C                     ELSE
     C                     MOVE *OFF      *IN30
     C                     ENDIF
      *
E1   C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *   DISPLAY SCREEN 2
      *===============================================================
     C           #DSP2     BEGSR
     C*
     C                     EXFMTDSP02
     C                     SETOF                     85
     C                     SETOF                     30
     C                     SETOF                     31
     C                     MOVE *BLANK    XMSG
     C*
     C                     MOVE '#CHK2   '@STEP
     C*  < F3 >  BACK
     C           *INKC     IFEQ *ON
     C                     MOVE *OFF      *IN21
     C                     MOVE *OFF      *IN22
     C                     MOVE *BLANK    XMSG
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C*  < F5 >  UPDAT
     C           *INKE     IFEQ *ON
     C                     MOVE '#CHK2 F5'@STEP
     C           D1KBN     IFEQ '0'                        0-CANCEL
     C                     MOVE '#UPDAT  '@STEP
     C                     ENDIF
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  CHECK SCREEN 2
      *===============================================================
     C           #CHK2     BEGSR
     C*
     C           D2TRN#    IFEQ 0
     C                     SETON                     85
     C                     SETON                     31
     C                     MOVELMSG,8     XMSG
     C                     MOVEL'#DSP2   '@STEP
     C                     GOTO @CHK2X
     C                     ENDIF
     C*
     C*-------------------------
     C           @CHK2X    TAG
     C*-------------------------
     C           *IN85     IFEQ *OFF
     C           @STEP     IFEQ '#CHK2 F5'
     C                     MOVEL'#UPDAT  '@STEP
     C                     ELSE
     C                     MOVELMSG,3     XMSG
     C                     MOVEL'#DSP2   '@STEP
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *===============================================================
      * UPDATE
      *===============================================================
     C           #UPDAT    BEGSR
     C*
     C           KEY01     CHAINAAHPPS5              90
     C*
     C           D1KBN     IFEQ '0'                        0-CANCEL
     C                     MOVE 'D'       S5SKJY           DELETE CODE
     C                     Z-ADD@SYSHZ    S5SKDT           DELETE DATE
     C  N90                UPDATAAHPPS51
     C                     ELSE
     C                     MOVE *BLANK    S5SKJY           DELETE CODE
     C                     Z-ADD0         S5SKDT           DELETE DATE
     C                     Z-ADD@SYSHZ    S5KODT           UPDATE DATE
     C                     Z-ADD@SYSTM    S5KOTM           UPDATE TIME
     C                     MOVEL#PGM      S5KOPG           UPDATE PGM
     C                     MOVEL#USER     S5KOUS           UPDATE USER
     C                     Z-ADDD1SRT#    S5LIN
     C                     Z-ADDD2TRN#    S5TRN#
      *
     C   90                WRITEAAHPPS51
     C  N90                UPDATAAHPPS51
     C                     ENDIF
      *
     C                     MOVE *BLANK    D1KBN
     C                     MOVE *BLANK    D1SRT#
     C                     MOVE *BLANK    XMSG
     C                     MOVE *OFF      *IN21
     C                     MOVE *OFF      *IN22
     C                     MOVE '#DSP1   '@STEP
      *
     C                     ENDSR
      *===============================================================
**  MSG  1         2         3         4         5         60 (60A)
 ENTER 0, 1 OR 2 FOR THE UPDATE ID !                          01
 ENTER SORT LINE# !                                           02
 PRESS F5 TO UPDATE...                                        03
 THERE IS NO TARGET DATA.                                     04
 SORT LINE# IS ALREADY REGISTERED !                           05
                                                              06
                                                              07
 ENTER TURN# !                                                08
                                                              09
                                                              10
