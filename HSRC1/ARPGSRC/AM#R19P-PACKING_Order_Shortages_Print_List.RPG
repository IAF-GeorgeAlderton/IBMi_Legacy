     H            Y.
      ** AM#R19P  ******************************************
      *  PACKING - ORDER SHORTAGE REVERSALS - PRINT LIST   *
      *                                                    *
      * LEC   20/09/14 CREATE                              *
      ******************************************************
     FAM#WP19 UF  E           K        DISK
     FQPRINT  O   F     150     OF     PRINTER
      *
     E                    TBL     1   1 50
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
      *
      * PART NUMBER
     I            DS
     I                                        1  12 W1MHN
     I                                        1   5 W1MHN1
     I                                        6  10 W1MHN2
      * EDITED PART NUMBER
     I            DS
     I                                        1  12 PART#
     I                                        1   5 MHN1
     I                                        6   6 DASH
     I                                        7  11 MHN2
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  14 SDATE
     I                                        1   6 STIME
      *
     C           *ENTRY    PLIST
     C                     PARM           PRT     1
      *
     C                     MOVE *BLANK    PRT
      *
     C                     DO   *HIVAL
      *
     C                     READ AM#WP19                  99
     C   99                LEAVE
      *
     C           W1FLDA    IFEQ 'PRINTED'
     C                     ITER
     C                     ELSE
      *
     C           W@1STP    IFEQ *ON
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     MOVEL*OFF      W@1STP
     C                     ENDIF
      *
     C                     MOVELW1SHID    SHIPDT  80
     C                     MOVELW1SHIT    SHIPTM  40
      *
     C                     MOVELW1MHN1    MHN1
     C                     MOVELW1MHN2    MHN2
      *
     C                     MOVELW1BOX#    BOX#    40
     C                     MOVELW1BXTL    BXTL    40
      *
     C                     CALL 'UTLR31'
     C                     PARM           W1KOME
     C                     PARM           P@WKNM 15
      *
     C                     EXCPT@DTL
      *
     C                     MOVEL'PRINTED' W1FLDA
     C           SDATE     CAT  STIME:1   W1FLDB
     C                     UPDATAM#WP191
     C                     MOVE 'Y'       PRT
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
      * INITIAL SET
      *-----------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     MOVEL'-'       DASH
     C                     TIME           WSDT
     C                     Z-ADDWSDT      WTIME
     C                     MOVEL*ON       W@1STP  1
      *
     C                     ENDSR
      *
      *-----------------------------------------------------
     OQPRINT  E   01           @HED
     O                         #PGM      10
     O                         TBL,1     75
     O                                   87 'DATE'
     O                         WSSDATY   98
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O        E   02           @HED
     O                                   87 'TIME'
     O                         WSSTM6    98 '  :  :  '
     O        E   03           @HED
     O                                   11 'SHIP_DATE'
     O                                   18 'TIME'
     O                                   25 'ROUTE'
     O                                   34 'PLANT'
     O                                   43 'DELV_CD'
     O                                   49 'DOCK'
     O                                   58 'ORDER#'
     O                                   67 'PL'
     O                                   81 'PART_NUMBER'
     O                                   88 'KAN#'
     O                                   94 'BOX#'
     O                                   99 'TOTL'
     O                                  104 'QPC'
     O                                  117 'MANIFEST#'
     O                                  138 'TEAM_MEMBER'
     O        E 1              @DTL
     O                         SHIPDTY   11
     O                         SHIPTM    18 ' 0:  '
     O                         W1SURT    29
     O                         W1NAMC    34
     O                         W1NONY    42
     O                         W1NUKE    48
     O                         W1ORD#    63
     O                         W1PALT    67
     O                         PART#     82
     O                         W1SBAN    88
     O                         BOX#  Z   94
     O                         BXTL  Z   99
     O                         W1QPC Z  105
     O                         W1MAN#   124
     O                         P@WKNM   142
