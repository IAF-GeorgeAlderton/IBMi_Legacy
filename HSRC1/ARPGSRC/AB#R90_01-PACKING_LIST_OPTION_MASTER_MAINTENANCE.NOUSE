     C                     SETON                     0699
     C                     MOVELER,12     MSG
     C                     ELSE
     C                     SETON                     06
     C                     ENDIF
     C*---------           GOTO STP3
     C                     END
     C                     END
     C*
     C* CHECK(CUSTOM SHEET TYPE)
     C           DCUST     IFEQ *ZERO
     C           DCUST     OREQ *BLANKS
     C           DCTYP     IFNE *BLANKS
     C           *IN99     IFEQ '0'
     C                     SETON                     0799
     C                     MOVELER,17     MSG
     C                     ELSE
     C                     SETON                     07
     C                     ENDIF
     C*---------           GOTO STP3
     C                     END
     C*
     C                     ELSE
