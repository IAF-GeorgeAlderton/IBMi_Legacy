     C                     SETON                     0799
     C                     MOVELER,13     MSG
     C                     ELSE
     C                     SETON                     07
     C                     ENDIF
     C*----------          GOTO STP3
     C                     END
     C                     END
     C*
     C* SUPPLIER FOR PRINT
     C*          DSUPP     IFEQ *BLANKS
     C*          *IN99     IFEQ '0'
