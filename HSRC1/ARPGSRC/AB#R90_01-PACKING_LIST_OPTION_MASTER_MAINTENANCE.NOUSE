     C                     MOVELER,15     MSG
     C                     ELSE
     C                     SETON                     08
     C                     ENDIF
     C                     ENDIF
     C                     END
      *
     C* CHECK PART/PALLET FLAG
     C           DPPART    IFEQ *BLANK
     C                     MOVEL'N'       DPPART
     C                     ENDIF
     C           DPPART    IFNE 'Y'
     C           DPPART    ANDNE'N'
