     C*
     C* CHECK(PICK-UP LIST TYPE)
     C           YATYPE    IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVELER,6      MSG
     C*------------        GOTO STP3
     C                     END
      *
     C           YATYPE    IFNE '01'
     C           YATYPE    ANDNE'02'
     C           YATYPE    ANDNE'03'
     C           YATYPE    ANDNE'04'
     C           YATYPE    ANDNE'05'
     C           YATYPE    ANDNE'06'
     C           YATYPE    ANDNE'07'
     C           YATYPE    ANDNE'08'
     C           YATYPE    ANDNE'09'
     C           YATYPE    ANDNE'10'
     C                     SETON                     0199
     C                     MOVELER,7      MSG
     C*-------------       GOTO STP3
     C                     END
     C*
     C           DMXPL     IFEQ 0
     C           DMXPL     ORGT 999
     C           *IN99     IFEQ '0'
     C                     SETON                     0299
     C                     MOVELER,16     MSG
     C                     ELSE
     C                     SETON                     02
     C                     ENDIF
     C*---------           GOTO STP3
     C                     END
     C*
     C* CHECK(NUMBER OF PICK-UP LIST)
     C           DPICK     IFEQ *BLANK
     C           DPICK     OREQ *ZERO
     C           *IN99     IFEQ '0'
     C                     SETON                     0399
     C                     MOVELER,10     MSG              ENTER # OF PACKING LIS
     C                     ELSE
     C                     SETON                     03
     C                     ENDIF
     C*----------          GOTO STP3
     C                     END
     C*
JW   C* SET DEFALT VALUE
     C           DMIX      IFEQ *BLANK
     C                     MOVE *ZERO     DMIX
     C                     END
     C*
     C* SET DEFALT VALUE
     C           DCUST     IFEQ *BLANK
     C                     MOVE *ZERO     DCUST
     C                     END
     C*
