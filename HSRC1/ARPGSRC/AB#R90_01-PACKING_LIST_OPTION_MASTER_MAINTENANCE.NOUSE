     C*                    MOVELER,18     MSG
     C*                    ELSE
     C*                    SETON                     09
     C*                    ENDIF
     C*                    ENDIF
     C*
     C* CHECK COUNTRY
     C           DCUST     IFEQ *ZERO
     C           DCUST     OREQ *BLANKS
     C           DCNAM     IFNE *BLANK
     C           *IN99     IFEQ '0'
