     C                     MOVELER,11     MSG
     C                     ELSE
     C                     SETON                     05
     C                     ENDIF
     C*---------           GOTO STP3
     C                     END
     C*
     C* CHECK(TRANSPORTATION)
     C           DCUST     IFEQ *ZERO
     C           DCUST     OREQ *BLANKS
     C           DTRAN     IFNE *BLANK
     C           *IN99     IFEQ '0'
     C                     SETON                     0699
     C                     MOVELER,12     MSG
     C                     ELSE
     C                     SETON                     06
     C                     ENDIF
     C*---------           GOTO STP3
     C                     END
     C*
