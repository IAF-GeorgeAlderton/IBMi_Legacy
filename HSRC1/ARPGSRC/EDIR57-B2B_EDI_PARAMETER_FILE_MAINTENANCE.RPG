     **==============================================================**
     **   ENTRY                                                      **
     **==============================================================**
     C           *ENTRY    PLIST
     C                     PARM           P1SUPP  4
     **==============================================================**
     **                    MAIN ROUTINE                              **
     **==============================================================**
      *
     C                     EXSR #INIT
      *
     C           W@NEXT    DOUEQ'END   '
      * SCREEN1
     C           W@NEXT    CASEQ'SET10 '  #SET10
     C           W@NEXT    CASEQ'PNL10 '  #PNL10
     C           W@NEXT    CASEQ'CHK10 '  #CHK10
      * SCREEN2
     C           W@NEXT    CASEQ'SET830'  #SE830
     C           W@NEXT    CASEQ'PNL830'  #PN830
     C           W@NEXT    CASEQ'CHK830'  #CH830
     C           W@NEXT    CASEQ'DB830 '  #DB830
      *
     C           W@NEXT    CASEQ'SET850'  #SE850
     C           W@NEXT    CASEQ'PNL850'  #PN850
     C           W@NEXT    CASEQ'CHK850'  #CH850
     C           W@NEXT    CASEQ'DB850 '  #DB850
     C                     END
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-------------------------------------------------------------------------
      * SET INITIAL VALUE FOR SCREEN1
      *-------------------------------------------------------------------------
     C           #SET10    BEGSR
      *
     C                     SETOF                     909192
     C                     SETOF                     414243
     C                     SETOF                     44
JW1  C**                   SETOF                     6162
     C                     SETOF                     99
      *
     C                     MOVEL*BLANK    D1SEL
     C                     MOVELP1SUPP    D1NONY
     C                     MOVEL*BLANK    D1SNRV
     C                     MOVEL*BLANK    D1NAME
     C                     MOVEL*BLANK    D1MSG
      *
      * NEXT-CONTROL
     C                     MOVEL'PNL10 '  W@NEXT           G1-PNL
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      * SCREEN1 PROCESS
      *-------------------------------------------------------------------------
     C           #PNL10    BEGSR
      *
     C                     MOVE *BLANK    D1NAME
      * CHECK SUPPLIER
     C           D1NONY    IFNE *BLANK
     C                     MOVELD1NONY    NUM4
     C           NUM4      CHAINFGBPL01              95
     C           *IN95     IFEQ *OFF
     C                     MOVELB2SMEI    D1NAME
     C                     ENDIF
     C                     ENDIF
      *
     C                     EXFMTDSP01
      *
     C                     SETOF                     909192
     C                     SETOF                     414243
     C                     SETOF                     44
JW1  C**                   SETOF                     6162
     C                     SETOF                     99
     C                     MOVEL*BLANK    D1MSG            * ERR MSG
      *
      * F03: END
     C           *INKA     IFEQ *ON
     C                     MOVEL'END   '  W@NEXT
     C                     GOTO XPNL10
     C                     ENDIF
      * F12: INQ
     C           *INKL     IFEQ *ON
     C                     CALL 'EDIR56'
     C                     PARM           D1NONY
     C                     PARM           D1SNRV
     C                     PARM           D1DKBN
     C                     MOVEL'PNL10 '  W@NEXT
     C                     GOTO XPNL10
     C                     ENDIF
      * ENTER
     C                     MOVEL'CHK10 '  W@NEXT
      *
     C           XPNL10    ENDSR
      *-------------------------------------------------------------------------
      *  CHECK FIELDS OF SCREEN1
      *-------------------------------------------------------------------------
     C           #CHK10    BEGSR
      *
     C           D1SEL     IFNE '0'
     C           D1SEL     ANDNE'1'
     C           D1SEL     ANDNE'2'
     C  N99                MOVEL@MS,01    D1MSG     P
     C                     SETON                     4199
     C                     GOTO XCHK10
     C                     ENDIF
      *
     C                     SELEC
     C           D1SEL     WHEQ '0'
     C                     SETON                     90
     C           D1SEL     WHEQ '1'
     C                     SETON                     91
     C           D1SEL     WHEQ '2'
     C                     SETON                     92
     C                     ENDSL
      * CHECK SUPPLIERL CODE
      *
     C           D1NONY    IFEQ *BLANK
     C  N99                MOVEL@MS,02    D1MSG     P
     C                     SETON                     42
     C                     SETON                     99
     C                     GOTO XCHK10
     C                     ENDIF
      *
     C                     MOVELD1NONY    NUM4    40
     C           NUM4      CHAINFGBPL01              95
     C           *IN95     IFEQ *ON
     C  N99                MOVEL@MS,08    D1MSG     P
     C                     SETON                     42
     C                     SETON                     99
     C                     GOTO XCHK10
     C                     ENDIF
     C                     MOVELB2SMEI    D1NAME
      * CHECK R/S
     C           D1SNRV    IFNE 'S'
     C           D1SNRV    ANDNE'R'
     C  N99                MOVEL@MS,06    D1MSG     P
     C                     SETON                     43
     C                     SETON                     99
     C                     GOTO XCHK10
     C                     ENDIF
      * CHECK EDI-CODE
     C           D1DKBN    IFNE '830'
     C           D1DKBN    ANDNE'850'
     C  N99                MOVEL@MS,07    D1MSG     P
     C                     SETON                     44
     C                     SETON                     99
     C                     GOTO XCHK10
     C                     ENDIF
      * IF NO ERROR, -------------------------------------
     C           *IN99     IFEQ '0'
     C                     MOVELD1NONY    K@NONY
     C                     MOVELD1SNRV    K@SNRV
     C                     MOVELD1DKBN    K@DKBN
     C           K@EDI     CHAINEDIPP50             N80
     C           *IN80     IFEQ '0'
      * ADD
     C           D1SEL     IFEQ '2'
     C           E5SKJY    IFEQ 'D'
     C                     ELSE
     C  N99                MOVEL@MS,05    D1MSG     P
     C                     SETON                     424344
     C                     SETON                     99
     C                     GOTO XCHK10
     C                     ENDIF
     C                     ENDIF
      * CHANGE/DELETE
     C           D1SEL     IFEQ '0'
     C           D1SEL     OREQ '1'
     C           E5SKJY    IFEQ 'D'
     C  N99                MOVEL@MS,04    D1MSG     P
     C                     SETON                     424344
     C                     SETON                     99
     C                     ENDIF
     C                     ENDIF
      *
     C                     ELSE
      * CHANGE/DELETE
     C           D1SEL     IFEQ '0'
     C           D1SEL     OREQ '1'
     C  N99                MOVEL@MS,03    D1MSG     P
     C                     SETON                     424344
     C                     SETON                     99
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDIF
      * NEXT-CONTROL
     C           XCHK10    TAG
     C                     SELEC
     C           *IN99     WHEQ *ON
     C                     MOVEL'PNL10 '  W@NEXT
     C           D1DKBN    WHEQ '830'
     C                     MOVEL'SET830'  W@NEXT
     C           D1DKBN    WHEQ '850'
     C                     MOVEL'SET850'  W@NEXT
     C                     ENDSL
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      * SET INITIAL VALUE OF SCREEN2 (830)
      *-------------------------------------------------------------------------
     C           #SE830    BEGSR
      *
     C                     SETOF                     515253
     C                     SETOF                     99
      *
     C                     MOVEL'0111'    D2SHPT
     C                     MOVELD1NONY    D2SHPF
     C                     MOVEL*BLANK    D2NAM1
