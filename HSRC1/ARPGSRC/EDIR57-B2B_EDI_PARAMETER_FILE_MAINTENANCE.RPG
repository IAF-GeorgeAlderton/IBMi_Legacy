     C                     MOVELE5ALF2    D2ALF2
     C                     MOVELE5STCP    D2STCP
     C                     MOVELE5STPH    D2STPH
     C                     MOVELE5SFCP    D2SFCP
JW1  C*                    MOVELE5SFPH    D2SFPH
     C                     MOVELE5FRF1    D2FRF1
     C                     MOVELE5FRF2    D2FRF2
     C                     MOVELE5FRF3    D2FRF3
     C                     MOVELE5FRF4    D2FRF4
JW1   * GET NAME1
     C                     MOVE *BLANK    D2NAM1
     C           D2SHPT    IFNE *BLANK
     C                     MOVELD2SHPT    NUM4
     C           NUM4      CHAINFGBPL01              99
     C           *IN99     IFEQ *OFF
     C                     MOVELB2SMEI    D2NAM1
     C                     ENDIF
     C                     ENDIF
JW1   * GET NAME2
     C                     MOVE *BLANK    D2NAM2
     C           D2SHPF    IFNE *BLANK
     C                     MOVELD2SHPF    NUM4
     C           NUM4      CHAINFGBPL01              99
