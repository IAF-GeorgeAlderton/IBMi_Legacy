     C                     ENDIF
JW1  C                     MOVELB2SMEI    D2NAM1
      * CHECK SHIP FROM
     C           D2SHPF    IFEQ *BLANK
     C  N99                MOVEL@MS,10    D2MSG     P
     C                     SETON                     52  99
     C                     GOTO SKIP2
     C                     ELSE
     C                     MOVELD2SHPF    NUM4
     C           NUM4      CHAINFGBPL01              95
     C           *IN95     IFEQ *ON
     C  N99                MOVEL@MS,12    D2MSG     P
     C                     SETON                     52
     C                     SETON                     99
     C                     GOTO SKIP2
     C                     ENDIF
     C                     ENDIF
JW1  C                     MOVELB2SMEI    D2NAM2
      * CHECK SHIP TO & FROM
     C           D2SHPT    IFNE *BLANK
     C           D2SHPF    ANDNE*BLANK
     C           D2SHPT    IFEQ D2SHPF
     C  N99                MOVEL@MS,14    D2MSG     P
     C                     SETON                     5152
     C                     SETON                     99
     C                     GOTO SKIP2
     C                     ENDIF
     C                     ENDIF
      * NUM CHECK SELLING PARTY
     C           D2SELP    IFNE *BLANK
