     C  N99                MOVEL@MS,16    D2MSG     P
     C                     SETON                     65  99
     C                     GOTO SKIP3
     C                     ENDIF
     C                     ENDIF
      * CHECK COMMENT TYPE 4
     C           D2FRF4    IFNE *BLANK
     C           D2CMD4    IFNE '1'
     C           D2CMD4    ANDNE'2'
     C           D2CMD4    ANDNE'3'
     C           D2CMD4    ANDNE'9'
     C  N99                MOVEL@MS,16    D2MSG     P
     C                     SETON                     66  99
     C                     GOTO SKIP3
     C                     ENDIF
     C                     ENDIF
      * NEXT-CONTROL
     C           SKIP3     TAG
     C                     MOVEL'PNL850'  W@NEXT
      * IF F5
     C           *IN05     IFEQ '1'
     C           *IN99     ANDEQ'0'
     C                     MOVEL'DB850 '  W@NEXT
     C                     ENDIF
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *  UPDATE RECORD (850)
      *-------------------------------------------------------------------------
     C           #DB850    BEGSR
      *
     C                     TIME           S@TIME
      *
     C                     MOVELD1NONY    K@NONY
     C                     MOVELD1SNRV    K@SNRV
     C                     MOVELD1DKBN    K@DKBN
     C           K@EDI     CHAINEDIPP50              80
      *
      * DELETE
     C           D1SEL     IFEQ '0'
     C           *IN80     IFEQ '0'
     C                     EXSR #DEL10
     C                     ENDIF
     C                     ELSE
      * ADD / CHANGE
     C           *IN80     IFEQ '0'
      * ADD(UPDAT)
     C           D1SEL     IFEQ '2'
     C                     EXSR #WP850
     C                     ENDIF
      * CHANGE
     C           D1SEL     IFEQ '1'
     C                     EXSR #UP850
     C                     ENDIF
     C                     ELSE
      * ADD(WRITE)
     C                     EXSR #WT850
     C                     ENDIF
     C                     ENDIF
      *
      * NEXT-CONTROL
     C                     MOVEL'SET10 '  W@NEXT
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      * WRITE RECORD (850)
      *-------------------------------------------------------------------------
     C           #WT850    BEGSR
      *
     C                     CLEAREDIPP501
      *
     C                     Z-ADDS@YYMD    E5KOHZ
     C                     Z-ADDS@HMS     E5KOTM
     C                     MOVELS@PGID    E5KOPG
     C                     MOVELS@USID    E5KOME
     C                     MOVELD1NONY    E5NONY
     C                     MOVELD1SNRV    E5SNRV
     C                     MOVELD1DKBN    E5DKBN
     C                     MOVELD2PFOR    E5PFOR
     C                     MOVELD2PAYT    E5PAYT
     C                     MOVELD2CONF    E5CONF
     C                     MOVELD2SHPM    E5SHPM
     C                     MOVELD2SELP    E5SELP
     C                     MOVELD2STCP    E5STCP
     C                     MOVELD2SFCP    E5SFCP
     C                     MOVELD2CMD1    E5CMD1
     C                     MOVELD2CMD2    E5CMD2
     C                     MOVELD2CMD3    E5CMD3
     C                     MOVELD2CMD4    E5CMD4
     C                     MOVELD2FRF1    E5FRF1
     C                     MOVELD2FRF2    E5FRF2
     C                     MOVELD2FRF3    E5FRF3
     C                     MOVELD2FRF4    E5FRF4
      *
     C                     WRITEEDIPP501
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *  WRITE(UPDATE) RECORD (850)
      *-------------------------------------------------------------------------
     C           #WP850    BEGSR
      *
     C                     MOVEL*BLANK    E5SKJY
     C                     Z-ADD*ZERO     E5SKHZ
     C                     Z-ADDS@YYMD    E5KOHZ
     C                     Z-ADDS@HMS     E5KOTM
     C                     MOVELS@PGID    E5KOPG
     C                     MOVELS@USID    E5KOME
     C                     MOVELD2PFOR    E5PFOR
     C                     MOVELD2PAYT    E5PAYT
     C                     MOVELD2CONF    E5CONF
     C                     MOVELD2SHPM    E5SHPM
     C                     MOVELD2SELP    E5SELP
     C                     MOVELD2STCP    E5STCP
     C                     MOVELD2SFCP    E5SFCP
     C                     MOVELD2CMD1    E5CMD1
     C                     MOVELD2CMD2    E5CMD2
     C                     MOVELD2CMD3    E5CMD3
     C                     MOVELD2CMD4    E5CMD4
     C                     MOVELD2FRF1    E5FRF1
     C                     MOVELD2FRF2    E5FRF2
     C                     MOVELD2FRF3    E5FRF3
     C                     MOVELD2FRF4    E5FRF4
      *
     C                     UPDATEDIPP501
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      * UPDATE RECORD (850)
      *-------------------------------------------------------------------------
     C           #UP850    BEGSR
      *
     C                     MOVEL*BLANK    E5SKJY
     C                     Z-ADD*ZERO     E5SKHZ
     C                     Z-ADDS@YYMD    E5KOHZ
     C                     Z-ADDS@HMS     E5KOTM
     C                     MOVELS@PGID    E5KOPG
     C                     MOVELS@USID    E5KOME
     C                     MOVELD2PFOR    E5PFOR
     C                     MOVELD2PAYT    E5PAYT
     C                     MOVELD2CONF    E5CONF
     C                     MOVELD2SHPM    E5SHPM
     C                     MOVELD2SELP    E5SELP
     C                     MOVELD2STCP    E5STCP
     C                     MOVELD2SFCP    E5SFCP
     C                     MOVELD2CMD1    E5CMD1
     C                     MOVELD2CMD2    E5CMD2
     C                     MOVELD2CMD3    E5CMD3
     C                     MOVELD2CMD4    E5CMD4
     C                     MOVELD2FRF1    E5FRF1
     C                     MOVELD2FRF2    E5FRF2
     C                     MOVELD2FRF3    E5FRF3
     C                     MOVELD2FRF4    E5FRF4
      *
     C                     UPDATEDIPP501
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      * DELETE(UPDATE) RECORD
      *-------------------------------------------------------------------------
     C           #DEL10    BEGSR
      *
     C                     MOVEL'D'       E5SKJY           * DELETE CODE D
     C                     Z-ADDS@YYMD    E5SKHZ           * DELETE DATE
     C                     Z-ADDS@YYMD    E5KOHZ           * UPDATE DATE
     C                     Z-ADDS@HMS     E5KOTM           * UPDATE TIME
     C                     MOVELS@PGID    E5KOPG           * UPDATE PROGRAM
     C                     MOVELS@USID    E5KOME           * UPDATE PERSON
      *
     C                     UPDATEDIPP501
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *  NUMERIC CHECK
      *-------------------------------------------------------------------------
     C           #NCHK     BEGSR
      *
     C                     MOVEALTR4      @AR
     C                     MOVE *OFF      *IN86
     C           1         DO   4         IX      10
     C           @AR,IX    IFLT '0'
     C           @AR,IX    ORGT '9'
     C                     MOVE *ON       *IN86
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *  INITIAL PROCESS
      *-------------------------------------------------------------------------
     C           #INIT     BEGSR
      *
     C           K@EDI     KLIST
     C                     KFLD           K@NONY  4
     C                     KFLD           K@SNRV  1
     C                     KFLD           K@DKBN  3
      * NEXT-CONTROL
     C                     MOVEL'SET10 '  W@NEXT  6
      *
     C                     ENDSR
      *----------------------------------------------------------------
**  @SL  ( SELECT )
DELETE
CHANGE
ADD
**  @MS  ( ERR MSG )
SELECT 0, 1 OR 2 FOR UPDATE OPTION!
ENTER SUPPLIER!
NOT EXSIST IN B2B PARAMETER MASTER(EDIPP50)!
KEYS ALREADY DELETED!
KEYS EXIST IN B2B PARAMETER MASTER(EDIPP50)!
R/S SHOULD BE R OR S!
EDI-CODE SHOULD BE 830 OR 850!
SUPPLIER IS NOT IN M/F(FGBPL01)!
ENTER SHIP TO!
ENTER SHIP FROM!
SHIP TO IS NOT IN M/F(FGBPL01)!
SHIP FROM IS NOT IN M/F(FGBPL01)!
SELLING PARTY IS NOT IN M/F(FGBPL01)!
SHIP_TO AND SHIP_FROM SHOULD NOT BE SAME!
PART# FORMAT SHOULD BE I OR F!
COMMENT TYPE SHOULD BE 1, 2, 3 OR 9!
ER17
