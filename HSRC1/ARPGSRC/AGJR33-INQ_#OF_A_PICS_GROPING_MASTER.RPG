     F** AGJR32 **************************************
     F* INQ #OF A-PICS GROUPING MASTER               *
     F*    IWATA.          2018.05.15                *
     F************************************************
     FAGJPW33 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL
     F                                              KINFDS INFDS
     FAGJPL21 IF  E           K        DISK
      *
     E                    ER      1  11 65
     E                    MS         10  5 0
     E                    S1B       999  4
     E                    S2B       999  4
     E                    S3B       999  4
     E                    S4B       999  4
     E                    S5B       999  4
     E                    S6B       999  4
     E                    S7B       999  4
     E                    S8B       999  4
     E                    S9B       999  4
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTITM
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I            DS
     I                                        1   4 WKBLK
     I                                        1   1 AGBLK
     I                                        2   2 WHIFN
     I                                        3   4 AGBLK2
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 ##USER
     I                                      264 269 W#JBNO
      *
     IINFDS       DS
     I                                    B 370 3710#CUR
     I                                    B 378 3790#POS
      *
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INIT                                               *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     Z-ADD1         WKPAGE  30
     C                     Z-ADD0         MAX     40
     C                     Z-ADD1         I       40
     C                     MOVEL'-'       WHIFN
     C                     Z-ADD1         G1      40
     C                     Z-ADD1         G2      40
     C                     Z-ADD1         G3      40
     C                     Z-ADD1         G4      40
     C                     Z-ADD1         G5      40
     C                     Z-ADD1         G6      40
     C                     Z-ADD1         G7      40
     C                     Z-ADD1         G8      40
     C                     Z-ADD1         G9      40
     C                     CLEARS1B
     C                     CLEARS2B
     C                     CLEARS3B
     C                     CLEARS4B
     C                     CLEARS5B
     C                     CLEARS6B
     C                     CLEARS7B
     C                     CLEARS8B
     C                     CLEARS9B
     C                     EXSR #CLR
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * CONTROL                                            *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * INQ                                                *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      * CREATE ARRAY BY GROUP
     C                     EXSR #DATA
      * WRITE SFL
     C           *IN66     DOWEQ'0'
     C                     EXSR #READ
     C                     ENDDO
      *
     C                     MOVE '02'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * SFL                                                *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C           CTRX      IFEQ 0
     C                     SETON                     72
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     ELSE
     C                     SETON                     7273
     C                     ENDIF
      *
     C                     WRITEAGJPW339
     C                     EXFMTSFLCTL
     C                     SETOF                     7273
     C                     SETOF                     3199
     C                     MOVEL*BLANK    D9ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      * F1/F12
     C           *IN01     IFEQ '1'
     C           *IN12     OREQ '1'
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           CTRX      IFEQ 0
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
      * ROLLDOWN/PAGEUP *
      *-----------------*
     C           *IN52     IFEQ '1'
      * 1ST. PAGE
     C           WKPAGE    IFEQ 1
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
     C                     ADD  16        CTRX
      *                         L--表示行数
     C                     SETOF                     27
     C           *IN27     DOWEQ'0'
     C                     EXSR #READP
     C                     ENDDO
      * WRITE SFL
     C                     EXSR #CLR
      *
     C           *IN66     DOWEQ'0'
     C                     EXSR #READ
     C                     ENDDO
      *
     C                     SUB  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      *--------------------*
      * ROLL-UP            *
      *--------------------*
     C           *IN51     IFEQ '1'
      *
     C           I         IFGE MAX
     C                     GOTO ESB220
     C                     ENDIF
      *
     C                     EXSR #CLR
      *
     C           *IN66     DOWEQ'0'
     C                     EXSR #READ
     C                     ENDDO
      *
     C                     ADD  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * READ                                               *
      *----------------------------------------------------*
     CSR         #READ     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREAD
     C                     ENDIF
      *
     C                     EXSR #EDIT
     C                     ADD  1         RRN
     C                     ADD  1         @RRN
     C                     ADD  1         CTRX
     C                     ADD  1         I
      *
     C           I         IFGE MAX
     C                     MOVE *OFF      *IN82
     C                     ELSE
     C                     MOVE *ON       *IN82
     C                     ENDIF
      *
     C                     WRITESFL
      *
     C           CTRX      IFEQ 16
     C                     SETON                       66
     C                     ENDIF
      *
     CSR         EREAD     ENDSR
      *----------------------------------------------------*
      * READP                                              *
      *----------------------------------------------------*
     CSR         #READP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREADP
     C                     ENDIF
      *
     C                     SUB  1         CTRX           27
     C                     SUB  1         I
      *
     CSR         EREADP    ENDSR
      *----------------------------------------------------*
      * SELECT                                             *
      *----------------------------------------------------*
     CSR         #SELEC    BEGSR
      *
     C                     MOVEL'1'       WKGET
      *
     CSR         ESELEC    ENDSR
      *----------------------------------------------------*
      * CLEAR                                              *
      *----------------------------------------------------*
     CSR         #CLR      BEGSR
      *
     C                     SETON                     71
     C                     WRITESFLCTL
     C                     SETOF                     7166
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN    40
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         @SFRC1
      *
     CSR         ECLR      ENDSR
      *----------------------------------------------------*
      * EDIT                                               *
      *----------------------------------------------------*
     CSR         #DATA     BEGSR
      *
     C                     Z-ADD1         MAX     40
     C                     SETOF                     82
     C           *LOVAL    SETLLAGJPL211
     C                     DO   *HIVAL
     C                     READ AGJPL211                 82
     C   82                LEAVE
      *
     C                     SELEC
     C           AGGRUP    WHEQ '1'
     C                     MOVELWKBLK     S1B,G1
     C           G1        IFGT MAX
     C                     Z-ADDG1        MAX
     C                     ENDIF
     C                     ADD  1         G1
     C           AGGRUP    WHEQ '2'
     C                     MOVELWKBLK     S2B,G2
     C           G2        IFGT MAX
     C                     Z-ADDG2        MAX
     C                     ENDIF
     C                     ADD  1         G2
     C           AGGRUP    WHEQ '3'
     C                     MOVELWKBLK     S3B,G3
     C           G3        IFGT MAX
     C                     Z-ADDG3        MAX
     C                     ENDIF
     C                     ADD  1         G3
     C           AGGRUP    WHEQ '4'
     C                     MOVELWKBLK     S4B,G4
     C           G4        IFGT MAX
     C                     Z-ADDG4        MAX
     C                     ENDIF
     C                     ADD  1         G4
     C           AGGRUP    WHEQ '5'
     C                     MOVELWKBLK     S5B,G5
     C           G5        IFGT MAX
     C                     Z-ADDG5        MAX
     C                     ENDIF
     C                     ADD  1         G5
     C           AGGRUP    WHEQ '6'
     C                     MOVELWKBLK     S6B,G6
     C           G6        IFGT MAX
     C                     Z-ADDG6        MAX
     C                     ENDIF
     C                     ADD  1         G6
     C           AGGRUP    WHEQ '7'
     C                     MOVELWKBLK     S7B,G7
     C           G7        IFGT MAX
     C                     Z-ADDG7        MAX
     C                     ENDIF
     C                     ADD  1         G7
     C           AGGRUP    WHEQ '8'
     C                     MOVELWKBLK     S8B,G8
     C           G8        IFGT MAX
     C                     Z-ADDG8        MAX
     C                     ENDIF
     C                     ADD  1         G8
     C           AGGRUP    WHEQ '9'
     C                     MOVELWKBLK     S9B,G9
     C           G9        IFGT MAX
     C                     Z-ADDG9        MAX
     C                     ENDIF
     C                     ADD  1         G9
     C                     ENDSL
     C                     ENDDO
     C*
     CSR         EDATA     ENDSR
      *----------------------------------------------------*
      * EDIT                                               *
      *----------------------------------------------------*
     CSR         #EDIT     BEGSR
      *
     C                     MOVELS1B,I     S1BLK1
     C                     MOVELS2B,I     S1BLK2
     C                     MOVELS3B,I     S1BLK3
     C                     MOVELS4B,I     S1BLK4
     C                     MOVELS5B,I     S1BLK5
     C                     MOVELS6B,I     S1BLK6
     C                     MOVELS7B,I     S1BLK7
     C                     MOVELS8B,I     S1BLK8
     C                     MOVELS9B,I     S1BLK9
     C*
     CSR         EEDIT     ENDSR
