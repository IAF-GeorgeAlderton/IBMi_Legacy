     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET1
     C           RRN1      IFGT *ZERO
     C                     MOVE '02'      @@ID
     C                     ELSE
     C                     MOVEA'111'     *IN,61
     C                     MOVE ERR,1     D@MSG
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
