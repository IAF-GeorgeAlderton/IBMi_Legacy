     C  N99                MOVE ERR,2     D@MSG
     C                     SETON                     626399
     C                     ENDIF
      *
     C           D@TO      IFLT D@FROM
     C  N99                MOVE ERR,2     D@MSG
     C                     SETON                     626399
     C                     ENDIF
