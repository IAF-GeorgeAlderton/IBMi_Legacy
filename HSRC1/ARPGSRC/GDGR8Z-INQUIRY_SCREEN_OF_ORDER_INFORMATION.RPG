     H            Y.
     F** GDGR80 ************************************
     A*   INQUIRY SCREEN OF ORDER INFORMATION      *
     F*       MSK.KUNIEDA         2000.03.17       *
     F*                           2000.11.09       *
     F*       K.KASHIWAGI         2001.05.04       *
     F*   SKIP RECORD WITH 'C' FLAG                *
     F*    2004/06/09                              *
     F************************************ GDGR80 **
     FGDGPW80 CF  E                    WORKSTN
     FGDGPL18 IF  E           K        DISK
     FGDGPL25 IF  E           K        DISK
     FGDIPL18 IF  E           K        DISK
     FGDIPL25 IF  E           K        DISK
     FGDGWP80 O   E           K        DISK
      *
     E                    $ER     1   5 60
     E*                   MSG     1   3 60
      *
     I            DS
     I                                        1  12 ICHIN
     I                                        1   5 ICHIN1
     I                                        6  10 ICHIN2
     I                                       11  12 ICHIN3
      *
     I            DS
     I                                        1  12 IEHIN
     I                                        1   5 IEHIN1
     I                                        6  10 IEHIN2
     I                                       11  12 IEHIN3
      *
     I            DS
     I                                        1   8 IKKATA
     I                                        1   2 IKKAT1
     I                                        3   6 IKKAT2
     I                                        7   7 IKKAT3
     I                                        8   8 IKKAT4
     I                                        1   6 IKKAT6
     I            DS
     I                                        1   8 IIKATA
     I                                        1   2 IIKAT1
     I                                        3   6 IIKAT2
     I                                        7   7 IIKAT3
     I                                        8   8 IIKAT4
     I                                        1   6 IIKAT6
      *
     I            DS
     I                                        1   60TIME
     I                                        1   20TIMHH
     I                                        3   40TIMMM
      *
     I            DS
     I                                        1   80HYMD8
     I                                        3   80HYMD6
     I                                        1   40HYY
     I                                        5   60HMM
     I                                        7   80HDD
      *
     C           *ENTRY    PLIST
     C                     PARM           RETNCD  1
     C                     PARM           PSNO    6
     C                     PARM           PENO    6
     C                     PARM           PNO     1
     C                     PARM           PPART  15
     C                     PARM           TMAIS   50
     C                     PARM           TNOHK   50
     C                     PARM           TMIHK   50
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
     C           KEYORN    KLIST
     C                     KFLD           #KODER  60
     C           KEYIG1    KLIST
     C                     KFLD           #KODER  60
     C                     KFLD           #KITEM  50
      *
      *----------------------------------------------------*
      *  メインルーチン                                  *
      *----------------------------------------------------*
     C                     EXSR $SB100
     C           *IN01     DOWEQ'0'
     C           *IN05     ANDEQ'0'
     C                     EXSR $SB200
     C                     END
     C                     EXSR $SB300
      *----------------------------------------------------*
      *   初期処理                                       *
      *----------------------------------------------------*
     CSR         $SB100    BEGSR
     C                     TIME           TIME
     C                     Z-ADD*DATE     HYMD8
     C                     SETOF                     1613
     C                     SETOF                     15
     C                     MOVEL*BLANK    @ERR
     C                     MOVE *BLANK    DSPSW1  1
     C                     MOVE *BLANK    DSPSW2  1
     C                     MOVE *BLANK    DSPSW3  1
     C                     Z-ADD0         X       10
     C                     Z-ADD0         TMAIS
     C                     Z-ADD0         TNOHK
     C                     Z-ADD0         TMIHK
     C                     MOVE *BLANK    GETFLG  1
     C                     MOVE *BLANK    SELFLG  1
     C                     MOVE '1'       DSPSW1
     C                     MOVE '0'       DSPSW2
     C           RETNCD    IFEQ '1'
     C                     MOVE '0'       DSPSW1
     C                     MOVE '1'       DSPSW2
     C                     MOVE *BLANK    RETNCD
     C                     MOVEL'1'       @NO
     C                     MOVELPSNO      @SNO
     C                     MOVELPENO      @ENO
     C                     MOVELPPART     @PARTS
     C                     END
     C           PNO       IFNE *BLANK
     C                     MOVE PNO       X
     C                     MOVE PNO       @NO
     C                     END
     CSR         $S100E    ENDSR
      *----------------------------------------------------*
      *   主処理                                         *
      *----------------------------------------------------*
     CSR         $SB200    BEGSR
     C           *IN01     DOWEQ'0'
     C           DSPSW1    ANDEQ'1'
     C                     EXSR $SB210
     C                     END
      *
     C           *IN01     DOWEQ'0'
     C           *IN03     ANDEQ'0'
     C           *IN05     ANDEQ'0'
     C           DSPSW2    ANDEQ'1'
     C                     EXSR $SB220
     C                     END
      *
     CSR         $S200E    ENDSR
      *----------------------------------------------------*
      *   第一画面処理(GDGPW801)                         *
      *----------------------------------------------------*
     CSR         $SB210    BEGSR
     C                     EXFMTGDGPW801
     C                     SETOF                     3199
     C                     MOVEL*BLANK    @ERR
      * CMD-1
     C           *IN01     IFEQ '1'
     C                     GOTO $S210E
     C                     END
      *
     C           @NO       IFEQ *BLANK
     C                     SETON                     3199
     C                     MOVEL$ER,1     @ERR
     C                     GOTO $S210E
     C                     END
      *
     C           @NO       IFNE '1'
     C           @NO       ANDNE'2'
     C                     SETON                     3199
     C                     MOVEL$ER,2     @ERR
     C                     GOTO $S210E
     C                     END
      *
     C                     MOVE @NO       X
     C                     MOVE *ZERO     @SNO
     C                     MOVE *ZERO     @ENO
     C                     MOVE *BLANK    @PARTS
      *
     C                     MOVE '1'       DSPSW2
     C                     MOVE '0'       DSPSW1
      *
     CSR         $S210E    ENDSR
      *----------------------------------------------------*
      *   第二画面処理(GDGPW802)                         *
      *----------------------------------------------------*
     CSR         $SB220    BEGSR
     C                     SETOF                     323334
     C                     SETOF                     99
     C                     MOVEL*BLANK    @ERR
      *
      *
     C           @SNO      IFEQ 0
     C                     Z-ADD0         @SNO
     C                     END
     C           @ENO      IFEQ 0
     C                     Z-ADD999999    @ENO
     C                     END
      *
     C                     MOVE @SNO      #KODER
      * PART & WASHER
     C           @NO       IFEQ '1'
     C                     MOVEL@PARTS    @HIN   12
      *
     C           KEYORN    SETLLGDGPL18
     C                     SETOF                     81
     C                     DO   *HIVAL
     C                     READ GDGPL181                 81
     C                     SETOF                     67
      *
     C           *IN81     IFEQ '0'
     C           ICSKJY    ANDEQ'D'
     C           ICSKHZ    ANDLEHYMD8
     C                     SETON                     67
     C                     END
      *
     C           *IN81     IFEQ '0'
     C           ICIFMK    ANDEQ'C'
     C                     SETON                     67
     C                     END
      *
     C           *IN81     IFEQ '0'
     C           *IN67     ANDEQ'0'
     C           ICODER    IFGE @SNO
     C           ICODER    ANDLE@ENO
      *
     C           @HIN      IFEQ *BLANK
     C                     SETON                     66
     C                     ELSE
     C           ICHIN     IFEQ @HIN
     C                     SETON                     66
     C                     END
     C                     END
      *
     C                     END
     C                     END
     C  N81N66             END
      *
     C                     END
      * TOOL
     C           @NO       IFEQ '2'
     C                     MOVEL@PARTS    @KATA   8
     C                     MOVEL@PARTS    @KAT6   6
      *
     C           KEYORN    SETLLGDIPL18
     C                     SETOF                     81
     C                     DO   *HIVAL
     C                     READ GDIPL181                 81
     C                     SETOF                     67
      *
     C           *IN81     IFEQ '0'
     C           IISKJY    ANDEQ'D'
     C           IISKHZ    ANDLEHYMD8
     C                     SETON                     67
     C                     END
      *
     C           *IN81     IFEQ '0'
     C           IIIFMK    ANDEQ'C'
     C                     SETON                     67
     C                     END
      *
     C           *IN81     IFEQ '0'
     C           *IN67     ANDEQ'0'
     C           IIODER    IFGE @SNO
     C           IIODER    ANDLE@ENO
      *
     C           @KATA     IFEQ *BLANK
     C                     SETON                     66
     C                     ELSE
     C*******    IIKATA    IFEQ @KATA
     C           IIKAT6    IFEQ @KAT6
     C                     SETON                     66
     C                     END
     C                     END
      *
     C                     END
     C                     END
     C  N81N66             END
      *
     C                     END
      *
     C           *IN81     IFEQ '1'
     C           *IN66     ANDEQ'0'
     C                     SETON                     323334
     C                     SETON                     99
     C*                    MOVEL$ER,5     @ERR
     C                     MOVEL'E'       RETNCD
     C                     SETON                     LR
     C                     RETRN
     C*
     C                     GOTO $S220E
     C                     END
      *------------------------*
      * CREATE OF INQUIRY DATA *
      *------------------------*
      *
      * PARTS / WASHER
     C           @NO       IFEQ '1'
     C                     SETOF                     6681
     C           KEYORN    SETLLGDGPL18
     C                     DO   *HIVAL
     C                     MOVE *BLANK    GETFLG
     C                     EXSR $SB900
     C           GETFLG    IFEQ '1'
     C                     EXSR $SB500
     C                     END
     C  N81                END
     C                     END
      * TOOL
     C           @NO       IFEQ '2'
     C                     SETOF                     6681
     C           KEYORN    SETLLGDIPL18
     C                     DO   *HIVAL
     C                     MOVE *BLANK    GETFLG  1
     C                     EXSR $SB910
     C           GETFLG    IFEQ '1'
     C                     EXSR $SB510
     C                     END
     C  N81                END
     C                     END
     C                     SETON                       05
     C                     MOVE '0'       DSPSW2
      *
     CSR         $S220E    ENDSR
      *----------------------------------------------------*
      *   終了処理                                       *
      *----------------------------------------------------*
     CSR         $SB300    BEGSR
     C                     MOVE @SNO      PSNO    6
     C                     MOVE @ENO      PENO    6
     C           PNO       IFEQ *BLANK
     C                     MOVE @NO       PNO     1
     C                     END
     C                     MOVEL@PARTS    PPART  15
     C           *IN01     IFEQ '1'
     C                     MOVE '9'       RETNCD
     C                     END
     C                     SETON                     LR
     C                     RETRN
     CSR         $S300E    ENDSR
      *----------------------------------------------------*
      *  INQUIRY DATA CREATE  (PARTS . WASHER)             *
      *----------------------------------------------------*
     CSR         $SB500    BEGSR
     C           KEYIG1    SETLLGDGPL25
     C                     SETOF                     8269
     C                     DO   *HIVAL
     C           KEYIG1    READEGDGPL25                  82
     C                     SETOF                     68
     C           *IN82     IFEQ '0'
     C           IESKJY    ANDEQ'D'
     C           IESKHZ    ANDLEHYMD8
     C                     SETON                     68
     C                     END
     C           *IN82     IFEQ '0'
     C           *IN68     ANDEQ'0'
     C                     MOVEL@PARTS    @HIN
     C                     MOVE *BLANK    SELFLG
     C           @PARTS    IFEQ *BLANK
     C                     MOVE '1'       SELFLG
     C                     ELSE
     C           IEHIN     IFEQ @HIN
     C                     MOVE '1'       SELFLG
     C                     END
     C                     END
      *
     C           SELFLG    IFEQ '1'
     C                     MOVELIEINVO    IXINV1
     C                     MOVE IEINVO    IXINV2
     C                     MOVE IESKOY    IXSPYY
     C                     MOVE IESKOM    IXSPMM
     C                     MOVE IESKOD    IXSPDD
     C                     ADD  IESURY    IXNOSU
     C                     ADD  IESBOX    IXNOHK
     C********             MOVE IEHANY    IXHANY
      * WITH  RESERVATIONS
     C                     MOVE *ZERO     IXMINO
     C                     MOVE *ZERO     IXMIHK
      *
     C                     Z-ADD0         IXKAZI
     C                     SETON                     69
     C                     END
      *
     C                     END
      *
     C  N82                END
      * MSK 2000.11.09
     C           *IN69     IFEQ '1'
     C           IXMAIS    SUB  IXNOHK    IXMIHK
     C           IXSURY    SUB  IXNOSU    IXMINO
     C                     WRITEGDGWP801
     C                     ADD  IXMAIS    TMAIS
     C                     ADD  IXNOHK    TNOHK
     C                     ADD  IXMIHK    TMIHK
     C                     Z-ADD0         IXNOSU
     C                     Z-ADD0         IXNOHK
     C                     END
      *-------------------*
     C           *IN82     IFEQ '1'
     C           *IN69     ANDEQ'0'
     C                     MOVE *BLANK    IXINV1
     C                     Z-ADD0         IXINV2
     C                     Z-ADD0         IXSPYY
     C                     Z-ADD0         IXSPMM
     C                     Z-ADD0         IXSPDD
     C                     Z-ADD0         IXNOSU
     C                     Z-ADD0         IXNOHK
     C********             MOVE *BLANK    IXHANY
     C                     Z-ADD0         IXMINO
     C                     Z-ADD0         IXMIHK
     C                     Z-ADD0         IXKAZI
     C                     SETON                     69
      *
     C                     WRITEGDGWP801
     C                     ADD  IXMAIS    TMAIS
     C                     ADD  IXNOHK    TNOHK
     C                     ADD  IXMIHK    TMIHK
     C                     Z-ADD0         IXNOSU
     C                     Z-ADD0         IXNOHK
     C                     END
     CSR         $S500E    ENDSR
      *----------------------------------------------------*
      *  INQUIRY DATA CREATE  (TOOL)                       *
      *----------------------------------------------------*
     CSR         $SB510    BEGSR
     C           KEYIG1    SETLLGDIPL25
     C                     SETOF                     8269
     C                     DO   *HIVAL
     C           KEYIG1    READEGDIPL25                  82
     C                     SETOF                     68
     C           *IN82     IFEQ '0'
     C           IKSKJY    ANDEQ'D'
     C           IKSKHZ    ANDLEHYMD8
     C                     SETON                     68
     C                     END
     C           *IN82     IFEQ '0'
     C           *IN68     ANDEQ'0'
     C                     MOVEL@PARTS    @KATA
     C                     MOVE *BLANK    SELFLG
     C           @PARTS    IFEQ *BLANK
     C                     MOVE '1'       SELFLG
     C                     ELSE
     C*******    IKKATA    IFEQ @KATA
     C           IKKAT6    IFEQ @KAT6
     C                     MOVE '1'       SELFLG
     C                     END
     C                     END
      *
     C           SELFLG    IFEQ '1'
     C                     MOVELIKINVO    IXINV1
     C                     MOVE IKINVO    IXINV2
     C                     MOVE IKSKOY    IXSPYY
     C                     MOVE IKSKOM    IXSPMM
     C                     MOVE IKSKOD    IXSPDD
     C                     ADD  IKSURY    IXNOSU
     C                     ADD  IKSBOX    IXNOHK
     C*********            MOVE IKHANY    IXHANY
      * WITH  RESERVATIONS
     C                     MOVE *ZERO     IXMINO
     C                     MOVE *ZERO     IXMIHK
      *
     C                     Z-ADD0         IXKAZI
     C                     SETON                       69
     C                     END
      *
     C                     END
     C  N82                END
      * MSK 2000.11.09
     C           *IN69     IFEQ '1'
     C           IXMAIS    SUB  IXNOHK    IXMIHK
     C           IXSURY    SUB  IXNOSU    IXMINO
     C                     WRITEGDGWP801
     C                     ADD  IXMAIS    TMAIS
     C                     ADD  IXNOHK    TNOHK
     C                     ADD  IXMIHK    TMIHK
     C                     Z-ADD0         IXNOSU
     C                     Z-ADD0         IXNOHK
     C                     END
      *-------------------*
     C           *IN82     IFEQ '1'
     C           *IN69     ANDEQ'0'
     C                     MOVE *BLANK    IXINV1
     C                     Z-ADD0         IXINV2
     C                     Z-ADD0         IXSPYY
     C                     Z-ADD0         IXSPMM
     C                     Z-ADD0         IXSPDD
     C                     Z-ADD0         IXNOSU
     C                     Z-ADD0         IXNOHK
     C*********            MOVE *BLANK    IXHANY
     C                     Z-ADD0         IXMINO
     C                     Z-ADD0         IXMIHK
     C                     Z-ADD0         IXKAZI
     C                     SETON                     69
      *
     C                     WRITEGDGWP801
     C                     ADD  IXMAIS    TMAIS
     C                     ADD  IXNOHK    TNOHK
     C                     ADD  IXMIHK    TMIHK
     C                     Z-ADD0         IXNOSU
     C                     Z-ADD0         IXNOHK
     C                     END
     CSR         $S510E    ENDSR
      *----------------------------------------------------*
      *  DALY ORDER DATA READ  (PARTS . WASHER)            *
      *----------------------------------------------------*
     C           $SB900    BEGSR
     C                     READ GDGPL181                 81
     C                     SETOF                     67
      *
     C           *IN81     IFEQ '0'
  KK C           ICIFMK    ANDEQ'C'
     C                     ELSE
      *
     C           *IN81     IFEQ '0'
     C           ICSKJY    ANDEQ'D'
     C           ICSKHZ    ANDLEHYMD8
     C                     SETON                     67
     C                     END
      *
     C           ICODER    IFGT @ENO
     C                     SETON                     81
     C                     END
      *
     C           *IN81     IFEQ '0'
     C           *IN67     ANDEQ'0'
     C           ICODER    IFGE @SNO
     C           ICODER    ANDLE@ENO
     C                     MOVE '1'       GETFLG
     C                     END
     C                     END
      *
     C           GETFLG    IFEQ '1'
     C                     MOVE *BLANK    GETFLG
     C           @PARTS    IFEQ *BLANK
     C                     MOVE '1'       GETFLG
     C                     ELSE
     C           ICHIN     IFEQ @HIN
     C                     MOVE '1'       GETFLG
     C                     END
     C                     END
     C                     END
      *
     C           GETFLG    IFEQ '1'
     C                     MOVE '1'       GETFLG
     C                     MOVE ICODER    #KODER
     C                     MOVE ICITEM    #KITEM
      *
     C                     MOVE ICODER    IXODER
     C                     MOVE ICITEM    IXITEM
     C                     MOVELICHIN     IXPART
     C                     MOVE ICSYOS    IXSYOS
     C                     MOVE ICMAIS    IXMAIS
     C                     MOVE ICSURY    IXSURY
     C                     MOVE ICODRY    IXODRY                       -
     C                     MOVE ICODRM    IXODRM                       -
     C                     MOVE ICODRD    IXODRD                       -
     C*
     C                     MOVE ICHANY    IXHANY
     C                     Z-ADDICDLVY    IXDLVY           DELIVERY DATE YEAR
     C                     Z-ADDICDLVM    IXDLVM           DELIVERY DATE MONTH
     C                     Z-ADDICDLVD    IXDLVD           DELIVERY DATE DAY
      *
     C                     END
     C                     END
     CSR         $S900E    ENDSR
      *----------------------------------------------------*
      *  DALY ORDER DATA READ  (TOOL)                      *
      *----------------------------------------------------*
     C           $SB910    BEGSR
     C                     READ GDIPL181                 81
     C                     SETOF                     67
      *
     C           *IN81     IFEQ '0'
     C           IISKJY    ANDEQ'D'
     C           IISKHZ    ANDLEHYMD8
     C                     SETON                     67
     C                     END
      *
     C           IIODER    IFGT @ENO
     C                     SETON                     81
     C                     END
      *
     C           *IN81     IFEQ '0'
     C           *IN67     ANDEQ'0'
     C           IIODER    IFGE @SNO
     C           IIODER    ANDLE@ENO
     C                     MOVE '1'       GETFLG
     C                     END
     C                     END
      *
     C           GETFLG    IFEQ '1'
     C                     MOVE *BLANK    GETFLG
     C           @PARTS    IFEQ *BLANK
     C                     MOVE '1'       GETFLG
     C                     ELSE
     C*******    IIKATA    IFEQ @KATA
     C           IIKAT6    IFEQ @KAT6
     C                     MOVE '1'       GETFLG
     C                     END
     C                     END
     C                     END
      *
     C           GETFLG    IFEQ '1'
     C                     MOVE '1'       GETFLG
     C                     MOVE IIODER    #KODER
     C                     MOVE IIITEM    #KITEM
      *
     C                     MOVE IIODER    IXODER
     C                     MOVE IIITEM    IXITEM
     C                     MOVELIIKATA    IXPART
     C                     MOVE IISYOS    IXSYOS
     C                     MOVE IIMAIS    IXMAIS
     C                     MOVE IISURY    IXSURY
     C                     MOVE IIODRY    IXODRY                       -
     C                     MOVE IIODRM    IXODRM                       -
     C                     MOVE IIODRD    IXODRD                       -
     C*
     C                     MOVE IIHANY    IXHANY
     C                     Z-ADDIIDLVY    IXDLVY           DELIVERY DATE YEAR
     C                     Z-ADDIIDLVM    IXDLVM           DELIVERY DATE MONTH
     C                     Z-ADDIIDLVD    IXDLVD           DELIVERY DATE DAY
      *
     C                     END
     CSR         $S910E    ENDSR
**
PART & WASHER
TOOL
IN THE MAKING INQUIRY DATA FILE
