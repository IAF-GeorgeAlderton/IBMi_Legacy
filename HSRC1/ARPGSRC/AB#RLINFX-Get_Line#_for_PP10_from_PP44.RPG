     H            Y.
     FAB#PL1L UF  E           K        DISK
     FAB#PL44DIF  E           K        DISK
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  140SDATE
     I                                        7  100SDYY
     I                                       11  120SDMM
     I                                       13  140SDDD
     I                                        1   60STIME
     I                                        1   20STHH
     I                                        3   40STMM
      *
     I            DS
     I                                        1   8 ##NYMD
     I                                        1   40P#NOYY
     I                                        5   60P#NOMM
     I                                        7   80P#NODD
      *
     I            DS
     I                                        1   80BANYMD
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
      *
     I            DS
     I                                        1  12 MHN
     I                                        1   5 MHN1
     I                                        6  10 MHN2
     I                                       11  12 MHN3
     I                                        1  20 MHN20
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P#NYMD  8
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
      *
     C           K#1L      SETLLAB#PL1L
     C                     READ AB#PL1L                  50
      *
     C           *IN50     DOWEQ*OFF
      *
     C           BALIN#    IFEQ *BLANK
      *
     C                     EXSR CHK44P
     C           #LINE#    IFNE *BLANKS
     C                     MOVEL#LINE#    BALIN#
     C                     MOVEL'X'       BAFLG1
     C                     UPDATAB#PL1L1
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     READ AB#PL1L                  50
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVELP#NYMD    ##NYMD
     C                     Z-ADD323       NONY
      *
     C           K#1L      KLIST
     C                     KFLD           NONY    40
     C                     KFLD           P#NOYY
     C                     KFLD           P#NOMM
     C                     KFLD           P#NODD
      *
     C           K#44D     KLIST
     C                     KFLD           NONY
     C                     KFLD           ODRN15
     C                     KFLD           BAMHN1
     C                     KFLD           BAMHN2
     C                     KFLD           BAMHN3
     C                     KFLD           BAMHN4
      *
     CSR         ESB100    ENDSR
      *------------------------------------------------------------------*
      * Get Orig PO Line Number from EDI file.             *
      *
     C           CHK44P    BEGSR
      *
     C                     MOVELBAODRN    ODRN15 15
     C                     MOVE *BLANKS   #LINE#  5
      *
     C           K#44D     SETLLAB#PL44D
      *
     C                     MOVE *OFF      *IN51
     C           *IN51     DOWEQ*OFF
     C           K#44D     READEAB#PL44D                 51
      *
     C           *IN51     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C           DANUKE    IFNE BANUKE
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELDALINE    #LINE#
     C                     LEAVE
      *
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------*
