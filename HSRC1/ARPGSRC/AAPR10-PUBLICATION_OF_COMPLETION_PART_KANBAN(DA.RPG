     F*          |     |          |          EXPANSION OF THE "KANBAN"*
     F******************************************************* AAPR10 **
     FAAPPP01 UP  E                    DISK
     F*****AAPPL05 IF  E           K        DISK
     I            DS
     I                                        1   80L5SKHZ
     I                                        1   40L5SKYY
     I                                        5   60L5SKMM
     I                                        7   80L5SKDD
     I            DS
     I                                        1   80L5STHZ
     I                                        1   40L5STYY
     I                                        5   60L5STMM
     I                                        7   80L5STDD
     I            DS
     I                                        1  12 L5SHIN
     I                                        1   5 L5SHN1
     I                                        6  10 L5SHN2
     I                                       11  12 L5SHN3
%0001 *
     I            DS
     I                                        1   80L5UKHZ
     I                                        1   40L5UKYY
     I                                        5   60L5UKMM
     I                                        7   80L5UKDD
     I            DS
     I                                        1   6 KTKR
     I                                        1   1 KTKR1
     I                                        2   3 KTKR2
     I                                        4   5 KTKR3
     I                                        6   6 KTKR4
%0001 *
     C           *ENTRY    PLIST
     C                     PARM           PUS    10
      *
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    IFLE *DATE
     C                     GOTO END
     C                     END
     C                     END
      *
     C           L5DTKO    IFEQ '2'
     C           L5DTKO    OREQ 'D'
     C                     GOTO END
     C                     END
      *
     C           L5SYOS    IFEQ 0
     C                     GOTO END
     C                     END
      *
     C           L5KOUT    IFNE 'Y'
     C                     GOTO END
     C                     END
      *
     C           L5KMIN    IFEQ L5KMAX
     C                     GOTO END
     C                     END
      *
     C           L5STHZ    IFNE 99999999
     C                     GOTO END
     C                     END
      *
     C*****                Z-ADDL5SYOS    WSYOS   60
      *
     C*****                MOVE L5KMIN    PKMIN   3
     C*****                MOVE L5KMAX    PKMAX   3
     C*****                MOVE WSYOS     PSYOS   6
%0001 *
     C*****                Z-ADDL5STI1    WSTI1   20
     C*****                MOVE L5KCD1    PKCD1   1
     C*****                MOVE L5SHIN    PSHIN  12
     C*****                MOVE L5ZETI    PZETI   4
     C*****                Z-ADDL5UKHZ    WUKHZ   80
     C*****                Z-ADDL5UBIN    WUKBB   20
      *
     C*****                MOVE L5ZETI    KZETI   4
     C*****                Z-ADDL5UKYY    KUKYY   40
     C*****                Z-ADDL5UKMM    KUKMM   20
     C*****                Z-ADDL5UKDD    KUKDD   20
     C*****                Z-ADDL5UBIN    KUBIN   20
%0001 *
     C                     MOVE *BLANK    L5KOUT
     C                     MOVE 'Y'       L5DOUT
     C                     MOVE '*'       L5DTHE
      *
     C                     UPDATAAPPP011
%0001 *
     C*****      WSTI1     IFLE 49
     C*****                EXSR #MAI
     C*****                END
%0001 *
     C*                    CALL 'AAPR02'
     C*                    PARM           PUS
     C*                    PARM           PKCD1
     C*                    PARM           PSHIN
     C*                    PARM           PKMIN
     C*                    PARM           PKMAX
     C*                    PARM           PZETI
     C*                    PARM           PSYOS
      *
     C           END       TAG
%0001 *-----------------------------------------------------*
      *             前回かんばん枚数収得                  *
      *-----------------------------------------------------*
     C*****      #MAI      BEGSR
     C*****      KEY1      KLIST
     C*****                KFLD           KZETI
     C*****                KFLD           KUKYY
     C*****                KFLD           KUKMM
     C*****                KFLD           KUKDD
     C*****                KFLD           KUBIN
     C*****      KEY1      SETLLAAPPL051
     C*****                DO   *HIVAL
     C*****                SETOF                     55
     C*****                READPAAPPL051                 55
     C*****      *IN55     IFEQ '0'
     C*****      L5SHIN    IFEQ PSHIN
     C*****      L5STHZ    IFEQ WUKHZ
     C*****      L5SBIN    ANDEQWUKBB
