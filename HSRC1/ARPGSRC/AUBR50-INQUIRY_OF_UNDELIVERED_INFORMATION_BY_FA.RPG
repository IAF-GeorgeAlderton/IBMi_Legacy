     H            Y
     F*******************************************
     F* INQUIRY OF UNDELIVERED INFORMATION BY FACTORY APPOINTMENT AUBR50
     F*******************************************
     FAUBPW50 CF  E                    WORKSTN
     E                    $MSG    1   4 60
     C/SPACE 1
     C************************
     C*  初期処理          *
     C************************
     C*
     C           *ENTRY    PLIST
     C                     PARM           PARM1   1
     C                     MOVE *DATE     @DATE
     C                     TIME           @TIME
     C           $100S     TAG
     C                     EXFMTAUBPW501
     C                     MOVE *BLANK    @ERR
     C                     SETOF                     101199
     C           *IN01     IFEQ '1'
     C                     MOVE '9'       PARM1
     C                     SETON                       LR
     C                     RETRN
     C                     END
     C************************
     C*  入力チェック処理  *
     C************************
     C*
     C           @TYPE     IFNE '1'
     C           @TYPE     IFNE '2'
     C           @TYPE     IFNE '3'
     C           @TYPE     IFNE '4'
     C                     SETON                     1099
     C                     MOVEL$MSG,1    @ERR
     C                     GOTO $100S
     C                     END
     C                     END
     C                     END
     C                     END
     C           @TYPE     IFNE '4'
     C           @KEY      IFNE 'A'
     C           @KEY      IFNE 'B'
     C                     SETON                     1199
     C                     MOVEL$MSG,2    @ERR
     C                     GOTO $100S
     C                     END
     C                     END
     C                     END
     C*
     C           @TYPE     IFEQ '1'
     C           @KEY      IFEQ 'A'
     C                     MOVE '1'       PARM1
     C                     ELSE
     C                     MOVE '2'       PARM1
     C                     END
     C                     END
     C           @TYPE     IFEQ '2'
     C           @KEY      IFEQ 'A'
     C                     MOVE '3'       PARM1
     C                     ELSE
     C                     MOVE '4'       PARM1
     C                     END
     C                     END
     C           @TYPE     IFEQ '3'
     C           @KEY      IFEQ 'A'
     C                     MOVE '5'       PARM1
     C                     ELSE
     C                     MOVE '6'       PARM1
     C                     END
     C                     END
     C           @TYPE     IFEQ '4'
     C           @KEY      IFEQ *BLANK
     C                     MOVE '7'       PARM1
     C                     ELSE
     C                     SETON                     1199
     C                     MOVEL$MSG,3    @ERR
     C                     GOTO $100S
     C                     END
     C                     END
     C                     MOVEL$MSG,4    @MSG
     C                     SETON                       97
     C                     WRITEAUBPW501
     C                     SETON                       LR
     C                     RETRN
**
THE SELECT NO IS WRONG
SELECT KEY IS WRONG
SELECT KEY USELESSNESS
NOW SEARCHING INQUIRY PGMS
