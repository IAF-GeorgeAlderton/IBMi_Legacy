     H            Y.
     F** MRAR92 *********************************************
     F* UNTRANSMIT LIST                                     *
     F*     TRANCOM ITS.           2012.09.18               *
     F*******************************************************
     FMRAPL11 IF  E           K        DISK
      *
     I            DS
     I                                        1   80MASKHZ
     I                                        1   40MASKYY
     I                                        5   60MASKMM
     I                                        7   80MASKDD
      *
     I            DS
     I                                        1   80MASAHZ
     I                                        1   40MASAYY
     I                                        5   60MASAMM
     I                                        7   80MASADD
      *
     C           *ENTRY    PLIST
     C                     PARM           P1KENO  9
     C                     PARM           P1KENA  1
     C                     PARM           P1KEED  2
     C                     PARM           P1KAHZ  8
     C                     PARM           P9STAT  2
     C                     PARM           P9GET   1
      *
     C           KEYMA1    KLIST
     C                     KFLD           P1KENO
     C                     KFLD           P1KENA
     C                     MOVELP1KAHZ    WKKAHZ  80
     C                     MOVEL'00'      P9STAT
     C                     MOVEL'0'       P9GET
     C                     MOVEL'00'      WKSTAT  2
     C                     MOVEL'0'       GET     1
     C           KEYMA1    SETGTMRAPL111
     C           KEYMA1    REDPEMRAPL111                 80
     C           *IN80     DOWEQ'0'
     C           WKSTAT    ANDEQ'00'
     C           MASKJY    IFEQ 'D'
     C           MASKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #SB400
     C                     ENDIF
     C           KEYMA1    REDPEMRAPL111                 80
     C                     ENDDO
      *
     C                     MOVELWKSTAT    P9STAT
     C                     MOVELGET       P9GET
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     SELEC
     C           MASTAT    WHEQ '01'
     C                     EXSR #SB401
     C           MASTAT    WHEQ '03'
     C                     EXSR #SB403
     C                     OTHER
     C                     MOVELMASTAT    WKSTAT
     C                     ENDSL
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB401    BEGSR
      *
     C           MALIDT    IFNE 0
     C                     GOTO ESB401
     C                     ENDIF
      *
     C           MASAHZ    IFGT WKKAHZ
     C                     GOTO ESB401
     C                     ENDIF
      *
     C                     MOVEL'01'      WKSTAT
     C                     MOVEL'1'       GET
      *
     CSR         ESB401    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB403    BEGSR
      *
     C           MALIDT    IFNE 0
     C                     GOTO ESB403
     C                     ENDIF
      *
     C           MASBDT    IFGT WKKAHZ
     C                     GOTO ESB403
     C                     ENDIF
      *
     C                     MOVEL'03'      WKSTAT
     C                     MOVEL'1'       GET
      *
     CSR         ESB403    ENDSR
