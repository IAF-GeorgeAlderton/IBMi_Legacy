     C*--------------*
     C*  画面－１  *
     C*--------------*
     C           STP1      TAG
     C                     EXFMTAIAPW071
     C                     SETOF                     0199
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           WIKOJ     IFEQ 0
     C                     SETON                     0199
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     END
      *
     C           WIKOJ     IFNE 0111
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
      *
     C           *INKE     IFEQ '0'
     C           *INKG     ANDEQ'0'
     C                     GOTO STP1
     C                     END
      *
     C           *INKG     IFEQ '1'
     C                     MOVE 'D'       PDSKT
     C                     END
      *
     C                     MOVE WIKOJ     PBMN1
      *
     C                     SETON                     U1
     C*----------------------------*
     C* GET DAY 1 YEAR AGO        *
     C*----------------------------*
     C                     MOVE *DATE     PDATE
     C                     MOVE '-'       PPORM
     C                     MOVE '0365'    PDAYS
     C                     CALL 'DATR12'
     C                     PARM           PDATE   8
     C                     PARM           PPORM   1        + OR -
     C                     PARM           PDAYS   4
     C                     PARM           PRDAT   8
     C                     PARM           PRTN    1
     C                     MOVE PRDAT     XDATE   80
      *
     C*----------------------------*
     C*  メッキかんばんマスター  *
     C*----------------------------*
     C                     DO   *HIVAL
     C                     SETOF                         01
     C                     READ AAFTL011                 01
     C           *IN01     IFEQ '1'
     C                     GOTO STP2
     C                     END
      *
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLE*DATE
     C                     GOTO MP1
     C                     END
     C           A3STHZ    IFLT XDATE
     C***        A3UKHZ    IFGE *DATE
     C***        A3STHZ    ANDLT*DATE
     C                     GOTO MP1
     C                     END
      *
     C           A3MAKB    CABEQ0         MP1
     C*
      *
     C                     MOVE A31HB5    WHIN1   5
     C                     MOVE A32HB5    WHIN2   5
     C                     MOVE A33HB2    WHIN3   2
     C                     SETOF                     8889
     C           KEYHIN    CHAINAGAPL31              88
     C           *IN88     IFEQ '0'
     C           CBSKJY    IFEQ 'D'
     C           CBSKHZ    ANDLE*DATE
     C                     SETON                     88
     C                     END
     C           *IN88     IFEQ '0'
