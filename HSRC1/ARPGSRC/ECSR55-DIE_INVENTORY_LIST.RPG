     FECSPW55 CF  E                    WORKSTN
     FECSPL20 IF  E           K        DISK
     FECSWL10 IF  E           K        DISK
     FECSPL05 IF  E           K        DISK
     FECQPP01 IF  E           K        DISK
     FECSPL10 IF  E           K        DISK
TCHK2F*GKGDDM  IF  E           K        DISK
TCHK2F*JW1 GKGPP50 IF  E           K        DISK
     F*JW1 GDIPL27 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FAB#PPCT UF  E           K        DISK
     FECSWP55 O   F      90            DISK
     FECSWP551O   E                    DISK
      *-----------------------------------------------------------
     E                    CMD     1   1 78
     E                    MSG     1   1 78
      *-----------------------------------------------------------
      *
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I                                        1   60K@YYMM
     I            DS
     I                                        1   80D@DATE
     I                                        1   40D@YY
     I                                        5   60D@MM
     I                                        7   80D@DD
     I            DS
     I                                        1   80EQYMD
     I                                        1   40EQYOYY
     I                                        5   60EQYOMM
     I                                        7   80EQYODD
     I            DS
     I                                        1   80WTO3
     I                                        1   40GKEDYY
     I                                        5   60GKEDMM
     I                                        7   80GKEDDD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------
      *  MAIN ROUTINE
      *--------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVEL'ECSR55  'K@KWD   8 P
     C           K@KWD     CHAINAB#PPCT              90
     C           *IN90     IFEQ *OFF
     C                     MOVEL*BLANK    CTCHR1
     C                     UPDATAB#PPCT1
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *------------------------------------------------------
      *
     C           KEY1      KLIST
     C                     KFLD           E1KAT1
     C                     KFLD           E1KAT2
     C                     KFLD           E1KAT3
     C******               KFLD           E1KAT4
     C                     KFLD           @@DATE
     C           KEY2      KLIST
     C                     KFLD           E1KAT1
     C                     KFLD           E1KAT2
     C                     KFLD           E1KAT3
     C******               KFLD           E1KAT4
     C           K#EC1     KLIST
     C                     KFLD           E1KAT1
     C                     KFLD           E1KAT2
     C                     KFLD           E1KAT3
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#EC11    KLIST
     C                     KFLD           E1KAT1
     C                     KFLD           E1KAT2
     C                     KFLD           E1KAT3
     C           K#WK      KLIST
     C                     KFLD           E1KAT1
     C                     KFLD           E1KAT2
     C                     KFLD           E1KAT3
     C*****                KFLD           E1KAT4
     C           K#WKX     KLIST
     C                     KFLD           E1KAT1
     C                     KFLD           E1KAT2
     C                     KFLD           E1KAT3
     C           K#WKY     KLIST
     C                     KFLD           E1KAT1
     C                     KFLD           E1KAT2
     C           K#WL      KLIST
     C                     KFLD           D@DATE
     C                     KFLD           E1KAT1
     C                     KFLD           E1KAT2
     C                     KFLD           E1KAT3
     C*****                KFLD           E1KAT4
     C           K#WLX     KLIST
     C                     KFLD           @@DATE
     C                     KFLD           E1KAT1
     C                     KFLD           E1KAT2
     C                     KFLD           E1KAT3
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
      *
     C                     MOVE '01'      W@ID    2
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SCRN1    BEGSR
      *-----------------------------------------------------
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
      * F1: END
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK
      * F5: CREATE DATA
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #OUT
      * CSV INTO K DRIVE
JW   C                     CALL 'ECSC55D'
      *
     C                     MOVE '99'      W@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #CHK      BEGSR
      *-----------------------------------------------------
     C                     SETOF                     616299
     C                     MOVE *BLANK    D@MSG
      *
     C                     Z-ADDD@YYMM    K@YYMM
     C           K#AGD     SETGTAGDPL12
     C           K#AGD     REDPEAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDF8KAYY    D@YY
     C                     Z-ADDF8KAMM    D@MM
     C                     Z-ADDF8KADD    D@DD
     C                     ENDIF
      *
     C           D@DATE    CHAINECSWL10              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     MOVE MSG,1     D@MSG
     C                     ENDIF
      *
     C                     Z-ADDD@DATE    K@YMD
      *
     C                     ENDSR
      *------------------------------------------------------
      *   OUTPUT
      *------------------------------------------------------
     C           #OUT      BEGSR
      *
     C                     TIME           @@TIM   60
     C           D@DATE    CHAINECSWL10              90
     C           *IN90     IFEQ *OFF
     C                     EXSR #OUT1
     C********             EXSR #OUT3
     C                     ELSE
     C                     EXSR #OUT2
     C********             EXSR #OUT3
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   OUTPUT
      *------------------------------------------------------
     C           #OUT1     BEGSR
      *
     C           D@DATE    SETLLECSWL10
 B0  C           *IN90     DOUEQ*ON
     C           D@DATE    READEECSWL10                  90
 B1  C           *IN90     IFEQ *OFF
      * NEW INVENTORY
     C                     Z-ADDE1SQTY    @NQTY
     C                     Z-ADD*ZERO     @@UPRC 100
      * UNIT PRICE
     C                     EXSR #UPRC
      *
     C           @NQTY     MULT @@UPRC    @@AMT  100
     C                     EXCPT@DTL
TCHK1C                     Z-ADDD@YYMM    @IYYMM
TCHK1C                     WRITEECSWP55R
      *
     C           K#WL      SETGTECSWL10
 E1  C                     ENDIF
 E0  C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   UNIT PRICE
      *------------------------------------------------------
     C           #UPRC     BEGSR
      *
     C**JW1      K#WKX     SETGTGDIPL27
     C**         *IN95     DOUEQ*ON
     C**         K#WKX     REDPEGDIPL27                  95
     C**         *IN95     IFEQ *OFF
     C**         IKSKJY    ANDEQ*BLANK
     C**                   Z-ADDIKTANK    @@UPRC
     C**                   LEAVE
     C**                   ENDIF
     C**                   ENDDO
      *
     C**JW1      @@UPRC    IFEQ *ZERO
TCHK2C**         K#WKY     SETGTGKGPP50
     C**         *IN95     DOUEQ*ON
TCHK2C**         K#WKY     REDPEGKGPP50                  95
     C**         *IN95     IFEQ *OFF
     C**         IKSKJY    ANDEQ*BLANK
     C**         WTO3      ANDGE*DATE
     C**                   Z-ADDGKNHTN    @@UPRC
     C**                   LEAVE
     C**                   ENDIF
     C**                   ENDDO
     C**                   ENDIF
      *
     C**JW1      @@UPRC    IFEQ *ZERO
     C           K#WKY     SETGTECQPP01
     C           *IN95     DOUEQ*ON
     C           K#WKY     REDPEECQPP01                  95
     C           *IN95     IFEQ *OFF
     C           ECSKJY    ANDEQ*BLANK
     C           ECVALD    ANDLED@DATE
     C                     Z-ADDECUPRC    @@UPRC 100
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C**                   ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   OUTPUT
      *------------------------------------------------------
     C           #OUT3     BEGSR
      *
     C           *LOVAL    SETLLECSPL10
     C           *IN90     DOUEQ*ON
     C                     READ ECSPL10                  90
     C           *IN90     IFEQ *OFF
      * NEW INVENTORY
     C           K#WL      CHAINECSWL10              95
     C           *IN95     IFEQ *ON
     C                     Z-ADD*ZERO     @IQTY   50
     C           KEY2      SETGTECSPL20              96
     C           *IN96     DOUEQ*ON
     C           KEY2      REDPEECSPL20                  96
     C           *IN96     IFEQ *OFF
     C           E2DATE    IFLE D@DATE
     C                     LEAVE
     C                     ENDIF
     C           E2WHID    IFNE '3'
     C                     ADD  E2WQTY    @IQTY
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *  OUT
     C                     Z-ADD*ZERO     @OQTY   50
     C           K#EC11    SETGTECSPL05
     C           *IN96     DOUEQ*ON
     C           K#EC11    REDPEECSPL05                  96
     C           *IN96     IFEQ *OFF
     C           EQYMD     IFLE D@DATE
     C                     LEAVE
     C                     ENDIF
     C                     ADD  EQKOSU    @OQTY
     C                     ENDIF
     C                     ENDDO
      * NEW INVENTORY
     C           E1SQTY    ADD  @OQTY     @NQTY   50
     C                     SUB  @IQTY     @NQTY
      *
     C                     EXSR #UPRC
     C           @NQTY     MULT @@UPRC    @@AMT  100
     C                     EXCPT@DTL
TCHK1C                     Z-ADDD@YYMM    @IYYMM
TCHK1C                     WRITEECSWP55R
      *
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   OUTPUT
      *------------------------------------------------------
     C           #OUT2     BEGSR
      *
     C           *HIVAL    SETGTECSWL10
     C                     READPECSWL10                  90
 B0  C           *IN90     IFEQ *OFF
     C                     Z-ADDE1DATE    @@DATE  80
 E0  C                     ENDIF
      *
     C                     Z-ADD@@DATE    K@YMD
      *
     C           @@DATE    SETLLECSWL10
 B0  C           *IN90     DOUEQ*ON
     C           @@DATE    READEECSWL10                  90
 B1  C           *IN90     IFEQ *OFF
      * IN
     C                     Z-ADD*ZERO     @IQTY   50
     C           KEY1      SETLLECSPL20              95
 B2  C           *IN95     DOUEQ*ON
     C           KEY2      READEECSPL20                  95
 B3  C           *IN95     IFEQ *OFF
     C           E2DATE    ANDGT@@DATE
     C           E2DATE    ANDLED@DATE
     C           E2WHID    ANDNE'3'
     C                     ADD  E2WQTY    @IQTY
 E3  C                     ENDIF
 E2  C                     ENDDO
      *  OUT
     C                     Z-ADD*ZERO     @OQTY   50
     C           K#EC1     SETLLECSPL05
 B2  C           *IN95     DOUEQ*ON
     C           K#EC11    READEECSPL05                  95
 B3  C           *IN95     IFEQ *OFF
     C           EQYMD     ANDGT@@DATE
     C           EQYMD     ANDLED@DATE
     C                     ADD  EQKOSU    @OQTY
 E3  C                     ENDIF
 E2  C                     ENDDO
      * NEW INVENTORY
     C           E1SQTY    SUB  @OQTY     @NQTY   50
     C                     ADD  @IQTY     @NQTY
      *
     C                     EXSR #UPRC
     C           @NQTY     MULT @@UPRC    @@AMT  100
     C                     EXCPT@DTL
TCHK1C                     Z-ADDD@YYMM    @IYYMM
TCHK1C                     WRITEECSWP55R
      *
     C           K#WLX     SETGTECSWL10
      *
 E1  C                     ENDIF
 E0  C                     ENDDO
      *
     C                     ENDSR
