     H            Y.
      **********************************************************
      *         I CONVERT 10 SINNSUU INTO 16 SINNSUU           *
      *                                                        *
      **********************************************************
      * PROGRAM NAME         : ALBRBB                          *
      **********************************************************
      * FILE   (INPUT)       :                                 *
      *        (OUTPUT)      :                                 *
      **********************************************************
      * DATE   (CODING)      : 97.04.16     K.OKACHI           *
      *        (UPDATE)      :                                 *
      **********************************************************
     E                    #HEX       15  1               * MAX=15
     E                    #DEC       15  1               * MAX=15
     E                    #T1     1   6  2 0 #T2     1   * s]f]
      *
     I            DS
     I                                        1  15 #HEX
     I                                        1  15 WHEX
     I            DS
     I                                        1  15 #DEC
     I                                        1  15 @DEC
      *
     C           *ENTRY    PLIST
     C                     PARM           DEC    15
     C                     PARM           HEX    15
     C                     MOVELDEC       WDEC   150
      *  NUMERICAL VALUE OR CHECK
     C                     MOVELWDEC      @DEC
     C                     Z-ADD1         X       20
     C                     DO   15        X
     C           #DEC,X    IFGE ' '
     C           #DEC,X    ANDLE'Z'
     C                     MOVE *ALL'?'   HEX
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C                     ENDDO
      * IN CASE OF 0
     C           WDEC      IFEQ 0
     C                     MOVE *ALL'?'   HEX
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C                     EXSR $CHK1
     C*
     C                     Z-ADD1         X
     C                     DO   15        X
     C           #HEX,X    IFEQ *BLANK
     C                     MOVE '0'       #HEX,X
     C                     END
     C                     ENDDO
     C                     MOVE WHEX      HEX
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C*----------------------------------------------------------------
     C* CODE CALCULATION
     C*----------------------------------------------------------------
     C           $CHK1     BEGSR
     C                     Z-ADD16        X
     C                     DO   *HIVAL
     C                     SUB  1         X
      *
     C           WDEC      DIV  16        A      130
     C                     MVR            B       20
      *   IT IS CONVERSION OBJECT FROM 10 TO 15
     C           B         IFGE 10
     C           B         ANDLE15
     C                     EXSR $CHK2
     C                     END
      *   I CONVERT NOTHING INTO FROM 1 TO 9
     C           B         IFLT 10
     C                     MOVE B         WCOD
     C                     END
      *   THEN DEC IS SMALLER THAN 16, IT IS END
     C           A         IFEQ 0
     C           B         IFGE 10
     C           B         ANDLE15
     C                     EXSR $CHK2
     C                     ELSE
     C                     MOVE B         WCOD
     C                     END
     C                     MOVE WCOD      #HEX,X
     C                     GOTO END
     C                     END
      *
     C                     MOVE WCOD      #HEX,X
      *   IT IS END WHEN NOT DIVISIBLE BY 16
     C           A         IFGE 1
     C           A         ANDLE15
     C                     SUB  1         X
     C                     Z-ADDA         B
     C           B         IFGE 10
     C           B         ANDLE15
     C                     EXSR $CHK2
     C                     MOVE WCOD      #HEX,X
     C                     ELSE
     C                     MOVE B         #HEX,X
     C                     END
     C                     GOTO END
     C                     END
      *  I SUBSTITUTE A QUOTIENT
     C                     Z-ADDA         WDEC
     C                     ENDDO
     C           END       TAG
     C                     ENDSR
     C*
     C*----------------------------------------------------------------
     C* CODE CONVERSION
     C*----------------------------------------------------------------
     C           $CHK2     BEGSR
     C                     MOVE *BLANK    WCOD    1
     C                     Z-ADD1         C       20
     C                     SETOF                     11
     C           B         LOKUP#T1,C                    11
     C           *IN11     IFEQ '1'
     C                     MOVE #T2,C     WCOD
     C                     ELSE
     C                     MOVE *ALL'?'   HEX
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C                     ENDSR
**  #T1/#T2
10A
11B
12C
13D
14E
15F
