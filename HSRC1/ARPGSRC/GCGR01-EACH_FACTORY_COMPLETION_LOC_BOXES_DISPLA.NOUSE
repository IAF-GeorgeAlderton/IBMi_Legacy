      * KEY *
     C           KEY1      KLIST
     C                     KFLD           CKHIN1
     C                     KFLD           CKHIN2
     C                     KFLD           CKHIN3
      *
     C           KEY2      KLIST
     C                     KFLD           SHNB1
     C                     KFLD           SHNB2
     C                     KFLD           SHNB3
     C                     KFLD           SKOTI
     C                     KFLD           SBMON
      * PARM *
     C           *ENTRY    PLIST
     C                     PARM           @SNY    1
      **************
      * 初期設定 *
      **************
     C                     SETOF                     010203
     C                     SETOF                     0499
     C                     MOVE *BLANK    @KJY
     C                     MOVE 'N'       @SNY
     C                     MOVE *BLANK    @TRO
     C                     MOVE *BLANK    @SYO
      **********
      * 画面 *
      **********
     C           STP10     TAG
     C                     EXFMTGCGPW011
     C                     SETOF                     010203
     C                     SETOF                     0499
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      * 工場 *
     C           @KJY      IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,01     MSG
     C                     GOTO STP10
     C                     END
      *
     C                     MOVEL@KJY      KJY     40
     C                     SETOF                     10
     C           KJY       CHAINFGBPL011             10
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '1'
     C                     SETON                     0199
     C                     MOVE ER,02     MSG
     C                     GOTO STP10
     C                     END
      * 専用品番マスター *
     C           @SNY      IFNE 'Y'
     C           @SNY      ANDNE'N'
     C                     SETON                     0299
     C                     MOVE ER,03     MSG
     C                     GOTO STP10
     C                     END
      * かんばん種類 *
     C           @SYO      IFNE *BLANK
     C                     SETOF                     12
     C           @SYO      LOKUPKNS                      12
     C           *IN12     IFEQ '0'
     C                     SETON                     0499
     C                     MOVE ER,04     MSG
     C                     GOTO STP10
     C                     END
     C                     END
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP10
     C                     END
      ****************
      * データ作成 *
      ****************
     C                     SETOF                     10
     C                     DO   *HIVAL
     C                     MOVE *BLANK    SYKA
     C                     MOVE *BLANK    SYTO
     C                     Z-ADD0         SBMN
     C                     MOVE *BLANK    SKOT
     C                     MOVE *BLANK    SHIN
     C                     MOVE *BLANK    FSHN1   5
     C                     MOVE *BLANK    FSHN2   5
     C                     MOVE *BLANK    FSHN3   2
     C                     MOVE *BLANK    FTKRO   6
     C                     Z-ADD0         FBMON   40
     C                     MOVE *BLANK    FJSYU   1
     C                     MOVE *BLANK    FOTKR   6
     C                     Z-ADD0         FOBMN   40
     C                     MOVE *BLANK    FOSYU   1
     C                     Z-ADD0         FKHIZ  100
     C                     Z-ADD0         FOHIZ  100
      *
     C                     READ AAMPP111                 10
     C           *IN10     IFEQ '0'
     C           CKSKJY    IFEQ 'D'
     C           CKSKHZ    ANDLE*DATE
     C                     ELSE
      *新旧の決定*
     C                     Z-ADD1         A       20
     C                     SETOF                     11
     C           1         DO   15        A
     C           NBMN,A    IFEQ 0
     C           OBMN,A    ANDEQ0
     C                     SETON                     11
     C                     ELSE
     C                     Z-ADDKANK,A    KHIB
     C           KHIZ      IFGT *DATE
     C                     MOVELOKAN,A    SYKA,A
     C                     MOVELOTOK,A    SYTO,A
     C                     Z-ADDOBMN,A    SBMN,A
     C                     MOVELOKOT,A    SKOT,A
     C                     MOVELOHIN,A    SHIN,A
     C                     ELSE
     C                     MOVELNKAN,A    SYKA,A
     C                     MOVELNTOK,A    SYTO,A
     C                     Z-ADDNBMN,A    SBMN,A
     C                     MOVELNKOT,A    SKOT,A
     C                     MOVELNHIN,A    SHIN,A
     C                     END
     C                     END
     C  N11                END
      *各条件でデータの出力*
     C                     Z-ADD16        A
     C                     SETOF                     11
     C           1         DO   15
     C                     SUB  1         A
      *工場*
     C           KJY       IFEQ SBMN,A
     C                     GOTO STPAA
     C                     END
     C           KJY       IFEQ 8907
     C           SBMN,A    ANDNE0111
     C                     GOTO STPAA
     C                     END
     C                     GOTO STP20
      *
     C           STPAA     TAG
      *所番地*
     C                     MOVELSYTO,A    TOKRO
     C           @TRO      IFNE *BLANK
     C           TOKR2     IFEQ @TRO
     C                     SETON                     11
     C                     END
     C                     END
     C           TOKRO     IFEQ '------'
     C           TOKRO     OREQ '++++++'
     C                     GOTO STP20
     C                     END
      *通路*
     C           @TRO      IFNE *BLANK
     C           TOKR2     IFNE @TRO
     C                     GOTO STP20
     C                     END
     C                     ELSE
      *
     C           KJY       IFEQ 8907
     C           TOKR1     IFEQ 'T'
     C           TOKR1     OREQ 'S'
     C           TOKR1     OREQ 'G'
     C                     GOTO STPBB
     C                     END
     C                     GOTO STP20
     C                     END
     C                     END
      *
     C           STPBB     TAG
      *後工程の検索*
     C                     Z-ADDA         B       20
     C                     SETOF                     12
     C                     DO   *HIVAL
     C           B         IFGE 15
     C                     SETON                     12
     C                     ELSE
     C                     ADD  1         B
     C           SYKA,B    IFNE *BLANK
     C                     Z-ADDSBMN,B    FOBMN
     C                     MOVELSYTO,B    FOTKR
     C                     Z-ADDKANK,B    FOHIZ
      *
     C           SBMN,A    IFEQ 0111
     C                     MOVELSYKA,B    FOSYU
     C                     ELSE
     C                     MOVELSYKA,A    FOSYU
     C                     END
      *
     C                     ELSE
     C                     Z-ADDSBMN,A    FOBMN
     C                     MOVELSYTO,A    FOTKR
     C                     Z-ADDKANK,A    FOHIZ
     C                     MOVELSYKA,A    FOSYU
     C                     SETON                     12
     C                     END
     C                     END
     C  N12                END
      *後工程の有無*
     C           FOSYU     IFEQ *BLANK
     C                     GOTO STP20
     C                     END
      *かんばん種類*
     C                     SETOF                     12
     C           FOSYU     LOKUPKNS                      12
     C           *IN12     IFEQ '0'
     C                     GOTO STP20
     C                     END
      *
     C           @SYO      IFNE *BLANK
     C           @SYO      IFNE FOSYU
     C                     GOTO STP20
     C                     END
     C                     END
      *部品情報マスター*
     C                     SETOF                     12
     C           KEY1      CHAINFCEPL011             12
     C           *IN12     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2SKHZ    ANDLE*DATE
     C                     SETON                     12
     C                     END
     C                     END
     C           *IN12     IFEQ '1'
     C                     GOTO STP20
     C                     END
      *共通品のチェック*
     C                     MOVELSHIN,A    SHNBN  12
     C                     MOVELSKOT,A    SKOTI   3
     C                     Z-ADDSBMN,A    SBMON   40
     C                     MOVE *BLANK    FKYTU   1
      *
     C           KEY2      SETLLGHCPL221
     C                     SETOF                     30
     C                     DO   *HIVAL
     C           KEY2      READEGHCPL221                 30
     C           *IN30     IFEQ '0'
     C           MMJHN1    IFNE MMMHN1
     C           MMJHN2    ANDNEMMMHN2
     C           MMJHN3    ANDNEMMMHN3
     C                     MOVE '*'       FKYTU
     C                     SETON                     30
     C                     END
     C                     END
     C  N30                END
      *ファイルに出力*
     C                     MOVELCKHIN1    FSHN1
     C                     MOVELCKHIN2    FSHN2
     C                     MOVELCKHIN3    FSHN3
     C                     MOVELSYTO,A    FTKRO
     C                     Z-ADDSBMN,A    FBMON
     C                     MOVELSYKA,A    FJSYU
     C                     Z-ADDKANK,A    FKHIZ
     C                     EXCPTDT
     C                     SETON                     U1
     C           STP20     TAG
     C  N11                END
      *
     C                     END
     C                     END
     C  N10                END
      *
     C                     SETON                     LR
     C                     RETRN
