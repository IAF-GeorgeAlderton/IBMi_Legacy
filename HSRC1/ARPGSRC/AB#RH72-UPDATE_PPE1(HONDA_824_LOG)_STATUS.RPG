     H            Y.
     F** AB#RH72 *****************************************************
     F*  UPDATE PPE1(HONDA 824 LOG) STATUS                           *
     F*  PICK HONDA TR FROM PPE1(824 LOG),                           *
     F*   AND SET "ACCEPT" IF IT IS ALREADY ACCEPTED.                *
     F*  RUN IN FCKC03 (7:33AM WEEKDAY)                              *
     F*  RUN IN VJBC72 (4:33PM WEEKDAY)                              *
     F*  JW     2024.10.10                                           *
     F****************************************************************
     FAB#PLE2 UF  E           K        DISK
     F************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *----------------------------------------------------*
      * MAIN ROUTINE
      *----------------------------------------------------*
     C                     EXSR #INIT
      * SEARCH LOOP
     C           @FROM     SETLLAB#PLE2
     C                     DO   *HIVAL
     C                     READ AB#PLE2                  98
     C   98                LEAVE
      *
     C           M6ACKC    IFNE 'TR'
     C           M6RSUS    ORNE *BLANK
     C           M6PTRN    ORNE 'HONDA'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELM6SHID    $SHID
     C                     CALL 'UEXR31G'
     C                     PARM           $SHID  15
     C                     PARM           $STT    1
      *
     C           $STT      IFEQ 'Y'
     C                     MOVEL'ACCEPT ' M6RSUS
     C                     MOVELTODAY     M6FIL1
     C                     MOVE #PGM      M6FIL1
     C                     UPDATAB#PPE11
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------------*
      * INITIAL SETTING
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $FROM   8
      *
     C                     TIME           SDATE
      *
      * IF $FROM = BLANK --> SET DATE ONE MONTH AGO
     C           $FROM     IFEQ *BLANK
     C                     MOVELTODAY     $DT8
     C                     MOVE '-'       $SIGN
     C                     MOVE '0030'    $DAYS
     C                     MOVE 'N'       $IAF
     C                     CALL 'UTLR10'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN    1
     C                     MOVEL$TGT8     @FROM   80
     C                     ELSE
     C                     MOVEL$FROM     @FROM
     C                     ENDIF
      *
     C                     ENDSR
