     H            Y.
      ** UTLR55 *************************************************
      *  GET IAF PART# FROM USER PART                           *
      *  (COPIED FROM BBHR50)                                   *
      ***********************************************************
      *  CALLING SEQ.                                           *
      *                    CALL 'UTLR55'                        *
     C*                    PARM           $TOKU   4
     C*                    PARM           $NONY   4
     C*                    PARM           $NKOJ   1
     C*                    PARM           $NUKE   4
     C*                    PARM           $MHIN  20
     C*                    PARM           @SHIN  12
     C*                    PARM           @FLG    1
     C*   IN  $TOKU   4A CUST#                                  *
     C*       $NONY   4A DELIV#                                 *
     C*       $NKOJ   1A FACTORY                                *
     C*       $NUKE   4A DOCK                                   *
     C*       $MHIN  20A CUST PART#                             *
     C*   OUT @SHIN  12A IAF  PART#                             *
     C*       @FLG    1A RETURN FLAG (BLANK=OK, *=ERROR)        *
      ***********************************************************
     FFAAPL02 IF  E           K        DISK
     FFAAPL06 IF  E           K        DISK
     FFAAPL05 IF  E           K        DISK
     FFAAPL09 IF  E           K        DISK
     FEDIPP42 IF  E           K        DISK
      ***********************************************************
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
     I            DS
     I                                        1   80B7SKHZ
     I                                        1   40B7SKYY
     I                                        5   60B7SKMM
     I                                        7   80B7SKDD
     I            DS
     I                                        1   80FBTKDT
     I                                        1   40FBTKYY
     I                                        5   60FBTKMM
     I                                        7   80FBTKDD
     I            DS
     I                                        1   80FBTSDT
     I                                        1   40FBTSYY
     I                                        5   60FBTSMM
     I                                        7   80FBTSDD
     I            DS
     I                                        1  20 PMHIN
     I                                        1   5 PMHN1
     I                                        6  10 PMHN2
     I                                       11  15 PMHN3
     I                                       11  11 PMHN4
     I                                       16  20 PMHN5
     I            DS
     I                                        1  12 PSHIN
     I                                        1   5 PSHN1
     I                                        6  10 PSHN2
     I                                       11  12 PSHN3
      ****************************************************
      * MAIN ROUTINE
      ****************************************************
      *
     C                     EXSR #INIT
      *
     C                     MOVELPMHN1     IMHN1   5
     C                     MOVELPMHN2     IMHN2   5
     C                     Z-ADD@TOKU     ITOKU   40
     C                     Z-ADD@NONY     INONY   40
     C           KEY       SETLLFAAPL061
     C                     DO   *HIVAL
     C           KEY       READEFAAPL061                 10
     C   10                LEAVE
      *
     C           B7SKBN    IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C  N10                GOTO STP1
     C*
     C                     Z-ADD0111      INONY
     C           KEY       SETLLFAAPL061
     C                     DO   *HIVAL
     C           KEY       READEFAAPL061                 10
     C   10                LEAVE
     C           B7SKBN    IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C  N10                GOTO STP1
      *
     C                     GOTO STP2
      *
     C           STP1      TAG
      *
     C           1         DO   2         B       10
      *
     C                     Z-ADD@TOKU     JTOKU   40
     C                     Z-ADD@NONY     JNONY   40
     C                     MOVELPNKOJ     JNKOJ   1
     C                     MOVELPNUKE     JNUKE   4
     C                     MOVELPMHN1     JMHN1   5
     C                     MOVELPMHN2     JMHN2   5
     C                     MOVE *BLANK    JMHN3   5
     C                     MOVE *BLANK    JMHN4   5
      *
     C           B         IFEQ 1
     C                     MOVELPMHN3     JMHN3
     C                     MOVELPMHN5     JMHN4
     C                     ENDIF
      *
     C* TOYOTA
     C           @GRP      IFEQ 'TYT'
     C           B         IFEQ 1
     C           PMHN3     IFEQ *BLANK
     C                     MOVEL'00   '   JMHN3
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     SETOF                     10
     C           KEY1      CHAINFAAPL021             10
     C           *IN10     IFEQ '0'
     C           B7SKBN    CABNE'D'       STP3
     C           B7SKHZ    CABGTWSSDAT    STP3
     C                     ENDIF
      *
     C                     SETOF                     10
     C                     MOVE *BLANK    JNKOJ
     C           KEY1      CHAINFAAPL021             10
     C           *IN10     IFEQ '0'
     C           B7SKBN    CABNE'D'       STP3
     C           B7SKHZ    CABGTWSSDAT    STP3
     C                     END
      *
     C                     SETOF                     10
     C                     MOVELPNKOJ     JNKOJ
     C                     MOVEL*BLANK    JNUKE
     C           KEY1      CHAINFAAPL021             10
     C           *IN10     IFEQ '0'
     C           B7SKBN    CABNE'D'       STP3
     C           B7SKHZ    CABGTWSSDAT    STP3
     C                     END
      *
     C                     SETOF                     10
     C                     MOVE *BLANK    JNKOJ
     C           KEY1      CHAINFAAPL021             10
     C           *IN10     IFEQ '0'
     C           B7SKBN    CABNE'D'       STP3
     C           B7SKHZ    CABGTWSSDAT    STP3
     C                     END
      *
     C                     SETOF                     10
     C                     Z-ADD0111      JNONY
     C           KEY1      CHAINFAAPL021             10
     C           *IN10     IFEQ '0'
     C           B7SKBN    CABNE'D'       STP3
     C           B7SKHZ    CABGTWSSDAT    STP3
     C                     END
     C*
     C                     ENDDO
      * FORD/ANDROID/PISTON
     C           @GRP      IFEQ 'FRD'
     C           @GRP      OREQ 'AND'
     C           @GRP      OREQ 'PIS'
     C           KEY2      SETLLFAAPL09
     C           *IN10     DOUEQ*ON
     C           KEY2      READEFAAPL09                  10
     C           *IN10     IFEQ *OFF
     C           B7SKBN    ANDEQ*BLANK
     C                     GOTO STP3
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      * HONDA
     C           @GRP      IFEQ 'HND'
     C                     MOVEL*BLANK    PSHIN
     C           K#L05     KLIST
     C                     KFLD           PMHN1
     C                     KFLD           PMHN2
     C                     KFLD           PMHN3
     C                     KFLD           PMHN5
     C                     KFLD           @TOKU
     C                     KFLD           @NONY
     C           K#L05     SETLLFAAPL05
     C                     DO   *HIVAL
     C           K#L05     READEFAAPL05                  10
     C   10                LEAVE
     C           B7SKBN    IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C           *IN10     IFEQ *ON
     C           K#L05@    KLIST
     C                     KFLD           PMHN1
     C                     KFLD           PMHN2
     C                     KFLD           PMHN3
     C                     KFLD           PMHN5
     C                     KFLD           @TOKU
     C           K#L05@    SETLLFAAPL05
     C                     DO   *HIVAL
     C           K#L05@    READEFAAPL05                  10
     C   10                LEAVE
     C           B7SKBN    IFEQ *BLANK
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     END
     C  N10                GOTO STP3
     C                     END
     C* NOT FOUND IN COMMON PART MASTER
     C           STP2      TAG
     C                     MOVEL'*'       @FLG
     C                     MOVE PMHN1     PSHN1
     C                     MOVE PMHN2     PSHN2
     C                     MOVE *BLANK    PSHN3
     C           @TOKU     IFEQ 5149
     C           @TOKU     OREQ 2855
     C           @TOKU     OREQ 2856
TCHK3C           @TOKU     OREQ 7448
     C                     MOVELPMHN3     PSHN3
     C                     ENDIF
     C                     GOTO END
      *
      * FOUND IN COMMON MASTER
     C           STP3      TAG
     C                     MOVE B7SHN1    PSHN1
     C                     MOVE B7SHN2    PSHN2
     C                     MOVE B7SHN3    PSHN3
      *
     C           END       TAG
     C                     MOVELPSHIN     @SHIN
     C*
     C                     MOVE *ON       *INLR
     C                     RETRN
      ****************************************************
      * INITIALIZE
      ****************************************************
     C           #INIT     BEGSR
     C*
     C           *ENTRY    PLIST
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           @MHIN  20
     C                     PARM           @SHIN  12
     C                     PARM           @FLG    1
      *
     C           KEY       KLIST
     C                     KFLD           ITOKU
     C                     KFLD           INONY
     C                     KFLD           IMHN1
     C                     KFLD           IMHN2
      *
     C           KEY1      KLIST
     C                     KFLD           JTOKU
     C                     KFLD           JNONY
     C                     KFLD           JNKOJ
     C                     KFLD           JNUKE
     C                     KFLD           JMHN1
     C                     KFLD           JMHN2
     C                     KFLD           JMHN3
     C                     KFLD           JMHN4
      *
     C           KEY2      KLIST
     C                     KFLD           @TOKU
     C                     KFLD           @NONY
     C                     KFLD           PMHN1
     C                     KFLD           PMHN2
     C                     KFLD           PMHN3
     C                     KFLD           PMHN5
      *
     C                     TIME           WSDT
      *
     C                     MOVE PTOKU     @TOKU   40
     C                     MOVE PNONY     @NONY   40
     C                     MOVEL@MHIN     PMHIN
     C                     MOVEL*BLANK    @SHIN
     C                     MOVEL@SHIN     PSHIN
     C                     MOVEL*BLANK    @FLG
      * GET CUSTOMER GROUP
     C           PNONY     CHAINEDIPP42              99
     C           *IN99     IFEQ *OFF
     C                     MOVELE4GRP     @GRP    4
     C                     ELSE
     C                     MOVEL'TYT'     @GRP
     C                     ENDIF
     C*
     C                     ENDSR
     C*
