     C*-----------------------------------------------*
     C*                データのチェック             *
     C*-----------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           SLCT    1
      *
     C                     Z-ADD3174      TOKUI   40
     C                     MOVE 'G'       TKOJY   1
     C                     MOVEL30        TUKIR   4
     C                     Z-ADD0         Y       10
     C                     TIME           WTIME   60
     C           LOOP11    TAG
     C                     EXSR SYOKI
     C                     READ GCEWP301                 20
     C           *IN20     IFEQ '1'
     C***** 出力（終了）*****
     C           HIN1,1    IFNE *BLANK
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     END
     C                     Z-ADD1         Z       10
     C                     Z-ADD0         X       20
     C           1         DO   Y         Z
     C           30        ADD  Z         X
     C                     MOVE '1'       *IN,X
     C                     END
     C                     EXCPTME
     C                     END
     C   30                CLOSEQPRINT
     C*****
     C                     SETON                     LR
     C   LR                RETRN
     C                     END
     C                     MOVE '-'       HI1
     C                     MOVE '-'       HI2
     C*-----------------------------------------------*
     C*                   品番・区別                *
     C*-----------------------------------------------*
     C           HNBAN     CHAINAAMPL111             25
     C           *IN25     IFEQ '1'
     C                     GOTO LOOP11
     C                     END
     C                     EXSR SYTE
      *
TCHK2C                     MOVEL*OFF      @TMMWV  1
     C                     EXSR #ACT
      *
     C***** 出力*****
     C           KANSY     IFEQ *BLANK
     C  N30                OPEN QPRINT
     C  N30                EXCPTHD
     C                     SETON                     30
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     END
     C                     ADD  1         Y
     C           Y         IFGE 6
     C                     MOVEA'11111'   *IN,31
     C                     EXCPTME
     C                     MOVEA'00000'   *IN,31
     C                     MOVE *BLANK    HIN1
     C                     MOVE *BLANK    HIN2
     C                     MOVE *BLANK    HIN3
     C                     Z-ADD1         Y
     C                     END
     C                     MOVELSYNI01    HIN1,Y
     C                     MOVELSYNI02    HIN2,Y
     C                     MOVELSYNI03    HIN3,Y
     C                     GOTO LOOP11
     C                     END
     C*****
     C           KANSY     IFNE 'C'
     C           KANSY     ANDNE'D'
     C           KANSY     ANDNE'E'
     C           KANSY     ANDNE'0'
     C           KANSY     ANDNE'4'
     C           KANSY     ANDNE'1'
     C           KANSY     ANDNE'2'
     C           KANSY     ANDNE'6'
     C           KANSY     ANDNE'A'
     C           KANSY     ANDNE'B'
     C           KANSY     ANDNE'7'
     C           KANSY     ANDNE'F'
     C                     GOTO LOOP11
     C                     END
     C*-----------------------------------------------*
     C*                メッキ・マスター             *
     C*-----------------------------------------------*
     C           KANSY     IFEQ 'C'
     C                     MOVE '-'       HI3
     C                     MOVE '-'       HI4
     C                     MOVE '-'       HI5
     C           OLMI      SETLLAAFPL031
     C           *IN26     DOUEQ*ON
TCHK1C*                    READEAAFPL031                 26
TCHK1C           OLMI      READEAAFPL031                 26
     C           *IN26     IFEQ *OFF
     C           A3SKJY    ANDEQ*BLANK
     C           A3UKHZ    ANDLE*DATE
     C           A3STHZ    ANDGT*DATE
     C                     Z-ADDA3BARA    BARA    20
     C                     Z-ADDA3MAXH    MAXH    20
     C                     MOVE HNBA      HBAN   14
     C                     MOVE TKORC     TKOB    9
     C                     Z-ADD*DATE     TOKI    80
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN26     IFEQ '1'
     C                     GOTO LOOP11
     C                     END
     C           A3SSYS    IFEQ 0
     C                     EXSR SECOD
     C                     EXSR ADUP
     C                     GOTO LOOP11
     C                     END
      *
ADUP C           A3KTSU    IFEQ A3KSSU
     C                     MOVE A3KMAX    MISUY   4
     C                     ELSE
      *
     C           A3KSSU    MULT A3READ    @@QTY   90
     C           A3SSYS    IFNE 0
     C           @@QTY     DIV  A3SSYS    @@MM    40
     C                     MVR            @@MVR   70
     C           @@MVR     IFNE 0
     C                     ADD  1         @@MM
     C                     ENDIF
     C                     MOVE @@MM      MISUY
     C                     ENDIF
     C                     ENDIF
     C                     MOVE A3KMAX    MISUY
      *
     C* 箱数の計算 *
TCHK7C*          A3KTSU    DIV  A3SSYS    DI1     62
TCHK7C           A3KSSU    DIV  A3SSYS    DI1     62
     C           DI1       IFEQ 0
TCHK6C                     Z-ADD0.1       HAKO    51
     C                     ELSE
TCHK6C           DI1       ADD  0.09      DI2     51
     C                     Z-ADDDI2       HAKO
     C                     END
TCHK5C           A3READ    IFLT 2
TCHK5C           A3READ    DIV  2         W@ML1   62
TCHK5C           DI1       MULT W@ML1     W@ML2   62
TCHK5C           W@ML2     IFEQ 0
TCHK6C                     Z-ADD0.1       HAKO    51
TCHK5C                     ELSE
TCHK6C           W@ML2     ADD  0.09      W@ML3   51
TCHK5C                     Z-ADDW@ML3     HAKO
TCHK5C                     END
TCHK5C                     END
      *
     C           @ACTD     IFNE *ZERO
     C****       A3KTSU    SUB  @ACTD     @@BAL  112
     C******     @@BAL     IFLT *ZERO
     C******               Z-SUB@@BAL     @@BAL
     C*****                ENDIF
     C*****      @@BAL     DIV  A3KTSU    @@BALX 114H
     C****       @@BALX    IFGT 0.25
     C********   @STRD     ANDLE*DATE
     C           @ACTD     DIV  A3SSYS    DI1     62
TCHK6C           DI1       ADD  0.09      DI2     51
     C           DI2       IFLE 0
     C                     Z-ADD0.1       DI2
     C                     ENDIF
     C                     Z-ADDDI2       HAKO
     C*******              ENDIF
     C                     ENDIF
      *
     C                     MOVELA3MTK2    @P      1
TCHK4C*          A3MAKB    IFEQ 8990
TCHK4C*          @P        OREQ 'P'
TCHK3C*TCHK2     @TMMWV    OREQ *ON
TCHK4C*          HAKO      MULT 2         HAKO
TCHK4C*                    ENDIF
     C* ----------- *
     C                     END
     C*-----------------------------------------------*
     C*               トンネル・マスター            *
     C*-----------------------------------------------*
     C           KANSY     IFEQ 'D'
     C                     MOVE '-'       HI6
     C                     MOVE '-'       HI7
     C                     MOVE '-'       HI8
     C           OLMI      SETLLAAGPL031
     C           *IN27     DOUEQ*ON
     C           OLMI      READEAAGPL031                 27
     C           *IN27     IFEQ *OFF
     C           O4SKJY    ANDEQ*BLANK
     C           O4UKHZ    ANDLE*DATE
     C           O4STHZ    ANDGT*DATE
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN27     IFEQ '1'
     C                     GOTO LOOP11
     C                     END
     C                     Z-ADDO4BARA    BARA
     C                     Z-ADDO4MAXH    MAXH
     C                     MOVE HNBA      HBAN
     C                     MOVE TKORD     TKOB
     C                     Z-ADD*DATE     TOKI
     C           O4SYOS    IFEQ 0
     C                     EXSR SECOD
     C                     EXSR ADUP
     C                     GOTO LOOP11
     C                     END
      *
     C           O4KTSU    IFEQ O4KSSU
     C                     MOVE O4KMAX    MISUY
     C                     ELSE
     C           O4KSSU    MULT O4LTIM    @@QTY   90
     C           O4SYOS    IFNE 0
     C           @@QTY     DIV  O4SYOS    @@MM    40
     C                     MVR            @@MVR   70
     C           @@MVR     IFNE 0
     C                     ADD  1         @@MM
     C                     ENDIF
     C                     MOVE @@MM      MISUY
     C                     ENDIF
     C                     ENDIF
     C                     MOVE O4KMAX    MISUY
     C* 箱数の計算 *
TCHK7C*          O4KTSU    DIV  O4SYOS    DI1
TCHK7C           O4KSSU    DIV  O4SYOS    DI1
     C           DI1       IFEQ 0
TCHK6C                     Z-ADD0.1       HAKO    51
     C                     ELSE
TCHK6C           DI1       ADD  0.09      DI2     51
     C                     Z-ADDDI2       HAKO
     C                     END
      *
     C           @ACTD     IFNE *ZERO
     C******     O4KTSU    SUB  @ACTD     @@BAL  112
     C******     @@BAL     IFLT *ZERO
     C*******              Z-SUB@@BAL     @@BAL
     C******               ENDIF
     C******     @@BAL     DIV  O4KTSU    @@BALX 114H
     C*******8   @@BALX    IFGT 0.25
     C*****      @STRD     ANDLE*DATE
     C           @ACTD     DIV  O4SYOS    DI1     62
TCHK6C           DI1       ADD  0.09      DI2     51
     C           DI2       IFLE 0
     C                     Z-ADD0.1       DI2
     C                     ENDIF
     C                     Z-ADDDI2       HAKO
     C****                 ENDIF
     C                     ENDIF
      *
     C                     MOVELO4BAN2    @P      1
TCHK4C*          O4MAKB    IFEQ 8990
TCHK4C*          @P        OREQ 'P'
TCHK3C*TCHK2     @TMMWV    OREQ *ON
TCHK4C*          HAKO      MULT 2         HAKO
TCHK4C*                    ENDIF
     C* ----------- *
     C                     END
     C*-----------------------------------------------*
     C*                 引取・マスター              *
     C*-----------------------------------------------*
     C           KANSY     IFEQ 'E'
     C                     MOVE '-'       HI9
     C                     MOVE '-'       HIA
     C                     MOVE '-'       HIB
     C           OLMI      SETLLAAHPL031
     C           *IN28     DOUEQ*ON
     C           OLMI      READEAAHPL031                 28
     C           *IN28     IFEQ *OFF
     C           L6SKJY    ANDEQ*BLANK
     C           L6UKHZ    ANDLE*DATE
     C           L6STHZ    ANDGT*DATE
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN28     IFEQ '1'
     C                     GOTO LOOP11
     C                     END
     C                     Z-ADDL6MAXH    MAXH
     C                     MOVE HNBA      HBAN
     C                     MOVE TKORE     TKOB
     C                     Z-ADD*DATE     TOKI
     C           L6SYOS    IFEQ 0
     C                     EXSR SECOD
     C                     EXSR ADUP
     C                     GOTO LOOP11
     C                     END
      *
     C           L6KTSU    IFEQ L6KSSU
     C                     MOVE L6KMAX    MISUY
     C                     ELSE
     C           L6KSSU    MULT L6LTIM    @@QTY   90
     C           L6SYOS    IFNE 0
     C           @@QTY     DIV  L6SYOS    @@MM    40
     C                     MVR            @@MVR   70
     C           @@MVR     IFNE 0
     C                     ADD  1         @@MM
     C                     ENDIF
     C                     MOVE @@MM      MISUY
     C                     ENDIF
     C                     ENDIF
     C                     MOVE L6KMAX    MISUY
     C* 箱数の計算 *
TCHK7C*          L6KTSU    DIV  L6SYOS    DI1
TCHK7C           L6KSSU    DIV  L6SYOS    DI1
     C           DI1       IFEQ 0
TCHK6C                     Z-ADD0.1       HAKO    51
     C                     ELSE
TCHK6C           DI1       ADD  0.09      DI2     51
     C                     Z-ADDDI2       HAKO
     C                     END
TCHK5C           L6LTIM    IFLT 2
TCHK5C           L6LTIM    DIV  2         W@ML1   62
TCHK5C           DI1       MULT W@ML1     W@ML2   62
TCHK5C           W@ML2     IFEQ 0
TCHK6C                     Z-ADD0.1       HAKO    51
TCHK5C                     ELSE
TCHK6C           W@ML2     ADD  0.09      W@ML3   51
TCHK5C                     Z-ADDW@ML3     HAKO
TCHK5C                     END
TCHK5C                     END
