     C           OLMI      SETLLCADPL031
     C           *IN26     DOUEQ*ON
     C           OLMI      READECADPL031                 26
     C           *IN26     IFEQ *OFF
     C           C2SKJY    ANDEQ*BLANK
     C           C2UKHZ    ANDLE*DATE
     C           C2STHZ    ANDGT*DATE
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN26     IFEQ '1'
     C                     GOTO LOOP11
     C                     END
     C                     Z-ADDC2BARA    BARA    20
     C                     MOVE HNBA      HBAN   14
     C                     MOVE TKORN     TKOB    9
     C                     Z-ADD*DATE     TOKI    80
     C           C2SYOS    IFEQ 0
     C                     EXSR SECOD
     C                     EXSR ADUP
     C                     GOTO LOOP11
     C                     END
      *
     C           C2KTSU    IFNE C2KSSU
     C                     MOVE C2KMAX    MISUY   4
     C                     ELSE
     C           C2KSSU    MULT C2LTIM    @@QTY   90
     C           C2SYOS    IFNE 0
     C           @@QTY     DIV  C2SYOS    @@MM    40
     C                     MVR            @@MVR   70
     C           @@MVR     IFNE 0
     C                     ADD  1         @@MM
     C                     ENDIF
     C                     MOVE @@MM      MISUY
     C                     ENDIF
     C                     ENDIF
     C* 箱数の計算 *
TCHK7C*          C2KTSU    DIV  C2SYOS    DI1
TCHK7C           C2KSSU    DIV  C2SYOS    DI1
     C           DI1       IFEQ 0
TCHK6C                     Z-ADD0.1       HAKO    51
     C                     ELSE
TCHK6C           DI1       ADD  0.09      DI2     51
     C                     Z-ADDDI2       HAKO
     C                     END
      *
     C           @ACTD     IFNE *ZERO
     C****       C2KTSU    SUB  @ACTD     @@BAL  112
     C******     @@BAL     IFLT *ZERO
     C******               Z-SUB@@BAL     @@BAL
     C******               ENDIF
     C******     @@BAL     DIV  C2KTSU    @@BALX 114H
     C******     @@BALX    IFGT 0.25
     C*****      @STRD     ANDLE*DATE
     C           @ACTD     DIV  C2SYOS    DI1     62
TCHK6C           DI1       ADD  0.09      DI2     51
     C           DI2       IFLE 0
     C                     Z-ADD0.1       DI2
     C                     ENDIF
     C                     Z-ADDDI2       HAKO
     C*******              ENDIF
     C                     ENDIF
      *
     C                     MOVELC2TKR2    @P
TCHK4C*          C2MBMN    IFEQ 8990
TCHK4C*          @P        OREQ 'P'
TCHK3C*TCHK2     @TMMWV    OREQ *ON
TCHK4C*          HAKO      MULT 2         HAKO
TCHK4C*                    ENDIF
     C* ----------- *
     C                     END
     C                     EXSR SZERO
     C                     EXSR SECOD
     C                     EXSR ADUP
     C                     GOTO LOOP11
     C*-----------------------------------------------*
     C*          品番のテーブル　サブルーチン       *
     C*-----------------------------------------------*
     C           SYTE      BEGSR
     C                     Z-ADD1         K       20
     C           SLOP11    TAG
     C           K         IFLE 15
     C                     Z-ADDKANK,K    KHIB
     C***        KHIZ      IFGT *DATE
     C***                  MOVE OTOK,K    SYTO,K
     C***                  MOVE OKAN,K    SYKA,K
     C***                  ELSE
TCHK1C           KHIZ      IFGT *DATE
TCHK1C                     MOVE OTOK,K    SYTO,K
TCHK1C                     MOVE OKAN,K    SYKA,K
TCHK1C                     ELSE
     C                     MOVE NTOK,K    SYTO,K
     C                     MOVE NKAN,K    SYKA,K
     C***                  END
TCHK1C                     END
     C                     ADD  1         K
     C                     GOTO SLOP11
     C                     END
     C                     Z-ADD15        K
     C           SLOP12    TAG
     C           K         IFGE 1
     C           SYTO,K    IFEQ *BLANK
     C           SYTO,K    OREQ '++++++'
     C           SYTO,K    OREQ '------'
     C                     SUB  1         K
     C                     GOTO SLOP12
     C                     END
     C                     MOVE SYTO,K    KEYTO   6
     C                     MOVE SYKA,K    KANSY   1
     C                     Z-ADDKANK,K    KHIB
     C                     END
     C                     ENDSR
