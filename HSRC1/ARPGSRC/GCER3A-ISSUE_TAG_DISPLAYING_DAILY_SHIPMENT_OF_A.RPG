     C           @ACTD     IFNE *ZERO
     C****       L6KTSU    SUB  @ACTD     @@BAL  112
     C****       @@BAL     IFLT *ZERO
     C****                 Z-SUB@@BAL     @@BAL
     C****                 ENDIF
     C****       @@BAL     DIV  L6KTSU    @@BALX 114H
     C******     @@BALX    IFGT 0.25
     C******8    @STRD     ANDLE*DATE
