     H            Y.
     F** AFGR01 *********************************************
     F* CREATE EDI ORDER DATA 850 FOR OUTSOURCE             *
     F*             T.SAKAKI       2016.11.08               *
     F*  %0001      T.SAKAKI       2018.05.30  FREEWAY      *
     F*******************************************************
     FAFGPL02 IF  E           K        DISK
     FAFGWP01 UF  E           K        DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I            DS
     I                                        1   5 W1PAR1
     I                                        1   2 W1PX2
     I                                        1   3 W1PX3
     I                                        1   4 W1PX4
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     I              '0123456789'          C         WKCKSU
      *----------------------------------------------------*
      *  ENTRY LIST                                        *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1SUPP  4
      *----------------------------------------------------*
      *   KEY LIST                                         *
      *----------------------------------------------------*
     C           KEY1      KLIST
     C                     KFLD           AGDKBN
     C                     KFLD           P1SUPP
     C                     KFLD           AGODNO
      *----------------------------------------------------*
      *   MAIN ROUTINE                                     *
      *----------------------------------------------------*
     C                     TIME           WTIME
     C*
     C           P1SUPP    SETLLAFGPL021
     C                     DO   *HIVAL
     C           P1SUPP    READEAFGPL021                 81
     C   81                LEAVE
     C*
     C           AGSKJY    IFEQ 'D'
     C           AGSKDT    ANDLE*DATE
     C                     ELSE
      * %0001  FREEWAY
     C           P1SUPP    IFEQ '2323'
     C                     EXSR #SB510
     C                     ELSE
      * OTHERS
     C                     EXSR #SB500
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDDO
      *
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * WRITE AFGWP01 PO PER PART                        *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARAFGWP011
     C                     MOVELAGDKBN    W1DKBN
     C                     MOVELP1SUPP    W1SUPP
     C                     Z-ADDAGODNO    W1ODNO
     C                     Z-ADDAGSUMD    W1SUMD
     C                     Z-ADDAGSUMT    W1SUMT
     C                     MOVELAGZETI    W1ZETI
     C                     MOVELAGPAR1    W1PAR1
     C                     MOVELAGPAR2    W1PAR2
     C                     MOVELAGPAR3    W1PAR3
     C                     Z-ADDAGIQTY    W1IQTY
     C                     Z-ADDAGRQTY    W1RQTY
     C                     Z-ADDAGIWGT    W1IWGT
     C                     Z-ADDAGRWGT    W1RWGT
     C                     Z-ADDAGHAKO    W1HAKO
     C                     MOVELAGUPID    W1UPID
     C                     Z-ADDAGORSD    W1ORSD
     C                     Z-ADDAGORST    W1ORST
     C                     Z-ADDAGROSD    W1ROSD
     C                     Z-ADDAGROST    W1ROST
     C                     Z-ADDAGREVD    W1REVD
     C                     Z-ADDAGREVT    W1REVT
     C                     MOVELAGGPPO    W1GPPO
     C                     MOVELAGREVN    W1REVN
     C                     WRITEAFGWP011
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      * UPDATE AFGWP01  MASTER PO PER ODER                 *
      *----------------------------------------------------*
     CSR         #SB510    BEGSR
      *
     C           KEY1      CHAINAFGWP011             82
     C           *IN82     IFEQ *OFF
     C                     ADD  1         WK#PA
     C                     MOVE *BLANK    W1PAR1
     C                     MOVE WK#PA     W1PAR1
     C           W1PX4     IFEQ ' 000'
     C                     MOVEL'    '    W1PAR1
     C                     ENDIF
     C           W1PX3     IFEQ ' 00'
     C                     MOVEL'   '     W1PAR1
     C                     ENDIF
     C           W1PX2     IFEQ ' 0'
     C                     MOVEL'  '      W1PAR1
     C                     ENDIF
     C*
     C                     MOVEL'PARTS'   W1PAR2
     C                     MOVEL*BLANK    W1PAR3
     C                     ADD  AGIQTY    W1IQTY
     C                     ADD  AGRQTY    W1RQTY
     C                     ADD  AGIWGT    W1IWGT
     C                     ADD  AGRWGT    W1RWGT
     C                     ADD  AGHAKO    W1HAKO
     C                     UPDATAFGWP011
     C                     ELSE
     C                     Z-ADD1         WK#PA   40
     C                     CLEARAFGWP011
     C                     MOVELAGDKBN    W1DKBN
     C                     MOVELP1SUPP    W1SUPP
     C                     Z-ADDAGODNO    W1ODNO
     C                     Z-ADDAGSUMD    W1SUMD
     C                     Z-ADDAGSUMT    W1SUMT
     C                     MOVELAGZETI    W1ZETI
     C                     MOVELAGPAR1    W1PAR1
     C                     MOVELAGPAR2    W1PAR2
     C                     MOVELAGPAR3    W1PAR3
     C                     Z-ADDAGIQTY    W1IQTY
     C                     Z-ADDAGRQTY    W1RQTY
     C                     Z-ADDAGIWGT    W1IWGT
     C                     Z-ADDAGRWGT    W1RWGT
     C                     Z-ADDAGHAKO    W1HAKO
     C                     MOVELAGUPID    W1UPID
     C                     Z-ADDAGORSD    W1ORSD
     C                     Z-ADDAGORST    W1ORST
     C                     Z-ADDAGROSD    W1ROSD
     C                     Z-ADDAGROST    W1ROST
     C                     Z-ADDAGREVD    W1REVD
     C                     Z-ADDAGREVT    W1REVT
     C                     MOVELAGGPPO    W1GPPO
     C                     MOVELAGREVN    W1REVN
     C                     WRITEAFGWP011
     C                     ENDIF
      *
     CSR         ESB510    ENDSR
