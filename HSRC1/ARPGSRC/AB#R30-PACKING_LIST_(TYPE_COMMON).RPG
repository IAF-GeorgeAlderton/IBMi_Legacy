     H            Y.
     F** AB#R30 *******************************************************
     F*  PACKING LIST (TYPE COMMON)                                   *
     F*  KIRI   2018.04.03                                            *
     F*  JW1    2019.01.30 CHG SRG ASN#                               *
     F*                    CHG HONDA ASN#                             *
     F*  JW2    2019.07.17 ADD ADDRESS LINE (7TH) : NADD7             *
     F*  JW3    2020.05.15 PRINT 'RETURNABLE"                         *
     F*  LEC    2020.09.24 DON'T PRINT BARCODE IF BARCODE DATA IS BLNK*
     F*  JW4    2020.10.20 CHANGE ASN# FOR FORD(5149)                 *
     F*  JW5    2021.08.11 PUT 'YK000504' FOR MANIFEST# (YKTA)        *
     F*  JW5    2022.01.28 PUT INVOICE#   FOR MANIFEST# (FUTABA:0579) *
     F*  JW6    2025.03.13 ADD PACKING LIST TYPE                      *
     F*****************************************************************
      *  WORK FILE FOR NEW PACKING LIST 2018 *
     FAB#WP37 IF  E                    DISK
      *
      *  ADDRESS MASTER FILE UPDATE
     FEDIPL40 IF  E           K        DISK
      *
      *  NEW SHIPMENT M/F
     FGADPL41 IF  E           K        DISK
      *  TRANSPORTATION M/F
     FGAHPL30 IF  E           K        DISK
      *  CARRIER M/F
     FGAHPL35 IF  E           K        DISK
      *
JW1  FAB#PL2S IF  E           K        DISK
      *  PACKING LIST (TYPE COMMON)
     FAB#PR3K O   E             77     PRINTER
      *================================================================
     E                    MEM     1   6 60
      *================================================================
     I           SDS
     I                                        1   8 @PGMID
     I                                        1   6 PGMID
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      * ('PRINT DATE')
     I            DS
     I                                        1   80A7PDAT
     I                                        1   40A7PDYY
     I                                        5   60A7PDMM
     I                                        7   80A7PDDD
     I            DS
     I                                        1   80PHZ
     I                                        1   20PHZMM
     I                                        3   40PHZDD
     I                                        5   80PHZYY
      *
     I            DS
     I                                        1   80E4SKHZ
     I                                        1   40E4SKYY
     I                                        5   60E4SKMM
     I                                        7   80E4SKDD
      *
     I            DS
     I                                        1  30 $$CANA
     I                                        1  15 $$CAN1
     I                                       16  30 $$CAN2
      *================================================================
     C* KEY LIST
      *================================================================
     C           K#4G      KLIST
     C                     KFLD           K1TOKU  40
     C                     KFLD           K1NONY  40
     C                     KFLD           K1NKOJ  1
     C                     KFLD           K1NUKE  4
     C*****                KFLD           K1NOBN  20
     C                     KFLD           WWNOBN  20
     C*
     C           K#30      KLIST
     C                     KFLD           $$CAR   2
     C                     KFLD           $$RUT   4
     C                     KFLD           K1BIN#  20
      *================================================================
     C* MAIN
      *================================================================
     C                     TIME           @TIME
     C                     Z-ADD0         PHZ
     C                     Z-ADD0         WTIME
     C                     MOVE *BLANK    @BARC
      *-----------------------------------
      *  WORK FILE FOR NEW PACKING LIST 2018 *
      *-----------------------------------
     C                     DO   *HIVAL
     C                     READ AB#WP37                  90
     C   90                LEAVE
     C*
     C                     SELEC
     C*      ..PRINT DATE..
     C           A7PDAT    WHNE 0
     C                     EXSR #HED
     C                     EXSR #NSP
     C                     EXSR #MEX
     C*      ..PART # .....
     C           A7PART    WHNE *BLANK
     C                     EXSR #DTL
     C*      ..# OF BOX....
     C           A7TBOX    WHNE 0
     C                     EXSR #TTL
     C                     ENDSL
     C*
     C                     ENDDO
      *-----------------------------------
      *-----------------------------------
     C                     SETON                     LR
     C                     RETRN
      *================================================================
      * HEADER
      *================================================================
     C           #HED      BEGSR
      *
     C           A7PDYY    IFEQ PHZYY
     C           A7PDMM    ANDEQPHZMM
     C           A7PDDD    ANDEQPHZDD
     C           A7PTIM    ANDEQWTIME
     C           A7BARC    ANDEQ@BARC
     C*                   元の改ページを無視する
     C                     GOTO $HED99
     C                     ENDIF
      *
     C                     MOVELA7SHP#    $$SHP#            CHRSIZ(1 2)
     C                     Z-ADDA7PDYY    PHZYY
     C                     Z-ADDA7PDMM    PHZMM
     C                     Z-ADDA7PDDD    PHZDD
     C                     Z-ADDA7PTIM    WTIME
      *           PGMID          6       + 0
      *
     C                     MOVELA7NAD1    NADD1
     C                     MOVELA7NAD2    NADD2
     C                     MOVELA7NAD3    NADD3
     C                     MOVELA7NAD4    NADD4
     C                     MOVELA7NAD5    NADD5
     C                     MOVELA7NAD6    NADD6
JW2  C                     MOVELA7NAD7    NADD7
      *
     C                     MOVE *BLANK    WNONY   4
     C                     MOVE *BLANK    SADD1
     C                     MOVE *BLANK    SADD2
     C                     MOVE *BLANK    SADD3
     C                     MOVE '0111'    WNONY
     C* IAF ADDRESS
     C           WNONY     CHAINEDIPL401             10
S1   C           *IN10     IFEQ *OFF
 S2  C           E4SKJY    IFEQ 'D'
     C           E4SKHZ    ANDLEA7PDAT
 X2  C                     ELSE
     C                     MOVELE4ADD1    SADD1
     C                     MOVELE4ADD2    SADD2
     C                     MOVELE4ADD3    SADD3
 E2  C                     ENDIF
E1   C                     ENDIF
      *
     C                     MOVELA7FSUP    $$FSUP
     C                     MOVELA7BARC    BARC
      *
     C           BARC      IFEQ *BLANKS
     C                     SETON                     61
     C                     ENDIF
      *
     C                     MOVELA7EXPE    P@TTLA
     C                     MOVELA7SUBR    @SUB#
     C                     MOVELA7BARC    @BARC
      *
     C                     Z-ADDA7DEDT    $$DEDT
     C                     Z-ADDA7DETM    $$DETM
     C                     Z-ADDA7TOKU    $$TOKU
     C                     Z-ADDA7NONY    $$NONY
     C                     MOVELA7NKOJ    $$NKOJ
     C                     MOVELA7NUKE    $$NUKE
     C                     Z-ADDA7REDT    $$REDT
      *
     C                     MOVELA7SIRE    $$SIRE
      * FORD ONLY
S1   C           A7TOKU    IFEQ 5149
     C                     MOVELA7FPLT    WPLAN
     C                     MOVELA7NONY    WDELY
     C                     MOVELA7FDCK    WDOCK
E1   C                     ENDIF
      * ----
     C                     MOVELA7PBOX    PBOX
     C                     MOVELA7ASN#    $$ASN#
      *
     C                     MOVELA7RLS#    $$RLS#
     C                     MOVELA7DLV#    $$DLV#
     C                     MOVELA7SPR#    $$SPR#
     C                     MOVELA7MAN#    $$MAN#
JW5   * YKTA(4022)
 .   C           A7NONY    IFEQ 4022
 .   C                     MOVEL'YK000504'$$MAN#    P
JW5  C                     ENDIF
      *
     C                     Z-ADDA7PSDT    $$PSDT
     C                     Z-ADDA7PSTM    $$PSTM
      *
     C           A7PPS#    IFEQ 0
     C                     MOVEL*BLANK    $$PPS#
     C                     ELSE
     C                     MOVE A7PPS#    $$PPS#
     C                     ENDIF
      *
     C                     MOVELA7BIL#    $$BIL#
JW1   * ADJUSTING...
"     * SRG USES PACKING LIST# AS OF ASN#
"    C           A7TOKU    IFEQ 2727
"    C                     MOVELA7BARC    $$ASN#    P
"    C                     MOVELA7BARC    $$PPS#    P
"    C                     ENDIF
JW1   * HONDA USES SHIPPER#(INVOICE#) AS OF ASN#
"    C           A7NONY    CHAINAB#PL2S              99
"    C           *IN99     IFEQ *OFF
"    C                     MOVELA7SPR#    $$ASN#    P
"    C                     MOVELA7BARC    $$PPS#    P
"    C                     ENDIF
JW4   * ADJUST ASN FOR FORD
"    C           A7TOKU    IFEQ 5149
"    C                     MOVEL$$PPS#    $$ASN#    P
"    C                     MOVE *BLANK    $$PPS#
"    C                     ENDIF
JW4   * ADJUST ASN FOR ADI
"    C           A7NONY    IFEQ 0777
"    C                     MOVELA7BARC    $$ASN#    P
"    C                     MOVELA7BARC    $$PPS#    P
"    C                     MOVELA7INV#    $$MAN#    P
"    C                     ENDIF
      *
JW6   * GET PACKING LIST TYPE
 .   C                     MOVEL$$NONY    $NONY
 .   C                     CALL 'UTLR52A'
 .   C                     PARM           $NONY   4
 .   C                     PARM           $PTYP   2
JW6  C                     MOVEL$PTYP     PLTYPE
      *
     C                     WRITE@3CHED
      * SAVE
     C                     MOVEL*BLANK    HORDER 16
     C                     MOVELA7ORD#    HORDER    P
     C                     Z-ADD0         $$LCTR  20
      *
     C           $HED99    ENDSR
      *================================================================
      * DETAIL
      *================================================================
     C           #DTL      BEGSR
      *
     C           A7EOR#    IFNE *BLANK
     C                     MOVELA7EOR#    @ORDER    P
     C                     ELSE
     C                     MOVELHORDER    @ORDER    P
     C                     ENDIF
      *
     C                     MOVELA7SBAN    W@SBAN
     C                     MOVELA7PART    @PART
     C                     Z-ADDA7EBOX    WKT1
      *           A7SYOS         6  0     54EDTCDE(1)
     C                     Z-ADDA7SRYO    WSRYO
     C                     Z-ADDA7EPWG    WEIGH
      *
     C           $$LCTR    IFGE 25
     C                     WRITE@3CHED
     C                     Z-ADD0         $$LCTR
     C                     ENDIF
      *
     C                     WRITE@3CDTL
     C                     ADD  1         $$LCTR
      *
     C                     ENDSR
      *================================================================
      * TRAILER
      *================================================================
     C           #TTL      BEGSR
      *
     C                     Z-ADDA7TBOX    TKT1
     C                     Z-ADDA7TNWK    TEIGH
     C                     Z-ADDA7TGWK    GEIGH
      *
     C                     Z-ADDA7TNWL    WLB1
     C                     Z-ADDA7TGWL    GLB1
      *
     C                     Z-ADDA7PPLT    PPLT
      *
     C                     WRITE@3CTTL
      *
     C                     Z-ADD0         PHZ
     C                     Z-ADD0         WTIME
     C                     MOVE *BLANK    @BARC
     C                     ENDSR
      *================================================================
      * NEW SHIPMENT M/F
      *================================================================
     C           #NSP      BEGSR
     C*
     C                     Z-ADD0         K1TOKU
     C                     Z-ADD0         K1NONY
     C                     MOVEL*BLANK    K1NKOJ
     C                     MOVEL*BLANK    K1NUKE
     C***                  Z-ADD0         K1NOBN
     C*
     C                     MOVEL*BLANK    $$CAR
     C                     MOVEL*BLANK    $$RUT
     C                     MOVEL*BLANK    $$BIN
     C                     MOVEL*BLANK    $$CANA
     C                     MOVEL*BLANK    $$CAN3 15
     C                     Z-ADD0         $$STM
     C*
     C                     Z-ADDA7TOKU    K1TOKU
     C                     Z-ADDA7NONY    K1NONY
     C                     MOVELA7NKOJ    K1NKOJ
     C                     MOVELA7NUKE    K1NUKE
     C****                 Z-ADDA7DETM    K1NOBN
     C                     Z-ADD1         WWNOBN
     C*
     C           K#4G      CHAINGADPL41              62
1    C           *IN62     IFEQ '0'
|    C           B4SKJY    ANDNE'D'
|    C*
|2   C           @SYSHZ    IFGE B4CHDT
||   C                     MOVE B4NCAR    $$CAR            NEW
||   C                     MOVE B4NRUT    $$RUT            NEW
||   C                     MOVE B4NBIN    $$BIN            NEW
||   C                     Z-ADDB4NBIN    K1BIN#           NEW
||   C                     ELSE
||   C                     MOVE B4OCAR    $$CAR            OLD
||   C                     MOVE B4ORUT    $$RUT            OLD
||   C                     MOVE B4OBIN    $$BIN            OLD
||   C                     Z-ADDB4OBIN    K1BIN#           OLD
|2   C                     ENDIF
|    C*
|    C* TRANSPORTAION M/F
|    C           K#30      CHAINGAHPL30              63
|2   C           *IN63     IFEQ '0'
||   C           G3SKJY    ANDNE'D'
||   C*
||3  C           A7DEDT    IFGE G3CHDT
|||  C                     Z-ADDG3NSTM    $$STM            NEW
||E  C                     ELSE
|||  C                     Z-ADDG3OSTM    $$STM            OLD
||3  C                     ENDIF
||   C*
|2   C                     ENDIF
|    C* CARRIER M/F
|    C           $$CAR     CHAINGAHPL35              64
|2   C           *IN64     IFEQ '0'
||   C           G5SKJY    ANDNE'D'
||   C                     MOVE G5CRN1    $$CAN1
||   C                     MOVE G5CRN2    $$CAN2
||   C                     MOVE G5CRN3    $$CAN3
|2   C                     ENDIF
|    C*
1    C                     ENDIF
     C*
     C                     ENDSR
      *================================================================
      * FOR SRG MEXICO
      *================================================================
     C           #MEX      BEGSR
      *
     C                     MOVEL*BLANK    $MEMO1
     C                     MOVEL*BLANK    $MEMO2
     C                     MOVEL*BLANK    $MEMO3
     C                     MOVEL*BLANK    $MEMO4
     C                     MOVEL*BLANK    $MEMO5
     C                     MOVEL*BLANK    $MEMO6
      * FOR SRG MEXICO
     C           A7NONY    IFEQ 2737
     C                     MOVELMEM,1     $MEMO1
     C                     MOVELMEM,2     $MEMO2
     C                     MOVELMEM,3     $MEMO3
     C                     MOVELMEM,4     $MEMO4
     C                     MOVELMEM,5     $MEMO5
     C                     MOVELMEM,6     $MEMO6
     C                     ENDIF
     C                     ENDSR
      *================================================================
** MEM
