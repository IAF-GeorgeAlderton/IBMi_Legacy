     H            Y.
     F** ABMRI7 *********************************************
     F* A-PICS OVERLAP ERROR LIST
     F*    HOTTA.               2018.10.08                  *
     F*******************************************************
     FABMPL31 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FABMPRI7 O   E             55     PRINTER
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
      *
     I            DS
     I                                        1   80A2GEHZ
     I                                        1   40A2GEYY
     I                                        5   60A2GEMM
     I                                        7   80A2GEDD
      *
     I            DS
     I                                        1   80W@DATE
     I                                        1   40W@DAYY
     I                                        5   60W@DAMM
     I                                        7   80W@DADD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
      *
     I            DS
     I                                        1   8 CTIHZ
     I                                        1   2 CTIMM
     I                                        3   4 CTIDD
     I                                        5   8 CTIYY
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P@DTYM  60
      *
     C                     TIME           WTIME
      *
     C                     Z-ADDUDATE     @HYMD
     C                     Z-ADDP@DTYM    K@DTYM  60
     C                     SETON                     55
     C           K@DTYM    SETLLABMPL311
     C           K@DTYM    READEABMPL311                 87
     C           *IN87     DOWEQ'0'
     C           S5DUP@    IFEQ '@'
     C           S5KMAX    ANDNES5KMAA
     C           *IN55     IFEQ '1'
     C                     WRITEABMPRI71
     C                     SETOF                     55
     C                     ENDIF
     C                     EXSR #DTOUT
     C                     ENDIF
     C           K@DTYM    READEABMPL311                 87
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
     C                     SETON                     LR
     C                     RETRN
     C*
      *--------------------------------------------------------*
      *                                                        *
      *--------------------------------------------------------*
     CSR         #DTOUT    BEGSR
      *
     C                     MOVELS5KCD1    P2KCD1
     C                     MOVELS5ATK1    P2ATK1
     C                     MOVELS5ATK2    P2ATK2
     C                     MOVELS5ATK3    P2ATK3
     C                     MOVELS5ATK4    P2ATK4
     C                     MOVEL*BLANK    P2SHIN
     C           S5SHN1    CAT  '-':0     P2SHIN
     C           P2SHIN    CAT  S5SHN2:0  P2SHIN
     C           P2SHIN    CAT  '-':0     P2SHIN
     C           P2SHIN    CAT  S5SHN3:0  P2SHIN
     C                     Z-ADDS5KTSU    P2KTSU
     C                     Z-ADDS5KTSA    P2KTSA
     C                     Z-ADDS5SSYS    P2SSYS
     C                     Z-ADDS5KMAX    P2KMAX
     C                     Z-ADDS5KMAA    P2KMAA
     C                     Z-ADDS5DUPH    P2DUPH
     C                     Z-ADDS5DUP#    P2DUPA
     C                     Z-ADDS5BOXD    P2BOXD
     C                     Z-ADDS5SA      P2SA
      *
     C                     Z-ADD0         P@BOXD
     C           S5SSYS    IFNE 0
     C           S5KTSU    DIV  S5SSYS    P@BOXD
     C                     ENDIF
     C                     Z-ADD0         P2BOXP
     C           S5KMAX    IFNE 0
     C           S5KMAA    DIV  S5KMAX    P2BOXP
     C                     ENDIF
      *
     C           KEYFC1    KLIST
     C                     KFLD           S5SHN1
     C                     KFLD           S5SHN2
     C                     KFLD           S5SHN3
     C                     Z-ADD0         P2GEHZ
     C           KEYFC1    CHAINFCEPL011             25
     C           *IN25     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     25
     C                     ENDIF
     C           *IN25     IFEQ '0'
     C                     MOVELA2GEHZ    P2GEHZ
     C                     ENDIF
      *
     C                     WRITEABMPRI72
      *
     CSR         EDTOUT    ENDSR
