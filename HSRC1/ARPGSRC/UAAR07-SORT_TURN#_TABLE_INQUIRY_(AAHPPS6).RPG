     FUAAPW07 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN1  KSFILE SFL01
     FAAHPPS6 IF  E           K        DISK
      *================================================================
     IINFDS       DS
     I                                    B 378 3790$$RRN
      *
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *     <<
      *
     I           SDS
     I                                     *PROGRAM W@PGM
     I                                      244 253 W@WSID
     I                                      254 263 W@USER
     I                                      264 269 W@JBNO
     C*===============================================================
     C           *ENTRY    PLIST
     C                     PARM           P@MCN#  3
     C*===============================================================
     C*  START  PROGRAM
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
     C                     TIME           @TIME
     C                     MOVEA*ALL'0'   *IN
     C                     MOVE 'Y'       FIRST   1
     C                     MOVE *BLANK    SVMCN#  3
      *
     C* SFLCLR
     C                     SETON                     72
     C                     WRITECTL01
     C                     SETOF                     72
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         ENDRRN  40
      *
     C           KEY01     KLIST
     C                     KFLD           K@MCN#
      *
     C                     MOVELP@MCN#    K@MCN#  3
     C                     MOVEL*BLANK    P@MCN#
      *
     C           KEY01     SETLLAAHPPS6
      *-----------------------------------
     C                     DO   *HIVAL
     C                     READ AAHPPS6                  90
     C   90                LEAVE
     C*
     C           S6SKJY    IFEQ 'D'                        DELETE CODE
     C                     ITER
     C                     ENDIF
     C*
     C                     MOVELS6MCN     S1MCN#
     C                     MOVELS6TRN#    S1TRN#
     C*
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C*
     C                     ENDDO
      *-----------------------------------
     C                     Z-ADDRRN1      ENDRRN
     C                     Z-ADD1         RRN1             エラー
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
      *===============================================================
      *  DISPLAY SCREEN 1
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     SETON                     70
     C           ENDRRN    IFNE 0
     C                     SETON                     71
     C                     ENDIF
     C                     WRITEDSP99
     C                     EXFMTCTL01
     C                     SETOF                     707199
     C                     Z-ADD$$RRN     RRN1
     C*----------
     C                     SELEC
     C* < F3/F12 > END
     C           *INKC     WHEQ *ON
     C           *INKL     OREQ *ON
     C                     MOVE '#END    '@STEP
     C* < PAGE UP/DOWN >
     C           *IN73     WHEQ *ON
     C           *IN73     OREQ *ON
     C                     MOVE '#DSP1   '@STEP
     C* < ENTR >
     C                     OTHER
     C           $RRN      IFNE 0
     C           $RRN      CHAINSFL01                95
     C           *IN95     IFEQ *OFF
     C                     MOVELS1MCN#    P@MCN#
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
     C                     ENDSR
      *===============================================================
