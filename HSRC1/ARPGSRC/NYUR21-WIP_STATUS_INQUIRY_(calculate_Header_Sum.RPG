     H            Y.
     F**************************************************************************
     F*  PROGRAM    : NYUR21 (CALCULATE HEADER SUMMARY)                        *
     F*  WRITTEN    : 10/2322015                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F*  FUNCTION   :                                                          *
     F*             :                                                          *
     F**************************************************************************
     FNZUPL02 IF  E           K        DISK
     F**************************************************************************
     I            DS
     I                                        1   80$DATE
     I                                        1   4 @HAYY
     I                                        5   6 @HAMM
     I                                        7   8 @HADD
      *----------------------------------------------------*
      *                    MAIN ROUTINE                    *
      *----------------------------------------------------*
     C                     EXSR @INIT
      * SET KEY
     C                     MOVEL$HIN1     K2SHN1
     C                     MOVEL$HIN2     K2SHN2
     C                     MOVEL$HIN3     K2SHN3
     C                     MOVEL$DATE     K2HAHZ
     C                     MOVEL$HABB     K2HABB
     C                     MOVE *BLANK    K2TEHI
     C                     MOVE *BLANK    K2PAGN
     C                     SETOF                     8166
     C           KEYN11    SETLLNZUPL02
     C           KEYN12    READENZUPL02                  81
      *
     C           *IN81     DOWEQ'0'
     C                     EXSR @CALC
     C           KEYN12    READENZUPL02                  81
     C  N81                ENDDO
      *
     C                     MOVELHKSU      $OHKSU
     C                     MOVELNYSU      $ONYSU
     C                     MOVELSISU      $OSISU
     C                     MOVELKISU      $OKISU
      *WIP
     C           HKSU      SUB  NYSU      SYSU
     C                     SUB  SISU      SYSU
     C                     MOVELSYSU      $OSYSU
      *INVENTORY
     C           NYSU      SUB  KISU      INV
     C                     MOVELINV       $OINV
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  CALCULATION                                       *
      *----------------------------------------------------*
     C           @CALC     BEGSR
      *# OF KANBAN
     C                     ADD  1         HKSU
      *STOCK-IN
     C           N2NYHZ    IFNE 0
     C                     ADD  1         NYSU
     C                     ELSE
     C           N2DEHZ    IFNE 0
     C                     ADD  1         NYSU
     C                     ENDIF
     C                     ENDIF
      *STOCK-OUT
     C           N2DEHZ    IFNE 0
     C                     ADD  1         KISU
     C                     ENDIF
      *BACKOFF
     C           N2SKJY    IFNE *BLANK
     C                     ADD  1         SISU
     C                     ENDIF
      *
     C           ECALC     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           @INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $HIN1   5
     C                     PARM           $HIN2   5
     C                     PARM           $HIN3   2
     C                     PARM           $HAYY   4
     C                     PARM           $HAMM   2
     C                     PARM           $HADD   2
     C                     PARM           $HABB   2
      *OUT
     C                     PARM           $OHKSU  5
     C                     PARM           $OSISU  5
     C                     PARM           $ONYSU  5
     C                     PARM           $OSYSU  5
     C                     PARM           $OKISU  5
     C                     PARM           $OINV   5
      * KEY LIST
     C           KEYN11    KLIST
     C                     KFLD           K2SHN1  5
     C                     KFLD           K2SHN2  5
     C                     KFLD           K2SHN3  2
     C                     KFLD           K2HAHZ  80
     C                     KFLD           K2HABB  20
     C                     KFLD           K2TEHI  3
     C                     KFLD           K2PAGN  2
      *
     C           KEYN12    KLIST
     C                     KFLD           K2SHN1
     C                     KFLD           K2SHN2
     C                     KFLD           K2SHN3
     C**                   KFLD           K2HAHZ
     C**                   KFLD           K2HABB
      *
     C                     MOVEL$HAYY     @HAYY
     C                     MOVEL$HAMM     @HAMM
     C                     MOVEL$HADD     @HADD
     C                     MOVE *ALL'0'   $OHKSU
     C                     MOVE *ALL'0'   $OSISU
     C                     MOVE *ALL'0'   $ONYSU
     C                     MOVE *ALL'0'   $OSYSU
     C                     MOVE *ALL'0'   $OKISU
     C                     MOVE *ALL'0'   $OINV
      *
     C                     Z-ADD0         HKSU    50
     C                     Z-ADD0         SISU    50
     C                     Z-ADD0         NYSU    50
     C                     Z-ADD0         SYSU    50
     C                     Z-ADD0         KISU    50
     C                     Z-ADD0         INV     50
      *
     C           EINIT     ENDSR
