     H            Y.
     F** AB#R2I *******************************
     F*  TMI         FORECAST PROCESSING   *
     F*                                       *
     F*           MAR/12/04                   *
TCH72F* TCH 05/31/05 FOR TMI     COPIED FROM AB#R27
     F******************************* AB#R2E **
     FTMIF    IP  F     600            DISK
     FABAWTMF O   E                    DISK
     FAGDPL12 IF  E           K        DISK
     F*AAPL02 IF  E           K        DISK
     F*CEPL01 IF  E           K        DISK
      *--------------------------------------------------------
     E                    AY        500  1
     E                    DT1        13  8 0
     E                    DAT        13  8 0
     E                    A21         2  1
     E                    A22         2  1
     E                    A9          9  1
     E                    A9X         9  1
      *
     E                    AMM        30  2
     E                    ADD        30  2
     E                    AYY        30  4
     E                    ZYY         4  1
     E                    ADT        30  8
     E                    APT        14  1
     E                    AQT        09  1
     E                    XQT        13  9
     E                    SQT         9  1
      *--------------------------------------------------------
     ITMIF    AA  01
     I                                        1 256 DAT1
     I                                      257 500 DAT2
     I            DS
     I                                        1   80YMD
     I                                        1   40YEAR
     I                                        5   60MONTH
     I                                        7   80DAY
     I            DS
     I                                        1   8 YMD6
     I                                        1   4 YY
     I                                        5   6 MM
     I                                        7   8 DD
     I            DS
     I                                        1  17 #PART
     I                                        1   5 AWMHN1
     I                                        7  11 AWMHN2
     I                                       13  17 AWMHN3
      *
     I            DS
     I                                        1   8 WADT
     I                                        1   4 WAYY
     I                                        5   6 WAMM
     I                                        7   8 WADD
      *
     I            DS
     I                                        1   80AWENDD
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I            DS
     I                                        1   80AWSTRD
     I                                        1   40NAYY
     I                                        5   60NAMM
     I                                        7   80NADD
      *
     C           *ENTRY    PLIST
     C                     PARM           PID     1
      *
     C           KEY3      KLIST
     C                     KFLD           NAYY    40
     C                     KFLD           NAMM    20
     C                     KFLD           NADD    20
      *
     C           KEY4      KLIST
     C                     KFLD           AWTOKU
     C                     KFLD           AWNONY
     C                     KFLD           XXNKOJ
     C                     KFLD           XXNUKE
     C                     KFLD           AWMHN1
     C                     KFLD           AWMHN2
     C                     KFLD           AWMHN3
     C*          KEY5      KLIST
     C*                    KFLD           B7SHN1
     C*                    KFLD           B7SHN2
     C*                    KFLD           B7SHN3
      * CONSTANT
     C                     Z-ADD3540      AWTOKU
     C                     Z-ADD3540      AWNONY
     C                     MOVE '0'       AWNKOJ
     C                     MOVE '00  '    AWNUKE
      *
     C                     MOVEADAT1      AY,1
     C                     MOVEADAT2      AY,257
     C* ======
     C* HEADER
     C* ======
B0   C           *IN99     IFEQ *OFF
     C                     Z-ADD1         X       30
     C           'DATE'    SCAN DAT1      X              10
     C  N10      'date'    SCAN DAT1      X              10
     C  N10                GOTO @END
      *
      * START DATE
      * (SKIP)
      * (POSITION TO FIRST START DATE)
     C           ','       SCAN DAT1      X              10
B1   C                     DO   10
     C           AY,X      IFEQ ','
     C                     ADD  1         X
     C                     ITER
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
 E1  C                     ENDDO
      *
     C                     MOVE *BLANK    A21
     C                     MOVE *BLANK    A22
     C                     MOVE *BLANK    AMM
     C                     MOVE *BLANK    ADD
     C                     MOVE *BLANK    AYY
     C                     Z-ADD0         Y       30
     C                     Z-ADD1         Z       30
     C                     Z-ADD0         G       30
      * ============== *
B1   C                     DO   20
     C                     ADD  1         Y
     C           '/'       LOKUPAY,X                     10
B2   C           *IN10     IFEQ '1'
     C* GET MM
     C           X         SUB  2         G
     C           AY,G      IFEQ ','
     C                     MOVEL'0'       AMM,Y
     C                     ELSE
     C                     MOVELAY,G      AMM,Y
     C                     ENDIF
     C           X         SUB  1         G
     C                     MOVE AY,G      AMM,Y
     C                     ADD  1         X
     C           '/'       LOKUPAY,X                     10
B3   C           *IN10     IFEQ '1'
     C* GET DD
     C           X         SUB  2         G
     C           AY,G      IFEQ '/'
     C                     MOVEL'0'       ADD,Y
     C                     ELSE
     C                     MOVELAY,G      ADD,Y
     C                     ENDIF
     C           X         SUB  1         G
     C                     MOVE AY,G      ADD,Y
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
B4   C           *IN10     IFEQ '1'
     C* GET YYYY
     C           X         SUB  4         G
     C                     MOVELAY,G      ZYY,1
     C                     ADD  1         G
     C                     MOVELAY,G      ZYY,2
     C                     ADD  1         G
     C                     MOVELAY,G      ZYY,3
     C                     ADD  1         G
     C                     MOVELAY,G      ZYY,4
     C                     MOVEAZYY       AYY,Y
      *
     C                     MOVEAAYY,Y     WAYY
     C                     MOVEAAMM,Y     WAMM
     C                     MOVEAADD,Y     WADD
     C                     MOVE WADT      ADT,Y
      * LAST RECORD
     C           X         ADD  1         G
B5   C           AY,G      IFEQ ' '
     C                     LEAVE
E5   C                     ENDIF
E4   C                     ENDIF
E3   C                     ENDIF
E2   C                     ENDIF
E1   C                     ENDDO
      *
      * ============== *
      *
     C*          A21,2     IFEQ *BLANK
     C*                    MOVE A21,1     A21,2
     C*                    MOVE '0'       A21,1
     C*                    ENDIF
      *
      * END DATE
      *
      *++++++
     C                     MOVE *ON       *IN99
     C                     GOTO @END
      *++++++
      *
E0   C                     ENDIF
     C*=======
      * DETAIL
     C*=======
B0   C           *IN88     IFEQ *OFF
     C                     Z-ADD1         X       30
     C           'PART'    SCAN DAT1      X              10
     C  N10      'part'    SCAN DAT1      X              10
     C  N10                GOTO @END
     C           *IN10     IFEQ '1'
     C                     MOVE '1'       *IN88
     C                     GOTO @END
     C                     ENDIF
E0   C                     ENDIF
     C                     Z-ADD1         X
      * -------------
      *   PART NUMBER
      * -------------
     C                     MOVE *BLANKS   APT
     C           ','       LOKUPAY,X                     10
B0   C           *IN10     IFEQ '1'
     C           X         SUB  14        G
B1   C           1         DO   14        H       30
B2   C           AY,G      IFEQ ','
     C                     LEAVE
     C                     ELSE
     C                     MOVELAY,G      APT,H
     C                     ADD  1         G
E2   C                     ENDIF
E1   C                     ENDDO
E0   C                     ENDIF
      *
     C                     MOVEAAPT       #PART
      * ---
      * QTY/# BOX
      * ---
     C                     MOVE AWNKOJ    XXNKOJ  1
     C                     MOVE AWNUKE    XXNUKE  4
     C*                    CLEARAWSYOS
     C*          KEY4      CHAINFAAPL021             67
B0   C*          *IN67     IFEQ '1'
     C*                    CLEARXXNKOJ
     C*                    CLEARXXNUKE
     C*          KEY4      CHAINFAAPL021             67
B1   C*          *IN67     IFEQ '0'
     C*          KEY5      CHAINFCEPL011             68
     C*          *IN68     IFEQ '0'
B2   C*          A2GSKD    ANDEQ' '
     C*                    Z-ADDA2SSYS    AWSYOS
E2   C*                    ENDIF
E1   C*                    ENDIF
X0   C*                    ELSE
     C*          KEY5      CHAINFCEPL011             68
     C*          *IN68     IFEQ '0'
B1   C*          A2GSKD    ANDEQ' '
     C*                    Z-ADDA2SSYS    AWSYOS
E1   C*                    ENDIF
E0   C*                    ENDIF
      *
B0   C           1         DO   Y         K       30
      *
      * ---
      * QTY
      * ---
     C                     MOVE *BLANKS   AQT
     C           ','       LOKUPAY,X                     10
B1   C           *IN10     IFEQ '1'
     C                     ADD  1         X
     C           ','       LOKUPAY,X                     10
E1   C                     ENDIF
     C           X         ADD  1         G
B1   C           1         DO   09        H       30
B2   C           AY,G      IFEQ ','
     C                     LEAVE
     C                     ELSE
     C                     MOVE AY,G      AQT,H
     C                     ADD  1         G
E2   C                     ENDIF
E1   C                     ENDDO
     C                     EXSR #QTY
     C                     MOVEASQT       XQT,K
     C                     MOVE XQT,K     AWSRYO
     C                     MOVE ADT,K     AWSTRD
     C                     CLEARSQT
      * FOR END   DATE
     C                     MOVE '0'       *IN44
     C           KEY3      SETLLAGDPL121
     C           *IN44     DOWEQ'0'
     C                     READ AGDPL121                 44
     C                     READ AGDPL121                 44
     C                     READ AGDPL121                 44
     C                     READ AGDPL121                 44
     C                     READ AGDPL121                 44
     C                     READ AGDPL121                 44
     C                     READ AGDPL121                 44
     C                     LEAVE
     C                     ENDDO
      *
     C*++++++++
     C* WRITE
     C*++++++++
      *
     C                     WRITEABAWTMF1
      *
E0   C                     ENDDO
      *
     C                     MOVE '1'       PID
      *
     C           @END      TAG
      *--------------------------------------------------------
     C           #QTY      BEGSR
      *--------------------------------------------------------
     C                     Z-ADD9         S       10
     C                     Z-ADD9         F       10
     C                     DO   9
     C           AQT,S     IFNE ' '
     C                     MOVE AQT,S     SQT,F
     C           F         SUB  1         F
     C                     ENDIF
     C           S         SUB  1         S
     C                     ENDDO
      *
     C                     ENDSR
      *--------------------------------------------------------
     C           #DATE     BEGSR
      *--------------------------------------------------------
     C                     MOVE *BLANK    A21
     C                     MOVE *BLANK    A22
     C                     Z-ADD1         Z       30
     C                     Z-ADD*ZERO     Y       30
     C                     DO   *HIVAL
     C                     ADD  1         X
     C           AY,X      IFEQ ','
     C           AY,X      OREQ '-'
     C           AY,X      OREQ *BLANK
     C                     LEAVE
     C                     ENDIF
      *
     C           AY,X      IFEQ '/'
     C                     ADD  1         Z
     C                     Z-ADD*ZERO     Y
     C                     ELSE
     C                     ADD  1         Y
     C                     SELEC
     C           Z         WHEQ 1
     C                     MOVE AY,X      A21,Y
     C           Z         WHEQ 2
     C                     MOVE AY,X      A22,Y
     C                     ENDSL
     C                     ENDIF
     C                     ENDDO
      *
     C           A21,2     IFEQ *BLANK
     C                     MOVE A21,1     A21,2
     C                     MOVE '0'       A21,1
     C                     ENDIF
     C           A22,2     IFEQ *BLANK
     C                     MOVE A22,1     A22,2
     C                     MOVE '0'       A22,1
     C                     ENDIF
      *
     C                     MOVEAA21       MM
     C                     MOVEAA22       DD
      *
     C                     MOVE MM        MONTH
     C                     MOVE DD        DAY
     C*          MM        IFGE @@MM
     C*                    Z-ADD@@YY      YEAR
     C*                    ELSE
     C*          @@YY      ADD  1         YEAR
     C*                    ENDIF
      *
     C                     ENDSR
