     H            Y.
     F** CHKR20 *******************************************************
     F* SET QUICK IPL FLAG                                            *
     F* CREATE DATE : 2018.08.06                                      *
     F* AUTHOR      : J.WATANABE                                      *
     F* FUNCTION    : SET FALG Y OR N                                 *
     F*               WHEN FLAG=Y, IPL SKIPS FILE REORGANIZE PROCESS  *
     F*****************************************************************
     FCHKPW20 CF  E                    WORKSTN
     FAB#PPCK UF  E           K        DISK                      A
     F*-----------------------------------------------------------
     E                    TTL     1   3 55
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I                                      264 269 #JOB
      *--------------------------------------------------
      *  MAIN ROUTINE
      *--------------------------------------------------
     C                     TIME           WSDT
     C                     EXSR #SETD
      * DISPLAY LOOP
     C                     DO   *HIVAL
     C                     EXFMTWIN01
     C                     MOVE *BLANK    XMSG
      * END?
     C           *INKA     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C                     EXSR #CHK1
      *
     C           OKFLG     IFEQ 'Y'
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD1
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *--------------------------------------------------
      *  SET DATA
      *--------------------------------------------------
     C           #SETD     BEGSR
     C                     MOVEL'QIPL'    $KEY1  10 P
     C           $KEY1     CHAINAB#PPCK             N90
      *
     C           *IN90     IFEQ *OFF
     C                     MOVELCKSFLG    XFLAG
     C                     MOVELCKSUSR    XUSER
     C                     MOVELCKSWS     XWSID
     C                     Z-ADDCKSDAT    XDATE
     C                     Z-ADDCKSTIM    XTIME
     C                     MOVELCKSPGM    XPGM
     C                     ELSE
     C                     MOVE *BLANK    XFLAG
     C                     MOVE *BLANK    XUSER
     C                     MOVE *BLANK    XWSID
     C                     Z-ADD0         XDATE
     C                     Z-ADD0         XTIME
     C                     MOVEL*BLANK    XPGM
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------
      *  CHECK DATA
      *--------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     MOVE 'N'       OKFLG   1
      *
     C           XFLAG     IFNE 'Y'
     C           XFLAG     ANDNE'N'
     C                     MOVELTTL,1     XMSG
     C                     GOTO #CHKX
     C                     ENDIF
      * IF NO ERROR,
     C                     MOVE 'Y'       OKFLG
     C                     MOVELTTL,2     XMSG
      *
     C           #CHKX     TAG
     C                     ENDSR
      *--------------------------------------------------
      *  UPDATE AB#PPCK
      *--------------------------------------------------
     C           #UPD1     BEGSR
      *
     C           $KEY1     CHAINAB#PPCK              91
     C           *IN91     IFEQ *OFF
     C                     MOVELCKSFLG    CKLFLG
     C                     MOVELCKSUSR    CKLUSR
     C                     MOVELCKSWS     CKLWS
     C                     MOVELCKSJNO    CKLJNO
     C                     Z-ADDCKSDAT    CKLDAT
     C                     Z-ADDCKSTIM    CKLTIM
     C                     MOVELCKSPGM    CKLPGM
      *
     C                     MOVELXFLAG     CKSFLG
     C                     MOVEL#USER     CKSUSR
     C                     MOVEL#WSID     CKSWS
     C                     MOVEL#JOB      CKSJNO
     C                     Z-ADDTODAY     CKSDAT
     C                     Z-ADDNOW       CKSTIM
     C                     MOVEL#PGM      CKSPGM
      *
     C                     UPDATAB#PPCK1
     C                     ENDIF
      *
     C           *IN91     IFEQ *ON
     C                     CLEARAB#PPCK1
     C                     MOVEL$KEY1     CKKEY1
     C                     MOVELXFLAG     CKSFLG
     C                     MOVEL#USER     CKSUSR
     C                     MOVEL#WSID     CKSWS
     C                     MOVEL#JOB      CKSJNO
     C                     Z-ADDTODAY     CKSDAT
     C                     Z-ADDNOW       CKSTIM
     C                     MOVEL#PGM      CKSPGM
     C                     WRITEAB#PPCK1
     C                     ENDIF
      *
     C                     MOVELTTL,3     XMSG
      *
     C                     ENDSR
** TTL
FLAG SHOULD BE Y OR N!
PRESS F5 TO UPDATE...
FLAG HAS BEEN UPDATED. PRESS F1 TO END JOB.
