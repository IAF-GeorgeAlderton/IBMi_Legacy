     C                     MOVELDAJOKN    WAJOKN  2
     C                     MOVELDAKBAN    WAKBAN  3
     C                     MOVELDAKBNC    WAKBNC  1
     C                     Z-ADDDASRYO    WASRYO  70
     C                     Z-ADDDASORT    WASORT  30
     C                     MOVELDAGETS    WAGETS  1
     C                     MOVELDAUKEI    WAUKEI  4
     C                     Z-ADDDARZBI    WARZBI  80
     C                     Z-ADDDADTYY    WADTYY  40
     C                     Z-ADDDADTMM    WADTMM  20
     C                     Z-ADDDADTDD    WADTDD  20
     C                     Z-ADDDADTBB    WADTBB  20
      *
     CSR         ESB111    ENDSR
      *--------------------------------------*
      *                                      *
      *--------------------------------------*
     CSR         #SB400    BEGSR
      *
     C           DASKJY    IFEQ 'D'
     C           DASKHZ    ANDLE*DATE
     C                     ELSE
     C           DAMAK2    IFEQ *BLANK
     C                     ADD  DAMAIS    WKMAIS
     C                     ADD  1         WKRCNT
     C                     MOVE '*'       DAMAK2
     C                     MOVE '*'       DAMAK1
     C                     Z-ADDK1APYY    DADTYY
     C                     Z-ADDK1APMM    DADTMM
     C                     Z-ADDK1APDD    DADTDD
     C                     Z-ADDP1APBN    DADTBB
     C                     UPDATADAPL641
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *--------------------------------------*
      *                                      *
      *--------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYAGA    KLIST
     C                     KFLD           WAHIN1  5
     C                     KFLD           WAHIN2  5
     C                     KFLD           WAHIN3  2
     C                     Z-ADD0         SITEBN  20
     C                     Z-ADD1         X       30
     C           KEYAGA    CHAINAGAPL311             22
     C           X         DOWLE24
     C           CBTR,X    IFNE 0
     C                     ADD  1         SITEBN
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     C           WKMAIS    IFNE 0
     C                     CLEARADKWP311
     C                     MOVELWAHIN1    W1SHN1
     C                     MOVELWAHIN2    W1SHN2
     C                     MOVELWAHIN3    W1SHN3
     C                     Z-ADDWKBARL    W1BARL
     C                     Z-ADDWKMAIS    W1MAIS
     C                     Z-ADDWKRCNT    W1RCNT
     C           SITEBN    IFEQ 0
     C                     MOVEL'1'       W1TRBN
     C                     ELSE
     C                     MOVEL'0'       W1TRBN
     C                     ENDIF
     C                     Z-ADDP1APHZ    W1APHZ
     C                     Z-ADDP1APBN    W1APBN
      *
     C                     MOVELWABRUI    W1BRUI  1
