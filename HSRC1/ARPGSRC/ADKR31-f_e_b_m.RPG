     C                     MOVELWAFILR    W1FILR156
     C                     MOVELWAMAK1    W1MAK1  1
     C                     MOVELWAMAK2    W1MAK2  1
     C                     Z-ADDWADATE    W1DATE  80
     C                     MOVELWABAN2    W1BAN2  6
     C                     MOVELWABAN3    W1BAN3  6
     C                     Z-ADDWASYUY    W1SYUY  50
     C                     Z-ADDWABMON    W1BMON  40
     C                     MOVELWAZENO    W1ZENO  4
     C                     MOVELWABLOK    W1BLOK  2
     C                     Z-ADDWACODE    W1CODE  40
