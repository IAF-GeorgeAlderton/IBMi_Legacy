     C                     MOVELWAMEK1    W1MEK1  4
     C                     MOVELWAMEK2    W1MEK2  2
     C                     MOVELWAMEK3    W1MEK3  1
     C                     Z-ADDWAMKLT    W1MKLT  31
     C                     MOVELWACOLR    W1COLR  1
     C                     Z-ADDWASIZE    W1SIZE  20
     C                     Z-ADDWAKUBI    W1KUBI  30
     C                     Z-ADDWACIHI    W1CIHI  20
     C                     Z-ADDWACIBI    W1CIBI  20
     C                     Z-ADDWACIOK    W1CIOK  20
     C                     MOVELWAOFFL    W1OFFL  1
     C                     Z-ADDWAKACO    W1KACO  40
     C                     Z-ADDWATOKI    W1TOKI  40
     C                     Z-ADDWANOBB    W1NOBB  20
     C                     MOVELWAMLIN    W1MLIN  1
     C                     MOVELWAJOKN    W1JOKN  2
     C                     MOVELWAKBAN    W1KBAN  3
     C                     MOVELWAKBNC    W1KBNC  1
     C                     Z-ADDWASRYO    W1SRYO  70
     C                     Z-ADDWASORT    W1SORT  30
