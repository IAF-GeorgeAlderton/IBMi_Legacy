     C                     TIME           WDATE
     C                     CALL 'ADKR95'
     C                     PARM           P1APHZ  80
     C                     PARM           P1APBN  20
      *
     C                     Z-ADDP1APHZ    K1APHZ  80
     C           KEYADA    KLIST
     C                     KFLD           K1APYY
     C                     KFLD           K1APMM
     C                     KFLD           K1APDD
     C           KEYADA    SETLLADAPL641
     C           KEYADA    READEADAPL641                 80
     C           *IN80     DOWEQ'0'
     C                     MOVELDAHIN     WAHIN  12
     C                     Z-ADDDABARL    WKBARL  50
     C                     Z-ADD0         WKMAIS  50
     C                     Z-ADD0         WKRCNT  50
     C                     EXSR #SB111
     C           *IN80     DOWEQ'0'
     C           DAHIN     ANDEQWAHIN
     C                     EXSR #SB400
     C           KEYADA    READEADAPL641                 80
     C                     ENDDO
     C                     EXSR #SB500
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------*
      *                                      *
      *--------------------------------------*
     CSR         #SB111    BEGSR
      *
     C                     MOVELDABRUI    WABRUI  1
     C                     Z-ADDDAHTYY    WAHTYY  40
     C                     Z-ADDDAHTMM    WAHTMM  20
