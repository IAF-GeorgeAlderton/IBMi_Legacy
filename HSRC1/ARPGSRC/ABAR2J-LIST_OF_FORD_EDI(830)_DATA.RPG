      * SYSTEM TIME & DATE
     I            DS
     I                                        1  140WTMDT
     I                                        1   60WTIME
     I                                        1   20WTIHH
     I                                        3   40WTIMM
     I                                        5   60WTISS
     I                                        7  140WDATE
     I                                        9  140WDAT6
     I                                        7  100WDAY4
     I                                        9  100WDAYY
     I                                       11  120WDAMM
     I                                       13  140WDADD
      *
     C                     TIME           WTMDT
      *
     C           *IN77     IFEQ '0'
     C                     SETON                     77
     C                     TIME           WTIME   60
     C                     SETOF                     101112
     C                     END
      *
     C           *INOA     IFEQ '1'
     C                     EXCPTHD
     C                     SETOF                     OA
     C                     END
     C           *INOB     IFEQ '1'
     C                     EXCPTHDE
     C                     SETOF                     OB
     C                     END
     C           *INOC     IFEQ '1'
     C                     EXCPTHDA
     C                     SETOF                     OC
     C                     END
      *
     C                     MOVE *BLANK    ECMT   50
     C           IERCD     IFEQ 0
     C                     EXSR #SUB01
     C                     ELSE
     C           INUKE     IFNE 'APNA'
     C           IERCD     IFEQ 1
     C                     MOVELCMT,1     ECMT
     C                     END
     C           IERCD     IFEQ 2
     C                     MOVELCMT,2     ECMT
     C                     END
     C           IERCD     IFEQ 3
     C                     MOVELCMT,3     ECMT
     C                     END
     C           *IN11     IFEQ '0'
     C                     SETON                     11
     C                     EXCPTHDE
     C                     END
     C                     EXCPTDATER
     C                     ELSE
     C           *IN12     IFEQ '0'
     C                     SETON                     12
     C                     EXCPTHDA
     C                     END
     C                     EXCPTDATA
     C                     END
     C                     END
      *
     CL1 72                SETON                     OA
      *-----------------------------------------------------*
     C           #SUB01    BEGSR
     C                     MOVELITOKU     PTOKU   4
     C                     MOVELINONY     PNONY   4
     C                     MOVELINKOJ     PNKOJ   1
     C                     MOVELINUKE     PNUKE   4
     C                     MOVELIMHIN     @MHIN  20
     C                     MOVEL*BLANK    @SHIN  12
     C                     MOVEL*BLANK    @FLG    1
      *
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           @MHIN  20
     C                     PARM           @SHIN  12
     C                     PARM           @FLG    1
     C           @FLG      IFEQ '*'
     C                     MOVELIMHIN     @SHIN
     C                     END
     C           KEY1      KLIST
     C                     KFLD           WSHN1
     C                     KFLD           WSHN2
     C                     KFLD           WSHN3
      *
     C                     Z-ADD0         WSYS    50
     C                     MOVE *BLANK    TANI    1
     C                     SETOF                     71
     C           KEY1      CHAINFCEPL011             71
     C           *IN71     IFEQ '0'
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLEWDATE
     C                     SETON                     71
     C                     END
     C                     END
     C           *IN71     IFEQ '0'
     C           A2SYHZ    IFGT INYMD
     C                     Z-ADDA2KSYS    WSYS
     C                     MOVELA2KSYT    TANI
     C                     ELSE
     C                     Z-ADDA2SSYS    WSYS
     C                     MOVELA2SSYT    TANI
     C                     END
     C           *IN10     IFEQ '0'
     C                     SETON                     10
     C                     EXCPTHD
     C                     END
     C                     EXCPTDAT
     C                     SETON                     72
     C                     END
     C           *IN71     IFEQ '1'
     C           *IN11     IFEQ '0'
     C                     SETON                     11
     C                     EXCPTHDE
     C                     END
     C                     MOVELCMT,4     ECMT
     C                     EXCPTDATER
     C                     END
     C           EXIT01    ENDSR
