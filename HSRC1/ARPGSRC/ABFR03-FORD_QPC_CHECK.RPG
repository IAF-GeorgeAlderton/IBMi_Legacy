     H            Y.
     F** ABRR03 ********************************************************
     F*  FORD QTY/CONT. CHECK                                          *
     F******************************************************** AB#RF4 **
     FABFPW03 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     FAB#PL16 IF  E           K        DISK
     FAB#PL14 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
      *------------------------------------------------------------
     E                    CMD     1   1 78
      *------------------------------------------------------------
     I            DS
     I                                        1   80K@DYMD
     I                                        1   40K@DEYY
     I                                        5   60K@DEMM
     I                                        7   80K@DEDD
     I            DS
     I                                        1   80K@NYMD
     I                                        1   40K@NOYY
     I                                        5   60K@NOMM
     I                                        7   80K@NODD
     I            DS
     I                                        1   80@@SYMD
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------------
      *   MAIN
      *------------------------------------------------------------
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           P@NONY  4
     C                     PARM           P@DOCK  4
     C                     PARM           P@SHDT  80
     C                     PARM           P@BIN   20
     C                     PARM           P@RLDT  80
     C                     PARM           P@FLG   1
     C           K#16      KLIST
     C                     KFLD           K@NONY  40
     C                     KFLD           K@DOCK  4
     C                     KFLD           K@NOYY
     C                     KFLD           K@NOMM
     C                     KFLD           K@NODD
     C                     KFLD           K@DEYY
     C                     KFLD           K@DEMM
     C                     KFLD           K@DEDD
     C           K#14      KLIST
     C                     KFLD           K@NOYY
     C                     KFLD           K@NOMM
     C                     KFLD           K@NODD
     C                     KFLD           K@NOBN  20
     C                     KFLD           K@DEYY
     C                     KFLD           K@DEMM
     C                     KFLD           K@DEDD
     C           K#FCE     KLIST
     C                     KFLD           BASHN1
     C                     KFLD           BASHN2
     C                     KFLD           BASHN3
     C           K#FCEX    KLIST
     C                     KFLD           BASHN1
     C                     KFLD           BASHN2
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
      *
     C                     Z-ADDP@RLDT    K@DYMD
     C                     Z-ADDP@SHDT    K@NYMD
     C                     Z-ADDP@BIN     K@NOBN
     C           P@NONY    IFNE *BLANK
     C                     MOVE P@NONY    K@NONY
     C                     MOVE P@DOCK    K@DOCK
     C                     EXSR #CHK1
      *
     C                     ELSE
     C                     EXSR #CHK2
     C                     ENDIF
      *
     C           RRN1      IFEQ *ZERO
     C                     MOVE '99'      @@ID    2
     C                     MOVE *BLANK    P@FLG
     C                     ELSE
     C                     MOVE '01'      @@ID
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #CHK1     BEGSR
      *-----------------------------------------------------
     C           K#16      SETLLAB#PL16
     C           *IN90     DOUEQ*ON
     C           K#16      READEAB#PL16                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BANOBN    ANDEQK@NOBN
      *
     C           BASYOS    IFEQ *ZERO
     C           K#FCE     CHAINFCEPL01              95
     C   95      K#FCEX    CHAINFCEPL01              95
     C           *IN95     IFEQ *OFF
     C           @@SYMD    IFGE K@DYMD
     C           A2KSYS    ANDNE*ZERO
     C                     Z-ADDA2KSYS    BASYOS
     C                     ELSE
     C                     Z-ADDA2SSYS    BASYOS
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C           BASYOS    IFNE *ZERO
     C           BASRYO    DIV  BASYOS    @@ANS   50
     C                     MVR            @@MVR   50
     C                     ELSE
     C           BAUSYS    IFNE *ZERO
     C           BASRYO    DIV  BAUSYS    @@ANS   50
     C                     MVR            @@MVR   50
     C                     ENDIF
     C                     ENDIF
      *
     C           @@MVR     IFGT *ZERO
     C           BASYOS    OREQ *ZERO
     C           BAUSYS    ANDEQ*ZERO
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     Z-ADDP@SHDT    S@SHDT
     C                     MOVE BAMHN1    S@MHN1
     C                     MOVE BAMHN2    S@MHN2
     C                     MOVE BAMHN3    S@MHN3
     C                     Z-ADDBANONY    S@NONY
     C                     MOVELBANUKE    S@DOCK
     C                     Z-ADDBANOBN    S@BIN
     C                     Z-ADDBASRYO    S@SQTY
     C                     Z-ADDBASYOS    S@BQTY
     C                     ADD  1         @@ANS
     C           BASYOS    IFNE *ZERO
     C           BASYOS    MULT @@ANS     S@AQTY
     C                     ELSE
     C           BAUSYS    IFNE *ZERO
     C           BAUSYS    MULT @@ANS     S@AQTY
     C                     ENDIF
     C                     ENDIF
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #CHK2     BEGSR
      *-----------------------------------------------------
     C           K#14      SETLLAB#PL14
     C           *IN90     DOUEQ*ON
     C           K#14      READEAB#PL14                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
      *
     C           BASYOS    IFEQ *ZERO
     C           K#FCE     CHAINFCEPL01              95
     C   95      K#FCEX    CHAINFCEPL01              95
     C           *IN95     IFEQ *OFF
     C           @@SYMD    IFGE K@DYMD
     C           A2KSYS    ANDNE*ZERO
     C                     Z-ADDA2KSYS    BASYOS
     C                     ELSE
     C                     Z-ADDA2SSYS    BASYOS
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C           BASYOS    IFNE *ZERO
     C           BASRYO    DIV  BASYOS    @@ANS   50
     C                     MVR            @@MVR   50
     C                     ELSE
     C           BAUSYS    IFNE *ZERO
     C           BASRYO    DIV  BAUSYS    @@ANS   50
     C                     MVR            @@MVR   50
     C                     ENDIF
     C                     ENDIF
      *
     C           @@MVR     IFGT *ZERO
     C           BASYOS    OREQ *ZERO
     C           BAUSYS    ANDEQ*ZERO
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     Z-ADDP@SHDT    S@SHDT
     C                     MOVE BAMHN1    S@MHN1
     C                     MOVE BAMHN2    S@MHN2
     C                     MOVE BAMHN3    S@MHN3
     C                     Z-ADDBANONY    S@NONY
     C                     MOVELBANUKE    S@DOCK
     C                     Z-ADDBANOBN    S@BIN
     C                     Z-ADDBASRYO    S@SQTY
     C                     Z-ADDBASYOS    S@BQTY
     C                     ADD  1         @@ANS
     C           BASYOS    IFNE *ZERO
     C           BASYOS    MULT @@ANS     S@AQTY
     C                     ELSE
     C           BAUSYS    IFNE *ZERO
     C           BAUSYS    MULT @@ANS     S@AQTY
     C                     ENDIF
     C                     ENDIF
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #SCRN1    BEGSR
      *-----------------------------------------------------
     C                     MOVE CMD,1     D@CMD
      *
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     SELEC
     C           *INKG     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     MOVE *BLANK    P@FLG
     C                     OTHER
     C                     MOVE '99'      @@ID
     C                     MOVE '9'       P@FLG
     C                     ENDSL
      *
     C                     ENDSR
** CMD
 ENTER:END        F7:IGNORE & CONTINUE
