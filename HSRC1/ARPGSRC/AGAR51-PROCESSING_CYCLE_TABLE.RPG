     H            Y
      **   AGAR51   *********************************
      *        PROCESSING CYCLE TABLE             *
      *                    WRITTEN ==> S.OOTAKE     *
      *                    UPDATE  ==> 1993/07/08   *
      *********************************   AGAR51   **
      ** LEVELLED PRODUCTION FILE PROCESSING CYCLE CHECK M/F
     FAGAWP52 IP  F      45            DISK
      ********************************************
      ** RATHER THIN M/F
     FFGBPL01 IF  E           K        DISK
      ********************************************
      ** PRINTER FILE
     FAGAPR51 O   E             98     PRINTER
      ********************************************
      *
      ***** ARRANGEMENT *****
     E                    MAE         3  4 0
     E                    MAEN        3 15
     IAGAWP52 AA
     I                                        1   50WKWBMN
     I                                        6  100WKWMKR
     I                                       11  150WKWNEX
     I                                       16  190WKMBMN
     I                                       20  230WKMMKR
     I                                       24  270WKNEXT
     I                                       28  290WKMSA1
     I                                       30  310WKMSA2
     I                                       32  330WKMSA3
     I                                       34  350WKTSA1
     I                                       36  370WKTSA2
     I                                       38  390WKTSA3
     I                                       40  410WKKSA1
     I                                       42  430WKKSA2
     I                                       44  450WKKSA3
      *** AN ARRANGEMENT OF SECTION CODE ***
     I            DS
     I                                        1  120MAE
     I                                        1   40WKMBMN
     I                                        5   80WKMMKR
     I                                        9  120WKNEXT
      *** AN ARRANGEMENT OF A SECTION NAME ***
     I            DS
     I                                        1  45 MAEN
     I                                        1  15 MBMNNM
     I                                       16  30 MMKRNM
     I                                       31  45 NEXTNM
      *** DS OF RATHER THIN DELETE DATE ***
     I            DS
     I                                        1   80SAIHIZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
     C           *ENTRY    PLIST
     C                     PARM           USER   10
      *
     C           KEY2      KLIST
     C                     KFLD           B2CODE
      *****************************************
      ***            PGM START              ***
      *****************************************
      *
     C           *IN50     IFEQ '0'
     C                     MOVE *BLANK    PUSNM  15
     C                     CALL 'APLR00'
     C                     PARM           USER
     C                     PARM           PUSNM
     C                     MOVELPUSNM     USERNM  9
      *
     C                     WRITEAGAPR511
     C                     SETON                     50
     C                     END
      *
     C                     MOVE *BLANK    MBMNNM
     C                     MOVE *BLANK    MMKRNM
     C                     MOVE *BLANK    NEXTNM
     C                     SETOF                     010203
     C                     Z-ADD1         I       10
      *
     C                     DO   3         I
     C           MAE,I     IFEQ 0
     C                     GOTO EXIT
     C                     END
     C                     MOVE MAE,I     B2CODE
     C                     SETOF                     15
     C           KEY2      CHAINFGBPL011             15
     C           *IN15     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           SAIHIZ    ANDLE*DATE
     C                     GOTO EXIT
     C                     END
     C           *IN15     IFEQ '1'
     C                     GOTO EXIT
     C                     END
     C                     MOVE B2SMEI    MAEN,I
     C           EXIT      TAG
     C                     ENDDO
      *
     C           WKMBMN    IFEQ 0
     C                     SETON                     01
     C                     END
     C           WKMMKR    IFEQ 0
     C                     SETON                     02
     C                     END
     C           WKNEXT    IFEQ 0
     C                     SETON                     03
     C                     END
      *
     C           *IN98     IFEQ '1'
     C                     WRITEAGAPR511
     C                     WRITEAGAPR512
     C                     SETOF                     98
     C                     ELSE
     C                     WRITEAGAPR512
     C                     END
