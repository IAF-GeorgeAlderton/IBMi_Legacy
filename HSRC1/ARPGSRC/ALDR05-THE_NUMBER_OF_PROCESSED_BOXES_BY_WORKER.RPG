     H            Y.
     F** ALDR05 ********************************************************
     F*  THE NUMBER OF PROCESSED BOXES BY WORKER LIST                  *
     F*                                                                *
     F*  TCH 2000.08.14                                                *
     F*  TCH.2004.05.06                                                *
     F*  TCH.2004.11.15                                                *
     F*                                                                *
     F* *IN90=1(NOT READ ALDPP20)                                      *
     F* *IN91=1(NOT READ ALDPP30)                                      *
     F* *IN92=1(NOT READ ALDPP40)                                      *
     F* *IN93=1(NOT READ ALBPL30)                                      *
     F********************************************  ALDR05 *************
     FALDPL24 IF  E           K        DISK
     FALDPL34 IF  E           K        DISK
     FALDPL44 IF  E           K        DISK
     FALBPL30 IF  E           K        DISK
     FALDPP70 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FALDWP05 O   E                    DISK
     I******************************************************************
     I            DS
     I                                        1   80A1DATE
     I                                        1   40A1KSYY
     I                                        5   60A1KSMM
     I                                        7   80A1KSDD
     I            DS
     I                                        1   80A3DATE
     I                                        1   40A3KSYY
     I                                        5   60A3KSMM
     I                                        7   80A3KSDD
     I            DS
     I                                        1   80A5DATE
     I                                        1   40A5KSYY
     I                                        5   60A5KSMM
     I                                        7   80A5KSDD
     I            DS
     I                                        1   80D5DATE
     I                                        1   40D5YYYY
     I                                        5   60D5MMMM
     I                                        7   80D5DDDD
     I            DS
     I                                        1   80WWDATE
     I                                        1   40WWYY
     I                                        5   60WWMM
     I                                        7   80WWDD
     I            DS
     I                                        1   80XXDATE
     I                                        1   40XXYY
     I                                        5   60XXMM
     I                                        7   80XXDD
     I            DS
     I                                        1   80KKDATE
     I                                        1   40KYYYY
     I                                        5   60KMMMM
     I                                        7   80KDDDD
     I            DS
     I                                        1   40A1TIM
     I                                        1   20A1KSJI
     I                                        3   40A1KSPN
     I            DS
     I                                        1   40A2TIM
     I                                        1   20A2KSJI
     I                                        3   40A2KSPN
     I            DS
     I                                        1   40A3TIM
     I                                        1   20A3KSJI
     I                                        3   40A3KSPN
     I            DS
     I                                        1   40A5TIM
     I                                        1   20A5KSJI
     I                                        3   40A5KSPN
     I* SYSTEM(TIME + DATE)
     I            DS
     I                                        1  120WWTIME
     I                                        1   6 Z6TIME
     I                                        7  12 Z6DATE
     C**************************************************************************
     C*                    MAIN ROUTINE
     C**************************************************************************
     C           *ENTRY    PLIST
     C                     PARM           PYYYY   40
     C                     PARM           PMMMM   20
     C* ALDPL24,ALDPL34,ALDPL44
     C**         K1        KLIST
     C***                  KFLD           PYYYY
     C***                  KFLD           PMMMM
     C           K1        KLIST
     C                     KFLD           KYYYY
     C                     KFLD           KMMMM
     C                     KFLD           KDDDD
     C*
     C           K2        KLIST
     C                     KFLD           K21     60
      *
     C           K#AGD     KLIST
     C                     KFLD           K@YYYY  40
     C                     KFLD           K@MMMM  20
     C                     KFLD           K@DDDD  20
     C*
     C                     EXSR @INT
     C                     EXSR @MAIN
     C                     EXSR @END
     C**************************************************************************
     C*                    @INT
     C**************************************************************************
     C           @INT      BEGSR
     C*
     C                     Z-ADDPYYYY     WWYY
     C                     Z-ADDPMMMM     WWMM
     C                     Z-ADD1         WWDD
     C                     ADD  1         WWMM
     C           WWMM      IFGT 12
     C                     SUB  12        WWMM
     C                     ADD  1         WWYY
     C                     ENDIF
      *
     C                     Z-ADDPYYYY     KYYYY
     C                     Z-ADDPMMMM     KMMMM
     C                     Z-ADD1         KDDDD
     C           K1        SETLLAGDPL12
     C                     READPAGDPL12                  80
     C           *IN80     IFEQ *OFF
     C                     Z-ADDF8KAYY    KYYYY
     C                     Z-ADDF8KAMM    KMMMM
     C                     Z-ADDF8KADD    KDDDD
     C                     ENDIF
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @MAIN
     C**************************************************************************
     C           @MAIN     BEGSR
     C*
     C                     EXSR @P20
     C                     EXSR @P30
     C                     EXSR @P40
     C*
     C                     ENDSR
     C**************************************************************************
     C*          @P20 WRITE ALDPL24
     C**************************************************************************
     C           @P20      BEGSR
     C*
     C                     SETON                     80
     C*
     C           K1        SETLLALDPP201
     C*******    K1        READEALDPP201                 90
     C                     READ ALDPP201                 90
B01  C           *IN90     DOWEQ'0'
     C*
     C           A1DATE    IFGT WWDATE
     C                     LEAVE
     C                     ENDIF
      *
     C           A1DATE    IFEQ WWDATE
     C           A1TIM     ANDGE2230
     C                     GOTO @SKP1
     C                     ENDIF
      *
     C           A1DATE    IFEQ KKDATE
     C           A1TIM     ANDLT2230
     C                     GOTO @SKP1
     C                     ENDIF
      *
     C           A1TIM     IFGE 2230
     C                     Z-ADDA1KSYY    K@YYYY  40
     C                     Z-ADDA1KSMM    K@MMMM  20
     C                     Z-ADDA1KSDD    K@DDDD  20
     C           K#AGD     SETGTAGDPL12
     C                     READ AGDPL12                  94
     C           *IN94     IFEQ *OFF
     C                     Z-ADDF8KAYY    XXYY
     C                     Z-ADDF8KAMM    XXMM
     C                     Z-ADDF8KADD    XXDD
     C                     ENDIF
     C                     ELSE
     C                     Z-ADDA1KSYY    XXYY
     C                     Z-ADDA1KSMM    XXMM
     C                     Z-ADDA1KSDD    XXDD
     C                     ENDIF
      *
     C           A1OPER    CHAINALDPP70              95
     C*          *IN95     IFEQ *OFF
     C*          A7SHFT    ANDEQ'3'
     C*          A1KSJI    ANDLT12
     C*                    Z-ADDA1KSYY    K@YYYY  40
     C*                    Z-ADDA1KSMM    K@MMMM  20
     C*                    Z-ADDA1KSDD    K@DDDD  20
     C*          K#AGD     SETLLAGDPL12
     C*                    READPAGDPL12                  94
     C*          *IN94     IFEQ *OFF
     C*                    Z-ADDF8KAYY    A1KSYY
     C*                    Z-ADDF8KAMM    A1KSMM
     C*                    Z-ADDF8KADD    A1KSDD
     C*                    ENDIF
     C*                    ENDIF
      *
     C******     A1KSMM    CABNEPMMMM     @SKP1
     C* FIRST RECORD
B02  C           *IN80     IFEQ '1'
     C                     SETOF                     80
     C                     MOVE A1OPER    D5OPER
     C                     MOVE A1OPER    K21
     C           K2        CHAINALBPL30              93
B03  C           *IN93     IFEQ '0'
     C                     MOVE ALWKNM    D5NAME
     C*
     C                     ELSE
     C                     MOVE *BLANK    D5NAME
E03  C                     END
     C*
     C*                    Z-ADDA1KSYY    D5YYYY
     C*                    Z-ADDA1KSMM    D5MMMM
     C*                    Z-ADDA1KSDD    D5DDDD
     C                     Z-ADDXXDATE    D5DATE
     C                     ADD  1         D5BOX
     C*
     C                     ELSE
B03  C           A1OPER    IFNE D5OPER
     C           XXDATE    ORNE D5DATE
     C*          A1KSYY    ORNE D5YYYY
     C*          A1KSMM    ORNE D5MMMM
     C*          A1KSDD    ORNE D5DDDD
     C                     WRITEALDWP051
     C                     CLEARALDWP051
     C                     MOVE A1OPER    D5OPER
     C                     MOVE A1OPER    K21
     C           K2        CHAINALBPL30              93
B04  C           *IN93     IFEQ '0'
     C                     MOVE ALWKNM    D5NAME
     C*
     C                     ELSE
     C                     MOVE *BLANK    D5NAME
E04  C                     END
     C*
     C                     Z-ADDXXDATE    D5DATE
     C*                    Z-ADDA1KSYY    D5YYYY
     C*                    Z-ADDA1KSMM    D5MMMM
     C****                 Z-ADDA1KSDD    D5DDDD
     C                     ADD  1         D5BOX
     C*
     C                     ELSE
     C                     ADD  1         D5BOX
     C                     END
E02  C                     END
     C*
     C           @SKP1     TAG
     C***        K1        READEALDPP201                 90
     C                     READ ALDPP201                 90
E01  C                     END
     C*
     C  N80                WRITEALDWP051
     C  N80                CLEARALDWP051
     C*
     C                     ENDSR
     C**************************************************************************
     C*          @P30 WRITE ALDPL34
     C**************************************************************************
     C           @P30      BEGSR
     C*
     C                     SETON                     80
     C*
     C           K1        SETLLALDPP301
     C*******    K1        READEALDPP301                 91
     C                     READ ALDPP301                 91
B01  C           *IN91     DOWEQ'0'
     C*
     C           A3DATE    IFGT WWDATE
     C                     LEAVE
     C                     ENDIF
      *
     C           A3DATE    IFEQ WWDATE
     C           A3TIM     ANDGE2230
     C                     GOTO @SKP2
     C                     ENDIF
      *
     C           A3DATE    IFEQ KKDATE
     C           A3TIM     ANDLT2230
     C                     GOTO @SKP2
     C                     ENDIF
      *
     C           A3TIM     IFGE 2230
     C                     Z-ADDA3KSYY    K@YYYY  40
     C                     Z-ADDA3KSMM    K@MMMM  20
     C                     Z-ADDA3KSDD    K@DDDD  20
     C           K#AGD     SETGTAGDPL12
     C                     READ AGDPL12                  94
     C           *IN94     IFEQ *OFF
     C                     Z-ADDF8KAYY    XXYY
     C                     Z-ADDF8KAMM    XXMM
     C                     Z-ADDF8KADD    XXDD
     C                     ENDIF
     C                     ELSE
     C                     Z-ADDA3KSYY    XXYY
     C                     Z-ADDA3KSMM    XXMM
     C                     Z-ADDA3KSDD    XXDD
     C                     ENDIF
     C*
     C           A3OPER    CHAINALDPP70              95
     C*          *IN95     IFEQ *OFF
     C*          A7SHFT    ANDEQ'3'
     C*          A3KSJI    ANDLT12
     C*                    Z-ADDA3KSYY    K@YYYY  40
     C*                    Z-ADDA3KSMM    K@MMMM  20
     C*                    Z-ADDA3KSDD    K@DDDD  20
     C*          K#AGD     SETLLAGDPL12
     C*                    READPAGDPL12                  94
     C*          *IN94     IFEQ *OFF
     C*                    Z-ADDF8KAYY    A3KSYY
     C*                    Z-ADDF8KAMM    A3KSMM
     C*                    Z-ADDF8KADD    A3KSDD
     C*                    ENDIF
     C*                    ENDIF
      *
     C**         A3KSMM    CABNEPMMMM     @SKP2
     C* FIRST RECORD
B02  C           *IN80     IFEQ '1'
     C                     SETOF                     80
     C                     MOVE A3OPER    D5OPER
     C                     MOVE A3OPER    K21
     C           K2        CHAINALBPL30              93
B03  C           *IN93     IFEQ '0'
     C                     MOVE ALWKNM    D5NAME
     C*
     C                     ELSE
     C                     MOVE *BLANK    D5NAME
E03  C                     END
     C*
     C*********            Z-ADDA3DATE    D5DATE
     C                     Z-ADDXXDATE    D5DATE
     C*                    Z-ADDA3KSYY    D5YYYY
     C*                    Z-ADDA3KSMM    D5MMMM
     C*                    Z-ADDA3KSDD    D5DDDD
     C                     ADD  1         D5BOX
     C*
     C                     ELSE
B03  C           A3OPER    IFNE D5OPER
     C****       A3DATE    ORNE D5DATE
     C           XXDATE    ORNE D5DATE
     C*          A3KSYY    ORNE D5YYYY
     C*          A3KSMM    ORNE D5MMMM
     C*          A3KSDD    ORNE D5DDDD
     C                     WRITEALDWP051
     C                     CLEARALDWP051
     C*
     C                     MOVE A3OPER    D5OPER
     C                     MOVE A3OPER    K21
     C           K2        CHAINALBPL30              93
B04  C           *IN93     IFEQ '0'
     C                     MOVE ALWKNM    D5NAME
     C*
     C                     ELSE
     C                     MOVE *BLANK    D5NAME
E04  C                     END
     C*
     C********             Z-ADDA3DATE    D5DATE
     C                     Z-ADDXXDATE    D5DATE
     C*                    Z-ADDA3KSYY    D5YYYY
     C*                    Z-ADDA3KSMM    D5MMMM
     C*                    Z-ADDA3KSDD    D5DDDD
     C                     ADD  1         D5BOX
     C*
     C                     ELSE
     C                     ADD  1         D5BOX
     C*
E03  C                     END
E02  C                     END
     C*
     C           @SKP2     TAG
     C*******    K1        READEALDPP301                 91
     C                     READ ALDPP301                 91
E01  C                     END
     C*
     C  N80                WRITEALDWP051
     C  N80                CLEARALDWP051
     C*
     C                     ENDSR
     C**************************************************************************
     C*          @P40 WRITE ALDPL44
     C**************************************************************************
     C           @P40      BEGSR
     C*
     C                     SETON                     80
     C*
     C           K1        SETLLALDPP401
     C***        K1        READEALDPP401                 92
     C                     READ ALDPP401                 92
B01  C           *IN92     DOWEQ'0'
     C*
     C           A5DATE    IFGT WWDATE
     C                     LEAVE
     C                     ENDIF
      *
     C           A5DATE    IFEQ WWDATE
     C           A5TIM     ANDGE2230
     C                     GOTO @SKP3
     C                     ENDIF
      *
     C           A5DATE    IFEQ KKDATE
     C           A5TIM     ANDLT2230
     C                     GOTO @SKP3
     C                     ENDIF
      *
     C           A5TIM     IFGE 2230
     C                     Z-ADDA5KSYY    K@YYYY  40
     C                     Z-ADDA5KSMM    K@MMMM  20
     C                     Z-ADDA5KSDD    K@DDDD  20
     C           K#AGD     SETGTAGDPL12
     C                     READ AGDPL12                  94
     C           *IN94     IFEQ *OFF
     C                     Z-ADDF8KAYY    XXYY
     C                     Z-ADDF8KAMM    XXMM
     C                     Z-ADDF8KADD    XXDD
     C                     ENDIF
     C                     ELSE
     C                     Z-ADDA5KSYY    XXYY
     C                     Z-ADDA5KSMM    XXMM
     C                     Z-ADDA5KSDD    XXDD
     C                     ENDIF
     C*
     C           A5OPER    CHAINALDPP70              95
     C*          *IN95     IFEQ *OFF
     C*          A7SHFT    ANDEQ'3'
     C*          A5KSJI    ANDLT12
     C*                    Z-ADDA5KSYY    K@YYYY  40
     C*                    Z-ADDA5KSMM    K@MMMM  20
     C*                    Z-ADDA5KSDD    K@DDDD  20
     C*          K#AGD     SETLLAGDPL12
     C*                    READPAGDPL12                  94
     C*          *IN94     IFEQ *OFF
     C*                    Z-ADDF8KAYY    A5KSYY
     C*                    Z-ADDF8KAMM    A5KSMM
     C*                    Z-ADDF8KADD    A5KSDD
     C*                    ENDIF
     C*                    ENDIF
      *
     C*          A5KSMM    CABNEPMMMM     @SKP3
     C* FIRST RECORD
B02  C           *IN80     IFEQ '1'
     C                     SETOF                     80
     C                     MOVE A5OPER    D5OPER
     C                     MOVE A5OPER    K21
     C           K2        CHAINALBPL30              93
B03  C           *IN93     IFEQ '0'
     C                     MOVE ALWKNM    D5NAME
     C*
     C                     ELSE
     C                     MOVE *BLANK    D5NAME
E03  C                     END
     C*
     C*********            Z-ADDA5DATE    D5DATE
     C                     Z-ADDXXDATE    D5DATE
     C*                    Z-ADDA5KSYY    D5YYYY
     C*                    Z-ADDA5KSMM    D5MMMM
     C*                    Z-ADDA5KSDD    D5DDDD
     C                     ADD  1         D5BOX
     C*
     C                     ELSE
B03  C           A5OPER    IFNE D5OPER
     C*******    A5DATE    ORNE D5DATE
     C           XXDATE    ORNE D5DATE
     C*          A5KSYY    ORNE D5YYYY
     C*          A5KSMM    ORNE D5MMMM
     C*          A5KSDD    ORNE D5DDDD
     C                     WRITEALDWP051
     C                     CLEARALDWP051
     C*
     C                     MOVE A5OPER    D5OPER
     C                     MOVE A5OPER    K21
     C           K2        CHAINALBPL30              93
B04  C           *IN93     IFEQ '0'
     C                     MOVE ALWKNM    D5NAME
     C*
     C                     ELSE
     C                     MOVE *BLANK    D5NAME
E04  C                     END
     C*
     C***                  Z-ADDA5DATE    D5DATE
     C                     Z-ADDXXDATE    D5DATE
     C*                    Z-ADDA5KSYY    D5YYYY
     C*                    Z-ADDA5KSMM    D5MMMM
     C*                    Z-ADDA5KSDD    D5DDDD
     C                     ADD  1         D5BOX
     C*
     C                     ELSE
     C                     ADD  1         D5BOX
     C*
E03  C                     END
E02  C                     END
     C*
     C           @SKP3     TAG
     C*******    K1        READEALDPP401                 92
     C                     READ ALDPP401                 92
E01  C                     END
     C*
     C  N80                WRITEALDWP051
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @END
     C**************************************************************************
     C           @END      BEGSR
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C                     ENDSR
