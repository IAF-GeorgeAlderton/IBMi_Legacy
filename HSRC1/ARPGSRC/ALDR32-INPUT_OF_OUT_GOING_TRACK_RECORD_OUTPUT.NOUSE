      ************************************* ALDR32 ***
     FALDWP30 IP  F     200            DISK
     FALDPL30 IF  E           K        DISK
     FALDPP30 O   E                    DISK                      A
     FALDWP31 O   F     200            DISK
     IALDWP30 AA  01
     I                                        1 200 DATA
     I                                        1   1 KANS
     I                                        2   5 ZETI
     I                                        6   8 TEHI
     I                                        9  10 PAG
     I                                       11  11 SKAK
     I                                       12  12 TASY
     I                                       13  13 YUKO
     I                                       14  14 HASY
     I                                       15  15 CHEK
     I                                       16  17 FILL
     I                                       18  45 BARC
     I                                       46  530SYHZ
     I                                       46  490SYYY
     I                                       50  510SYMM
     I                                       52  530SYDD
     I                                       54  570SYTM
     I                                       54  550SYJI
     I                                       56  570SYFN
     I                                       58  63 OPER
