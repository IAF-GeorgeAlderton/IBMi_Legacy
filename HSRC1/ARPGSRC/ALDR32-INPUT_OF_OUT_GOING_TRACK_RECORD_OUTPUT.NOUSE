     I                                        3   40WFN
      *--------*
      *  KEYS  *
      *--------*
     C           *ENTRY    PLIST
     C                     PARM           PUS    10
     C                     PARM           PRTFLG  1
      *
     C           KEY1      KLIST
     C                     KFLD           ZETI
     C                     KFLD           TEHI
     C                     KFLD           PAG
     C                     KFLD           SKAK
     C                     KFLD           TASY
     C                     KFLD           YUKO
     C                     KFLD           HASY
     C                     KFLD           SYYY
     C                     KFLD           SYMM
     C                     KFLD           SYDD
     C                     KFLD           SYJI
     C                     KFLD           SYFN
      *--------------------*
      *  ALDR32 EXECUSION  *
     C*--------------------*
     C           *IN80     IFEQ '0'
     C                     SETON                     80
     C                     MOVE PUS       US     10
     C                     ENDIF
      *
     C                     MOVE *BLANK    EROR    1
     C                     SETOF                     50
     C           KEY1      CHAINALDPL301             50
     C           *IN50     IFEQ '0'
     C                     MOVE '*'       PRTFLG  1
     C                     MOVE '1'       EROR
     C                     EXSR LSTSUB
     C                     GOTO EXT
     C                     ENDIF
     C                     EXSR OUTSUB
     C           EXT       TAG
     CLR                   RETRN
      *----------*
      *  OUTSUB  *
      *----------*
     C           OUTSUB    BEGSR
     C                     Z-ADD*YEAR     A3KSYY
     C                     Z-ADD*MONTH    A3KSMM
     C                     Z-ADD*DAY      A3KSDD
     C                     TIME           WTIME
     C                     Z-ADDWJI       A3KSJI
     C                     Z-ADDWFN       A3KSPN
     C                     MOVE US        A3KSNA
     C                     MOVE KANS      A3KANS
     C                     MOVE ZETI      A3ZETI
     C                     MOVE TEHI      A3TEHI
     C                     MOVE PAG       A3PAGE
     C                     MOVE SKAK      A32KAK
     C                     MOVE TASY      A3TASY
     C                     MOVE YUKO      A3YUKO
     C                     MOVE HASY      A3HASY
     C                     MOVE SHN1      A3SHN1
     C                     MOVE SHN2      A3SHN2
     C                     MOVE SHN3      A3SHN3
     C                     Z-ADDSYYY      A3SYYY
     C                     Z-ADDSYMM      A3SYMM
     C                     Z-ADDSYDD      A3SYDD
     C                     Z-ADDSYJI      A3SYJI
     C                     Z-ADDSYFN      A3SYFN
     C                     MOVE TKR1      A3TKR1
     C                     MOVE TKR2      A3TKR2
     C                     MOVE TKR3      A3TKR3
     C                     MOVE TKR4      A3TKR4
     C                     MOVE OPER      A3OPER
     C                     MOVE MHN1      A3MHN1
     C                     MOVE MHN2      A3MHN2
     C                     MOVE MHN3      A3MHN3
     C                     MOVE MHN4      A3MHN4
     C                     Z-ADDSSYS      A3SSYS
     C                     Z-ADDUSYS      A3USYS
     C                     Z-ADDNONY      A3NONY
     C                     MOVE NKOJ      A3NKOJ
     C                     MOVE NUKE      A3NUKE
     C                     MOVE TOPX      A3TOPX
     C                     MOVE EFF       A3SALE
     C                     WRITEALDPP301
     C                     ENDSR
      *----------*
      *  LSTSUB  *
      *----------*
     C           LSTSUB    BEGSR
     C                     EXCPTDAT
     C                     ENDSR
