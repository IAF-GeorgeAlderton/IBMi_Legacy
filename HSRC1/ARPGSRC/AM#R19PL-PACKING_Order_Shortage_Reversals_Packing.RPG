     H            Y.
      ** AM#R19PL ******************************************
      *  PACKING - ORDER SHORTAGE REVERSALS - PACK LISTS   *
      *                                                    *
      * LEC   21/07/09 CREATE                              *
      ******************************************************
     FAM#WP19 IF  E           K        DISK
     FAB#PL75DIF  E           K        DISK
      *
     E                    SERL      100  9
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  14 SDATE
     I                                        1   6 STIME
      *
     I            DS
     I                                        1   8 SHID
     I                                        1   40NOYY
     I                                        5   60NOMM
     I                                        7   80NODD
      *
     C           PP75      KLIST
     C                     KFLD           W1NONY
     C                     KFLD           NUKE    4
     C                     KFLD           ODRN   10
     C                     KFLD           NOYY    40
     C                     KFLD           NOMM    20
     C                     KFLD           NODD    20
      *
     C                     DO   *HIVAL
      *
     C                     READ AM#WP19                  99
     C   99                LEAVE
      *
      * check packing list file to get serial#...
     C                     MOVELW1NUKE    NUKE      P
     C                     MOVELW1MAN#    ODRN      P
     C                     MOVELW1SHID    SHID
      *
     C           PP75      CHAINAB#PL75D             50
     C           *IN50     IFEQ *ON
     C                     MOVEL*BLANKS   PUSERL
     C                     ENDIF
      *
     C           PUSERL    IFNE *BLANKS
      *
     C           PUSERL    LOKUPSERL                     30
     C           *IN30     IFEQ *OFF
     C                     ADD  1         X       40
     C                     MOVELPUSERL    SERL,X
     C                     EXSR PCKLST
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
      *-----------------------------------------------------
      * CALL PROGRAM TO PRINT PACKING LIST
      *-----------------------------------------------------
     C           PCKLST    BEGSR
      *
     C                     CALL 'AB#C3Q19'
     C                     PARM           W1NONY
     C                     PARM           PUNKOJ
     C                     PARM           NUKE
     C                     PARM           W1SHID
     C                     PARM           PUBINN
     C                     PARM           ODRN
      *
     C                     ENDSR
      *
      *-----------------------------------------------------
