     H            Y.
     F** AAIR35 **************************************
     F* UPDATE PICKUP TIME CONTROL M/F               *
     F*        ITS.         2012.11.05               *
     F************************************************
     FAAIWP31 IF  E           K        DISK
     FAAIPL31 UF  E           K        DISK                      A
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   40WJFF
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 @@USER
     I                                      264 269 W$JBNO
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1KOSN  1
     C                     PARM           P1BMON  4
     C                     PARM           PCMD    2
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
     C                     TIME           WTIME
     C                     EXSR #SB599
      *
     C                     READ AAIWP311                 80
     C           *IN80     DOWEQ'0'
     C                     SELEC
     C           P1KOSN    WHEQ '0'
     C           P1KOSN    WHEQ '1'
     C                     EXSR #SB520
     C           P1KOSN    WHEQ '2'
     C                     EXSR #SB520
     C                     ENDSL
     C                     READ AAIWP311                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *----------------------------------------------------*
      * CHANGE,ADD
      *----------------------------------------------------*
     CSR         #SB520    BEGSR
      *
     C           KEYG21    KLIST
     C                     KFLD           #KBMON  40
     C                     KFLD           #KBIN   20
      *
     C                     MOVELP1BMON    #KBMON
     C                     MOVELW1BIN     #KBIN
     C           KEYG21    CHAINAAIPL311             20
     C                     CLEARAAIPL311
     C                     Z-ADD*DATE     G2KOHZ
     C                     TIME           G2KOTI
     C                     MOVEL@@USER    G2KOME
     C                     MOVELW$PGM     G2KOPG
     C                     MOVELW1BMON    G2BMON
     C                     Z-ADDW1BIN     G2BIN
     C                     Z-ADDW1TIME    G2TIME
     C                     Z-ADDW1ADJS    G2ADJS
     C           *IN20     IFEQ '0'
     C                     UPDATAAIPL311
     C                     ELSE
     C                     WRITEAAIPL311
     C                     ENDIF
      *
     CSR         ESB520    ENDSR
      *----------------------------------------------------*
      * DELETE ALL DATA
      *----------------------------------------------------*
     CSR         #SB599    BEGSR
      *
     C                     MOVELP1BMON    #KBMON
     C           #KBMON    SETLLAAIPL311
     C           #KBMON    READEAAIPL311                 20
     C           *IN20     DOWEQ'0'
     C                     MOVE 'D'       G2SKJY
     C                     Z-ADD*DATE     G2SKHZ
     C                     UPDATAAIPL311
     C           #KBMON    READEAAIPL311                 20
     C                     ENDDO
      *
     CSR         ESB599    ENDSR
