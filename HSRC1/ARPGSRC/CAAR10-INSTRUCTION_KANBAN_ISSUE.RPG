     I            DS
     I                                        1  140#DATE
     I                                        1   60STIME
     I                                        7  140SDATE
      *--------------------------------------------------
      *  ENTRY LIST
      *--------------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           PBMON   4
     C                     PARM           PBIN    2
      *--------------------------------------------------
      *  KEY LIST
      *--------------------------------------------------
     C           KEY1      KLIST
     C                     KFLD           IBMON
     C                     KFLD           IDATE
     C                     KFLD           IBIN
      *
     C           KEY2      KLIST
     C                     KFLD           K2DATE
     C                     KFLD           K2TIME
      *
      *--------------------------------------------------
      *  MAIN
      *--------------------------------------------------
     C                     TIME           #DATE
     C                     Z-ADD0         WBIN    20
     C                     Z-ADD0111      IBMON
     C                     Z-ADD0         IBIN
     C                     SETOF                     55
     C*------------------------------*
     C*  ..時刻別計算便マスター..  *
     C*------------------------------*
     C                     SETOF                     10
     C           IBMON     CHAINCAIPL111             10
     C           *IN10     IFEQ *OFF
     C                     Z-ADDC5TOHZ    IDATE
     C                     ENDIF
     C*------------------*
     C*  ..画面－１..  *
     C*------------------*
     C           STP1      TAG
     C                     EXFMTCAAPW101
     C                     SETOF                     010299
      * F1 END
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      * F3 BACK
     C           *IN55     IFEQ *ON
     C           *INKC     ANDEQ'1'
     C                     SETOF                     55
     C                     ENDIF
      * F9 RE-ISSUE
     C           *INKI     IFEQ '1'
     C                     SETON                     55
     C                     Z-ADDSDATE     IDATE
     C                     Z-ADD77        IBIN
     C                     GOTO STP1
     C                     ENDIF
      *
      * BIN 77  = RE-PRINT
      * BIN 88  = OFF-LINE
     C                     SETOF                     88
     C           IBIN      IFEQ 77
     C           IBIN      OREQ 88
     C                     SETON                     88
     C                     END
     C*------------------*
     C*  ISSUE DATE  ..  *
     C*------------------*
     C           IDATE     IFEQ 0
     C                     SETON                     0199
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     END
     C*------------*
     C*  ..便..  *
     C*------------*
     C           IBIN      IFEQ 0
     C                     SETON                     0299
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     END
     C*----------------*
     C*  ..最終便..  *
     C*----------------*
     C                     SETOF                     11
     C                     Z-ADD1         A       20
     C                     Z-ADD0         WBIN
      *
     C           1         DO   24        A
     C           C5BI,A    IFNE 0
     C                     Z-ADDC5BI,A    WBIN
     C                     ENDIF
      *
     C                     ENDDO
      *
      *  INPUT BIN > PREVIOUS BIN
     C           IBIN      IFGT WBIN
     C  N88                SETON                     0299
     C  N88                MOVE ER,5      MSG
     C  N88                GOTO STP1
     C                     END
      *
     C*------------------------------*
     C*  ..前回便の受信チェック..  *
     C*------------------------------*
     C           IBIN      IFGT 01
     C           IBIN      SUB  1         WSBIN   20
      *
     C                     SETOF                     10
     C                     Z-ADD1         B       20
     C           WSBIN     LOKUPC5BI,B                   10
      *
     C           C5DT,B    IFEQ '*'
     C           C5OK,B    ANDEQ*BLANK
     C                     SETON                     0299
     C                     MOVE ER,6      WMSG
     C                     MOVE WSBIN     WER
     C                     MOVE WMSG      MSG
     C                     GOTO STP1
     C                     ENDIF
     C                     ENDIF
      *
     C*------------------------------------------*
     C*  ..時刻別計算便マスター　便チェック..  *
     C*------------------------------------------*
     C                     SETOF                     10
     C                     Z-ADD1         A
     C           IBIN      LOKUPC5BI,A                   10
     C           *IN10     IFEQ '0'
     C  N88                SETON                     0299
     C  N88                MOVE ER,7      MSG
     C  N88                GOTO STP1
     C                     END
      *
     C*------------------------------------------*
     C*  ..準備されているか？　の　チェック..  *
     C*------------------------------------------*
     C           C5DT,A    IFEQ *BLANK
     C           C5OK,A    ANDEQ*BLANK
     C  N88                SETON                     0299
     C  N88                MOVE ER,8      MSG
     C  N88                GOTO STP1
     C                     END
      *
     C*----------------------------------*
     C*  ..準備中か？　の　チェック..  *
     C*----------------------------------*
     C           C5DT,A    IFEQ 'H'
     C           C5OK,A    ANDEQ*BLANK
     C                     SETON                     0299
     C                     MOVE ER,9      MSG
     C                     GOTO STP1
     C                     END
      *
     C*--------------------------------------------------*
     C* CHECK DESIGNATED DATA                            *
     C*--------------------------------------------------*
     C                     MOVEL*BLANK    DTCHK   1
      *
      * CHECK RE-PRINT DATA
     C           IBIN      IFEQ 77
     C*
     C                     Z-ADD0         K2DATE  80
     C                     Z-ADD0         K2TIME  60
     C           KEY2      SETLLCAAPP081
     C                     DO   *HIVAL
     C           KEY2      READECAAPP081                 15
     C   15                LEAVE
     C           C8SKJY    IFEQ *BLANK
     C                     MOVEL'*'       DTCHK
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
      * DAILY ISSUE
     C                     ELSE
     C           KEY1      SETLLCAAPP051
     C                     DO   *HIVAL
     C           KEY1      READECAAPP051                 15
     C   15                LEAVE
     C           C6SKJY    IFEQ 'D'
     C           C6SKDT    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C           C6DATH    IFNE *BLANK
     C                     ITER
     C                     ENDIF
     C                     MOVEL'*'       DTCHK
     C                     LEAVE
     C                     ENDDO
     C*
     C                     ENDIF
     C*
     C           DTCHK     IFEQ *BLANK
     C                     SETON                     010299
     C                     MOVE ER,12     MSG
     C                     GOTO STP1
     C                     ENDIF
     C*--------------------------------------------------*
     C*
     C           *INKE     IFEQ '0'
     C                     GOTO STP1
     C                     END
      *
     C                     MOVE IBMON     PBMON
     C                     Z-ADDIDATE     PDATE   80
     C                     MOVE IBIN      PBIN
      *
     C*------------------------------------*
     C*  ..指示かんばん発行データ作成..  *
     C*------------------------------------*
     C                     CALL 'CAAC17'
     C                     PARM           PBMON
     C                     PARM           PDATE
     C                     PARM           PBIN
      *
     C                     SETON                     U1LR
     C                     RETRN
** ER
