      ** MYBR13 ***************************
      * 仕掛けﾜｮn及び出現率mﾞｰj作成 *
      *  ﾃﾇnﾈ]jｰ機番別                  *
      *  EXCEL CSV形式                  *
      *    I-HASADA         2013/02/28    *
      *  I-HASADA 2013/04/04              *
      *   COPY RPG(IAFAYM):TG033R         *
      *************************** MYBR13 **
     FMYBNP1B IP  E           K        DISK
     FMYBWP11 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FMYBWP13 O   F     300            DISK
      *
     E                    TK1     1  10  1   TN1    20   かんばん種類名
      *
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
     I            DS
     I                                        1  14 WDHIN
     I                                        1   5 WDHN1
     I                                        6   6 WDH1
     I                                        7  11 WDHN2
     I                                       12  12 WDH2
     I                                       13  14 WDHN3
      *
     C           *ENTRY    PLIST
     C                     PARM           PBRYM   6
      *
     C                     MOVELPBRYM     IBRYM   60
      *
      *=========
      *  sｮjﾞｰ
     C           *IN11     IFEQ '0'
     C                     SETON                     11
     C                     EXCPTHD
     C                     END
      *
      *==========
      * 工場名
     C                     SETOF                     01
     C                     MOVE *BLANK    WKJNM  16
     C           W#KOJO    CHAINFGBPL01              01
     C           *IN01     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     01
     C                     END
     C           *IN01     IFEQ '0'
     C                     MOVELB2KEMI    WKJNM
     C                     END
      *
      *============
      * 代表品番
     C                     MOVE *BLANK    WDHIN
     C                     MOVELW#DHN1    WDHN1
     C                     MOVELW#DHN2    WDHN2
     C                     MOVELW#DHN3    WDHN3
     C           W#DHN2    IFNE *BLANK
     C                     MOVEL'-'       WDH1
     C                     END
     C           W#DHN3    IFNE *BLANK
     C                     MOVEL'-'       WDH2
     C                     END
      *
      *========================
      * 仕掛けﾜｮn:24箱以上
     C                     MOVE *BLANK    WSK24   1
     C           W#SKLT    IFGT 24
     C                     MOVEL'*'       WSK24
     C                     END
      *
      *====================
      * かんばん種類名称
     C                     SETOF                     01
     C                     Z-ADD1         A       20
     C                     MOVE *BLANK    WKDAI  20
     C           W#KDAI    LOKUPTK1,A                    01
     C           *IN01     IFEQ '1'
     C                     MOVELTN1,A     WKDAI
     C                     END
      *
      *******************
      *  ﾌﾟjｰ]ﾃｰnﾞ内容
     C                     Z-ADD0         WHIHS   40
     C                     MOVE *BLANK    WIFJ1   1
     C                     MOVE *BLANK    WIFJ2   1
     C                     Z-ADD0         WNATK   20
     C                     Z-ADD0         WNAKI   20
     C                     Z-ADD0         WHKSU   40
     C                     MOVE *BLANK    WKMKB   1
      *
      *===========================================
      * 仕掛けﾜｮn及び出現率ﾌﾟjｰ]表WORKmﾞｰj
     C           *LOVAL    SETLLMYBWP111
     C                     DO   *HIVAL
     C                     SETOF                     01
     C                     READ MYBWP111                 01
     C           *IN01     IFEQ '0'
     C           W#PTCD    IFEQ W$PTCD
     C                     SETON                     01
     C                     Z-ADDW$HIHS    WHIHS
     C                     MOVELW$IFJ1    WIFJ1
     C                     MOVELW$IFJ2    WIFJ2
     C                     Z-ADDW$NATK    WNATK
     C                     Z-ADDW$NAKI    WNAKI
     C                     Z-ADDW$HKSU    WHKSU
     C                     MOVELW$KMKB    WKMKB
     C                     END
     C                     END
     C  N01                END
      *
      *=================================================
      * 直に回：標識21=ON  ,加味する　：標識22=ON
      * 箱　　：標識21=OFF ,加味しない：標識22=OFF
     C                     SETOF                     2122
     C           WNATK     IFNE 0
     C                     SETON                     21
     C                     END
     C           WKMKB     IFEQ 'Y'
     C                     SETON                     22
     C                     END
      *
      *========
      *  mﾞｰj
     C           *IN21     IFEQ '1'
     C           *IN22     IFEQ '1'
     C                     EXCPTDT1
     C                     ELSE
     C                     EXCPTDT2
     C                     END
     C                     ELSE
      *
     C           *IN22     IFEQ '1'
     C                     EXCPTDT3
     C                     ELSE
     C                     EXCPTDT4
     C                     END
     C                     END
