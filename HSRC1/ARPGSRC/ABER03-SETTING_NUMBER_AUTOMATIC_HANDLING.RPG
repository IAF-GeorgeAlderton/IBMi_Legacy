     C           M1SKJY    IFEQ 'D'
     C           M1SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C*------------------------------------------*
     C*  ..構成品工程別　月間必要数ファイル..  *
     C*------------------------------------------*
     C                     Z-ADD0         WNGEK   90
     C           KEY1      SETLLAEBPL111
      *
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY1      READEAEBPL111                 10
     C           *IN10     IFEQ '0'
      *
     C                     ADD  AGNGEK    WNGEK
     C                     END
     C  N10                END
      *
     C           WNGEK     IFNE M1GEKN
      *
     C                     Z-ADDM1GEKN    YGEKN   90
     C                     Z-ADD*DATE     M1KOHZ
     C                     TIME           M1TIME
     C                     MOVEL'ZIDOU'   M1KOME
     C                     Z-ADDWNGEK     M1GEKN
     C                     UPDATAKCPP011
      *
     C*--------------------------------*
     C*  ..構成品番　工程マスター..  *
     C*--------------------------------*
     C           WNGEK     SUB  YGEKN     XGEKN   90
      *
     C           KEY1      SETLLAKDPL011
     C                     DO   *HIVAL
     C                     SETOF                     20
     C           KEY1      READEAKDPL011                 20
     C           *IN20     IFEQ '0'
      *
     C           KEY2      SETLLAKDPL021
     C                     DO   *HIVAL
     C                     SETOF                     21
     C           KEY2      READEAKDPL021                 21
     C           *IN21     IFEQ '0'
      *
     C           MNJHIN    IFEQ M1KHIN
     C                     Z-ADDWNGEK     MNSETI
     C                     END
     C                     ADD  XGEKN     MNSRYO
     C                     UPDATAKDPL021
      *
     C                     END
     C  N21                END
      *
     C                     END
     C  N20                END
      *
     C*------------------------------------------*
     C*  ..構成品かんばん　切り替えマスター..  *
     C*------------------------------------------*
     C                     SETOF                     22
     C           KEY1      CHAINAKEPL011             22
     C           *IN22     IFEQ '0'
     C           M3SKJY    ANDEQ'D'
     C           M3SKHZ    ANDLE*DATE
     C                     SETON                     22
     C                     END
     C           *IN22     IFEQ '0'
      *
     C                     Z-ADD0         SSU
     C                     Z-ADD1         A       20
     C           1         DO   15        A
     C           SDH,A     IFNE *BLANK
     C                     MOVE SDH,A     WSHIN
     C                     MOVE SKO,A     WKOTI   3
     C                     Z-ADDSBM,A     WKBMN   40
     C                     MOVE SBN,A     WTKRO
      *
     C                     SETOF                     22
     C           KEY3      CHAINAKDPL021             22
     C           *IN22     IFEQ '0'
     C                     Z-ADDMNSRYO    SSU,A
     C                     END
     C                     END
     C                     END
      *
     C                     Z-ADD*DATE     M3KOHZ
     C                     TIME           M3TIME
     C                     MOVEL'ZIDOU'   M3KOME
     C                     UPDATAKEPL011
     C                     END
      *
     C                     END
      *
     C*--------------------------------------*
     C*  ..構成品番計画通知書　マスター..  *
     C*--------------------------------------*
     C                     SETOF                     10
     C           KEY1      CHAINAKFPL011             10
     C           *IN10     IFEQ '0'
     C           M4SKJY    IFEQ 'D'
     C           M4SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C           M1GEKN    IFNE M4NGEK
      *
     C           M4IKOU    IFEQ '#'
     C                     MOVE *BLANK    M4TAHH
     C                     MOVE *BLANK    M4KATH
     C                     MOVE *BLANK    M4SYSH
     C                     MOVE *BLANK    M4SYHH
     C                     MOVE *BLANK    M4GEKH
     C                     MOVE *BLANK    M4KOTH
     C                     MOVE *BLANK    M4IKOU
     C                     Z-ADD1         M4KOSN
     C                     END
      *
     C           M4KOSN    IFNE 2
     C                     MOVE '*'       M4GEKH
     C                     Z-ADDM4NGEK    M4OGEK
     C                     END
      *
     C                     Z-ADDM1GEKN    M4NGEK
     C                     Z-ADD*DATE     M4KOHZ
     C                     TIME           M4TIME
     C                     MOVEL'ZIDOU'   M4KOME
     C                     UPDATAKFPL011
     C                     END
      *
     C                     END
     C                     END
     C                     END
