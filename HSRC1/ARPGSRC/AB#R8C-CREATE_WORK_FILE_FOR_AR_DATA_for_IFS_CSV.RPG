     H            Y.
     F** AB#R8C *******************************************
     F*  CREATE WORK FILE FOR AR DATA FOR IFS.CSV         *
     F*  J.WATANABE  2018.10.03                           *
     F* ------------------------------------------------- *
     F*  JW1     2026.02.25 ADD AB#WP8E                   *
     F*****************************************************
     FAB#WP8A IF  E           K        DISK
     FAB#WP8C O   E                    DISK
JW1  FAB#WP8E O   E                    DISK
      *
     E                    TTL     1   2 20
      *
     I            DS
     I                                        1  140@DATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1  20 W8MHIN
     I                                        1   5 W8MHN1
     I                                        6  10 W8MHN2
     I                                       11  15 W8MHN3
     I                                       16  20 W8MHN4
     I            DS
     I                                        1  12 W8SHIN
     I                                        1   5 W8SHN1
     I                                        6  10 W8SHN2
     I                                       11  12 W8SHN3
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-------------------------------------------------------
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ AB#WP8A                  98
     C   98                LEAVE
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     EXSR #HEAD
     C                     ENDIF
      *
     C                     CLEARAB#WP8C1
      *
     C                     MOVELW8TOKU    LTR20  20 P
     C                     EXSR #MOV1
     C                     MOVELLTR20     WCTOKU
      *
     C                     MOVELW8NONY    LTR20     P
     C                     EXSR #MOV1
     C                     MOVELLTR20     WCNONY
      *
     C                     MOVELW8NKOJ    LTR20     P
     C                     EXSR #MOV1
     C                     MOVELLTR20     WCNKOJ
      *
     C                     MOVELW8NUKE    LTR20     P
     C                     EXSR #MOV1
     C                     MOVELLTR20     WCNUKE
      *
     C                     MOVELW8ODRN    LTR20     P
     C                     EXSR #MOV1
     C                     MOVELLTR20     WCODRN
      *
     C                     MOVELW8SHN1    LTR20     P
     C                     EXSR #MOV1
     C                     MOVELLTR20     WCSHN1
      *
     C                     MOVELW8SHN2    LTR20     P
     C                     EXSR #MOV1
     C                     MOVELLTR20     WCSHN2
      *
     C                     MOVELW8SHN3    LTR20     P
     C                     EXSR #MOV1
     C                     MOVELLTR20     WCSHN3
      *
     C                     MOVELW8SHDT    LTR20     P
     C                     EXSR #MOV1
     C                     MOVELLTR20     WCSHDT
      *
     C                     MOVELW8NOBN    LTR20     P
     C                     EXSR #MOV1
     C                     MOVELLTR20     WCNOBN
      *
     C                     MOVELW8SERL    WCSERL    P
      *
     C                     WRITEAB#WP8C1
      * WRITE AB#WP8E
     C                     MOVELW8SHIN    $SHIN
     C                     CALL 'EDTR02'
     C                     PARM           $SHIN  12
     C                     PARM           $SHIN2 14
     C                     MOVEL$SHIN2    WCSHIN
     C                     MOVELW8MHIN    $MHIN
     C                     CALL 'EDTR02A'
     C                     PARM           $MHIN  20
     C                     PARM           $MHIN2 23
     C                     MOVEL$MHIN2    WCMHIN    P
JW1  C                     MOVELW8URHZ    WCURHZ
     C                     MOVELW8INVN    WCINVN    P
JW1  C                     WRITEAB#WP8E1
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *--------------------------------------------------------
      * CHECK 0 AND MOVE
      *--------------------------------------------------------
     C           #MOV1     BEGSR
      *
     C                     MOVELLTR20     LTR1    1
     C           LTR1      IFEQ '0'
     C                     MOVE LTR20     LTR21
     C                     MOVELLTR21     LTR20
     C                     ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------------
      * HEADER
      *--------------------------------------------------------
     C           #HEAD     BEGSR
      * HEADER 1
     C                     MOVEL'AB#R8C'  WCTOKU
     C                     MOVELTTL,1     WCNONY
      *
     C                     MOVEL'DATE:'   LTR14  14
     C                     MOVE TODAY     LTR14
     C                     MOVELLTR14     WCNKOJ
      *
     C                     MOVEL'TIME:'   LTR12  12
     C                     MOVE NOW       LTR12
     C                     MOVELLTR12     WCNUKE
      *
     C                     MOVEL'DLV#:'   LTR10  10
     C                     MOVE P#NONY    LTR10
     C                     MOVELLTR10     WCODRN
      *
     C                     MOVEL'FACT:'   LTR7    7
     C                     MOVE P#NKOJ    LTR7
     C                     MOVELLTR7      WCSHN1
      *
     C                     MOVEL'STAT:'   LTR8    8
     C                     MOVE P#STAT    LTR8
     C                     MOVELLTR8      WCSHN2
      *
     C                     MOVEL'FROM:'   LTR14
     C                     MOVE P#FROM    LTR14
     C                     MOVELLTR14     WCSHN3
      *
     C                     MOVEL'TO  :'   LTR14
     C                     MOVE P#TO      LTR14
     C                     MOVELLTR14     WCSHDT
      *
     C                     WRITEAB#WP8C1
      * HEADER 2
     C                     CLEARAB#WP8C1
     C                     MOVEL'CUST#'   WCTOKU
     C                     MOVEL'DELIV#'  WCNONY
     C                     MOVEL'FACTORY' WCNKOJ
     C                     MOVEL'DOCK'    WCNUKE
     C                     MOVEL'ORDER#'  WCODRN
     C                     MOVEL'PART1'   WCSHN1
     C                     MOVEL'PART2'   WCSHN2
     C                     MOVEL'PART3'   WCSHN3
     C                     MOVEL'SHP DATE'WCSHDT
     C                     MOVEL'BIN#'    WCNOBN
     C                     MOVEL'PCK_LST#'WCSERL
     C                     WRITEAB#WP8C1
      *
JW1  C                     MOVEL'IAF_PART'WCSHIN
     C                     MOVEL'CST_PART'WCMHIN
     C                     MOVEL'INVOICE#'WCINVN
     C                     MOVEL'BIL_DATE'WCURHZ
     C                     WRITEAB#WP8E1
      *
     C                     ENDSR
      *--------------------------------------------------------
      * INIT
      *--------------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P#NONY  4
     C                     PARM           P#NKOJ  1
     C                     PARM           P#STAT  2
     C                     PARM           P#FROM  8
     C                     PARM           P#TO    8
      *
     C                     TIME           @DATE
     C                     MOVE 'Y'       FIRST   1
     C                     MOVELTTL,2     LTR21  21
      *
     C                     ENDSR
** TTL ------------> (20)
 ** A/R DATA **
'
