      *------------*
      *データ検索*
      *------------*
      * 工程機番 *
      *------------*
     C           @LST      IFEQ 'A'
      *
     C           *LOVAL    SETLLCADPL02
     C                     DO   *HIVAL
     C                     SETOF                     15
     C                     READ CADPL02                  15
     C           *IN15     IFEQ '0'
     C           C2SKJY    IFEQ 'D'
     C           C2SKH8    ANDEQ*DATE
     C                     ELSE
     C           C2STH8    IFEQ 99999999
      *
     C                     Z-ADD1         A       20
     C                     SETOF                     25
     C           @KBN      LOKUPKB,A                     25
     C  N25                GOTO END1
      *
     C           BM,A      IFNE @KOJ
     C                     GOTO END1
     C                     END
      *
     C           @KOT      IFEQ *BLANK
     C                     SETOF                     89
     C           KT,A      LOKUP#KOT                     89
      *MSK 2006.12.19
     C           *IN89     IFEQ '0'
     C                     MOVELKT,A      KOTE    3
     C                     GOTO SKP1
     C                     ELSE
     C                     GOTO END1
     C                     END
     C                     ELSE
     C           KT,A      IFEQ @KOT
     C                     MOVEL@KOT      KOTE    3
     C                     GOTO SKP1
     C                     ELSE
     C                     GOTO END1
     C                     END
     C                     END
      *
     C           A         IFEQ 1
     C                     GOTO END1
     C                     END
      *
     C           SKP1      TAG
      *
     C                     SETOF                       44
     C           KEY4      CHAINAAMPL111             44
      *
     C           *IN44     IFEQ '0'
     C                     MOVEL$TK,A     TKR
     C                     END
      *
     C                     EXSR $KAD
     C                     Z-ADD0         KTSU    90
     C                     Z-ADDC2KTSU    KTSU
     C*          C2KTSU    DIV  @KAD      KTSU
     C                     Z-ADD0         JISEKI 100
     C                     Z-ADD0         JISSE  100
     C                     Z-ADD0         #LTIME  62
      *
     C           KEY1      SETLLGHCPL221
     C                     DO   *HIVAL
     C           KEY1      READEGHCPL22                  20
     C           *IN20     IFEQ '0'
     C                     SETOF                     25
     C                     Z-ADD$NEN      @JNEN
     C           KEY2      CHAINMBEPL051             25
     C           *IN25     IFEQ '0'
     C                     Z-ADD@TKI      W       20
     C                     ADD  SR,W      JISSE  100
     C                     END
     C                     END
     C  N20                ENDDO
      *
     C                     Z-ADD0         #T1    120
     C                     Z-ADD0         #T2    120
     C                     Z-ADD0         #T3     92
      *
     C                     EXSR $KAD
     C           JISSE     IFNE 0
     C           JISSE     DIV  @KAD      JISEKI    H
     C                     ENDIF
      *
     C                     Z-ADD0         LLT
     C           C2SYOS    MULT C2BARA    #T1
     C           JISEKI    IFNE 0
     C           #T1       DIV  JISEKI    #LTIME
     C                     END
%0001C*
     C                     SETOF                     50
     C           KEY4      CHAINABHTL021             50
     C           *IN50     IFEQ '0'
     C           M6SKJY    IFEQ 'D'
     C                     ELSE
     C                     Z-ADDM6SETO    SETO
     C                     END
     C                     END
%0001C*
     C                     EXSR IKO
     C                     EXCPTDT1
     C                     EXSR CLS
     C                     END
     C                     END
     C                     END
     C           END1      TAG
     C  N15                ENDDO
     C                     END
