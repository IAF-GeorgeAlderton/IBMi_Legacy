     C                     MOVEL*BLANK    @K8,IX           *箱種名称
     C                     MOVEL@D8,IY    @K8,IX           *箱種名称
     C                     END                             _｢IF_01
      *
     C                     Z-ADD@D9,IY    W@MDY2
     C                     EXSR #CMTY2                     *日付変換MDY->YMD
     C                     Z-ADDW@YYMD    @K9,IX           *工程納期YYYYMMDD
     C                     MOVEL@DA,IY    @KA,IX           *工程備考
     C                     END                             ｢DO_01
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #DSP20   テーブル　自動圧縮処理
      *-------------------------------------------------------------------------
     C           #DSP20    BEGSR
      *<自動圧縮用WKクリア>
     C                     CLEAR@W1                        *工程コード
     C                     CLEAR@W2                        *加工工場コード
     C                     CLEAR@W3                        *加工工場名称
     C                     CLEAR@W4                        *機番
     C                     CLEAR@W5                        *箱色コード
     C                     CLEAR@W6                        *箱種コード
     C                     CLEAR@W7                        *箱色名称
     C                     CLEAR@W8                        *箱種名称
     C                     CLEAR@W9                        *工程納期YYYYMMDD
     C                     CLEAR@WA                        *工程備考
     C                     CLEAR@WB                        *ゲート入YYYYMMDD
     C                     CLEAR@WC                        *ゲート入作業者
     C                     CLEAR@WD                        *ゲート出YYYYMMDD
     C                     CLEAR@WE                        *ゲート出作業者
      *
     C                     Z-ADD*ZERO     IX
     C                     Z-ADD*ZERO     IZ      20
      *
     C           IX        DOWLT15                         ¬DO_01
     C           IZ        ANDLT15
     C                     ADD  1         IX
      *入力あり
     C           @K1,IX    IFNE *BLANK                     ~¬IF_01
     C           @K2,IX    ORNE *ZERO
     C           @K4,IX    ORNE *BLANK
     C           @K5,IX    ORNE *BLANK
     C           @K6,IX    ORNE *BLANK
     C           @K7,IX    ORNE *BLANK
     C           @K8,IX    ORNE *BLANK
     C           @K9,IX    ORNE *ZERO
     C           @KA,IX    ORNE *BLANK
     C                     ADD  1         IZ
     C                     MOVEL@K1,IX    @W1,IZ           *工程コード
     C                     Z-ADD@K2,IX    @W2,IZ           *加工工場コード
     C                     MOVEL@K3,IX    @W3,IZ           *加工工場名称
     C                     MOVEL@K4,IX    @W4,IZ           *機番
     C                     MOVEL@K5,IX    @W5,IZ           *箱色コード
     C                     MOVEL@K6,IX    @W6,IZ           *箱種コード
     C                     MOVEL@K7,IX    @W7,IZ           *箱色名称
     C                     MOVEL@K8,IX    @W8,IZ           *箱種名称
     C                     MOVEL@K9,IX    @W9,IZ           *工程納期YYYYMMDD
     C                     MOVEL@KA,IX    @WA,IZ           *工程備考
     C                     Z-ADD@KB,IX    @WB,IZ           *ゲート入YYYYMMDD
     C                     MOVEL@KC,IX    @WC,IZ           *ゲート入作業者
     C                     Z-ADD@KD,IX    @WD,IZ           *ゲート出YYYYMMDD
     C                     MOVEL@KE,IX    @WE,IZ           *ゲート出作業者
     C                     END                             _｢IF_01
     C                     END                             ｢DO_01
      *再セット
     C                     CLEAR@K1                        *工程コード
     C                     CLEAR@K2                        *加工工場コード
     C                     CLEAR@K3                        *加工工場名称
     C                     CLEAR@K4                        *機番
     C                     CLEAR@K5                        *箱色コード
     C                     CLEAR@K6                        *箱種コード
     C                     CLEAR@K7                        *箱色名称
     C                     CLEAR@K8                        *箱種名称
     C                     CLEAR@K9                        *工程納期YYYYMMDD
     C                     CLEAR@KA                        *工程備考
     C                     CLEAR@KB                        *ゲート入YYYYMMDD
     C                     CLEAR@KC                        *ゲート入作業者
     C                     CLEAR@KD                        *ゲート出YYYYMMDD
     C                     CLEAR@KE                        *ゲート出作業者
      *
     C                     Z-ADD*ZERO     IX
      *
     C           IX        DOWLT15                         ¬DO_01
     C                     ADD  1         IX
     C                     MOVEL@W1,IX    @K1,IX           *工程コード
     C                     Z-ADD@W2,IX    @K2,IX           *加工工場コード
     C                     MOVEL@W3,IX    @K3,IX           *加工工場名称
     C                     MOVEL@W4,IX    @K4,IX           *機番
     C                     MOVEL@W5,IX    @K5,IX           *箱色コード
     C                     MOVEL@W6,IX    @K6,IX           *箱種コード
     C                     MOVEL@W7,IX    @K7,IX           *箱色名称
     C                     MOVEL@W8,IX    @K8,IX           *箱種名称
     C                     MOVEL@W9,IX    @K9,IX           *工程納期YYYYMMDD
     C                     MOVEL@WA,IX    @KA,IX           *工程備考
     C                     Z-ADD@WB,IX    @KB,IX           *ゲート入YYYYMMDD
     C                     MOVEL@WC,IX    @KC,IX           *ゲート入作業者
     C                     Z-ADD@WD,IX    @KD,IX           *ゲート出YYYYMMDD
     C                     MOVEL@WE,IX    @KE,IX           *ゲート出作業者
     C                     END                             ｢DO_01
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #PNL20   第二画面(G2) 表示処理
      *-------------------------------------------------------------------------
     C           #PNL20    BEGSR
      *
     C                     EXFMTMRHPW322
      *
     C                     SETOF                     333435
     C                     SETOF                     363738
     C                     SETOF                     394041
     C                     SETOF                     5532
     C                     SETOF                     515253*構成品ER-FLG
     C                     SETOF                     545657
     C                     SETOF                     5850
     C                     SETOF                     616263*工程ER-FLG
     C                     SETOF                     646566
     C                     SETOF                     676869
     C                     SETOF                     717273*工程ER-FLG
     C                     SETOF                     747576
     C                     SETOF                     777879
     C                     SETOF                     80
     C                     SETOF                     99
     C                     MOVEL*BLANK    D2EMSG           * ERR MSG
      *
      * NEXT-CONTROL
     C                     SELEC                           ¬SELEC_01
      * PAGE-UP(IN28)/DOWN(IN29)
     C           *IN28     WHEQ '1'                        +WHEN_01
     C           *IN29     OREQ '1'
      ** UP/DOWN無効
     C           *IN28     IFEQ '1'                        ~¬IF_01
     C           W@PAGE    ANDEQ1
