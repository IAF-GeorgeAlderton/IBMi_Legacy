     C           D2BNC2    ANDEQA2STRT
     C           D2BNC3    ANDEQA2STRR
     C           D2BNC4    ANDEQA2STRD
     C                     MOVEL'1'       W@DMYF           *ダミーフラグ
     C                     END                             ___｢IF_04
