     C                     MOVEL@BM,4     D2DVNM           *発行部署名
     C                     ENDSL                           ｢IF_01
     C           D2DVKB    IFEQ *BLANK                     ¬IF_01
     C  N99                MOVEL@MS,02    D2EMSG    P      * ERR MSG
     C  N99                SETON                     3299
     C                     ELSE                            +ELSE_01
     C           D2DVKB    IFNE '1'                        ~¬IF_02
     C           D2DVKB    ANDNE'2'
     C           D2DVKB    ANDNE'3'
     C           D2DVKB    ANDNE'4'
     C  N99                MOVEL@MS,03    D2EMSG    P      * ERR MSG
     C  N99                SETON                     3299
     C                     ENDIF                           _｢IF_02
     C                     ENDIF                           ｢IF_01
      *箱数=総生産数/収容数（切上）
     C                     Z-ADD*ZERO     W@SHKS  80       *箱数（総生産数）
     C                     Z-ADD*ZERO     W@MVR   80       *余り
     C           W@SSYS    IFNE *ZERO                      ¬IF_01
     C           D2SISU    DIV  W@SSYS    W@SHKS           *箱数（総生産数）
     C                     MVR            W@MVR            *余り
     C           W@MVR     IFNE *ZERO                      ~¬IF_02
     C                     ADD  1         W@SHKS           *箱数（総生産数）
     C                     END                             _｢IF_02
     C                     END                             ｢IF_01
      *<発行依頼者> *ノーチェック
