     C                     END                             ___｢IF_04
     C                     END                             __｢IF_03
     C                     END                             _｢IF_02
     C                     END                             ｢IF_01
      **社内品番
      *部品情報マスタ(MRHPL21)
     C                     MOVELD2SHN1    EASHN1           *社内品番１
     C                     MOVELD2SHN2    EASHN2           *社内品番２
     C                     MOVELD2SHN3    EASHN3           *社内品番３
     C                     MOVELW@SEHI    EASEHI           *製品区分
     C                     MOVELW@TEHI    EATEHI           *手配区分
     C           EAKEY     CHAINMRHPL211             92
     C           *IN92     IFEQ '1'                        ¬IF_01
     C  N99                MOVEL@MS,12    D2EMSG    P      * ERR MSG
     C  N99                SETON                     99
     C                     ELSE                            +ELSE_01
      *削除済み
     C           EAGSJY    IFEQ 'D'                        ~¬IF_02
     C           EAGSHZ    ANDLES@YYMD
     C  N99                MOVEL@MS,12    D2EMSG    P      * ERR MSG
     C  N99                SETON                     99
     C                     END                             _｢IF_02
     C                     END                             ｢IF_01
      *
      * NEXT-CONTROL
     C                     MOVEL'PNL20'   W@NEXT
     C           *IN99     IFEQ '0'                        ¬IF_01
     C           *IN05     ANDEQ'1'
     C                     MOVEL'DBOUT'   W@NEXT
     C                     END                             ｢IF_01
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #CHK21   表示工程情報　エラーフラグおよび画面表示切替
      *                             IN : W@PAGE 2S0 画面表示ページ
      *                                  W@IX   2S0 エラー工程
      *                                  W@IJ   2S0  ERR-FLG NO.
      *-------------------------------------------------------------------------
     C           #CHK21    BEGSR
      *
     C                     Z-ADDW@IJ      IJ      20       *フラグ№（横）
     C                     Z-ADD*ZERO     IK      20       *フラグ№（縦）
      *エラー工程01-10
     C           W@IX      IFGE 1                          ¬IF_01
     C           W@IX      ANDLE10
     C           W@PAGE    IFEQ 2                          ~¬IF_02
     C                     Z-ADD1         W@PAGE           *ページ番号
     C                     END                             _｢IF_02
     C           70        ADD  W@IX      IK               *フラグ№（縦）
     C                     END                             ｢IF_01
      *エラー工程11-15
     C           W@IX      IFGE 11                         ¬IF_01
     C           W@IX      ANDLE15
     C           W@PAGE    IFEQ 1                          ~¬IF_02
     C                     Z-ADD2         W@PAGE           *ページ番号
     C                     END                             _｢IF_02
     C           60        ADD  W@IX      IK               *フラグ№（縦）
     C                     END                             ｢IF_01
      *
      *配列⇒工程表示　セット処理
     C                     EXSR #SET21
      *
     C                     MOVEL'1'       *IN,IJ    P      *フラグ№（横）
     C                     MOVEL'1'       *IN,IK    P      *フラグ№（縦）
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #CHK22   構成品納期　チェック
      *                             IN : W@MDY2 6S0  MMDDYY
      *                             OUT: W@KSEF 1   構成品納期エラーフラグ
      *                                  W@YYMD 8S0  YYYYMMDD
      *-------------------------------------------------------------------------
     C           #CHK22    BEGSR
      *
     C                     MOVEL*BLANK    W@KSEF  1        *構成品納期ERR-FLG
      *
     C                     EXSR #CMTY2                     *日付変換MDY->YMD
      *カレンダーマスタ(AGDPL12)
     C                     Z-ADDW@YYY     F8KAYY           *年
     C                     Z-ADDW@YMM     F8KAMM           *月
     C                     Z-ADDW@YDD     F8KADD           *日
     C           F8KEY     CHAINAGDPL121             92
     C           *IN92     IFEQ '1'                        ¬IF_01
     C                     MOVEL'1'       W@KSEF  1        *構成品納期ERR-FLG
     C                     END                             ｢IF_01
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #DBOUT   Ｄ．Ｂ　アクセス処理
      *-------------------------------------------------------------------------
     C           #DBOUT    BEGSR
      *
     C                     TIME           S@TIME
      *
     C                     SETOF                     99
     C                     MOVEL*BLANK    D2EMSG           * ERR MSG
      *
     C                     Z-ADD*ZERO     W@GRHZ  80       *登録日
     C                     Z-ADD*ZERO     W@GRTM  60       *登録時間
      *
      *部品情報マスタ(MRHPL21)
     C                     MOVELD2SHN1    EASHN1           *社内品番１
     C                     MOVELD2SHN2    EASHN2           *社内品番２
     C                     MOVELD2SHN3    EASHN3           *社内品番３
     C                     MOVELW@SEHI    EASEHI           *製品区分
     C                     MOVELW@TEHI    EATEHI           *手配区分
     C           EAKEY     CHAINMRHPL211             92
     C           *IN92     IFEQ '0'                        ¬IF_01
     C           EAGSJY    IFEQ 'D'                        ~¬IF_02
     C           EAGSHZ    ANDLES@YYMD
      ** （処理無し）
     C                     ELSE                            -+ELSE_02
      *
      *<旧試作手配データ消去>
      *同時に他の端変更で変更した場合、
      *登録日・時間が変更されている可能性がおきるため、
      *最新の手配番号の登録日・時間と取り直す
      *
      *試作手配データファイル(MRHPL51)
     C                     MOVELW@THI1    STTHI1           *手配№　絶対番号
     C                     MOVELW@THI2    STTHI2           *手配№　連番
     C           STKEY1    SETGTMRHPL511
     C           STKEY1    REDPEMRHPL511            N    91
     C           *IN91     IFEQ '0'                        ~~¬IF_03
     C           STGSJY    IFEQ 'D'                        ~~~¬IF_04
     C           STGSHZ    ANDLES@YYMD
      **変更時、他端末で削除・再発行の場合、エラー
     C           *IN96     IFEQ '1'                        ~~~~¬IF_05
     C  N99                MOVEL@MS,15    D2EMSG    P      * ERR MSG
     C  N99                SETON                     99
     C                     END                             ____｢IF_05
     C                     ELSE                            ---+ELSE_04
     C           STGRHZ    IFNE W@TGHZ                     ~~~~¬IF_05
     C           STGRTM    ORNE W@TGTM
     C                     Z-ADDSTGRHZ    W@TGHZ           *手配番号登録日
     C                     Z-ADDSTGRTM    W@TGTM           *手配番号登録時間
     C                     END                             ____｢IF_05
      *
     C                     MOVELW@THI1    STTHI1           *手配№　絶対番号
     C                     MOVELW@THI2    STTHI2           *手配№　連番
     C                     Z-ADDW@TGHZ    STGRHZ           *登録作業　年月日
     C                     Z-ADDW@TGTM    STGRTM           *登録作業　時分秒
     C           STKEY2    SETLLMRHPL511
     C                     EXSR #RED11
      *
     C           *IN91     DOWEQ'0'                        ~~~~¬DO_01
     C                     EXSR #UPD10                     *削除更新UPDAT
      *
     C                     EXSR #RED11
     C                     END                             ____｢DO_01
     C                     END                             ___｢IF_04
     C                     END                             __｢IF_03
      *
      *<新試作手配データ出力>
      **変更のみ
     C           *IN99     IFEQ '0'                        ~~¬IF_03
     C           *IN96     IFEQ '1'                        ~~~¬IF_04
      **必須項目・納期が存在する工程を出力する
     C                     EXSR #MOV10                     *出力用共通SET
      *
     C                     Z-ADD1         J       20
     C                     Z-ADD*ZERO     @CHK    10
     C*          1         DO   15        J
     C           'LOQ '    LOKUP@K1,J                    88
     C           *IN88     IFEQ '1'                        ~~¬IF_03
     C                     Z-ADD2         @CHK             * LOQ FLG
     C                     END                             __｢IF_03
     C                     Z-ADD1         J       20
     C           'OQ  '    LOKUP@K1,J                    88
     C           *IN88     IFEQ '1'                        ~~¬IF_03
     C                     Z-ADD1         @CHK             * OQ FLG
     C                     END                             __｢IF_03
     C*                    ENDDO
      *
     C                     SELEC
     C           @CHK      WHEQ 1                          *工程
     C                     MOVE '1'       STBFLG
     C           @CHK      WHEQ 2                          *工程
     C                     MOVE '2'       STBFLG
     C                     OTHER
     C                     MOVE *BLANK    STBFLG
     C                     ENDSL
      *
     C                     Z-ADD*ZERO     IX               *自工程
     C           IX        DOWLT15                         ~~~~¬DO_01
     C                     ADD  1         IX               *自工程
     C           @K9,IX    IFEQ *ZERO                      ~~~~~¬IF_05
     C                     LEAVE
     C                     END                             _____｢IF_05
      *
     C                     EXSR #MOV11                     *出力用工程SET
     C                     WRITEMRHPL511
     C                     END                             ____｢DO_01
     C                     END                             ___｢IF_04
     C                     END                             __｢IF_03
      *
     C                     END                             _｢IF_02
     C                     END                             ｢IF_01
      *
     C           *IN99     IFEQ '0'                        ¬IF_01
     C           D1SELC    IFEQ '0'                        ¬IF_01
     C                     EXSR #UPD99
     C                     ENDIF                           ｢IF_01
     C                     ENDIF                           ｢IF_01
      * NEXT-CONTROL
     C                     MOVEL'SET10'   W@NEXT
      *エラー時
     C           *IN99     IFEQ '1'                        ¬IF_01
     C                     MOVEL'PNL20'   W@NEXT
     C                     END                             ｢IF_01
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #UPD10   スクラップ
      *-------------------------------------------------------------------------
     C           #UPD99    BEGSR
      *
     C           SBKEY     KLIST
     C                     KFLD           SBBAN1           *番地１
     C                     KFLD           SBBAN2           *番地２
     C                     KFLD           SBBAN3           *番地３
     C                     KFLD           SBBAN4           *番地４
     C                     MOVELD2BNC1    SBBAN1           *番地１
     C                     MOVELD2BNC2    SBBAN2           *番地２
     C                     MOVELD2BNC3    SBBAN3           *番地３
     C                     MOVELD2BNC4    SBBAN4           *番地４
     C           SBKEY     CHAINMRHPL111             92
     C           *IN92     IFEQ '0'
     C                     MOVEL*BLANK    SBGSJY           * DELETE CODE D
     C                     Z-ADD*ZERO     SBGSHZ           * DELETE DATE
     C                     MOVEL*BLANK    SBGSNM           * DELETE PERSON
     C                     Z-ADDS@YYMD    SBGKHZ           * UPDATE DATE
     C                     Z-ADDS@HMS     SBGKTM           * UPDATE TIME
     C                     MOVELS@PGID    SBGKPG           * UPDATE PROGRAM
     C                     MOVELS@USID    SBGKNM           * UPDATE PERSON
     C                     MOVEL*BLANK    SBHIN1           * PART NUMBER 1
     C                     MOVEL*BLANK    SBHIN2           * PART NUMBER 2
     C                     MOVEL*BLANK    SBHIN3           * PART NUMBER 3
     C                     MOVEL*BLANK    SBLNO1           * LOT NO 1
     C                     MOVEL*BLANK    SBLNO2           * LOT NO 2
     C                     Z-ADDS@YYMD    SBSCHZ           * SCRAP DATE
     C                     UPDATMRHPL111
     C                     ENDIF
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #UPD10   試作手配データ　削除更新　処理
      *-------------------------------------------------------------------------
     C           #UPD10    BEGSR
      *
     C                     MOVEL'D'       STGSJY           *削除コード
     C                     Z-ADDS@YYMD    STGSHZ           *削除予定　年月日
     C                     MOVELS@USID    STGSNM           *削除作業者
     C                     Z-ADDS@YYMD    STGKHZ           *更新作業　年月日
     C                     Z-ADDS@HMS     STGKTM           *更新作業　時分秒
     C                     MOVELS@PGID    STGKPG           *更新ﾎﾟﾜhﾞ[w
     C                     MOVELS@USID    STGKNM           *更新作業者
      *
     C                     Z-ADDSTGRHZ    W@GRHZ           *登録日
     C                     Z-ADDSTGRTM    W@GRTM           *登録時間
      *
     C                     UPDATMRHPL511
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #MOV10   試作手配データ　項目セット処理（共通セット・出力用）
      *-------------------------------------------------------------------------
     C           #MOV10    BEGSR
      *
     C                     CLEARMRHPL511
      *
