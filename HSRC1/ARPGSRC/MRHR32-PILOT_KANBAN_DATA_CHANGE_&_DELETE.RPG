      *
     C                     END                             ｢IF_01
      *
     C           W@DMYF    IFEQ *BLANK                     ¬IF_01
      *試作番地マスタ(MRHPL11)
     C                     MOVELD2BNC1    SBBAN1           *番地 1
     C                     MOVELD2BNC2    SBBAN2           *番地 2
     C                     MOVELD2BNC3    SBBAN3           *番地 3
     C                     MOVELD2BNC4    SBBAN4           *番地 4
     C           SAKEY1    CHAINMRHPL111             92
      ***読み取れない
     C           *IN92     IFEQ '1'                        ~¬IF_02
