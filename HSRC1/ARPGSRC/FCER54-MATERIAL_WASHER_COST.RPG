     H            Y.                                                      MER040
     F***********************************************
     F* MATERIAL/WASHER COST                                               *
     F*        DEC/02/2002                          *
     F*           EXCLUDE PT, PPT
     F***********************************************
     FFCEPW54 CF  E                    WORKSTN
     FAB#PL09 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FGBFPL51 IF  E           K        DISK
     FAAPTL01 IF  E           K        DISK
     FFCEPL40 IF  E           K        DISK
     FFCEWP54 UF  E           K        DISK                      A
      *
      *------------------------------------------------------------
     E                    CST        50  4 0
     E                    HIN        50 10
     E                    QTY        50 11 0
      *------------------------------------------------------------
     I            DS
     I                                        1  15 @@SHIN
     I                                        1   5 @SHN1
     I                                        6   6 @S1
     I                                        7  11 @SHN2
     I                                       12  12 @S2
     I                                       13  14 @SHN3
     I            DS
     I                                        1   60D@YYMM
     I                                        1   40D@YY
     I                                        5   60D@MM
     I            DS
     I                                        1  10 SHIN
     I                                        1   5 B1MHN1
     I                                        6  10 B1MHN2
     I            DS
     I                                        1  10 @HIN
     I                                        1   5 K@MHN1
     I                                        6  10 K@MHN2
     I            DS
     I                                        1  12 WHIN
     I                                        1   5 W@SHN1
     I                                        6  10 W@SHN2
     I                                       11  12 W@SHN3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#AGD     KLIST
     C                     KFLD           D@YY
     C                     KFLD           D@MM
     C           K#AB      KLIST
     C                     KFLD           K@PRT1  5
     C                     KFLD           K@PRT2  5
     C                     KFLD           K@PRT3  2
     C                     KFLD           D@YY    40
     C                     KFLD           D@MM    20
     C           K#ABX     KLIST
     C                     KFLD           K@PRT1  5
     C                     KFLD           K@PRT2  5
     C                     KFLD           K@PRT3  2
     C           K#GB      KLIST
     C                     KFLD           K@CUST  40
     C                     KFLD           K@KOJ   1
     C                     KFLD           K@MHN1  5
     C                     KFLD           K@MHN2  5
      *
     C                     MOVEL'01'      W@ID    2
     C                     MOVE '*'       K@KOJ
      *
     C                     Z-ADD*YEAR     D@YY
     C                     Z-ADD*MONTH    D@MM
      *
     C                     Z-ADDD@YYMM    WWYYMM  60
      *
     C                     SUB  1         D@MM
     C           D@MM      IFEQ *ZERO
     C                     ADD  12        D@MM
     C                     SUB  1         D@YY
     C                     ENDIF
      *
     C                     ENDSR
      *-------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      W@ID
     C                     OTHER
     C                     EXSR #CHK
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #WRT
     C                     MOVE '99'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *-------------------------------------------------------
     C           #CHK      BEGSR
      *
     C                     SETOF                     6199
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ELSE
     C           D@YYMM    IFGT WWYYMM
     C                     SETON                     6199
     C                     ENDIF
     C                     ENDIF
      *
     C           D@YYMM    MULT 100       W@YMD   80
     C                     ADD  1         W@YMD
     C           W@YMD     ADD  30        W@END   80
      *
     C                     ENDSR
      *-------------------------------------------------------
     C           #WRT      BEGSR
      *
      *
     C           *LOVAL    SETLLAB#PL09
     C           *IN80     DOUEQ*ON
     C                     READ AB#PL09                  80
     C           *IN80     IFEQ *OFF
     C           B1SKJY    ANDEQ*BLANK
     C                     MOVE B1SHN1    K@PRT1
     C                     MOVE B1SHN2    K@PRT2
     C                     MOVE B1SHN3    K@PRT3
     C                     Z-ADDB1TOKU    K@CUST
     C                     MOVE B1SHN1    @SHN1
     C                     MOVE B1SHN2    @SHN2
     C                     MOVE B1SHN3    @SHN3
     C                     Z-ADD*ZERO     CST
     C                     Z-ADD*ZERO     QTY
     C                     MOVE *BLANK    HIN
     C                     Z-ADD*ZERO     X       30
     C                     Z-ADD*ZERO     Y       30
     C                     Z-ADD*ZERO     @@SQTY 110
     C           K#ABX     SETLLAAPTL01
     C           *IN97     DOUEQ*ON
     C           K#ABX     READEAAPTL01                  97
     C           *IN97     IFEQ *OFF
     C           L5SKJY    ANDEQ*BLANK
     C           L5STYY    ANDEQ9999
     C           K#ABX     SETGTAB#PL09
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN97     IFEQ *OFF
     C                     ITER
     C                     ENDIF
      *
     C           K#ABX     SETLLFCEPL40
     C           *IN97     DOUEQ*ON
     C           K#ABX     READEFCEPL40                  97
     C           *IN97     IFEQ *OFF
     C           F4GSKD    ANDEQ*BLANK
     C           K#ABX     SETGTAB#PL09
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN97     IFEQ *OFF
     C                     ITER
     C                     ENDIF
      *
     C           K#AB      SETLLAB#PL09
     C           *IN85     DOUEQ*ON
     C           K#AB      READEAB#PL09                  85
     C           *IN85     IFEQ *OFF
     C           B1SKJY    ANDEQ*BLANK
     C                     ADD  B1SRYO    @@SQTY
     C           B1TOKU    LOKUPCST                      10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         X
     C                     Z-ADDB1TOKU    CST,X
     C                     ENDIF
      *
     C                     Z-ADD1         Z
     C           SHIN      LOKUPHIN,Z                    10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         Y
     C                     MOVE SHIN      HIN,Y
     C                     Z-ADDB1SRYO    QTY,Y
     C                     ELSE
     C                     ADD  B1SRYO    QTY,Z
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           @@SQTY    IFGT *ZERO
     C                     EXSR #WRT1
     C                     ENDIF
      *
     C           K#ABX     SETGTAB#PL09
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-------------------------------------------------------
     C           #WRT1     BEGSR
      *
     C                     Z-ADD0         @@COST 114
     C                     Z-ADD0         @@TNK1 114
     C                     Z-ADD0         @@TNK2 114
     C                     Z-ADD0         @@TNK3 114
     C                     Z-ADD0         @@TNK4 114
     C                     Z-ADD0         @@TNK5 114
      *
     C                     MOVE *OFF      *IN20
     C           1         DO   X         Z       30
     C                     Z-ADDCST,Z     K@CUST
     C           1         DO   Y         W       30
     C           HIN,W     IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
      *
     C                     MOVE HIN,W     @HIN
     C           K#GB      SETLLGBFPL51
     C           *IN85     DOUEQ*ON
     C           K#GB      READEGBFPL51                  85
     C           *IN85     IFEQ *OFF
     C           G9SKJY    ANDEQ*BLANK
     C           G9KAHZ    ANDLTW@YMD
     C           G9SUHZ    ANDGTW@END
     C                     MOVE *ON       *IN20
     C                     Z-ADDG9ZAIH    @@COST 114
     C                     Z-ADDG9TNK1    @@TNK1 114
     C                     Z-ADDG9TNK2    @@TNK2 114
     C                     Z-ADDG9TNK3    @@TNK3 114
     C                     Z-ADDG9TNK4    @@TNK4 114
     C                     Z-ADDG9TNK5    @@TNK5 114
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C   20                LEAVE
     C                     ENDDO
     C   20                LEAVE
      *
     C                     ENDDO
      *
     C           *IN20     IFEQ *OFF
     C                     Z-ADD3411      K@CUST
     C           K#GB      SETLLGBFPL51
     C           *IN85     DOUEQ*ON
     C           K#GB      READEGBFPL51                  85
     C           *IN85     IFEQ *OFF
     C           G9SKJY    ANDEQ*BLANK
     C           G9KAHZ    ANDLTW@YMD
     C           G9SUHZ    ANDGTW@END
     C                     Z-ADDG9ZAIH    @@COST 114
     C                     Z-ADDG9TNK1    @@TNK1 114
     C                     Z-ADDG9TNK2    @@TNK2 114
     C                     Z-ADDG9TNK3    @@TNK3 114
     C                     Z-ADDG9TNK4    @@TNK4 114
     C                     Z-ADDG9TNK5    @@TNK5 114
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C*          1         DO   Y         Z       30
     C*          HIN,Z     IFEQ *BLANK
     C*                    LEAVE
     C*                    ENDIF
      *
     C**                   MOVE HIN,Z     WHIN
     C                     MOVE *BLANK    @@SHIN
     C                     MOVE K@PRT1    @SHN1
     C                     MOVE K@PRT2    @SHN2
     C                     MOVE K@PRT3    @SHN3
     C           @SHN2     COMP *BLANK               1010
     C   10                MOVE '-'       @S1
     C           @SHN3     COMP *BLANK               1010
     C   10                MOVE '-'       @S2
     C           @@SHIN    CHAINFCEWP54              90
     C           *IN90     IFEQ *OFF
     C                     ADD  @@SQTY    FWSQTY
     C           @@COST    IFNE *ZERO
     C                     Z-ADD@@COST    FWMATC
     C                     ENDIF
     C           @@TNK1    IFNE *ZERO
     C                     Z-ADD@@TNK1    FWWSH1
     C                     ENDIF
     C           @@TNK2    IFNE *ZERO
     C                     Z-ADD@@TNK2    FWWSH2
     C                     ENDIF
     C           @@TNK3    IFNE *ZERO
     C                     Z-ADD@@TNK3    FWWSH3
     C                     ENDIF
     C           @@TNK4    IFNE *ZERO
     C                     Z-ADD@@TNK4    FWWSH4
     C                     ENDIF
     C           @@TNK5    IFNE *ZERO
     C                     Z-ADD@@TNK5    FWWSH5
     C                     ENDIF
     C           FWMATC    MULT FWSQTY    FWMATA
     C           FWWSH1    MULT FWSQTY    @@FWC1 114
     C           FWWSH2    MULT FWSQTY    @@FWC2 114
     C           FWWSH3    MULT FWSQTY    @@FWC3 114
     C           FWWSH4    MULT FWSQTY    @@FWC4 114
     C           FWWSH5    MULT FWSQTY    @@FWC5 114
     C           @@FWC1    ADD  @@FWC2    FWWSHA
     C                     ADD  @@FWC3    FWWSHA
     C                     ADD  @@FWC4    FWWSHA
     C                     ADD  @@FWC5    FWWSHA
     C           FWWSHA    ADD  FWMATA    FWAMNT
     C                     UPDATFCEWP541
     C                     ELSE
     C                     MOVEL@@SHIN    FWSHIN
     C                     Z-ADD@@COST    FWMATC
     C                     Z-ADD@@TNK1    FWWSH1
     C                     Z-ADD@@TNK2    FWWSH2
     C                     Z-ADD@@TNK3    FWWSH3
     C                     Z-ADD@@TNK4    FWWSH4
     C                     Z-ADD@@TNK5    FWWSH5
     C                     Z-ADD@@SQTY    FWSQTY
     C           FWMATC    MULT FWSQTY    FWMATA
     C           FWWSH1    MULT FWSQTY    @@FWC1 114
     C           FWWSH2    MULT FWSQTY    @@FWC2 114
     C           FWWSH3    MULT FWSQTY    @@FWC3 114
     C           FWWSH4    MULT FWSQTY    @@FWC4 114
     C           FWWSH5    MULT FWSQTY    @@FWC5 114
     C           @@FWC1    ADD  @@FWC2    FWWSHA
     C                     ADD  @@FWC3    FWWSHA
     C                     ADD  @@FWC4    FWWSHA
     C                     ADD  @@FWC5    FWWSHA
     C           FWWSHA    ADD  FWMATA    FWAMNT
     C                     WRITEFCEWP541
     C                     ENDIF
     C***********          ENDDO
      *
     C                     ENDSR
