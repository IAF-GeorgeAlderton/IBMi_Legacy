     H            Y.
      *  UTLR00F   ********************************************************
      *  UTILITY- Process List of Files in LIBRARY
      *----------------------------------------------------*
      *
      ******************************************************************
     F##FILLSTIF  E           K        DISK
      *
      *----------------------------------------------------
      * MAIN ROUTINE
      *----------------------------------------------------
     C                     DO   *HIVAL
      *
     C                     READ ##FILLST                 50
     C           *IN50     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
      * check that object attribute is Physical File
     C           ODOBAT    IFNE 'PF'
     C                     ITER
     C                     ENDIF
      *
      * check that object name starts with A - S...
     C           ODOBNM    IFGT 'S'
     C                     ITER
     C                     ENDIF
      *
      * file names longer than 7 chars are probably backups...
      * so the first blank char should be in position 8 if it's good.
     C           ' '       SCAN ODOBNM:1  POS
     C           POS       IFEQ 0
     C           POS       ORGE 9
     C                     ITER
     C                     ENDIF
      *
      * only files that have PP, EP, or NP are valid...
     C           'PP'      SCAN ODOBNM:1  POS     40
     C           POS       IFEQ *ZERO
      *
     C           'EP'      SCAN ODOBNM:1  POS
     C           POS       IFEQ *ZERO
      *
     C           'NP'      SCAN ODOBNM:1  POS
     C           POS       IFEQ *ZERO
     C                     ITER
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     CALL 'UTLC752'
     C                     PARM           ODOBNM
     C                     PARM           ODLBNM
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------
