     H            Y.                                    1
     H** ALDR6D ****************************************************************
     H*  SHIPPING SHORTAGE SCAN RESULT - MENU                                  *
     H*  JW       2020.03.18                                                   *
     H**************************************************************************
     FALDPW6D CF  E                    WORKSTN
     F*
     F**************************************************************************
     E                    ERR     1   5 60
      *
     I**************************************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60NOW
     I                                        7  140TODAY
     C**************************************************************************
     C*                    MAIN ROUTINE
     C**************************************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     EXFMTDSP01
     C                     MOVE *OFF      *IN41
     C                     MOVE *OFF      *IN85
     C                     MOVE *BLANK    XMSG
      *
     C                     SELEC
      * F3 END
     C           *INKC     WHEQ *ON
     C                     LEAVE
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN85     IFEQ *ON
     C                     ITER
     C                     ELSE
     C                     EXSR #PROC
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------
     C           #CHK1     BEGSR
      *----------------------------------------------
      * CHECK SHIFT
     C           XSLCT     IFNE '1'
     C           XSLCT     ANDNE'2'
     C           XSLCT     ANDNE'3'
     C           XSLCT     ANDNE'4'
     C                     SETON                     4185
     C                     MOVELERR,1     XMSG
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           XCHK1     ENDSR
      *----------------------------------------------
     C           #PROC     BEGSR
      *----------------------------------------------
      *
     C                     SELEC
     C           XSLCT     WHEQ '1'
     C                     CALL 'ALDC6F'
     C           XSLCT     WHEQ '2'
     C                     CALL 'ALDC6G'
     C           XSLCT     WHEQ '3'
     C**                   CALL 'ALDC6H'
     C                     MOVELERR,2     XMSG
     C           XSLCT     WHEQ '4'
     C**                   CALL 'ALDC6I'
     C                     MOVELERR,2     XMSG
     C                     ENDSL
      *
     C                     MOVE *BLANK    XSLCT
      *
     C                     ENDSR
     C**************************************************************************
     C* INITIAL SETTING
     C**************************************************************************
     C           #INIT     BEGSR
     C                     TIME           WSDT
     C                     ENDSR
