     C           SBGSJY    IFEQ 'D'                        ~~~~~~¬IF_07
     C           SBGSHZ    ANDLES@YYMD
      *
     C                     ELSE                            ------+ELSE_07
     C                     EXSR #UPD20                     *番地更新UPDAT
     C                     END                             ______｢IF_07
     C                     END                             _____｢IF_06
     C                     END                             ____｢IF_05
     C                     END                             ___｢IF_04
      *
     C                     END                             __｢IF_03
     C                     END                             _｢IF_02
     C                     END                             ｢IF_01
