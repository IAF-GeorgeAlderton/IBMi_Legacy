     C                     UPDATMRHPL111
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #MOV10   試作手配データ　項目セット処理（共通セット・出力用）
      *-------------------------------------------------------------------------
     C           #MOV10    BEGSR
      *
     C                     CLEARMRHPL511
      *
     C                     MOVEL*BLANK    STGSJY           *削除コード
     C                     Z-ADD*ZERO     STGSHZ           *削除予定　年月日
     C                     MOVEL*BLANK    STGSNM           *削除作業者
      *
     C                     Z-ADDS@YYMD    STGKHZ           *更新作業　年月日
     C                     Z-ADDS@HMS     STGKTM           *更新作業　時分秒
     C                     MOVELS@PGID    STGKPG           *更新ﾎﾟﾜhﾞ[w
     C                     MOVELS@USID    STGKNM           *更新作業者
      *
     C                     MOVELD4DVKB    STDVKB           *発行部署
     C                     MOVELD4DVNM    STDVNM           *発行部署名
     C                     MOVELD4DPNM    STDPNM           *発行依頼者
     C                     MOVELD4SHN1    STSHN1           *社内品番１
     C                     MOVELD4SHN2    STSHN2           *社内品番２
     C                     MOVELD4SHN3    STSHN3           *社内品番３
     C                     MOVELW@SEHI    STSEHI           *製品区分
     C                     MOVELW@TEHI    STTEHI           *手配区分
      *
     C                     MOVELEABDAI    STBDAI           *大分類
     C                     MOVELEABTIU    STBTIU           *中分類
     C                     MOVELEABHIN    STBHIN           *小分類
     C                     MOVELEASMEI    STSMEI           *品名
     C                     MOVELEATMEI    STTMEI           *中名称
     C                     MOVELEADMEI    STDMEI           *大名称
      *
     C                     Z-ADDD4TOKU    STTOKU           *ユーザーコード
     C                     MOVELD4TKNM    STTKNM           *ユーザー名称
     C                     MOVELD4MHN1    STMHN1           *ユーザー品番１
     C                     MOVELD4MHN2    STMHN2           *ユーザー品番２
     C                     MOVELD4MHN3    STMHN3           *ユーザー品番３
     C                     MOVELD4MHN4    STMHN4           *ユーザー品番４
     C                     MOVELD4BHN1    STBHN1           *ブランク品番１
     C                     MOVELD4BHN2    STBHN2           *ブランク品番２
     C                     MOVELD4BHN3    STBHN3           *ブランク品番３
      *
     C                     Z-ADDD4NOHZ    W@YYMD
     C*                    Z-ADDD4NOHZ    W@MMDY
     C*                    EXSR #CMTY                      *日付変換MDY->YMD
     C                     Z-ADDW@YYMD    STNOHZ           *納期　年月日
     C                     Z-ADDD4THSU    STTHSU           *手配数量
     C                     Z-ADDD4SISU    STSISU           *総生産数量
      *箱数=総生産数/収容数（切上）
     C                     Z-ADD*ZERO     W@SHKS           *箱数（総生産数）
     C                     Z-ADD*ZERO     W@MVR            *余り
     C           W@SSYS    IFNE *ZERO                      ¬IF_01
     C           D4SISU    DIV  W@SSYS    W@SHKS           *箱数（総生産数）
     C                     MVR            W@MVR            *余り
     C           W@MVR     IFNE *ZERO                      ~¬IF_02
     C                     ADD  1         W@SHKS           *箱数（総生産数）
     C                     END                             _｢IF_02
     C                     END                             ｢IF_01
     C                     MOVELW@SHKS    STHKSU           *箱数
      *重量（箱）＝K単重×収容数
     C           EAKASI    MULT EASSYS    STHKJU           *重量（箱）
     C           STHKJU    DIV  1000      STHKJU           *重量（箱）
      *
     C                     MOVELD4THMK    STTHMK           *手配目的
     C                     MOVELH4VIKO    STVIKO           *備考
      *
     C                     MOVELD4INSP    STINSP           *データ要否
     C                     MOVELD4HNL1    STHNL1           * HN LOC1
     C                     MOVELD4HNL2    STHNL2           * HN LOC2
     C                     MOVELD4HNL3    STHNL3           * HN LOC3
     C                     MOVELD4HNL4    STHNL4           * HN LOC4
      *
     C                     MOVELH4BRHZ    STBRHZ           *中断日
     C                     MOVELH4BRMK    STBRMK           *中断理由
     C                     MOVELH4NKHZ    STNKHZ           *入庫日
     C                     MOVELH4FFLG    STFFLG           *終了フラグ
     C                     MOVELH4PCHZ    STPCHZ           * PCCS戻り日
      *
     C                     MOVELH4BAN1    STBAN1           *番地1
     C                     MOVELH4BAN2    STBAN2           *番地2
     C                     MOVELH4BAN3    STBAN3           *番地3
     C                     MOVELH4BAN4    STBAN4           *番地4
      *
     C                     MOVELP3THI1    STTHI1           *手配№　絶対番号
     C                     MOVELP3THI2    STTHI2           *手配№　連番
      *
     C                     Z-ADDEAKUBI    STKUBI           *首下長さ
     C                     Z-ADDEASOZI    STSOZI           *Ｓ単重
     C                     MOVELEASOZT    STSOZT           *Ｓ単重　単位
     C                     Z-ADDEAKASI    STKASI           *Ｋ単重
     C                     MOVELEAKAST    STKASK           *Ｋ単重　単位
     C                     MOVELEAZANM    STZANM           *材質名
      *
     C                     MOVELEAZAIC    C1ZACD           *MATERIAL CODE
     C           C1KEY     CHAINCACPL011             92
     C           *IN92     IFEQ '0'                        ¬IF_01
     C           C1SKJY    IFEQ 'D'                        ~¬IF_02
     C           C1SKHZ    ANDLES@YYMD
      ** （処理無し）
