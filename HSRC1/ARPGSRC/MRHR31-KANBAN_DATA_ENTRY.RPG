     C                     ELSE
     C                     MOVEL'Z'       STZAIR           * ERR MSG
     C                     END                             ｢IF_01
      *
     C                     Z-ADDEAKAZI    STKAZI           *材径
      *
     C                     MOVELH4ZBN1    STZBN1           *材料番地１
     C                     MOVELH4ZBN2    STZBN2           *材料番地２
     C                     MOVELH4ZBN3    STZBN3           *材料番地３
     C                     MOVELH4ZBN4    STZBN4           *材料番地４
      *
     C                     MOVELEAMEK1    STMEK1           *表面処理コード１
     C                     MOVELEAMEK2    STMEK2           *表面処理コード２
     C                     MOVELEAMEK3    STMEK3           *表面処理コード３
     C                     MOVELEAMMEI    STMMEI           *表面処理名
     C                     Z-ADDEAMKSU    STMKSU           *メッキ係数
     C                     Z-ADDEABLSU    STBLSU           *バレル数
     C                     MOVELEASETR    STSETR           *二次処理名
     C                     MOVELEASECD    STSECD           *二次処理名称コード
     C                     Z-ADDEATUSZ    STTUSZ           *ネジサイズ
     C                     Z-ADDEAKIKI    STKIKI           *強度
     C                     Z-ADDEAOQTP    STOQTP           *焼入れ温度
     C                     Z-ADDEAKPTM    STKPTM           *焼入れ時間
     C                     Z-ADDEATMTP    STTMTP           *焼戻し温度
     C                     Z-ADDEACO2     STCO2            *二酸化炭素濃度
     C                     Z-ADDEAOQLT    STOQLT           * OQロット
     C                     Z-ADDEALATP    STLATP           * LAN/AOQ温度
     C                     Z-ADDEALATM    STLATM           * LAN/AOQ処理時間
     C                     Z-ADDEABSK1    STBSK1           *バスケット1
     C                     Z-ADDEABSK2    STBSK2           *バスケット2
     C                     Z-ADDEABSK3    STBSK3           *バスケット3
     C                     Z-ADDEABSK4    STBSK4           *バスケット4
     C                     Z-ADDEASSYS    STSSYS           *収容数
     C                     MOVELEASSYT    STSSYT           *箱種
      *
     C                     Z-ADDH4KTHZ    STKTHZ           *型納期　年月日
     C                     Z-ADDH4ZRHZ    STZRHZ           *材料納期　年月日
      *構成品納期は最大数を獲得
     C                     Z-ADDH4WHZ1    STWAHZ           *構成品納期　年月日
     C           H4WHZ2    IFGT STWAHZ                     ¬IF_01
     C                     Z-ADDH4WHZ2    STWAHZ           *構成品納期　年月日
     C                     END                             ｢IF_01
     C           H4WHZ3    IFGT STWAHZ                     ¬IF_01
     C                     Z-ADDH4WHZ3    STWAHZ           *構成品納期　年月日
     C                     END                             ｢IF_01
     C           H4WHZ4    IFGT STWAHZ                     ¬IF_01
     C                     Z-ADDH4WHZ4    STWAHZ           *構成品納期　年月日
     C                     END                             ｢IF_01
      *<構成品1>
     C                     MOVELD4KH11    STKH11           *構成品番1-1
     C                     MOVELD4KH12    STKH12           *構成品番1-2
     C                     MOVELD4KH13    STKH13           *構成品番1-3
     C                     MOVELD4KB11    STKB11           *構成品番地 1-1
     C                     MOVELD4KB12    STKB12           *構成品番地 1-2
     C                     MOVELD4KB13    STKB13           *構成品番地 1-3
     C                     MOVELD4KB14    STKB14           *構成品番地 1-4
     C                     Z-ADDEASKS1    STSKS1           *使用個数1
     C                     MOVELEAKOT1    STKOT1           *組付け工程1
     C                     Z-ADDEAKBM1    STKBM1           *持込先1
     C                     Z-ADDH4WHZ1    STWHZ1           *構成品納期　年月日
      *<構成品2>
     C                     MOVELD4KH21    STKH21           *構成品番2-1
     C                     MOVELD4KH22    STKH22           *構成品番2-2
     C                     MOVELD4KH23    STKH23           *構成品番2-3
     C                     MOVELD4KB21    STKB21           *構成品番地 2-1
     C                     MOVELD4KB22    STKB22           *構成品番地 2-2
     C                     MOVELD4KB23    STKB23           *構成品番地 2-3
     C                     MOVELD4KB24    STKB24           *構成品番地 2-4
     C                     Z-ADDEASKS2    STSKS2           *使用個数2
     C                     MOVELEAKOT2    STKOT2           *組付け工程2
     C                     Z-ADDEAKBM2    STKBM2           *持込先2
     C                     Z-ADDH4WHZ2    STWHZ2           *構成品納期　年月日
      *<構成品3>
     C                     MOVELD4KH31    STKH31           *構成品番3-1
     C                     MOVELD4KH32    STKH32           *構成品番3-2
     C                     MOVELD4KH33    STKH33           *構成品番3-3
     C                     MOVELD4KB31    STKB31           *構成品番地 3-1
     C                     MOVELD4KB32    STKB32           *構成品番地 3-2
     C                     MOVELD4KB33    STKB33           *構成品番地 3-3
     C                     MOVELD4KB34    STKB34           *構成品番地 3-4
     C                     Z-ADDEASKS3    STSKS3           *使用個数3
     C                     MOVELEAKOT3    STKOT3           *組付け工程3
     C                     Z-ADDEAKBM3    STKBM3           *持込先3
     C                     Z-ADDH4WHZ3    STWHZ3           *構成品納期　年月日
      *<構成品4>
     C                     MOVELD4KH41    STKH41           *構成品番4-1
     C                     MOVELD4KH42    STKH42           *構成品番4-2
     C                     MOVELD4KH43    STKH43           *構成品番4-3
     C                     MOVELD4KB41    STKB41           *構成品番地 4-1
     C                     MOVELD4KB42    STKB42           *構成品番地 4-2
     C                     MOVELD4KB43    STKB43           *構成品番地 4-3
     C                     MOVELD4KB44    STKB44           *構成品番地 4-4
