     C                     Z-ADD*ZERO     W@TGTM  60       *手配番号登録時間
      *<更新区分>
     C           D1SELC    IFNE 'A'                        ¬IF_01
     C           D1SELC    ANDNE'B'
     C  N99                MOVEL@MS,01    D1EMSG    P      * ERR MSG
     C  N99                SETON                     3199
      *
     C                     ELSE                            +ELSE_01
     C                     SELEC                           ~¬SELEC_01
     C           D1SELC    WHEQ 'A'                        -+WHEN_01
     C                     SETON                     96    * NEW ISSUE
     C           D1SELC    WHEQ 'B'                        -+WHEN_01
     C                     SETON                     97    * REPEAT ISSUE
     C                     END                             _｢SELEC_01
     C                     END                             ｢IF_01
      *
      * NEXT-CONTROL
     C                     MOVEL'PNL10'   W@NEXT
     C           *IN99     IFEQ '0'                        ¬IF_01
