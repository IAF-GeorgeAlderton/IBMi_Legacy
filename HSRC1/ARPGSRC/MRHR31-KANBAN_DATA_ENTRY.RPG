     C                     Z-ADD*ZERO     STCIHZ           *ゲート入　年月日
     C                     MOVEL*BLANK    STCINM           *ゲート入作業者
     C                     Z-ADD*ZERO     STCOHZ           *ゲート出　年月日
     C                     MOVEL*BLANK    STCONM           *ゲート出作業者
     C                     Z-ADD*ZERO     STHKHZ           *かんばん発行日
     C                     Z-ADD*ZERO     STHKTM           *かんばん発行時間
     C                     Z-ADDP3LPHZ    STLPHZ           *前回手配発行日
      *
     C                     MOVELS@YYMD    STGRHZ           *登録作業　年月日
     C                     MOVELS@HMS     STGRTM           *登録作業　時分秒
     C                     MOVELS@PGID    STGRPG           *登録ﾎﾟﾜhﾞ[w
     C                     MOVELS@USID    STGRNM           *登録作業者
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #MOV11   試作手配データ　項目セット処理（工程情報・出力用）
      *-------------------------------------------------------------------------
     C           #MOV11    BEGSR
      *
     C                     Z-ADDIX        STKTNO           *工程№
     C                     MOVEL@K1,IX    STKTEI           *工程
     C                     Z-ADD@K2,IX    STKBMN           *加工工場
     C                     MOVEL@K3,IX    STKBNM           *加工工場名
     C                     MOVEL@K4,IX    STMSNO           *機番
     C                     MOVEL@K5,IX    STBCCD           *箱色コード
     C                     MOVEL@K7,IX    STBCNM           *箱色名
     C                     MOVEL@K6,IX    STBTCD           *箱種
     C                     MOVEL@K8,IX    STBTNM           *箱種　名称
     C                     Z-ADD@K9,IX    STKNHZ           *加工納期　年月日
     C                     MOVEL@KA,IX    STKVIK           *工程ごとの備考
      **再発行は仕切りなおしのため、
      **ゲート情報はセットしない(2014/2/12)
      *ゲート情報
     C****       *IN97     IFEQ '1'
     C****                 Z-ADD@KB,IX    STCIHZ           *ゲート入　年月日
     C****                 MOVEL@KC,IX    STCINM           *ゲート入作業者
     C****                 Z-ADD@KD,IX    STCOHZ           *ゲート出　年月日
     C****                 MOVEL@KE,IX    STCONM           *ゲート出作業者
     C****                 END
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #CYTM    日付変換FROM YYYYMMDD TO MMDDYYYY
      *                             IN : W@YYMD 8S0  YYYYMMDD
      *                             OUT: W@MMDY 8S0  MMDDYYYY
      *                                  W@MDY2 6S0  MMDDYY
      *-------------------------------------------------------------------------
     C           #CYTM     BEGSR
      *
     C                     Z-ADD*ZERO     W@MMDY           * TO日付MMDDYYYY
     C                     Z-ADDW@YYY     W@MYY            * TO日付YYYY
     C                     Z-ADDW@YMM     W@MMM            * TO日付MM
     C                     Z-ADDW@YDD     W@MDD            * TO日付DD
      *
     C                     Z-ADD*ZERO     W@MDY2           * TO日付MMDDYY
     C                     Z-ADDW@YYY     W@MYY2           * TO日付YY
     C                     Z-ADDW@YMM     W@MMM2           * TO日付MM
     C                     Z-ADDW@YDD     W@MDD2           * TO日付DD
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #CMTY    日付変換FROM MMDDYYYY TO YYYYMMDD
      *                             IN : W@MMDY 8S0  MMDDYYYY
      *                             OUT: W@YYMD 8S0  YYYYMMDD
      *-------------------------------------------------------------------------
     C           #CMTY     BEGSR
      *
     C                     Z-ADD*ZERO     W@YYMD           * TO日付YYYYMMDD
     C                     Z-ADDW@MYY     W@YYY            * TO日付YYYY
     C                     Z-ADDW@MMM     W@YMM            * TO日付MM
     C                     Z-ADDW@MDD     W@YDD            * TO日付DD
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #CMTY2   日付変換FROM MMDDYY TO YYYYMMDD
      *                             IN : W@MDY2 6S0  MMDDYY
      *                             OUT: W@YYMD 8S0  YYYYMMDD
      *-------------------------------------------------------------------------
     C           #CMTY2    BEGSR
      *
     C                     Z-ADD*ZERO     W@YYMD           * TO日付YYYYMMDD
      *
     C*                    Z-ADD*ZERO     W@YMD2           * TO日付YYYYMMDD
     C*                    Z-ADDW@MYY2    W@YYY2           * WK日付YY
     C*                    Z-ADDW@MMM2    W@YMM2           * WK日付MM
     C*                    Z-ADDW@MDD2    W@YDD2           * WK日付DD
      *
     C* <<日付変換　6桁⇒8桁(DATR00) >>
     C           W@YMD2    IFNE *ZERO                      ¬IF_01
     C                     MOVE W@YMD2    P1ZYMD           *日付6桁YYMMDD
     C                     MOVE *ZERO     P1KYMD           *日付8桁YYYYMMD
     C                     CALL 'DATR00'  P1DA00
      *
     C                     MOVE P1KYMD    W@YYMD           * TO日付YYYYMMDD
     C                     END                             ｢IF_01
      *
     C                     ENDSR
      *----------------------------------------------------------------
