     C                     ITER
     C                     END                             __｢IF_02
     C                     END                             _｢IF_01
      *
     C                     LEAVE
     C                     ENDDO                           ｢DO_01
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #RED21   試作番地マスタ　読込（番地順　自動空き番地取得）
      *-------------------------------------------------------------------------
     C           #RED21    BEGSR
      *
     C                     DO   *HIVAL                     ¬DO_01
     C                     READ MRHPL111            N  9892
     C   92                LEAVE
     C   98                ITER
      *
      *<対象範囲データ抽出>
      *削除データ
     C           SBGSJY    IFEQ 'D'                        ~¬IF_01
     C           SBGSHZ    ANDLES@YYMD
     C                     ITER
     C                     END                             _｢IF_01
      *品番登録済み
     C           SBHIN1    IFNE *BLANK                     ~¬IF_01
     C           SBHIN2    ORNE *BLANK
     C           SBHIN3    ORNE *BLANK
     C                     ITER
     C                     END                             _｢IF_01
      *収容箱数＜箱数（総生産数）
     C           SBHAKO    IFLT W@SHKS                     ~¬IF_01
     C                     ITER
     C                     END                             _｢IF_01
      *スクラップ後一ヶ月自動引当不可
     C           SBSCHZ    IFNE *ZERO                      ~¬IF_01
     C                     Z-ADDSBSCHZ    W@CYMD           *スクラップ日付
     C                     ADD  1         W@CMM            *スクラップ月
     C           W@SMM     IFGE 13                         ~~¬IF_02
     C                     ADD  1         W@CYY            *スクラップ年
     C                     Z-ADD1         W@CMM            *スクラップ月
     C                     END                             __｢IF_02
     C           W@CYMD    IFGT S@YYMD                     ~~¬IF_02
     C                     ITER
     C                     END                             __｢IF_02
     C                     END                             _｢IF_01
      *
     C                     LEAVE
     C                     ENDDO                           ｢DO_01
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #DBOUT   Ｄ．Ｂ　アクセス処理
      *-------------------------------------------------------------------------
     C           #DBOUT    BEGSR
      *
     C                     TIME           S@TIME
      *
     C                     SETOF                     99
     C                     MOVEL*BLANK    D4EMSG           * ERR MSG
      *
      *<手配番号採番>
     C                     MOVELD4SHN1    P3SHN1           *社内品番1
     C                     MOVELD4SHN2    P3SHN2           *社内品番2
     C                     MOVELD4SHN3    P3SHN3           *社内品番3
     C                     CALL 'MRHR38'  P3MR38
      **採番できず
     C           P3RTCD    IFNE *BLANK                     ¬IF_01
     C  N99                MOVEL@MS,17    D4EMSG    P      * ERR MSG
     C  N99                SETON                     99
     C           *IN97     IFEQ '1'                        ~¬IF_02
     C                     MOVEL*BLANK    D4THI1           *手配番号1
     C                     MOVEL*BLANK    D4THI2           *手配番号2
     C                     END                             _｢IF_02
     C                     ELSE                            +ELSE_01
      *部品情報マスタ(MRHPL21)
      *手配番号獲得の際には読取エラーは起こらない
     C                     MOVELD4SHN1    EASHN1           *社内品番１
     C                     MOVELD4SHN2    EASHN2           *社内品番２
     C                     MOVELD4SHN3    EASHN3           *社内品番３
     C                     MOVELW@SEHI    EASEHI           *製品区分
     C                     MOVELW@TEHI    EATEHI           *手配区分
     C           EAKEY     CHAINMRHPL211             92
     C           *IN92     IFEQ '0'                        ~¬IF_02
     C           EAGSJY    IFEQ 'D'                        ~~¬IF_03
     C           EAGSHZ    ANDLES@YYMD
      ** （処理無し）
     C                     ELSE                            --+ELSE_03
      *
      *<旧試作手配データ消去>
      *再発行時（同時に他の端変更で変更した場合、
      *          登録日・時間が変更されている可能性がおきるため、
      *          最新の手配番号の登録日・時間と取り直す）
      *
     C*          *IN97     IFEQ '1'                        ~~~¬IF_04
      *試作手配データファイル(MRHPL51)
     C*                    MOVELW@THI1    STTHI1           *手配№　絶対番号
     C*                    MOVELW@THI2    STTHI2           *手配№　連番
     C*          STKEY1    SETGTMRHPL511
     C*          STKEY1    REDPEMRHPL511            N    91
     C*          *IN91     IFEQ '0'                        ~~~~¬IF_05
     C*          STGSJY    IFEQ 'D'                        ~~~~~¬IF_06
     C*          STGSHZ    ANDLES@YYMD
      **他端末で削除・再発行の場合、エラー
     C* N99                MOVEL@MS,23    D4EMSG    P      * ERR MSG
     C* N99                SETON                     99
     C*                    ELSE                            -----+ELSE_06
     C*          STGRHZ    IFNE W@TGHZ                     ~~~~~~¬IF_07
     C*          STGRTM    ORNE W@TGTM
     C*                    Z-ADDSTGRHZ    W@TGHZ           *手配番号登録日
     C*                    Z-ADDSTGRTM    W@TGTM           *手配番号登録時間
     C*                    END                             ______｢IF_07
      *
     C*                    MOVELW@THI1    STTHI1           *手配№　絶対番号
     C*                    MOVELW@THI2    STTHI2           *手配№　連番
     C*                    Z-ADDW@TGHZ    STGRHZ           *登録作業　年月日
     C*                    Z-ADDW@TGTM    STGRTM           *登録作業　時分秒
     C*          STKEY2    SETLLMRHPL511
     C*                    EXSR #RED11
      *
     C*          *IN91     DOWEQ'0'                        ~~~~~~¬DO_01
     C*                    EXSR #UPD10                     *削除更新UPDAT
      *
     C*                    EXSR #RED11
     C*                    END                             ______｢DO_01
     C*                    END                             _____｢IF_06
     C*                    END                             ____｢IF_05
     C*                    END                             ___｢IF_04
      *
      *<新試作手配データ出力>
     C           *IN99     IFEQ '0'                        ~~~¬IF_04
      **必須項目・納期が存在する工程を出力する
     C                     EXSR #MOV10                     *出力用共通SET
      *
     C                     Z-ADD1         J       20
     C                     Z-ADD*ZERO     @CHK    10
     C*          1         DO   15        J
     C           'LOQ '    LOKUP@K1,J                    88
     C           *IN88     IFEQ '1'                        ~~¬IF_03
     C                     Z-ADD2         @CHK             * LOQ FLG
     C                     END                             __｢IF_03
     C                     Z-ADD1         J       20
     C           'OQ  '    LOKUP@K1,J                    88
     C           *IN88     IFEQ '1'                        ~~¬IF_03
     C                     Z-ADD1         @CHK             * OQ FLG
     C                     END                             __｢IF_03
     C*                    ENDDO
      *
     C                     SELEC
     C           @CHK      WHEQ 1                          *工程
     C                     MOVE '1'       STBFLG
     C           @CHK      WHEQ 2                          *工程
     C                     MOVE '2'       STBFLG
     C                     OTHER
     C                     MOVE *BLANK    STBFLG
     C                     ENDSL
      *
     C                     Z-ADD*ZERO     IX               *自工程
     C           IX        DOWLT15                         ~~~~¬DO_01
     C                     ADD  1         IX               *自工程
     C           @K9,IX    IFEQ *ZERO                      ~~~~~¬IF_05
     C                     LEAVE
     C                     END                             _____｢IF_05
      *
     C                     EXSR #MOV11                     *出力用工程SET
     C                     WRITEMRHPL511
     C                     END                             ____｢DO_01
      *
      *<試作番地マスタ更新>
      **ユーザー入力がブランク以外の場合
      *** PC/QDでダミー番地の場合、更新しない
     C                     MOVEL*BLANK    W@DMYF           *ダミーフラグ
     C           D4DVKB    IFEQ '2'                        ~~~~¬IF_05
     C           D4BAN1    IFEQ *BLANK                     ~~~~~¬IF_06
     C           D4BAN2    ANDEQ@BN,1
     C           D4BAN3    ANDEQ*BLANK
     C           D4BAN4    ANDEQ*BLANK
     C                     MOVEL'1'       W@DMYF           *ダミーフラグ
     C                     END                             _____｢IF_06
     C                     END                             ____｢IF_05
     C           D4DVKB    IFEQ '3'                        ~~~~¬IF_05
     C           D4BAN1    IFEQ *BLANK                     ~~~~~¬IF_06
     C           D4BAN2    ANDEQ@BN,2
     C           D4BAN3    ANDEQ*BLANK
     C           D4BAN4    ANDEQ*BLANK
     C                     MOVEL'1'       W@DMYF           *ダミーフラグ
     C                     END                             _____｢IF_06
     C                     END                             ____｢IF_05
      *
     C           W@DMYF    IFEQ *BLANK                     ~~~~¬IF_05
      *試作番地マスタ(MRHPL11)
     C                     MOVELH4BAN1    SBBAN1           *番地 1
     C                     MOVELH4BAN2    SBBAN2           *番地 2
     C                     MOVELH4BAN3    SBBAN3           *番地 3
     C                     MOVELH4BAN4    SBBAN4           *番地 4
