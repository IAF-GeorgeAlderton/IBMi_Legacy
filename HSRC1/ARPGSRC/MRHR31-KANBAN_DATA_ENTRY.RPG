     C                     MOVEL@K8,IX    @D8,IY           *箱種名称
     C                     Z-ADD@K9,IX    W@YYMD
     C                     EXSR #CYTM                      *日付変換YMD->MDY
     C                     Z-ADDW@YYMD    @D9,IY           *工程納期MMDDYY
     C*                    Z-ADDW@MDY2    @D9,IY           *工程納期MMDDYY
     C                     MOVEL@KA,IX    @DA,IY           *工程備考
     C                     MOVEL'1'       *IN,ID    P      *工程表示フラグ
     C                     END                             ｢DO_01
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #SET42   第四画面(G4) 工程表示⇒配列　戻し処理
      *-------------------------------------------------------------------------
     C           #SET42    BEGSR
      *
     C                     Z-ADD*ZERO     IY      20       *表示行数
     C                     MOVEL*BLANK    W@HCNM  6        *箱色名CHK用
     C                     MOVEL*BLANK    W@HTNM  5        *箱種名CHK用
      *
     C                     SELEC                           ¬SELEC_01
     C           W@PAGE    WHEQ 1                          +WHEN_01
     C                     Z-ADD*ZERO     IX               *自工程
     C           W@PAGE    WHEQ 2                          +WHEN_01
     C                     Z-ADD10        IX               *自工程
     C                     END                             ｢SELEC_01
      *
     C           IY        DOWLT10                         ¬DO_01
     C           IX        ANDLT15
     C                     ADD  1         IX               *自工程
     C                     ADD  1         IY               *表示行数
      *
     C                     MOVEL@D1,IY    @K1,IX           *工程コード
     C                     Z-ADD@D2,IY    @K2,IX           *加工工場コード
     C                     MOVEL@D3,IY    @K3,IX           *加工工場名称
     C                     MOVEL@D4,IY    @K4,IX           *機番
     C                     MOVEL@D5,IY    @K5,IX           *箱色コード
     C                     MOVEL@D6,IY    @K6,IX           *箱種コード
      *
     C                     MOVEL@K7,IX    W@HCNM           *箱色名CHK用
     C           @D7,IY    IFNE W@HCNM                     ~¬IF_01
     C                     MOVEL*BLANK    @K7,IX           *箱色名称
     C                     MOVEL@D7,IY    @K7,IX           *箱色名称
     C                     END                             _｢IF_01
      *
     C                     MOVEL@K8,IX    W@HTNM           *箱種名CHK用
     C           @D8,IY    IFNE W@HTNM                     ~¬IF_01
     C                     MOVEL*BLANK    @K8,IX           *箱種名称
     C                     MOVEL@D8,IY    @K8,IX           *箱種名称
     C                     END                             _｢IF_01
      *
     C                     Z-ADD@D9,IY    W@YMD2
     C                     EXSR #CMTY2                     *日付変換MDY->YMD
     C                     Z-ADDW@YYMD    @K9,IX           *工程納期YYYYMMDD
     C                     MOVEL@DA,IY    @KA,IX           *工程備考
     C                     END                             ｢DO_01
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #DSP40   テーブル　自動圧縮処理
      *-------------------------------------------------------------------------
     C           #DSP40    BEGSR
      *<自動圧縮用WKクリア>
     C                     CLEAR@W1                        *工程コード
     C                     CLEAR@W2                        *加工工場コード
     C                     CLEAR@W3                        *加工工場名称
     C                     CLEAR@W4                        *機番
     C                     CLEAR@W5                        *箱色コード
     C                     CLEAR@W6                        *箱種コード
     C                     CLEAR@W7                        *箱色名称
     C                     CLEAR@W8                        *箱種名称
     C                     CLEAR@W9                        *工程納期YYYYMMDD
     C                     CLEAR@WA                        *工程備考
     C                     CLEAR@WB                        *ゲート入YYYYMMDD
     C                     CLEAR@WC                        *ゲート入作業者
     C                     CLEAR@WD                        *ゲート出YYYYMMDD
     C                     CLEAR@WE                        *ゲート出作業者
      *
     C                     Z-ADD*ZERO     IX
     C                     Z-ADD*ZERO     IZ      20
      *
     C           IX        DOWLT15                         ¬DO_01
     C           IZ        ANDLT15
     C                     ADD  1         IX
      *入力あり
     C           @K1,IX    IFNE *BLANK                     ~¬IF_01
     C           @K2,IX    ORNE *ZERO
     C           @K4,IX    ORNE *BLANK
     C           @K5,IX    ORNE *BLANK
     C           @K6,IX    ORNE *BLANK
     C           @K7,IX    ORNE *BLANK
     C           @K8,IX    ORNE *BLANK
     C           @K9,IX    ORNE *ZERO
     C           @KA,IX    ORNE *BLANK
     C                     ADD  1         IZ
     C                     MOVEL@K1,IX    @W1,IZ           *工程コード
     C                     Z-ADD@K2,IX    @W2,IZ           *加工工場コード
     C                     MOVEL@K3,IX    @W3,IZ           *加工工場名称
     C                     MOVEL@K4,IX    @W4,IZ           *機番
     C                     MOVEL@K5,IX    @W5,IZ           *箱色コード
     C                     MOVEL@K6,IX    @W6,IZ           *箱種コード
     C                     MOVEL@K7,IX    @W7,IZ           *箱色名称
     C                     MOVEL@K8,IX    @W8,IZ           *箱種名称
     C                     MOVEL@K9,IX    @W9,IZ           *工程納期YYYYMMDD
     C                     MOVEL@KA,IX    @WA,IZ           *工程備考
     C                     Z-ADD@KB,IX    @WB,IZ           *ゲート入YYYYMMDD
     C                     MOVEL@KC,IX    @WC,IZ           *ゲート入作業者
     C                     Z-ADD@KD,IX    @WD,IZ           *ゲート出YYYYMMDD
     C                     MOVEL@KE,IX    @WE,IZ           *ゲート出作業者
     C                     END                             _｢IF_01
     C                     END                             ｢DO_01
      *再セット
     C                     CLEAR@K1                        *工程コード
     C                     CLEAR@K2                        *加工工場コード
     C                     CLEAR@K3                        *加工工場名称
     C                     CLEAR@K4                        *機番
     C                     CLEAR@K5                        *箱色コード
     C                     CLEAR@K6                        *箱種コード
     C                     CLEAR@K7                        *箱色名称
     C                     CLEAR@K8                        *箱種名称
     C                     CLEAR@K9                        *工程納期YYYYMMDD
     C                     CLEAR@KA                        *工程備考
     C                     CLEAR@KB                        *ゲート入YYYYMMDD
     C                     CLEAR@KC                        *ゲート入作業者
     C                     CLEAR@KD                        *ゲート出YYYYMMDD
     C                     CLEAR@KE                        *ゲート出作業者
      *
     C                     Z-ADD*ZERO     IX
      *
     C           IX        DOWLT15                         ¬DO_01
     C                     ADD  1         IX
     C                     MOVEL@W1,IX    @K1,IX           *工程コード
     C                     Z-ADD@W2,IX    @K2,IX           *加工工場コード
     C                     MOVEL@W3,IX    @K3,IX           *加工工場名称
     C                     MOVEL@W4,IX    @K4,IX           *機番
     C                     MOVEL@W5,IX    @K5,IX           *箱色コード
     C                     MOVEL@W6,IX    @K6,IX           *箱種コード
     C                     MOVEL@W7,IX    @K7,IX           *箱色名称
     C                     MOVEL@W8,IX    @K8,IX           *箱種名称
     C                     MOVEL@W9,IX    @K9,IX           *工程納期YYYYMMDD
     C                     MOVEL@WA,IX    @KA,IX           *工程備考
     C                     Z-ADD@WB,IX    @KB,IX           *ゲート入YYYYMMDD
     C                     MOVEL@WC,IX    @KC,IX           *ゲート入作業者
     C                     Z-ADD@WD,IX    @KD,IX           *ゲート出YYYYMMDD
     C                     MOVEL@WE,IX    @KE,IX           *ゲート出作業者
     C                     END                             ｢DO_01
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #PNL40   第四画面(G4) 表示処理
      *-------------------------------------------------------------------------
     C           #PNL40    BEGSR
      *
     C                     EXFMTMRHPW314
      *
     C                     SETOF                     434445
     C                     SETOF                     464748
     C                     SETOF                     49
     C                     SETOF                     515253*構成品ER-FLG
     C                     SETOF                     54  56
     C                     SETOF                     5058
     C                     SETOF                     616263*工程ER-FLG
     C                     SETOF                     646566
     C                     SETOF                     676869
     C                     SETOF                     717273*工程ER-FLG
     C                     SETOF                     747576
     C                     SETOF                     777879
     C                     SETOF                     80
     C                     SETOF                     99
     C                     MOVEL*BLANK    D4EMSG           * ERR MSG
      *
      * NEXT-CONTROL
     C                     SELEC                           ¬SELEC_01
     C           *IN11     WHEQ '1'
     C                     CALL 'MRHR84'
     C                     MOVEL'PNL40'   W@NEXT
      *
     C           *IN12     WHEQ '1'
     C                     CALL 'MRHR12'
     C                     PARM           D4BAN1  1
     C                     PARM           D4BAN2  2
     C                     PARM           D4BAN3  2
     C                     PARM           D4BAN4  1
     C                     MOVEL'PNL40'   W@NEXT
      * PAGE-UP(IN28)/DOWN(IN29)
     C           *IN28     WHEQ '1'                        +WHEN_01
     C           *IN29     OREQ '1'
      ** UP/DOWN無効
     C           *IN28     IFEQ '1'                        ~¬IF_01
     C           W@PAGE    ANDEQ1
     C  N99                MOVEL@MS,18    D4EMSG    P      * ERR MSG
     C  N99                SETON                     99
     C                     END                             _｢IF_01
     C           *IN29     IFEQ '1'                        ~¬IF_01
     C           W@PAGE    IFEQ 2                          ~~¬IF_02
     C  N99                MOVEL@MS,19    D4EMSG    P      * ERR MSG
     C  N99                SETON                     99
     C                     END                             __｢IF_02
     C           *IN97     IFEQ '1'                        ~~¬IF_02
     C           W@KMX3    ANDLE10
     C  N99                MOVEL@MS,19    D4EMSG    P      * ERR MSG
     C  N99                SETON                     99
     C                     END                             __｢IF_02
     C                     END                             _｢IF_01
      *
     C           *IN99     IFEQ '1'                        ~¬IF_01
     C                     MOVEL'PNL40'   W@NEXT
     C                     ELSE                            -+ELSE_01
      ** UP/DOWN有効
     C                     EXSR #SET42                     *表示⇒配列
     C           W@PAGE    IFEQ 1                          ~~¬IF_02
     C                     Z-ADD2         W@PAGE           *ページ数
     C                     ELSE                            --+ELSE_02
     C                     Z-ADD1         W@PAGE           *ページ数
     C                     END                             __｢IF_02
     C                     MOVEL'SET40'   W@NEXT
     C                     END                             _｢IF_01
      * CF03
     C           *IN03     WHEQ '1'                        +WHEN_01
     C           *IN96     IFEQ '1'                        ~¬IF_01
     C                     MOVEL'PNL20'   W@NEXT
     C                     END                             _｢IF_01
     C           *IN97     IFEQ '1'                        ~¬IF_01
     C                     MOVEL'PNL30'   W@NEXT
     C                     END                             _｢IF_01
      *その他
     C                     OTHER                           +WHEN_01
     C                     EXSR #SET42                     *工程表示⇒配列
     C           *IN96     IFEQ '1'                        ~¬IF_01
     C                     EXSR #DSP40                     *空白工程自動圧縮
     C                     END                             _｢IF_01
     C                     EXSR #SET41                     *配列⇒工程表示
     C                     MOVEL'CHK40'   W@NEXT
     C                     END                             ｢SELEC_01
      *
     C                     ENDSR
      *-------------------------------------------------------------------------
      *          #CHK40   第四画面(G4) チェック処理
      *-------------------------------------------------------------------------
     C           #CHK40    BEGSR
      *
     C                     MOVEL*BLANK    W@CHK1  1        *入力チェック
      *箱数=総生産数/収容数（切上）
     C                     Z-ADD*ZERO     W@SHKS  80       *箱数（総生産数）
     C                     Z-ADD*ZERO     W@MVR   80       *余り
     C           W@SSYS    IFNE *ZERO                      ¬IF_01
     C           D4SISU    DIV  W@SSYS    W@SHKS           *箱数（総生産数）
     C                     MVR            W@MVR            *余り
     C           W@MVR     IFNE *ZERO                      ~¬IF_02
     C                     ADD  1         W@SHKS           *箱数（総生産数）
     C                     END                             _｢IF_02
     C                     END                             ｢IF_01
     C                     Z-ADDW@SHKS    D4BOXQ
      *<発行依頼者> *ノーチェック
      *
      *<番地> *新規のみチェック
     C           *IN96     IFEQ '1'                        ¬IF_01
      **ハイド番地初期化
     C                     MOVELD4BAN1    H4BAN1           *番地1
     C                     MOVELD4BAN2    H4BAN2           *番地2
     C                     MOVELD4BAN3    H4BAN3           *番地3
     C                     MOVELD4BAN4    H4BAN4           *番地4
      **ユーザー入力がブランクの場合
     C           D4BAN1    IFEQ *BLANK                     ~¬IF_02
     C           D4BAN2    ANDEQ*BLANK
     C           D4BAN3    ANDEQ*BLANK
     C           D4BAN4    ANDEQ*BLANK
      *** PC/QDの場合
     C           D4DVKB    IFEQ '2'                        ~~¬IF_03
     C           D4DVKB    OREQ '3'
      *試作番地マスタ(MRHPL12)
     C                     MOVELD4SHN1    SBHIN1           *品番1
     C                     MOVELD4SHN2    SBHIN2           *品番2
     C                     MOVELD4SHN3    SBHIN3           *品番3
     C           SAKEY2    SETLLMRHPL121
     C                     EXSR #RED20
     C           *IN92     IFEQ '0'                        ~~~¬IF_04
     C                     MOVELSBBAN1    H4BAN1           *番地1
     C                     MOVELSBBAN2    H4BAN2           *番地2
     C                     MOVELSBBAN3    H4BAN3           *番地3
     C                     MOVELSBBAN4    H4BAN4           *番地4
     C                     END                             ___｢IF_04
     C                     END                             __｢IF_03
      **ブランクの場合
     C           H4BAN1    IFEQ *BLANK                     ~~¬IF_03
     C           H4BAN2    ANDEQ*BLANK
     C           H4BAN3    ANDEQ*BLANK
     C           H4BAN4    ANDEQ*BLANK
      *試作番地マスタ(MRHPL11)
     C           *LOVAL    SETLLMRHPL111
     C                     EXSR #RED21
     C           *IN92     IFEQ '0'                        ~~~¬IF_04
     C                     MOVELSBBAN1    H4BAN1           *番地1
     C                     MOVELSBBAN2    H4BAN2           *番地2
     C                     MOVELSBBAN3    H4BAN3           *番地3
     C                     MOVELSBBAN4    H4BAN4           *番地4
     C                     END                             ___｢IF_04
     C                     END                             __｢IF_03
      **自動引当できない場合
     C           H4BAN1    IFEQ *BLANK                     ~~¬IF_03
     C           H4BAN2    ANDEQ*BLANK
     C           H4BAN3    ANDEQ*BLANK
     C           H4BAN4    ANDEQ*BLANK
     C  N99                MOVEL@MS,10    D4EMSG    P      * ERR MSG
     C  N99                SETON                     4399
     C                     END                             __｢IF_03
      *
     C                     ELSE                            -+ELSE_02
      **ユーザー入力がブランク以外の場合
      *** PC/QDでダミー番地の場合、ノーチェック
     C                     MOVEL*BLANK    W@DMYF  1        *ダミーフラグ
     C           D4DVKB    IFEQ '2'                        ~~¬IF_03
     C           D4BAN1    IFEQ *BLANK                     ~~~¬IF_04
     C           D4BAN2    ANDEQ@BN,1
     C           D4BAN3    ANDEQ*BLANK
     C           D4BAN4    ANDEQ*BLANK
     C                     MOVEL'1'       W@DMYF           *ダミーフラグ
     C                     END                             ___｢IF_04
     C                     END                             __｢IF_03
     C           D4DVKB    IFEQ '3'                        ~~¬IF_03
     C           D4BAN1    IFEQ *BLANK                     ~~~¬IF_04
     C           D4BAN2    ANDEQ@BN,2
     C           D4BAN3    ANDEQ*BLANK
     C           D4BAN4    ANDEQ*BLANK
     C                     MOVEL'1'       W@DMYF           *ダミーフラグ
     C                     END                             ___｢IF_04
     C                     END                             __｢IF_03
      *** 号口番地の場合、ノーチェック
     C*          D4DVKB    IFEQ '4'                        ~~¬IF_03
     C           D4BAN1    IFEQ W@GBN1                     ~~~¬IF_04
     C           D4BAN2    ANDEQW@GBN2
     C           D4BAN3    ANDEQW@GBN3
     C           D4BAN4    ANDEQW@GBN4
     C                     MOVEL'1'       W@DMYF           *ダミーフラグ
     C                     END                             ___｢IF_04
     C*                    END                             __｢IF_03
      *
      *** サービス番地の場合、ノーチェック
     C*          D4DVKB    IFEQ '4'                        ~~¬IF_03
     C           D4BAN1    IFEQ W@SBN1                     ~~~¬IF_04
     C           D4BAN2    ANDEQW@SBN2
     C           D4BAN3    ANDEQW@SBN3
     C           D4BAN4    ANDEQW@SBN4
     C                     MOVEL'1'       W@DMYF           *ダミーフラグ
     C                     END                             ___｢IF_04
     C*                    END                             __｢IF_03
      *
     C           W@DMYF    IFEQ *BLANK                     ~~¬IF_03
      *試作番地マスタ(MRHPL11)
     C                     MOVELD4BAN1    SBBAN1           *番地 1
     C                     MOVELD4BAN2    SBBAN2           *番地 2
     C                     MOVELD4BAN3    SBBAN3           *番地 3
     C                     MOVELD4BAN4    SBBAN4           *番地 4
     C           SAKEY1    CHAINMRHPL111            N92
      ***読み取れない
     C           *IN92     IFEQ '1'                        ~~~¬IF_04
     C  N99                MOVEL@MS,11    D4EMSG    P      * ERR MSG
     C  N99                SETON                     4399
     C                     ELSE                            ---+ELSE_04
      ***削除データ
     C           SBGSJY    IFEQ 'D'                        ~~~~¬IF_05
     C           SBGSHZ    ANDLES@YYMD
     C  N99                MOVEL@MS,12    D4EMSG    P      * ERR MSG
     C  N99                SETON                     4399
     C                     ELSE                            ----+ELSE_05
      ***品番登録済み
     C           SBHIN1    IFNE *BLANK                     ~~~~~¬IF_06
     C           SBHIN2    ORNE *BLANK
     C           SBHIN3    ORNE *BLANK
     C           SBHIN1    IFNE D4SHN1                     ~~~~~~¬IF_07
     C           SBHIN2    ORNE D4SHN2
     C           SBHIN3    ORNE D4SHN3
     C  N99                MOVEL@MS,13    D4EMSG    P      * ERR MSG
     C  N99                SETON                     4399
     C                     END                             ______｢IF_07
     C                     END                             _____｢IF_06
      ***収容箱数＜箱数（総生産数）
     C           SBHAKO    IFLT W@SHKS                     ~~~~~¬IF_06
     C  N99                MOVEL@MS,14    D4EMSG    P      * ERR MSG
     C  N99                SETON                     4399
     C                     END                             _____｢IF_06
     C                     END                             ____｢IF_05
     C                     END                             ___｢IF_04
     C                     END                             __｢IF_03
     C                     END                             _｢IF_02
     C                     END                             ｢IF_01
      *
      *<生産数量> *再発行のみチェック
     C           *IN97     IFEQ '1'                        ¬IF_01
     C           D4SISU    IFEQ *ZERO                      ~¬IF_02
     C  N99                MOVEL@MS,02    D4EMSG    P      * ERR MSG
     C  N99                SETON                     4499
     C                     END                             _｢IF_02
      *<手配数量> *再発行のみチェック
     C           D4THSU    IFEQ *ZERO                      ~¬IF_02
     C  N99                MOVEL@MS,02    D4EMSG    P      * ERR MSG
     C  N99                SETON                     4599
     C                     ELSE                            -+ELSE_02
     C           D4THSU    IFGT D4SISU                     ~~¬IF_03
     C  N99                MOVEL@MS,08    D4EMSG    P      * ERR MSG
     C  N99                SETON                     4599
     C                     END                             __｢IF_03
     C                     END                             _｢IF_02
      *<納期>  *再発行のみチェック
     C                     Z-ADDD4NOHZ    W@YYMD
     C*                    Z-ADDD4NOHZ    W@MMDY
     C*                    EXSR #CMTY                      *日付変換MDY->YMD
      *ゼロエラー
     C           D4NOHZ    IFEQ *ZERO                      ~¬IF_02
     C  N99                MOVEL@MS,02    D4EMSG    P      * ERR MSG
     C  N99                SETON                     4699
     C                     ELSE                            -+ELSE_02
      *カレンダーマスタ(AGDPL12)
     C                     Z-ADDW@YYY     F8KAYY           *年
     C                     Z-ADDW@YMM     F8KAMM           *月
     C                     Z-ADDW@YDD     F8KADD           *日
     C           F8KEY     CHAINAGDPL121             92
     C           *IN92     IFEQ '1'                        ~~¬IF_03
     C  N99                MOVEL@MS,09    D4EMSG    P      * ERR MSG
     C  N99                SETON                     4699
     C                     END                             __｢IF_03
     C                     END                             _｢IF_02
     C                     END                             ｢IF_01
      *<手配目的> *ノーチェック
      *
      *<データ要否> *
     C           D4INSP    IFNE 'Y'                        ~¬IF_02
     C           D4INSP    ANDNE'N'                          &
     C  N99                MOVEL@MS,25    D4EMSG    P      * ERR MSG
     C  N99                SETON                     5899
     C                     END                             _｢IF_02
      *
      *< HN LOCATION> *
      *  CHECK HN-0111 EXIST
     C                     Z-ADD1         J
     C           'HN  '    LOKUP@K1,J                    27
     C           *IN27     IFEQ '1'                        ~~¬IF_01
     C           @K2,J     ANDEQ0111
     C           D4HNL1    IFEQ *BLANK                     ~¬IF_02
     C           D4HNL2    OREQ *BLANK
     C           D4HNL3    OREQ *BLANK
     C           D4HNL4    OREQ *BLANK
     C  N99                MOVEL@MS,21    D4EMSG    P      * ERR MSG
     C  N99                SETON                     5099
     C                     ENDIF                           _｢IF_02
     C                     ENDIF                           _｢IF_01
      *---------------------------------*
      *<<工程>> *全工程をチェックする
      *  @K1:工程コード
      *  @K2:加工工場コード
      *  @K3:加工工場名称
      *  @K4:機番
      *  @K5:箱色コード
      *  @K6:箱種コード
      *  @K7:箱色名称
      *  @K8:箱種名称
      *  @K9:工程納期YYYYMMDD
      *  @KA:備考
      *---------------------------------*
     C                     Z-ADD*ZERO     IX               *自工程
     C                     Z-ADD*ZERO     W@IX    20       *エラー工程
     C                     Z-ADD*ZERO     W@IJ    20       * ERR-FLG NO.
     C                     Z-ADD*ZERO     W@BKTN  80       *前工程納期
      *
     C           IX        DOWLT15                         ¬DO_01
     C                     ADD  1         IX               *自工程
      *
     C           @K1,IX    IFNE *BLANK                     ~¬IF_01
     C           @K2,IX    ORNE *ZERO
     C           @K3,IX    ORNE *BLANK
     C           @K4,IX    ORNE *BLANK
     C           @K5,IX    ORNE *BLANK
     C           @K6,IX    ORNE *BLANK
     C           @K7,IX    ORNE *BLANK
     C           @K8,IX    ORNE *BLANK
     C           @K9,IX    ORNE *ZERO
     C                     MOVEL'1'       W@CHK1           *入力チェック
