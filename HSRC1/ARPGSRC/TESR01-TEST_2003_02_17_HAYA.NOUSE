     H            Y/                                    1
     FGDGPL30 UF  E           K        DISK                      A
     FGDGPL10 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FAKBPL04 IF  E           K        DISK
     FAKCPL01 IF  E           K        DISK
     FQPRINT  O   F     132            PRINTER
     FFCEPL11 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
 %002FAANPL06 IF  E           K        DISK
     FAAPTL01 IF  E           K        DISK
     I            DS
     I                                        1   80FCSKHZ
     I                                        1   40FCSKYY
     I                                        5   60FCSKMM
     I                                        7   80FCSKDD
     C*===============================================================
     C*  START  PROGRAM
     C*===============================================================
 %002C*製品区分再入力
     C                     MOVE *BLANK    WWSEIH           PART CODE
     C                     MOVE *BLANK    WWZETI  4        ID NO.
     C                     EXSR #TYPE
     C           WWSEIH    IFEQ *BLANK
     C                     MOVE IBSEIH    S1SEIH
     C                     ELSE
     C                     MOVE WWSEIH    S1SEIH
     C                     END
     C* 絶対番号再入力
     C           WWZETI    IFEQ *BLANK
     C                     MOVE IBZETI    S1ZETI
     C                     ELSE
     C                     MOVE WWZETI    S1ZETI
 %002C                     END
     C*
     C                     ADD  1         RRN1
     C                     WRITESFREC1
E1   C                     ENDDO
     C*--------------------
     C                     Z-ADDRRN1      ENDRRN  40
     C                     Z-ADD1         RRN
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
     C****************************************************************
     C*<KANBAN TYPE>
     C           KEY02     KLIST
     C                     KFLD           IBHIN1
     C                     KFLD           IBHIN2
     C                     KFLD           IBHIN3
     C                     SETOF                     54
     C           KEY02     SETGTAAPTL011
     C                     DO   *HIVAL
     C           ##1       TAG
     C           KEY02     REDPEAAPTL011                 54
     C           *IN54     IFEQ '0'
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    IFLE *DATE
     C                     GOTO ##1
     C                     END
     C                     END
     C*
     C           L5UKHZ    IFGT *DATE
     C                     GOTO ##1
     C                     END
     C*
     C           L5STHZ    IFLT *DATE
     C                     GOTO ##1
     C                     END
     C*
     C           L5STHZ    IFNE 99999999
     C                     GOTO ##1
     C                     END
     C*
     C                     MOVE '0'       WWSEIH  1
     C                     MOVE L5ZETI    WWZETI
     C                     GOTO ETYPE
     C                     END
     C  N54                ENDDO
      *
      *
     C                     SETOF                     54
     C           KEY02     SETLLAKBPL041                 54
     C                     DO   *HIVAL
     C           ##2       TAG
     C           KEY02     READEAKBPL041                 54
     C           *IN54     IFEQ '0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    IFLE *DATE
     C                     GOTO ##2
     C                     END
     C                     END
     C           L1UKHZ    IFGT *DATE
     C                     GOTO ##2
     C                     END
     C           L1STHZ    IFLT *DATE
     C                     GOTO ##2
     C                     END
     C                     MOVE L1ZETI    WWZETI
     C                     MOVE '3'       WWSEIH
     C                     GOTO ETYPE
     C                     END
     C  N54                ENDDO
      *
      *
     C                     SETOF                     54
     C           KEY02     SETLLAANPL061                 54
     C                     DO   *HIVAL
     C           ##3       TAG
     C           KEY02     READEAANPL061                 54
     C           *IN54     IFEQ '0'
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    IFLE *DATE
     C                     GOTO ##3
     C                     END
     C                     END
     C           L7UKHZ    IFGT *DATE
     C                     GOTO ##3
     C                     END
     C           L7STHZ    IFLT *DATE
     C                     GOTO ##3
     C                     END
     C                     MOVE L7ZETI    WWZETI
     C                     MOVE '6'       WWSEIH  1
     C                     GOTO ETYPE
     C                     END
     C  N54                ENDDO
     C*
     C****************************************************************
 %003C           #TYPE2    BEGSR                                     *
     C****************************************************************
     C******************
     C* KANSEIHIN KANBAN
