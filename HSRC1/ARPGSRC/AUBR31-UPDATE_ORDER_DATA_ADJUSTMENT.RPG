     FAUBPW31 CF  E                    WORKSTN
     FAUBPL31 UF  E           K        DISK                      A
     E                    MSG     1  12 60               d[ｰ xｮﾈｰﾆﾞ
     I            DS
     I                                        1   80CESTHZ
     I                                        1   40CESTYY
     I                                        5   60CESTMM
     I                                        7   80CESTDD
     I            DS
     I                                        1   80CEENHZ
     I                                        1   40CEENYY
     I                                        5   60CEENMM
     I                                        7   80CEENDD
     I            DS
     I                                        1   80CESKHZ
     I                                        1   40CESKYY
     I                                        5   60CESKMM
     I                                        7   80CESKDD
     I            DS
     I                                        1   80CEKOHZ
     I                                        1   40CEKOYY
     I                                        5   60CEKOMM
     I                                        7   80CEKODD
     I            DS
     I                                        1   60JIKAN
     I                                        1   20CEKOHH
     I                                        3   40CEKOSS
     I                                        5   60CEZZZZ
     C           *ENTRY    PLIST
     C                     PARM           PUSER  10
     C****************************************************************
     C*  START PROGRAM  <ATAR01>                                     *
     C****************************************************************
     C*
     C*  ﾎｧｰﾓnﾞ ﾉ hﾒa
     C*
     C           STP0      TAG
     C                     MOVEL*BLANK    KBN
     C                     MOVEL*BLANK    HIN01
     C                     MOVEL*BLANK    HIN02
     C                     MOVEL*BLANK    HIN03
     C                     Z-ADD0         TOKCD
     C                     MOVEL*BLANK    TOKOU
     C                     MOVEL*BLANK    TOUKE
     C                     Z-ADD0         NOKCD
     C                     MOVEL*BLANK    NOKOU
     C                     MOVEL*BLANK    NOUKE
     C                     MOVEL*BLANK    CESTHZ
     C                     MOVEL*BLANK    CEENHZ
     C                     MOVEA'00000'   *IN,01
     C                     MOVEA'000'     *IN,06
     C                     MOVEA'000'     *IN,80
     C                     MOVEA'0'       *IN,99
     C*
     C*  ﾅbﾆｭ ﾉ ﾈｮn
     C*
     C           STP1      TAG
     C                     EXFMTAUBPW311
     C                     MOVEA'00000'   *IN,01
     C                     MOVEA'000'     *IN,06
     C                     MOVEA'0'       *IN,99
     C                     MOVEA'000'     *IN,80
     C*
     C           *INKA     IFEQ '1'
     C                     MOVEL'1'       *INLR
     C                     RETRN
     C                     END
     C*
     C           KBN       IFEQ *BLANK
     C                     MOVEA'1'       *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,1     ERRMSG
     C                     GOTO STP1
     C                     END
     C*
     C           KBN       IFNE '0'
     C           KBN       IFNE '1'
     C           KBN       IFNE '2'
     C                     MOVEA'1'       *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,2     ERRMSG
     C                     GOTO STP1
     C                     END
     C                     END
     C                     END
     C*
     C           KBN       IFEQ '0'
     C                     MOVEL'CALCEL'  KBNNM
     C                     MOVEA'1'       *IN,80
     C                     END
     C*
     C           KBN       IFEQ '1'
     C                     MOVEL'CHANGE'  KBNNM
     C                     MOVEA'1'       *IN,81
     C                     END
     C*
     C           KBN       IFEQ '2'
     C                     MOVEL'ADD   '  KBNNM
     C                     MOVEA'1'       *IN,82
     C                     MOVE HIN01     CEHIN1
     C                     MOVE HIN02     CEHIN2
     C                     MOVE HIN03     CEHIN3
     C                     Z-ADDTOKCD     CETOKU
     C                     MOVELTOKOU     CETKOJ
     C                     MOVELTOUKE     CETUKE
     C                     Z-ADDNOKCD     CENONY
     C                     MOVELNOKOU     CENKOJ
     C                     MOVELNOUKE     CENUKE
     C                     END
     C*
     C           HIN01     IFEQ *BLANK
     C           HIN02     IFEQ *BLANK
     C           HIN03     IFEQ *BLANK
     C                     MOVEA'1'       *IN,02
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,3     ERRMSG
     C                     GOTO STP1
     C                     END
     C                     END
     C                     END
     C*
     C           TOKCD     IFEQ 0
     C                     MOVEA'1'       *IN,03
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,4     ERRMSG
     C                     GOTO STP1
     C                     END
     C*
     C           TOKOU     IFEQ *BLANK
     C                     MOVEA'1'       *IN,04
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,5     ERRMSG
     C                     GOTO STP1
     C                     END
     C*
     C           TOUKE     IFEQ *BLANK
     C                     MOVEA'1'       *IN,05
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,6     ERRMSG
     C                     GOTO STP1
     C                     END
     C*
     C           NOKCD     IFEQ 0
     C                     MOVEA'1'       *IN,06
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,7     ERRMSG
     C                     GOTO STP1
     C                     END
     C*
     C           NOKOU     IFEQ *BLANK
     C                     MOVEA'1'       *IN,07
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,8     ERRMSG
     C                     GOTO STP1
     C                     END
     C*
     C           NOUKE     IFEQ *BLANK
     C                     MOVEA'1'       *IN,08
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,9     ERRMSG
     C                     GOTO STP1
     C                     END
     C*
     C*
     C           KEY1      KLIST
     C                     KFLD           HIN01
     C                     KFLD           HIN02
     C                     KFLD           HIN03
     C                     KFLD           TOKCD
     C                     KFLD           TOKOU
     C                     KFLD           TOUKE
     C                     KFLD           NOKCD
     C                     KFLD           NOKOU
     C                     KFLD           NOUKE
     C           KEY1      CHAINAUBPL311             10
B001 C           *IN,10    IFEQ '0'
B002 C           CESKJY    IFEQ 'D'
     C           CESKHZ    ANDLE*DATE
B003 C           KBN       IFNE '2'
     C                     MOVEA'1'       *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,11    ERRMSG
     C                     GOTO STP1
E003 C                     END
X002 C                     ELSE
B003 C           KBN       IFEQ '2'
     C                     MOVEA'1'       *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,10    ERRMSG
     C                     GOTO STP1
E003 C                     END
E002 C                     END
X001 C                     ELSE
B002 C           KBN       IFNE '2'
     C                     MOVEA'1'       *IN,01
     C                     MOVEA'1'       *IN,99
6    C                     MOVELMSG,12    ERRMSG
     C                     GOTO STP1
E002 C                     END
E001 C                     END
     C*
     C           KBN       IFEQ '2'
     C                     Z-ADD0         CESTHZ
     C                     Z-ADD0         CEENHZ
     C                     END
     C*
     C           STP2      TAG
     C                     EXFMTAUBPW312
     C*
     C           *INKA     IFEQ '1'
     C                     MOVEL'1'       *INLR
     C                     RETRN
     C                     END
     C*
     C                     MOVEA'0'       *IN,99
     C*
     C*
     C   KC                GOTO STP0
     C  NKE                GOTO STP2
     C******
     C** ﾎｦbﾓ ﾉ ﾃcﾆ]
     C******
     C           EOKK      TAG
     C                     MOVE PUSER     CEKOME
     C                     Z-ADD*DATE     CEKOHZ
     C                     TIME           JIKAN
     C*
     C           KBN       IFEQ '0'
     C                     MOVEL'D'       CESKJY
     C                     Z-ADD*DATE     CESKHZ
     C                     ELSE
     C                     MOVE *BLANK    CESKJY
     C                     Z-ADD0         CESKHZ
     C                     END
     C*
     C           *IN,10    IFEQ '0'
     C                     UPDATAUBPL311
     C                     ELSE
     C                     WRITEAUBPL311
     C                     END
     C                     GOTO STP0
     C**
     C**
     C**
**  MSG (ERROR MESSAGE )
E-01 INPUT UPDATE INSTRUCTION
E-02 UPDATE INSTRUCTION IS (0,1,2)
E-03 INPUT INTRAL COMPANY PART NO
E-04 INPUT CUSTOMER CODE
E-05 INPUT CUSTOMER FACTORY
E-06 INPUT CUSTOMER RECEIVING
E-07 INPUT RECEIVING CO. CODE
E-08 INPUT RECEIVING CO. FACTORY
E-09 INPUT RECEIVING CO. RECEIVING
E-10 INPUT ALREADY
E-11 DELETED ALREADY
E-12 THERE IS NOT APPLICABLE DATA
