     F********************************** MFAR06 ******
     FMFAPP21 IP  E                    DISK
     FMFAWP06 O   F     100            DISK
     IMFAPP211    01
     I            DS
     I                                        1   80M@SKHZ
     I                                        1   40M@SKYY
     I                                        5   60M@SKMM
     I                                        7   80M@SKDD
     C******************************************************
     C*  START PROGRAM  <MFAR06>                           *
     C******************************************************
     C  N01                GOTO @END
     C*
     C           *ENTRY    PLIST
     C                     PARM           PKJ     4
     C                     PARM           PKBN    1
     C                     PARM           PLST    1
     C                     MOVELPKJ       KOJO    40
     C*
     C           M@SKJY    IFEQ 'D'
     C           M@SKHZ    ANDLE*DATE
     C                     GOTO @END
     C                     END
     C*
B001 C           KOJO      IFNE 9999
     C           KOJO      CABNEM@KOJY    @END
E001 C                     END
     C*
B001 C           PKBN      IFNE '3'
     C           PKBN      CABNEM@SKBN    @END
E001 C                     END
     C*
     C                     SETON                     U1
     C                     EXCPTDT
     C           @END      TAG
     C*
     OMFAWP06 E                DT
     O                         M@KOJY     4
     O                         M@BUKA     5
     O                         M@KAKA     6
     O                         M@KBN1     9
     O                         M@KBN2    10
     O                         M@KOTE    13
     O                         M@RPMH    19
