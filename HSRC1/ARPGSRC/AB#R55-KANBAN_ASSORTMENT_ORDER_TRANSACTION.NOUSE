     F**************************************************
     FAB#PW55 CF  E                    WORKSTN
     FALBPL45 IF  E           K        DISK
     FGADPL24 IF  E           K        DISK
     FAB#WX55 O   F     100            DISK
     E                    ER      1   9 60
     I            DS
     I                                        1   80ISYHZ
     I                                        1   40ISYYY
     I                                        5   60ISYMM
     I                                        7   80ISYDD
     I            DS
     I                                        1   80A5SKHZ
     I                                        1   40A5SKYY
     I                                        5   60A5SKMM
     I                                        7   80A5SKDD
     I            DS
     I                                        1   80A5SYHZ
     I                                        1   40A5SYY
     I                                        5   60A5SMM
     I                                        7   80A5SDD
     I            DS
     I                                        1  20 A5MHIN
     I                                        1   5 A5UHN1
     I                                        6  10 A5UHN2
     I                                       11  15 A5UHN3
     I                                       16  20 A5UHN4
     I            DS
     I                                        1  20 WMHIN
     I                                        1   5 WMHN1
     I                                        6  10 WMHN2
     I                                       11  15 WMHN3
     I                                       16  20 WMHN4
      *
     C           KEY1      KLIST
     C                     KFLD           @SIRE
     C                     KFLD           ISKOJ
     C                     KFLD           IUKEI
     C                     KFLD           ISYYY
     C                     KFLD           ISYMM
     C                     KFLD           ISYDD
     C                     KFLD           WRGCD
      *
     C           KEY2      KLIST
     C                     KFLD           WTOKU
     C                     KFLD           WNONY
     C                     KFLD           WNUKE
      *
     C                     Z-ADD0         ISYHZ
     C                     Z-ADD0         IRGCD
     C                     MOVE 'M390'    ICARD
      *
     C           STP1      TAG
     C                     EXFMTAB#PW551
     C                     SETOF                     010203
     C                     SETOF                     0405
     C                     SETOF                     0799
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           ISYHZ     IFEQ 0
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
      *
     C           ISYYY     IFGE 1997
     C           ISYMM     ANDGE01
     C           ISYMM     ANDLE12
     C           ISYDD     ANDGE01
     C           ISYDD     ANDLE31
     C                     ELSE
     C                     SETON                     0199
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
      *
     C           IRGCD     IFEQ 0
     C                     SETON                     0299
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     END
     C                     MOVE IRGCD     WRGCD   2
      *
     C           ISIRE     IFEQ *BLANK
     C                     SETON                     0399
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     END
      *
     C           ISKOJ     IFEQ *BLANK
     C                     SETON                     0499
     C                     MOVE ER,5      MSG
     C                     GOTO STP1
     C                     END
      *
     C           IUKEI     IFEQ *BLANK
     C                     SETON                     0599
     C                     MOVE ER,6      MSG
     C                     GOTO STP1
     C                     END
      *
%0001C*          IODRN     IFEQ *BLANK
%0001C*                    SETON                     0699
%0001C*                    MOVE ER,7      MSG
%0001C*                    GOTO STP1
%0001C*                    END
      *
     C           ISIRE     IFEQ '3347'
     C           ICARD     IFNE 'M390'
     C                     SETON                     0799
     C                     MOVE ER,8      MSG
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP1
     C                     END
     C                     MOVE *BLANK    @SIRE   4
     C           ISIRE     IFEQ '3347'
     C                     MOVE '1406'    @SIRE
     C                     END
      *
     C           KEY1      SETLLALBPL451
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY1      READEALBPL451                 10
     C           *IN10     IFEQ '0'
     C           A5SKJY    IFEQ 'D'
     C           A5SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     SETON                     U1
     C                     EXSR SUBRTN
      *
     C                     END
     C                     END
     C  N10                END
      *
     C           *INU1     IFEQ '0'
     C                     SETON                     99
     C                     MOVE ER,9      MSG
     C                     GOTO STP1
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *
     C           SUBRTN    BEGSR
      *
     C                     MOVE A5SIRE    WSIRE   4
     C                     MOVE A5SKOJ    WSIRK   1
      *
     C           A5SIRE    IFEQ '1406'
     C                     Z-ADD3411      WTOKU   40
     C                     Z-ADD3347      WNONY   40
     C                     END
      *
     C                     MOVELA5UKEI    WNUKE   4
      *
     C                     SETOF                     11
     C                     MOVE A5SKOJ    WNKOJ   1
     C           KEY2      CHAINGADPL241             11
     C           *IN11     IFEQ '0'
     C                     MOVE B5NKOJ    WNKOJ
     C                     END
      *
     C                     MOVE A5SBAN    WSBAN   4
     C                     MOVELA5MHIN    WMHIN
     C                     MOVE A5USYS    WSYOS   60
     C                     MOVE A5USYS    WSURY   70
%0001C*                    MOVELIODRN     WODRN  10
     C                     MOVE *BLANK    WODRN  10
      *
     C                     Z-ADDA5SYHZ    WNOHZ   80
     C                     MOVE A5RGCD    WNOBI   20
     C                     Z-ADD0         WNOTM   40
      *
     C                     MOVELWTOKU     PTOKU   4
     C                     MOVELWNONY     PNONY   4
     C                     MOVELWNKOJ     PNKOJ   1
     C                     MOVELWNUKE     PNUKE   4
     C                     MOVELWMHIN     @MHIN  20
     C                     MOVEL*BLANK    @SHIN  12
     C                     MOVEL*BLANK    @FLG    1
      *
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           @MHIN  20
     C                     PARM           @SHIN  12
     C                     PARM           @FLG    1
      *
     C                     EXCPTDT
      *
     C                     ENDSR
      *
     OAB#WX55 E                DT
     O                         WSIRE      4
     O                         WSIRK      5
     O                         WTOKU      9
     O                         WNONY     13
     O                         WNKOJ     14
     O                         WNUKE     18
     O                         WSBAN     22
     O                         WMHIN     42
     O                         WNOHZ     50
     O                         WODRN     60
     O                         WSURY     67
     O                         WSYOS     73
     O                         WNOBI     75
     O                         @SHIN     87
     O                         ICARD     91
