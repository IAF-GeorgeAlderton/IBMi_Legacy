     H            Y.                                    1
     H* AFBR93D *******************************************************
     H* CHECK OUTSRC WASHER ORDER                                     *
     H* JW     2024.06.20                                             *
     H*********************AFBPL96*************************************
     FAFBPL90BIF  E           K        DISK
      *--------------------------------------------------------------
     I            DS
     I                                        1  12 B9PART
     I                                        1   5 B9PAR1
     I                                        6  10 B9PAR2
     I                                       11  12 B9PAR3
     I            DS
     I                                        1   80B9NYHZ
     I                                        1   40B9NYYY
     I                                        5   60B9NYMM
     I                                        7   80B9NYDD
     I            DS
     I                                        1   80B9NOHZ
     I                                        1   40B9NOYY
     I                                        5   60B9NOMM
     I                                        7   80B9NODD
     I            DS
     I                                        1   80B9ODHZ
     I                                        1   40B9ODYY
     I                                        5   60B9ODMM
     I                                        7   80B9ODDD
     I            DS
     I                                        1   80K1ODHZ
     I                                        1   40K1ODYY
     I                                        5   60K1ODMM
     I                                        7   80K1ODDD
     I            DS
     I                                        1  12 K1PART
     I                                        1   5 K1PAR1
     I                                        6  10 K1PAR2
     I                                       11  12 K1PAR3
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------
     C                     EXSR #INIT
      *
     C           K#90B     SETLLAFBPL90B
     C                     DO   *HIVAL
     C                     READ AFBPL90B                 98
     C   98                LEAVE
      * END
     C           B9ODHZ    IFGT @TO
     C                     LEAVE
     C                     ENDIF
      * DELETED
     C           B9SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * SUPP
     C           @SUPP     IFNE 9999
     C           B9SUPP    ANDNE$SUPP
     C                     ITER
     C                     ENDIF
      * PART
     C           $PART     IFNE *BLANK
     C           B9PART    ANDNE$PART
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         CNT
     C                     ENDDO
      *
     C           CNT       IFEQ 0
     C                     MOVE '*'       $RTN
     C                     ELSE
     C                     MOVE ' '       $RTN
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
      * INITIAL SETTING
      *-----------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SUPP   4
     C                     PARM           $FROM   8
     C                     PARM           $TO     8
     C                     PARM           $PART  12
     C                     PARM           $RTN    1
      *
     C                     TIME           SDATE
     C                     MOVE ' '       $RTN
      *
     C           $SUPP     IFEQ *BLANK
     C           $SUPP     OREQ '*ALL'
     C           $SUPP     OREQ '0000'
     C                     Z-ADD9999      @SUPP   40
     C                     ELSE
     C                     MOVEL$SUPP     @SUPP
     C                     ENDIF
      *
     C           K#90B     KLIST
     C                     KFLD           K1ODYY
     C                     KFLD           K1ODMM
     C                     KFLD           K1ODDD
      *
     C           $FROM     IFEQ *BLANK
     C           $FROM     OREQ *ZERO
     C                     MOVELTODAY     @FROM   80
     C                     ELSE
     C                     MOVEL$FROM     @FROM
     C                     ENDIF
      *
     C           $TO       IFEQ *BLANK
     C           $TO       OREQ *ZERO
     C                     MOVEL@FROM     @TO     80
     C                     ELSE
     C                     MOVEL$TO       @TO
     C                     ENDIF
      *
     C                     MOVEL@FROM     K1ODHZ
      *
     C                     Z-ADD0         CNT     90
      *
     C                     ENDSR
