     I*****                                   2  15 WJOK2
     C           KEY       KLIST
     C                     KFLD           A5JOKN
     C                     KFLD           A5KANB
      *
     C           *ENTRY    PLIST
     C                     PARM           US     10        ﾏｰﾅﾞｰ xb
     C                     Z-ADD0         A5SKHZ
      *
     C*------------------------------*
     C*     ...画面　－　１...     *
     C*------------------------------*
     C           STP1      TAG
     C                     EXFMTAAAPW011
     C                     SETOF                     010203
     C                     SETOF                     99
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C*----------------------------------------*
     C*     ...更新区分　の　チェック...     *
     C*----------------------------------------*
     C                     SETOF                     90
     C                     Z-ADD1         A
     C           KTYPE     LOKUPKOS,A                    90
     C           *IN90     IFEQ '0'
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
     C                     MOVE KON,A     WNAME
      *
     C*------------------------------------------*
     C*     ...条件コード　の　チェック...     *
     C*------------------------------------------*
     C           A5JOKN    IFEQ *BLANK
     C                     SETON                     0299
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
      *
     C*--------------------------------------------*
     C*     ...かんばん種類　の　チェック...     *
     C*--------------------------------------------*
     C                     SETOF                     90
     C                     Z-ADD1         A       20
     C           A5KANB    LOKUPKAB,A                    90
     C           *IN90     IFEQ '0'
     C                     SETON                     0399
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     END
     C                     MOVE KAN,A     SYURUI
      *
     C*----------------------------------------*
     C*     ...マスター　の　チェック...     *
     C*----------------------------------------*
     C                     SETOF                     90
     C           KEY       CHAINAAAPL011             90
     C           KTYPE     IFEQ '2'
     C           *IN90     IFEQ '0'
     C           A5SKJY    IFEQ 'D'
     C           A5SKHZ    ANDLE*DATE
     C                     GOTO STP2
     C                     END
      *
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,4      MSG
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C           KTYPE     IFEQ '1'
     C           *IN90     IFEQ '1'
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,5      MSG
     C                     GOTO STP1
     C                     END
      *
     C           A5SKJY    IFEQ 'D'
     C           A5SKHZ    ANDLE*DATE
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,6      MSG
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C           KTYPE     IFEQ '0'
     C           *IN90     IFEQ '1'
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,7      MSG
     C                     GOTO STP1
     C                     END
      *
     C           A5SKJY    IFEQ 'D'
     C           A5SKHZ    ANDLE*DATE
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,8      MSG
     C                     GOTO STP1
     C                     END
     C                     END
     C           STP2      TAG
      *
     C           KTYPE     IFEQ '2'
     C                     MOVE *BLANK    A5SKJY
     C                     Z-ADD0         A5SKHZ
     C                     MOVE *BLANK    A5JOK1
     C                     MOVE *BLANK    A5JOK2
     C                     MOVE *BLANK    A5JOKM
     C                     END
      *
     C*------------------------------*
     C*     ...画面　－　２...     *
     C*------------------------------*
     C           STP3      TAG
     C                     EXFMTAAAPW012
     C*****                SETOF                     040599
     C                     SETOF                     99
      *
     C           *INKC     IFEQ '1'
     C                     EXSR SUBRTN
     C                     GOTO STP1
     C                     END
      *
     C*--------------------------------------*
     C*     ...条件名　の　チェック...     *
     C*--------------------------------------*
     C*****      WJOK1     IFEQ *BLANK
     C*****                SETON                     0499
     C*****                MOVE ER,9      MSG
     C*****                GOTO STP3
     C*****                END
      *
     C*****      WJOK2     IFEQ *BLANK
     C*****                SETON                     0599
     C*****                MOVE ER,10     MSG
     C*****                GOTO STP3
     C*****                END
      *
     C           *INKE     IFEQ '0'
     C                     GOTO STP3
     C                     END
      *
     C           KTYPE     IFEQ '0'
     C                     MOVE 'D'       A5SKJY
     C                     Z-ADD*DATE     A5SKHZ
     C                     END
      *
     C                     Z-ADD*DATE     A5KOHZ
     C                     TIME           WTIME
     C                     MOVELUS        A5KOME
     C                     MOVE KTYPE     MTYPE
     C                     MOVE WNAME     MNAME
     C                     MOVE A5JOKN    MGYO
     C                     MOVE SYURUI    MKANS
      *
     C           *IN90     IFEQ '0'
     C                     UPDATAAAPL011
     C                     ELSE
     C                     WRITEAAAPL011
     C                     END
      *
     C                     EXCPTDT
     C                     EXSR SUBRTN
     C                     GOTO STP1
      *
      *
     C*----------------------------------------*
     C*         ...サブルーチン...           *
     C*     ...画面－１　の　クリアー...     *
     C*----------------------------------------*
     C           SUBRTN    BEGSR
     C                     MOVE *BLANK    KTYPE
     C                     MOVE *BLANK    A5JOKN
     C                     MOVE *BLANK    A5KANB
     C                     ENDSR
      *
     OAIANP04 EADD             DT
