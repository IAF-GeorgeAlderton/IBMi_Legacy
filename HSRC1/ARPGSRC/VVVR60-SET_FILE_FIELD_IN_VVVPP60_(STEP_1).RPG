     H            Y.
     F** VVVR60 ***********************************************************
     F*  SET FILE-FIELD IN VVVPP60 (STEP 1)                               *
     F*  (SET FILE NAME IN VVVPP60)                                       *
     F*  J.WATANABE   2022.09.06                                          *
     F*********************************************************************
     FVVVPP50BIF  E                    DISK
     FVVVPP60 O   E                    DISK
      *****************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *****************************************************
     C                     EXSR #INIT
      * SET FILE
     C                     EXSR #FIL
      *
     C                     SETON                     LR
     C                     RETRN
      ********************
      * SET FILE INFO
      ********************
     C           #FIL      BEGSR
      *
     C                     DO   *HIVAL
     C                     READ VVVPP50B                 98
     C   98                LEAVE
      *
     C           MLSEU     IFNE 'PF'
     C                     ITER
     C                     ENDIF
      *
     C                     CLEARVVVPP601
     C                     Z-ADDTODAY     V6CRHZ
     C                     Z-ADDNOW       V6CRTM
     C                     MOVEL#PGM      V6CRPG
     C**                   MOVEL#USER     V6CRUS
      *
     C                     MOVELMLLIB     V6LIB
     C                     MOVELMLFILE    V6FILE
     C                     MOVELMLNAME    V6MEM
     C                     MOVELMLMTXT    V6MEMT
      *
     C                     WRITEVVVPP601
     C                     ENDDO
      *
     C                     ENDSR
      ********************
      * INITIAL SET
      ********************
     C           #INIT     BEGSR
      *
     C                     TIME           SDATE
      *
     C                     ENDSR
