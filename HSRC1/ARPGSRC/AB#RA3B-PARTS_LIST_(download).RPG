     H            Y
      ** AB#RA3B ********************************************
      *  CREATE DOWNLOAD DATA
      *  JW     2024.07.31
      *******************************************************
     FAB#WPA2 IF  E           K        DISK
     FAB#WPA2BO   E                    DISK
      *-----------------------------------------------------------
     I            DS
     I                                        1  12 F3SHIN
     I                                        1   5 F3SHN1
     I                                        6  10 F3SHN2
     I                                       11  12 F3SHN3
     I            DS
     I                                        1  20 F3MHIN
     I                                        1   5 F3MHN1
     I                                        6  10 F3MHN2
     I                                       11  15 F3MHN3
     I                                       16  20 F3MHN4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ************************************************************
     C                     Z-ADD0         CNT     60
      *
     C           *LOVAL    SETLLAB#WPA2
     C                     DO   *HIVAL
     C                     READ AB#WPA2                  98
     C   98                LEAVE
      *
     C                     EXSR #OUT
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ************************************************************
      * OUTPUT AB#WPA2B
      ************************************************************
     C           #OUT      BEGSR
      *
     C                     ADD  1         CNT
     C           CNT       IFEQ 1
     C                     MOVEL'CUST#'   CUST#
     C                     MOVEL'DELV#'   DELV#
     C                     MOVEL'FACTORY' FACTR
     C                     MOVEL'DOCK'    DOCK
     C                     MOVEL'IAF_PART'IAFPRT
     C                     MOVEL'USR_PART'USRPRT
     C                     WRITEAB#WA2B1
     C                     ENDIF
      *
     C                     MOVELF3TOKU    CUST#
     C                     MOVELF3NONY    DELV#
     C                     MOVELF3NONY    FACTR
     C                     MOVELF3NKOJ    DOCK
      *
     C                     MOVELF3SHIN    $SHIN
     C                     CALL 'EDTR02'
     C                     PARM           $SHIN  12
     C                     PARM           $SHIN2 14
     C                     MOVEL$SHIN2    IAFPRT
      *
     C                     MOVELF3MHIN    $MHIN
     C                     CALL 'EDTR02A'
     C                     PARM           $MHIN  20
     C                     PARM           $MHIN2 23
     C                     MOVEL$MHIN2    USRPRT
      *
     C                     WRITEAB#WA2B1
      *
     C                     ENDSR
