     H            Y.
     F** AB#R2D *********************************************************
     F*  ..GM CUM CALCULATION                                           *
     F*                                                                 *
     F*                                                                 *
     F*************************************************** AB#R2T ********
     FAB#PL11 IF  E           K        DISK
     FAB#PP2G UF  E           K        DISK                      A
     FAB#PPCT UF  E           K        DISK                      A
      *----------------------------------------------------
      *----------------------------------------------------
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80W@YMD
     I                                        1   40W@YY
     I                                        5   60W@MM
     I                                        7   80W@DD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *----------------------------------------------------
     C                     MOVEL'GM      'K@KEY1
     C                     MOVEL'CUM     'K@KEY2
     C           K#PCT     CHAINAB#PPCT              90
     C           *IN90     IFEQ *ON
     C                     CLEARAB#PPCT1
     C                     MOVELK@KEY1    CTKEY1
     C                     MOVELK@KEY2    CTKEY2
     C                     WRITEAB#PPCT1
     C                     Z-ADD*ZERO     K@YMD
     C                     ELSE
     C                     Z-ADDCTNBR1    K@YMD
     C           K@YMD     IFEQ *DATE
     C                     MOVE *ON       *INLR
     C                     RETRN
     C                     ENDIF
      *
     C           K@YY      IFLT *YEAR
     C                     EXSR #RSET
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     EXSR #CAL
      *
     C           K#PCT     CHAINAB#PPCT              90
     C           *IN90     IFEQ *OFF
     C                     Z-ADD*DATE     CTNBR1
     C                     UPDATAB#PPCT1
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------------
     C           *INZSR    BEGSR
      *----------------------------------------------------
     C           K#PCT     KLIST
     C                     KFLD           K@KEY1  8
     C                     KFLD           K@KEY2  8
     C           K#AB      KLIST
     C                     KFLD           K@NONY  40
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#2G      KLIST
     C                     KFLD           BATOKU
     C                     KFLD           BANONY
     C                     KFLD           BANUKE
     C                     KFLD           BAMHN1
     C                     KFLD           BAMHN2
     C                     KFLD           BAMHN3
     C                     KFLD           BAMHN4
      *
     C                     ENDSR
      *----------------------------------------------------
     C           #CAL      BEGSR
      *----------------------------------------------------
     C                     Z-ADD0521      K@NONY
     C           K#AB      SETGTAB#PL11
     C           *IN80     DOUEQ*ON
     C           K@NONY    READEAB#PL11                  80
     C           *IN80     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BANOHZ    IFGE *DATE
     C                     LEAVE
     C                     ENDIF
      *
     C           K#2G      CHAINAB#PP2G              90
     C           *IN90     IFEQ *ON
     C                     CLEARAB#PP2G1
     C                     Z-ADDBATOKU    AGCUST
     C                     Z-ADDBANONY    AGNONY
     C                     MOVELBANUKE    AGNUKE
     C                     MOVELBAMHN1    AGMHN1
     C                     MOVELBAMHN2    AGMHN2
     C                     MOVELBAMHN3    AGMHN3
     C                     MOVELBASHN1    AGSHN1
     C                     MOVELBASHN2    AGSHN2
     C                     MOVELBASHN3    AGSHN3
     C                     Z-ADDBASRYO    AGCQTY
     C                     Z-ADDBANOHZ    AGSHDT
     C                     Z-ADD*YEAR     W@YY
     C                     Z-ADD1         W@MM
     C                     Z-ADD1         W@DD
     C                     Z-ADDW@YMD     AGSTDT
     C                     WRITEAB#PP2G1
     C                     ELSE
     C                     ADD  BASRYO    AGCQTY
     C                     Z-ADDBANOHZ    AGSHDT
     C                     UPDATAB#PP2G1
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *----------------------------------------------------
     C           #RSET     BEGSR
      *----------------------------------------------------
     C                     Z-ADD*YEAR     W@YY
     C                     Z-ADD1         W@MM
     C                     Z-ADD1         W@DD
     C           *LOVAL    SETLLAB#PP2G
     C           *IN80     DOUEQ*ON
     C                     READ AB#PP2G                  80
     C           *IN80     IFEQ *OFF
     C                     Z-ADDW@YMD     AGSTDT
     C                     Z-ADD*ZERO     AGCQTY
     C                     UPDATAB#PP2G1
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
