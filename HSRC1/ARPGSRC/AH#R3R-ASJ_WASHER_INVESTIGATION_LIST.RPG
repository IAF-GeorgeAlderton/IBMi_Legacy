TCH61F* TCH61 05/05/09 ADDED OUTQ                *
TCHK1F* TCHK1 06/01/05 ADDED SET DEFAULT PRINTER VALUE
TCHK2F* TCHK2 06/17/09 CHG LANPRT01 --> LANPRT04
     F************************* BASED ON AH#R30,3L
     FAH#PW3R CF  E                    WORKSTN
     FAAPTL01 IF  E           K        DISK
     FAKBPL04 IF  E           K        DISK
     FAKBPL08 IF  E           K        DISK
     FAH#WP30 IF  E           K        DISK                      A
     E                    ER      1  11 60               ERROR MSG
     I            DS
     I                                        1   80YMD
     I                                        1   40YY
     I                                        5   60MM
     I                                        7   80DD
     I            DS
     I                                        1   80AHSKHZ
     I                                        1   40AHSKYY
     I                                        5   60AHSKMM
     I                                        7   80AHSKDD
     I            DS
     I                                        1   80AHKOHZ
     I                                        1   40AHKOYY
     I                                        5   60AHKOMM
     I                                        7   80AHKODD
     I            DS
     I                                        1   60WTIME
     I                                        1   20AHKOHH
     I                                        3   40AHKOSS
     I            DS
     I                                        1   6 LOC1
     I                                        1   1 LOC11
     I                                        2   3 LOC12
     I                                        4   5 LOC13
     I                                        6   6 LOC14
     I            DS
     I                                        1   6 LOC2
     I                                        1   1 LOC21
     I                                        2   3 LOC22
     I                                        4   5 LOC23
     I                                        6   6 LOC24
     I            DS
     I                                        1   6 L1LOC
     I                                        1   1 L1TKR1
     I                                        2   3 L1TKR2
     I                                        4   5 L1TKR3
     I                                        6   6 L1TKR4
     C           KEY       KLIST
     C                     KFLD           HIN1
     C                     KFLD           HIN2
     C                     KFLD           HIN3
      *
     C           KEYA      KLIST
     C                     KFLD           HIN1
     C                     KFLD           HIN2
     C                     KFLD           HIN3
     C                     KFLD           YMD
     C                     KFLD           BIN
      *
     C           KEYB      KLIST
     C                     KFLD           LOC11
     C                     KFLD           LOC12
     C                     KFLD           LOC13
     C                     KFLD           LOC14
      *
     C           KEYC      KLIST
     C                     KFLD           L1SHN1
     C                     KFLD           L1SHN2
     C                     KFLD           L1SHN3
     C                     KFLD           YMD
     C                     KFLD           BIN
      *
     C           *ENTRY    PLIST
     C                     PARM           US     10        USER NAME
     C                     PARM           P1SFLG  1
     C                     PARM           P1RFLG  1
     C                     PARM           INVQ
TCH61C                     PARM           @OUTQ
      *
     C                     Z-ADD*DATE     AHSKHZ
      *
     C                     Z-ADD*DATE     YMD
     C                     Z-ADD01        BIN
     C                     MOVE 'N'       INVQ
TCHK1C                     MOVEL'3'       D@PRT
      *
     C           STP1      TAG
     C                     MOVE *BLANK    HIN1
     C                     MOVE *BLANK    HIN2
     C                     MOVE *BLANK    HIN3
      *
     C                     MOVE 'N'       @SFLG
     C                     MOVE 'N'       @RFLG
     C           STP2      TAG
     C                     EXFMTAH#PW3A1
     C                     SETOF                     010203
     C                     SETOF                     060708
     C                     SETOF                     99
      *
     C*  CMD-1
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
TCH61 * CHECK PRINTER SELECTION
     C                     SELEC
     C           D@PRT     WHEQ *BLANK
     C                     MOVEL'QPRINTC' @OUTQ   8
     C           D@PRT     WHEQ '1'
     C                     MOVEL'LANPRT02'@OUTQ
     C           D@PRT     WHEQ '2'
     C                     MOVEL'LANPRT07'@OUTQ
     C           D@PRT     WHEQ '3'
     C                     MOVEL'LANPRT03'@OUTQ
     C           D@PRT     WHEQ '4'
TCHK2C*                    MOVEL'LANPRT01'@OUTQ
TCHK2C                     MOVEL'LANPRT04'@OUTQ
     C           D@PRT     WHEQ '5'
     C                     MOVEL'QPRINTB '@OUTQ
     C           D@PRT     WHEQ '6'
     C                     MOVEL'QPRINT  '@OUTQ
     C           D@PRT     WHEQ '9'
     C                     MOVEL'QDKT    '@OUTQ
     C                     OTHER
     C                     SETON                     6899
     C                     MOVE ER,11     MSG
     C                     GOTO STP2
     C                     ENDSL
     C*  CHECK INTERNAL PART NUMBER
     C           HIN1      IFEQ *BLANK
     C           HIN2      ANDEQ*BLANK
     C           HIN3      ANDEQ*BLANK
     C           LOC1      ANDEQ*BLANK
     C           LOC2      ANDEQ*BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP2
     C                     END
     C*
     C           HIN1      IFNE *BLANK
     C           KEY       CHAINAAPTL011             10
     C           KEY       SETGTAKBPL04
     C           *IN10     DOUEQ*ON
     C           KEY       REDPEAKBPL04                  10
     C           *IN10     IFEQ *OFF
     C           L1STYY    ANDEQ9999
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C*
     C           *IN10     IFEQ '1'
     C                     SETON                     0199
     C                     MOVE ER,2      MSG
     C                     GOTO STP2
     C                     END
      *
     C                     ENDIF
      *
     C*  CHECK THE DAY OF INVESTIGATION
     C           YMD       IFEQ 0
     C                     SETON                     0299
     C                     MOVE ER,3      MSG
     C                     GOTO STP2
     C                     END
      *
     C           YY        IFLT 1988
     C           MM        ORGT 12
     C           MM        ORLT 01
     C           DD        ORGT 31
     C           DD        ORLT 01
     C                     SETON                     0299
     C                     MOVE ER,4      MSG
     C                     GOTO STP2
     C                     END
      *
     C* TIME  & BIN CHECK
     C           BIN       IFEQ 0
     C                     SETON                     0399
     C                     MOVE ER,5      MSG
     C                     GOTO STP2
     C                     END
      *MSK 00.12.05
     C           @SFLG     IFNE 'Y'
     C           @SFLG     ANDNE'N'
     C                     SETON                     0499
     C                     MOVE ER,7      MSG
     C                     GOTO STP2
     C                     END
     C           @RFLG     IFNE 'Y'
     C           @RFLG     ANDNE'N'
     C                     SETON                     0599
     C                     MOVE ER,8      MSG
     C                     GOTO STP2
     C                     END
      * LOCATION CHECK
     C           LOC2      IFEQ *BLANK
     C           LOC1      ANDNE*BLANK
     C                     MOVE LOC1      LOC2
     C                     ENDIF
      *
     C           LOC2      IFLT LOC1
     C                     SETON                     060799
     C                     MOVE ER,9      MSG
     C                     GOTO STP2
     C                     ENDIF
      *
     C           INVQ      IFNE 'Y'
     C           INVQ      ANDNE'N'
     C                     SETON                     0899
     C                     MOVE ER,10     MSG
     C                     GOTO STP2
     C                     ENDIF
      *
     C  NKE                GOTO STP2
      *
      *MSK 00.12.05
     C                     MOVE @SFLG     P1SFLG
     C                     MOVE @RFLG     P1RFLG
     C*  ADDTION
     C           HIN1      IFNE *BLANK
     C                     SETOF                     90
     C           KEYA      CHAINAH#WP301             90
     C           *IN90     IFEQ '0'
     C           AHSKJY    IFEQ 'D'
     C           AHSKHZ    ANDLE*DATE
     C                     GOTO STP2
     C                     END
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,6      MSG
     C                     GOTO STP2
     C                     END
      *
     C                     Z-ADD*DATE     AHKOHZ
     C                     TIME           WTIME
     C                     MOVELUS        AHKOME
     C                     MOVELHIN1      AHHIN1
     C                     MOVELHIN2      AHHIN2
     C                     MOVELHIN3      AHHIN3
     C                     Z-ADDYMD       AHYMD
     C                     Z-ADDBIN       AHBIN
      *
     C                     SETON                     U1
     C   90                WRITEAH#WP301
      *
     C                     ELSE
     C           KEYB      SETLLAKBPL08
     C           *IN80     DOUEQ*ON
     C                     READ AKBPL08                  80
     C           *IN80     IFEQ *OFF
     C           L1SKJY    ANDEQ*BLANK
     C           L1STYY    ANDEQ9999
     C           L1LOC     IFGT LOC2
     C                     LEAVE
     C                     ENDIF
      *
     C           KEYC      CHAINAH#WP301             90
     C           *IN90     IFEQ '0'
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADD*DATE     AHKOHZ
     C                     TIME           WTIME
     C                     MOVELUS        AHKOME
     C                     MOVELL1SHN1    AHHIN1
     C                     MOVELL1SHN2    AHHIN2
     C                     MOVELL1SHN3    AHHIN3
     C                     Z-ADDYMD       AHYMD
     C                     Z-ADDBIN       AHBIN
      *
     C                     SETON                     U1
     C                     WRITEAH#WP301
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
      *
     C                     GOTO STP1
      *
**  ERR
E-01 INPUT INTRAL COMPANY PART NO. OR LOCATION CODE.
E-02 THERE ISN'T INT CO P/N IN LEVELD PROD FIXED ORDERING F
E-03 INPUT INVESTIGATION DAY
E-04 INVESTIGATION DAY ISN'T RIGHT
E-05 INPUT INVESTIGATION TIME OR BIN
E-06 ADD WAS APPOINTED, BUT M/F EXIST.
E-07 SHIPMENT INFORMATION IS < Y/N >.
E-08 SATURDAY KANBAN INFOMATION IS < Y/N >
E-09 LOCATION CODE ERROR.
E-10 INVENTORY INFOMATION IS < Y/N >
E-11 PRINTER SELECTION ERROR
