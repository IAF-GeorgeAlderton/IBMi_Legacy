     C           1         DO   10        XX
     C           CNK,XX    IFNE 0
     C           CNB,XX    ANDEQ0
     C           CNK,XX    IFLT SDATE
     C           CNB,XX    IFEQ 0
     C                     Z-ADD0         ZZ      20
     C           XX        ADD  81        ZZ
     C                     MOVEA'1'       *IN,ZZ
     C                     ELSE
      *
     C           CNK,XX    IFLT CNB,XX
     C                     Z-ADD0         ZZ
     C           XX        ADD  81        ZZ
     C                     MOVEA'1'       *IN,ZZ
     C                     END
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C***        *IN92     IFEQ '1'
