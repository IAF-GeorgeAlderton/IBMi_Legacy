     C                     ENDSR
     C*----------------------------------------------------
     C*  RE-PRINT-  SUB ROUTINE
     C*----------------------------------------------------
     C           #REPR     BEGSR
      *
     C                     MOVELSG,D      D2ASG
     C                     Z-ADDHK,D      D2AHK
      *
     C           *INKC     DOWEQ*OFF
     C           *INKE     ANDEQ*OFF
      *
     C                     EXFMTCA#PW014
      *
     C           *INKE     IFEQ *ON
     C                     CLEARCAAPP081
     C                     MOVEL@@USER    C8CRUS
     C                     Z-ADDSDATE     C8CRDT
     C                     Z-ADDSTIME     C8CRTM
     C                     Z-ADD0111      C8TBCD
     C                     Z-ADD@@HKHZ    C8DTHZ
     C                     Z-ADD@@HKHB    C8DTBB
     C                     MOVELWWZETI    C8SGNO
     C                     MOVELWWRTNO    C8STNO
     C                     WRITECAAPP081
     C                     Z-ADD0         AANO
     C                     MOVEL*BLANK    AASK
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           EREPR     ENDSR
     C*----------------------------------------------------
     C*  DUMMY UPDATE
     C*----------------------------------------------------
     C           #DUMM     BEGSR
     C           *LOVAL    READECAAPP081                 88
     C                     UPDATCAAPP081
     C           EDUMM     ENDSR
      *-------------------------------------------------------------------------
      *          #CA#91    CA#PP91 CHECK
      *-------------------------------------------------------------------------
     C           #CA#91    BEGSR
      *
     C                     MOVE *BLANK    NC,Y
     C           STKEY4    CHAINCA#PP91              91
     C           *IN91     IFEQ '0'
     C           S9GSJY    ANDEQ*BLANK
     C                     MOVE '*'       NC,Y
     C                     ENDIF
      *
     C           Y         DIV  12        @DIV    20
     C                     MVR            @AMR    20
     C           C6FFLG    IFEQ *BLANK
     C                     SELEC
     C           @AMR      WHEQ 1
     C                     SETOF                     22
     C           @AMR      WHEQ 2
     C                     SETOF                     23
     C           @AMR      WHEQ 3
     C                     SETOF                     24
     C           @AMR      WHEQ 4
     C                     SETOF                     26
     C           @AMR      WHEQ 5
     C                     SETOF                     27
     C           @AMR      WHEQ 6
     C                     SETOF                     53
     C           @AMR      WHEQ 7
     C                     SETOF                     54
     C           @AMR      WHEQ 8
     C                     SETOF                     55
     C           @AMR      WHEQ 9
     C                     SETOF                     56
     C           @AMR      WHEQ 10
     C                     SETOF                     93
     C           @AMR      WHEQ 11
     C                     SETOF                     96
     C           @AMR      WHEQ 0
     C                     SETOF                     97
     C                     ENDSL
     C                     ENDIF
      *
     C           ECA#91    ENDSR
      *-------------------------------------------------------------------------
      *          #IN09     MRHPP91 UPDATE
      *-------------------------------------------------------------------------
     C           #IN09     BEGSR
      *
     C                     Z-ADD1         Z       50
     C***        @CONT     IFNE 0
     C***        @CONT     MULT 12        Z
     C***                  ADD  1         Z
     C***                  ENDIF
     C                     DO   12
     C           NC,Z      IFNE *BLANK
     C           NC,Z      ANDNE'*'
     C                     SETON                     1899
     C                     MOVELER,21     MSG
     C                     GOTO EIN09
     C                     ENDIF
     C                     ADD  1         Z
     C                     ENDDO
      *
      *
     C                     Z-ADD1         Z       50
     C***        @CONT     IFNE 0
     C***        @CONT     MULT 12        Z
     C***                  ADD  1         Z
     C***                  ENDIF
     C                     DO   12
      *
     C                     MOVELSG,Z      K@SGNO
     C                     Z-ADDHK,Z      K@HKDB
      *
     C           STKEY5    KLIST
     C                     KFLD           K@ZETI
     C                     KFLD           K@RTNO
     C                     KFLD           K@HKDT
      *
     C           STKEY5    CHAINCA#PP91              91
S1   C           *IN91     IFEQ '0'                        登録有り
      *削除ブランク、＊無し＝削除UPDATE
S2   C           S9GSJY    IFEQ *BLANK
S3   C           NC,Z      IFEQ *BLANK
     C                     MOVEL'D'       S9GSJY
     C                     Z-ADDSDATE     S9GSHZ
     C                     Z-ADDSDATE     S9GKHZ
     C                     Z-ADDSTIME     S9GKTM
     C                     MOVEL@@PGM     S9GKPG
     C                     MOVEL@@USER    S9GKNM
     C                     UPDATCA#PP911
E3   C                     ENDIF
      *削除済み、＊有り＝ UPDATE
X2   C                     ELSE
S3   C           NC,Z      IFEQ '*'
     C                     MOVEL*BLANK    S9GSJY
     C                     Z-ADD0         S9GSHZ
     C                     Z-ADDSDATE     S9GKHZ
     C                     Z-ADDSTIME     S9GKTM
     C                     MOVEL@@PGM     S9GKPG
     C                     MOVEL@@USER    S9GKNM
     C                     UPDATCA#PP911
E3   C                     ENDIF
E2   C                     ENDIF
      *
X1   C                     ELSE                            登録無し
S2   C           NC,Z      IFEQ '*'
     C                     MOVEL*BLANK    S9GSJY
     C                     Z-ADD0         S9GSHZ
     C                     Z-ADDSDATE     S9GKHZ
     C                     Z-ADDSTIME     S9GKTM
     C                     MOVEL@@PGM     S9GKPG
     C                     MOVEL@@USER    S9GKNM
     C                     MOVELK@ZETI    S9THI1
     C                     MOVELK@RTNO    S9THI2
     C                     MOVELK@HKDT    S9HAHZ
     C                     WRITECA#PP911
E2   C                     ENDIF
E1   C                     ENDIF
      *
     C                     ADD  1         Z
     C                     ENDDO
