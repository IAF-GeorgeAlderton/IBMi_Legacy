     C           MINO3     BEGSR
     C                     Z-ADD9         YY      20
     C                     Z-ADD1         XX
     C           1         DO   10        XX
     C           YY        IFLE 12
     C           CNK,YY    IFNE 0
     C           CNB,YY    ANDEQ0
     C           CNK,YY    IFLT SDATE
     C           CNB,YY    IFEQ 0
     C                     Z-ADD0         ZZ      20
     C           XX        ADD  81        ZZ
     C                     MOVEA'1'       *IN,ZZ
     C                     ELSE
      *
     C           CNK,YY    IFLT CNB,YY
     C                     Z-ADD0         ZZ
     C           XX        ADD  81        ZZ
     C                     MOVEA'1'       *IN,ZZ
