      *--------*
      *  KEYS  *
      *--------*
     C           *ENTRY    PLIST
     C                     PARM           PUS    10
     C                     PARM           PRTFLG  1
      *
     C           KEY1      KLIST
     C                     KFLD           ZETI
     C                     KFLD           KOJO
     C                     KFLD           KDAI
     C                     KFLD           LKOT
     C                     KFLD           LOTN
     C                     KFLD           SYYY
     C                     KFLD           SYMM
     C                     KFLD           SYDD
     C                     KFLD           SYJI
     C                     KFLD           SYFN
      *--------------------*
      *  ALDR42 EXECUSION  *
     C*--------------------*
     C           *IN80     IFEQ '0'
     C                     SETON                     80
     C                     MOVE PUS       US     10
     C                     ENDIF
      *
     C                     MOVE *BLANK    EROR    1
     C                     SETOF                     50
     C           KEY1      CHAINALDPL401             50
     C           *IN50     IFEQ '0'
     C                     MOVE '*'       PRTFLG  1
     C                     MOVE '1'       EROR
     C                     EXSR LSTSUB
     C                     GOTO EXT
     C                     ENDIF
     C                     EXSR OUTSUB
     C           EXT       TAG
     CLR                   RETRN
      *----------*
      *  OUTSUB  *
      *----------*
     C           OUTSUB    BEGSR
     C                     Z-ADD*YEAR     A5KSYY
     C                     Z-ADD*MONTH    A5KSMM
     C                     Z-ADD*DAY      A5KSDD
     C                     TIME           WTIME
     C                     Z-ADDWJI       A5KSJI
     C                     Z-ADDWFN       A5KSPN
     C                     MOVE US        A5KSNA
     C                     MOVE KANS      A5KANS
     C                     MOVE ZETI      A5ZETI
     C                     MOVE KOJO      A5KOJO
     C                     MOVE KDAI      A5KDAI
     C                     MOVE LKOT      A5LKOT
     C                     Z-ADDLOTN      A5LOTN
     C                     MOVE SHN1      A5SHN1
     C                     MOVE SHN2      A5SHN2
     C                     MOVE SHN3      A5SHN3
     C                     Z-ADDSYYY      A5SYYY
     C                     Z-ADDSYMM      A5SYMM
     C                     Z-ADDSYDD      A5SYDD
     C                     Z-ADDSYJI      A5SYJI
     C                     Z-ADDSYFN      A5SYFN
     C                     MOVE TKR1      A5TKR1
     C                     MOVE TKR2      A5TKR2
     C                     MOVE TKR3      A5TKR3
     C                     MOVE TKR4      A5TKR4
     C                     MOVE OPER      A5OPER
     C                     MOVE MHN1      A5MHN1
     C                     MOVE MHN2      A5MHN2
     C                     MOVE MHN3      A5MHN3
     C                     MOVE MHN4      A5MHN4
     C                     Z-ADDSSYS      A5SSYS
     C                     Z-ADDUSYS      A5USYS
     C                     Z-ADDNONY      A5NONY
     C                     MOVE NKOJ      A5NKOJ
     C                     MOVE NUKE      A5NUKE
     C                     MOVE TOPX      A5TOPX
     C                     MOVE EFF       A5SALE
     C                     WRITEALDPP401
     C                     ENDSR
      *----------*
      *  LSTSUB  *
      *----------*
     C           LSTSUB    BEGSR
     C                     EXCPTDAT
     C                     ENDSR
      **********************************************************
