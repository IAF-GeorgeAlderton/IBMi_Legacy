     H            Y.                                    1
     H** UTLR15B ***************************************************************
     H*  GET PROCESS/MACHINE BY PART/LOCATION
     H*  FROM AAMPP11
     H*  JW   09/27/2019
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR15B'
     F*                    PARM           PSHIN1  5
     F*                    PARM           PSHIN2  5
     F*                    PARM           PSHIN3  2
     F*                    PARM           PLOC    6
     F*                    PARM           PPRC1   3
     F*                    PARM           PPRC    3
     F*                    PARM           PMCN1   3
     F*                    PARM           PMCN    3
     F*                    PARM           PBMN1   4
     F*                    PARM           PBMN    4
     F*                    PARM           PBNAM  10
     F*                    PARM           PPRCA   3
     F*                    PARM           PMCNA   3
     F*                    PARM           PBMNA   4
     F*                    PARM           PRTN    1
     F*   IN  PSHIN1:  5A IAF PART1
     F*       PSHIN2:  5A IAF PART2
     F*       PSHIN3:  2A IAF PART3
     F*       PLOC  :  6A LOCATION
     F*   OUT PPRC1 :  3A FIRST    PROCESS
     F*       PPRC  :  3A LOCATION PROCESS
     F*       PMCN1 :  3A FIRST    MACHINE
     F*       PMCN  :  3A LOCATION MACHINE
     F*       PBMN1 :  4A FIRST    DEPT
     F*       PBMN  :  4A LOCATION DEPT
     F*       PBNAM : 10A DEPT NAME
     F*       PPRCA :  3A PRIOR LOC PROCESS  (USE WHEN PROC=TSL)
     F*       PMCNA :  3A PRIOR LOC MACHINE  (")
     F*       PBMNA :  4A PRIOR LOC DEPT     (")
     F*       PRTN  :  1A RETURN FLAG (BLANK=OK, *=ERROR)
     H**************************************************************************
     FAAMPL11 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
      **************************************************************************
      * TABLE
     E                    MCN        15  3
     E                    LOC        15  6
     E                    PRC        15  3
     E                    BMN        15  4 0
     I* PROCESS TABLE
     I            DS
     I                                        1  45 PRC
     I                                        1   3 CKKO01
     I                                        4   6 CKKO02
     I                                        7   9 CKKO03
     I                                       10  12 CKKO04
     I                                       13  15 CKKO05
     I                                       16  18 CKKO06
     I                                       19  21 CKKO07
     I                                       22  24 CKKO08
     I                                       25  27 CKKO09
     I                                       28  30 CKKO10
     I                                       31  33 CKKO11
     I                                       34  36 CKKO12
     I                                       37  39 CKKO13
     I                                       40  42 CKKO14
     I                                       43  45 CKKO15
     I* MACHINE TABLE
     I            DS
     I                                        1  45 MCN
     I                                        1   3 CKKB01
     I                                        4   6 CKKB02
     I                                        7   9 CKKB03
     I                                       10  12 CKKB04
     I                                       13  15 CKKB05
     I                                       16  18 CKKB06
     I                                       19  21 CKKB07
     I                                       22  24 CKKB08
     I                                       25  27 CKKB09
     I                                       28  30 CKKB10
     I                                       31  33 CKKB11
     I                                       34  36 CKKB12
     I                                       37  39 CKKB13
     I                                       40  42 CKKB14
     I                                       43  45 CKKB15
     I* DEPT TABLE
     I            DS
     I                                        1  600BMN
     I                                        1   40CKBM01
     I                                        5   80CKBM02
     I                                        9  120CKBM03
     I                                       13  160CKBM04
     I                                       17  200CKBM05
     I                                       21  240CKBM06
     I                                       25  280CKBM07
     I                                       29  320CKBM08
     I                                       33  360CKBM09
     I                                       37  400CKBM10
     I                                       41  440CKBM11
     I                                       45  480CKBM12
     I                                       49  520CKBM13
     I                                       53  560CKBM14
     I                                       57  600CKBM15
     I* LOCATION TABLE
     I            DS
     I                                        1  90 LOC
     I                                        1   6 CKNB01
     I                                        7  12 CKNB02
     I                                       13  18 CKNB03
     I                                       19  24 CKNB04
     I                                       25  30 CKNB05
     I                                       31  36 CKNB06
     I                                       37  42 CKNB07
     I                                       43  48 CKNB08
     I                                       49  54 CKNB09
     I                                       55  60 CKNB10
     I                                       61  66 CKNB11
     I                                       67  72 CKNB12
     I                                       73  78 CKNB13
     I                                       79  84 CKNB14
     I                                       85  90 CKNB15
     I* SYSTEM TIME
     I            DS
     I                                        1  140@SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *----------------------------------------------
     C           *ENTRY    PLIST
     C                     PARM           PSHIN1  5
     C                     PARM           PSHIN2  5
     C                     PARM           PSHIN3  2
     C                     PARM           PLOC    6
     C                     PARM           PPRC1   3
     C                     PARM           PPRC    3
     C                     PARM           PMCN1   3
     C                     PARM           PMCN    3
     C                     PARM           PBMN1   4
     C                     PARM           PBMN    4
     C                     PARM           PBNAM  10
     C                     PARM           PPRCA   3
     C                     PARM           PMCNA   3
     C                     PARM           PBMNA   4
     C                     PARM           PRTN    1
      *
     C                     MOVE *BLANK    PPRC1
     C                     MOVE *BLANK    PPRC
     C                     MOVE *BLANK    PMCN1
     C                     MOVE *BLANK    PMCN
     C                     MOVE *BLANK    PBMN1
     C                     MOVE *BLANK    PBMN
     C                     MOVE *BLANK    PBNAM
     C                     MOVE *BLANK    PPRCA
     C                     MOVE *BLANK    PMCNA
     C                     MOVE *BLANK    PBMNA
     C                     MOVE *BLANK    PRTN
      *
     C                     TIME           @SDATE
      *
     C           K#AMP     KLIST
     C                     KFLD           PSHIN1
     C                     KFLD           PSHIN2
     C                     KFLD           PSHIN3
      *
     C           K#AMP     SETLLAAMPL11
     C           *IN99     DOWEQ*OFF
     C           K#AMP     READEAAMPL11                  99
     C           *IN99     IFEQ *OFF
     C           CKSKJY    ANDEQ*BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN99     IFEQ *ON
     C                     MOVE '*'       PRTN
     C                     ELSE
     C           1         DO   15        IX      20
     C                     MOVELPRC,1     PPRC1
     C                     MOVELMCN,1     PMCN1
     C                     MOVELBMN,1     PBMN1
      *
     C           PLOC      IFEQ LOC,IX
     C                     MOVELMCN,IX    PMCN
     C                     MOVELPRC,IX    PPRC
     C                     MOVELBMN,IX    PBMN
     C                     LEAVE
     C                     ENDIF
      *
      * PRIOR PROCESS FROM LOCATION
     C                     MOVELMCN,IX    PMCNA
     C                     MOVELPRC,IX    PPRCA
     C                     MOVELBMN,IX    PBMNA
      *
     C                     ENDDO
     C                     ENDIF
      * GET DEPARTMENT NAME
     C                     MOVELPBMN      NUM4    40
     C           NUM4      CHAINFGBPL01              91
     C  N91                MOVELB2SMEI    PBNAM
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
