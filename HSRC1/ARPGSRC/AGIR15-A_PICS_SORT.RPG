     CSR         ESB452    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB453    BEGSR
      *
     C                     Z-ADD*HIVAL    MIN     30
     C                     Z-ADD1         AA
     C           AA        DOWLEWKCIBI
     C           KAI,AA    IFLT MIN
     C                     Z-ADDKAI,AA    MIN
     C                     ENDIF
     C                     ADD  1         AA
     C                     ENDDO
      *
     CSR         ESB453    ENDSR
      *----------------------------------------------------*
      * BIN                                                *
      *----------------------------------------------------*
     CSR         #SB460    BEGSR
      *
     C           KEYF#2    KLIST
     C                     KFLD           KKAPHZ  80
     C                     KFLD           KKAPBB  20
     C                     KFLD           W0SORT
     C                     Z-ADDWKTOHZ    KKAPHZ
     C                     Z-ADDI         KKAPBB
     C                     Z-ADDWKCIBI    WKKEIS  20
      *
     C                     Z-ADDI         ##BIN   20
     C                     Z-ADD*HIVAL    MNHAKO  81
     C                     Z-ADD1         ##Z     30
     C           ##Z       DOWLEWKCIBI
     C                     EXSR #SB461
     C                     ADD  1         KKAPBB
     C           KKAPBB    IFGT WKCIBI
     C                     Z-ADDWKYOHZ    KKAPHZ
     C                     Z-ADD1         KKAPBB
     C                     ENDIF
     C                     ADD  1         ##Z
     C                     SUB  1         WKKEIS
     C                     ENDDO
      *
     CSR         ESB460    ENDSR
      *----------------------------------------------------*
      * BIN                                                *
      *----------------------------------------------------*
     CSR         #SB461    BEGSR
      *
     C                     Z-ADD0         ZZHAKO  70
     C           KEYF#2    CHAINAGIPL511             27
     C           *IN27     IFEQ '0'
     C                     Z-ADDF#HAKO    ZZHAKO
     C                     ELSE
     C                     Z-ADD0         ZZHAKO
     C                     ENDIF
      *
     C                     Z-ADD0         KEIS    72
     C                     Z-ADD0         HAKO    81
     C           WKKEIS    IFNE 0
     C           WKCIBI    DIV  WKKEIS    KEIS
     C                     ENDIF
     C                     Z-ADD1         KEIS
     C           ZZHAKO    MULT KEIS      HAKO
      *
     C                     Z-ADDKKAPBB    AA      30
     C           HAKO      IFLT MNHAKO
     C           KAI,AA    ANDEQMIN
     C                     Z-ADDHAKO      MNHAKO
     C                     Z-ADDKKAPBB    ##BIN
     C                     ENDIF
      *
     CSR         ESB461    ENDSR
      *----------------------------------------------------*
      * BIN                                                *
      *----------------------------------------------------*
     CSR         #SB470    BEGSR
      *
     C           KEYC#     KLIST
