      *
     C           *ENTRY    PLIST
     C                     PARM           F04     4
      *
     C                     TIME           WTIME
     C                     Z-ADD0         HMS
     C                     MOVELF04       HMS
     C                     Z-ADD1         I       50
      *
     C                     Z-ADD0         WKHI    81
     C           1         SETLLAGIPP411
     C                     READ AGIPP411                 28
     C           *IN28     IFEQ '0'
     C                     Z-ADDE#HI      WKHI
     C                     ELSE
     C                     Z-ADD0         WKHI
     C                     ENDIF
      *
     C                     Z-ADD0         WKTOHZ  80
     C                     Z-ADD0         WKYOHZ  80
     C                     Z-ADD0         WKCIBI  20
     C                     MOVELF04       HHMM1
     C           0111      CHAINAAIPL111             44
     C           *IN44     IFEQ '0'
     C                     Z-ADDCDTOHZ    WKTOHZ
     C                     Z-ADDCDYOHZ    WKYOHZ
     C                     Z-ADDCDCIBI    WKCIBI
     C                     MOVE CDBI,HH1  I
     C                     ENDIF
      *
     C                     READ AGIWP301                 80
     C           *IN80     DOWEQ'0'
     C                     EXSR #SB400
     C                     READ AGIWP301                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * SELECT                                             *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C                     MOVEL'0'       GET     1
     C                     Z-ADD0         W0HI    81
     C           W0GEKH    DIV  20        W0HI
     C           W0HI      IFLT WKHI
     C                     MOVEL'1'       GET
     C                     ENDIF
      *
     C           GET       IFEQ '1'
     C                     EXSR #SB450
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB450    BEGSR
      *
     C           W0BARL    IFEQ 0
     C                     Z-ADD0         X       30
     C                     ELSE
     C           W0HAKO    DIV  W0BARL    X       30
     C                     ENDIF
      *
     C                     EXSR #SB470
     C                     EXSR #SB453
      *
     C                     Z-ADD1         Y       30
     C           Y         DOWLEX
     C                     EXSR #SB460
     C                     Z-ADDW0BARL    ##HAKO  50
     C           ##BIN     IFGE I
     C                     Z-ADDWKTOHZ    ##APHZ  80
     C                     MOVEL'0'       ##FLG   1
     C                     ELSE
     C                     Z-ADDWKYOHZ    ##APHZ  80
     C                     MOVEL'1'       ##FLG   1
     C                     ENDIF
     C                     Z-ADD##BIN     ##APBB  20
     C                     EXSR #SB451
     C                     EXSR #SB550
     C                     EXSR #SB452
     C                     EXSR #SB453
     C                     ADD  1         Y
     C                     ENDDO
      *
     CSR         ESB450    ENDSR
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB451    BEGSR
      *
     C                     CLEARAGIWP311
     C                     MOVELW0SHN1    W#SHN1
     C                     MOVELW0SHN2    W#SHN2
     C                     MOVELW0SHN3    W#SHN3
     C                     Z-ADD##APHZ    W#APHZ
