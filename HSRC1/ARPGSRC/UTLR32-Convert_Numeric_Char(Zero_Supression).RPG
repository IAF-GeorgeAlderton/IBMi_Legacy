     H            Y.
     F** UTLR32 ***********************************************************
     F*  CONVERT NUMERIC -> CHAR(ZERO SUPRESSION)                         *
     F*  COPIED FROM AB#R2K                                               *
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR32'
     F*                    PARM           PIN    300
     F*                    PARM           POUT   30
     F*   IN  PIN   : 30S 0  NUMBER
     F*   OUT POUT  : 30A    TEXT
     F*   EX.                                                             *
     F*   00000300 --> "300    "      REMOVE LEADING ZEROS                *
     F*********************************************************************
     E                    IN         30  1 0
     E                    OUT        30  1
     F******************************************************************
     I*
     I            DS
     I                                        1  300IN
     I                                        1  300WPIN
     C           *ENTRY    PLIST
     C                     PARM           PIN    300
     C                     PARM           POUT   30
      *
     C                     Z-ADDPIN       WPIN
     C                     MOVE *BLANK    OUT
     C                     SETOF                     90
     C                     Z-ADD*ZERO     I       20
     C                     Z-ADD*ZERO     M       20
     C* SEARCH FIRST
     C           *IN90     DOUEQ'1'
     C                     ADD  1         I
     C           I         IFGT 30
     C                     MOVE *ZERO     OUT,1
     C                     GOTO #END
     C                     END
     C           IN,I      IFNE *ZERO
     C                     SETON                     90
     C                     END
     C                     END
      *
     C           I         DO   30        I
     C                     ADD  1         M
     C                     MOVE IN,I      OUT,M
     C                     END
      *
     C           #END      TAG
     C                     MOVEAOUT       POUT
      *
     C                     SETON                     LR
     C                     RETRN
