     H            Y.
      ** MYBR04 *********************
      *  T.SAKASHITA    2011.10.24  *
      *  I-HASADA 2013/04/03        *
      *   COPY RPG(IAFAYM):CA039R   *
      ********************* MYBR04 **
     FAKGTL04 IF  E           K        DISK
     FAKITL04 IF  E           K        DISK
      *
     C           *ENTRY    PLIST
     C                     PARM           P@KACD  1
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
     C                     PARM           CBKO    20
     C                     PARM           BARA    20
     C                     PARM           BARB    31
      *
     C                     MOVE P@HIN1    K@HIN1  5
     C                     MOVE P@HIN2    K@HIN2  5
     C                     MOVE P@HIN3    K@HIN3  2
      *
     C           HINKEY    KLIST
     C                     KFLD           K@HIN1
     C                     KFLD           K@HIN2
     C                     KFLD           K@HIN3
      *
     C           P@KACD    IFEQ 'P'
     C                     EXSR #AKG
     C                     END
      *
     C           P@KACD    IFEQ 'Q'
     C*                    EXSR #AKI
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
      *
      *-----------------------------------------------------
     C           #AKG      BEGSR
      *
     C           HINKEY    SETLLAKGTL041
      *
     C                     DO   *HIVAL
     C           HINKEY    READEAKGTL041                 77
     C   77                LEAVE
      *
     C           E1SKJY    IFEQ 'D'
     C           E1SKHZ    ANDLE*DATE
     C                     ITER
     C                     END
      *
     C           E1STHZ    IFEQ *ALL'9'
     C                     Z-ADDE1CBKO    CBKO
     C           CBKO      IFEQ 0
     C                     ADD  1         CBKO
     C                     END
     C*                    Z-ADDE1BARA    BARA
     C*                    Z-ADDE1BARB    BARB
     C                     LEAVE
     C                     END
      *
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #AKI      BEGSR
      *
     C           HINKEY    SETLLAKITL041
      *
     C                     DO   *HIVAL
     C           HINKEY    READEAKITL041                 77
     C   77                LEAVE
      *
     C           E2SKJY    IFEQ 'D'
     C           E2SKHZ    ANDLE*DATE
     C                     ITER
     C                     END
      *
     C           E2STHZ    IFEQ *ALL'9'
     C                     Z-ADDE2CBKO    CBKO
     C           CBKO      IFEQ 0
     C                     ADD  1         CBKO
     C                     END
     C*                    Z-ADDE2BARA    BARA
     C*                    Z-ADDE2BARB    BARB
     C                     LEAVE
     C                     END
      *
     C                     ENDDO
      *
     C                     ENDSR
