     C                     END
     C                     END
     C*
     C                     ENDSR
     C*************************************************************************
     C*     3RD SCREEN
     C**************************************************************************
     C           #FMT30    BEGSR
      *
     C                     Z-ADD1         W#RNP3  40
      *
     C                     DO   *HIVAL
     C*
     C                     MOVEL*ON       *IN87
     C                     MOVEL*ON       *IN88
     C                     WRITEFMT099
     C                     Z-ADDW#RNP3    #RCN03
     C                     EXFMTCTL030
     C*
     C  NKJ                MOVELN#MOD3    *IN53
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP3
     C                     END
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN89
     C*
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVEL'99'      @@ID
     C                     LEAVE
     C           *INKL     WHEQ *ON
     C                     MOVEL*BLANK    C2LOT#
