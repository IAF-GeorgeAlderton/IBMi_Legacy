     H            Y.
     F** AL#R45 **************************************
     F*トラック便、ＩＡＦ便当りのパレット数取得    *
     F*        ITS.         2015.05.26               *
     F************************************************
     FAL#PL42 IF  E           K        DISK
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1FIXD  80
     C                     PARM           P1FIXT  60
     C                     PARM           P1TRKB  2
     C                     PARM           P1IAFB  3
     C                     PARM           P9PFTR  30
     C                     PARM           P9PFBI  30
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
     C                     Z-ADD0         P9PFTR
     C                     Z-ADD0         P9PFBI
     C                     EXSR #SB400
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *トラック便
      *-----------------------------------------------------
     CSR         #SB400    BEGSR
      *
     C           KEYC1     KLIST
     C                     KFLD           P1FIXD  80
     C                     KFLD           P1FIXT  60
     C                     KFLD           P1TRKB  2
      *
     C           KEYC1     SETLLAL#PL421
     C           KEYC1     READEAL#PL421                 81
     C           *IN81     DOWEQ'0'
     C           C4SKJY    IFEQ 'D'
     C           C4SKHZ    ANDLESDATE
     C                     ELSE
     C                     ADD  1         P9PFTR
     C                     ENDIF
     C           KEYC1     READEAL#PL421                 81
     C                     ENDDO
      *
     C           KEYC2     KLIST
     C                     KFLD           P1FIXD  80
     C                     KFLD           P1FIXT  60
     C                     KFLD           P1TRKB  2
     C                     KFLD           P1IAFB  3
      *
     C           KEYC2     SETLLAL#PL421
     C           KEYC2     READEAL#PL421                 81
     C           *IN81     DOWEQ'0'
     C           C4SKJY    IFEQ 'D'
     C           C4SKHZ    ANDLESDATE
     C                     ELSE
     C                     ADD  1         P9PFBI
     C                     ENDIF
     C           KEYC2     READEAL#PL421                 81
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
