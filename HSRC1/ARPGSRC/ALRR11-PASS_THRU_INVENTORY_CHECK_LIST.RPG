      **************************************************************************
     FALRWP10 IP  E           K        DISK
     FGDGPL19 IF  E           K        DISK
     FGDGPL27 IF  E           K        DISK
     FALRWP11 UF  E           K        DISK                      A
      **************************************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
     I            DS
     I                                        1   80SDAT8
     I                                        1   40SDYY
     I                                        5   60SDMM
     I                                        7   80SDDD
     I            DS
     I                                        1   80IESKHZ
     I                                        1   40IESKOY
     I                                        5   60IESKOM
     I                                        7   80IESKOD
     I            DS
     I                                        1   80IETOHZ
     I                                        1   40IETOYY
     I                                        5   60IETOYM
     I                                        7   80IETOYD
     I            DS
     I                                        1   80P1HZ
     I                                        1   40P1YY
     I                                        5   60P1MM
     I                                        7   80P1DD
     I            DS
     I                                        1   80P2HZ
     I                                        1   40P2YY
     I                                        5   60P2MM
     I                                        7   80P2DD
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C                     TIME           SDATE
     C                     Z-ADDWDATE     SDAT8
      * 3 MONTHS AGO
     C                     MOVE WDATE     QQDATE  8
     C                     MOVE '-'       QQPORM  1        + OR -
     C                     MOVE '0090'    QQDAYS  4
     C                     MOVE *BLANK    QQRDAT  8
     C                     MOVE *BLANK    QQRTN   1
     C                     CALL 'DATR12'                   CALCULATE DATE
     C                     PARM           QQDATE  8
     C                     PARM           QQPORM  1        + OR -
     C                     PARM           QQDAYS  4
     C                     PARM           QQRDAT  8
     C                     PARM           QQRTN   1
     C                     MOVE QQRDAT    P2HZ    80
      *
     C**
     C           KEY01     KLIST
     C                     KFLD           W1PRT1
     C                     KFLD           W1PRT2
     C                     KFLD           W1PRT3
     C                     KFLD           P2YY
     C                     KFLD           P2MM
     C                     KFLD           P2DD
     C**
     C           KEY02     KLIST
     C                     KFLD           W1PRT1
     C                     KFLD           W1PRT2
     C                     KFLD           W1PRT3
     C**
     C           KEY01     SETLLGDGPL27              19
     C                     DO   *HIVAL
     C           KEY02     READEGDGPL27                  19
     C   19                LEAVE
     C           ICSKJY    IFEQ *BLANK
     C                     MOVELIEINVO    WKIN2   2
     C           WKIN2     IFNE 'UA'
     C                     Z-ADDIETOHZ    WKINHZ  80
     C                     Z-ADDIESBOX    WKBOX   50
     C                     MOVELIEINVO    WKINVO  6
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *----------------------------------------------------*
      * SEARCH  GDGPP15   ORDERING BUT NOT SHIPPED         *
      *----------------------------------------------------*
      * 2 MONTHS AGO
     C                     MOVE WDATE     QQDATE  8
     C                     MOVE '-'       QQPORM  1        + OR -
     C                     MOVE '0060'    QQDAYS  4
     C                     MOVE *BLANK    QQRDAT  8
     C                     MOVE *BLANK    QQRTN   1
     C                     CALL 'DATR12'                   CALCULATE DATE
     C                     PARM           QQDATE  8
     C                     PARM           QQPORM  1        + OR -
     C                     PARM           QQDAYS  4
     C                     PARM           QQRDAT  8
     C                     PARM           QQRTN   1
     C                     MOVE QQRDAT    P1HZ    80
      *
     C           KEY03     KLIST
     C                     KFLD           W1PRT1
     C                     KFLD           W1PRT2
     C                     KFLD           W1PRT3
     C                     KFLD           P1YY
     C                     KFLD           P1MM
     C                     KFLD           P1DD
      *
     C           KEY03     SETLLGDGPL19              25
     C                     DO   *HIVAL
     C           KEY02     READEGDGPL19                  25
     C   25                LEAVE
     C           *IN25     IFEQ '0'
     C           ICSKJY    ANDEQ*BLANK
     C           ICINVO    ANDEQ*BLANK
     C                     Z-ADD0         WKINHZ
     C                     Z-ADDICMAIS    WKBOX
     C                     MOVEL*BLANK    WKINVO
     C                     EXSR #SB500
     C                     ENDIF
      *
     C                     ENDDO
      *
      *----------------------------------------------------*
      * UPDATE  ALRWP11                                    *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
     C**
     C           KEY04     KLIST
     C                     KFLD           W1PRT1
     C                     KFLD           W1PRT2
     C                     KFLD           W1PRT3
     C                     KFLD           WKINHZ
     C                     KFLD           WKINVO
      *
     C           KEY04     CHAINALRWP11              33
     C           *IN33     IFEQ '0'
     C                     ADD  WKBOX     W0BOX
     C                     UPDATALRWP111
     C                     ELSE
     C                     MOVELW1PRT1    W0PRT1
     C                     MOVELW1PRT2    W0PRT2
     C                     MOVELW1PRT3    W0PRT3
     C                     Z-ADDWKINHZ    W0INHZ
     C                     Z-ADDWKBOX     W0BOX
     C                     MOVELWKINVO    W0INVO
     C                     WRITEALRWP111
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
