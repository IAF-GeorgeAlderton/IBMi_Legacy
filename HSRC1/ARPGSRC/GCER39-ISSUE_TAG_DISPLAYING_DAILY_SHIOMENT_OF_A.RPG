      *----------------------------------*
      * 所番地出荷箱数表示ラベル　発行 *
      *----------------------------------*
     C           K#KEY     KLIST
     C                     KFLD           PART1
     C                     KFLD           PART2
     C                     KFLD           PART3
      *
     C  N56                GOTO LR
     C           *IN55     IFEQ '0'
     C                     MOVE '.'       CNM
     C                     Z-ADD1         J       10
     C                     EXSR SYOKI
     C                     SETON                     5560
     C                     END
     C           *IN60     IFEQ '1'
     C                     SETOF                     60
     C                     Z-ADD1         H       20
     C           1         DO   20        H
     C                     MOVE '0'       *IN,H
     C                     END
     C                     END
     C                     EXSR KANJI
     C                     MOVE STOKOR    TKOB,J
     C                     Z-ADDSTOKI     TOKI,J
     C                     Z-ADDSBAR      BARA,J
     C                     Z-ADDSMAXH     MAXH,J
     C           SBAR      IFNE *ZERO
     C                     Z-ADD0         BA      20
     C           10        ADD  J         BA
     C                     MOVE '1'       *IN,BA
     C                     END
     C           SHAKO     IFEQ 0
     C                     MOVE '1'       *IN,J
     C                     ADD  1         J
     C                     GOTO END
     C                     END
     C           SSENY     IFEQ 'S'
     C                     Z-ADD0         H
     C           J         ADD  5         H
     C                     MOVE '1'       *IN,H
     C                     END
     C           SMAXH     IFNE 0
     C           J         ADD  15        MA      20
     C                     MOVE '1'       *IN,MA
     C                     END
      *
     C                     MOVELSHAKO     HK1
     C                     MOVE SHAKO     HK2
     C           HK12      IFEQ '00'
     C                     MOVE *BLANK    HK12
     C                     ELSE
     C           HK11      IFEQ '0'
     C                     MOVE *BLANK    HK11
     C                     END
     C                     END
     C                     MOVE HK        HAKO,J
      *
     C                     MOVE SMISU     MISU,J
     C                     ADD  1         J
     C           END       TAG
     C           J         IFEQ 6
     C                     SETON                     60
     C                     Z-ADD1         J       10
     C                     WRITEGCEPR301
     C                     EXSR SYOKI
     C                     END
     C           LR        TAG
     CLR                   EXSR OWARI
      *--------------------------*
      * 漢字入力　サブルーチン *
      *--------------------------*
     C           KANJI     BEGSR
      *
     C                     MOVE *BLANK    @ASJ    1
     C                     MOVELSHNBAN    PART
     C           K#KEY     SETLLAAPTL01
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAAPTL01                  90
     C           *IN90     IFEQ *OFF
     C           L5STHZ    ANDEQ99999999
     C                     MOVE 'A'       @ASJ    1
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           K#KEY     SETLLAANPL06
     C           *IN90     DOUEQ*ON
     C           K#KEY     READEAANPL06                  90
     C           *IN90     IFEQ *OFF
     C           L7STHZ    ANDEQ99999999
     C                     MOVE 'A'       @ASJ    1
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE KTO,1     CTOK,J
     C                     MOVE KHK,1     CHIA,J
     C           @ASJ      IFEQ *BLANK
     C                     MOVELKHA,1     CHAK,J
     C                     ELSE
     C                     MOVELKHA,2     CHAK,J
     C                     ENDIF
      *
     C                     MOVE KKN,1     CKAN,J
     C                     MOVE KMI,1     CMAI,J
     C                     ENDSR
      *--------------*
      * 初期値設定 *
      *--------------*
     C           SYOKI     BEGSR
     C                     MOVE *BLANK    TKOB
     C                     MOVE *BLANK    CTOK
     C                     Z-ADD0         BARA
     C                     MOVE *BLANK    CHIA
     C                     MOVE *BLANK    CHAK
     C                     MOVE *BLANK    CKAN
     C                     MOVE *BLANK    CMAI
     C                     MOVE *BLANK    HAKO
     C                     MOVE *BLANK    MISU
     C                     Z-ADD0         TOKI
     C                     Z-ADD0         MAXH
     C                     ENDSR
      *------------------------*
      * 終了　サブ・ルーチン *
      *------------------------*
     C           OWARI     BEGSR
     C           TKOB,1    IFNE *BLANK
     C                     Z-ADD0         K       20
     C                     Z-ADD1         H
     C                     SETOF                     77
     C           1         DO   5         H
     C           TKOB,H    IFEQ *BLANK
     C                     SETON                     77
     C                     END
     C  N77                END
     C                     ADD  5         H
     C           H         DO   10        K
     C                     MOVE '0'       *IN,K
     C                     END
     C                     Z-ADD0         BAR     50
     C                     XFOOTBARA      BAR
     C           BAR       IFEQ *ZERO
     C                     SETON                     77
     C                     END
     C                     WRITEGCEPR301
     C                     END
     C                     ENDSR
