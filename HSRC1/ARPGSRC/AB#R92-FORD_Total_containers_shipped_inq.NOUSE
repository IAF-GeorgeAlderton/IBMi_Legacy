     H            Y/
     FAB#PW92 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     FAB#PL1D IF  E           K        DISK
      *
     E                    CMD     1   2 78
     E*                   MSG     1   1 78
      *
     I            DS
     I                                        1   80BANOHZ
     I                                        1   40BANOYY
     I                                        5   60BANOMM
     I                                        7   80BANODD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *
     C*          *ENTRY    PLIST
     C*                    PARM           PUSR   06
     C*                    PARM           PYYYY   40
     C*                    PARM           PMM     20
     C*                    PARM           PDD     20
     C*                    PARM           @@IDX   2
     C* ALDWL04
     C           KEY1      KLIST
     C                     KFLD           KATOKU  40
     C                     KFLD           D@YYYY                       G)
     C                     KFLD           D@MM                         G)
     C                     KFLD           D@DD                         G)
      *--------------------------------------------------
     C           @@ID      DOUEQ'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C           @@ID      CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *--------------------------------------------------
     C           *INZSR    BEGSR
      *
     C                     MOVE '01'      @@ID    2
     C                     CLEARS@BOXS
     C                     CLEARD@BOXS
     C                     Z-ADD5149      KATOKU
      *
     C                     ENDSR
      *--------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
     C                     MOVE '0'       *IN98
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN98     IFEQ *OFF
     C                     EXSR #SET
     C                     MOVE '02'      @@ID
     C           *IN98     IFEQ '1'
     C                     MOVE '01'      @@ID
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *--------------------------------------------------
     C           #CHK1     BEGSR
      *
     C*                    SETOF                     9961
     C*                    MOVE *BLANK    D@MSG
     C*          D@DATE    CHAINAB#WPLG              90
     C*          *IN90     IFEQ *ON
     C*                    SETON                     9961
     C*                    MOVE MSG,1     D@MSG
     C*                    ENDIF
      *
     C                     ENDSR
      *--------------------------------------------------
     C           #SET      BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     S@BOXS
     C                     Z-ADD*ZERO     D@BOXS
     C                     Z-ADDD@YYYY    C@YYYY
     C                     Z-ADDD@MM      C@MM
     C                     Z-ADDD@DD      C@DD
      *
     C           KEY1      SETLLAB#PP101
     C           *IN90     DOUEQ*ON
     C           KEY1      READEAB#PP101                 90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C           BASYOS    IFNE 0
     C           BASRYO    DIV  BASYOS    WRST    90
     C                     ENDIF
     C                     ADD  WRST      S@BOXS
     C                     ADD  WRST      D@BOXS
     C                     ADD  1         RRN1
     C                     ENDIF
     C                     ENDDO
     C           RRN1      IFNE 0
     C                     WRITESFL01
     C                     ELSE
     C                     MOVE '1'       *IN98
     C                     ENDIF
      *
      *
      *
     C                     ENDSR
      *--------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     MOVE '99'      @@ID
     C                     SELEC
     C           *INKA     WHEQ *ON
     C*                    MOVE '01'      @@IDX
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      @@ID
     C                     ENDSL
      *
     C                     ENDSR
      *---------------------------------------------------
** CMD
   F1:END
   F1:END     F12:GO BACK
