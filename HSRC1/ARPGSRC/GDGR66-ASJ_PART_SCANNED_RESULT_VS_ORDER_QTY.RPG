     H            Y/
     F***************************************************
     F*   ASJ PRT SCANNED QTY VS. ORDER  QTY              *
     F*                                                 *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FAGDPL12 IF  E           K        DISK
     FALDPL24 IF  E           K        DISK
     FGDGPL19 IF  E           K        DISK
     FGDGWP65 UF  E           K        DISK                      A
     FQPRINT  O   F     132     OF     PRINTER
      *------------------------------------------------------------
     E                    DT1         4  8 0
     E                    DT2         4  8 0
     E                    OQT         4  7 0
     E                    TSC         4  7 0
     E                    TOR         4  7 0
      *------------------------------------------------------------
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80F8YMD
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I            DS
     I                                        1   80A1YMD
     I                                        1   40A1KSYY
     I                                        5   60A1KSMM
     I                                        7   80A1KSDD
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C                     EXSR #WRT
     C                     EXSR #OUT
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#KEY     KLIST
     C                     KFLD           A1SHN1
     C                     KFLD           A1SHN2
     C                     KFLD           A1SHN3
     C           K#AGD     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#GDG     KLIST
     C                     KFLD           WPART1
     C                     KFLD           WPART2
     C                     KFLD           WPART3
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
     C           K#GDGX    KLIST
     C                     KFLD           WPART1
     C                     KFLD           WPART2
     C                     KFLD           WPART3
      *
     C                     MOVE *ALL'-'   WLIN   79
     C                     Z-ADD*ZERO     TOR
     C                     Z-ADD*ZERO     TSC
      *
     C                     ENDSR
      *------------------------------------------------------
      *   WRITE
      *------------------------------------------------------
     C           #WRT      BEGSR
      * LATEST WEDNESDAY
     C                     EXSR #DATE
      *
     C                     Z-ADDDT2,1     K@YMD
     C           K#AGD     SETLLALDPL24
     C           *IN90     DOUEQ*ON
     C                     READ ALDPL24                  90
     C           *IN90     IFEQ *OFF
     C           A1YMD     IFGT DT1,4
     C                     LEAVE
     C                     ENDIF
      *
     C           K#KEY     CHAINGDGWP65              95
     C           *IN95     IFEQ *ON
     C                     CLEARGDGWP651
     C                     MOVE A1SHN1    WPART1
     C                     MOVE A1SHN2    WPART2
     C                     MOVE A1SHN3    WPART3
     C                     ENDIF
      *
     C           A1USYS    IFNE *ZERO
     C                     Z-ADDA1USYS    @@QTY   70
     C                     ELSE
     C                     Z-ADDA1SSYS    @@QTY
     C                     ENDIF
      *
     C                     SELEC
     C           A1YMD     WHGE DT2,4
     C                     ADD  1         WQTY4
     C                     ADD  1         TSC,4
     C           A1YMD     WHGE DT2,3
     C                     ADD  1         WQTY3
     C                     ADD  1         TSC,3
     C           A1YMD     WHGE DT2,2
     C                     ADD  1         WQTY2
     C                     ADD  1         TSC,2
     C           A1YMD     WHGE DT2,1
     C                     ADD  1         WQTY1
     C                     ADD  1         TSC,1
     C                     ENDSL
      *
     C   95                WRITEGDGWP651
     C  N95                UPDATGDGWP651
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   OUTPUT
      *------------------------------------------------------
     C           #OUT      BEGSR
      *
     C                     MOVE *OFF      *IN98
     C                     Z-ADDDT1,1     K@YMD
     C           *LOVAL    SETLLGDGWP65
     C           *IN90     DOUEQ*ON
     C                     READ GDGWP65                  90
     C           *IN90     IFEQ *OFF
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
     C                     EXSR #ORD
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     EXCPT@TOT
      *
     C                     ENDSR
      *------------------------------------------------------
      *   ORDER
      *------------------------------------------------------
     C           #ORD      BEGSR
      *
     C                     Z-ADD*ZERO     OQT
     C                     Z-ADDDT2,1     K@YMD
     C           K#GDG     SETLLGDGPL19
     C           *IN95     DOUEQ*ON
     C           K#GDGX    READEGDGPL19                  95
     C           *IN95     IFEQ *OFF
     C           ICSKJY    ANDEQ*BLANK
     C           ICODHZ    IFGT DT1,4
     C                     LEAVE
     C                     ENDIF
      *
     C           ICSYOS    MULT ICMAIS    @@QTY
     C                     SELEC
     C           ICODHZ    WHGE DT2,4
     C                     ADD  ICMAIS    OQT,4
     C           ICODHZ    WHGE DT2,3
     C                     ADD  ICMAIS    OQT,3
     C           ICODHZ    WHGE DT2,2
     C                     ADD  ICMAIS    OQT,2
     C           ICODHZ    WHGE DT2,1
     C                     ADD  ICMAIS    OQT,1
     C                     ENDSL
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           WPART3    COMP *BLANK                   10
     C                     EXCPT@DTL
     C                     ADD  OQT       TOR
      *
     C                     ENDSR
      *------------------------------------------------------
      *   DATE
      *------------------------------------------------------
     C           #DATE     BEGSR
     C                     Z-ADD*ZERO     DT1
     C                     Z-ADD*ZERO     DT2
     C                     Z-ADD*ZERO     X       20
     C                     Z-ADD*ZERO     Y       20
     C                     Z-ADD*DATE     K@YMD
     C           K#AGD     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8YOBI    IFEQ 2
     C                     ADD  1         X
     C                     Z-ADDF8YMD     DT1,X
     C                     ENDIF
     C           F8YOBI    IFEQ 3
     C           Y         ANDLTX
     C                     ADD  1         Y
     C                     Z-ADDF8YMD     DT2,Y
     C                     ENDIF
      *
     C           Y         IFEQ 4
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     SORTADT1
     C                     SORTADT2
      *
     C                     Z-ADDDT1,1     @MD11   40
     C                     Z-ADDDT1,2     @MD21   40
     C                     Z-ADDDT1,3     @MD31   40
     C                     Z-ADDDT1,4     @MD41   40
     C                     Z-ADDDT2,1     @MD12   40
     C                     Z-ADDDT2,2     @MD22   40
     C                     Z-ADDDT2,3     @MD32   40
     C                     Z-ADDDT2,4     @MD42   40
      *
     C**********           EXCPT@ADD
      *
     C                     ENDSR
     OQPRINT  E   01           @HED
     O                         #PGM       8
     O                         UDATE Y  120
     O                                  122 'P.'
     O                         PAGE  Z  126
     O        E   02           @HED
     O                                   50 'ASJ ORDER QTY VS.'
     O                                   64 'SCANNED RESULT'
     O        E   04           @HED
     O                         @MD12     26 '  /  '
     O                                   28 '-'
     O                         @MD11     34 '  /  '
     O                         @MD22     41 '  /  '
     O                                   43 '-'
     O                         @MD21     49 '  /  '
     O                         @MD32     56 '  /  '
     O                                   58 '-'
     O                         @MD31     64 '  /  '
     O                         @MD42     71 '  /  '
     O                                   73 '-'
     O                         @MD41     79 '  /  '
     O        E 1              @DTL
     O                         WLIN      79
     O        E 1              @DTL
     O                         WPART1     5
     O                                    6 '-'
     O                         WPART2    11
     O                      N10          12 '-'
     O                         WPART3    14
     O                                   22 'SCANNED'
     O                         WQTY1 1   32
     O                         WQTY2 1   47
     O                         WQTY3 1   62
     O                         WQTY4 1   77
     O        E 1              @DTL
     O                                   22 'ORDERED'
     O                         OQT,1 1   32
     O                         OQT,2 1   47
     O                         OQT,3 1   62
     O                         OQT,4 1   77
     O        E 1              @TOT
     O                         WLIN      79
     O        E 1              @TOT
     O                                   13 'TOTAL:'
     O                                   22 'SCANNED'
     O                         TSC,1 1   32
     O                         TSC,2 1   47
     O                         TSC,3 1   62
     O                         TSC,4 1   77
     O        E 1              @TOT
     O                                   22 'ORDERED'
     O                         TOR,1 1   32
     O                         TOR,2 1   47
     O                         TOR,3 1   62
     O                         TOR,4 1   77
