     C                     Z-ADDP8NOYY    PXNOYY
     C                     Z-ADDP8NOMM    PXNOMM
     C                     Z-ADDP8NODD    PXNODD
     C                     MOVELP8FLD1    PXODR  10
     C                     MOVELP8FLD2    PXASN  16
     C                     MOVELP8FLD3    PXCASN
     C                     MOVELP8FLD4    PXCPCK  9
     C                     Z-ADD99        PXNOBN  20
      * CHECK SHIP TIME
     C           D@SPTM    IFEQ *BLANK
     C                     SETON                     4285
     C                     MOVE ERR,6     D@MSG
     C                     GOTO #CHK1E
