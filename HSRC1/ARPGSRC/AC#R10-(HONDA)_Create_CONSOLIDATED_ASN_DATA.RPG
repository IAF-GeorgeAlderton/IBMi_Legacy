     C                     EXSR #PROC
     C                     ENDIF
     C                     ENDDO
      * SUMMARY
     C           G@BOX     DIV  @@MAX     @@PLT
     C                     MVR            @@MVR   50
     C           @@MVR     IFNE *ZERO
     C                     ADD  1         @@PLT
     C                     ENDIF
     C           @@PLT     IFEQ *ZERO
     C                     Z-ADD1         @@PLT
      *
     C                     ENDIF
     C                     EXSR #SUM
