     C           #GETPT    BEGSR
      *
     C                     Z-ADD0         @ITM    50
     C                     MOVE *OFF      *IN89
     C                     MOVELP8FLD1    W8ODRN
     C           K#PL1C    SETLLAB#PL1C
      * READ ORDER (AB#PP10) ------------------------
     C           *IN89     DOWEQ*OFF
     C           K#PL1C    READEAB#PL1C                  89
     C           *IN89     IFEQ *OFF
     C           BASKJY    ANDNE'D'
