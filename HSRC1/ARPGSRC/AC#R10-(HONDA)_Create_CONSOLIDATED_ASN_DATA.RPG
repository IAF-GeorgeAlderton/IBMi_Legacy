     C                     ENDSR
      *===================================================
      *   GET PRICE INFO
      *===================================================
     C           #GETPC    BEGSR
      *
     C                     Z-ADDBATANK    WTANK  135
     C                     Z-ADDBATANK    @@TANK 115
     C                     Z-ADDBATANK    $$TANK 135
      *
     C           WTANK     IFEQ 0
     C                     MOVELBATOKU    $TOKU   4
     C                     MOVELBANONY    $NONY   4
     C                     MOVELBANKOJ    $NKOJ   1
     C                     MOVELBANUKE    $NUKE   4
     C                     MOVELBAMHN     $MHN
     C                     MOVEL*BLANK    $SHIN  12
     C                     MOVEL*BLANK    $FLG    1
      *
     C                     CALL 'BBHR50'
     C                     PARM           $TOKU
     C                     PARM           $NONY
     C                     PARM           $NKOJ
     C                     PARM           $NUKE
     C                     PARM           $MHN
     C                     PARM           $SHIN
     C                     PARM           $FLG
      *
     C           $FLG      IFEQ '*'
     C                     MOVE *BLANK    $MHN3
     C                     MOVE *BLANK    $MHN4
     C                     ENDIF
