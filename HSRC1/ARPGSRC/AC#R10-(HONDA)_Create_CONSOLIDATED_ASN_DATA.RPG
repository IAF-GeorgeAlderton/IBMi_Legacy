     C                     ADD  1         @ITM
     C           BASYOS    IFGT 1
     C           BASRYO    DIV  BASYOS    WSBOX   50
     C                     MVR            @@MVR
     C           @@MVR     IFGT *ZERO
     C                     ADD  1         WSBOX
     C                     ENDIF
     C                     ELSE
     C           BAUSYS    IFNE *ZERO
     C           BASRYO    DIV  BAUSYS    WSBOX   50
     C                     ELSE
     C                     Z-ADD1         WSBOX
     C                     ENDIF
     C                     ENDIF
      * ---------------
     C                     ADD  WSBOX     G@BOX
      *
      * IF K#SHN(INTRAL PART) IS NO GOOD, GET INTRAL PART FROM FAAPP02.
     C           *IN95     IFEQ *ON
     C           K#PP02    SETLLFAAPL05
     C           K#PP02    CHAINFAAPL05              99
     C           *IN99     IFEQ *OFF
     C                     MOVELB7SHN1    K@SHN1
     C                     MOVELB7SHN2    K@SHN2
     C                     MOVELB7SHN3    K@SHN3
     C           K#SHN     CHAINFCEPL01              95
