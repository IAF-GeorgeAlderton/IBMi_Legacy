     C                     PARM           @NONY
     C                     PARM           @NKOJ
     C                     PARM           @NUKE
     C                     PARM           @MHIN
     C                     PARM           @HIZK
     C                     PARM           @TANK
     C                     PARM           @CHEK
      *
     C                     Z-ADD@TANK     WTANK
     C                     Z-ADD@TANK     @@TANK
     C                     Z-ADD@TANK     $$TANK
      *
     C           @CHEK     IFEQ '*'
     C                     EXCPTMITAN
     C                     SETON                     U2
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVELBASHN1    K@SHN1
     C                     MOVELBASHN2    K@SHN2
     C                     MOVELBASHN3    K@SHN3
     C           K#SHN     CHAINFCEPL01              95
