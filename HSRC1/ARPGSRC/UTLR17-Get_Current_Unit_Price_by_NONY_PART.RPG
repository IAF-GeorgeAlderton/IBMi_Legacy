     H            Y.
     F** UTLR17 ********************************************
     F*  PROGRAM: GET CURRENT UNIT PRICE BY PART           *
     F*           WITH EFFECTIVE DATE                      *
     F*           (GET TODAY'S PRICE)
     F*  WRITTEN: JW (SRA)                                 *
     F*           10/10/2017                               *
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR17'
     F*                    PARM           $TOKU   4
     F*                    PARM           $NONY   4
     F*                    PARM           $CPART 20
     F*                    PARM           $EFDT   8
     F*                    PARM           $UP     9
     F*                    PARM           $RTN    1
     F*  IN  $TOKU  :  4A CUST#
     F*      $NONY  :  4A DELIVERY#
     F*      $CPART : 20A CUSTMER PART
     F*  OUT $EFDT  :  8A EFFECTIVE DATE
     F*      $UP    :  9A PRICE 9(5)
     F*      $RTN   :  1A RETURN CODE (BLANK=OK, *=ERROR, 9=NO EXP DATE)
     F******************************************************
     FFBCPL07 IF  E           K        DISK
      *--------------------------------------------------------
     E                    DAT        10  1
     IW@DATE      DS
     I                                        1   40W@YY
     I                                        5   60W@MM
     I                                        7   80W@DD
     I            DS
     I                                        1   60EF@DT
     I                                        1   40FBTKYY
     I                                        5   60FBTKMM
     I                                        7   80FBTKDD
     I            DS
     I                                        1   60EX@DT
     I                                        1   40FBTSYY
     I                                        5   60FBTSMM
     I                                        7   80FBTSDD
     I            DS
     I                                        1  20 @MHN
     I                                        1   5 @MHN1
     I                                        6  10 @MHN2
     I                                       11  15 @MHN3
     I                                       16  20 @MHN4
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
     C                     EXSR @INIT
      *
     C                     Z-ADD0         UPRICE  95
     C                     Z-ADD0         FBTKHZ
     C                     Z-ADD0         FBNTAN
      *
     C           KEY       CHAINFBCPL07              90
     C           *IN90     IFEQ *ON
     C                     MOVE '*'       $RTN
     C                     GOTO @END
     C                     ENDIF
      *
     C           KEY       SETLLFBCPL07
     C           *IN91     DOWEQ*OFF
     C           KEY       READEFBCPL07                  91
     C           *IN91     IFEQ *OFF
     C           FBSKJY    ANDEQ' '
     C           EX@DT     IFEQ 999999
     C                     Z-ADDFBNTAN    UPRICE
     C                     LEAVE
     C                     ENDIF
      *
     C                     Z-ADDFBNTAN    UPRICE
     C                     ENDIF
     C                     ENDDO
      *
     C           EX@DT     IFEQ 999999
     C                     MOVE *BLANK    $RTN
     C                     ELSE
     C                     MOVEL'9'       $RTN
     C                     ENDIF
      *
     C           @END      TAG
     C                     MOVELFBTKHZ    $EFDT
     C                     MOVELUPRICE    $UP
      *
     C                     SETON                     LR
     C                     RETRN
      *=============================================================
      *                    INITIAL PROCESS
      *=============================================================
     C           @INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $TOKU   4
     C                     PARM           $NONY   4
     C                     PARM           $CPART 20
     C                     PARM           $EFDT   8
     C                     PARM           $UP     9
     C                     PARM           $RTN    1
      *
     C           KEY       KLIST
     C                     KFLD           KBTOKU
     C                     KFLD           KBNONY
     C                     KFLD           KBMHN1
     C                     KFLD           KBMHN2
     C                     KFLD           KBMHN3
     C                     KFLD           KBMHN4
      *
     C           *LIKE     DEFN FBTOKU    KBTOKU
     C           *LIKE     DEFN FBNONY    KBNONY
     C           *LIKE     DEFN FBMHN1    KBMHN1
     C           *LIKE     DEFN FBMHN2    KBMHN2
     C           *LIKE     DEFN FBMHN3    KBMHN3
     C           *LIKE     DEFN FBMHN4    KBMHN4
      *
     C                     MOVEL$CPART    @MHN
     C                     MOVEL$TOKU     KBTOKU
     C                     MOVEL$NONY     KBNONY
     C                     MOVEL@MHN1     KBMHN1
     C                     MOVEL@MHN2     KBMHN2
     C                     MOVEL@MHN3     KBMHN3
     C                     MOVEL@MHN4     KBMHN4
      *
     C                     MOVEL' '       $RTN
      *
     C                     ENDSR
