     C           KEY3      CHAINIZBPL111             11
I0001C           *IN11     IFEQ '0'
      *
     C           PKOSN     IFEQ '0'
     C           WZAIR     OREQ '03'
     C           WZAIR     OREQ '04'
     C           WZAIR     OREQ '05'
     C                     MOVE 'D'       ZASKJY
     C                     Z-ADD*DATE     ZASKHZ
     C                     ELSE
     C                     MOVE *BLANK    ZASKJY
     C                     Z-ADD0         ZASKHZ
     C                     END
      *
     C                     Z-ADD*DATE     ZAKOHZ
     C                     TIME           ZAKOTM
     C                     MOVELPUS       ZAKOME
      *
     C           WZAIR     IFEQ '01'
     C           WZAIR     OREQ '02'
     C                     MOVE W3BOZN    ZAZAIS
     C                     Z-ADDW3BOZI    ZAZAIK
     C                     Z-ADDW3BOSI    ZASIRE
     C                     Z-ADDW3BOUK    ZAKOJE
     C                     Z-ADDA2GEKN    ZAGEKN
     C                     Z-ADDA2SOZI    ZASOZI
     C                     Z-ADDWMSJR     ZAMSJR
     C                     MOVELWZIRO     ZAZIRO
     C                     END
     C                     UPDATIZBPL111
      *
I0001C                     ELSE
     C           PKOSN     IFNE '0'
     C           WZAIR     IFEQ '01'
     C           WZAIR     OREQ '02'
     C                     MOVE *BLANK    ZASKJY
     C                     Z-ADD0         ZASKHZ
     C                     Z-ADD*DATE     ZAKOHZ
     C                     TIME           ZAKOTM
     C                     MOVELPUS       ZAKOME
     C                     MOVE W3BOZN    ZAZAIS
     C                     Z-ADDW3BOZI    ZAZAIK
     C                     Z-ADDW3BOSI    ZASIRE
     C                     Z-ADDW3BOUK    ZAKOJE
     C                     MOVE A2BHB1    ZASHN1
     C                     MOVE A2BHB2    ZASHN2
     C                     MOVE A2BHB3    ZASHN3
     C                     Z-ADDA2GEKN    ZAGEKN
     C                     Z-ADDA2SOZI    ZASOZI
     C                     Z-ADDWMSJR     ZAMSJR
     C                     MOVELWZIRO     ZAZIRO
     C                     WRITEIZBPL111
     C                     END
     C                     END
      *
I0001C                     END
     C           ESB340    ENDSR
      *-----------------------------------------------------*
      *              母材かんばんマスター更新             *
      *-----------------------------------------------------*
     C           #SB350    BEGSR
     C                     Z-ADD0         WAMSJR  80
     C                     MOVE *BLANK    CFLG
     C           KEY4      SETLLIZBPL101
     C                     DO   *HIVAL
      *
     C                     SETOF                     11
     C           KEY4      READEIZBPL101                 11
     C           *IN11     IFEQ '0'
     C           ZASKJY    IFEQ 'D'
     C           ZASKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVE '*'       CFLG
     C                     ADD  ZAMSJR    WAMSJR
     C                     END
     C                     END
      *
     C  N11                END
      *
     C                     MOVE *BLANK    WFLG
     C           KEY4      SETLLIZBPL011
     C                     DO   *HIVAL
      *
     C                     SETOF                     11
     C           KEY4      READEIZBPL011                 11
I0002C           *IN11     IFEQ '0'
I0003C           ZDSKJY    IFEQ 'D'
     C           ZDSKHZ    ANDLE*DATE
I0003C                     ELSE
I0005C           *DATE     IFGE ZDUKHZ
     C           *DATE     ANDLEZDSTHZ
     C                     MOVE '*'       WFLG
I0004C           CFLG      IFEQ *BLANK
     C                     Z-ADD*DATE     ZDKOHZ
     C                     TIME           ZDKOTM
     C                     MOVELPUS       ZDKOME
     C                     Z-ADDWZYMD     ZDSTHZ
     C                     Z-ADD01        ZDSBIN
     C                     UPDATIZBPL011
I0004C                     ELSE
     C           ZDMSJR    IFNE WAMSJR
     C                     MOVE *BLANK    ZDSKJY
     C                     Z-ADD0         ZDSKHZ
     C                     Z-ADD*DATE     ZDKOHZ
     C                     TIME           ZDKOTM
     C                     MOVELPUS       ZDKOME
     C                     Z-ADDWAMSJR    ZDMSJR
     C           ZDDTKO    IFNE '2'
     C                     MOVE '3'       ZDDTKO
     C                     END
     C                     MOVE *BLANK    ZDDTHE
     C                     UPDATIZBPL011
     C                     END
I0004C                     END
I0005C                     ELSE
     C           ZDUKHZ    IFEQ *DATE
     C                     MOVE '1'       WFLG
     C                     MOVE *BLANK    ZDSKJY
     C                     Z-ADD0         ZDSKHZ
     C                     Z-ADD*DATE     ZDKOHZ
     C                     TIME           ZDKOTM
     C                     MOVELPUS       ZDKOME
     C                     Z-ADDW3BOUK    ZDKOJE
     C                     MOVE W3BOZN    ZDZAIS
     C                     Z-ADDW3BOZI    ZDZAIK
     C                     Z-ADDW3BOSI    ZDSIRE
     C                     MOVE 'R'       ZDKNO2
     C                     Z-ADDWAMSJR    ZDMSJR
     C                     MOVELWZIRO     ZDZIRO
     C                     Z-ADD*DATE     ZDUKHZ
     C                     Z-ADD01        ZDUBIN
     C                     Z-ADD99999999  ZDSTHZ
     C                     Z-ADD99        ZDSBIN
     C                     MOVE '2'       ZDDTKO
     C                     MOVE *BLANK    ZDDTHE
     C                     MOVE '5'       ZDKOSN
     C                     Z-ADD0         ZDSRMS
     C                     Z-ADD0         ZDALHK
     C                     Z-ADD0         ZDMXHK
     C                     MOVE *BLANK    ZDKSHK
     C                     MOVE *BLANK    ZDKOUT
     C                     MOVE *BLANK    ZDDOUT
      *
     C                     MOVE *BLANK    ZDKOJK
     C                     MOVE *BLANK    ZDSIRK
     C                     MOVE *BLANK    ZDKNO1
     C                     MOVE *BLANK    ZDKNOE
     C                     Z-ADD0         ZDCHOS
     C                     Z-ADD0         ZDMKJR
     C                     MOVE *BLANK    ZDADR1
     C                     MOVE *BLANK    ZDADR2
     C                     MOVE *BLANK    ZDADR3
     C                     MOVE *BLANK    ZDADR4
     C                     MOVE *BLANK    ZDUKIR
     C                     Z-ADD0         ZDLOTO
     C                     Z-ADD0         ZDSETI
     C                     Z-ADD0         ZDTKJR
     C                     Z-ADD0         ZDNISG
     C                     MOVE *BLANK    ZDKHKO
     C                     MOVE *BLANK    ZDDHKO
     C                     Z-ADD0         ZDSLTM
     C                     Z-ADD0         ZDKEIS
     C                     Z-ADD0         ZDKMAL
     C                     Z-ADD0         ZDKMMN
     C                     Z-ADD0         ZDKMMX
     C                     UPDATIZBPL011
     C                     END
I0005C                     END
I0003C                     END
I0002C                     END
      *
     C  N11                ENDDO
      *
     C           PKOSN     IFNE '0'
     C           WFLG      ANDEQ*BLANK
     C           CFLG      ANDEQ'*'
     C                     MOVE *BLANK    ZDSKJY
     C                     Z-ADD0         ZDSKHZ
     C                     Z-ADD*DATE     ZDKOHZ
     C                     TIME           ZDKOTM
     C                     MOVELPUS       ZDKOME
     C                     Z-ADDW3BOUK    ZDKOJE
     C                     MOVE W3BOZN    ZDZAIS
     C                     Z-ADDW3BOZI    ZDZAIK
     C                     Z-ADDW3BOSI    ZDSIRE
     C                     MOVE 'R'       ZDKNO2
     C                     Z-ADDWAMSJR    ZDMSJR
     C                     MOVELWZIRO     ZDZIRO
     C                     Z-ADD*DATE     ZDUKHZ
     C                     Z-ADD01        ZDUBIN
     C                     Z-ADD99999999  ZDSTHZ
     C                     Z-ADD99        ZDSBIN
     C                     MOVE '2'       ZDDTKO
     C                     MOVE *BLANK    ZDDTHE
     C                     MOVE '5'       ZDKOSN
     C                     Z-ADD0         ZDSRMS
     C                     Z-ADD0         ZDALHK
     C                     Z-ADD0         ZDMXHK
     C                     MOVE *BLANK    ZDKSHK
     C                     MOVE *BLANK    ZDKOUT
     C                     MOVE *BLANK    ZDDOUT
      *
     C                     SETOF                     82
     C           1         CHAINIZBPPNO              82
     C           *IN82     IFEQ '0'
     C                     MOVE @ARECD    #ARECD  40
     C                     ADD  1         #ARECD
     C                     MOVE #ARECD    @ARECD
     C                     EXCPTUPZB
     C                     ELSE
      *
     C                     MOVE '0001'    @ARECD
     C                     EXCPTWTZB
     C                     END
      *
     C                     MOVE @ARECD    ZDKNO3
      *
     C                     MOVE *BLANK    ZDKOJK
     C                     MOVE *BLANK    ZDSIRK
     C                     MOVE *BLANK    ZDKNO1
     C                     MOVE *BLANK    ZDKNOE
     C                     Z-ADD0         ZDCHOS
     C                     Z-ADD0         ZDMKJR
     C                     MOVE *BLANK    ZDADR1
     C                     MOVE *BLANK    ZDADR2
     C                     MOVE *BLANK    ZDADR3
     C                     MOVE *BLANK    ZDADR4
     C                     MOVE *BLANK    ZDUKIR
     C                     Z-ADD0         ZDLOTO
     C                     Z-ADD0         ZDSETI
     C                     Z-ADD0         ZDTKJR
     C                     Z-ADD0         ZDNISG
     C                     MOVE *BLANK    ZDKHKO
     C                     MOVE *BLANK    ZDDHKO
     C                     Z-ADD0         ZDSLTM
     C                     Z-ADD0         ZDKEIS
     C                     Z-ADD0         ZDKMAL
     C                     Z-ADD0         ZDKMMN
     C                     Z-ADD0         ZDKMMX
      *
     C                     WRITEIZBPL011
     C                     END
     C           ESB350    ENDSR
      *-----------------------------------------------------*
     OIZAPPNO E                UPZA
     O                         @BRECD     4
     O        EADD             WTZA
     O                         @BRECD     4
      *
     OIZBPPNO E                UPZB
     O                         @ARECD     4
     O        EADD             WTZB
     O                         @ARECD     4
