      *
      * KEY LIST
      *
     C           KEYKAT    KLIST
     C                     KFLD           #KKAT1  2
     C                     KFLD           #KKAT2  4
     C           KEYDF1    KLIST
     C                     KFLD           #KKATA 15
     C           KEYI61    KLIST
     C                     KFLD           #KHYY   40
     C                     KFLD           #KHIN1  5
     C                     KFLD           #KHIN2  5
     C                     KFLD           #KHIN3  2
      *------------------*
     C           *INL1     IFEQ '1'
     C                     SETOF                     85
     C                     Z-ADD0         WKKIHZ
     C                     END
     C           T6SKJY    IFEQ 'D'
     C           T6SKHZ    ANDLE*DATE
     C                     GOTO LAST
     C                     END
      *
     C                     SETON                     85
     C           T6KIHZ    IFGE WKKIHZ
     C                     MOVE T6KIHZ    WKKIHZ
     C                     Z-ADDT6SRYO    @@GEKN  72
     C                     Z-ADDT6MAIS    @@MAIS  30
     C                     Z-ADDT6SYOS    @@SYOS  30
     C                     END
     C                     MOVE T6KIHZ    WKKIHZ
     C           LAST      TAG
      *
     CL1 85                EXSR $SB200
     CL1                   SETOF                     85
     CL1                   MOVE *ALL'0'   NBR
     CL1                   MOVE *ALL'0'   QUA
      *
      *---------------------------------------------------*
      *   ECXEL DATA CREATE                               *
      *---------------------------------------------------*
     CSR         $SB200    BEGSR
     C                     MOVE T6KAT1    KAT1
     C                     MOVE T6KAT2    KAT2
     C                     MOVE '-'       WKF1
      *
     C                     MOVE T6KAT1    #KKAT1
     C                     MOVE T6KAT2    #KKAT2
     C                     Z-ADD0         @@KOSU  70
     C                     EXSR $SB400
     C                     Z-ADD0         @@SRYO 150
     C                     MOVEL@@KAT     #KKATA
     C                     EXSR $SB410
      *
     C  N97                EXCPTHDE1
     C  N97                EXCPTHDE2
     C                     EXCPTFILE
     C                     SETON                       97
     C                     CLEAR@@KAT
     C                     CLEAR@@MAIS
     C                     CLEAR@@GEKN
     C                     CLEAR@@KOSU
     C                     CLEAR@@SYOS
      *
     CSR         $S200E    ENDSR
      *------------------------------------------------*
      *  出荷数を求める                              *
      *------------------------------------------------*
     CSR         $SB400    BEGSR
     C           KEYKAT    SETLLECSPL071
     C                     SETOF                       81
     C                     DO   *HIVAL
     C           KEYKAT    READEECSPL071                 81
     C   81                LEAVE
      *
     C           EQSKJY    IFEQ 'D'
     C           EQSKHZ    ANDLE*DATE
     C                     ITER
     C                     END
      *
     C           @@YOHZ    IFGE @SYHZ
     C           @@YOHZ    ANDLE@EYHZ
     C                     Z-ADD1         X
     C                     SETOF                       29
     C           @@YOHZ    LOKUPHYM,X                    29
     C   29                ADD  EQKOSU    NBR,X
     C                     END
      *
     C                     ENDDO
     CSR         $S400E    ENDSR
      *------------------------------------------------*
      *  引当品番を求める                            *
      *------------------------------------------------*
     CSR         $SB410    BEGSR
     C                     SETOF                       81
     C           KEYDF1    SETLLGCQPL361
     C                     DO   *HIVAL
     C           KEYDF1    READEGCQPL361                 81
     C   81                LEAVE
      *
     C           DFSKJY    IFEQ 'D'
     C           DFSKHZ    ANDLE*DATE
     C                     ITER
     C                     END
      *
     C                     MOVE DFSHN1    #KHIN1
     C                     MOVE DFSHN2    #KHIN2
     C                     MOVE DFSHN3    #KHIN3
     C                     EXSR $SB420
     C                     ENDDO
     CSR         $S410E    ENDSR
      *------------------------------------------------*
      *  生産数を求める                              *
      *------------------------------------------------*
     CSR         $SB420    BEGSR
     C           @SYY      IFEQ @EYY
     C                     MOVE '1'       TYPE    1
     C                     ELSE
     C                     MOVE '2'       TYPE
     C                     END
     C                     CLEARW@SYHZ
     C                     MOVE @SYY      W@SYY
     C                     MOVE @SMM      W@SMM
      *
     C           TYPE      IFEQ '1'
     C           TYPE      OREQ '2'
     C                     MOVE @SYY      #KHYY
     C           KEYI61    SETLLMBEPL051
      *
     C                     DO   *HIVAL
     C           KEYI61    READEMBEPL051                 82
     C   82                LEAVE
      *
     C                     Z-ADD@SMM      W@SMM   20
     C                     Z-ADD@SMM      X
     C                     DO   12
     C                     SETOF                     29
     C                     Z-ADD1         I       20
     C           W@SYHZ    LOKUPHYM,I                    29
     C                     ADD  SRY,X     QUA,I
     C           X         IFEQ 12
     C                     LEAVE
     C                     END
     C                     ADD  1         X
     C                     ADD  1         W@SMM
     C                     ENDDO
      *
     C                     ENDDO
      *
     C                     END
      *
     C           TYPE      IFEQ '2'
     C                     CLEARW@SYHZ
     C                     MOVE @EYY      W@SYY
     C                     MOVE @EYY      #KHYY
     C           KEYI61    SETLLMBEPL051
     C                     SETOF                         82
      *
     C                     DO   *HIVAL
     C           KEYI61    READEMBEPL051                 82
     C   82                LEAVE
      *
     C                     Z-ADD1         W@SMM   20
     C                     Z-ADD1         X       20
     C                     DO   12
     C                     SETOF                     29
     C                     Z-ADD1         I       20
     C           W@SYHZ    LOKUPHYM,I                    29
     C                     ADD  SRY,X     QUA,I
     C           X         IFEQ @EMM
     C                     LEAVE
     C                     END
     C                     ADD  1         X
     C                     ADD  1         W@SMM
     C                     ENDDO
      *
     C                     ENDDO
      *
     C                     END
     CSR         $S420E    ENDSR
      *------------------------------------------------*
      *  初期処理（期間設定）                        *
      *------------------------------------------------*
     CSR         *INZSR    BEGSR
     C                     Z-ADD0         WKKIHZ  80
      *
     C                     Z-ADD2004      @SYY
     C                     Z-ADD03        @SMM
      *
     C                     Z-ADD2005      @EYY
     C                     Z-ADD09        @EMM
     C                     MOVE *ALL'0'   NBR
     C                     MOVE *ALL'0'   QUA
     C                     Z-ADD1         X       20
     C           1         DO   19        X
     C                     MOVE @SYHZ     HYM,X
     C                     ADD  1         @SMM
     C           @SMM      IFGT 12
     C                     ADD  1         @SYY
     C                     SUB  12        @SMM
     C                     END
     C                     ENDDO
      *
     C                     Z-ADD2004      @SYY
     C                     Z-ADD03        @SMM
      *
     C                     MOVE *ALL' '   DYM
     C                     Z-ADD1         X
     C           1         DO   19        X
     C                     MOVELHYM,X     WKHYY
     C                     MOVE '/'       WKH1
     C                     MOVE HYM,X     WKHMM
     C                     MOVE WKHYM     DYM,X
     C                     ENDDO
      *
     CSR                   ENDSR
