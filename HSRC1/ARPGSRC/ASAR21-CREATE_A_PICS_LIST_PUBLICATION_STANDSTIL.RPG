     H            Y
     F********************************************************
     F* CREATE  A-PICS LIST PUBLICATION STANDSTILL M/F ASAR21 *
     F********************************************************
     FASAPW21 CF  E                    WORKSTN
     FFGBPL01 IF  E           K        DISK
     FASAPL21 UF  E           K        DISK                      A
     E                    $MSG    1   9 40
     I            DS
     I                                        1   80@START
     I                                        1   40STYY
     I                                        5   60STMM
     I                                        7   80STDD
     I            DS
     I                                        1   80@END
     I                                        1   40ENYY
     I                                        5   60ENMM
     I                                        7   80ENDD
     C/SPACE 1
     C           *ENTRY    PLIST
     C                     PARM           PARM1  10
     C*----------------------*
     C*   KLIST の作成     *
     C*----------------------*
     C           #KEY1     KLIST
     C                     KFLD           #MBMN   40
     C                     KFLD           #ABMN   40
     C/SPACE 1
     C************************
     C*  初期処理          *
     C************************
     C*
     C                     MOVE *BLANK    @ERR
     C                     MOVE *DATE     @DATE
     C                     TIME           @TIME
     C************************
     C*  第１画面処理      *
     C************************
     C           $100S     TAG
     C                     EXFMTASAPW211
     C                     SETOF                     202122
     C                     SETOF                     107071
     C                     SETOF                       99
     C           *IN01     IFEQ '1'
     C                     SETON                       LR
     C                     RETRN
     C                     END
     C************************
     C* 区分チェツク       *
     C************************
     C           @KUBUN    IFNE '0'
     C           @KUBUN    IFNE '1'
     C           @KUBUN    IFNE '2'
     C                     SETON                       9920
     C                     MOVEL$MSG,1    @ERR
     C                     GOTO $100S
     C                     END
     C                     END
     C                     END
     C************************
     C* 部門コードチェツク *
     C************************
     C*
     C           @KCODE    IFEQ *ZERO
     C                     MOVEL$MSG,2    @ERR
     C                     SETON                       9921
     C                     GOTO $100S
     C                     END
     C*
     C           @ACODE    IFEQ *ZERO
     C                     MOVEL$MSG,2    @ERR
     C                     SETON                       9922
     C                     GOTO $100S
     C                     END
     C*
     C                     MOVE @KCODE    KEY     40
     C           KEY       CHAINFGBPL011             70
     C           *IN70     IFEQ '0'
     C           B2CODE    IFEQ 8982
     C           B2CODE    OREQ 8974
     C           B2CODE    OREQ 8990
     C           B2CODE    OREQ 9032
     C           B2CODE    OREQ 9040
     C                     MOVELB2SMEI    @NAME1
     C*                    ELSE
     C*                    SETON                       9921
     C*                    MOVEL$MSG,3    @ERR
     C*                    GOTO $100S
     C                     END
     C                     ELSE
     C                     SETON                       9921
     C                     MOVEL$MSG,3    @ERR
     C                     GOTO $100S
     C                     END
     C                     MOVE @ACODE    KEY
     C           KEY       CHAINFGBPL011             71
     C           *IN71     IFEQ '0'
     C                     MOVELB2SMEI    @NAME2
     C                     ELSE
     C                     SETON                       9922
     C                     MOVEL$MSG,3    @ERR
     C                     GOTO $100S
     C                     END
     C*
     C                     MOVE @KCODE    #MBMN
     C                     MOVE @ACODE    #ABMN
     C           #KEY1     CHAINASAPL211             10
     C           @KUBUN    IFEQ '2'
     C           *IN10     IFEQ '0'
     C                     SETON                       9921
     C                     MOVEL$MSG,7    @ERR
     C                     GOTO $100S
     C                     END
     C                     END
     C*
     C           @KUBUN    IFEQ '1'
     C           *IN10     IFEQ '1'
     C                     SETON                       9921
     C                     MOVEL$MSG,8    @ERR
     C                     GOTO $100S
     C                     END
     C                     END
     C*
     C           @KUBUN    IFEQ '0'
     C           *IN10     IFEQ '1'
     C                     SETON                       9921
     C                     MOVEL$MSG,8    @ERR
     C                     GOTO $100S
     C                     END
     C                     END
     C                     SETOF                     457071
     C************************
     C*  固定項目          *
     C************************
     C                     MOVE *DATE     @DATE
     C                     TIME           @TIME
     C                     MOVE @KUBUN    @KBUN
     C                     MOVE @KCODE    @KOJO
     C                     MOVE @ACODE    @KOTEI
     C           @KUBUN    IFEQ '0'
     C                     MOVE 'CANCEL'  @KNAME
     C                     SETON                     45
     C                     END
     C           @KUBUN    IFEQ '1'
     C                     MOVE 'CHANGE'  @KNAME
     C                     END
     C           @KUBUN    IFEQ '2'
     C                     MOVE 'ADD   '  @KNAME
     C                     GOTO ADNG
     C                     END
     C************************
     C*  項目転送          *
     C************************
     C                     MOVE CHNPR1    @SAGYO
     C                     MOVE CHNPR2    @HACHU
     C                     MOVE CHNPR3    @JURYO
     C                     MOVE CHNPR4    @MKAI
     C                     MOVE CHNPR5    @MURI
     C                     MOVE CHNPR6    @YOBI1
     C                     MOVE CHNPR7    @YOBI2
     C                     MOVE CHNPR8    @YOBI3
     C                     MOVE CHSTYY    STYY
     C                     MOVE CHSTMM    STMM
     C                     MOVE CHSTDD    STDD
     C                     MOVE CHENYY    ENYY
     C                     MOVE CHENMM    ENMM
     C                     MOVE CHENDD    ENDD
     C                     GOTO $200S
     C           ADNG      TAG
     C                     MOVE 'N'       @SAGYO
     C                     MOVE 'N'       @HACHU
     C                     MOVE 'N'       @JURYO
     C                     MOVE 'N'       @MKAI
     C                     MOVE 'N'       @MURI
     C                     MOVE 'N'       @YOBI1
     C                     MOVE 'N'       @YOBI2
     C                     MOVE 'N'       @YOBI3
     C                     MOVE *ZERO     @START
     C                     MOVE *ZERO     @END
     C/SPACE 1
     C************************
     C*  第２画面処理      *
     C************************
     C           $200S     TAG
     C                     EXFMTASAPW212
     C                     MOVEA'00000000'*IN,23
     C                     SETOF                     293031
     C                     SETOF                     319932
     C           *IN05     IFEQ '0'
     C           WCHECK    IFEQ '*'
     C                     MOVE *BLANK    WCHECK  1
     C                     END
     C                     END
     C   45                MOVE '*'       WCHECK
     C           *IN03     IFEQ '1'
     C                     MOVE *ZERO     @KOJO
     C                     MOVE *ZERO     @KOTEI
     C                     MOVE *ZERO     @START
     C                     MOVE *ZERO     @END
     C                     MOVE *ZERO     @KCODE
     C                     MOVE *ZERO     @ACODE
     C                     MOVE *BLANK    @KBUN
     C                     MOVE *BLANK    @KNAME
     C                     MOVE *BLANK    @NAME1
     C                     MOVE *BLANK    @NAME2
     C                     MOVE *BLANK    @SAGYO
     C                     MOVE *BLANK    @HACHU
     C                     MOVE *BLANK    @JURYO
     C                     MOVE *BLANK    @MKAI
     C                     MOVE *BLANK    @MURI
     C                     MOVE *BLANK    @YOBI1
     C                     MOVE *BLANK    @YOBI2
     C                     MOVE *BLANK    @YOBI3
     C                     MOVE *BLANK    @KUBUN
     C                     SETOF                     202122
     C                     SETOF                     1099
     C                     GOTO $100S
     C                     END
     C*
     C           *IN05     IFEQ '1'
     C           WCHECK    IFEQ '*'
     C           @KUBUN    IFEQ '0'
     C                     MOVE 'D'       CHSKJY
     C                     MOVE *YEAR     CHSKYY
     C                     MOVE UMONTH    CHSKMM
     C                     MOVE UDAY      CHSKDD
     C                     EXCPTDEL
     C                     GOTO RTN01
     C                     END
     C           @KUBUN    IFEQ '1'
     C                     EXSR SB3000
     C                     EXCPTCHG
     C                     GOTO RTN01
     C                     END
     C           @KUBUN    IFEQ '2'
     C                     EXSR SB3000
     C                     WRITEASAPL211
     C                     GOTO RTN01
     C                     END
     C                     ELSE
     C                     GOTO CHECK
     C                     END
     C                     END
     C/SPACE 1
     C*======================*
     C*   入力チェック     *
     C*======================*
     C           CHECK     TAG
     C           *IN45     CABEQ'1'       $200S
     C************************
     C*      作業票        *
     C************************
     C           @SAGYO    IFNE 'Y'
     C           @SAGYO    IFNE 'N'
     C                     SETON                       9923
     C                     MOVEL$MSG,4    @ERR
     C                     GOTO $200S
     C                     END
     C                     END
     C************************
     C*   発注明細表       *
     C************************
     C           @HACHU    IFNE 'Y'
     C           @HACHU    IFNE 'N'
     C                     SETON                       9924
     C                     MOVEL$MSG,4    @ERR
     C                     GOTO $200S
     C                     END
     C                     END
     C************************
     C*      受領書        *
     C************************
     C           @JURYO    IFNE 'Y'
     C           @JURYO    IFNE 'N'
     C                     SETON                       9925
     C                     MOVEL$MSG,4    @ERR
     C                     GOTO $200S
     C                     END
     C                     END
     C************************
     C*  メッキ買掛金明細  *
     C************************
     C           @MKAI     IFNE 'Y'
     C           @MKAI     IFNE 'N'
     C                     SETON                       9926
     C                     MOVEL$MSG,4    @ERR
     C                     GOTO $200S
     C                     END
     C                     END
     C************************
     C*  メッキ売掛金明細  *
     C************************
     C           @MURI     IFNE 'Y'
     C           @MURI     IFNE 'N'
     C                     SETON                       9927
     C                     MOVEL$MSG,4    @ERR
     C                     GOTO $200S
     C                     END
     C                     END
     C******************************
     C*940304未納品チェックリスト*
     C******************************
     C           @YOBI1    IFNE 'Y'
     C           @YOBI1    IFNE 'N'
     C                     SETON                       9928
     C                     MOVEL$MSG,4    @ERR
     C                     GOTO $200S
     C                     END
     C                     END
     C************************
     C*940304出荷箱数集計表*
     C************************
     C           @YOBI2    IFNE 'Y'
     C           @YOBI2    IFNE 'N'
     C                     SETON                       9929
     C                     MOVEL$MSG,4    @ERR
     C                     GOTO $200S
     C                     END
     C                     END
     C************************
     C*      予備１        *
     C************************
     C           @YOBI3    IFNE 'Y'
     C           @YOBI3    IFNE 'N'
     C                     SETON                       9930
     C                     MOVEL$MSG,4    @ERR
     C                     GOTO $200S
     C                     END
     C                     END
     C************************
     C*   期日チェック     *
     C************************
     C           @SAGYO    IFEQ 'N'
     C           @HACHU    ANDEQ'N'
     C           @JURYO    ANDEQ'N'
     C           @MKAI     ANDEQ'N'
     C           @MURI     ANDEQ'N'
     C           @YOBI1    ANDEQ'N'
     C           @YOBI2    ANDEQ'N'
     C           @YOBI3    ANDEQ'N'
     C                     SETON                     45
     C                     GOTO LAST
     C                     ELSE
     C           @START    IFEQ *ZERO
     C           @START    OREQ 99999999
     C                     SETON                       9931
     C                     MOVEL$MSG,9    @ERR
     C                     GOTO $200S
     C                     ELSE
     C                     MOVE @START    WKHYMD  60
     C                     EXSR SB2100
     C           *IN90     IFEQ '1'
     C           *IN98     OREQ '1'
     C                     SETON                       9931
     C                     MOVEL$MSG,6    @ERR
     C                     GOTO $200S
     C                     END
     C                     END
     C           @START    IFNE *ZERO
     C           @END      ANDEQ*ZERO
     C                     SETON                       9932
     C                     MOVEL$MSG,5    @ERR
     C                     GOTO $200S
     C                     END
     C           @START    IFNE *ZERO
     C           @END      ANDEQ99999999
     C                     GOTO LAST
     C                     END
     C                     MOVE @END      WKHYMD
     C                     EXSR SB2100
     C           *IN90     IFEQ '1'
     C           *IN98     OREQ '1'
     C                     SETON                       9932
     C                     MOVEL$MSG,6    @ERR
     C                     GOTO $200S
     C                     END
     C           @START    IFGT @END
     C                     SETON                       9931
     C                     MOVEL$MSG,5    @ERR
     C                     GOTO $200S
     C                     END
     C                     END
     C           LAST      TAG
     C                     MOVE '*'       WCHECK
     C                     GOTO $200S
     C           RTN01     TAG
     C                     MOVE *ZERO     @KOJO
     C                     MOVE *ZERO     @KOTEI
     C                     MOVE *ZERO     @START
     C                     MOVE *ZERO     @END
     C                     MOVE *ZERO     @KCODE
     C                     MOVE *ZERO     @ACODE
     C                     MOVE *BLANK    @KBUN
     C                     MOVE *BLANK    @KNAME
     C                     MOVE *BLANK    @NAME1
     C                     MOVE *BLANK    @NAME2
     C                     MOVE *BLANK    @SAGYO
     C                     MOVE *BLANK    @HACHU
     C                     MOVE *BLANK    @JURYO
     C                     MOVE *BLANK    @MKAI
     C                     MOVE *BLANK    @MURI
     C                     MOVE *BLANK    @YOBI1
     C                     MOVE *BLANK    @YOBI2
     C                     MOVE *BLANK    @YOBI3
     C                     MOVE *BLANK    @KUBUN
     C                     SETOF                     202122
     C                     SETOF                     1099
     C                     GOTO $100S
     C/SPACE 1
     CSR         SB3000    BEGSR
     C                     MOVE *BLANK    CHSKJY
     C                     MOVE *ZERO     CHSKYY
     C                     MOVE *ZERO     CHSKMM
     C                     MOVE *ZERO     CHSKDD
     C                     MOVE *YEAR     CHKOYY
     C                     MOVE UMONTH    CHKOMM
     C                     MOVE UDAY      CHKODD
     C                     TIME           WKTIME  60
     C                     MOVELWKTIME    CHKOHH
     C                     MOVE WKTIME    CHKOSS
     C                     MOVE PARM1     CHKOME
     C                     MOVE @KCODE    CHMBMN
     C                     MOVE @ACODE    CHABMN
     C                     MOVE @SAGYO    CHNPR1
     C                     MOVE @HACHU    CHNPR2
     C                     MOVE @JURYO    CHNPR3
     C                     MOVE @MKAI     CHNPR4
     C                     MOVE @MURI     CHNPR5
     C                     MOVE @YOBI1    CHNPR6
     C                     MOVE @YOBI2    CHNPR7
     C                     MOVE @YOBI3    CHNPR8
     C                     MOVE STYY      CHSTYY
     C                     MOVE STMM      CHSTMM
     C                     MOVE STDD      CHSTDD
     C                     MOVE ENYY      CHENYY
     C                     MOVE ENMM      CHENMM
     C                     MOVE ENDD      CHENDD
     CSR                   ENDSR
     C/SPACE 1
     C************************
     C*  日付チエック      *
     C************************
     CSR         SB2100    BEGSR
     C                     SETOF                     9098
     C                     MOVELWKHYMD    HY      40
     C                     MOVE WKHYMD    HMD     40
     C                     MOVELHMD       HM      20
     C                     MOVE HMD       HD      20
     C           HY        DIV  4         URUDOS  50
     C                     MVR            AMARI   50
     C*  01
     C           HM        IFEQ 01
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  02
     C           HM        IFEQ 02
     C           AMARI     IFEQ *ZERO
     C           HD        IFLT 01
     C           HD        ORGT 28
     C                     SETON                       90
     C                     END
     C                     ELSE
     C           HD        IFLT 01
     C           HD        ORGT 29
     C                     SETON                       90
     C                     END
     C                     END
     C                     END
     C*  03
     C           HM        IFEQ 03
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  04
     C           HM        IFEQ 04
     C           HD        IFLT 01
     C           HD        ORGT 30
     C                     SETON                       90
     C                     END
     C                     END
     C*  05
     C           HM        IFEQ 05
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  06
     C           HM        IFEQ 06
     C           HD        IFLT 01
     C           HD        ORGT 30
     C                     SETON                       90
     C                     END
     C                     END
     C*  07
     C           HM        IFEQ 07
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  08
     C           HM        IFEQ 08
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  09
     C           HM        IFEQ 09
     C           HD        IFLT 01
     C           HD        ORGT 30
     C                     SETON                       90
     C                     END
     C                     END
     C*  10
     C           HM        IFEQ 10
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  11
     C           HM        IFEQ 11
     C           HD        IFLT 01
     C           HD        ORGT 30
     C                     SETON                       90
     C                     END
     C                     END
     C*  12
     C           HM        IFEQ 12
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  01 -- 12
     C           HM        IFLT 01
