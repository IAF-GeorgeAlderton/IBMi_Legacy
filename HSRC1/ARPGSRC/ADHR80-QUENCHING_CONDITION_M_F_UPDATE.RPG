     C                     ENDIF
     C*
     C                     MOVE *BLANK    D2ZANM           MATERIAL NAME
     C           D2ZACD    SETLLFCEPL08
     C                     DO   *HIVAL
     C           D2ZACD    READEFCEPL08                  91
