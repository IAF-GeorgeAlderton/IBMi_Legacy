 E2  C                     ENDIF
     C           S1IN30    COMP '1'                      30
     C                     UPDATSFREC1
E1   C  N99                ENDDO
      *----------------------*
      *----------------------*
     C           $CHK3Z    TAG
      *----------------------*
S1   C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK3 F5'
     C                     MOVE '#UPDAT  '@STEP
     C                     ELSE
     C                     MOVE '#DSP3   '@STEP
E1   C                     ENDIF
