     C           #SFSET    BEGSR
     C*  SFLCLR
     C                     SETON                     73
     C                     WRITESFCTL1
     C                     SETOF                     73
     C                     Z-ADD0         RRN     40
      *
     C           D2KKBN    COMP '1'                  3030  :変更
      *----------------------*
      **  K$ATOK  3 PRESENT PROCESS CODE  は、D1TYPEにより、
      **  K$PCLS  3 PART CLASS             #CHK1で、セットする
      *----------------------*
     C           KEY01     KLIST
     C                     KFLD           D2ZACD           MATERIAL CODE
     C                     KFLD           D2KIKI           MATERIAL PROPERTIES
     C                     KFLD           K$ATOK  3        PRESENT PROCESS CODE
     C                     KFLD           K$PCLS  3        PART CLASS
      *
     C           KEY01     SETLLADHPL80
      *----------------------*
     C                     DO   *HIVAL
     C           KEY01     READEADHPL80             N    90
     C   90                LEAVE
     C           J8SKJY    IFEQ 'D'
     C           J8SKHZ    ANDLE@SYSHZ
     C                     ITER
     C                     ENDIF
      **
     C                     Z-ADDJ8HOJI    S1HOJI
     C                     Z-ADDJ8ONDO    S1ONDO
     C                     Z-ADDJ8CO2P    S1CO2P
     C                     Z-ADDJ8KIK1    S1KIK1
     C                     Z-ADDJ8KIK2    S1KIK2
