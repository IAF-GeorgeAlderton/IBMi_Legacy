     C           A2GSKD    IFEQ 'D'
     C                     ITER
     C                     ENDIF
     C                     MOVE A2ZANM    D2ZANM           MATERIAL NAME
     C                     LEAVE
     C                     ENDDO
     C*
     C           *IN91     IFEQ *ON
     C                     SETON                     2299
     C                     MOVELER,4      D2ERR
     C                     GOTO $CHK2Z
     C                     ENDIF
      *----------------------*
      * MATERIAL PROPERTIES (23)
      *----------------------*
     C           D1TYPE    IFEQ '4'
     C           D1TYPE    OREQ '5'
     C           D1TYPE    OREQ '1'
     C                     ELSE
     C           D2KIKI    IFEQ 0
     C                     SETON                     2399
     C                     MOVELER,5      D2ERR
     C                     GOTO $CHK2Z
     C                     ENDIF
     C                     ENDIF
     C*
      *----------------------*
      *----------------------*
     C                     EXSR #SFSET
      *----------------------*
      *----------------------*
S1   C                     SELEC
-1   C           D2KKBN    WHEQ '0'                        :取消
     C           RRN       IFEQ 0
     C                     MOVEA'111'     *IN,21           : 21-23
     C                     SETON                     99
     C                     MOVELER,8      D2ERR
