     C                     MOVELER,17     D3ERR
     C                     ENDIF
     C           S1KIK2    IFEQ 0
     C                     SETON                     3599
     C                     MOVELER,17     D3ERR
     C                     ENDIF
      *----------------------*
     C           S1DT      LOKUP@DT                      50
     C           *IN50     IFEQ *ON
     C                     MOVEA'11111000'*IN,31           31-38
     C                     SETON                       99
     C                     MOVELER,18     D3ERR
     C                     ELSE
