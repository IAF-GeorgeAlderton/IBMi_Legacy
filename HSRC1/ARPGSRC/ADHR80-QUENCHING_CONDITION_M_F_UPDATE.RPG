      *-------------------------
S1   C                     DO   *HIVAL
     C                     ADD  1         RRN
     C           RRN       CHAINSFREC1               95
     C   95                LEAVE
     C                     MOVEA'00000000'*IN,31           31-38
     C*
 S2  C           S1HOJI    IFEQ 0
     C           S1ONDO    ANDEQ0
     C           S1CO2P    ANDEQ0
     C           S1KIK1    ANDEQ0
     C           S1KIK2    ANDEQ0
 X2  C                     ELSE
     C*----------------------*
