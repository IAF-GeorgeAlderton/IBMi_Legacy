     IINFDS       DS
     I                                    B 378 3790$$RRN
     I****************************
      *プログラム状況データ構造*
     I****************************
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        7  140@SYSHZ
      *
     I            DS
     I                                        1   20S1HOJI
     I                                        3   50S1ONDO
     I                                        6   82S1CO2P
     I                                        9  110S1KIK1
     I                                       12  140S1KIK2
     I                                        1  14 S1DT
      *
      *
      *
     I              '1: OQ       '        C         $TYP1
     I              '2: AOQ      '        C         $TYP2
     I              '3: LAN(HAN) '        C         $TYP3
     I              '4: NUT      '        C         $TYP4
     I              '5: OQ WASHER'        C         $TYP5
     C*===============================================================
     C*
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#PASS   '#PASS            パスワード
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C           @STEP     CASEQ'#DSP3   '#DSP3
     C           @STEP     CASEQ'#CHK3   '#CHK3
     C           @STEP     CASEQ'#CHK3 F5'#CHK3
     C           @STEP     CASEQ'#UPDAT  '#UPDAT
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
      * 初期ﾈｮmb
     C*===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     TIME           @TIME
      *
     C                     MOVE *BLANK    D1TYPE           区分
     C                     MOVE *BLANK    D1ERR
      *
     C                     MOVE '#DSP1   '@STEP
     C                     ENDSR
     C*===============================================================
      *画面１*
     C*===============================================================
     C           #DSP1     BEGSR
     C*
     C                     EXFMTADHPW801
     C                     MOVEA'00000000'*IN,11
     C                     SETOF                     99
      *-------*
     C                     SELEC
      *-------*
      * (F1)  * EXIT
      *-------*
     C           *INKA     WHEQ *ON
     C                     MOVE '#END    '@STEP
      *-------*
      * (F7)  * PASSWORD M/F
      *-------*
     C           *INKG     WHEQ *ON
     C                     MOVE '#PASS   '@STEP
      *-------*
      * (F12) * INQUIRTD
      *-------*
     C           *INKL     WHEQ *ON
     C                     CALL 'ADHR81'
     C                     PARM ' '       P@TYPE  1
     C                     MOVE '#DSP1   '@STEP
      *-------*
      *       *
      *-------*
     C                     OTHER
     C                     MOVE '#CHK1   '@STEP
     C                     ENDSL
     C*
     C                     ENDSR
     C*===============================================================
      *画面１チェック
     C*===============================================================
     C           #CHK1     BEGSR
     C                     SELEC
     C           D1TYPE    WHEQ '1'
     C                     MOVEL$TYP1     D$TYPE
     C                     MOVEL'OQ '     K$ATOK  3        PRESENT PROCESS CODE
     C                     MOVEL'   '     K$PCLS  3        PART CLASS
     C           D1TYPE    WHEQ '2'
     C                     MOVEL$TYP2     D$TYPE
     C                     MOVEL'AOQ'     K$ATOK           PRESENT PROCESS CODE
     C                     MOVEL'   '     K$PCLS           PART CLASS
     C           D1TYPE    WHEQ '3'
     C                     MOVEL$TYP3     D$TYPE
     C                     MOVEL'LAN'     K$ATOK           PRESENT PROCESS CODE
     C                     MOVEL'   '     K$PCLS           PART CLASS
     C           D1TYPE    WHEQ '4'
     C                     MOVEL$TYP4     D$TYPE
     C                     MOVEL'   '     K$ATOK           PRESENT PROCESS CODE
     C                     MOVEL'NUT'     K$PCLS           PART CLASS
     C           D1TYPE    WHEQ '5'
     C                     MOVEL$TYP5     D$TYPE
     C                     MOVEL'   '     K$ATOK           PRESENT PROCESS CODE
     C                     MOVEL'OQW'     K$PCLS           PART CLASS
     C                     OTHER
     C                     SETON                     1199
     C                     MOVELER,1      D1ERR
     C                     ENDSL
      *
     C           *IN99     IFEQ *ON
     C                     MOVE '#DSP1   '@STEP
     C                     ELSE
     C                     SETOF                     20    :LAST TIME
     C                     MOVEA'00000000'*IN,21
     C                     MOVE *BLANK    D2KKBN
     C                     MOVE *BLANK    D2ZACD           MATERIAL CODE
     C                     Z-ADD0         D2KIKI           MATERIAL PROPERTIES
     C                     MOVE *BLANK    D2ZANM           MATERIAL NAME
     C                     MOVE *BLANK    D3KKBN
     C                     MOVE *BLANK    D3ZACD
     C                     Z-ADD0         D3KIKI
     C                     MOVE *BLANK    D3ZANM
     C                     MOVE *BLANK    D2ERR
     C                     MOVE '#DSP2   '@STEP
