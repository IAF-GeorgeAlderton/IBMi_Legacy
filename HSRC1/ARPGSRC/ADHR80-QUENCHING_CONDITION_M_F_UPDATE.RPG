     C           #CHK2     BEGSR
      *----------------------*
      * UPDATE更新区分
      *----------------------*
S1   C                     SELEC
 1   C           D2KKBN    WHEQ '0'                        :取消
     C                     MOVEL'0-CANCEL'D3KKBN
     C                     SETON                     30    (PR)
 1   C           D2KKBN    WHEQ '1'                        :変更
     C                     MOVEL'1-CHANGE'D3KKBN
     C                     SETOF                     30    (CS)
 1   C           D2KKBN    WHEQ '2'                        :追加
     C                     MOVEL'2-ADD   'D3KKBN
     C                     SETOF                     30    (CS)
 1   C                     OTHER
     C                     SETON                     2199
     C                     MOVELER,2      D2ERR
     C                     GOTO $CHK2Z
E1   C                     ENDSL
      *----------------------*
      * MATERIAL CODE (22)
      *----------------------*
     C           D2ZACD    IFEQ *BLANK
     C                     SETON                     2299
     C                     MOVELER,3      D2ERR
