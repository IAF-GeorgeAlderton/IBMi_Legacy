     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           PCMD    2
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVEL'01'      DSPSW   2
     C                     MOVEL*BLANK    D1SHN1
     C                     MOVEL*BLANK    D1SHN2
     C                     MOVEL*BLANK    D1SHN3
     C                     Z-ADD0         D1YMD1
     C                     MOVEL*BLANK    D1SIGN
     C                     Z-ADD0         D1BOX
     C                     Z-ADD0         D1TIMS
     C                     MOVEL*BLANK    Z1SHN1
     C                     MOVEL*BLANK    Z1SF1
     C                     MOVEL*BLANK    Z1SHN2
     C                     MOVEL*BLANK    Z1SF2
     C                     MOVEL*BLANK    Z1SHN3
     C                     MOVEL*BLANK    D1MEM1
     C                     Z-ADD0         Z1YMD1
     C                     MOVEL*BLANK    Z1SIGN
     C                     Z-ADD0         Z1BOX
     C                     Z-ADD0         Z1TIMS
     C                     MOVEL*BLANK    Z1MEM1
     C                     TIME           WTIME
     C                     Z-ADD0         WKMNDT  80
     C                     Z-ADD0         WKMXDT  80
     C                     Z-ADD0         CNT     80
     C                     TIME           WTIME
     C                     MOVEL*BLANK    WKGRP  30
     C           WKGRP     CAT  W#USER:0  WKGRP
     C           WKGRP     CAT  SDATE:0   WKGRP
     C           WKGRP     CAT  STIME:0   WKGRP
     C                     Z-ADD0         WKSEQ   50
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTBTCPW011
     C                     MOVEL*BLANK    D1ERR
     C                     SETOF                     313233
     C                     SETOF                     349930
      *
     C                     TIME           WTIME
     C           *IN01     IFEQ '1'
     C*          CNT       IFNE 0
     C*                    WRITEW1
     C                     MOVEL*BLANK    WKCMD   2
     C*                    EXSR #SB900
     C*          WKCMD     IFEQ '03'
     C*                    GOTO ESB210
     C*                    ENDIF
     C*                    ENDIF
     C                     MOVEL'01'      PCMD
     C                     MOVEL'99'      DSPSW   2
     C                     GOTO ESB210
     C                     ENDIF
      *
     C*          *IN05     IFEQ '1'
      *
     C*          D1SHN     IFEQ *BLANK
     C*          D1YMD1    ANDEQ0
     C*          D1SIGN    ANDEQ*BLANK
     C*          D1BOX     ANDEQ0
     C*          D1TIMS    ANDEQ0
     C*          CNT       IFEQ 0
     C*                    MOVELER,10     D1ERR
     C*                    SETON                     99
     C*                    GOTO ESB210
     C*                    ENDIF
     C*                    MOVEL'05'      PCMD
     C*                    MOVEL'99'      DSPSW   2
     C*                    GOTO ESB210
     C*                    ENDIF
      *
     C*                    ENDIF
      *
     C           D1SHN     IFEQ *BLANK
     C                     MOVELER,1      D1ERR
     C                     SETON                     3099
     C                     GOTO ESB210
     C                     ENDIF
     C           KEYA2     KLIST
     C                     KFLD           D1SHN1
     C                     KFLD           D1SHN2
     C                     KFLD           D1SHN3
     C                     MOVEL'0'       GET     1
     C           KEYA2     SETLLFCEPL011
     C           KEYA2     READEFCEPL011                 20
     C           *IN20     DOWEQ'0'
     C           A2GSKD    IFEQ 'D'
     C           A2GS      ANDLE*DATE
     C                     ELSE
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           KEYA2     READEFCEPL011                 20
     C                     ENDDO
      *
     C           GET       IFEQ '0'
     C                     SETOF                         21
     C           KEYA2     SETLLAKCPL011
     C           KEYA2     READEAKCPL011                 21
     C           *IN21     DOWEQ'0'
     C           M1SKJY    IFEQ 'D'
     C                     ELSE
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           KEYA2     READEAKCPL011                 21
     C                     ENDDO
     C           GET       IFEQ '0'
     C                     MOVELER,8      D1ERR
     C                     SETON                     3099
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
      *
     C                     MOVEL'0'       GET     1
     C           KEYA2     SETLLAGAPL311
     C           KEYA2     READEAGAPL311                 20
     C           *IN20     DOWEQ'0'
     C           CBSKJY    IFEQ 'D'
     C           CBSKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           KEYA2     READEAGAPL311                 20
     C                     ENDDO
     C           GET       IFEQ '1'
     C**                   MOVELER,11     D1ERR
     C**                   SETON                     3099
     C**                   GOTO ESB210
     C                     ENDIF
      *
     C           D1YMD1    IFEQ 0
     C                     MOVELER,2      D1ERR
     C                     SETON                     3199
     C                     GOTO ESB210
     C                     ENDIF
     C           D1YMD1    IFLE *DATE
     C                     MOVELER,6      D1ERR
     C                     SETON                     3199
     C                     GOTO ESB210
     C                     ENDIF
     C           KEYF8     KLIST
     C                     KFLD           D1YY
     C                     KFLD           D1MM
     C                     KFLD           D1DD
     C           KEYF8     CHAINAGDPL121             20
     C           *IN20     IFEQ '1'
     C                     MOVELER,7      D1ERR
     C                     SETON                     3199
     C                     GOTO ESB210
     C                     ENDIF
     C           D1MNDT    IFNE 0
     C           D1YMD1    IFLT D1MNDT
     C*                    MOVELER,9      D1ERR
     C*                    SETON                     3199
     C*                    GOTO ESB210
     C                     ENDIF
     C           D1YMD1    IFGT D1MXDT
     C*                    MOVELER,9      D1ERR
     C*                    SETON                     3199
     C*                    GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
     C           D1SIGN    IFEQ *BLANK
     C           D1SIGN    OREQ '+'
     C           D1SIGN    OREQ '-'
     C                     ELSE
     C                     MOVELER,3      D1ERR
     C                     SETON                     3299
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1BOX     IFEQ 0
     C                     MOVELER,4      D1ERR
     C                     SETON                     3399
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1TIMS    IFEQ 0
     C                     MOVELER,5      D1ERR
     C                     SETON                     3499
     C                     GOTO ESB210
     C                     ENDIF
     C                     Z-ADD1         X       30
     C                     Z-ADD0         WKKA    80
     C           KEYF8     SETLLAGDPL121
     C                     READ AGDPL121                 20
     C           *IN20     DOWEQ'0'
     C           X         ANDLED1TIMS
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    OREQ *BLANK
     C           X         IFEQ D1TIMS
     C                     Z-ADDF8KA      WKKA
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDIF
     C                     READ AGDPL121                 20
     C                     ENDDO
     C           WKKA      IFEQ 0
     C                     MOVELER,7      D1ERR
     C                     SETON                     3499
     C                     GOTO ESB210
     C                     ENDIF
     C           D1MXDT    IFNE 0
     C           WKKA      IFGT D1MXDT
     C*                    MOVELER,9      D1ERR
     C*                    SETON                     3499
     C*                    GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN05     IFEQ '1'
     C                     EXSR #SB500
     C           WKMNDT    IFEQ 0
     C                     EXSR #SB220
     C                     ENDIF
     C                     MOVELD1SHN1    Z1SHN1
     C                     MOVEL'-'       Z1SF1
     C                     MOVELD1SHN2    Z1SHN2
     C                     MOVEL'-'       Z1SF2
     C                     MOVELD1SHN3    Z1SHN3
     C                     Z-ADDD1YMD1    Z1YMD1
     C                     MOVELD1SIGN    Z1SIGN
     C                     Z-ADDD1BOX     Z1BOX
     C                     Z-ADDD1TIMS    Z1TIMS
     C                     MOVELD1MEM1    Z1MEM1
     C                     MOVEL*BLANK    D1SHN1
     C                     MOVEL*BLANK    D1SHN2
     C                     MOVEL*BLANK    D1SHN3
     C                     Z-ADD0         D1YMD1
     C                     MOVEL*BLANK    D1SIGN
     C                     Z-ADD0         D1BOX
     C                     Z-ADD0         D1TIMS
     C                     MOVEL*BLANK    D1MEM1
     C                     ADD  1         D1CNT
     C                     ADD  1         CNT     80
     C                     ENDIF
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C           KEYDT     KLIST
     C                     KFLD           ##YY
     C                     KFLD           ##MM
     C                     KFLD           ##DD
      * MIN
     C                     Z-ADD1         X       30
     C                     Z-ADDWKKA      ##DT
     C           KEYDT     SETGTAGDPL121
     C                     READPAGDPL121                 20
     C           *IN20     DOWEQ'0'
     C           X         ANDLE99
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    OREQ *BLANK
     C                     Z-ADDF8KA      WKMNDT
     C                     ADD  1         X
     C                     ENDIF
     C                     READPAGDPL121                 20
     C                     ENDDO
      * MAX
     C                     Z-ADD1         X       30
     C                     Z-ADDD1YMD1    ##DT
     C           KEYDT     SETLLAGDPL121
     C                     READ AGDPL121                 20
     C           *IN20     DOWEQ'0'
     C           X         ANDLE99
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    OREQ *BLANK
     C                     Z-ADDF8KA      WKMXDT
     C                     ADD  1         X
     C                     ENDIF
     C                     READ AGDPL121                 20
     C                     ENDDO
      *
     C                     Z-ADDWKMNDT    D1MNDT
     C                     Z-ADDWKMXDT    D1MXDT
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB900    BEGSR
      *
     C           @@D0A     TAG
     C                     EXFMTBTCPW01A
      *
     C                     SELEC
      * F3
     C           *IN03     WHEQ '1'
     C                     MOVE '03'      WKCMD
     C                     GOTO ESB900
      * F5
     C           *IN05     WHEQ '1'
     C                     MOVE '05'      WKCMD
     C                     GOTO ESB900
     C                     ENDSL
      *
     C                     GOTO @@D0A
      *
     CSR         ESB900    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * OUTPUT                                             *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARBTCWP011
     C                     MOVELWKGRP     W1GRP
     C                     ADD  1         WKSEQ
     C                     MOVE WKSEQ     W1SEQ
     C                     MOVELD1SHN1    W1SHN1
     C                     MOVELD1SHN2    W1SHN2
     C                     MOVELD1SHN3    W1SHN3
     C                     Z-ADDD1YMD1    W1YMD1
     C                     MOVELD1SIGN    W1SIGN
     C                     Z-ADDD1BOX     W1BOX
     C**                   Z-ADDD1TIMS    W1TIMS
     C           D1BOX     DIV  D1TIMS    W1BOX1
     C                     MVR            AMR     30
     C           AMR       IFNE 0
     C                     ADD  1         W1BOX1
     C                     ENDIF
     C           D1BOX     DIV  W1BOX1    W1TIMS
     C                     MOVELD1MEM1    W1MEM1
     C                     MOVEL*BLANK    W1MEM2
     C                     WRITEBTCWP011
      *
     CSR         ESB500    ENDSR
** ER
E-01 INPUT PART NO.
E-02 INPUT START DATE.
E-03 INPUT + OR -.
E-04 INPUT BOXES.
E-05 INPUT TIMES OF DIVISION.
E-06 DATE ERR.(CAN'T INPUT PAST DATE)
E-07 DATE ERR.(NO AOYAMA CALENDAR)
E-08 NO PART M/F.
E-09 DATE ERR.(MORE 99)
E-10 NO DATA INPUTED.
E-11 THIS PART IS NOT ASJ PART.
