     H            Y.
      ** ANYR72 ********************************************
      *  ASJ PT PART DATE UPDATE                           *
      *                                                    *
      * TCHK  12/22/11 CREATE                              *
      ******************************************************
     FANYPW72 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL010
     F                                              KINFDS @INFDS
     FAGDPL12 IF  E           K        DISK
     FANYPP72 UF  E           K        DISK                      A
      *---------------------------------------------------
     E                    ERR     1  15 60
      *---------------------------------------------------
     I@INFDS      DS
     I                                     *STATUS  @STTS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME(6) + DATE(6)
     I            DS
     I                                        1  140WWTIME
     I                                        1   60WTIME
     I                                        1   40WTIM4
     I                                        1   20WTIMH
     I                                        3   40WTIMM
     I                                        7  120WSDATE
     I                                        9  120@@YM4
     I                                        7  120@@YM6
     I                                        7  140@@YMD
     I                                        7  100@@YY
     I                                       11  120@@MM
     I                                       13  140@@DD
     I            DS
     I                                        1  14 W@SHIN
     I                                        1   5 W@SHN1
     I                                        6   6 W@SHNA
     I                                        7  11 W@SHN2
     I                                       12  12 W@SHNB
     I                                       13  14 W@SHN3
     I            DS
     I                                        1   80ANPTDT
     I                                        1   40ANPTYY
     I                                        5   60ANPTMM
     I                                        7   80ANPTDD
     I            DS
     I                                        1   80F2PTDT
     I                                        1   40F2PTYY
     I                                        5   60F2PTMM
     I                                        7   80F2PTDD
      * ----------------------------------------------------
     C                     TIME           WWTIME
      ******************************************************
      *  MAIN
      ******************************************************
     C*
     C                     EXSR @S1INT
     C                     EXSR @S1SET
      *
     C                     DO   *HIVAL
      *
     C                     WRITEFMT090
     C                     Z-ADDW#RCN1    #RCN01
     C                     EXFMTCTL010
     C   KA                LEAVE
      *
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RCN1
     C                     END
      *
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      W#P1ER  1
      * add new
     C           *INKH     IFEQ *ON
     C                     EXSR @S2ADD
     C   KA                LEAVE
     C                     EXSR @S1INT
     C                     EXSR @S1SET
     C                     ITER
     C                     END
      * change
     C                     EXSR @S2CHG
     C   KA                LEAVE
     C                     EXSR @S1INT
     C                     EXSR @S1SET
     C                     ITER
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C*----------------------------------------------------*
      *  1ST SCREEN INITIALIZE
     C*----------------------------------------------------*
     C           @S1INT    BEGSR
      *
     C                     MOVEL*ON       *IN41
     C                     WRITECTL010
     C                     MOVEL*OFF      *IN41
      *
     C                     Z-ADD1         W#RCN1  40
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  SET
     C*----------------------------------------------------*
     C           @S1SET    BEGSR
      *
     C                     Z-ADD*ZERO     RRN1    40
     C           *LOVAL    SETLLANYPP72
      *
     C                     DO   *HIVAL
      *
     C                     READ ANYPP72             N    98
     C   98                LEAVE
     C           ANSKJY    IFNE *BLANK
     C                     ITER
     C                     END
      *
     C                     CLEARSFL010
     C*
     C                     MOVELANSHN1    S1SHN1
     C                     MOVELANSHN2    S1SHN2
     C                     MOVELANSHN3    S1SHN3
     C                     Z-ADDANPTDT    S1PTDT
     C*
     C                     ADD  1         RRN1
     C                     WRITESFL010
     C*
     C                     ENDDO
     C*
     C           RRN1      IFEQ *ZERO
     C                     CLEARSFL010
     C                     Z-ADD1         RRN1
     C                     MOVEL*ON       *IN31
     C                     WRITESFL010
     C                     MOVEL*ON       *IN69
     C                     MOVELERR,1     MSG
     C                     MOVEL*OFF      *IN31
     C                     END
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  ADD NEW RECORD
     C*----------------------------------------------------*
     C           @S2ADD    BEGSR
      *
     C                     EXSR @S2INT
     C                     MOVEL'ADD    ' F2ACTN    P
      *
     C                     DO   *HIVAL
      *
     C                     EXFMTFMT020
     C   KA
     COR KL                LEAVE
      *
     C                     MOVEL*OFF      *IN69
     C                     EXSR @S2CHK
     C           *IN69     IFEQ *OFF
     C           *INKE     IFEQ *ON
     C                     EXSR @ADDF
     C           *IN69     IFEQ *OFF
     C                     LEAVE
     C                     END
     C                     END
     C                     END
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  INITIAL SET TO FMT020
     C*----------------------------------------------------*
     C           @S2INT    BEGSR
     C*
     C                     SETOF                     5152
     C                     SETOF                     616269
     C*
     C                     MOVEL*BLANK    F2SHN1
     C                     MOVEL*BLANK    F2SHN2
     C                     MOVEL*BLANK    F2SHN3
     C                     Z-ADD*ZERO     F2PTYY
     C                     Z-ADD*ZERO     F2PTMM
     C                     Z-ADD*ZERO     F2PTDD
     C*
     C                     MOVEL*BLANK    MSG
     C*
     C                     ENDSR
     C*----------------------------------------------------*
     C*  CHECK FMT020
     C*----------------------------------------------------*
     C           @S2CHK    BEGSR
     C*
     C                     SETOF                     5152
     C                     MOVEL*BLANK    MSG
     C*
     C                     DO
     C*
     C           F2SHN1    IFEQ *BLANK
     C           F2SHN2    ANDEQ*BLANK
     C           F2SHN3    ANDEQ*BLANK
     C                     SETON                     5169
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,2     MSG
     C                     END
     C                     END
     C*
     C           K#AGD     KLIST
     C                     KFLD           F2PTYY
     C                     KFLD           F2PTMM
     C                     KFLD           F2PTDD
     C           K#AGD     CHAINAGDPL12              91
     C           *IN91     IFEQ *ON
     C                     SETON                     5269
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,3     MSG
     C                     END
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  WRITE NEW RECORD
     C*----------------------------------------------------*
     C           @ADDF     BEGSR
      *
     C                     DO
      *
     C           K#FSHN    KLIST
     C                     KFLD           F2SHN1
     C                     KFLD           F2SHN2
     C                     KFLD           F2SHN3
     C           K#FSHN    CHAINANYPP72              98
     C           *IN98     IFEQ *OFF
     C           ANSKJY    ANDEQ*BLANK
     C                     SETON                     515269
     C                     MOVELERR,04    MSG
     C                     LEAVE
     C                     END
     C*
     C                     CLEARANYPP72R
     C*
     C                     EXSR @EDTF
      *
     C           *IN98     IFEQ *OFF
     C                     UPDATANYPP72R
     C                     ELSE
     C                     WRITEANYPP72R
     C                     END
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  EDIT RECORD (NEW/CHANGE)
     C*----------------------------------------------------*
     C           @EDTF     BEGSR
     C*
     C                     TIME           WWTIME
     C                     Z-ADD@@YY      ANKOYY
     C                     Z-ADD@@MM      ANKOMM
     C                     Z-ADD@@DD      ANKODD
     C                     Z-ADDWTIMH     ANKOHH
     C                     Z-ADDWTIMM     ANKOSS
     C                     MOVEL#PGM      ANPGMN
     C                     MOVEL#USER     ANKOME
     C*
     C                     MOVELF2SHN1    ANSHN1
     C                     MOVELF2SHN2    ANSHN2
     C                     MOVELF2SHN3    ANSHN3
     C                     Z-ADDF2PTYY    ANPTYY
     C                     Z-ADDF2PTMM    ANPTMM
     C                     Z-ADDF2PTDD    ANPTDD
     C*
     C                     ENDSR
     C*----------------------------------------------------*
      *  CHANGE/DELETE MAIN
     C*----------------------------------------------------*
     C           @S2CHG    BEGSR
      *
     C                     Z-ADD*ZERO     RRN1
      *
     C                     DO   *HIVAL
      *
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL010               98
     C   98                LEAVE
     C           S1SEL     IFEQ *BLANK
     C                     ITER
     C                     END
      *
     C                     EXSR @S2CDP
     C   KA                LEAVE
      *
     C                     MOVEL*BLANK    S1SEL
     C                     MOVEL*ON       *IN32
     C                     UPDATSFL010
     C                     MOVEL*OFF      *IN32
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  CHANGE/DELETE SET
     C*----------------------------------------------------*
     C           @S2CDP    BEGSR
      *
     C                     EXSR @S2INT
     C           S1SEL     IFEQ 'C'
     C                     MOVEL'CHANGE  'F2ACTN    P
     C                     MOVEL*ON       *IN61
     C                     MOVEL*OFF      *IN62
     C                     ELSE
     C                     MOVEL'DELETE  'F2ACTN    P
     C                     MOVEL*ON       *IN61
     C                     MOVEL*ON       *IN62
     C                     END
     C                     MOVELS1SHN1    F2SHN1
     C                     MOVELS1SHN2    F2SHN2
     C                     MOVELS1SHN3    F2SHN3
     C                     Z-ADDS1PTDT    F2PTDT
      *
     C                     DO   *HIVAL
      *
     C                     EXFMTFMT020
     C   KA
     COR KL                LEAVE
      *
     C           *INKE     IFEQ *ON
     C                     EXSR @CHGF
     C                     LEAVE
     C                     END
      *
     C                     ENDDO
      *
     C                     ENDSR
     C*----------------------------------------------------*
      *  UPDAT
     C*----------------------------------------------------*
     C           @CHGF     BEGSR
      *
     C                     DO
      *
     C           K#FSHN    CHAINANYPP72R             98
     C           *IN98     IFEQ *ON
     C                     LEAVE
     C                     END
      *
     C           S1SEL     IFEQ 'D'
     C                     TIME           WWTIME
     C                     MOVEL'D'       ANSKJY
     C                     Z-ADD@@YY      ANKOYY
     C                     Z-ADD@@MM      ANKOMM
     C                     Z-ADD@@DD      ANKODD
     C                     Z-ADDWTIMH     ANKOHH
     C                     Z-ADDWTIMM     ANKOSS
     C                     MOVEL#PGM      ANPGMN
     C                     MOVEL#USER     ANKOME
     C                     ELSE
     C                     EXSR @EDTF
     C                     END
      *
     C                     UPDATANYPP72R
      *
     C                     ENDDO
      *
     C                     ENDSR
