     H            Y.
     F** AB#RAQ ****************************************************************
     F*  UPDATE LABEL DATA                                                     *
     F*                                                                        *
JW1  F*  JW(SRAA) 2015/12/15 ADD LINE: SKIP IF 7450(PISTON)                    *
JW2  F*  JW       2021.04.22 CHG SUMMARIZING SCAN QTY                          *
     F****************************************** AB#RAQ ************************
     FAB#PWAQ CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                        RRN2  KSFILE SFL02
     FAB#PL70 IF  E           K        DISK
     F            AB#PP701                          KRENAMEAB#PL70R
     FAB#PL71 UF  E           K        DISK
     FAB#PL14 IF  E           K        DISK
     E*****************************************************************
     E                    ER      1   8 60
     E                    CMD     1   3 78
     I*****************************************************************
     I@INFDA      DS
     I                                    B 397 4000@@RCD
     I            DS
     I                                        1   60EKTIME
     I                                        1   20EKKOHH
     I                                        3   40EKKOMN
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@NOYY
     I                                        5   60K@NOMM
     I                                        7   80K@NODD
     I            DS
     I                                        1  12 S@PART
     I                                        1   5 S@PRT1
     I                                        6  10 S@PRT2
     I                                       11  12 S@PRT3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-------------------------------------------------------------
      *  MAIN
      *-------------------------------------------------------------
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C           @@ID      CASEQ'02'      #SCRN2
     C           @@ID      CASEQ'03'      #SCRN3
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-------------------------------------------------------------
      *  INITIALIZE
      *-------------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#14      KLIST
     C                     KFLD           K@NOYY
     C                     KFLD           K@NOMM
     C                     KFLD           K@NODD
     C                     KFLD           D@NOBN
     C                     KFLD           K@DEYY  40
     C                     KFLD           K@DEMM  20
     C                     KFLD           K@DEDD  20
     C                     KFLD           D@NONY  40
     C                     KFLD           D@NKOJ  1
     C                     KFLD           D@NUKE  4
     C           K#70      KLIST
     C                     KFLD           BATOKU
     C                     KFLD           @@NONY  4
     C                     KFLD           BANKOJ
     C                     KFLD           BANUKE
     C                     KFLD           BAMHN1
     C                     KFLD           BAMHN2
     C                     KFLD           BAMHN3
     C                     KFLD           BAMHN4
     C                     KFLD           @@ODRN 10
     C                     KFLD           BANOYY
     C                     KFLD           BANOMM
     C                     KFLD           BANODD
     C                     KFLD           @@NOBN  2
      *
     C           K#7Y      KLIST
     C                     KFLD           H@TOKU
     C                     KFLD           H@NONY
     C                     KFLD           H@NKOJ
     C                     KFLD           H@NUKE
     C                     KFLD           H@MHN1
     C                     KFLD           H@MHN2
     C                     KFLD           H@MHN3
     C                     KFLD           H@MHN4
     C                     KFLD           @@ODRN
     C                     KFLD           H@NOYY
     C                     KFLD           H@NOMM
     C                     KFLD           H@NODD
     C                     KFLD           H@NOBN
      *
     C                     MOVE '01'      @@ID    2
      *
     C                     ENDSR
      *-------------------------------------------------------------
      *  1ST SCREEN
      *-------------------------------------------------------------
     C           #SCRN1    BEGSR
      *
     C                     MOVE CMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
      * F1: END
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
      * ENTER KEY
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           RRN1      IFEQ 0
     C                     MOVE ER,5      MSG
     C                     ELSE
     C                     MOVE '02'      @@ID
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *-------------------------------------------------------------
      *  CHECK
      *-------------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     MOVEA'00000000'*IN,61
     C                     SETOF                     99
     C                     MOVE *BLANK    MSG
      *
     C           D@CUST    IFEQ 5149
     C                     SETON                     6199
     C                     MOVELER,1      MSG
     C                     ELSE
      *
     C                     Z-ADDD@DATE    K@YMD
     C           K#14      SETLLAB#PL14
     C           *IN90     DOUEQ*ON
     C           K#14      READEAB#PL14                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     MOVELER,2      MSG
     C                     MOVEA'111111'  *IN,61
     C                     MOVE *ON       *IN99
     C                     ENDIF
     C                     ENDIF
     C           *IN99     IFEQ *OFF
     C                     EXSR #SCK
     C                     ENDIF
      *
     C                     ENDSR
      *-------------------------------------------------------------
      *  SCAN CHECK
      *-------------------------------------------------------------
     C           #SCK      BEGSR
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     MOVE *ON       *IN32
     C                     WRITECTL01
     C                     MOVE *OFF      *IN32
      *
     C           K#14      SETLLAB#PL14
     C           *IN90     DOUEQ*ON
     C           K#14      READEAB#PL14                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
      *
     C                     MOVE BANONY    @@NONY
     C                     MOVE BANOBN    @@NOBN
     C                     MOVE BAODRN    @@ODRN
     C                     Z-ADD*ZERO     @@QTY   90
     C           K#70      SETLLAB#PL70
     C           *IN91     DOUEQ*ON
     C           K#70      READEAB#PL70                  91
     C           *IN91     IFEQ *OFF
     C           EKSKJY    ANDEQ*BLANK
     C                     ADD  EKSRYO    @@QTY
     C                     ENDIF
     C                     ENDDO
      *
JW1  C**         BATOKU    IFNE 7450
JW2  C           @@QTY     IFEQ 0
     C                     MOVELBAINVN    @@ODRN
     C           K#70      SETLLAB#PL70
     C           *IN91     DOUEQ*ON
     C           K#70      READEAB#PL70                  91
     C           *IN91     IFEQ *OFF
     C           EKSKJY    ANDEQ*BLANK
     C                     ADD  EKSRYO    @@QTY
     C                     ENDIF
     C                     ENDDO
JW1  C                     ENDIF
      *
     C           @@QTY     IFLT BASRYO
     C                     CLEARSFL01
     C                     ADD  1         RRN1
     C                     MOVE BASHN1    S@PRT1
     C                     MOVE BASHN2    S@PRT2
     C                     MOVE BASHN3    S@PRT3
     C                     MOVE BAODRN    S@ODRN
     C                     Z-ADD@@QTY     S@QTY2
     C                     Z-ADDBASRYO    S@QTY1
     C           BASRYO    SUB  @@QTY     S@QTY3
     C                     MOVE BATOKU    H@TOKU
     C                     MOVE BANONY    H@NONY
     C                     MOVE BANKOJ    H@NKOJ
     C                     MOVE BANUKE    H@NUKE
     C                     MOVE BAMHN1    H@MHN1
     C                     MOVE BAMHN2    H@MHN2
     C                     MOVE BAMHN3    H@MHN3
     C                     MOVE BAMHN4    H@MHN4
     C                     MOVE BAODRN    H@ODRN
     C                     MOVE BANOYY    H@NOYY
     C                     MOVE BANOMM    H@NOMM
     C                     MOVE BANODD    H@NODD
     C                     MOVE BANOBN    H@NOBN
     C                     MOVE BAINVN    H@INVN
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-------------------------------------------------------------
      *  2ND SCREEN
      *-------------------------------------------------------------
     C           #SCRN2    BEGSR
      *
     C                     MOVE CMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN31
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN31
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      @@ID
     C                     OTHER
     C                     EXSR #CHK2
     C                     ENDSL
      *
     C                     ENDSR
      *-------------------------------------------------------------
      *  SCAN CHECK
      *-------------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     Z-ADD*ZERO     WRRN    40
      *
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           S@SLCT    ANDNE*BLANK
     C                     MOVE *BLANK    S@SLCT
     C                     UPDATSFL01
     C                     MOVE S@PRT1    D@PRT1
     C                     MOVE S@PRT2    D@PRT2
     C                     MOVE S@PRT3    D@PRT3
     C                     MOVELS@ODRN    D@ODRN
     C                     Z-ADDS@QTY1    D@TOTQ
     C                     Z-ADDS@QTY2    D@SCNQ
     C                     Z-ADDS@QTY2    W@SCNQ  90
     C                     EXSR #NEXT
     C           RRN2      IFEQ *ZERO
     C           ER,6      CAT  S@PART:1  MSG       P
     C                     ELSE
     C                     MOVE '03'      @@ID
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-------------------------------------------------------------
      *  NEXT
      *-------------------------------------------------------------
     C           #NEXT     BEGSR
      *
     C                     Z-ADD*ZERO     RRN2    40
     C                     MOVE *ON       *IN34
     C                     WRITECTL02
     C                     MOVE *OFF      *IN34
      *
     C                     MOVE H@ODRN    @@ODRN
     C           K#7Y      SETLLAB#PL70
     C           *IN93     DOUEQ*ON
     C           K#7Y      READEAB#PL70                  93
     C           *IN93     IFEQ *OFF
JW   C           EKSKJY    ANDNE'D'
     C           EKSRYO    ANDEQ*ZERO
     C                     CLEARSFL02
     C                     MOVELEKSERL    S@SERL
     C                     MOVE EKSYOS    S@QTY
JW    * LABEL TYPE
 .   C           EKLOC1    IFEQ ' '
 .   C                     MOVELER,7      S@LBL
 .   C                     ELSE
 .   C                     MOVELER,8      S@LBL
JW   C                     ENDIF
 .   C           EKNONY    IFEQ '8450'
 .   C           EKSYOS    IFEQ '99999'
 .   C                     MOVELER,7      S@LBL
 .   C                     ELSE
 .   C                     MOVELER,8      S@LBL
 .   C                     ENDIF
JW   C                     ENDIF
      *
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVELH@INVN    @@ODRN
     C           K#7Y      SETLLAB#PL70
     C           *IN93     DOUEQ*ON
     C           K#7Y      READEAB#PL70                  93
     C           *IN93     IFEQ *OFF
JW   C           EKSKJY    ANDNE'D'
     C           EKSRYO    ANDEQ*ZERO
     C                     CLEARSFL02
     C                     MOVELEKSERL    S@SERL
     C                     MOVE EKSYOS    S@QTY
JW    * LABEL TYPE
 .   C           EKLOC1    IFEQ ' '
 .   C                     MOVELER,7      S@LBL
 .   C                     ELSE
 .   C                     MOVELER,8      S@LBL
JW   C                     ENDIF
 .   C           EKNONY    IFEQ '8450'
 .   C           EKSYOS    IFEQ '99999'
 .   C                     MOVELER,7      S@LBL
 .   C                     ELSE
 .   C                     MOVELER,8      S@LBL
 .   C                     ENDIF
JW   C                     ENDIF
      *
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-------------------------------------------------------------
      *  3RD SCREEN
      *-------------------------------------------------------------
     C           #SCRN3    BEGSR
      *
     C                     MOVE CMD,3     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN33
     C                     EXFMTCTL02
     C                     MOVE *OFF      *IN33
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKL     WHEQ *ON
     C                     MOVE '02'      @@ID
     C                     OTHER
     C                     EXSR #CHK3
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPSC
     C                     EXSR #SCK
     C           RRN1      IFGT *ZERO
     C                     MOVE '02'      @@ID
     C                     ELSE
     C                     MOVE '99'      @@ID
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *-------------------------------------------------------------
      *  CHECK
      *-------------------------------------------------------------
     C           #CHK3     BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVE *BLANK    MSG
      *
     C                     Z-ADDW@SCNQ    @@SCNQ  90
     C                     Z-ADD*ZERO     WRRN    40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL02                90
     C           *IN90     IFEQ *OFF
     C           S@UPID    ANDNE*BLANK
     C                     ADD  S@QTY     @@SCNQ
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD@@SCNQ    D@SCNQ
     C           @@SCNQ    IFNE D@TOTQ
     C                     MOVELER,4      MSG
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     ENDSR
      *-------------------------------------------------------------
      *  UPDATE LABEL FILE
      *-------------------------------------------------------------
     C           #UPSC     BEGSR
      *
     C                     Z-ADD*ZERO     WRRN    40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL02                90
     C           *IN90     IFEQ *OFF
     C           S@UPID    ANDNE*BLANK
     C           S@SERL    CHAINAB#PL71              95
     C           *IN95     IFEQ *OFF
      * DO NOT CAHNGE DATE AND TIME TO KEEP CREATE DATE AND TIME
JW   C**JW                 Z-ADD*YEAR     EKKOYY
 .   C**                   Z-ADD*MONTH    EKKOMM
 .   C**                   Z-ADD*DAY      EKKODD
JW   C**                   TIME           EKTIME
      * SCAN DATE AND TIME
     C                     MOVEL#USER     EKKOME
     C                     Z-ADD*YEAR     EKDEYY
     C                     Z-ADD*MONTH    EKDEMM
     C                     Z-ADD*DAY      EKDEDD
     C                     TIME           EKDETM
      *
     C                     Z-ADDS@QTY     EKSRYO
     C                     UPDATAB#PP701
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C***********************************************************
