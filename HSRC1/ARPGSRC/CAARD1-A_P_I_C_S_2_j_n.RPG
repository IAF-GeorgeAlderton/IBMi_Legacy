     H            Y.
     F** CAARD1 ************************************
     F*  ..пјЎпјЌпј°пј©пјЈпјів…ЎгЂЂгѓ‡гѓјг‚їг‚·гѓ•гѓ€..        *
     F*  ..пјЎпјЌпј°пј©пјЈпјів…Ўе№іжє–еЊ–зўєе®љз™єжіЁгѓ•г‚Ўг‚¤гѓ«  *
     F*  ..пј·пјЇпјІпј«гѓ•г‚Ўг‚¤гѓ«                      *
     F*      I-HASADA                93.05.13      *
     F************************************ CAARD1 **
     FCABWP01 UP  E                    DISK
     FCABPL01 UF  E           K        DISK                      A
     I            DS
     I                                        1   80GBUKHZ
     I                                        1   40GBUKYY
     I                                        5   60GBUKMM
     I                                        7   80GBUKDD
     C           KEY1      KLIST
     C                     KFLD           GBSHN1
     C                     KFLD           GBSHN2
     C                     KFLD           GBSHN3
      *
     C           GBFRAG    IFEQ '1'
     C                     DELETCABWP011
     C                     GOTO END
     C                     END
      *
     C           GBUKHZ    IFGT *DATE
     C                     GOTO END
     C                     END
      *
     C                     SETOF                     10
     C           KEY1      CHAINCABPL011             10
      *
     C           GBKBBN    IFEQ '2'
     C                     Z-ADDGBBHAS    C3BHAS
     C                     Z-ADDGBT1SU    C3T1SU
     C                     Z-ADDGBT1KU    C3T1KU
     C                     Z-ADDGBT2SU    C3T2SU
     C                     Z-ADDGBT2KU    C3T2KU
     C                     Z-ADDGBY1SU    C3Y1SU
     C                     Z-ADDGBY1KU    C3Y1KU
     C                     Z-ADDGBY2SU    C3Y2SU
     C                     Z-ADDGBY2KU    C3Y2KU
     C                     END
      *
     C           *IN10     IFEQ '1'
     C                     Z-ADDGBBHAS    C3BHAS
     C                     MOVELGBRTNO    C3RTNO
     C                     Z-ADDGBT1SU    C3T1SU
     C                     Z-ADDGBT1KU    C3T1KU
     C                     Z-ADDGBT2SU    C3T2SU
     C                     Z-ADDGBT2KU    C3T2KU
     C                     Z-ADDGBY1SU    C3Y1SU
     C                     Z-ADDGBY1KU    C3Y1KU
     C                     Z-ADDGBY2SU    C3Y2SU
     C                     Z-ADDGBY2KU    C3Y2KU
     C                     ELSE
      *
     C           C3SKJY    IFEQ 'D'
     C           C3SKHZ    ANDLE*DATE
     C                     Z-ADDGBBHAS    C3BHAS
     C                     Z-ADDGBT1SU    C3T1SU
     C                     Z-ADDGBT1KU    C3T1KU
     C                     Z-ADDGBT2SU    C3T2SU
     C                     Z-ADDGBT2KU    C3T2KU
     C                     Z-ADDGBY1SU    C3Y1SU
     C                     Z-ADDGBY1KU    C3Y1KU
     C                     Z-ADDGBY2SU    C3Y2SU
     C                     Z-ADDGBY2KU    C3Y2KU
     C                     END
     C                     END
      *
     C                     MOVELGBSKJY    C3SKJY
     C                     Z-ADDGBSKYY    C3SKYY
     C                     Z-ADDGBSKMM    C3SKMM
     C                     Z-ADDGBSKDD    C3SKDD
     C                     Z-ADDGBKOYY    C3KOYY
     C                     Z-ADDGBKOMM    C3KOMM
     C                     Z-ADDGBKODD    C3KODD
     C                     Z-ADDGBKOHH    C3KOHH
     C                     Z-ADDGBKOSS    C3KOSS
     C                     MOVELGBKOME    C3KOME
     C                     MOVELGBSHN1    C3SHN1
     C                     MOVELGBSHN2    C3SHN2
     C                     MOVELGBSHN3    C3SHN3
     C                     Z-ADDGBUKYY    C3UKYY
     C                     Z-ADDGBUKMM    C3UKMM
     C                     Z-ADDGBUKDD    C3UKDD
     C                     Z-ADDGBUKBB    C3UKBB
     C                     Z-ADDGBTAYY    C3TAYY
     C                     Z-ADDGBTAMM    C3TAMM
     C                     Z-ADDGBTADD    C3TADD
     C                     MOVELGBSJSR    C3SJSR
     C                     Z-ADDGBGEHA    C3GEHA
     C                     Z-ADDGBSJSU    C3SJSU
     C                     MOVELGBZETI    C3ZETI
     C                     Z-ADDGBTBCD    C3TBCD
     C                     Z-ADDGBMBCD    C3MBCD
     C                     MOVELGBTKR1    C3TKR1
     C                     MOVELGBTKR2    C3TKR2
     C                     MOVELGBTKR3    C3TKR3
     C                     MOVELGBTKR4    C3TKR4
     C                     Z-ADDGBMKBA    C3MKBA
     C                     MOVELGBRAIN    C3RAIN
     C                     Z-ADDGBPROL    C3PROL
     C                     Z-ADDGBCART    C3CART
     C                     MOVE GBGYOM    C3GYOM
     C                     Z-ADDGBGYYY    C3GYYY
     C                     Z-ADDGBGYMM    C3GYMM
     C                     Z-ADDGBGYDD    C3GYDD
      *
     C                     MOVE GBTYPE    C3TYPE
      *
     C           *IN10     IFEQ '1'
     C                     WRITECABPL011
     C                     ELSE
     C                     UPDATCABPL011
     C                     END
      *
     C                     MOVEL'1'       GBFRAG
     C                     UPDATCABWP011
      *
     C           END       TAG
