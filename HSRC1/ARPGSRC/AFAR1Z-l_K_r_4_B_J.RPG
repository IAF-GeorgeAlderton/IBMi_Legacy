     C*-------------------------*
     C                     DO   *HIVAL
     C                     READ INPUT                    90
     C   90                LEAVE
     C*
     C                     EXSR ##MAE
     C                     EXCPT$UPDAT
     C*
     C                     ENDDO
     C*-------------------------*
     C                     SETON                     LR
     C                     RETRN
      *================================================================
      *  ..前工程番地を求める
      *================================================================
     C           ##MAE     BEGSR
      *
     C           KEY1      KLIST
     C                     KFLD           IHIN1
     C                     KFLD           IHIN2
     C                     KFLD           IHIN3
      *
     C                     MOVEL*BLANK    $$MAE   6        前工程番地
      *
     C           KEY1      CHAINAAMPL111             91
     C   91                GOTO $MAEZ
     C           CKSKJY    IFEQ 'D'
     C           CKSKHZ    ANDLE*DATE
     C                     GOTO $MAEZ
     C                     ENDIF
      *
     C                     SETOF                     10
     C*-------------------------*
S1   C           1         DO   15        XX      20
     C           16        SUB  XX        X       20
     C           CKHZ,X    DIV  100       $CKHZ   80
     C**
 S2  C           $CKHZ     IFGT *DATE
     C*         所番地
     C   10      CKQT,X    IFNE '      '
     C           CKQT,X    ANDNE'------'
     C                     MOVELCKQT,X    $$MAE
     C                     LEAVE
     C                     ENDIF
     C*         かんばん種類
  S3 C           CKQR,X    IFEQ IKDAI
     C                     SETON                     10
  E3 C                     ENDIF
 X2  C                     ELSE
     C*         所番地
     C   10      CKNB,X    IFNE '      '
     C           CKNB,X    ANDNE'------'
     C                     MOVELCKNB,X    $$MAE
     C                     LEAVE
     C                     ENDIF
  S3 C           CKKR,X    IFEQ IKDAI
     C                     SETON                     10
  E3 C                     ENDIF
 E2  C                     ENDIF
     C**
E1   C                     ENDDO
     C*-------------------------*
     C           $MAEZ     ENDSR
      *================================================================
      *================================================================
     OINPUT   E                $UPDAT
     O                         $$MAE    117
