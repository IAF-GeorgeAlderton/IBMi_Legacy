     FAFFPW10ACF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                        RRN2  KSFILE SFL02
     F                                              KINFDS @INFDS
     FFGBPL01 IF  E           K        DISK
     FFCEPL01 IF  E           K        DISK
     FFCCTL15 IF  E           K        DISK
     FAAHTL06 IF  E           K        DISK
     FAAFTL06 IF  E           K        DISK
     FAB#PL17 IF  E           K        DISK
     FEDIPP42 IF  E           K        DISK
     FAB#PP85 IF  E           K        DISK
     FAFFWP10 IF  E           K        DISK                           UC
     FAFFWP11 O   E           K        DISK
      *
     E                    UP1     1  11 20   NK1    02   0465 ABI
     E                    ERR     1  25 60
      *-----------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     I            DS
     I                                        1   80A2SSHZ
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
      *
     I            DS
     I                                        1  20 S1PART
     I                                        1   5 S1MHN1
     I                                        6  10 S1MHN2
     I                                       11  15 S1MHN3
     I                                       16  20 S1MHN4
     I            DS
     I                                        1  20 AFMHIN
     I                                        1   5 AFMHN1
     I                                        6  10 AFMHN2
     I                                       11  15 AFMHN3
     I                                       16  20 AFMHN4
     I            DS
     I                                        1  20 WMHIN
     I                                        1   5 WMHN1
     I                                        6  10 WMHN2
     I                                       11  15 WMHN3
     I                                       16  20 WMHN4
     I            DS
     I                                        1  12 @SHIN
     I                                        1   5 WSHN1
     I                                        6  10 WSHN2
     I                                       11  12 WSHN3
     I            DS
     I                                        1   80AFSHDT
     I                                        1   40WNOYY
     I                                        5   60WNOMM
     I                                        7   80WNODD
     I            DS
     I                                        1   80@SHDT
     I                                        1   40@SHYY
     I                                        5   60@SHMM
     I                                        7   80@SHDD
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *----------------------------------------------------*
      * MAIN ROUTINE
      *----------------------------------------------------*
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     SELEC
      * DSP01 -------------------------
     C           @SCRN     WHEQ 'DSP01'
     C                     EXSR #DSP01
      * F1: EXIT
     C           *INKA     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      * SFL01 -------------------------
     C           @SCRN     WHEQ 'SFL01'
     C                     EXSR #SFL01
      * F5: EXIT
     C           *INKE     IFEQ *ON
     C           UPFLG     ANDEQ'Y'
     C                     LEAVE
     C                     ENDIF
      * F5:
     C           *INKE     IFEQ *ON
     C           UPFLG     ANDNE'Y'
     C                     MOVELERR,16    D9ERR
     C                     ENDIF
      * SFL02 -------------------------
     C           @SCRN     WHEQ 'SFL02'
     C                     EXSR #SFL02
      *
     C                     ENDSL
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      * DISPLAY DSP01                                      *
      *----------------------------------------------------*
     C           #DSP01    BEGSR
     C                     EXFMTDSP01
     C                     SETOF                     85
     C                     MOVEL*BLANK    XMSG
      * F1:EXIT
     C           *INKA     IFEQ *ON
     C                     GOTO DSP01X
     C                     ENDIF
      *--------------
      * IF NO ERROR,
      *--------------
      *          ** CLEAR SUB FILE **
     C                     SETON                     71
     C                     WRITECTL01
     C                     WRITECTL02
     C                     SETOF                     71
      *          ** SET ORDER DATA **
     C                     CALL 'AFFC11A'
     C                     PARM           RFLG    1
      * CHECK AND SET DATA
     C           RFLG      IFNE 'N'
     C                     EXSR #CHK1
     C                     ENDIF
      *
     C           DSP01X    ENDSR
      *----------------------------------------------------*
      *  CHECK DATA                                        *
      *----------------------------------------------------*
     C           #CHK1     BEGSR
      *
     C                     MOVE 'N'       ENDFLG  1
     C                     MOVE *OFF      *IN85
     C                     Z-ADD0         YCNT    30
     C                     Z-ADD0         NCNT    30
     C                     Z-ADD0         OCNT    30
     C                     Z-ADD0         LIN#    30
     C                     Z-ADD0         RRN1    40
     C                     Z-ADD0         RRN2    40
     C                     MOVE *BLANK    XSUPP
     C                     MOVE *BLANK    XSUPN
JW1  C                     MOVE *BLANK    XALT
     C                     Z-ADD0         SVNONY  40
     C                     OPEN AFFWP10                    OPEN
      *
     C                     DO   *HIVAL
     C                     READ AFFWP10                  91
     C   91                LEAVE
      * CHECK END FLAG
     C           ENDFLG    IFEQ 'Y'
     C                     LEAVE
     C                     ENDIF
      *
     C                     ADD  1         LIN#
     C                     EXSR #CHK12
      * COUNT
     C                     SELEC
     C           OKFLG     WHEQ 'Y'
     C                     ADD  1         YCNT
     C           OKFLG     WHEQ 'N'
     C                     ADD  1         NCNT
     C                     OTHER
     C                     ADD  1         OCNT
     C                     ENDSL
     C                     ENDDO
      *
     C           *IN85     IFEQ *OFF
     C           YCNT      ANDEQ0
     C                     MOVELERR,1     XMSG
     C                     ENDIF
      *
     C           *IN85     IFEQ *OFF
     C                     MOVEL'SFL01'   @SCRN
     C                     ELSE
     C                     MOVEL'SFL02'   @SCRN
     C                     ENDIF
      *
     C           RRN1      IFEQ 0
     C           RRN2      ANDEQ0
     C                     MOVEL'DSP01'   @SCRN
     C                     MOVELERR,1     XMSG
     C                     ENDIF
      *
     C                     CLOSEAFFWP10                    CLOSE
      *
     C           CHK1X     ENDSR
      *----------------------------------------------------*
      *  CHECK 2                                           *
      *----------------------------------------------------*
     C           #CHK12    BEGSR
      *
     C                     MOVE ' '       OKFLG   1
      * CHECK HEADER, BY "D"
     C                     MOVELFLD1      LTR1    1
     C           LTR1      IFEQ 'D'
     C           LTR1      OREQ 'd'
     C           FLD1      OREQ *BLANK
     C                     MOVE ' '       OKFLG
     C                     GOTO CHK12X
     C                     ENDIF
      * CHECK COMMENT LINE
     C           LTR1      IFEQ '*'
     C                     MOVE ' '       OKFLG
     C                     GOTO CHK12X
     C                     ENDIF
      * CHECK HEADER, BY FIRST 4 DIGITS (NUMERIC?)
     C                     Z-ADD0         @NONY   40
     C                     MOVELFLD1      LTR4    4
     C                     MOVELLTR4      $CHAR  17 P
     C                     CALL 'UTLR60'
     C                     PARM           $CHAR  17
     C                     PARM           $T156  156
     C                     PARM           $RTN    1
     C           $RTN      IFNE *BLANK
     C                     MOVE ' '       OKFLG
     C                     GOTO CHK12X
     C                     ENDIF
      *
      * 1.(A) CHECK DELIVVERY CODE
     C                     MOVE ' '       XNONY   1
     C                     Z-ADD$T156     @NONY   40
     C           @NONY     CHAINFGBPL01              99
     C           *IN99     IFEQ *OFF
     C           XSUPP     IFEQ *BLANK
     C                     MOVELB2CODE    XSUPP
     C                     MOVELB2SMEI    XSUPN
     C                     ENDIF
     C                     ELSE
     C                     MOVELFLD1      S2ERR
     C                     MOVELERR,2     S2MSG
     C                     EXSR #ERR1
     C                     MOVE 'X'       XNONY
     C                     ENDIF
      * OMIT HONDA/TOYOTA/FORD/VW ORDER
     C                     MOVEL@NONY     LTR4
     C           LTR4      CHAINEDIPP42              99
     C           *IN99     IFEQ *OFF
     C**         E4GRP     IFEQ 'HND'
     C           E4GRP     IFEQ 'TYT'
     C           E4GRP     OREQ 'FRD'
     C           E4GRP     OREQ 'VW '
     C                     MOVELFLD1      S2ERR
     C                     MOVELERR,20    S2MSG
     C                     EXSR #ERR1
     C                     MOVE 'X'       XNONY
     C                     ENDIF
     C                     ENDIF
      * SAVE DELIVERY CODE
     C           SVNONY    IFEQ 0
     C           XNONY     ANDNE'X'
     C                     Z-ADD@NONY     SVNONY
     C                     ENDIF
      * CHECK MULTIPLE DELIVERYV CODE
     C           @NONY     IFNE SVNONY
     C           SVNONY    ANDNE0
     C                     MOVELFLD1      S2ERR
     C                     MOVELERR,14    S2MSG
     C                     EXSR #ERR1
     C                     MOVE 'X'       XNONY
     C                     ENDIF
      *
      * 2.(B) CHECK SHIP DATE
     C                     Z-ADD0         @SHDT
     C                     MOVELFLD2      $SRC
     C                     CALL 'UTLR01'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE   8
     C                     PARM           $RTN    1
     C           $RTN      IFNE *BLANK
     C                     MOVEL$SRC      S2ERR     P
     C                     MOVELERR,3     S2MSG
     C                     EXSR #ERR1
     C                     ENDIF
      *
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$TRUE     @SHDT
     C           @SHDT     IFLT TODAY
     C                     MOVEL$SRC      S2ERR     P
     C                     MOVELERR,18    S2MSG
     C                     EXSR #ERR1
     C                     ENDIF
     C                     ENDIF
      *
      * 3.(C) CHECK BIN#
     C                     Z-ADD0         @BIN    20
     C                     MOVELFLD3      $CHAR     P
     C                     CALL 'UTLR60'                   CONVERT CHR TO NUM
     C                     PARM           $CHAR  17
     C                     PARM           $T156  156
     C                     PARM           $RTN    1
     C           $RTN      IFNE *BLANK
     C                     MOVELFLD3      S2ERR
     C                     MOVELERR,8     S2MSG
     C                     EXSR #ERR1
JW1  C                     GOTO #STP4
     C                     ENDIF
      *
     C           $T156     IFLT 1
     C           $T156     ORGT 99
     C                     MOVELFLD3      S2ERR
     C                     MOVELERR,8     S2MSG
     C                     EXSR #ERR1
     C                     GOTO #STP4
     C                     ENDIF
      *
     C                     Z-ADD$T156     @BIN
      * 4.(D) CHECK PART#
     C           #STP4     TAG
     C           XNONY     IFNE 'X'
     C                     MOVE *BLANK    @PART  20
     C                     MOVE *BLANK    @UHIN  20
     C                     MOVEL@NONY     $NONY
     C                     MOVELFLD7      $NKOJ
     C                     MOVELFLD8      $NUKE
     C                     MOVELFLD4      $MHIN1
     C                     CALL 'UTLR61'
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $MHIN1 20
     C                     PARM           @TOKU   40
     C                     PARM           @MHIN2 20
     C                     PARM           @SHIN  12
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVELFLD4      @UHIN            ORIGINAL USR PART
     C                     MOVEL@MHIN2    @PART            NO HIPH USER PART
     C                     ELSE
     C                     MOVELFLD4      S2ERR
      * SET MSG
     C                     SELEC
     C           $RTN      WHEQ '1'
     C                     MOVELERR,17    S2MSG
     C           $RTN      WHEQ '2'
     C                     MOVELERR,9     S2MSG
     C           $RTN      WHEQ '3'
     C                     MOVELERR,15    S2MSG
     C                     ENDSL
      *
     C                     EXSR #ERR1
     C                     ENDIF
     C                     ENDIF
      * 5.(E) CHECK ORDER QTY
     C                     Z-ADD0         @QTY    70
     C                     MOVELFLD5      $CHAR  17 P
     C                     CALL 'UTLR60'
     C                     PARM           $CHAR  17
     C                     PARM           $T156  156
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     Z-ADD$T156     @QTY
     C                     ELSE
     C                     MOVELFLD5      S2ERR
     C                     MOVELERR,10    S2MSG
     C                     EXSR #ERR1
     C                     ENDIF
      * 6.(F) CHECK ORDER#
     C                     MOVELFLD6      @PO    10
     C           @PO       IFEQ *BLANK
     C                     MOVELFLD6      S2ERR
     C                     MOVELERR,11    S2MSG
     C                     EXSR #ERR1
     C                     ENDIF
      * 7.(G) CHECK FACTORY
     C                     MOVELFLD7      @NKOJ   1
      * 8.(H) CHECK DOCK
     C                     MOVELFLD8      @NUKE   4
      * 9.(I) CHECK INVOICE#
     C                     MOVELFLD9      @INVN  10
      * 10.(J) CHECK KANBAN#
     C**                   MOVELFLDA      @SBAN   6
      *
      * 11. CHECK DUPLICATE ORDERS
     C                     MOVE *OFF      *IN81
     C           K#17      SETLLAB#PL17
     C                     DO   *HIVAL
     C           K#17      READEAB#PL17                  81
     C   81                LEAVE
     C           *IN81     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN81     IFEQ *OFF
     C                     MOVELFLD6      S2ERR
     C                     MOVELERR,19    S2MSG
     C                     EXSR #ERR1
     C                     ENDIF
JW1   * CHECK BIN# BY PP10
 .   C                     EXSR #PP10
 .   C           P10FLG    IFEQ 'Y'
 .   C                     MOVELERR,22    XALT
JW1  C                     ENDIF
      *
      * END OF CHECK --------------------------------------
     C           OKFLG     IFNE 'N'
     C**                   CLEARSFL01
     C                     Z-ADDLIN#      S1LIN#
     C                     Z-ADD@TOKU     S1TOKU
     C                     MOVELXSUPP     S1NONY
     C                     Z-ADD@SHDT     S1SHDT
     C                     Z-ADD@BIN      S1BN#
     C                     MOVEL@UHIN     S1UHIN
     C                     MOVEL@PART     S1PART
     C                     MOVEL@UHIN     S1PRT2
     C                     Z-ADD@QTY      S1QTY
     C                     MOVEL@PO       S1PO#
     C                     MOVEL@NKOJ     S1NKOJ
     C                     MOVEL@NUKE     S1NUKE
     C                     MOVEL@INVN     S1INVN
     C                     MOVEL@SHIN     S1SHIN
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     MOVE 'Y'       OKFLG
     C                     ENDIF
      *
     C           RRN1      IFGT MAX1
     C                     MOVELERR,4     D9ERR
     C                     MOVE 'Y'       ENDFLG
     C                     ENDIF
      *
     C           RRN2      IFGT MAX2
     C                     MOVELERR,5     S2MSG
     C                     MOVELERR,5     D9ERR
     C                     SETON                     85
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C                     MOVE 'Y'       ENDFLG
     C                     ENDIF
      *
     C           CHK12X    ENDSR
      *----------------------------------------------------*
JW1   *  CHECK BIN# IN PP10                                 *
      *----------------------------------------------------*
     C           #PP10     BEGSR
      *
     C                     MOVEL@NONY     $NONY
     C                     MOVELFLD7      $NKOJ
     C                     MOVELFLD8      $NUKE
     C**                   MOVELFLD2      $NOHZ
      *
     C                     MOVELFLD2      $SRC
     C                     CALL 'UTLR01'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE   8
     C                     PARM           $RTN    1
     C                     MOVEL$TRUE     $NOHZ
      *
     C                     MOVEL@BIN      $NOBN
     C                     MOVE *BLANK    P10FLG
     C                     CALL 'UEXR29C'
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $NOHZ   8
     C                     PARM           $NOBN   2
     C                     PARM           P10FLG  1        Y/N
      *
JW1  C                     ENDSR
      *----------------------------------------------------*
      *  DISPLAY ORDER (SFL01)                             *
      *----------------------------------------------------*
     C           #SFL01    BEGSR
      *
     C           ENDFLG    IFEQ 'Y'
     C                     MOVELERR,21    D9ERR
     C                     ELSE
     C                     MOVELERR,6     D9ERR
     C                     ENDIF
      *
     C                     WRITEDSP91
     C                     SETON                     72
     C                     EXFMTCTL01
     C                     SETOF                     72
     C                     MOVE *BLANK    D9ERR
      * F3/12 BACK
     C           *INKC     IFEQ *ON
     C           *INKL     OREQ *ON
     C                     MOVEL'DSP01'   @SCRN
     C                     ENDIF
      * CHECK END FLAG
     C           ENDFLG    IFEQ 'Y'
     C                     MOVE *OFF      *INKE
     C                     ENDIF
      * F5: UPLOAD
     C           *INKE     IFEQ *ON
     C                     EXSR #UPL
     C                     MOVEL'DSP01'   @SCRN
     C                     ENDIF
      *
     C           SFL01X    ENDSR
      *----------------------------------------------------*
      *  DISPLAY ERROR (SFL02)                             *
      *----------------------------------------------------*
     C           #SFL02    BEGSR
      *
     C           ENDFLG    IFEQ 'Y'
     C                     MOVELERR,5     D9ERR
     C                     ELSE
     C                     MOVELERR,7     D9ERR
     C                     ENDIF
      *
     C                     WRITEDSP92
     C                     SETON                     72
     C                     EXFMTCTL02
     C                     SETOF                     72
     C                     MOVE *BLANK    D9ERR
      * F3/12 BACK
     C           *INKC     IFEQ *ON
     C           *INKL     OREQ *ON
     C                     MOVEL'DSP01'   @SCRN
     C                     ENDIF
      *
     C           SFL02X    ENDSR
      *----------------------------------------------------*
      *  WRITE ERROR SFL                                   *
      *----------------------------------------------------*
     C           #ERR1     BEGSR
      *
     C                     Z-ADDLIN#      S2LIN#
     C                     MOVELFLD7      S2NKOJ
     C                     MOVELFLD8      S2NUKE
     C                     SETON                     85
     C                     ADD  1         RRN2
     C                     WRITESFL02
     C                     MOVE 'N'       OKFLG
      *
     C           ERR1X     ENDSR
      *----------------------------------------------------*
      *  WRITE WORK FILE                                   *
      *----------------------------------------------------*
     C           #UPL      BEGSR
      *
     C                     Z-ADD0         RRN1
      *
     C                     DO   *HIVAL
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL01                99
     C   99                LEAVE
      * OUT
     C                     CLEARAFFWP111
     C                     Z-ADDS1LIN#    AFLIN#
     C                     Z-ADDS1TOKU    AFTOKU
     C                     Z-ADDS1NONY    AFNONY
     C                     MOVELS1NKOJ    AFNKOJ
     C                     MOVELS1NUKE    AFNUKE
     C                     Z-ADDS1SHDT    AFSHDT
     C                     MOVELS1BN#     AFSHBN
     C                     MOVELS1PART    AFMHIN
     C                     Z-ADDS1QTY     AFSRYO
     C                     MOVELS1PO#     AFORDN
     C                     MOVELS1INVN    AFINVN
     C                     MOVELS1UHIN    AFUHIN
     C                     MOVELS1SHIN    AFSHIN
      * DEFAULT
     C           AFNKOJ    IFEQ *BLANK
     C                     MOVEL'0'       AFNKOJ
     C                     ENDIF
      *
     C           AFNUKE    IFEQ *BLANK
     C           AFNUKE    OREQ '0   '
     C                     MOVEL'00  '    AFNUKE
     C                     ENDIF
      *
     C           AFSIRK    IFEQ *BLANK
     C                     MOVELAFNKOJ    AFSIRK
     C                     ENDIF
      *
     C           AFSIRE    IFEQ *BLANK
     C                     MOVELAFNONY    AFSIRE
     C                     ENDIF
      *
     C                     Z-ADD0         AFSETQ
      * GET Q/C
     C                     EXSR #SYOS
     C                     Z-ADD@SYOS     AFSYOS
      * GET SBAN
     C                     EXSR #SBAN
     C                     MOVEL@SBAN     AFSBAN
      * ADJUST
     C                     EXSR #ADJ
      *
     C                     WRITEAFFWP111
     C                     MOVE 'Y'       UPFLG
     C                     MOVELXSUPP     USIRE
      *
     C                     ENDDO
      *
     C           UPLX      ENDSR
      *-----------------------------------------------------
      *  SET QTY/CONTAINER
      *-----------------------------------------------------
     C           #SYOS     BEGSR
      *
     C                     Z-ADD0         @SYOS   90
     C                     SETOF                     6364
     C                     MOVELAFTOKU    PTOKU
     C                     MOVELAFNONY    PNONY
     C                     MOVELAFMHIN    PMHIN
      *
     C                     MOVEL'0'       PNKOJ
     C           AFNUKE    IFEQ *BLANK
     C                     MOVEL'00  '    PNUKE
     C                     ELSE
     C                     MOVELAFNUKE    PNUKE
     C                     ENDIF
      *
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           PMHIN  20
     C                     PARM           @SHIN  12
     C                     PARM           @FLG    1
     C                     MOVEL@SHIN     AFSHIN
     C           KEY1      CHAINFCEPL01              99
     C           *IN99     IFEQ *OFF
     C           A2GSKD    ANDEQ*BLANK
     C           A2SSHZ    IFLE TODAY
     C                     Z-ADDA2SSYS    @SYOS
     C                     ELSE
     C                     Z-ADDA2KSYS    @SYOS
     C                     ENDIF
     C                     ENDIF
      *
     C           KEY1      SETLLAAHTL06
     C           *IN77     DOUEQ*ON
     C           KEY1      READEAAHTL06                  77
     C           *IN77     IFEQ *OFF
     C           L6SKJY    ANDEQ*BLANK
     C           L6STHZ    ANDEQ99999999
     C                     Z-ADDL6KMAX    AFSETQ
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN77     IFEQ *ON
     C           KEY1      SETLLAAFTL06
     C           *IN77     DOUEQ*ON
     C           KEY1      READEAAFTL06                  77
     C           *IN77     IFEQ *OFF
     C           A3SKJY    ANDEQ*BLANK
     C           A3STHZ    ANDEQ99999999
     C                     Z-ADDA3KMAX    AFSETQ
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      * GET SBAN                                           *
      *----------------------------------------------------*
     C           #SBAN     BEGSR
      *
     C                     MOVE *BLANK    @SBAN   4
      *
     C                     Z-ADDAFTOKU    WTOKU
     C                     Z-ADDAFNONY    WNONY
     C                     MOVELAFNKOJ    WNKOJ
     C                     MOVELAFNUKE    WNUKE
     C                     MOVELAFMHIN    WMHIN
     C                     MOVE *OFF      *IN95
     C           K#15      SETLLFCCTL15
     C                     DO   *HIVAL
     C           K#15      READEFCCTL15                  95
     C   95                LEAVE
     C                     MOVELB4SBAN    @SBAN
     C                     ENDDO
      *
     C           @SBAN     IFEQ *BLANK
     C                     MOVE *OFF      *IN96
     C           K#85      SETLLAB#PP85
     C                     DO   *HIVAL
     C           K#85X     READEAB#PP85                  96
     C   96                LEAVE
     C                     MOVELA5SBAN    @SBAN
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDSR
      *----------------------------------------------------*
      * ADJUST BY EACH DELIVERY CODE                       *
      *----------------------------------------------------*
     C           #ADJ      BEGSR
      *
     C                     SELEC
      * TAKATA
     C           AFNONY    WHEQ 3656
     C           AFNONY    OREQ 3682
     C           AFNONY    OREQ 3712
     C           AFNONY    OREQ 3842
     C           AFNONY    OREQ 3713
JW   C           AFNONY    OREQ 3714
     C                     EXSR #TKT
      * PMO
     C           AFNONY    WHEQ 0681
     C                     EXSR #PMO
