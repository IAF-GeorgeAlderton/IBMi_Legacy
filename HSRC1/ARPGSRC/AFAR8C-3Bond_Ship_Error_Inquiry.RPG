     F************************************************
     FAFAPW8C CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL
     FAFAWP8A IF  E                    DISK
     FALBPL30 IF  E           K        DISK
      *
     E                    ER      1   4 65
      *
     I            DS
     I                                        3  140W6RD
     I                                        1   80W6KSDT
     I                                        9  140W6KSTM
      *
     I            DS
     I                                        1  14 WWSHN
     I                                        1   5 WWSHN1
     I                                        6   6 WWSF1
     I                                        7  11 WWSHN2
     I                                       12  12 WWSF2
     I                                       13  14 WWSHN3
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTITM
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
      *
     C           *ENTRY    PLIST
     C                     PARM           P1COH1  8
     C                     PARM           P1COH2  8
     C                     PARM           P1COUS  6
     C                     PARM           P1LHN  12
     C                     PARM           P1DET1  4
     C                     PARM           P1DET2  4
     C                     PARM           PCMD    2
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * MAINLINE                                           *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INITIALIZATION                                     *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     C                     MOVE P1COH1    C1COH1
     C                     MOVE P1COH2    C1COH2
     C                     MOVE P1DET1    C1DET1
     C                     MOVE P1DET2    C1DET2
      *
     C                     MOVEL*BLANK    C1COUS
     C           P1COUS    IFEQ *BLANK
     C                     MOVEL'ALL'     C1COUS
     C                     ELSE
     C                     MOVELP1COUS    C1COUS
     C                     ENDIF
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     C                     SETOF                     8166
     C                     READ AFAWP8A1                 81
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ AFAWP8A1                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     MOVE '02'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C           CTRX      IFEQ 0
     C                     SETON                     72
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     ELSE
     C                     SETON                     7273
     C                     ENDIF
      *
     C                     WRITEAFAPW989
     C                     EXFMTSFLCTL
     C                     SETOF                     7273
     C                     SETOF                     3199
     C                     MOVEL*BLANK    D9ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVE '03'      PCMD
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           CTRX      IFEQ 0
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
      * ROLLDOWN/PAGEUP *
      *-----------------*
     C           *IN52     IFEQ '1'
      *
      * 1ST. PAGE
     C           WKPAGE    IFEQ 1
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
     C           *IN81     IFEQ '1'
     C                     SETOF                     81
     C           *HIVAL    SETGTAFAWP8A1
     C                     READPAFAWP8A1                 81
     C                     SUB  1         CTRX
     C                     ENDIF
      *
     C                     ADD  12        CTRX
      *
     C                     SETOF                     6627
      *
     C           *IN81     DOWEQ'0'
     C           *IN27     ANDEQ'0'
     C                     EXSR #READP
     C                     READPAFAWP8A1                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXTP
     C                     ENDDO
      *
     C                     Z-ADD0         CTRX    40
      *
     C           *IN81     IFEQ '1'
     C                     READ AFAWP8A1                 81
     C                     ENDIF
      *
     C                     EXSR #CLR
     C                     SETOF                     8166
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ AFAWP8A1                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     SUB  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      *--------------------*
      * ROLL-UP            *
      *--------------------*
     C           *IN51     IFEQ '1'
     C           *IN81     ANDEQ'0'
      *
     C                     EXSR #CLR
      *
     C                     SETOF                     6681
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ AFAWP8A1                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     ADD  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      * CHECK
     C                     SETOF                     3199
     C                     Z-ADD1         X       20
     C                     Z-ADD0         WKSEL   20
     C           X         DOWLE12
     C           X         CHAINSFL                  25
     C           *IN25     IFEQ '0'
     C           *IN99     ANDEQ'0'
     C                     SETOF                     31
     C                     EXSR #SB221
     C                     MOVELH139      *IN,39
     C                     UPDATSFL
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
     C           *IN99     IFEQ '1'
     C                     GOTO ESB220
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * CHECK SFL                                          *
      *----------------------------------------------------*
     CSR         #SB221    BEGSR
      *
     C                     SELEC
     C           S1SEL     WHEQ ' '
     C           S1SEL     WHEQ 'M'
     C                     MOVELH1RDHZ    D2RDHZ
     C                     MOVELH1RDTI    D2RDTI
     C                     MOVELH1BAR1    D2BRCD
     C                     MOVELH1EMSG    D2EMSG
     C                     MOVELH1LTNO    D2LTNO
     C                     MOVELH1PID     D2PID
     C                     MOVELH1SHN     D2SHN
     C                     MOVELH1KO      D2KO
     C                     MOVELH1SUPP    D2SUPP
     C                     MOVE *BLANKS   D2NAME
     C                     MOVELD2KO      D2KONM  60
     C           D2KONM    CHAINALBPL301             28
     C           *IN28     IFEQ *OFF
     C                     MOVELALWKNM    D2NAME
     C                     ENDIF
      *
      *
     C                     EXFMTAFAPW982
     C                     MOVEL*BLANK    S1SEL
     C                     OTHER
     C                     MOVELER,2      D9ERR
     C                     SETON                     3199
     C                     ENDSL
      *
     CSR         ESB221    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     CSR         #READ     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREAD
     C                     ENDIF
      *
     C                     EXSR #EDIT
     C                     ADD  1         RRN
     C                     ADD  1         @RRN
     C                     ADD  1         CTRX
     C                     WRITESFL
      *
     C           CTRX      IFEQ 12
     C                     SETON                       66
     C                     ENDIF
      *
     CSR         EREAD     ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     CSR         #READP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREADP
     C                     ENDIF
      *
     C                     SUB  1         CTRX           27
      *
     CSR         EREADP    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     CSR         #SELEC    BEGSR
      *
     C                     MOVEL'1'       WKGET
      *
     CSR         ESELEC    ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     CSR         #CLR      BEGSR
      *
     C                     SETON                     71
     C                     WRITESFLCTL
     C                     SETOF                     7166
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN    40
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         @SFRC1
      *
     CSR         ECLR      ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     CSR         #EDIT     BEGSR
      *
     C                     MOVEL*BLANK    S1SEL
     C                     MOVELW6RD      S1COHZ
      *
     C                     MOVEL*BLANK    S1SHN
     C                     MOVEL*BLANK    WWSHN
     C                     MOVELW6BHB1    WWSHN1
     C                     MOVEL'-'       WWSF1
     C                     MOVELW6BHB2    WWSHN2
     C           W6BHB3    IFNE *BLANK
     C                     MOVEL'-'       WWSF2
     C                     MOVELW6BHB3    WWSHN3
     C                     ENDIF
     C                     MOVELWWSHN     S1SHN
     C                     MOVELW6OPER    S1KO
     C                     MOVELW6EMSG    S1EMSG
      *
     C                     MOVELS1KO      S1KONM  60
     C           S1KONM    CHAINALBPL301             28
     C           *IN28     IFEQ *OFF
     C                     MOVELALWKNM    S1NAME
     C                     ENDIF
      *
     C                     SETOF                     39
     C                     MOVELW6KSDT    H1RDHZ
     C                     MOVELW6KSTM    H1RDTI
     C                     MOVELW6BRC1    H1BAR1
     C                     MOVELW6LTNO    H1LTNO
     C                     MOVELW6ZETI    H1PID
     C                     MOVELS1SHN     H1SHN
     C                     MOVELS1KO      H1KO
     C                     MOVELS1EMSG    H1EMSG
     C                     MOVELW6ATOB    H1SUPP
      *
     CSR         EEDIT     ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     CSR         #NEXT     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXT
     C                     ENDIF
      *
     C                     READ AFAWP8A1                 81
      *
     CSR         ENEXT     ENDSR
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
     CSR         #NEXTP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXTP
     C                     ENDIF
      *
     C                     READPAFAWP8A1                 81
      *
     CSR         ENEXTP    ENDSR
