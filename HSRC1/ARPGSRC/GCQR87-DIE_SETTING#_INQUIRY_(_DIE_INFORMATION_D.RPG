     C*****************************************************
     C*          PARM LIST                                *
     C*****************************************************
     C           *ENTRY    PLIST
     C                     PARM           P@BASE  60
     C                     PARM           P@EXTR  1
     C                     PARM           P@DISP  1
     C*
     C*****************************************************
     C*          KEY LIST                                 *
     C*****************************************************
     C*==< MBEPL05 : SALES TOTALIZATION FILE >==*
     C           K@MB05    KLIST
     C                     KFLD           K@DNEN  40        DATA YY
     C                     KFLD           K@SHN1  5         PART NO.1
     C                     KFLD           K@SHN2  5         PART NO.2
     C                     KFLD           K@SHN3  2         PART NO.3
     C*
     C*==< ABMPL21 : FORECAST INTRAL PART NO. >==*
     C           K@AB21    KLIST
     C                     KFLD           K@NTYM  60        N:YYYY/MM
     C                     KFLD           K@SHN1            PART NO.1
     C                     KFLD           K@SHN2            PART NO.2
     C                     KFLD           K@SHN3            PART NO.3
     C*
     C*****************************************************
     C*          MAIN ROUTINE                             *
     C*****************************************************
     C                     TIME           S@TIME
     C*                    ____________
     C           *LOVAL    SETLLGCQWP86
     C                     READ GCQWP86                  91
     C*                    ~~~~~~~~~~~~
D----C           *IN91     DOWEQ'0'
|    C                     EXSR #SHN@
|    C                     MOVELW1SHN@    W@SHN@
|    C*
|D---C           *IN91     DOWEQ'0'
||   C           W1SHN@    ANDEQW@SHN@
||   C                     MOVELW1REC@    W2REC1
||   C*                    _____________
||   C                     WRITEGCQWP871
||   C                     READ GCQWP86                  91
||   C*                    ~~~~~~~~~~~~~
|E---C                     ENDDO
E----C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C*****************************************************
     C*  #SHN@   GET SALES & FORECAST                     *
     C*****************************************************
     C           #SHN@     BEGSR
     C*
     C                     Z-ADD*ZERO     @OSR              W2SRO5-0
     C                     Z-ADD*ZERO     W2FSM0
     C                     Z-ADD*ZERO     W2FSM1
     C                     Z-ADD*ZERO     W2FSM2
     C*
     C*==< SALES TOTALIZATION >==*
     C                     Z-ADD1         J       30
     C*
D----C           J         DOWLE6
|    C           @YYM,J    DIV  100       W@DNEN  40        YYYY
|    C                     Z-ADD@YYM,J    K       20        MM
|    C                     Z-ADDW@DNEN    K@DNEN            DATA YY
|    C                     MOVELW1SHN1    K@SHN1            PART NO.1
|    C                     MOVELW1SHN2    K@SHN2            PART NO.2
|    C                     MOVELW1SHN3    K@SHN3            PART NO.3
|    C*                    ____________
|    C           K@MB05    SETLLMBEPL05
|    C           K@MB05    READEMBEPL05                  92
|    C*                    ~~~~~~~~~~~~
|I---C           *IN92     DOWEQ'0'
||   C                     ADD  @ISR,K    @OSR,J
||   C*                    ____________
||   C           K@MB05    READEMBEPL05                  92
||   C*                    ~~~~~~~~~~~~
|E---C                     ENDDO
|    C*
|    C                     ADD  1         J
E----C                     ENDDO
     C*
     C*==< FORECAST QUANTITY >==*
     C                     Z-ADD@YYM,6    K@NTYM            N:YYYY/MM
     C                     MOVELW1SHN1    K@SHN1            PART NO.1
     C                     MOVELW1SHN2    K@SHN2            PART NO.2
     C                     MOVELW1SHN3    K@SHN3            PART NO.3
     C*                    ____________
     C           K@AB21    SETLLABMPL21
     C           K@AB21    READEABMPL21                  93
     C*                    ~~~~~~~~~~~~
I----C           *IN93     DOWEQ'0'
|I---C           S4SKJY    IFEQ 'D'
||   C           S4SKHZ    ANDLES@YMD
||   C*
|+---C                     ELSE
||   C                     ADD  S4FSMN    W2FSM0
||   C                     ADD  S4FSM1    W2FSM1
||   C                     ADD  S4FSM2    W2FSM2
|E---C                     ENDIF
|    C*                    ____________
|    C           K@AB21    READEABMPL21                  93
|    C*                    ~~~~~~~~~~~~
E----C                     ENDDO
     C*
     C           #SHN@E    ENDSR
     C*
