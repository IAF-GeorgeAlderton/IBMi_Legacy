     H            Y.                                    1
     F**ALDRTB ********************************************************
     F* GET PRELOAD IN FRONT OF MACHINES  ALCPP01                     *
     F*  2019.09.17      SAKAKI                                       *
     F*****************************************************************
     FALCPL06 IF  E           K        DISK                           UC
      *
     C           *ENTRY    PLIST
     C                     PARM           P@CHYU  1
     C                     PARM           P@ZENO  4
     C                     PARM           P@THNO  3
     C                     PARM           P@PAGE  2
     C                     PARM           P@HTHZ  80
     C                     PARM           P@PLJC  40       設備前JC
     C                     PARM           P@PLBZ  40       設備前BZ
     C                     PARM           P@PLDS  40       設備前DS
     C                     PARM           P@PLSB  40       設備前SB
     C                     PARM           P@PLOU  40       設備前OUTSOURCE
     C                     PARM           P@PRE   40        PRE
     C                     PARM           P@CODT  80        LAST PRE DATE
     C                     PARM           P@COTM  60        LAST PRE TIME
     C                     PARM           P#OPN   1
     C           P#OPN     IFEQ '9'
     C           OPNFL     IFEQ '1'
     C                     CLOSEALCPL06
     C                     ENDIF
     C                     SETON                     LR
     C                     RETRN
     C                     ENDIF
     C           OPNFL     IFEQ *BLANK
     C                     MOVEL'1'       OPNFL   1
     C                     OPEN ALCPL06
     C                     ENDIF
      *
     C                     MOVE P@HTHZ    K@HTHZ  80
      *
     C                     Z-ADD0         P@PLJC
     C                     Z-ADD0         P@PLBZ
     C                     Z-ADD0         P@PLDS
     C                     Z-ADD0         P@PLSB
     C                     Z-ADD0         P@PLOU
     C                     Z-ADD0         P@PRE
     C                     Z-ADD0         P@CODT
     C                     Z-ADD0         P@COTM
      *
     C           AFAKES    KLIST
     C                     KFLD           P@CHYU
     C                     KFLD           P@ZENO
     C                     KFLD           P@THNO
     C                     KFLD           P@HTHZ
      *
     C           AFAKEY    KLIST
     C                     KFLD           P@CHYU
     C                     KFLD           P@ZENO
     C                     KFLD           P@THNO
      *
     C           AFAKES    SETLLALCPL06
     C           AFAKEY    READEALCPL06                  88
     C           *IN88     DOWEQ'0'
     C           P@CODT    ANDEQ0
     C           A8BRC3    IFEQ *BLANK
||   C           A8ERR     ANDEQ*BLANK
     C           A8BRCD    ANDEQP@PAGE
     C                     EXSR #SB123
     C                     ENDIF
     C           AFAKEY    READEALCPL06                  88
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *------------------------------------*
     C           #SB123    BEGSR
      *
     C                     MOVEL*BLANK    WK12    2
     C                     MOVEL*BLANK    WK13    3
     C                     MOVEL*BLANK    WK31    1
     C                     MOVEL*BLANK    WK15    5
     C                     MOVEL*BLANK    WK18    8
     C                     MOVEL*BLANK    WK14    4
     C           2         SUBSTA8BRC2:1  WK12             １～２桁目
     C           3         SUBSTA8BRC2:1  WK13             １～３桁目
     C           1         SUBSTA8BRC2:3  WK31             ３桁目
     C           5         SUBSTA8BRC2:1  WK15             １～５桁目
     C           8         SUBSTA8BRC2:1  WK18             １～８桁目
     C           4         SUBSTA8BRC2:1  WK14             １～４桁目
      *
     C                     SELEC
     C           WK12      WHEQ 'SB'
     C                     ADD  4         P@PLSB             SB
     C                     Z-ADDA8DATE    P@CODT
     C                     Z-ADDA8TIME    P@COTM
     C           WK12      WHEQ 'BZ'
     C                     ADD  4         P@PLBZ             BZ
     C                     Z-ADDA8DATE    P@CODT
     C                     Z-ADDA8TIME    P@COTM
     C           WK12      WHEQ 'DS'
     C                     ADD  4         P@PLDS             DS
     C                     Z-ADDA8DATE    P@CODT
     C                     Z-ADDA8TIME    P@COTM
     C                     OTHER
     C           WK31      IFEQ *BLANK
     C                     ADD  4         P@PLJC             JC
     C                     Z-ADDA8DATE    P@CODT
     C                     Z-ADDA8TIME    P@COTM
     C                     ENDIF
     C           WK15      IFEQ 'MAGNI'
     C                     ADD  4         P@PLDS             DS
     C                     Z-ADDA8DATE    P@CODT
     C                     Z-ADDA8TIME    P@COTM
     C                     ENDIF
     C           WK18      IFEQ 'SHIPPING'
     C                     ADD  1         P@PRE              PRE
     C***                  Z-ADDA8DATE    P@CODT
     C***                  Z-ADDA8TIME    P@COTM
     C                     ENDIF
     C           WK15      IFEQ 'OUTS'
     C                     ADD  4         P@PLOU             OUTSOURCE
     C***                  Z-ADDA8DATE    P@CODT
     C***                  Z-ADDA8TIME    P@COTM
     C                     ENDIF
     C                     ENDSL
      *
     C           ESB123    ENDSR
