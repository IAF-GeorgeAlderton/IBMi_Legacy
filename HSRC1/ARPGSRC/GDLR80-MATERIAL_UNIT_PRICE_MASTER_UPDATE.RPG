     C                     Z-ADDLHSTHZ    XSTHZ
     C                     Z-ADDLHEDHZ    XEDHZ
     C                     END
     C                     SUB  1         A
     C                     END
     C                     END
     C                     END
     C  N45                ENDDO
     C                     ENDSR
      *-----------*
      * ROLL-DOWN *
      *-----------*
     C           RLDN      BEGSR
     C                     Z-ADD1         A       20
     C           KEY4      SETGTGDLPL80
     C                     DO   *HIVAL
     C                     SETOF                     45
     C           KEY2      READEGDLPL801                 45
     C           *IN45     IFEQ '0'
     C           LHSKJY    IFEQ 'D'
     C           LHSKHZ    ANDLE*DATE
     C                     ELSE
     C           A         IFLE 9
     C                     MOVELLHUNIT    PC,A
     C                     Z-ADDLHTANK    PR,A
     C                     MOVELLHTANC    UN,A
     C                     Z-ADDLHSTHZ    BD,A
     C                     Z-ADDLHEDHZ    ED,A
     C                     END
      *
     C           A         IFEQ 1
     C                     Z-ADDLHSTHZ    XSTHZ
     C                     Z-ADDLHEDHZ    XEDHZ
     C                     END
      *
     C           A         IFEQ 9
     C                     Z-ADDLHSTHZ    WSTHZ
     C                     Z-ADDLHEDHZ    WEDHZ
     C                     END
     C                     ADD  1         A
     C                     END
     C                     END
     C  N45                ENDDO
      *
     C           A         IFLE 10
     C                     SETON                     20
     C                     END
     C                     ENDSR
