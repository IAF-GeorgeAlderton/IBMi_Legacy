      *
     C           OBLTKB    IFEQ 'N'                        行先票不要
     C                     ITER
     C                     END
      *
     C           OBIKSK    IFNE '1'
     C                     ITER
     C                     END
      *
     C                     ADD  1         CTRX    40
      *
     C           CTRX      IFEQ 1
     C                     SETON                       10
     C                     CLEAR@KATA
     C                     MOVE OBKAT1    @KAT1
     C                     MOVE '-'       WKF1
     C                     MOVE OBKAT2    @KAT2
     C                     MOVE '-'       WKF3
     C                     MOVE OBKAT3    @KAT3
     C           @KAT3     IFEQ *BLANK
