     C                     END
     C           OBIKSK    IFEQ '2'
     C                     MOVELATM,2     @AATEN
     C                     END
     C           OBIKSK    IFEQ ' '
     C                     MOVELATM,3     @AATEN
     C                     END
      *
     C                     WRITEFOAPR131
     C                     CLEARFOAPR131
      *
     C                     END
      *
     C           CTRX      IFEQ 2
     C                     SETON                       10
     C                     CLEAR@KATA
     C                     MOVE OBKAT1    @KAT1
     C                     MOVE '-'       WKF1
     C                     MOVE OBKAT2    @KAT2
     C                     MOVE '-'       WKF3
     C                     MOVE OBKAT3    @KAT3
     C           @KAT3     IFEQ *BLANK
     C                     MOVE *BLANK    WKF3
     C                     END
     C                     MOVE @KATA     @BKATA
     C                     Z-ADDOBSRYO    @BSRYO
     C                     MOVE *BLANK    @BATEN
     C           OBIKSK    IFEQ '1'
     C                     MOVELATM,1     @BATEN
     C                     END
     C           OBIKSK    IFEQ '2'
     C                     MOVELATM,2     @BATEN
     C                     END
     C           OBIKSK    IFEQ ' '
     C                     MOVELATM,3     @BATEN
     C                     END
      *
     C                     WRITEFOAPR132
     C                     CLEARFOAPR132
      *
     C                     END
      *
     C           CTRX      IFEQ 3
     C                     CLEAR@KATA
     C                     MOVE OBKAT1    @KAT1
     C                     MOVE '-'       WKF1
     C                     MOVE OBKAT2    @KAT2
     C                     MOVE '-'       WKF3
     C                     MOVE OBKAT3    @KAT3
     C           @KAT3     IFEQ *BLANK
     C                     MOVE *BLANK    WKF3
     C                     END
     C                     MOVE @KATA     @CKATA
     C                     Z-ADDOBSRYO    @CSRYO
     C                     MOVE *BLANK    @CATEN
     C           OBIKSK    IFEQ '1'
     C                     MOVELATM,1     @CATEN
     C                     END
     C           OBIKSK    IFEQ '2'
     C                     MOVELATM,2     @CATEN
     C                     END
     C           OBIKSK    IFEQ ' '
     C                     MOVELATM,3     @CATEN
     C                     END
      *
     C                     WRITEFOAPR133
     C                     CLEARFOAPR133
      *
     C                     Z-ADD0         CTRX
     C                     END
     C                     ENDDO
      *
     C                     SETON                       LR
     C                     RETRN
      *
**
REPRODUCTION FACTORY
TYPEMAKER
OTHERS
