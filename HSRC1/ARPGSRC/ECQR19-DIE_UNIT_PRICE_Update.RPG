     H            Y.
     F** ECQR19 ********************************************
     F*  DIE UNIT PRICE UPDATE FROM UPLOAD DATA            *
     F*                                                    *
     F* TCHK1 05/20/10 CREATE(COPY FROM ECQR16)            *
     F******************************************************
     FECQPW19 CF  E                    WORKSTN
     FECQWP18 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FECQPP01 UF  E           K        DISK                      A
      *-----------------------------------------------------------
     E                    ERR     1   5 60
      *-----------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60WSSTM6
     I                                        1   40WSSTM4
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  140WSSDAT
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YYYY
     I                                        5   60K@MMMM
     I                                        7   80K@DDDD
      *--------------------------------------------------
      *  MAIN ROUTINE
      *--------------------------------------------------
     C                     EXSR #SCRN1
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *------------------------------------------------------
     C                     TIME           WSDT
      *
     C           *ENTRY    PLIST
     C                     PARM           PMSRVF  1
     C*
     C                     ENDSR
      *-----------------------------------------------------
     C           #SCRN1    BEGSR
     C*-----------------------------------------------------
     C*
     C                     DO   *HIVAL
     C*
     C           PMSRVF    IFEQ '1'
     C                     MOVEL*ON       *IN60
     C                     ELSE
     C                     MOVEL*OFF      *IN60
     C                     MOVEL*ON       *IN99
     C                     MOVELERR,1     MSG
     C                     END
     C                     EXFMTDSP01
     C*
     C   KA                LEAVE
     C           PMSRVF    IFNE '1'
     C                     ITER
     C                     END
     C*
     C                     MOVEL*BLANK    MSG
     C                     SETOF                     6199
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
      *-----------------------------------------------------
     C           #CHK1     BEGSR
      *-----------------------------------------------------
     C                     DO
     C*
     C           D@DATE    IFEQ *ZERO
     C                     MOVELERR,2     MSG
     C                     SETON                     6199
     C                     LEAVE
     C                     END
     C*
     C                     Z-ADDD@DATE    K@YMD
     C           K#AGD     KLIST
     C                     KFLD           K@YYYY
     C                     KFLD           K@MMMM
     C                     KFLD           K@DDDD
     C           K#AGD     CHAINAGDPL12              96
     C           *IN96     IFEQ *ON
     C                     MOVELERR,2     MSG
     C                     SETON                     6199
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------
     C           #UPD      BEGSR
      *-----------------------------------------------------
     C           *LOVAL    SETLLECQWP18
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ECQWP18                  98
     C   98                LEAVE
     C*
     C                     SELEC
     C           E8CSTY    WHNE *ZERO
     C                     Z-ADDE8CSTY    W@CST  110
     C           E8CSTD    WHNE *ZERO
     C           E8CSTD    MULT 100       W@CST
     C                     OTHER
     C                     ITER
     C                     ENDSL
     C*
     C           K#ECQX    KLIST
     C                     KFLD           E8DIE1
     C                     KFLD           E8DIE2
     C                     KFLD           E8DIE3
     C                     KFLD           K@DIE4  1
     C                     KFLD           D@DATE
     C                     MOVEL*BLANK    K@DIE4
     C           K#ECQX    CHAINECQPP01              96
     C           *IN96     IFEQ *OFF
     C                     Z-ADDW@CST     ECUPRC
     C                     Z-ADDWSSDAT    ECKODT
     C                     Z-ADDWSSTM6    ECKOTM
     C                     MOVEL#USER     ECKOME
     C                     UPDATECQPP011
     C                     ELSE
     C                     CLEARECQPP011
     C                     MOVELE8DIE1    ECKAT1
     C                     MOVELE8DIE2    ECKAT2
     C                     MOVELE8DIE3    ECKAT3
     C                     Z-ADDW@CST     ECUPRC
     C                     Z-ADDD@DATE    ECVALD
     C                     Z-ADDWSSDAT    ECKODT
     C                     Z-ADDWSSTM6    ECKOTM
     C                     MOVEL#USER     ECKOME
     C                     WRITEECQPP011
     C                     END
      *
     C                     ENDDO
      *
     C                     ENDSR
** ERR
NOT FOUND UPLOAD(FROM DIE ACCESS DATABASE) FILE.
EFECTIVE DATE ERROR.



