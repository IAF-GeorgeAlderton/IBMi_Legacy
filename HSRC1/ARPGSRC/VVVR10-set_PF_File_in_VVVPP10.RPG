     H            Y.
     F** VVVR10 ****************************
     F*  SET PF FILE IN VVVPP10            *
     F**************************************
     FVVVPP10 UF  E                    DISK
     FVVVPPA1 IF  E           K        DISK
      *
     C           *IN81     DOWEQ*OFF
     C                     READ VVVPP10                  81
     C           *IN81     IFEQ *OFF
     C                     CLEARWHPF
     C                     CLEARWHI
     C                     CLEARWHU
     C                     CLEARWHO
      *
     C           WHFUSG    IFNE 0
     C                     MOVELWHFNAM    KEY10  10
     C           KEY10     CHAINVVVPPA1              99
     C           *IN99     IFEQ *OFF
     C                     MOVELVVRFI     WHPF
     C                     ELSE
     C                     MOVELWHFNAM    WHPF
     C                     ENDIF
      * SET I/U/O
     C                     SELEC
     C           WHFUSG    WHEQ 1
     C                     MOVEL'I'       WHI
     C           WHFUSG    WHEQ 2
     C                     MOVEL'O'       WHO
     C           WHFUSG    WHEQ 3
     C                     MOVEL'I'       WHI
     C                     MOVEL'O'       WHO
     C           WHFUSG    WHEQ 4
     C                     MOVEL'U'       WHU
     C           WHFUSG    WHEQ 5
     C                     MOVEL'I'       WHI
     C                     MOVEL'U'       WHU
     C           WHFUSG    WHEQ 6
     C                     MOVEL'U'       WHU
     C                     MOVEL'O'       WHO
     C           WHFUSG    WHEQ 7
     C                     MOVEL'I'       WHI
     C                     MOVEL'U'       WHU
     C                     MOVEL'O'       WHO
     C                     ENDSL
      *
     C                     UPDATVVVPP101
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
