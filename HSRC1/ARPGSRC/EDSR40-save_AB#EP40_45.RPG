     H            Y.
     F** EDSR40 ********************************************
     F*  PROGRAM: UTILITY - SAVE AB#EP40 TO AB#EP40S       *
     F*  WRITTEN: JW (SRA)                                 *
     F*           02/18/2016                               *
     F*----------------------------------------------------*
     FAB#EP40 IF  E           K        DISK
     FAB#EP40SO   E                    DISK
     FAB#EP45 IF  E           K        DISK
     FAB#EP45SO   E                    DISK
      *--------------------------------------------------------
     I            DS
     I                                        1  140D#TIME
     I                                        1   60NOW
     I                                        7  140TODAY
      *--------------------------------------------------------
      * INITIAL SETTING
     C                     TIME           D#TIME
      * SAVE AB#EP40 --------------------------------------
     C                     MOVE *OFF      *IN99
     C           *IN99     DOWEQ*OFF
     C                     READ AB#EP40                  99
     C           *IN99     IFEQ *OFF
     C                     Z-ADDTODAY     ECRDT
     C                     Z-ADDNOW       ECRTM
     C                     EXSR #ADJ40
      *
     C                     WRITEAB#E40S1
     C                     ENDIF
     C                     ENDDO
      *
      * SAVE AB#EP45 --------------------------------------
     C                     MOVE *OFF      *IN99
     C           *IN99     DOWEQ*OFF
     C                     READ AB#EP45                  99
     C           *IN99     IFEQ *OFF
     C                     Z-ADDTODAY     BNSVDT
     C                     Z-ADDNOW       BNSVTM
     C                     WRITEAB#E45S1
     C                     ENDIF
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *========================================
      * ADJUST EP40                           =
      *========================================
     C           #ADJ40    BEGSR
      *
     C                     MOVELENONY     EALFL
      * EDIT
     C           EPODT     IFEQ 0
     C                     Z-ADDTODAY     EPODT
     C                     ENDIF
     C           EPOTM     IFEQ 0
     C                     Z-ADDNOW       EPOTM
     C                     ENDIF
     C           ENKOJ     IFEQ *BLANK
     C                     MOVE '0'       ENKOJ
     C                     ENDIF
     C           ENUKE     IFEQ *BLANK
     C                     MOVEL'00  '    ENUKE
     C                     ENDIF
      *
     C                     SELEC
     C           ENONY     WHEQ '5910'                     FNG5910
     C           ENONY     WHEQ '5912'                     FNG5912
     C           ENONY     WHEQ '5915'                     FNG5915
     C           ENONY     WHEQ '5917'                     FNG5917
     C           ENONY     WHEQ '5919'                     FNG5919
     C           ENONY     WHEQ '5923'                     FNG5923
     C           ENONY     WHEQ '5924'                     FNG5924
     C           ENONY     WHEQ '5242'                     FNG5242
     C                     MOVEL'830'     EPGID
     C                     ENDSL
      *
     C                     ENDSR
