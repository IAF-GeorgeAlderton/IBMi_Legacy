     H            Y.
     F***CHKR38*****************************************************************
     F*  PROGRAM    : DELETE PROCESSED ORDER (HONDA) -PP2A                     *
     F*  WRITTEN    : 2020.06.30                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F**************************************************************************
     FAB#PL2R UF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     E                    ERR     1   5 40
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           TODAY     SETLLAB#PL2R
     C                     DO   *HIVAL
     C                     READ AB#PL2R                  98
     C   98                LEAVE
      *
     C           ACUPID    IFNE *BLANK
     C                     ITER
     C                     ENDIF
      *
     C           ACQNTY    IFEQ 0
     C                     MOVELERR,1     MSG1
     C                     EXSR #PRINT
      * UPDATE
     C           $UPD      IFEQ 'Y'
     C                     MOVEL'D'       ACUPID
     C                     MOVELTODAY     ACCOLR    P
     C                     MOVE 'DLT'     ACCOLR
     C                     MOVEL#PGM      ACKPGM
     C                     UPDATAB#PP2A1
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      * EDIT
     C                     MOVELACODRN    XCODRN 12
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $UPD    1
     C                     PARM           $RTN    1
      *
     C                     MOVE *BLANK    $RTN
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     MOVE *BLANK    MSG1   40
     C                     Z-ADD0         SVNONY  40
     C                     Z-ADD0         SVPLSH  80
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      10
     O                         $UPD      11
     O                                   40 '** HONDA ORDER CHECK'
     O                                   60 'LIST ** (ALREADY PRO'
     O                                   80 'CESSED)             '
     O                                   99 'DATE'
     O                         TODAY     82 '    .  .  '
     O                         NOW       92 '  :  :  '
     O                                   95 'P.'
     O                         PAGE  Z   99
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   10 'CUST'
     O                                   15 'DELV'
     O                                   31 'SHP_DATE'
     O                                   37 'BIN'
     O                                   47 'USER_PART'
     O                                   62 'ORDER#'
     O                                   80 'QTY'
     O                                   96 '*** ERROR MSG'
     O        E 1              @DTL
     O                         SEQ#  1 +000
     O                         ACTOKU  +001
     O                         ACNONY  +001
     O                         ACNKOJ  +001
     O                         ACNUKE  +001
     O                         ACPLSHY +001
     O                         ACBIN   +002
     O                         ACMHN1  +001
     O                         ACMHN2  +001
     O                         ACMHN3  +001
     O                         XCODRN  +001
     O                         ACQNTYJ +001
     O                         MSG1    +002
** ERR (40A) ......2.........3.........4
QTY=0 ! ORDER SHOULD BE DELETED.         01
                                         02
                                         03
                                         04
                                         05
