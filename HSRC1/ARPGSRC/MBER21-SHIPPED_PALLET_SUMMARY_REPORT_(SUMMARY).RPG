     H            Y.
      **MBER21 *****************************************************************
      * SHIPPED PALLET SUMMARY REPORT (SUMMARY)                                *
      * J.WATANABE  2018.03.02                                                 *
      **************************************************************************
     FMBEWP20 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FEDIPP42 IF  E           K        DISK
     FAB#PL90 IF  E           K        DISK
     FMBEWP21 O   E           K        DISK
      *------------------------------------------------------------
     I* SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60NOW
     I                                        7  140TODAY
     I                                        1   20WSHH
     I                                        3   40WSMN
     I                                        5   60WSSS
     I                                        7  100WSYY
     I                                       11  120WSMM
     I                                       13  140WSDD
     I                                        1   40WSTM4
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C                     EXSR #INIT
      *
     C           *IN95     DOWEQ*OFF
     C                     READ MBEWP20                  95
     C           *IN95     IFEQ *OFF
      * FIRST?
     C           FIRST     IFEQ 'Y'
     C                     MOVE 'N'       FIRST
     C                     Z-ADDM0NOHZ    SVNOHZ  80
     C                     Z-ADDM0NONY    SVNONY  40
     C                     ENDIF
      * BREAK?
     C           M0NOHZ    IFNE SVNOHZ
     C           M0NONY    ORNE SVNONY
     C                     EXSR #BRK
     C                     ENDIF
      * DETAIL PROCESS
     C                     ADD  M0BOX     WKBOX
     C                     ADD  M0PAL     WKPAL
      *
     C                     ENDIF
     C                     ENDDO
      * LAST BREAK
     C           FIRST     IFEQ 'N'
     C                     EXSR #BRK
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      **************************************************************************
      *          BREAK
      **************************************************************************
     C           #BRK      BEGSR
      *
     C                     Z-ADDSVNOHZ    M1NOHZ
     C                     Z-ADDSVNONY    M1NONY
     C                     Z-ADDWKBOX     M1BOX
     C                     Z-ADDWKPAL     M1PAL
      * GET NAME
     C           SVNONY    CHAINFGBPL01              99
     C           *IN99     IFEQ *OFF
     C                     MOVELB2SMEI    M1NAME
     C                     ELSE
     C                     MOVE *BLANK    M1NAME
     C                     ENDIF
      * GET MAXBOX
     C                     Z-ADD0         MAXBOX  30
     C                     MOVELSVNONY    XNONY   4
     C           XNONY     CHAINAB#PL90              99
     C           *IN99     IFEQ *OFF
     C                     Z-ADDYAMXPL    MAXBOX
     C                     Z-ADDYAMXPL    M1MAX
     C                     ENDIF
      * ADJUST PALLET
     C           XNONY     CHAINEDIPP42              99
     C           *IN99     IFEQ *OFF
     C                     MOVELE4FLG1    PPFLG   1
     C                     ELSE
     C                     MOVE *BLANK    PPFLG
     C                     ENDIF
      * EXCEPTION
     C           PPFLG     IFEQ 'N'
     C           MAXBOX    ANDNE0
     C**         SVNONY    ANDNE5117
     C           M1BOX     DIV  MAXBOX    WKPAL2  50
     C                     MVR            FLD2    53
     C           FLD2      IFGT 0
     C                     ADD  1         WKPAL2
     C                     ENDIF
     C                     Z-ADDWKPAL2    M1PAL
     C                     ENDIF
      * OUTPUT
     C                     WRITEMBEWP211
      * REESET
     C                     Z-ADDM0NOHZ    SVNOHZ
     C                     Z-ADDM0NONY    SVNONY
     C                     Z-ADD0         WKBOX
     C                     Z-ADD0         WKPAL
      *
     C                     ENDSR
      **************************************************************************
      * INITIALIZE
      **************************************************************************
     C           #INIT     BEGSR
      *
      * RETRIEVE SYSTEM TIME
     C                     TIME           WSDT
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         WKBOX   60
     C                     Z-ADD0         WKPAL   60
     C                     Z-ADD0         SVNOHZ  80
     C                     Z-ADD0         SVNONY  40
      *
     C                     ENDSR
