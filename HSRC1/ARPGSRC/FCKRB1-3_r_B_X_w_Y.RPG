     H            Y.                                                      MBR020
     F** FCKRB1 *************************************
     F*  ３ヶ月生産予定内示を取得                 *
     F*       A.INOUE       2006.07.04              *
     F************************************* FCKRB1 **
     FFCEPL01 IF  E           K        DISK                           UC
     FFCTPL41 IF  E           K        DISK                           UC
     FABBPL21 IF  E           K        DISK                           UC
%0001I            DS
     I                                        1  12 PSHINA
     I                                        1   5 PSHIN1
     I                                        6  10 PSHIN2
%0001I                                       11  12 PSHIN3
     I            DS
     I                                        1   80WY4MD
     I                                        1   60WY4M
     I                                        3   60WYM
     I                                        1   20WY12
     I                                        3   40WYY
     I                                        5   60WMM
     I                                        7   80WDD
     I            DS
     I                                        1   80WKRHZ
     I                                        1   40WKRYY
     I                                        5   60WKRMM
     I                                        7   80WKRDD
     I            DS
     I                                        1   80XKRHZ
     I                                        1   40XKRYY
     I                                        5   60XKRMM
     I                                        7   80XKRDD
      *------------------------------------------------------*
      *  PLIST                                               *
      *      INPUT                                           *
      *        PYM   :対象年月(YYMM)                       *
      *        PHIN1 :品番１                               *
      *        PHIN2 :品番２                               *
      *        PHIN3 :品番３                               *
      *        OPNCLS:初回コール時'1'をセット            *
      *             終了時'9'をセット                  *
      *      OUTPUT                                          *
      *        PSNO  :Ｎ月必要数                           *
      *        PSNO  :Ｎ＋１月必要数                       *
      *        PSNO  :Ｎ＋２月必要数                       *
      *        PSTS  : '0'検索ＯＫ '9'検索ＮＧ           *
      *------------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           PYM     4
     C                     PARM           PHIN1   5
     C                     PARM           PHIN2   5
     C                     PARM           PHIN3   2
     C                     PARM           OPNCLS  1
     C                     PARM           PSN0    90
     C                     PARM           PSN1    90
     C                     PARM           PSN2    90
     C                     PARM           PSTS    1
      *
     C           HKEY      KLIST
     C                     KFLD           PHIN1
     C                     KFLD           PHIN2
     C                     KFLD           PHIN3
      *
     C           AKEY      KLIST
     C                     KFLD           PHIN1
     C                     KFLD           PHIN2
     C                     KFLD           PHIN3
     C                     KFLD           WY4M
      *
      *----------------------------------------------------*
     C           OPNCLS    IFEQ '1'
     C                     OPEN FCEPL01
     C                     OPEN FCTPL41
     C                     OPEN ABBPL21
     C                     CALL 'FCKRA1'
     C                     PARM           PYM     4
     C                     PARM           PHIN1   5
     C                     PARM           PHIN2   5
     C                     PARM           PHIN3   2
     C                     PARM           OPNCLS  1
     C                     PARM           PASN0   90
     C                     PARM           PASN1   90
     C                     PARM           PASN2   90
     C                     PARM           PASTS   1
     C                     MOVE '0'       OPNCLS
     C                     END
      *強制終了
     C           OPNCLS    IFEQ '9'
     C                     CLOSEFCEPL01
     C                     CLOSEFCTPL41
     C                     CLOSEABBPL21
     C                     CALL 'FCKRA1'
     C                     PARM           PYM     4
     C                     PARM           PHIN1   5
     C                     PARM           PHIN2   5
     C                     PARM           PHIN3   2
     C                     PARM           OPNCLS  1
     C                     PARM           PASN0   90
     C                     PARM           PASN1   90
     C                     PARM           PASN2   90
     C                     PARM           PASTS   1
     C                     SETON                     LR
     C                     RETRN
     C                     END
      **----*
     C                     MOVE PYM       WYM
     C           WYY       IFGE 50
     C                     Z-ADD19        WY12
     C                     ELSE
     C                     Z-ADD20        WY12
     C                     END
     C*
     C                     Z-ADD31        WDD
      *
     C                     MOVELPHIN1     PSHIN1
     C                     MOVELPHIN2     PSHIN2
     C                     MOVELPHIN3     PSHIN3
      *
     C                     Z-ADD0         PSN0    90
     C                     Z-ADD0         PSN1    90
     C                     Z-ADD0         PSN2    90
     C                     MOVEL*BLANK    PSTS    1
      **----*
      *
     C                     SETOF                     0102
     C                     MOVE *BLANK    A2AK11
     C           HKEY      CHAINFCEPL011             01
      *
     C           *IN01     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C                     SETON                     01
     C                     END
     C*
     C           *IN01     IFEQ '1'
     C                     MOVE '9'       PSTS
     C                     GOTO #END
     C                     END
      *
     C           AKEY      CHAINABBPL211             02
      *
     C*------------------------------------*
     C*   ..ﾆ]ﾈl､ﾈｮsﾟ]､s]ﾃcuﾇjｰ n kｩｮh..   *
     C*------------------------------------*
     C           *IN02     IFEQ '0'
     C           A2AK11    ANDEQ*BLANK
      *
     C                     Z-ADD0         WKRHZ
     C           HKEY      SETLLFCTPL411
     C                     SETOF                     05
     C                     DO   *HIVAL
     C           HKEY      READEFCTPL411                 05
     C*
     C                     SELEC
     C           *IN05     WHEQ '1'
     C*
     C           Q9SKJY    WHEQ 'D'
     C           Q9SKHZ    ANDLE*DATE
     C*
     C           WKRHZ     WHEQ 0
     C                     Z-ADDQ9KRHZ    WKRHZ
     C*
     C           Q9KRHZ    WHEQ WKRHZ
     C                     Z-ADDQ9KRHZ    WKRHZ
     C                     OTHER
     C*
     C                     ENDSL
     C*
     C  N05                ENDDO
      *
     C           WKRHZ     IFNE 0
     C                     Z-ADDWKRHZ     XKRHZ
     C           1         DO   2
     C           XKRMM     IFEQ 01
     C           XKRYY     SUB  1         XKRYY
     C                     Z-ADD12        XKRMM
     C                     ELSE
     C           XKRMM     SUB  1         XKRMM
     C                     END
     C                     ENDDO
     C*
     C           XKRHZ     IFLE WY4MD
     C                     SETON                     02
     C                     END
     C                     END
      *
     C                     ENDIF
      *
      * 2005.02.01
     C                     Z-ADD0         PASN0
     C                     Z-ADD0         PASN1
     C                     Z-ADD0         PASN2
     C                     MOVEL*BLANK    PASTS   1
     C                     CALL 'FCKRA1'
     C                     PARM           PYM     4
     C                     PARM           PHIN1   5
     C                     PARM           PHIN2   5
     C                     PARM           PHIN3   2
     C                     PARM           OPNCLS  1
     C                     PARM           PASN0   90
     C                     PARM           PASN1   90
     C                     PARM           PASN2   90
     C                     PARM           PASTS   1
     C           PASTS     IFEQ '0'
     C                     Z-ADDPASN0     PSN0
     C                     Z-ADDPASN1     PSN1
     C                     Z-ADDPASN2     PSN2
     C                     END
%0001 *
     C           *IN02     IFEQ '0'
     C* * *                MOVE *BLANK    PSTSY   1
     C* * *                CALL 'ABBR97'
     C* * *                PARM           PSHINA
     C* * *                PARM           PSTSY
     C* * *      PSTSY     IFEQ '*'
     C* * *                SETON                     02
     C* * *                END
     C                     END
%0001 *
      *
     C           *IN02     IFEQ '1'
     C                     MOVE PASTS     PSTS
     C                     GOTO #END
     C                     END
      *
     C           A2AK11    IFEQ *BLANK
     C                     MOVE PASTS     PSTS
     C                     GOTO #END
     C                     END
      *
      *
     C*
     C           PASTS     IFEQ '9'
     C                     Z-ADDA2GEKN    PSN0
     C                     END
     C*
     C           U1NGKB    IFEQ 'N'
     C                     Z-ADDU1N1NM    PSN1
     C                     Z-ADDU1N2NM    PSN2
     C                     ELSE
     C           PASTS     IFEQ '9'
     C                     Z-ADDU1S1NM    PSN1
     C                     Z-ADDU1S2NM    PSN2
     C                     END
     C                     END
      *
     C                     MOVE '0'       PSTS
      *
     C           #END      TAG
      *
     C                     RETRN
      *
