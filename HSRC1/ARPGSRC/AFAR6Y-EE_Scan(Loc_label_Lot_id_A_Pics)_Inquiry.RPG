     C                     WRITESFL020
     C                     LEAVE
     C                     ELSE
     C                     MOVELAXPAGE    S2TOPG
     C                     END
     C                     ENDDO
     C*
     C           RRN2      IFEQ 9999
     C                     LEAVE
     C                     END
     C*
     C           K@6R2     SETGTAFAPL6R2
     C                     DO   *HIVAL
     C           A2ZETI    READEAFAPL6R2                 96
     C           *IN96     IFEQ *ON
     C                     LEAVE
     C                     END
     C           AXSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C                     Z-ADDAXCDAT    O@CDAT
     C                     Z-ADDAXCTIM    O@CTIM
     C                     Z-ADDAXCSEQ    O@CSEQ
     C                     MOVELAXTEHI    O@TEHI
     C                     LEAVE
     C                     ENDDO
     C*
     C           *IN96     IFEQ *ON
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C           RRN2      IFEQ *ZERO
     C                     CLEARSFL020
     C                     MOVEL*ON       *IN51
     C                     Z-ADD1         RRN2
     C                     WRITESFL020
     C                     END
     C*
     C           RRN2      IFEQ 9999
     C                     MOVELER,19     MSG
     C                     MOVEL*ON       *IN49
     C                     END
     C*
     C                     ENDSR
     C*----------------------------------------------------*
     C* FMT020 GET HEADER INFORMATION                      *
     C*----------------------------------------------------*
     C           @F2IT1    BEGSR
     C*
     C                     MOVEL*BLANK    S2LOC
     C                     MOVEL*BLANK    S2LOT
     C                     MOVEL*BLANK    S2LOTP
     C*
     C           K@6R1     KLIST
