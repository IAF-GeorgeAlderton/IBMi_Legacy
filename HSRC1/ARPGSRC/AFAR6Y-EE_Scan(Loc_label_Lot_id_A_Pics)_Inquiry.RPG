     C* FMT020 INITIALIZE                                  *
     C*----------------------------------------------------*
     C           @F2INT    BEGSR
     C*
     C                     MOVEL*ON       *IN41
     C                     WRITECTL020
     C                     MOVEL*OFF      *IN41
     C*
     C                     MOVEL*BLANK    F2HIN
     C                     MOVELF1HIN1    F2HIN1
     C                     MOVELF1HIN2    F2HIN2
     C                     MOVELF1HIN3    F2HIN3
     C                     MOVEL'-'       F2SHF1
     C           F1HIN3    IFNE *BLANK
     C                     MOVEL'-'       F2SHF2
     C                     END
     C*
     C                     MOVEL*BLANK    MSG
     C                     Z-ADD*ZERO     RRN2    40
     C                     Z-ADDAXCDAT    O@CDAT  80
     C                     Z-ADDAXCTIM    O@CTIM  60
     C                     Z-ADDAXCSEQ    O@CSEQ  40
     C                     MOVELAXTEHI    O@TEHI  3
     C*
     C                     DO   *HIVAL
     C*
     C                     MOVEL*BLANK    S2SEL
     C                     MOVELAXZETI    S2ZETI
     C                     MOVELAXTEHI    S2TEHI
     C                     MOVELAXPAGE    S2FRPG
TCHK2C*                    Z-ADDAXCDAT    W@CDAT
TCHK2C*                    MOVELW@CDMM    W#CDMM
TCHK2C*                    MOVELW@CDDD    W#CDDD
TCHK2C                     MOVELAXKOMM    W#CDMM
TCHK2C                     MOVELAXKODD    W#CDDD
     C                     MOVEL'/'       W#CDHF
     C                     MOVELW#CDAT    S2MMDD
TCHK2C*                    Z-ADDAXCTIM    W@CTIM
TCHK2C*                    MOVELW@CTHH    W#CTHH
TCHK2C*                    MOVELW@CTMM    W#CTMM
TCHK2C                     MOVELAXKOHH    W#CTHH
TCHK2C                     MOVELAXKOSS    W#CTMM
     C                     MOVEL':'       W#CTHF
     C                     MOVELW#CTIM    S2HHMM
     C                     Z-ADDAXCSEQ    S2CSEQ
     C*
TCHK2C*                    MOVELAXKOME    S2USER
TCHK2C*                    MOVE AXKOWS    S2USER
TCHK2C                     MOVELAXKOME    W@AN01  1
TCHK2C                     MOVELAXKOME    S2USER    P
TCHK2C           W@AN01    IFGE '0'
TCHK2C           W@AN01    ANDLE'9'
TCHK2C                     MOVELAXKOME    W@NN06  60
TCHK2C           W@NN06    CHAINALBPL30              94
TCHK2C           *IN94     IFEQ *OFF
TCHK2C                     MOVELALWKNM    S2USER
TCHK2C                     END
TCHK2C                     END
     C*
     C                     Z-ADDAXCDAT    H2CDAT
     C                     Z-ADDAXCTIM    H2CTIM
     C                     Z-ADDAXCSEQ    H2CSEQ
     C*
     C                     MOVELAXPAGE    S2TOPG
     C           K@6R2     KLIST
     C                     KFLD           A2ZETI
     C                     KFLD           O@CDAT
     C                     KFLD           O@CTIM
     C                     KFLD           O@CSEQ
     C                     KFLD           O@TEHI
     C                     DO   *HIVAL
     C           K@6R2     READEAFAPL6R2                 97
     C           *IN97     IFEQ *OFF
     C           AXSKJY    ANDNE*BLANK
     C                     ITER
     C                     END
     C           *IN97     IFEQ *ON
     C                     EXSR @F2IT1
