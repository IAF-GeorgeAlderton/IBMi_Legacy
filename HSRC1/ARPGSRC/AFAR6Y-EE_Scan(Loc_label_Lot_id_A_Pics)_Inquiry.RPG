     C******************************************************
     C* MAIN                                               *
     C******************************************************
     C                     EXSR @INT
     C*
     C                     DO   *HIVAL
     C*
     C                     EXSR @F1PRC
     C   KA                LEAVE
     C*
     C                     EXSR @F2PRC
     C   KA                LEAVE
     C   KL                ITER
     C*
     C                     ENDDO
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C******************************************************
     C* INITIAL                                            *
     C******************************************************
     C           @INT      BEGSR
     C*
     C                     TIME           W@TMDT
     C*
     C                     ENDSR
     C******************************************************
     C* FMT010 1ST SCREEN PROC                             *
     C******************************************************
     C           @F1PRC    BEGSR
     C*
     C                     EXSR @F1INT
     C*
     C                     DO   *HIVAL
     C*
     C                     EXFMTFMT010
     C   KA                LEAVE
     C*
     C                     MOVEL*OFF      W@ERR   1
     C                     MOVEL*BLANK    MSG
     C                     EXSR @F1CHK
     C           W@ERR     IFEQ *ON
     C                     ITER
     C                     END
     C*
     C                     LEAVE
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*----------------------------------------------------*
     C* FMT010 INITIALIZE                                  *
     C*----------------------------------------------------*
     C           @F1INT    BEGSR
     C*
     C                     MOVE *BLANK    HIN
     C                     Z-ADD*ZERO     BEHZ
     C                     Z-ADD*ZERO     BETM
     C                     MOVEL*BLANK    MSG
     C*
     C                     ENDSR
     C*----------------------------------------------------*
     C* FMT010 CHECK                                       *
     C*----------------------------------------------------*
     C           @F1CHK    BEGSR
     C*
     C                     SETOF                     313233
     C                     SETOF                     3439
      *  CHECK OF PARTS NO  *
     C           HIN       IFEQ *BLANK
     C                     SETON                     3139
     C                     MOVEL*ON       W@ERR
     C           MSG       IFEQ *BLANK
     C                     MOVELER,1      MSG
     C                     END
     C                     END
     C*
     C                     DO
      *  CHECK OF DATE  *
     C           BEHZ      IFEQ *ZERO
     C                     SETON                     323334
     C                     SETON                     39
     C                     MOVEL*ON       W@ERR
     C           MSG       IFEQ *BLANK
     C                     MOVELER,2      MSG
     C                     END
     C                     LEAVE
     C                     END
     C           F1YY      IFEQ *ZERO
     C                     SETON                     3239
     C                     MOVEL*ON       W@ERR
     C           MSG       IFEQ *BLANK
     C                     MOVELER,3      MSG
     C                     END
     C                     END
     C           F1MM      IFEQ *ZERO
     C                     SETON                     3339
     C                     MOVEL*ON       W@ERR
     C           MSG       IFEQ *BLANK
     C                     MOVELER,4      MSG
     C                     END
     C                     END
     C           F1MM      IFGT 12
     C                     SETON                     3339
     C                     MOVEL*ON       W@ERR
     C           MSG       IFEQ *BLANK
     C                     MOVELER,10     MSG
     C                     END
     C                     END
     C           F1DD      IFEQ *ZERO
     C                     SETON                     3439
     C                     MOVEL*ON       W@ERR
     C           MSG       IFEQ *BLANK
     C                     MOVELER,5      MSG
     C                     END
     C                     END
     C           F1DD      IFGT 31
     C                     SETON                     3439
     C                     MOVEL*ON       W@ERR
     C           MSG       IFEQ *BLANK
     C                     MOVELER,11     MSG
     C                     END
     C                     END
     C*
     C                     ENDDO
      * FILE VALID CHECK
     C           W@ERR     IFEQ *OFF
     C                     EXSR @F1CH1
     C           W@ERR     IFEQ *ON
     C                     SETON                     3139
     C           MSG       IFEQ *BLANK
     C                     MOVELER,6      MSG
     C                     END
     C                     END
     C                     END
     C*
     C                     ENDSR
     C*----------------------------------------------------*
     C* FMT010 FILE VALID CHECK                            *
     C*----------------------------------------------------*
     C           @F1CH1    BEGSR
     C*
     C                     DO
     C*
     C           K@FCEP    KLIST
     C                     KFLD           F1HIN1
     C                     KFLD           F1HIN2
     C                     KFLD           F1HIN3
     C           K@FCEP    CHAINFCEPL01              98
     C           *IN98     IFEQ *ON
     C           A2GSKD    ORNE *BLANK
     C                     MOVEL*ON       W@ERR
     C                     LEAVE
     C                     END
     C*
     C           K@6R2A    KLIST
     C                     KFLD           A2ZETI
     C                     KFLD           BEHZ
     C                     KFLD           BETM
     C           K@6R2A    SETLLAFAPL6R2
     C                     DO   *HIVAL
     C           A2ZETI    READEAFAPL6R2                 97
     C           *IN97     IFEQ *ON
     C                     MOVEL*ON       W@ERR
     C                     LEAVE
     C                     END
     C           AXSKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C                     LEAVE
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C* FMT020 2ND SCREEN PROC                             *
     C******************************************************
