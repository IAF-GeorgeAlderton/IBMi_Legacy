      ** AFBR96 **************************
      *  COMPONENTS PARTS ORDER LIST     *
      *  BY ORDER NO.
      *  K.KASHIWAGI 2000.12.07          *
      *  COPY FROM AFBR95                *
      ******************* AFBR96 *********
     FAFBPL93 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *
     I            DS
     I                                        1  12 B9PAR
     I                                        1   5 B9PAR1
     I                                        6  10 B9PAR2
     I                                       11  12 B9PAR3
     I            DS
     I                                        1  12 O9PAR
     I                                        1   5 O9PAR1
     I                                        6  10 O9PAR2
     I                                       11  12 O9PAR3
     I            DS
     I                                        1   60B9ODNO
     I                                        1   20B9ODN1
     I                                        3   40B9ODN2
     I                                        5   60B9ODN3
     I            DS
     I                                        1   60O9ODNO
     I                                        1   20O9ODN1
     I                                        3   40O9ODN2
     I                                        5   60O9ODN3
     I            DS
     I                                        1  100B9OD
     I                                        1   40B9ODYY
     I                                        5   60B9ODMM
     I                                        7   80B9ODDD
     I                                        9  100B9ODBB
     I            DS
     I                                        1   80@9OD
     I                                        1   40@9ODYY
     I                                        5   60@9ODMM
     I                                        7   80@9ODDD
     I            DS
     I                                        1   80B9NO
     I                                        1   40B9NOYY
     I                                        5   60B9NOMM
     I                                        7   80B9NODD
