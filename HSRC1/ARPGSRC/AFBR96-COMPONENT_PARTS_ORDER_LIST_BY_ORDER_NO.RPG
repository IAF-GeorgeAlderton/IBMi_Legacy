      *------*
      * PARM *
      *------*
     C           *ENTRY    PLIST
     C                     PARM           #FD    100
     C                     PARM           #TD    100
     C                     PARM           #SPCD   4
     C                     PARM           US     10
      *-----*
      * KEY *
      *-----*
     C           KEY1      KLIST
     C                     KFLD           B2CODE
      *-----*
     C           KEY2      KLIST
     C                     KFLD           B9SUPP
      *-----*
      * INZ *
      *-----*
      *
     C                     MOVELUS        WUSER   9
     C           *INOF     IFEQ '1'
     C                     MOVE B9SUPP    O9SUPP  40
     C                     EXCPTHD
     C                     MOVEL'Y'       DSW     1
     C                     SETOF                     OF
     C                     END
      *
     C*--------------*
     C* MAIN ROUTINE *
     C*--------------*
     C                     MOVEL*HIVAL    S@OD#   60       ORDER# SAVEAREA
     C                     MOVEL*HIVAL    S@SPCD  4        SAVE SUPP CD
     C*
     C           #SPCD     IFEQ *BLANKS
     C           *IN90     DOWEQ'0'
     C                     READ AFBPL93                  90
     C           *IN90     IFEQ '0'
     C                     Z-ADDB9ODYY    @9ODYY
     C                     Z-ADDB9ODYY    @9ODMM
     C                     Z-ADDB9ODYY    @9ODDD
     C           B9SKJY    IFEQ 'D'
     C           @9OD      ANDLE*DATE
     C                     ELSE
     C           #TD       IFEQ 0
     C                     MOVEL*HIVAL    #TD
     C                     ENDIF
     C           B9OD      IFGE #FD
     C                     MOVEL'-'       HY1     1
     C           B9PAR3    IFEQ *BLANKS
     C                     MOVEL*BLANKS   HY2     1
     C                     ELSE
     C                     MOVEL'-'       HY2     1
     C                     ENDIF
     C           B9HAKO    MULT B9SYOS    S@QTY   80       QTY WK AREA
     C                     Z-ADDS@QTY     OQTY    80
     C                     Z-ADD0         S@QTY
     C           B9HAKO    SUB  B9NOSU    S@NCB   30       NO REC BOX
     C           B9NOSU    IFGT B9HAKO
     C                     Z-ADD0         S@NCB
     C                     ENDIF
     C                     Z-ADDS@NCB     O9NRBX  30
     C                     Z-ADD0         S@NCB
     C*
     C           B9ODNO    IFNE S@OD#
     C           B9SUPP    ANDEQS@SPCD
     C                     MOVELB9SUPP    B2CODE
     C           KEY1      CHAINFGBPL01              50
     C           *IN50     IFEQ '0'
     C                     MOVELB2SMEI    WMEI   15
     C                     ELSE
     C                     MOVEL*BLANKS   WMEI
     C                     ENDIF
     C                     TIME           WTIME   60
     C                     MOVE B9SUPP    O9SUPP
     C                     MOVELB9ODNO    O9ODNO
     C                     MOVELB9ODNO    S@OD#
     C                     EXCPTHD
     C                     MOVEL'Y'       DSW     1
     C                     ENDIF
     C*
     C           B9OD      IFEQ 0
     C                     MOVEL*BLANKS   SL1     1
     C                     MOVEL*BLANKS   SL2     1
     C                     ELSE
     C                     MOVEL'/'       SL1
     C                     MOVEL'/'       SL2
     C                     ENDIF
     C           B9NY      IFEQ 0
     C                     MOVEL*BLANKS   SL3     1
     C                     MOVEL*BLANKS   SL4     1
     C                     ELSE
     C                     MOVEL'/'       SL3
     C                     MOVEL'/'       SL4
     C                     ENDIF
     C           B9NO      IFEQ 0
     C                     MOVEL*BLANKS   O9NO
     C                     MOVEL*BLANKS   SL5     1
     C                     MOVEL*BLANKS   SL6     1
     C                     ELSE
     C                     MOVE B9NO      O9NO
     C                     MOVEL'/'       SL5
     C                     MOVEL'/'       SL6
     C                     ENDIF
     C*
     C           B9SUPP    IFNE S@SPCD
     C                     MOVELB9SUPP    B2CODE
     C           KEY1      CHAINFGBPL01              50
     C           *IN50     IFEQ '0'
     C                     MOVELB2SMEI    WMEI   15
     C                     ELSE
     C                     MOVEL*BLANKS   WMEI
     C                     ENDIF
     C                     TIME           WTIME   60
     C                     MOVE B9SUPP    O9SUPP
     C                     MOVELB9ODNO    O9ODNO
     C                     MOVELB9SUPP    S@SPCD
     C                     EXCPTHD
     C                     MOVEL'Y'       DSW     1
     C                     ENDIF
     C*
     C*
     C           *INOF     IFEQ '1'
     C                     MOVE B9SUPP    O9SUPP
     C                     MOVELB9ODNO    O9ODNO
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     MOVEL'Y'       DSW     1
     C                     END
     C           S@OD#     IFNE B9ODNO
     C           DSW       OREQ 'Y'
     C                     EXCPTDT1
     C                     MOVEL*BLANKS   DSW
     C                     Z-ADDB9ODNO    S@OD#
     C                     ELSE
     C                     EXCPTDT2
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C*
     C                     ELSE
     C                     MOVEL#SPCD     B9SUPP
     C           KEY2      SETLLAFBPL93
     C           *IN90     DOWEQ'0'
     C           KEY2      READEAFBPL93                  90
     C           *IN90     IFEQ '0'
     C                     Z-ADDB9ODYY    @9ODYY
     C                     Z-ADDB9ODYY    @9ODMM
     C                     Z-ADDB9ODYY    @9ODDD
     C           B9SKJY    IFEQ 'D'
     C           @9OD      ANDLE*DATE
     C                     ELSE
     C           #TD       IFEQ 0
     C                     MOVEL*HIVAL    #TD
     C                     ENDIF
     C           B9OD      IFGE #FD
     C           B9OD      ANDLE#TD
     C********   #SPCD     ANDEQB9SUPP
     C                     MOVEL'-'       HY1     1
     C           B9PAR3    IFEQ *BLANKS
     C                     MOVEL*BLANKS   HY2     1
     C                     ELSE
     C                     MOVEL'-'       HY2
     C                     ENDIF
     C           B9HAKO    MULT B9SYOS    S@QTY   80       QTY WK AREA
     C                     Z-ADDS@QTY     OQTY
     C                     Z-ADD0         S@QTY
     C           B9HAKO    SUB  B9NOSU    S@NCB   30       NO REC BOX
     C           B9NOSU    IFGT B9HAKO
     C                     Z-ADD0         S@NCB
     C                     ENDIF
     C                     Z-ADDS@NCB     O9NRBX
     C                     Z-ADD0         S@NCB
     C*
     C           B9ODNO    IFNE S@OD#
     C*KKKKKK    B9SUPP    ANDEQS@SPCD
     C                     MOVELB9SUPP    B2CODE
     C           KEY1      CHAINFGBPL01              50
     C           *IN50     IFEQ '0'
     C                     MOVELB2SMEI    WMEI   15
     C                     ELSE
     C                     MOVEL*BLANKS   WMEI
     C                     ENDIF
     C                     TIME           WTIME   60
     C                     MOVE B9SUPP    O9SUPP
     C                     MOVELB9ODNO    O9ODNO
     C                     MOVELB9ODNO    S@OD#
     C                     EXCPTHD
     C                     MOVEL'Y'       DSW     1
     C                     ENDIF
     C*
     C           B9OD      IFEQ 0
     C                     MOVEL*BLANKS   SL1
     C                     MOVEL*BLANKS   SL2
     C                     ELSE
     C                     MOVEL'/'       SL1
     C                     MOVEL'/'       SL2
     C                     ENDIF
     C           B9NY      IFEQ 0
     C                     MOVEL*BLANKS   SL3
     C                     MOVEL*BLANKS   SL4
     C                     ELSE
     C                     MOVEL'/'       SL3
     C                     MOVEL'/'       SL4
     C                     ENDIF
     C           B9NO      IFEQ 0
     C                     MOVEL*BLANKS   O9NO
     C                     MOVEL*BLANKS   SL5
     C                     MOVEL*BLANKS   SL6
     C                     ELSE
     C                     MOVE B9NO      O9NO
     C                     MOVEL'/'       SL5
     C                     MOVEL'/'       SL6
     C                     ENDIF
     C*
     C           *INOF     IFEQ '1'
     C                     MOVE B9SUPP    O9SUPP
     C                     MOVELB9ODNO    O9ODNO
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     MOVEL'Y'       DSW
     C                     END
     C           S@OD#     IFNE B9ODNO
     C           DSW       OREQ 'Y'
     C                     EXCPTDT1
     C                     Z-ADDB9ODNO    S@OD#
     C                     MOVEL*BLANKS   DSW
     C                     ELSE
     C                     EXCPTDT2
     C                     ENDIF
     C*
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C*
     C                     ENDIF
     C*
     C                     MOVEL'1'       *INLR
     C                     RETRN
     OQPRINT  E  103           HD
     O                                  131 '､､､､､､､､､､､､､､､､､､､､､'
