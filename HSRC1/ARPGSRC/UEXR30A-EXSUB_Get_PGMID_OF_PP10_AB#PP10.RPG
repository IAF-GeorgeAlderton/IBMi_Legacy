     H            Y.
     F** UEXR30A*********************************************
     F*  PROGRAM: EXSUB - GET PGMID OF PP10                 *
     F*  WRITTEN: JW (SRA) 2022.08.29                       *
     F*-----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UEXR30A'
     F*                    PARM           $NONY   4
     F*                    PARM           $NKOJ   1
     F*                    PARM           $NUKE   4
     F*                    PARM           $NOHZ   8
     F*                    PARM           $NOBN   2
     F*                    PARM           $PGID  12
     F*                    PARM           $RAN#  14
     F*  IN  $NONY   4A   DELIVERY#
     F*      $NKOJ   1A   FACTORY
     F*      $NUKE   4A   DOCK
     F*      $NOHZ   8A   SHIP DATE
     F*      $NOBN   2A   BIN#
     F*  OUT $PGID  12A   PROGRAM ID
     F*      $RAN#  14A   AISIN RAN#
     F*******************************************************
     FAB#PL19EIF  E           K        DISK
      *===================================================
      *           MAIN ROUTINE
      *===================================================
     C                     EXSR #INIT
      *
     C           K#19E     SETLLAB#PL19E
      *
     C                     DO   *HIVAL
     C           K#NONY    READEAB#PL19E                 98
     C   98                LEAVE
      * IGNORE
     C           BASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELBAPGID    $PGID
     C                     MOVELBAEDIK    $EDIK
     C                     LEAVE
     C                     ENDDO
      *
     C                     MOVEL$PGID     $PGID
     C                     MOVEL$PGID     $RAN#
     C           $EDIK     IFEQ 'E'
     C                     MOVEL$NUKE     LTR2    2
     C                     MOVE LTR2      $RAN#
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *===================================================
      * INITIAL SETTING
      *===================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4
     C                     PARM           $NKOJ   1
     C                     PARM           $NUKE   4
     C                     PARM           $NOHZ   8
     C                     PARM           $NOBN   2
     C                     PARM           $PGID  12
     C                     PARM           $RAN#  14
      *
     C           K#19E     KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#NOHZ  80
     C                     KFLD           K#NOBN  20
     C                     KFLD           K#NKOJ  1
     C                     KFLD           K#NUKE  4
      *
     C                     MOVEL$NONY     K#NONY
     C                     MOVEL$NOHZ     K#NOHZ
     C                     MOVEL$NOBN     K#NOBN
     C                     MOVEL$NKOJ     K#NKOJ
     C                     MOVEL$NUKE     K#NUKE
     C                     MOVE *BLANK    $PGID
     C                     MOVE *BLANK    $RAN#
     C                     MOVE *BLANK    $EDIK   1
      *
     C                     ENDSR
