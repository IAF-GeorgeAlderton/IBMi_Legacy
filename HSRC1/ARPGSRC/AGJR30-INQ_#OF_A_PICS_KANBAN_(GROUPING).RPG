     F************************************************
     FAGJPW30 CF  E                    WORKSTN
     E                    ER      1  19 65
      *
     I            DS
     I                                        1  100D1C1
     I                                        1   80D1CR1
     I                                        9  100D1CB1
      *
     I            DS
     I                                        1  100D1C2
     I                                        1   80D1CR2
     I                                        9  100D1CB2
      *
     I            DS
     I                                        1  100A1C1
     I                                        1   80A1CR1
     I                                        9  100A1CB1
      *
     I            DS
     I                                        1  100A1C2
     I                                        1   80A1CR2
     I                                        9  100A1CB2
      *
     I            DS
     I                                        1   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   40WJFF
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     I              '0123456789'          C         WKCKSU
     I              X'0E0F40'             C         WKCKCH
     I              '(BY GROUP)'          C         WKGRP
     I              '(BY NEXT PROCESS)'   C         WKNEXT
     I              '(BY PRV PROCESS)'    C         WKPRV
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1DATA  1
     C                     PARM           P1CR1   8
     C                     PARM           P1CB1   2
     C                     PARM           P1CR2   8
     C                     PARM           P1CB2   2
     C                     PARM           P1FILT  1
     C                     PARM           PCMD    2
      *----------------------------------------------------*
      *   K  E  Y   L I  S  T                              *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * CONTROL                                            *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INIT                                               *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVE '01'      DSPSW   2
     C                     MOVEL*BLANK    D1DATA
     C                     Z-ADD0         D1CR1
     C                     Z-ADD0         D1CR2
     C                     Z-ADD0         D1CB1
     C                     Z-ADD0         D1CB2
     C                     MOVEL*BLANK    P1DATA
     C                     MOVEL*BLANK    P1CR1
     C                     MOVEL*BLANK    P1CR2
     C                     MOVEL*BLANK    P1CB1
     C                     MOVEL*BLANK    P1CB2
     C                     MOVEL*BLANK    PCMD
     C                     MOVEL'0'       D1FILT
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     C           DSPSW     DOWEQ'03'
     C                     EXSR #SB230
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
      *
     C                     SETON                     LR
     C                     RETRN
      *
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * 1ST.                                               *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTAGJPW301
     C                     SETOF                     313233
     C                     SETOF                     343536
     C                     SETOF                     993088
     C                     MOVEL*BLANK    D1ERR
      * F1
     C           *IN01     IFEQ '1'
     C                     MOVEL'01'      PCMD
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1DATA    IFEQ '1'
     C           D1DATA    OREQ '2'
     C           D1DATA    OREQ '3'
     C           D1DATA    OREQ '4'
     C           D1DATA    OREQ '5'
     C           D1DATA    OREQ '6'
     C           D1DATA    OREQ '7'
     C                     ELSE
     C                     MOVELER,2      D1ERR
     C                     SETON                     3599
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     MOVEL*BLANK    D2CMT
     C                     MOVEL*BLANK    D3CMT
     C                     SELEC
     C           D1DATA    WHEQ '1'
     C                     MOVE '02'      DSPSW
     C                     MOVELWKGRP     D2CMT
     C           D1DATA    WHEQ '2'
     C                     MOVE '03'      DSPSW
     C                     MOVELWKGRP     D3CMT
     C           D1DATA    WHEQ '3'
     C                     MOVE '02'      DSPSW
     C                     MOVELWKNEXT    D2CMT
     C                     SETON                     88
     C           D1DATA    WHEQ '4'
     C                     MOVE '03'      DSPSW
     C                     MOVELWKNEXT    D3CMT
     C                     SETON                     88
     C           D1DATA    WHEQ '5'
     C                     MOVE '02'      DSPSW
     C                     MOVELWKPRV     D2CMT
     C                     SETON                     88
     C           D1DATA    WHEQ '6'
     C                     MOVE '03'      DSPSW
     C                     MOVELWKPRV     D3CMT
     C                     SETON                     88
     C           D1DATA    WHEQ '7'
     C                     MOVELD1DATA    P1DATA
     C                     MOVEL'05'      PCMD
     C                     MOVE '99'      DSPSW
     C                     ENDSL
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * 2ND.                                               *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C                     EXFMTAGJPW302
     C                     SETOF                     313233
     C                     SETOF                     343536
     C                     SETOF                     9930
     C                     MOVEL*BLANK    D2ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVEL*BLANK    D1DATA
     C                     Z-ADD0         D1CR1
     C                     Z-ADD0         D1CR2
     C                     Z-ADD0         D1CB1
     C                     Z-ADD0         D1CB2
     C                     MOVE '01'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           D1CR1     IFEQ 0
     C                     MOVELER,1      D2ERR
     C                     SETON                     3199
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           D1CR2     IFEQ 0
     C                     MOVELER,1      D2ERR
     C                     SETON                     3299
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           D1CR1     IFGT D1CR2
     C                     MOVELER,3      D2ERR
     C                     SETON                     313299
     C                     GOTO ESB220
     C                     ENDIF
      *
     C   88      D1FILT    IFNE '0'
     C           D1FILT    ANDNE'1'
     C                     MOVELER,2      D2ERR
     C                     SETON                     3699
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           *IN05     IFEQ '1'
     C                     MOVELD1DATA    P1DATA
     C                     MOVELD1CR1     P1CR1
     C                     MOVELD1CR2     P1CR2
     C                     MOVELD1FILT    P1FILT
     C                     MOVEL'00'      P1CB1
     C                     MOVEL'99'      P1CB2
     C                     MOVEL'05'      PCMD
     C                     MOVE '99'      DSPSW
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * 3RD.                                               *
      *----------------------------------------------------*
     CSR         #SB230    BEGSR
      *
     C                     EXFMTAGJPW303
     C                     SETOF                     313233
     C                     SETOF                     343536
     C                     SETOF                     9930
     C                     MOVEL*BLANK    D3ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVEL*BLANK    D1DATA
     C                     Z-ADD0         D1CR1
     C                     Z-ADD0         D1CR2
     C                     Z-ADD0         D1CB1
     C                     Z-ADD0         D1CB2
     C                     MOVE '01'      DSPSW
     C                     GOTO ESB230
     C                     ENDIF
      *
     C           D1CR1     IFEQ 0
     C                     MOVELER,1      D3ERR
     C                     SETON                     3199
     C                     GOTO ESB230
     C                     ENDIF
      *
     C           D1CR2     IFEQ 0
     C                     MOVELER,1      D3ERR
     C                     SETON                     3299
     C                     GOTO ESB230
     C                     ENDIF
      *
     C                     Z-ADDD1C1      A1C1
     C                     Z-ADDD1C2      A1C2
     C***        D1CR2     IFEQ 0
     C***                  Z-ADD99999999  A1CR2
     C***                  ENDIF
     C***        D1CB2     IFEQ 0
     C***                  Z-ADD99        A1CB2
     C***                  ENDIF
     C***        A1C2      IFNE 0
     C           A1C1      IFGT A1C2
     C                     MOVELER,3      D3ERR
     C                     SETON                     313233
     C                     SETON                     3499
     C                     GOTO ESB230
     C                     ENDIF
     C***                  ENDIF
      *
     C   88      D1FILT    IFNE '0'
     C           D1FILT    ANDNE'1'
     C                     MOVELER,2      D2ERR
     C                     SETON                     3699
     C                     GOTO ESB230
     C                     ENDIF
      *
     C           *IN05     IFEQ '1'
     C                     MOVELD1DATA    P1DATA
     C                     MOVELD1CR1     P1CR1
     C                     MOVELD1CR2     P1CR2
     C                     MOVELD1CB1     P1CB1
     C                     MOVELD1CB2     P1CB2
     C                     MOVELD1FILT    P1FILT
     C           D1CB2     IFEQ 0
     C                     MOVEL'99'      P1CB2
     C                     ENDIF
     C                     MOVEL'05'      PCMD
     C                     MOVE '99'      DSPSW
     C                     ENDIF
      *
     CSR         ESB230    ENDSR
**
ER-01 INPUT APICS DATE.
ER-02 INPUT INCORRECT.
ER-03 DATE ERR. (FROM > TO)
ER-04 CAN'T INPUT.
ER-05 PARTS NO. ERR.
