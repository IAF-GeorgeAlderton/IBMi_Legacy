     C           #DATA0    TAG
     C                     READ GDGPL101                 10
     C   10                GOTO #DATA1
     C           IBSKJY    IFEQ 'D'
     C           IBSKHZ    ANDLE*DATE                                  )
     C                     GOTO #DATA0
     C                     ENDIF
%0001C                     MOVE '*'       DATAS1
%0001C**************       GOTO #DATA9
     C*
     C           #DATA1    TAG
     C                     READ GDIPL101                 10
