     C                     Z-ADD*DATE     K@YMD
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDF8YOBI    @YOBI   10
     C                     ENDIF
      *
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C                     PARM           PPGO    2
     C                     PARM           PPRNTR  8
     C                     PARM           P@FACT  3
      *
     C           *NAMVAR   DEFN           TRANS   2        < TO ASJ
     C                     IN   *NAMVAR
     C           *NAMVAR   DEFN           TRANSA  2        < TO ATC
     C                     IN   *NAMVAR
     C*
     C                     MOVE *BLANK    TRANSW  2
     C                     SELEC
     C           P@FACT    WHEQ 'ASJ'
     C                     MOVE TRANS     TRANSW
     C           P@FACT    WHEQ 'ATC'
     C                     MOVE TRANSA    TRANSW
     C                     ENDSL
     C*
     C                     EXSR #INIT
%9999C***STOP              EXSR #SUB0
%0001C* ORDER DATA CHECK
  I  C                     MOVE *BLANK    DATAS1  1        PARTS
  I  C                     MOVE *BLANK    DATAS2  1        DIE
  I  C                     EXSR #DATA
  I  C* PARTS & DIE NOTHING
  I  C           DATAS1    IFEQ *BLANK
  I  C           DATAS2    ANDEQ*BLANK
  I  C                     MOVELMSG,7     D#MSG
  I  C                     EXFMTDSP02
  I  C                     GOTO @END
  I  C                     END
  I  C* DIE NOTHING
  I  C           DATAS2    IFEQ *BLANK
  I  C                     MOVELMSG,6     D#MSG
  I  C           @LOOP2    TAG
  I  C                     EXFMTDSP02
  I  C           *INKA     IFEQ '1'
  I  C                     GOTO @END
  I  C                     END
  I  C           *INKL     IFEQ '1'
  I  C                     GOTO @EXIT2
  I  C                     END
  I  C                     GOTO @LOOP2
  I  C           @EXIT2    TAG
  I  C                     END
  I  C* PARTS NOTHING
  I  C           DATAS1    IFEQ *BLANK
  I  C                     MOVELMSG,2     D#MSG
  I  C           @LOOP1    TAG
  I  C                     EXFMTDSP02
  I  C           *INKA     IFEQ '1'
  I  C                     GOTO @END
  I  C                     END
  I  C           *INKL     IFEQ '1'
  I  C                     GOTO @EXIT1
  I  C                     END
  I  C                     GOTO @LOOP1
  I  C           @EXIT1    TAG
%0001C                     END
     C*
     C********   @YOBI     IFEQ 4
     C********   TRANS     IFNE '**'
     C           TRANSW    IFEQ '  '
     C                     MOVELMSG,3     D#MSG
     C                     EXFMTDSP02
     C                     GOTO @END
     C                     END
     C*
     C           TRANSW    IFEQ ' *'
     C                     MOVELMSG,4     D#MSG
     C           @LOOP3    TAG
     C                     EXFMTDSP02
     C           *INKA     IFEQ '1'
     C                     GOTO @END
     C                     END
     C           *INKL     IFEQ '1'
     C                     GOTO @EXIT3
     C                     END
     C                     GOTO @LOOP3
     C                     END
     C*
B0004C           TRANSW    IFEQ '* '
     C                     MOVELMSG,5     D#MSG
     C           @LOOP4    TAG
     C                     EXFMTDSP02
     C           *INKA     IFEQ '1'
     C                     GOTO @END
     C                     END
     C           *INKL     IFEQ '1'
     C                     GOTO @EXIT3
     C                     END
     C                     GOTO @LOOP4
E0004C                     END
     C***********          END
     C           @EXIT3    TAG
      *
     C***        @YOBI     IFNE 4
