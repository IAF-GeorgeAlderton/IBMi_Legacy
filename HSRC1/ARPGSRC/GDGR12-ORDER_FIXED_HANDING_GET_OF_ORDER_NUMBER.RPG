     C***                  GOTO @END
     C***                  ENDIF
     C*
     C           @DSP01    TAG
     C                     EXFMTDSP01
     C                     MOVEA'0000'    *IN,11
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    D#MSG
     C* < F1=ON >
     C           *INKA     CABEQ'1'       @END
     C*
     C                     EXSR #CHK01
     C           *IN99     CABEQ'1'       @DSP01
     C* < F5=OFF >
     C           *INKE     CABEQ'0'       @DSP01
     C*
     C* eｰjﾞｰNO ﾈｮn
     C                     SELEC
     C           P@FACT    WHEQ 'ASJ'
     C                     MOVEL'ORDER '  K#ORD   6
     C           P@FACT    WHEQ 'ATC'
     C                     MOVEL'OD0200'  K#ORD   6
     C                     ENDSL
     C*
     C                     TIME           @@TIME
     C           K#ORD     CHAINGDGPL301             10
     C           *IN10     IFEQ '0'
     C                     Z-ADD*DATE     IFKOHZ
     C                     Z-ADD@TIME     IFKOTM
     C                     MOVELPPUSER    IFKOME
     C                     Z-ADDD1ODR3    IFNO
     C                     Z-ADDUMONTH    IFMONT
     C                     Z-ADDW1YEAR    IFYEAR
     C                     UPDATGDGPL301
     C                     END
     C                     MOVE 'GO'      PPGO
      *
     C* <END>
     C           @END      TAG
     C                     SETON                     LR
     C                     RETRN
     C****************************************************************
     C           #INIT     BEGSR                                     *
     C****************************************************************
     C**INIT
     C                     MOVE 'NG'      PPGO
     C                     Z-ADD*DATE     W1DATE
     C*
     C                     MOVEA'000'     *IN,11
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    D#MSG
     C                     Z-ADDUYEAR     D1ODR1
     C                     Z-ADDUMONTH    D1ODR2
     C*
     C                     SELEC
     C           P@FACT    WHEQ 'ASJ'
     C                     MOVEL'ORDER '  K#ORD   6
     C           P@FACT    WHEQ 'ATC'
     C                     MOVEL'OD0200'  K#ORD   6
     C                     ENDSL
     C*
     C                     TIME           @@TIME
     C           K#ORD     CHAINGDGPL301             10
     C           *IN10     IFEQ '1'
     C                     MOVE *BLANK    IFSKJY
     C                     Z-ADD0         IFSKYY
     C                     Z-ADD0         IFSKMM
     C                     Z-ADD0         IFSKDD
     C                     Z-ADD*DATE     IFKOHZ
     C                     Z-ADD@TIME     IFKOTM
     C                     MOVELPPUSER    IFKOME
     C                     MOVELK#ORD     IFKEY
     C                     SELEC
     C           P@FACT    WHEQ 'ASJ'
     C                     Z-ADD0         IFNO
     C           P@FACT    WHEQ 'ATC'
     C                     Z-ADD25        IFNO
     C                     ENDSL
     C                     Z-ADD0         IFMONT
     C                     Z-ADDW1YEAR    IFYEAR
     C                     END
     C           IFMONT    IFNE UMONTH
     C                     SELEC
     C           P@FACT    WHEQ 'ASJ'
     C                     Z-ADD0         IFNO
     C           P@FACT    WHEQ 'ATC'
     C                     Z-ADD25        IFNO
     C                     ENDSL
     C                     Z-ADDUMONTH    IFMONT
     C                     Z-ADDW1YEAR    IFYEAR
     C                     END
     C   10                WRITEGDGPL301
     C                     ADD  1         IFNO
     C                     Z-ADDIFNO      D1ODR3
      *
     C                     MOVE '1'       D@PRT
     C*
     C                     ENDSR
     C****************************************************************
     C           #CHK01    BEGSR                                     *
     C****************************************************************
     C**DSP1 CHECK
      *
     C           D1ODER    IFEQ 0
     C                     MOVEA'111'     *IN,11
     C  N99                MOVELMSG,1     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK1E
     C                     END
      *
     C           D1ODR2    IFLT 1
     C           D1ODR2    ORGT 12
     C                     MOVEA'1'       *IN,12
     C  N99                MOVELMSG,1     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK1E
     C                     END
      *
     C           D1ODR3    IFEQ 0
     C                     MOVEA'1'       *IN,13
     C  N99                MOVELMSG,1     D#MSG
     C  N99                MOVEA'1'       *IN,99
     C                     GOTO @CHK1E
     C                     END
      *
     C           D@PRT     IFLT '1'
     C           D@PRT     ORGT '3'
     C                     MOVE *ON       *IN14
     C  N99                MOVELMSG,8     D#MSG
     C  N99                MOVE *ON       *IN99
     C                     ELSE
     C                     SELEC
     C           D@PRT     WHEQ '1'
     C                     MOVEL'LANPRT03'PPRNTR
     C           D@PRT     WHEQ '2'
     C                     MOVEL'LANPRT02'PPRNTR
     C           D@PRT     WHEQ '3'
     C                     MOVEL'LANPRT07'PPRNTR
     C                     ENDSL
     C                     ENDIF
      *
     C           @CHK1E    ENDSR
      *
     C****************************************************************
     C           #SUB0     BEGSR                                     *
     C****************************************************************
     C                     Z-ADD*DATE     $WYMD
     C                     Z-ADD*DATE     @WYMD
     C           @WMM      IFEQ 01
     C                     SUB  1         @WYY
     C                     Z-ADD12        @WMM
     C                     ELSE
     C                     SUB  1         @WMM
     C                     END
      *
     C                     DO   *HIVAL
     C                     SETOF                     1052
     C                     READ BTAPP051                 10
     C           *IN10     IFEQ '0'
      *
     C           BTSKJY    IFEQ 'D'
     C           BTSKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     SETOF                     50
     C                     Z-ADD0         WWMAIS  50
     C           KEY1      CHAINGDGPL101             50
     C           *IN50     IFEQ '0'
     C           IBSKJY    ANDEQ'D'
     C           IBSKHZ    ANDLE*DATE
     C                     SETON                     50
     C                     END
     C           *IN50     IFEQ '0'
     C                     Z-ADDIBMAIS    WWMAIS
     C                     END
      *
     C           @WYM      IFEQ BTKEYM
      *
     C                     Z-ADD1         U
     C                     Z-ADD0         WPSU    50
     C           1         DO   31        U
     C           HTZ,U     IFEQ *BLANK
     C           HTP,U     IFNE 0
     C                     SETON                     52
     C                     ADD  HTP,U     WWMAIS
     C                     ADD  HTP,U     WPSU
     C                     MOVE '*'       HTZ,U
     C                     END
     C                     END
     C                     END
      *
     C                     Z-ADD1         U       20
     C                     Z-ADD0         WMSU    50
     C                     Z-ADD0         WMSU1   50
     C           1         DO   31        U
     C           HTZ,U     IFEQ *BLANK
     C           HTM,U     IFNE 0
     C                     Z-ADDHTM,U     WMSU2   50
     C                     Z-SUBHTM,U     WMSU3   50
     C           WWMAIS    IFGE WMSU2
     C                     SETON                     52
     C                     ADD  WMSU3     WWMAIS
     C                     ADD  HTM,U     WMSU1
     C                     Z-SUBWMSU1     WMSU
     C                     MOVE '*'       HTZ,U
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C           *IN52     IFEQ '1'
     C                     UPDATBTAPP051
     C                     EXSR #SUB1
     C                     END
      *
     C                     END
      *
     C           $WYM      IFEQ BTKEYM
      *
     C                     Z-ADD1         U
     C                     Z-ADD0         WPSU
     C           1         DO   $WDD      U
     C           HTZ,U     IFEQ *BLANK
     C           HTP,U     IFNE 0
     C                     SETON                     52
     C                     ADD  HTP,U     WWMAIS
     C                     ADD  HTP,U     WPSU
     C                     MOVE '*'       HTZ,U
     C                     END
     C                     END
     C                     END
      *
     C                     Z-ADD1         U
     C                     Z-ADD0         WMSU
     C                     Z-ADD0         WMSU1
     C           1         DO   $WDD      U
     C           HTZ,U     IFEQ *BLANK
     C           HTM,U     IFNE 0
     C                     Z-ADDHTM,U     WMSU2
     C                     Z-SUBHTM,U     WMSU3
     C           WWMAIS    IFGE WMSU2
     C                     SETON                     52
     C                     ADD  WMSU3     WWMAIS
     C                     ADD  HTM,U     WMSU1
     C                     Z-SUBWMSU1     WMSU
     C                     MOVE '*'       HTZ,U
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C           *IN52     IFEQ '1'
     C                     UPDATBTAPP051
     C                     EXSR #SUB1
     C                     END
      *
     C                     END
      *
     C                     END
     C                     END
     C  N10                END
      *
     C                     ENDSR
      *
     C****************************************************************
     C           #SUB1     BEGSR                                     *
     C****************************************************************
     C                     SETOF                     50
     C           KEY1      CHAINGDGPL101             50
      *
     C                     MOVE *BLANK    IBSKJY
     C                     Z-ADD0         IBSKHZ
     C                     Z-ADD*DATE     IBKOHZ
     C                     TIME           IBKOTM
     C                     MOVELPPUSER    IBKOME
      *
     C           WPSU      ADD  WMSU      $WMAIS  50
      *
     C           *IN50     IFEQ '0'
     C                     ADD  $WMAIS    IBMAIS
     C           IBSYOS    MULT IBMAIS    IBSURY
     C                     UPDATGDGPL101
     C                     ELSE
      *
     C                     MOVE *BLANK    IBSEIH
     C                     MOVE BTSHN1    IBHIN1
     C                     MOVE BTSHN2    IBHIN2
     C                     MOVE BTSHN3    IBHIN3
      *
     C                     SETOF                     51
     C                     Z-ADD0         IBSYOS
     C           KEY1      CHAINFCEPL011             51
     C           *IN51     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     51
     C                     END
     C           *IN51     IFEQ '0'
     C           A2SYHZ    IFGT *DATE
     C                     Z-ADDA2KSYS    IBSYOS
     C                     ELSE
     C                     Z-ADDA2SSYS    IBSYOS
     C                     END
     C                     ELSE
      *
     C                     SETOF                     51
     C           KEY1      CHAINAKCPL011             51
     C           *IN51     IFEQ '0'
     C           M1SKJY    ANDEQ'D'
     C           M1SKHZ    ANDLE*DATE
     C                     SETON                     51
     C                     END
     C           *IN51     IFEQ '0'
     C           M1SYHZ    IFGT *DATE
     C                     Z-ADDM1KSYS    IBSYOS
     C                     ELSE
     C                     Z-ADDM1SSYS    IBSYOS
     C                     END
     C                     END
     C                     END
      *
     C                     Z-ADD$WMAIS    IBMAIS
     C           IBSYOS    MULT IBMAIS    IBSURY
     C                     WRITEGDGPL101
      *
     C                     END
     C                     ENDSR
