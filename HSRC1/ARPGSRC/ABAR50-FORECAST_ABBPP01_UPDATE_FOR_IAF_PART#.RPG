     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           P@MHIN
     C                     PARM           P@SHIN
     C                     PARM           @FLG    1
     C           P@SHIN    IFNE *BLANK
     C                     MOVELP@SHN1    Q5SHN1
     C                     MOVELP@SHN2    Q5SHN2
     C                     MOVELP@SHN3    Q5SHN3
     C                     UPDATABBPL011
TCHK2C           K#PL51    KLIST
