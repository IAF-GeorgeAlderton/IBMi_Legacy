     C                     MOVELQ5NUKE    PNUKE   4
     C                     MOVELQ5MHN1    P@MHN1
     C                     MOVELQ5MHN2    P@MHN2
     C                     MOVELQ5MHN3    P@MHN3
     C                     MOVELQ5MHN4    P@MHN4
