     C                     MOVELJCKANK    #KNKB
     C                     MOVELJCZETI    #ZNO
     C                     MOVELJCTHAI    #TNO
     C                     MOVELJCPAG1    #PNO1
     C                     MOVELJCPAG2    #PNO2
     C                     MOVELJCPAG3    #PNO3
     C                     MOVELJCPAG4    #PNO4
     C                     MOVELJC2JKA    #2JIK
     C                     MOVELJCTASY    #TISG
     C                     MOVELJCSYKO    #SYKB
     C                     MOVELJCHKBR    #HAKO
     C                     Z-ADDJCMKSU    #KEIS
     C                     MOVELJCIROK    #IRO
     C                     Z-ADDJCSYUY    #SYOS
     C                     MOVELJCHKFA    #MHKO
     C                     Z-ADDJCTANJ    #TANJ
     C                     Z-ADDJCWKHZ    #THIZ
     C                     Z-ADDJCWKTM    #TTIM
     C                     Z-ADDJCWMJY    #TNMJ
     C                     MOVE JCMKKB    #KIBN
     C                     Z-ADDJCKEHZ    #KHIZ
     C                     Z-ADDJCKETM    #KTIM
     C                     Z-ADDJCWAIT    #KEIJ
     C                     MOVE JCTOCD    #TOCD
     C                     SETOF                     90
     C           JCTOCD    CHAINAJSPLCD1             90
     C           JASKJY    IFEQ ' '
     C           *IN90     ANDEQ*OFF
     C                     MOVE JAWKNM    #TOCM
     C                     END
     C                     MOVE JCZBR1    #ZAI1
     C                     MOVE JCZBR2    #ZAI2
     C                     MOVE JCKECD    #KECD
     C                     SETOF                     91
     C           JCKECD    CHAINAJSPLCD1             91
     C           JASKJY    IFEQ ' '
     C           *IN91     ANDEQ*OFF
     C                     MOVE JAWKNM    #KECM
     C                     END
     C                     MOVE JCGAFR    #GAFR
     C                     MOVE JCNGFR    #NGFR
     C                     MOVE JCMKFR    #MKFR
     C                     Z-ADDJCSOKK    #SOKK
     C                     Z-ADDJCTMAI    #TMAI
     C                     MOVE JCSAIK    #SAIK
      *
     C           JCSAIK    IFEQ '0'
     C           JCSAIK    OREQ ' '
     C                     MOVEA'0'       *IN,21
     C                     ELSE
     C                     MOVEA'1'       *IN,21
     C                     END
      *
     C           JCGAFR    IFEQ '1'
     C           JCNGFR    OREQ '1'
     C           JCMKFR    OREQ '1'
     C                     MOVEA'1'       *IN,22
     C                     ELSE
     C                     MOVEA'0'       *IN,22
     C                     END
      *
     C                     ADD  1         RRN
     C                     ADD  1         CNTR
     C                     WRITEDSP2R
     C                     MOVEL'*'       SW
      * MAX mﾞｰj <15>
     C           CNTR      IFGE 15
     C                     LEAVE
     C                     ENDIF
E001 C                     ENDDO
