     C                     GOTO #SET2E
E001 C                     END
      *
     C           #SET2E    ENDSR
      ******************************************************
     C           ROLLUP    BEGSR                           *
      ******************************************************
     C                     MOVE *BLANK    SW      1
     C                     Z-ADD*ZERO     CNTR    50
      *-----------------------------------
B001 C                     DO   *HIVAL
     C           KEY2      READEAJHPL121                 40
     C   40                LEAVE
     C           JCWKHT    IFGT EHIZT
     C                     LEAVE
     C                     ENDIF
      *
     C           JCSKJY    IFEQ 'D'
     C           JCSKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
      *
     C           JCWKHT    IFLT SHIZT
     C                     ITER
     C                     END
      *
     C           JCWKHT    IFGT EHIZT
     C                     ITER
     C                     END
      *
     C                     MOVEA'0'       *IN,21
     C                     MOVEA'0'       *IN,22
     C                     MOVEL*BLANK    HIN
     C                     MOVELJCHIN1    HIN1
     C                     MOVELJCHIN2    HIN2
     C                     MOVELJCHIN3    HIN3
     C           HIN2      IFNE *BLANK
     C                     MOVEL'-'       HINA
     C                     END
     C           HIN3      IFNE *BLANK
     C                     MOVEL'-'       HINB
     C                     END
     C                     MOVE HIN       @HIN
     C                     MOVELJCTHAI    @THI
     C                     MOVELJCPAG1    @PNO1
     C                     MOVELJCPAG2    @PNO2
     C                     MOVELJCPAG3    @PNO3
     C                     MOVELJCPAG4    @PNO4
     C                     Z-ADDJCMKSU    @KEIS
