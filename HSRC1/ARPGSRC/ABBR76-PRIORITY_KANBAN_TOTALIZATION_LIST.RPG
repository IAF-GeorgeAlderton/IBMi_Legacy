     C                     WRITEABBWP771
     C                     ENDIF
     C                     ENDDO
      *
     C                     CLOSEABBWP77
     C                     OPEN ABBWP77
      *
     C                     MOVE *BLANK    WMCHN   3
     C                     Z-ADD*ZERO     @CONT   50
     C                     MOVE *BLANK    W@PART
     C                     Z-ADD*ZERO     W@DATE  80
     C                     CLEARABBWP781
     C           *LOVAL    SETLLABBWP77
     C           *IN80     DOUEQ*ON
     C                     READ ABBWP77                  80
     C           *IN80     IFEQ *OFF
      *
     C           @CONT     IFNE *ZERO
     C           WMCHN     ANDNEA7MCHN
     C                     EXSR #WRT8
     C                     ENDIF
      *
     C           A7PART    IFNE W@PART
     C           W@DATE    ORNE A7DATE
     C                     ADD  1         @CONT
     C                     ENDIF
      *
     C                     Z-ADDA7DATE    W@DATE
     C                     MOVE A7MCHN    WMCHN
     C                     MOVE A7PART    W@PART
     C                     ENDIF
     C                     ENDDO
      *
     C           @CONT     IFNE *ZERO
     C                     EXSR #WRT8
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------
     C           #WRT8     BEGSR
      *-----------------------------------------------
     C                     MOVE WMCHN     AWMCHN
     C                     Z-ADD@CONT     AWCONT
      *
     C                     Z-ADD*ZERO     @PCONT  50
     C                     MOVE WMCHN     K@MCH
     C           K#GHC     SETLLGHCTL22
     C           *IN81     DOUEQ*ON
     C           K#GHC     READEGHCTL22                  81
     C           *IN81     IFEQ *OFF
     C                     ADD  1         @PCONT
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD@PCONT    AWITEM
      *
     C                     WRITEABBWP781
     C                     Z-ADD*ZERO     @CONT
     C                     MOVE *BLANK    W@PART
     C                     Z-ADD*ZERO     W@DATE  80
      *
     C                     ENDSR
      *-----------------------------------------------
     C           #PRT2     BEGSR
      *-----------------------------------------------
     C                     TIME           @@TIME  60
     C                     MOVE *ALL'-'   @@LN  198
     C                     MOVE *ALL'-'   @@LN2 172
     C                     MOVE *OFF      *IN98
     C                     Z-ADD*ZERO     @RANK   30
     C                     Z-ADD*ZERO     @CONT   50
     C           D@LOC     LOKUPTAB1      TAB2           90
      *
     C           *HIVAL    SETLLABBWP78
     C           *IN80     DOUEQ*ON
     C                     READ ABBWP78                  80
     C           *IN80     IFEQ *OFF
      *
     C           @CONT     IFNE AWCONT
     C                     ADD  1         @RANK
     C           @RANK     IFGT D@TOP
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HEDM
     C                     EXCPT@LINE
     C                     Z-ADD5         @CNT    20
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
     C                     ADD  4         @CNT
     C           @CNT      IFGT 62
     C                     EXCPT@HEDM
     C                     EXCPT@LINE
     C                     Z-ADD9         @CNT    20
     C                     ENDIF
      *
     C           AWCONT    COMP @CONT                1010
     C                     Z-ADDAWCONT    @CONT
      *
     C           @CNT      IFGT 9
     C                     EXCPT@LINE
     C                     ENDIF
     C                     EXCPT@DTLM1
      *
     C                     EXSR #PART
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------
     C           #PART     BEGSR
      *-----------------------------------------------
     C                     MOVE *BLANK    W@PART
     C                     MOVE AWMCHN    K@MCH
     C           K#GHC     SETLLGHCTL22
     C           *IN81     DOUEQ*ON
     C           K#GHC     READEGHCTL22                  81
     C           *IN81     IFEQ *OFF
      *
     C           MCJHN2    COMP *BLANK               0101
     C           MCJHN3    COMP *BLANK               0202
      *
      *
     C                     MOVE MCJHN1    W7PRT1
     C                     MOVE MCJHN2    W7PRT2
     C                     MOVE MCJHN3    W7PRT3
      *
     C           K#FCX     CHAINFCEPL01              95
      *
     C                     Z-ADD*ZERO     B       20
     C           K#FCX     CHAINAAMPL11              95
     C           *IN95     IFEQ *OFF
     C           1         DO   15        K       20
     C           NKOT,K    IFNE *BLANK
JW1   * MAX 8 PROCESS
"    C           B         IFGE 9
"    C           K         ORGE 16
"    C                     MOVEL'***'     #OVR
"    C                     ELSE
     C                     ADD  1         B
     C                     MOVELNKOT,K    @KOT,B
     C                     MOVELNTOK,K    QQQQ
     C                     MOVELQQ02      TKR2
     C                     MOVELQQ03      TKR3
     C           PPP       IFNE 'P'
     C                     MOVEL@TKR      @TK,B
     C                     ELSE
     C           @TKR      CAT  '-':0     @@6     6
     C           @@6       CAT  QQ04:0    @TK,B     P
     C                     ENDIF
      *
     C           NKOT,K    IFNE 'BZ '
     C                     MOVELNKBN,K    @KBN,B
     C                     ELSE
     C                     MOVELA2MEK1    @KBN,B
     C                     ENDIF
      *
     C           NBM,K     IFNE 0111
     C           NBM,K     CHAINFGBPL011             30
     C           *IN30     IFEQ '0'
     C                     MOVELB2SMEI    @KOT,B
     C                     END
     C                     END
JW1  C                     ENDIF
      *
     C                     MOVE NKAN,K    KANSY   1
     C                     Z-ADDKANK,K    KHIB
      *
     C                     ENDIF
     C                     ENDDO
      * LAST TREATMENT INFORMATION
     C                     EXSR #MIN
      *
     C           W@20      IFNE *BLANK
JW1  C           B         ANDLE8
     C                     MOVELW@20      @KBN,B
     C                     ENDIF
      *
     C           K#FCX     CHAINFCEPL11              96
     C           *IN96     IFEQ *OFF
     C           FCGK01    DIV  FCCD01    @@SQTY  90
     C           @@SQTY    DIV  A2SSYS    @@SBOX  52
     C                     ENDIF
      * WASHER
     C                     EXSR #WASH
      * COUNT
     C                     EXSR #PCON
      *
     C           @CNT      IFGT 62
     C                     EXCPT@HEDM
     C                     EXCPT@LINE
     C                     Z-ADD9         @CNT    20
     C                     ENDIF
      *
     C           W@PART    IFNE *BLANK
     C           @CNT      IFGT 9
     C                     EXCPT@LINX
     C                     ELSE
     C                     EXCPT@BLK
     C                     ENDIF
     C                     ENDIF
      *
     C                     EXCPT@DTLM2
     C                     ADD  4         @CNT
     C                     ENDIF
      *
     C                     MOVE A7PART    W@PART
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     SUB  4         @CNT
      *
     C                     ENDSR
      *-----------------------------------------------
     C           #PCON     BEGSR
      *-----------------------------------------------
     C                     Z-ADD*ZERO     @PP     30
     C                     Z-ADD*ZERO     WWDATE  80
     C           K#W77     SETLLABBWL77
     C           *IN82     DOUEQ*ON
     C           K#W77     READEABBWL77                  82
     C           *IN82     IFEQ *OFF
     C           A7DATE    IFNE WWDATE
     C                     ADD  1         @PP
     C                     ENDIF
     C                     Z-ADDA7DATE    WWDATE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
