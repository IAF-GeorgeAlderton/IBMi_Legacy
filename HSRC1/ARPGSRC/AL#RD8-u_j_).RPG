     C           W9KBN     WHEQ '2'
     C                     EXSR #EDIT2
     C           W9KBN     WHEQ '3'
     C                     EXSR #EDIT3
     C                     ENDSL
     C                     Z-ADDW9SEQ     H1SEQ
      *
     CSR         EEDIT     ENDSR
      *----------------------------------------------------*
      * PALLET TICKET                                      *
      *----------------------------------------------------*
     CSR         #EDIT1    BEGSR
      *
     C                     CLEARTIK
     C                     MOVELW9DATA    TIK
     C                     MOVEL*BLANK    S1TXT
     C           S1TXT     CAT  'PALLET':0S1TXT
     C           S1TXT     CAT  'TICKET':1S1TXT
     C           S1TXT     CAT  'PALLET':2S1TXT
     C           S1TXT     CAT  '# =':0   S1TXT
     C           S1TXT     CAT  W9IAFP:1  S1TXT
      *
     CSR         EEDIT1    ENDSR
      *----------------------------------------------------*
      * KANBAN                                             *
      *----------------------------------------------------*
     CSR         #EDIT2    BEGSR
      *
     C                     CLEARKAN
     C                     MOVELW9DATA    KAN
     C                     MOVEL*BLANK    S1TXT
     C           S1TXT     CAT  'KANBAN':0S1TXT
     C           S1TXT     CAT  'DATA':1  S1TXT
      *
     C                     MOVEL*BLANK    S1MHN  14
     C           S1MHN     CAT  W9MHN1:0  S1MHN
     C           S1MHN     CAT  '-':0     S1MHN
     C           S1MHN     CAT  W9MHN2:0  S1MHN
