     C           S1MHN     CAT  '-':0     S1MHN
     C           S1MHN     CAT  W9MHN3:0  S1MHN
     C                     ENDIF
      *
     C           S1TXT     CAT  S1MHN:1   S1TXT
     C           S1TXT     CAT  'SEQ#=':1 S1TXT
     C           S1TXT     CAT  W9SEQ#:0  S1TXT
     C           S1TXT     CAT  'BOX#=':1 S1TXT
