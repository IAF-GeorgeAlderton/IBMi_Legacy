     C                     MOVELJ42JKA    #2JIK
     C                     MOVELJ4TASY    #TISG
     C                     MOVELJ4SYKO    #SYKB
     C                     MOVELJ4HKBR    #HAKO
     C                     Z-ADDJ4MKSU    #KEIS
