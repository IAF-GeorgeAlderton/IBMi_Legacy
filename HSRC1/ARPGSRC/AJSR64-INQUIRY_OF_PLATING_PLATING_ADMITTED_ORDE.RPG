     C                     Z-ADDJ4WKHZ    @THIZ
     C                     Z-ADDJ4WKTM    @TTIM
     C                     Z-ADDJ4WMJY    @GRYO
     C                     Z-ADDJ4MKSU    @KEIS
     C                     MOVELJ4IROK    @IRO
     C                     Z-ADDJ4WKHZ    @THIZ
     C                     Z-ADDJ4WKTM    @TTIM
     C                     MOVELJ4KANK    #KNKB
     C                     MOVELJ4ZETI    #ZNO
     C                     MOVELJ4THAI    #TNO
     C                     MOVELJ4PAG1    #PNO1
     C                     MOVELJ4PAG2    #PNO2
     C                     MOVELJ4PAG3    #PNO3
     C                     MOVELJ42JKA    #2JIK
     C                     MOVELJ4TASY    #TISG
     C                     MOVELJ4SYKO    #SYKB
     C                     MOVELJ4HKBR    #HAKO
     C                     Z-ADDJ4MKSU    #KEIS
     C                     MOVELJ4IROK    #IRO
     C                     MOVELJ4HKFA    #MHKO
