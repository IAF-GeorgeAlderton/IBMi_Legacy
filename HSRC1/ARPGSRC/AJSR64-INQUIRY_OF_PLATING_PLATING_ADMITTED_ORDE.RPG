     C           #SET2E    ENDSR
      ******************************************************
     C           ROLLUP    BEGSR                           *
      ******************************************************
     C                     MOVE *BLANK    SW      1
      *
B001 C                     DO   *HIVAL
     C           MORE2     TAG
     C           GOKI      READEAJSPL341                 40
     C   40                GOTO @ROLE
      *
     C           J4SKJY    IFEQ 'D'
     C           J4SKHZ    IFLE *DATE
     C                     GOTO MORE2
     C                     END
     C                     END
      *
     C                     MOVEL'*'       SW
     C                     Z-ADDJ4WKHZ    @1YMD
     C                     Z-ADDJ4WKTM    @1JI
     C                     Z-ADDJ4WKHZ    @2YMD
     C                     Z-ADDJ4WKTM    @2JI
      *
     C           @2        CABGT$2        @ROLE
     C                     MOVELJ4HIN1    @HIN1
     C                     MOVELJ4HIN2    @HIN2
     C                     MOVELJ4HIN3    @HIN3
      *
     C           @HIN2     IFNE *BLANK
     C                     MOVEL'-'       @HINA
     C                     END
      *
     C           @HIN3     IFNE *BLANK
     C                     MOVEL'-'       @HINB
     C                     END
      *
     C                     MOVELJ4THAI    @THI
     C                     MOVELJ4PAG1    @PNO1
     C                     MOVELJ4PAG2    @PNO2
     C                     MOVELJ4PAG3    @PNO3
     C                     Z-ADDJ4MKSU    @KEIS
