     C                     MOVELJ4IROK    @IRO
     C                     Z-ADDJ4WKHZ    @THIZ
     C                     Z-ADDJ4WKTM    @TTIM
     C                     Z-ADDJ4WMJY    @GRYO
     C                     Z-ADDJ4MKSU    @KEIS
     C                     MOVELJ4IROK    @IRO
     C                     Z-ADDJ4WKHZ    @THIZ
     C                     Z-ADDJ4WKTM    @TTIM
     C                     MOVELJ4KANK    #KNKB
     C                     MOVELJ4ZETI    #ZNO
     C                     MOVELJ4THAI    #TNO
     C                     MOVELJ4PAG1    #PNO1
