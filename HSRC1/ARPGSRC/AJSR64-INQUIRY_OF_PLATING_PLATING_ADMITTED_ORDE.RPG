     C                     Z-ADDJ4WMJY    #TNMJ
     C                     Z-ADDJ4MKKB    #KIBN
     C                     Z-ADDJ4KEHZ    #KHIZ
     C                     Z-ADDJ4KETM    #KTIM
     C                     Z-ADDJ4WAIT    #KEIJ
     C                     MOVELJ4HSUK    #TNSS
     C                     Z-ADDJ4KBUH    #TNHK
     C                     Z-ADDJ4KBUK    #TNKO
     C                     MOVELJ4HIN1    #HIN1
     C                     MOVELJ4HIN2    #HIN2
     C                     MOVELJ4HIN3    #HIN3
      *
     C           #HIN2     IFNE *BLANK
     C                     MOVEL'-'       #HINA
     C                     END
      *
     C           #HIN3     IFNE *BLANK
     C                     MOVEL'-'       #HINB
     C                     END
      *
     C           J4HNTE    IFNE '0'
     C           J4HNTE    ANDNE'1'
     C                     MOVEA'1'       *IN,21
     C                     ELSE
     C                     MOVEA'0'       *IN,21
     C                     END
      *
     C                     ADD  1         RRN
     C                     ADD  1         CNTR
     C                     WRITEDSP2R
      * MAX mﾞｰj <16>
     C           CNTR      CABEQ16        @@@
E002 C                     END
     C           @END      TAG
E001 C  N40                END
      *
     C           @@@       TAG
      *  fﾞbnc mﾞｰj oﾆ
B001 C           RRN       IFEQ 0
     C                     MOVEA'11111'   *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,12    ERR
     C                     END
      *
     C                     ENDSR
      ******************************************************
     C           #SET2     BEGSR                           *
      ******************************************************
     C           STP3      TAG
     C                     EXFMTAJSPW642
      *
