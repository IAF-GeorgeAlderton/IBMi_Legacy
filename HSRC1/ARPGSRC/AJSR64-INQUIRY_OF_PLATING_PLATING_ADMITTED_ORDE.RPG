     C                     Z-ADDJ4WKHZ    #THIZ
     C                     Z-ADDJ4WKTM    #TTIM
     C                     Z-ADDJ4WMJY    #TNMJ
     C                     Z-ADDJ4MKKB    #KIBN
     C                     Z-ADDJ4KEHZ    #KHIZ
     C                     Z-ADDJ4KETM    #KTIM
     C                     Z-ADDJ4WAIT    #KEIJ
     C                     MOVELJ4HSUK    #TNSS
     C                     Z-ADDJ4KBUH    #TNHK
     C                     Z-ADDJ4KBUK    #TNKO
     C                     MOVELJ4HIN1    #HIN1
     C                     MOVELJ4HIN2    #HIN2
     C                     MOVELJ4HIN3    #HIN3
      *
     C           #HIN2     IFNE *BLANK
     C                     MOVEL'-'       #HINA
     C                     END
      *
     C           #HIN3     IFNE *BLANK
     C                     MOVEL'-'       #HINB
