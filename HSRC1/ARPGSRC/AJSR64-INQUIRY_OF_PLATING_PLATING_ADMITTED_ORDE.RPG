      *
     C           J4SKJY    IFEQ 'D'
     C           J4SKHZ    IFLE *DATE
     C                     GOTO MORE1
     C                     END
     C                     END
      *
B002 C           *IN,40    IFEQ '0'
     C                     Z-ADDJ4WKHZ    @1YMD
     C                     Z-ADDJ4WKTM    @1JI
     C                     Z-ADDJ4WKHZ    @2YMD
     C                     Z-ADDJ4WKTM    @2JI
      *
     C           @2        CABGT$2        @@@
     C                     MOVELJ4HIN1    @HIN1
