     C           KEYKR1    KLIST
     C                     KFLD           #KGTDT  80
     C                     KFLD           #KGTTI  60
      *
     C           KEYHIN    KLIST
     C                     KFLD           #KHIN1  5
     C                     KFLD           #KHIN2  5
     C                     KFLD           #KHIN3  2
      *----------------------------------------------------------------
      * SEND BACK DATA FROM ASJ  (PROCESS INFORMATION) READ
      *----------------------------------------------------------------
     C                     Z-ADD0         #KGTDT
     C                     Z-ADD0         #KGTTI
     C           KEYKR1    SETLLMRAPLT11
     C           KEYKR1    READEMRAPLT11                 80
     C  N80                EXSR #SB531
     C           *IN80     DOWEQ'0'
     C                     EXSR #SB530
     C                     Z-ADDWTIHZ     KTGTDT
     C                     Z-ADDWJFB      KTGTTI
     C                     UPDATMRAPLT11
     C           KEYKR1    READEMRAPLT11                 80
     C           @X        IFGT 15
     C                     SETON                         80
     C                     END
     C                     ENDDO
      *
     C           KOT,1     IFNE *BLANK
     C                     EXSR #SB532
     C                     END
      *----------------------------------------------------------------
      * EXIT
      *----------------------------------------------------------------
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------------------
      * INTRA COMPANY KANBAN CHANGE M/F CREATION
      *----------------------------------------------------------------
     CSR         #SB530    BEGSR
     C           KTSHIN    IFEQ W@SHIN
     C                     CLEARW@TKR
     C                     MOVE KTMBN1    W@TKR1
     C                     MOVE KTMBN2    W@TKR2
     C                     MOVE KTMBN3    W@TKR3
     C                     MOVE KTMBN4    W@TKR4
