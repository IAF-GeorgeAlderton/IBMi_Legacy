     C                     MOVE KTKDAI    KID,@X
     C                     ADD  1         @X
     C                     MOVE KTSHIN    W@SHIN
     C                     ELSE
      *
     C                     EXSR #SB532
     C                     EXSR #SB531
     C                     END
     CSR         ESB530    ENDSR
      *----------------------------------------------------------------
      * ITEM INITIALIZATION
      *----------------------------------------------------------------
     CSR         #SB531    BEGSR
     C                     MOVE *ALL' '   KOT
     C                     MOVE *ALL'0'   KBM
     C                     MOVE *ALL' '   KBN
