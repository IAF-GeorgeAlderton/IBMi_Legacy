      *  fnﾞcﾍﾞ 1.2
     C                     Z-ADD0         @DD1    31
     C                     Z-ADD0         @DD2    31
     C           KEY1      SETLLAGDPL121
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY1      READEAGDPL121                 10
     C           *IN10     IFEQ '0'
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         @DD1
     C                     ELSE
     C                     ADD  0.5       @DD1
     C                     END
      *
     C                     END
     C                     END
     C  N10                END
      *
     C                     Z-ADDDAYYY     YYL
     C                     Z-ADDDAYMM     MML
     C           KEY2      SETLLAGDPL121
     C                     DO   *HIVAL
     C                     SETOF                     20
     C                     READ AGDPL121                 20
     C           *IN20     IFEQ '0'
      *
     C           F8KAHZ    IFGT DAYL
     C                     SETON                     20
     C                     ELSE
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         @DD2
     C                     ELSE
     C                     ADD  0.5       @DD2
     C                     END
      *
     C                     END
     C                     END
     C                     END
     C  N20                END
      *
