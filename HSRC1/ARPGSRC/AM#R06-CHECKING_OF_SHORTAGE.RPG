     F*******************************************************
     FAL#PL03 IF  E           K        DISK
     FAM#WP06 UF  E           K        DISK                      A
     FAB#PP65 IF  E           K        DISK
      *
     I            DS
     I                                        1  72 TICKET
     I                                        1   9 TISURT
     I                                       10  17 TISHID
     I                                       18  23 TISHIT
     I                                       24  38 TISMEI
     I                                       39  40 TIDOCK
     I                                       41  52 TIORD#
     I                                       53  54 TIPALT
     I                                       55  58 TINONY
     I                                       59  59 TINKOJ
     I                                       60  63 TINUKE
     I                                       64  66 TIIAFB
     I                                       67  69 TIIAFP
     I                                       70  70 TIPPUL
     I                                       71  71 TIEXT
     I                                       72  72 TISAT
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  140SDATE
     I                                        1   60STIME
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P9TICK100
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     TIME           WTIME
     C                     MOVELP9TICK    TICKET
     C                     EXSR #SB400
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C           KEY01     KLIST
     C                     KFLD           KKSHID  8
     C                     KFLD           KKSHIT  6
     C                     KFLD           KKSURT  9
     C                     KFLD           KKNONY  40
     C                     KFLD           KKNKOJ  1
     C                     KFLD           KKNUKE  4
     C                     KFLD           KKORD# 12
     C                     KFLD           KKPALT  2
      *チケットよりセット
     C                     MOVELTISHID    KKSHID
     C                     MOVELTISHIT    KKSHIT
     C                     MOVELTISURT    KKSURT
     C                     MOVE TINONY    KKNONY
     C                     MOVELTINKOJ    KKNKOJ
     C                     MOVELTINUKE    KKNUKE
     C                     MOVELTIORD#    KKORD#
     C                     MOVELTIPALT    KKPALT
      *
     C                     MOVEL'0'       GET     1
     C                     TIME           WTIME
     C           KEY01     SETLLAL#PL031
     C           KEY01     READEAL#PL031                 80
     C           *IN80     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           CASKJY    IFEQ 'D'
     C           CASKHZ    ANDLESDATE
     C                     ELSE
     C           CAIAFB    IFEQ TIIAFB
     C           CAIAFP    ANDEQTIIAFP
     C                     EXSR #SB720
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C           KEY01     READEAL#PL031                 80
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      * AM#WP06                                            *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYW6     KLIST
     C                     KFLD           CAKNB#
     C                     KFLD           CATKR1
     C                     KFLD           CATKR2
     C                     KFLD           CATKR3
     C                     KFLD           CATKR4
      *
     C           KEYW6     CHAINAM#WP061             46
     C           *IN46     IFEQ '0'
     C                     ADD  1         W6BOX
     C                     ADD  1         W6BOX3
     C           CAPLDT    IFNE 0
     C                     ADD  1         W6SUMI
     C                     ENDIF
     C                     ADD  WKSUM3    W6SUM3
     C                     UPDATAM#WP061
     C                     ELSE
     C                     CLEARAM#WP061
     C                     MOVELCATKR1    W6TKR1
     C                     MOVELCATKR2    W6TKR2
     C                     MOVELCATKR3    W6TKR3
     C                     MOVELCATKR4    W6TKR4
     C                     MOVELCAKNB#    W6KNB#
     C                     Z-ADD1         W6BOX
     C                     Z-ADD1         W6BOX3
     C           CAPLDT    IFNE 0
     C                     Z-ADD1         W6SUMI
     C                     ENDIF
     C                     Z-ADDWKSUM3    W6SUM3
     C                     WRITEAM#WP061
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB720    BEGSR
      *
     C                     Z-ADD0         WKSUM3  10
     C           K#65      KLIST
     C                     KFLD           K@DEST  5
     C                     KFLD           K@NUKE  4
     C                     KFLD           K@ORNO 12
     C                     KFLD           K@KANO  4
     C                     KFLD           K@BOXN  4
     C                     MOVELCANAMC    K@DEST  5
     C                     MOVELCADOCK    K@NUKE  4
     C                     MOVELCAORD#    K@ORNO 12
     C                     MOVELCAKNB#    K@KANO  4
     C                     MOVELCABOX#    K@BOXN  4
     C                     MOVEL'0'       GET65   1
     C           K#65      SETLLAB#PP65
     C           K#65      READEAB#PP65             N    90
     C           *IN90     DOWEQ'0'
     C           GET65     ANDEQ'0'
     C           A6SKJY    IFEQ *BLANK
     C                     MOVEL'1'       GET65
     C                     ENDIF
     C           K#65      READEAB#PP65             N    90
     C                     ENDDO
      *
     C           GET65     IFEQ '1'
     C                     ADD  1         WKSUM3  10
     C                     ENDIF
      *
     CSR         ESB720    ENDSR
