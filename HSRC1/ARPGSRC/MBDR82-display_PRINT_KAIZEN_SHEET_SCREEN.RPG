     H            Y/
     F** MBDR82 *****************************************
     F*  DISPLAY PRINT KAIZEN SHEET SCREEN              *
     F*  * CALL MBDR83 (CREATE WORK FILE )              *
     F*  J.WATANABE   2017.11.07                        *
     F*                                                 *
     F***************************************************
     FMBDPW82 CF  E                    WORKSTN
     FEDIPL43 IF  E           K        DISK
     FEDIPP43 IF  E           K        DISK
     FMBDPL15 IF  E           K        DISK
      *------------------------------------------------------------
      *
     E                    MSG     1   7 77
     E                    SLS        12  7 0
      *------------------------------------------------------------
     I            DS
     I                                        1  840SLS
     I                                        1   70F4TS01
     I                                        8  140F4TS02
     I                                       15  210F4TS03
     I                                       22  280F4TS04
     I                                       29  350F4TS05
     I                                       36  420F4TS06
     I                                       43  490F4TS07
     I                                       50  560F4TS08
     I                                       57  630F4TS09
     I                                       64  700F4TS10
     I                                       71  770F4TS11
     I                                       78  840F4TS12
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
      *  DISPLAY SCREEN
     C           *IN90     DOWEQ*OFF
     C                     EXFMTDSP01
     C                     MOVE *BLANK    XMSG
     C                     MOVE *OFF      *IN41
     C                     MOVE *OFF      *IN42
     C                     MOVE *OFF      *IN85
      * F1: END
     C           *INKA     IFEQ *ON
     C                     MOVE *ON       *IN90
     C                     ITER
     C                     ENDIF
      * F12: INQ
     C           *INKL     IFEQ *ON
     C                     CALL 'EDIR51'
     C                     PARM           XGRP
     C                     ITER
     C                     ENDIF
      * CHECK SCREEN DATA
     C                     EXSR #CHK1
      * F5: PRINT KANZEN SHEET
     C           *IN85     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     MOVELXDATE1    $DATE1
     C                     CALL 'MBDC83'
     C                     PARM           XGRP
     C                     PARM           $DATE1  6
     C                     PARM           $RTN2   1
     C           $RTN2     IFEQ *BLANK
     C  N85                MOVELMSG,7     XMSG
     C                     ELSE
     C  N85                MOVELMSG,6     XMSG
     C                     MOVE *ON       *IN85
     C                     MOVE *ON       *IN41
     C                     MOVE *ON       *IN42
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDDO
      *
     C           ENDP      TAG
     C                     SETON                     LR
     C                     RETRN
      *------------------------------------------------------
      *  #CHK1 CHAECK SCREEN DATA
      *-------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C           XGRP      IFEQ *BLANK
     C  N85                MOVELMSG,1     XMSG
     C                     MOVE *ON       *IN85
     C                     MOVE *ON       *IN41
     C                     ENDIF
      *
     C           XGRP      CHAINEDIPP43              99
     C           *IN99     IFEQ *ON
     C  N85                MOVELMSG,2     XMSG
     C                     MOVE *ON       *IN85
     C                     MOVE *ON       *IN41
     C                     ELSE
     C                     MOVELE3GPNM    XGNAM
     C                     ENDIF
      *
     C           XDATE1    IFEQ 0
     C  N85                MOVELMSG,3     XMSG
     C                     MOVE *ON       *IN85
     C                     MOVE *ON       *IN42
     C                     ENDIF
      *
     C                     MOVELXDATE1    XYY     40
     C                     MOVE XDATE1    XMM     20
     C           XYY       IFLT 2000
     C           XYY       ORGT 2100
     C  N85                MOVELMSG,4     XMSG
     C                     MOVE *ON       *IN85
     C                     MOVE *ON       *IN42
     C                     ENDIF
      *
     C           XMM       IFLT 01
     C           XMM       ORGT 12
     C  N85                MOVELMSG,4     XMSG
     C                     MOVE *ON       *IN85
     C                     MOVE *ON       *IN42
     C                     ENDIF
      * CHECK RECORD COUNT
     C                     EXSR #RCNT
     C           RCNT      IFEQ 0
     C  N85                MOVELMSG,6     XMSG
     C                     MOVE *ON       *IN85
     C                     MOVE *ON       *IN42
     C                     ENDIF
      *  IF NO ERROR...
     C           *IN85     IFEQ *OFF
     C                     MOVELMSG,5     XMSG
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK RECORD
      *------------------------------------------------------
     C           #RCNT     BEGSR
      *
     C                     Z-ADD0         RCNT
     C                     MOVELXDATE1    K#TNEN
     C                     MOVE XDATE1    MM      20
      * READ CUSTMER GROUP
     C           XGRP      SETLLEDIPL43
     C                     MOVE *OFF      *IN91
     C           *IN91     DOWEQ*OFF
     C           XGRP      READEEDIPL43                  91
     C           *IN91     IFEQ *OFF
      * READ SALES
     C                     MOVELE4NONY    K#NONY
     C                     MOVE *OFF      *IN92
     C           K#PL15    SETLLMBDPL15
     C           *IN92     DOWEQ*OFF
     C           K#PL15    READEMBDPL15                  92
     C           *IN92     IFEQ *OFF
     C           SLS,MM    ANDNE0
     C                     ADD  1         RCNT
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#PL15    KLIST
     C                     KFLD           K#NONY  40
     C                     KFLD           K#TNEN  40
      *
     C                     MOVE *BLANK    XGRP
     C                     MOVE *BLANK    XGNAM
     C                     Z-ADD0         XDATE1
     C                     Z-ADD0         RCNT    70
      *
     C                     ENDSR
      *------------------------------------------------------
** MSG,   1         2         3         4         5         6         7......>
MSG01: ENTER CUSTOMER GROUP CODE!
MSG02: CUSTOMER GROUP NOT FOUNF IN A GROUP MASTER!
MSG03: ENTER SHIP DATE!
MSG04: SHIP DATE IS INVALID!
MSG05: PRESS F5 TO PRINT, OR F1 TO EXIT...
MSG06: TARGET DATA NOT FOUND!
MSG07: DATA HAS BEEN CREATED IN J:DOWNLOAD/USER ID/KAIZEN LIST YYMMDD.CSV...
