     H            Y.
     F** MRARC2 *********************************************
     F* RECEIVE SEND BACK DATA FROM ASJ                     *
     F*     TRANCOM ITS.           2012.10.04               *
     F*******************************************************
     FMRAPLC1 UF  E           K        DISK
     FMRAPL02 UF  E           K        DISK
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WJFB
     I                                        1   40WJFF
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C                     TIME           WTIME
     C           KEYKR1    KLIST
     C                     KFLD           #KGTDT  80
     C                     KFLD           #KGTTI  60
     C                     Z-ADD0         #KGTDT
     C                     Z-ADD0         #KGTTI
     C           KEYKR1    SETLLMRAPLC11
     C           KEYKR1    READEMRAPLC11                 80
     C           *IN80     DOWEQ'0'
     C                     EXSR #SB500
     C                     Z-ADD*DATE     KRGTDT
     C                     TIME           KRGTTI
     C                     UPDATMRAPLC11
     C           KEYKR1    READEMRAPLC11                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C           KEYM11    KLIST
     C                     KFLD           KRKENO
     C                     KFLD           KRKENA
     C           KEYM11    CHAINMRAPL021             20
     C           *IN20     IFEQ '0'
     C                     Z-ADD*YEAR     M1KOYY
     C                     Z-ADDUMONTH    M1KOMM
     C                     Z-ADDUDAY      M1KODD
     C                     Z-ADDTIMHH     M1KOHH
     C                     Z-ADDTIMMM     M1KOSS
     C                     Z-ADDTIMSS     M1KOBB
     C                     MOVELW#PGM     M1KOPG
     C                     MOVELW#USER    M1KOME
     C                     MOVELKRRIYU    M1RIYU
     C                     UPDATMRAPL021
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
