      ** UTLR56 *************************************************
      *  CLEAR AB#PPCT (WEEKLY JOB)                             *
      *                                                         *
      ***********************************************************
      *  CALLING SEQ.                                           *
      *                    CALL 'UTLR56'                        *
      *                    PARM           $UPD    1
      *   IN  $UPD    1A "Y"= UPDATE FILE                       *
      ***********************************************************
     FAB#PPCT UF  E           K        DISK
      ***********************************************************
     E                    KEY     1  10  8
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *==================================================
     C           *ENTRY    PLIST
     C                     PARM           $UPD    1
      ****************************************************
      * MAIN ROUTINE
      ****************************************************
      *
     C           $UPD      IFNE 'Y'
     C                     GOTO ENDPGM
     C                     ENDIF
      *
     C           1         DO   10        IX      20
     C           KEY,IX    IFEQ 'X'
     C                     LEAVE
     C                     ENDIF
      *
     C           KEY,IX    CHAINAB#PPCT              99
     C           *IN99     IFEQ *OFF
     C           CTCHR1    ANDNE*BLANK
     C                     MOVE *BLANK    CTCHR1
     C                     UPDATAB#PPCT1
     C                     ENDIF
     C                     ENDDO
      *
     C           ENDPGM    TAG
     C                     MOVE *ON       *INLR
     C                     RETRN
      *
**   KEY
AB#RA1
AB#RSO
ECQR14
ECQR15
ECQR17
ECQR45
