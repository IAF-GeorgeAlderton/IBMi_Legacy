     F********************************** MFAR08 **
     FMFAPP21 IP  E                    DISK
     FMFAWP08 O   F     100            DISK
     IMFAPP211    01
     I            DS
     I                                        1   80M@SKHZ
     I                                        1   40M@SKYY
     I                                        5   60M@SKMM
     I                                        7   80M@SKDD
     C******************************************************
     C*  START PROGRAM  <MFAR08>                           *
     C******************************************************
     C  N01                GOTO @END
     C*
     C           *ENTRY    PLIST
     C                     PARM           PKJ     4
     C                     PARM           PKBN    1
     C                     PARM           PLST    1
     C                     MOVELPKJ       KOJO    40
     C*
     C           M@SKJY    IFEQ 'D'
     C           M@SKHZ    ANDLE*DATE
     C                     GOTO @END
     C                     END
     C*
B001 C           KOJO      IFNE 9999
     C           KOJO      CABNEM@KOJY    @END
E001 C                     END
     C*
B001 C           PKBN      IFNE '3'
     C           PKBN      CABNEM@SKBN    @END
E001 C                     END
     C*
     C                     SETON                     U1
     C                     EXCPTDT
     C           @END      TAG
     C*
     OMFAWP08 E                DT
     O                         M@BSYO     3
     O                         M@SYS1     7
     O                         M@SYS2    11
     O                         M@COS1    13
     O                         M@COS2    15
     O                         M@COS3    17
     O                         M@BUKA    18
     O                         M@KAKA    19
     O                         M@KOJY    23
