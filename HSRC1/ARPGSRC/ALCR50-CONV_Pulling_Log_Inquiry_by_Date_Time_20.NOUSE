     C                     END
     C           C2PAG#    IFNE *BLANK
     C                     MOVEL*ON       *IN46
     C                     END
     C           C2SMOD    IFNE *BLANK
     C                     MOVEL*ON       *IN47
     C                     END
     C                     SETON                     89
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,3     MSG
     C                     END
     C                     END
     C*
     C           RRN3      IFEQ 9999
     C           C2LOT#    IFNE *BLANK
     C                     MOVEL*ON       *IN45
     C                     END
     C           C2PAG#    IFNE *BLANK
     C                     MOVEL*ON       *IN46
     C                     END
     C           C2SMOD    IFNE *BLANK
     C                     MOVEL*ON       *IN47
     C                     END
     C                     SETON                     89
     C           MSG       IFEQ *BLANK
