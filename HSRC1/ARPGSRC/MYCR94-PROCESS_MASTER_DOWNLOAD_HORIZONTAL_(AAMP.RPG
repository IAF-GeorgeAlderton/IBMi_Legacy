     C*                    MOVELOKD,X     HKD,Y
     C*                    Z-ADDSSU,X     HSU,Y
     C*                    END
     C*                    ELSE
      *
     C           SKT,X     IFNE *BLANK
     C                     ADD  1         Y
     C                     ADD  1         Z
     C                     MOVEL'1'       *IN,Z
     C                     MOVELSKT,X     HKT,Y
     C                     Z-ADDSBM,X     HBM,Y
     C                     MOVELSKI,X     HKI,Y
     C                     MOVELSMB,X     HMB,Y
     C                     MOVELSDH,X     HDH,Y
     C                     MOVELSKD,X     HKD,Y
     C                     Z-ADDSSU,X     HSU,Y
     C                     END
     C                     END
     C*                    END
      *
     C                     MOVE *BLANK    WHIN3   1
     C           CKHIN3    IFNE *BLANK
     C                     MOVEL'-'       WHIN3
     C                     END
      *
     C                     EXCPTDT
     C                     END
     C                     END
