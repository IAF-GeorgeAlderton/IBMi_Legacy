      *
     C                     Z-ADD50        Z       20
     C                     MOVEL'00000000'*IN,51
     C                     MOVEL'0000000' *IN,59
      *
     C                     Z-ADD0         Y       20
     C           1         DO   15        X       20
     C*                    MOVELSUK,X     WUKH    80
     C*          WUKH      IFGT *DATE
     C*          OKT,X     IFNE *BLANK
