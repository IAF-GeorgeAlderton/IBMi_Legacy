      ******************************************************
     FANFPW06 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL020
     F                                              KINFDS @INFDS
     FABRAP01 UF  E           K        DISK                      A
      *---------------------------------------------------
     E                    ERR     1  10 78
     E                    APL         4  1
     E                    ADK         4  1
     E                    APT        12  1
     E                    BPL         4  1
     E                    BDK         4  1
     E                    BPT        12  1
      *---------------------------------------------------
     I@INFDS      DS
     I                                     *STATUS  @STTS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME(6) + DATE(6)
     I            DS
     I                                        1  140WWTIME
     I                                        1   60WTIME
     I                                        1   40WTIM4
     I                                        1   20WTIMHH
     I                                        3   40WTIMMM
     I                                        7  120WSDATE
     I                                        9  120@@YM4
     I                                        7  120@@YM6
     I                                        7  140@@YMD
     I                                        7  100@@YY
     I                                       11  120@@MM
     I                                       13  140@@DD
     C******************************************************
     C*  MAIN
     C******************************************************
     C*
     C                     EXSR @INT
     C*
     C                     DO   *HIVAL
     C*
     C                     EXSR @F1RTN
     C   KA                LEAVE
     C*
     C                     EXSR @F2RTN
     C   KA                LEAVE
     C   KL                ITER
     C*
     C                     ENDDO
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C*
     C******************************************************
     C*  INITTIAL SET
     C******************************************************
     C           @INT      BEGSR
     C*
     C                     TIME           WWTIME
     C*
     C                     MOVEL*BLANK    F1DOCK
     C                     MOVEL*BLANK    F1DOC2
     C                     MOVEL*BLANK    F1PART
     C                     MOVEL*BLANK    F1STS
     C           *LIKE     DEFN F1DOCK    WWDOCK
     C                     MOVEL*BLANK    WWDOCK
     C           *LIKE     DEFN F1DOC2    WWDOC2
     C                     MOVEL*BLANK    WWDOC2
     C           *LIKE     DEFN F1PART    WWPART
     C                     MOVEL*BLANK    WWPART
     C           *LIKE     DEFN F1STS     WWSTS
     C                     MOVEL*BLANK    WWSTS
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
     C*
     C                     ENDSR
     C******************************************************
     C*  FMT010
     C******************************************************
     C           @F1RTN    BEGSR
     C*
     C                     DO
     C*
     C                     EXFMTFMT010
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
     C*
     C                     END
     C*
     C                     ENDSR
     C******************************************************
     C*  FMT020
     C******************************************************
     C           @F2RTN    BEGSR
     C*
     C                     MOVEL*BLANK    MSG
     C                     EXSR @F2SET
     C                     Z-ADD1         W#RNP1  40
     C*
     C                     DO   *HIVAL
     C*
     C                     WRITEFMT029
     C                     Z-ADDW#RNP1    #RCN01
     C                     EXFMTCTL020
     C   KA
     COR KL                LEAVE
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP1
     C                     END
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
     C                     MOVEL*OFF      W#ERR   1
     C                     MOVEL*BLANK    W@ACT   3
     C                     EXSR @F2CHK
     C           W#ERR     IFEQ *ON
     C                     ITER
     C                     END
     C*
     C           W@ACT     IFEQ 'CHG'
     C                     EXSR @F2CHG
     C   KA                LEAVE
     C   KL                ITER
     C                     EXSR @F2SET
     C                     ITER
     C                     END
     C*
     C           *INKE     IFEQ *ON
     C                     EXSR @UPD
     C                     EXSR @F2SET
     C                     ITER
     C                     END
     C*
     C           *INKH     IFEQ *ON
     C                     MOVEL'NEW'     W@ACT   3
     C                     EXSR @F3RTN
     C   KA                LEAVE
     C   KL                ITER
     C                     EXSR @F2SET
     C           *INKE     IFEQ *ON
     C                     Z-ADD1         W#RNP1
     C                     END
     C                     ITER
     C                     END
     C*
     C           F1DOCK    IFNE WWDOCK
     C           F1DOC2    ORNE WWDOC2
     C           F1PART    ORNE WWPART
     C           F1STS     ORNE WWSTS
     C                     EXSR @F2SET
     C                     Z-ADD1         W#RNP1
     C                     MOVELF1DOCK    WWDOCK
     C                     MOVELF1DOC2    WWDOC2
     C                     MOVELF1PART    WWPART
     C                     MOVELF1STS     WWSTS
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  SFL020 SET
     C******************************************************
     C           @F2SET    BEGSR
     C*
     C                     MOVEL*ON       *IN41
     C                     WRITECTL020
     C                     MOVEL*OFF      *IN41
     C                     MOVEL*OFF      *IN42
     C* PLANT
     C           F1DOCK    IFNE *BLANK
     C                     Z-ADD*ZERO     I       20
     C                     MOVEAF1DOCK    APL
     C                     DO   *HIVAL
     C                     ADD  1         I
     C           I         IFGT 4
     C                     Z-ADD4         I
     C                     LEAVE
     C                     END
     C           APL,I     IFEQ *BLANK
     C                     SUB  1         I
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     END
     C* DOCK
     C           F1DOC2    IFNE *BLANK
     C                     Z-ADD*ZERO     J       20
     C                     MOVEAF1DOC2    ADK
     C                     DO   *HIVAL
     C                     ADD  1         J
     C           J         IFGT 4
     C                     Z-ADD4         J
     C                     LEAVE
     C                     END
     C           ADK,J     IFEQ *BLANK
     C                     SUB  1         J
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     END
     C* PART
     C           F1PART    IFNE *BLANK
     C                     Z-ADD*ZERO     K       20
     C                     MOVEAF1PART    APT
     C                     DO   *HIVAL
     C                     ADD  1         K
     C           K         IFGT 12
     C                     Z-ADD12        K
     C                     LEAVE
     C                     END
     C           APT,K     IFEQ *BLANK
     C                     SUB  1         K
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     END
     C*
     C                     Z-ADD*ZERO     RRN1    40
     C           *LOVAL    SETLLABRAP01
     C*
     C                     DO   *HIVAL
     C*
     C                     READ ABRAP01             N    91
     C   91                LEAVE
     C* PLANT
     C           F1DOCK    IFNE *BLANK
     C                     MOVEACFDOCK    APL
     C                     MOVEL*BLANK    BPL
     C                     Z-ADD*ZERO     II      20
     C                     DO   *HIVAL
     C                     ADD  1         II
     C           II        IFGT I
     C                     LEAVE
     C                     END
     C                     MOVELAPL,II    BPL,II
     C                     ENDDO
     C                     MOVEABPL       W@DOCK  4 P
     C           F1DOCK    IFNE W@DOCK
     C                     ITER
     C                     END
     C                     END
     C* DOCK
     C           F1DOC2    IFNE *BLANK
     C                     MOVEACFDOC2    ADK
     C                     MOVEL*BLANK    BDK
     C                     Z-ADD*ZERO     JJ      20
     C                     DO   *HIVAL
     C                     ADD  1         JJ
     C           JJ        IFGT J
     C                     LEAVE
     C                     END
     C                     MOVELADK,JJ    BDK,JJ
     C                     ENDDO
     C                     MOVEABDK       W@DOC2  4 P
     C           F1DOC2    IFNE W@DOC2
     C                     ITER
     C                     END
     C                     END
     C* PART
     C           F1PART    IFNE *BLANK
     C                     MOVEACFPART    APT
     C                     MOVEL*BLANK    BPT
     C                     Z-ADD*ZERO     KK      20
     C                     DO   *HIVAL
     C                     ADD  1         KK
     C           KK        IFGT K
     C                     LEAVE
     C                     END
     C                     MOVELAPT,KK    BPT,KK
     C                     ENDDO
     C                     MOVEABPT       W@PART 12 P
     C           F1PART    IFNE W@PART
     C                     ITER
     C                     END
     C                     END
     C* DATA STATUS
     C           F1STS     IFEQ 'D'
     C           CFDLCD    IFNE 'D'
     C                     ITER
     C                     END
     C                     END
     C           F1STS     IFEQ *BLANK
     C           CFDLCD    IFNE *BLANK
     C                     ITER
     C                     END
     C                     END
     C* CREATE SUB-FILE
     C                     CLEARSFL020
     C*
     C                     MOVELCFDLCD    S2DELF
     C                     MOVELCFDLCD    H2DELF
     C                     MOVELCFDOCK    S2DOCK
     C                     MOVELCFDOC2    S2DOC2
     C                     MOVELCFPART    S2PART
     C                     Z-ADDCFSIDT    S2SIDT
     C                     Z-ADDCFHSDT    S2HSDT
     C           CFCDAT    IFNE *ZERO
     C           20000000  ADD  CFCDAT    S2CDAT
     C                     END
     C                     Z-ADDCFCAMT    S2CAMT
     C                     Z-ADDCFCAMT    H2CAMT
     C                     Z-ADDCFCAMN    S2CAMN
     C                     Z-ADDCFCAMN    H2CAMN
     C           CFDLCD    IFNE *BLANK
     C                     MOVEL'Deleted' S2DSTS
     C                     MOVEL*ON       *IN32
     C                     ELSE
     C                     MOVEL*OFF      *IN32
     C                     END
     C                     MOVELCFPOR#    S2POR#
     C                     MOVELCFREF#    S2REF#
     C*
     C                     ADD  1         RRN1
     C                     WRITESFL020
     C*
     C                     ENDDO
     C*
     C           RRN1      IFEQ *ZERO
     C                     CLEARSFL020
     C                     MOVEL*ON       *IN31
     C                     MOVEL*ON       H2IN31
     C                     Z-ADD1         RRN1
     C                     WRITESFL020
     C                     MOVEL*OFF      *IN31
     C                     MOVELERR,1     MSG
     C                     MOVEL*ON       *IN49
     C                     END
     C*
     C                     ENDSR
     C******************************************************
     C*  SFL020 CHECK
     C******************************************************
     C           @F2CHK    BEGSR
     C*
     C                     Z-ADD*ZERO     RRN1
     C                     DO   *HIVAL
     C*
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL020               92
     C   92                LEAVE
     C*
     C                     SETOF                     3233
     C*
     C           S2DELF    IFNE ' '
     C           S2DELF    ANDNE'C'
     C           S2DELF    ANDNE'D'
     C                     MOVEL*ON       W#ERR
     C                     MOVELERR,2     MSG
     C                     MOVEL*ON       *IN49
     C                     MOVEL*ON       *IN33
     C                     END
     C*
     C           H2IN31    IFNE *BLANK
     C                     MOVEL*ON       *IN31
     C                     END
     C*
     C           S2DELF    IFEQ 'D'
     C                     MOVEL*ON       *IN32
     C                     END
     C*
     C           S2DELF    IFEQ 'C'
     C                     MOVEL'CHG'     W@ACT
     C                     END
     C*
     C                     UPDATSFL020
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  SFL020 CHANGE
     C******************************************************
     C           @F2CHG    BEGSR
     C*
     C                     Z-ADD*ZERO     RRN1
     C                     DO   *HIVAL
     C*
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL020               92
     C   92                LEAVE
     C*
     C           S2DELF    IFEQ 'C'
     C                     EXSR @F3RTN
     C   KA                LEAVE
     C   KL                MOVELH2DELF    S2DELF
     C           H2IN31    IFNE *BLANK
     C                     MOVEL*ON       *IN31
     C                     END
     C           S2DELF    IFNE *BLANK
     C                     MOVEL'Deleted' S2DSTS
     C                     MOVEL*ON       *IN32
     C                     ELSE
     C                     MOVEL*OFF      *IN32
     C                     MOVEL*BLANK    S2DSTS
     C                     END
     C*
     C                     UPDATSFL020
     C   KL                ITER
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  UPDATE FILE
     C******************************************************
     C           @UPD      BEGSR
     C*
     C                     Z-ADD*ZERO     RRN1
     C                     DO   *HIVAL
     C*
     C                     ADD  1         RRN1
     C           RRN1      CHAINSFL020               92
     C   92                LEAVE
     C*
     C           S2DELF    IFEQ H2DELF
     C           S2CAMT    ANDEQH2CAMT
     C           S2CAMN    ANDEQH2CAMN
     C                     ITER
     C                     END
     C*
     C           K#AP#1    KLIST
     C                     KFLD           S2DOCK
     C                     KFLD           S2DOC2
     C                     KFLD           S2PART
     C           K#AP#1    CHAINABRAP01R             93
     C           *IN93     IFEQ *OFF
     C                     MOVELS2DELF    CFDLCD
     C           S2DELF    IFNE H2DELF
     C           S2DELF    IFEQ 'D'
     C                     Z-ADD@@YY      CFDLDY
     C                     Z-ADD@@MM      CFDLDM
     C                     Z-ADD@@DD      CFDLDD
     C                     ELSE
     C                     Z-ADD*ZERO     CFDLDY
     C                     Z-ADD*ZERO     CFDLDM
     C                     Z-ADD*ZERO     CFDLDD
     C                     END
     C                     END
     C                     Z-ADDS2CAMT    CFCAMT
     C                     Z-ADDS2CAMN    CFCAMN
     C                     Z-ADD@@YY      CFUPDY
     C                     Z-ADD@@MM      CFUPDM
     C                     Z-ADD@@DD      CFUPDD
     C                     Z-ADDWTIMHH    CFUPTH
     C                     Z-ADDWTIMMM    CFUPTM
     C                     UPDATABRAP01R
     C                     END
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  FMT030
     C******************************************************
     C           @F3RTN    BEGSR
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
     C                     EXSR @F3SET
     C*
     C                     DO   *HIVAL
     C*
     C                     EXFMTFMT030
     C   KA
     COR KL                LEAVE
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
     C                     MOVEL*OFF      W#ERR
     C                     EXSR @F3CHK
     C           W#ERR     IFEQ *ON
     C                     ITER
     C                     END
     C*
     C           *INKE     IFEQ *ON
     C                     EXSR @F3UPD
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
     C*
     C                     ENDSR
     C******************************************************
     C*  FMT030 SET
     C******************************************************
     C           @F3SET    BEGSR
     C*
     C           W@ACT     IFEQ 'CHG'
     C                     MOVEL*ON       *IN51
     C                     ELSE
     C                     MOVEL*OFF      *IN51
     C                     END
     C                     SETOF                     525354
     C                     SETOF                     55
     C*
     C                     SELEC
     C*
     C           W@ACT     WHEQ 'CHG'
     C                     MOVEL'  CHANGE'F3TITL    P
     C                     MOVELH2DELF    F3DELF
     C                     MOVELS2DOCK    F3DOCK
     C                     MOVELS2DOC2    F3DOC2
     C                     MOVELS2PART    F3PART
     C                     Z-ADDS2SIDT    F3SIDT
     C                     Z-ADDS2HSDT    F3HSDT
     C                     Z-ADDS2CDAT    F3CDAT
     C                     Z-ADDS2CAMT    F3CAMT
     C                     Z-ADDS2CAMN    F3CAMN
     C                     MOVELS2POR#    F3POR#
     C                     MOVELS2REF#    F3REF#
     C                     OTHER
     C                     MOVEL'   ADD  'F3TITL    P
     C                     MOVEL*BLANK    F3DELF
     C                     MOVEL*BLANK    F3DOCK
     C                     MOVEL*BLANK    F3DOC2
     C                     MOVEL*BLANK    F3PART
     C                     Z-ADD*ZERO     F3SIDT
     C                     Z-ADD*ZERO     F3HSDT
     C                     Z-ADD*ZERO     F3CDAT
     C                     Z-ADD*ZERO     F3CAMT
     C                     Z-ADD*ZERO     F3CAMN
     C                     MOVEL*BLANK    F3POR#
     C                     MOVEL*BLANK    F3REF#
     C                     ENDSL
     C*
     C                     ENDSR
     C******************************************************
     C*  FMT030 CHECK
     C******************************************************
     C           @F3CHK    BEGSR
     C*
     C                     DO
     C*
     C                     SETOF                     525354
     C                     SETOF                     55
     C*
     C           F3DOCK    IFEQ *BLANK
     C                     SETON                     52
     C  N49                MOVEL*ON       W#ERR
     C  N49                MOVELERR,6     MSG
     C  N49                MOVEL*ON       *IN49
     C                     END
     C           F3DOC2    IFEQ *BLANK
     C                     SETON                     53
     C  N49                MOVEL*ON       W#ERR
     C  N49                MOVELERR,7     MSG
     C  N49                MOVEL*ON       *IN49
     C                     END
     C           F3PART    IFEQ *BLANK
     C                     SETON                     54
     C  N49                MOVEL*ON       W#ERR
     C  N49                MOVELERR,8     MSG
     C  N49                MOVEL*ON       *IN49
     C                     END
     C           F3DELF    IFNE *BLANK
     C           F3DELF    ANDNE'D'
     C                     SETON                     55
     C  N49                MOVEL*ON       W#ERR
     C  N49                MOVELERR,5     MSG
     C  N49                MOVEL*ON       *IN49
     C                     END
     C*
     C   49                LEAVE
     C*
     C           K#AP#2    KLIST
     C                     KFLD           F3DOCK
     C                     KFLD           F3DOC2
     C                     KFLD           F3PART
     C           K#AP#2    CHAINABRAP01R            N93
     C*
     C                     SELEC
     C*
     C           W@ACT     WHEQ 'CHG'
     C           *IN93     IFEQ *ON
     C                     SETON                     525354
     C  N49                MOVEL*ON       W#ERR
     C  N49                MOVELERR,3     MSG
     C  N49                MOVEL*ON       *IN49
     C                     END
     C                     OTHER
     C           *IN93     IFEQ *OFF
     C           CFDLCD    ANDEQ*BLANK
     C                     SETON                     525354
     C  N49                MOVEL*ON       W#ERR
     C  N49                MOVELERR,4     MSG
     C  N49                MOVEL*ON       *IN49
     C                     END
     C*
     C                     ENDSL
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C******************************************************
     C*  FMT030 UPDATE
     C******************************************************
     C           @F3UPD    BEGSR
     C*
     C           K#AP#2    CHAINABRAP01R             93
     C*
     C                     SELEC
     C*
     C           W@ACT     WHEQ 'CHG'
     C           *IN93     IFEQ *OFF
     C           F3DELF    IFEQ *BLANK
     C           CFDLCD    IFEQ 'D'
     C                     MOVEL*BLANK    CFDLCD
     C                     MOVEL*BLANK    S2DELF
     C                     MOVEL*BLANK    H2DELF
     C                     Z-ADD*ZERO     CFDLDY
     C                     Z-ADD*ZERO     CFDLDM
     C                     Z-ADD*ZERO     CFDLDD
     C                     END
     C                     ELSE
     C           CFDLCD    IFEQ *BLANK
     C                     MOVEL'D'       CFDLCD
     C                     MOVEL'D'       S2DELF
     C                     MOVEL'D'       H2DELF
     C                     Z-ADD@@YY      CFDLDY
     C                     Z-ADD@@MM      CFDLDM
     C                     Z-ADD@@DD      CFDLDD
     C                     END
     C                     END
     C                     Z-ADDF3SIDT    CFSIDT
     C                     Z-ADDF3HSDT    CFHSDT
     C                     Z-ADDF3CDAT    CFCDAT
     C                     Z-ADDF3CAMT    CFCAMT
     C                     Z-ADDF3CAMN    CFCAMN
     C                     MOVELF3POR#    CFPOR#
     C                     MOVELF3REF#    CFREF#
     C                     UPDATABRAP01R
     C                     END
     C                     OTHER
     C                     CLEARABRAP01R
     C           F3DELF    IFNE *BLANK
     C                     MOVEL'D'       CFDLCD
     C                     Z-ADD@@YY      CFDLDY
     C                     Z-ADD@@MM      CFDLDM
     C                     Z-ADD@@DD      CFDLDD
     C                     END
     C                     MOVELF3DOCK    CFDOCK
     C                     MOVELF3DOC2    CFDOC2
     C                     MOVELF3PART    CFPART
     C                     Z-ADDF3SIDT    CFSIDT
     C                     Z-ADDF3HSDT    CFHSDT
     C                     Z-ADDF3CDAT    CFCDAT
     C                     Z-ADDF3CAMT    CFCAMT
     C                     Z-ADDF3CAMN    CFCAMN
     C                     MOVELF3POR#    CFPOR#
     C                     MOVELF3REF#    CFREF#
     C  N93                UPDATABRAP01R
     C   93                WRITEABRAP01R
     C                     ENDSL
     C*
     C                     ENDSR
