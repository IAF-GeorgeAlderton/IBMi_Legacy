     I                                        1   40L7STYY
     I                                        5   60L7STMM
     I                                        7   80L7STDD
     C           *ENTRY    PLIST
     C                     PARM           PDATE   8
     C           *IN20     IFEQ '0'
     C                     SETON                     20
     C                     MOVE PDATE     DATE    80
     C                     EXCPTHD
     C                     END
     C*
     C                     SETOF                     99
     C*
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLEDATE
     C                     GOTO END
     C                     END
     C*
     C                     MOVE *BLANK    WWZETI  4
     C                     MOVE *BLANK    WWTKR1  1
     C                     MOVE *BLANK    WWTKR2  2
     C                     MOVE *BLANK    WWTKR3  2
     C                     MOVE *BLANK    WWTKR4  1
     C                     MOVE *BLANK    WWSEIH  1
     C                     Z-ADD0         WWSYOS  70
     C*<KANBAN TYPE>
     C           KEY02     KLIST
     C                     KFLD           KHIN1
     C                     KFLD           KHIN2
     C                     KFLD           KHIN3
     C                     MOVELA2BHB1    KHIN1   5
     C                     MOVELA2BHB2    KHIN2   5
     C                     MOVELA2BHB3    KHIN3   2
     C                     SETOF                     54
     C           KEY02     SETGTAAPTL011
     C                     DO   *HIVAL
     C           ##1       TAG
     C           KEY02     REDPEAAPTL011                 54
     C           *IN54     IFEQ '0'
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    IFLE DATE
     C                     GOTO ##1
     C                     END
     C                     END
     C*
     C           L5UKHZ    IFGT DATE
     C                     GOTO ##1
     C                     END
     C*
     C           L5STHZ    IFLT DATE
     C                     GOTO ##1
     C                     END
     C*
     C           L5STHZ    IFNE 99999999
     C                     GOTO ##1
     C                     END
     C*
     C                     MOVE '0'       WWSEIH
     C                     Z-ADDL5SYOS    WWSYOS
     C                     MOVE L5ZETI    WWZETI
     C                     MOVE L5TKR1    WWTKR1
     C                     MOVE L5TKR2    WWTKR2
     C                     MOVE L5TKR3    WWTKR3
     C                     MOVE L5TKR4    WWTKR4
     C                     GOTO ETYPE
     C                     END
     C  N54                ENDDO
      *
      *
     C                     SETOF                     54
     C           KEY02     SETLLAKBPL041                 54
     C                     DO   *HIVAL
     C           ##2       TAG
     C           KEY02     READEAKBPL041                 54
     C           *IN54     IFEQ '0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    IFLE DATE
     C                     GOTO ##2
     C                     END
     C                     END
     C           L1UKHZ    IFGT DATE
     C                     GOTO ##2
     C                     END
     C           L1STHZ    IFLT DATE
     C                     GOTO ##2
     C                     END
     C                     MOVE '3'       WWSEIH
     C                     MOVE L1ZETI    WWZETI
     C                     Z-ADDL1SYOS    WWSYOS
     C                     MOVE L1TKR1    WWTKR1
     C                     MOVE L1TKR2    WWTKR2
     C                     MOVE L1TKR3    WWTKR3
     C                     MOVE L1TKR4    WWTKR4
     C                     GOTO ETYPE
     C                     END
     C  N54                ENDDO
      *
      *
     C                     SETOF                     54
     C           KEY02     SETLLAANPL061                 54
     C                     DO   *HIVAL
     C           ##3       TAG
     C           KEY02     READEAANPL061                 54
     C           *IN54     IFEQ '0'
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    IFLE DATE
     C                     GOTO ##3
     C                     END
     C                     END
     C           L7UKHZ    IFGT DATE
     C                     GOTO ##3
     C                     END
     C           L7STHZ    IFLT DATE
     C                     GOTO ##3
     C                     END
     C                     MOVE '6'       WWSEIH
     C                     MOVE L7ZETI    WWZETI
     C                     Z-ADDL7SYOS    WWSYOS
     C                     MOVE L7TKR1    WWTKR1
     C                     MOVE L7TKR2    WWTKR2
     C                     MOVE L7TKR3    WWTKR3
     C                     MOVE L7TKR4    WWTKR4
     C                     GOTO ETYPE
     C                     END
     C  N54                ENDDO
     C*
     C           ETYPE     TAG
     C* BUHIN MASTER TO CHECK
     C* SYUYOU SUU
     C           A2SYHZ    IFGT DATE
     C                     Z-ADDA2KSYS    XXSYOS  70
     C                     ELSE
     C                     Z-ADDA2SSYS    XXSYOS
     C                     END
     C*
     C           WWSYOS    IFNE 0
     C           XXSYOS    IFNE 0
     C           XXSYOS    IFNE WWSYOS
     C                     SETON                     9990
     C                     END
     C                     END
     C                     END
     C* BANTI
     C           A2TRHZ    IFGT DATE
     C                     MOVE A2KTRK    XXTKR1  1
     C                     MOVE A2KTRT    XXTKR2  2
     C                     MOVE A2KTRR    XXTKR3  2
     C                     MOVE A2KTRD    XXTKR4  1
     C                     ELSE
     C                     MOVE A2STRK    XXTKR1
     C                     MOVE A2STRT    XXTKR2
     C                     MOVE A2STRR    XXTKR3
     C                     MOVE A2STRD    XXTKR4
     C                     END
     C*
     C           WWTKR1    IFNE *BLANK
     C           XXTKR1    IFEQ WWTKR1
     C           XXTKR2    ANDEQWWTKR2
     C           XXTKR3    ANDEQWWTKR3
     C           XXTKR4    ANDEQWWTKR4
     C                     ELSE
     C                     SETON                     9991
     C                     END
     C                     END
     C* ZETI
     C           A2ZETI    IFNE WWZETI
     C*************        SETON                     9992
     C                     END
     C* PRINT
     C           *IN99     IFEQ '1'
     C                     EXCPTME
     C           *INOF     IFEQ '1'
     C                     SETOF                     OF
     C                     EXCPTHD
     C                     END
     C                     END
     C* END
     C           END       TAG
     OQPRINT  E  1             HD
     O                                   10 'ZETI KA'
     O                                   20 'ZETI BU'
     O                                   30 'SYOU KA'
     O                                   40 'SYOU BU'
     O                                   50 'BANT KA'
     O                                   60 'BANT BU'
     O                                   70 'SEIKUB'
