     C           #KHMM     OREQ 06
     C           #KHMM     OREQ 09
     C           #KHMM     OREQ 11
     C           #KHDD     IFGT 30
     C                     SETON                     21
     C                     GOTO $S901E
     C                     END
     C                     END
      *
     C                     Z-ADD0         WHD
     C                     Z-ADD0         URU
     C                     Z-ADD0         AMA
     C                     Z-ADD0         URU1
     C                     Z-ADD0         AMA1
     C                     Z-ADD0         URU2
     C                     Z-ADD0         AMA2
     C           #KHMM     IFEQ 02
     C                     Z-ADD28        WHD
     C           #KHYY     DIV  4         URU     40
     C                     MVR            AMA     40
     C           AMA       IFEQ 0
     C                     Z-ADD29        WHD
     C           #KHYY     DIV  100       URU1    40
     C                     MVR            AMA1    40
     C           #KHYY     DIV  400       URU2    40
     C                     MVR            AMA2    40
      *
     C           AMA1      IFEQ 0
     C           AMA2      ANDNE0
     C                     Z-ADD28        WHD
     C                     END
      *
     C                     END
     C           #KHDD     IFGT WHD
     C                     SETON                       21
     C                     GOTO $S901E
     C                     END
      *
     C                     END
     CSR         $S901E    ENDSR
      *----------------------------------------------------*
      *  DATE CALCULATION                                  *
      *----------------------------------------------------*
     CSR         $SB910    BEGSR
     C                     Z-ADD#KHYY     WHY     40
     C                     Z-ADD#KHMM     WHM     20
TCHK1C*                    Z-ADD#KHYY     WHD     20
TCHK1C                     Z-ADD#KHDD     WHD     20
     C           #KHDD     SUB  1         WHD
      *
     C           WHD       IFEQ 0
     C           #KHMM     SUB  1         WHM
     C                     END
      *
     C           WHM       IFEQ 0
     C           #KHYY     SUB  1         WHY
     C                     END
      *
     C           WHM       IFEQ 0
     C                     Z-ADD12        WHM
     C                     END
      *
     C           WHD       IFEQ 0
      *
     C           WHM       IFEQ 01
     C           WHM       OREQ 03
     C           WHM       OREQ 05
     C           WHM       OREQ 07
     C           WHM       OREQ 08
     C           WHM       OREQ 10
     C           WHM       OREQ 12
     C                     Z-ADD31        WHD
     C                     END
      *
     C           WHM       IFEQ 04
     C           WHM       OREQ 06
     C           WHM       OREQ 09
     C           WHM       OREQ 11
     C                     Z-ADD30        WHD
     C                     END
      *
     C           WHM       IFEQ 02
     C                     Z-ADD28        WHD
     C           WHY       DIV  4         URU     40
     C                     MVR            AMA     40
     C           AMA       IFEQ 0
     C                     Z-ADD29        WHD
     C           WHY       DIV  100       URU1    40
     C                     MVR            AMA1    40
     C           WHY       DIV  400       URU2    40
     C                     MVR            AMA2    40
      *
     C           AMA1      IFEQ 0
     C           AMA2      ANDNE0
     C                     Z-ADD28        WHD
     C                     END
      *
     C                     END
     C                     END
      *
     C                     END
      *
     CSR         $S910E    ENDSR
      *----------------------------------------------------*
      *  UNIT PRICE UPDATE IN AB#PP01,AB#PP10              *
      *----------------------------------------------------*
     C           $SB600    BEGSR
      * AB#PP01
     C           K#APP     SETLLAB#PL09
     C           *IN90     DOUEQ*ON
     C           K#APX     READEAB#PL09                  90
     C           *IN90     IFEQ *OFF
