     C                     MOVELA3ATOK    WKATOK
     C                     Z-ADD1         WKLOT
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYTKR    READEAAFPL031                 45
     C                     ENDDO
     CSR         EAAF1     ENDSR
