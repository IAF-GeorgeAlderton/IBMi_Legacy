      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
      *
     C                     READ ABMWPF01                 80
     C           *IN80     DOWEQ'0'
     C           W0SEHI    IFEQ 'S'
     C                     EXSR #SB200
     C                     ENDIF
     C                     READ ABMWPF01                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           KEY       KLIST
     C                     KFLD           W0SHN1
     C                     KFLD           W0SHN2
     C                     KFLD           W0SHN3
     C                     CLEARSKOT
     C                     CLEARSBMN
     C                     CLEARSKBN
     C                     CLEARSTKR
     C                     CLEARSSHR
     C                     CLEARSHBN
     C           KEY       CHAINAAMPL111             23
     C           *IN23     IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     23
     C                     ENDIF
     C           *IN23     IFEQ '0'
     C                     Z-ADD1         X       30
     C           X         DOWLE15
     C                     MOVEANKOT,X    SKOT,X
     C                     MOVEANBMN,X    SBMN,X
     C                     MOVEANKBN,X    SKBN,X
     C                     MOVEANTKR,X    STKR,X
     C                     MOVEANSHR,X    SSHR,X
     C                     MOVEANHBN,X    SHBN,X
     C                     MOVELKHZ,X     WDATE   80
     C           WDATE     IFGT *DATE
     C                     MOVEAOKOT,X    SKOT,X
     C                     MOVEAOBMN,X    SBMN,X
     C                     MOVEAOKBN,X    SKBN,X
     C                     MOVEAOTKR,X    STKR,X
     C                     MOVEAOSHR,X    SSHR,X
     C                     MOVEAOHBN,X    SHBN,X
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
     C                     ENDIF
      *
     C                     Z-ADD0         IDX1    30
     C                     Z-ADD15        X       30
     C                     MOVEL'0'       GET     1
     C           X         DOWGE1
     C                     MOVELSTKR,X    WKTKR
     C                     MOVEL'1'       DT      1
     C**         WKTKR1    IFEQ '0'
     C**                   MOVEL'0'       DT
     C**                   ENDIF
     C           SKOT,X    IFEQ 'KN '
     C           SBMN,X    ANDEQ8990
     C                     MOVEL'0'       DT
     C                     ENDIF
     C           SSHR,X    IFEQ 'Z'
     C           SSHR,X    OREQ '0'
     C           SSHR,X    OREQ '6'
     C                     MOVEL'0'       DT
     C                     ENDIF
      *
     C           STKR,X    IFNE *BLANK
     C           DT        ANDEQ'1'
     C                     EXSR #SB211
     C                     ENDIF
     C                     SUB  1         X
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * UPDATE                                             *
      *----------------------------------------------------*
     CSR         #SB211    BEGSR
      *
     C                     MOVEL*BLANK    WKATOK  3
     C                     Z-ADD0         WKKMAX  50
     C                     Z-ADD0         WKLOT   30
     C                     CLEARABMWPF11
     C                     MOVELW0SHN1    W1SHN1
     C                     MOVELW0SHN2    W1SHN2
     C                     MOVELW0SHN3    W1SHN3
     C                     MOVELW0SEHI    W1SEHI
     C                     Z-ADDW0SSYS    W1SSYS
     C                     MOVELSBMN,X    W1BM
     C                     MOVELSKOT,X    W1KO
     C                     MOVELSTKR,X    W1NB
     C                     MOVELSKBN,X    W1KB
     C                     MOVEL*BLANK    WIRO1   1
     C                     MOVEL*BLANK    WIRO2   1
     C                     MOVEL*BLANK    WIRO3   1
     C                     MOVEL*BLANK    WIRO4   1
     C           W1NB      IFNE '------'
     C           W1NB      ANDNE'++++++'
     C                     MOVEL*BLANK    WKATOK  3
     C                     Z-ADD0         WKKMAX  50
     C                     MOVELSSHR,X    WKKCD1  1
     C                     Z-ADD0         WKLOT   30
     C                     EXSR #SB400
     C                     ENDIF
     C                     MOVELSKOT,X    W1ATOK
     C                     Z-ADDWKKMAX    W1KMAX
     C                     Z-ADDWKLOT     W1LOT
     C                     MOVELSSHR,X    W1TY
     C                     Z-ADDSU,X      W1SU
     C                     Z-ADDX         W1KSEQ
      *前工程
     C           X         SUB  1         M       20
     C                     Z-ADDM         W1KSE1
     C           M         IFGE 1
     C                     MOVELSKOT,M    W1KOM1
     C                     MOVELSBMN,M    W1BMM1
     C                     ENDIF
      *次工程
     C           X         ADD  1         M       20
     C           M         IFLE 15
     C                     MOVELSKOT,M    W1KOA1
     C                     MOVELSKBN,M    W1AKKB
     C                     MOVELSBMN,M    W1BMA1
     C                     ENDIF
      *次々工程
     C           X         ADD  2         M       20
     C           M         IFLE 15
     C                     MOVELSKOT,M    W1KOA2
     C                     MOVELSBMN,M    W1BMA2
     C                     ENDIF
      *
     C           WKKCD1    IFEQ 'A'
     C           WKKCD1    OREQ 'B'
     C           WKKCD1    OREQ 'C'
     C           WKKCD1    OREQ 'E'
      *
     C           WIRO1     IFNE *BLANK
     C                     MOVELWIRO1     W1BCCD
     C                     EXSR #CHG
     C                     WRITEABMWPF11
     C                     ENDIF
     C           WIRO2     IFNE *BLANK
     C                     MOVELWIRO2     W1BCCD
     C                     EXSR #CHG
     C                     WRITEABMWPF11
     C                     ENDIF
     C           WIRO3     IFNE *BLANK
     C                     MOVELWIRO3     W1BCCD
     C                     EXSR #CHG
     C                     WRITEABMWPF11
     C                     ENDIF
     C           WIRO4     IFNE *BLANK
     C                     MOVELWIRO4     W1BCCD
     C                     EXSR #CHG
     C                     WRITEABMWPF11
     C                     ENDIF
      *
     C                     ENDIF
      *
     CSR         ESB211    ENDSR
      *----------------------------------------------------*
      * BOX COLOR                                          *
      *  D  BLUE/WHITE   ----> B  BLUE
      *  E  YELLOW/BLACK ----> Y  YELLOW
      *  Z  YELLOW/BLUE  ----> Y  YELLOW
      *  F  ORANGE/BLACK ----> O  ORANGE
      *----------------------------------------------------*
     CSR         #CHG      BEGSR
      *
     C                     SELEC
     C           W1BCCD    WHEQ 'D'
     C                     MOVEL'B'       W1BCCD
     C           W1BCCD    WHEQ 'E'
     C                     MOVEL'Y'       W1BCCD
     C           W1BCCD    WHEQ 'Z'
     C                     MOVEL'Y'       W1BCCD
     C           W1BCCD    WHEQ 'F'
     C                     MOVEL'O'       W1BCCD
     C           W1BCCD    WHEQ 'H'
     C                     MOVEL'%'       W1BCCD
     C                     ENDSL
      *
     CSR         ECHG      ENDSR
      *----------------------------------------------------*
      * KANBAN M/F                                         *
      *----------------------------------------------------*
     CSR         #SB400    BEGSR
      *
     C           KEYTKR    KLIST
     C                     KFLD           WKTKR1
     C                     KFLD           WKTKR2
     C                     KFLD           WKTKR3
     C                     KFLD           WKTKR4
     C                     MOVELSTKR,X    WKTKR
     C                     MOVELKHZ,X     WDATE   80
      *
     C                     MOVEL*BLANK    WIRO1   1
     C                     MOVEL*BLANK    WIRO2   1
     C                     MOVEL*BLANK    WIRO3   1
     C                     MOVEL*BLANK    WIRO4   1
      *
     C                     SELEC
     C           WKKCD1    WHEQ 'A'
     C                     EXSR #ABH
     C           WKKCD1    WHEQ 'B'
     C                     EXSR #ADH
     C           WKKCD1    WHEQ 'C'
     C                     EXSR #AAF
     C                     EXSR #AAF1
     C           WKKCD1    WHEQ 'E'
     C                     EXSR #AAH
     C                     EXSR #AAH1
     C****       WKKCD1    WHEQ '6'
     C****                 EXSR #AAN
     C****       WKKCD1    WHEQ '0'
     C****                 EXSR #AAP
     C                     ENDSL
      *
     CSR         ESB400    ENDSR
      *----------------------------------------------------*
      * KANBAN M/F  ABHPP01                                *
      *----------------------------------------------------*
     CSR         #ABH      BEGSR
      *
     C           KEYTKR    SETLLABHPL031
     C           KEYTKR    READEABHPL031                 45
     C           *IN45     DOWEQ'0'
     C           M6SKJY    IFEQ 'D'
     C           M6SKHZ    ANDLE*DATE
     C                     ELSE
     C           M6UKHZ    IFLE WDATE
     C           M6STHZ    ANDGTWDATE
     C                     MOVELM6IRO1    WIRO1
     C                     MOVELM6IRO2    WIRO2
     C                     MOVELM6IRO3    WIRO3
     C                     MOVELM6IRO4    WIRO4
     C                     Z-ADDM6KMAX    WKKMAX
     C                     Z-ADDM6LOTK    WKLOT
     C           WIRO1     IFEQ 'L'
     C           WIRO2     OREQ 'L'
     C           WIRO3     OREQ 'L'
     C           WIRO4     OREQ 'L'
     C                     Z-ADD1         WKLOT
     C                     ENDIF
     C                     MOVELM6AKT1    WKATOK
     C           M6AKT2    IFNE *BLANK
     C                     MOVELM6AKT2    WKATOK
     C                     ENDIF
     C           M6AKT3    IFNE *BLANK
     C                     MOVELM6AKT3    WKATOK
     C                     ENDIF
     C           M6AKT4    IFNE *BLANK
     C                     MOVELM6AKT4    WKATOK
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C           KEYTKR    READEABHPL031                 45
     C                     ENDDO
      *
     C           WIRO1     IFEQ 'Y'
