     H            Y/                                    1
     H**FBCR46  *******************************************************
     H* TOYOTA NAME CODE MAINTENANCE                                  *
     H* JW       2019.06.19                                           *
     H*****************************************************************
     FFBCPW46 CF  E                    WORKSTN
     FGADTL17 IF  E           K        DISK
     FFBCPL36 IF  E           K        DISK
     F            FBCPP361                          KRENAMEFBCPL361
     FFBCPP36 UF  E           K        DISK                      A
      *================================================================
     E                    MSG     1  20 60
      *================================================================
     I            DS
     I                                        1  140@STIME
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                     *PROGRAM #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I                                      264 269 #JBNO
      *===============================================================
      *  START  PROGRAM
      *===============================================================
     C                     EXSR #INIT
      *
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C                     ENDCS
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *===============================================================
      *   DISPLAY SCREEN 1
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     EXFMTDSP01
     C                     MOVEA'00000000'*IN,21
     C                     SETOF                     85
     C                     MOVE *BLANK    D1ERR
      * < F1 > END
     C           *INKA     IFEQ *ON
     C                     MOVE '#END    '@STEP
     C                     GOTO #DSP1X
     C                     ENDIF
      * < F12 > INQUIRY
     C           *INKL     IFEQ *ON
     C                     MOVE *BLANK    P@SHP1
     C                     MOVE *BLANK    P@SHP2
     C                     CALL 'FBCR47'
     C                     PARM           P@SHP1  5
     C                     PARM           P@SHP2  1
     C           P@SHP2    IFNE *BLANK
     C                     MOVELP@SHP1    D1SHP1
     C                     MOVELP@SHP2    D1SHP2
     C                     ENDIF
     C                     MOVE '#DSP1   '@STEP
     C                     GOTO #DSP1X
     C                     ENDIF
      * CHECK FIELD
     C                     EXSR #CHK1
      *
     C           *IN85     IFEQ *ON
     C                     MOVE '#DSP1   '@STEP
     C                     ELSE
     C                     MOVEL*BLANK    D2KMEI
     C                     MOVEA'00000000'*IN,31
     C                     MOVEL*BLANK    D2ERR
     C                     MOVE '#DSP2   '@STEP
     C                     ENDIF
      *
     C           #DSP1X    ENDSR
      *===============================================================
      *  CHECK SCREEN 1
      *===============================================================
     C           #CHK1     BEGSR
      * D1KBN (21)
     C                     SELEC
     C           D1KBN     WHEQ '0'
     C                     MOVEL'0-CANCEL'D2KBN
     C                     SETON                     30
     C           D1KBN     WHEQ '1'
     C                     MOVEL'1-CHANGE'D2KBN
     C                     SETOF                     30
     C           D1KBN     WHEQ '2'
     C                     MOVEL'2-ADD   'D2KBN
     C                     SETOF                     30
     C                     OTHER
     C                     SETON                     2185
     C                     MOVELMSG,1     D1ERR
     C                     GOTO #CHK1X
     C                     ENDSL
      * D1SHP1 (22)
     C           D1SHP1    IFEQ *BLANK
     C                     SETON                     2285
     C                     MOVELMSG,2     D1ERR
     C                     GOTO #CHK1X
     C                     ENDIF
      * D1SHP2 (23)
     C           D1SHP2    IFEQ *BLANK
     C                     SETON                     2385
     C                     MOVELMSG,3     D1ERR
     C                     GOTO #CHK1X
     C                     ENDIF
     C*--------------------
     C                     MOVELD1SHP1    K@SHP1
     C                     MOVELD1SHP2    K@SHP2
     C           KEY01     CHAINFBCPP36             N90
      *
     C           *IN90     IFEQ *OFF
     C           F3SKJY    ANDEQ'D'                        DELETE CODE
     C                     MOVE *ON       *IN90
     C                     ENDIF
      *
     C           *IN90     IFEQ *OFF
     C           D1KBN     IFEQ '2'                        2-ADD
     C                     SETON                     212223
     C                     SETON                         85
     C                     MOVELMSG,5     D1ERR
     C                     GOTO #CHK1X
     C                     ENDIF
      *
     C                     Z-ADDF3TOKU    D2TOKU
     C                     Z-ADDF3NONY    D2NONY
     C                     ELSE
     C           D1KBN     IFNE '2'                        NE 2-ADD
     C                     SETON                     212223
     C                     SETON                         85
     C                     MOVELMSG,4     D1ERR
     C                     GOTO #CHK1X
     C                     ENDIF
     C                     Z-ADD0         D2TOKU
     C                     Z-ADD0         D2NONY
     C                     ENDIF
      *
     C           #CHK1X    ENDSR
      *===============================================================
      *   DISPLAY SCREEN 2
      *===============================================================
     C           #DSP2     BEGSR
      *
     C           D2NONY    CHAINGADTL17              98
     C           *IN98     IFEQ *OFF
     C                     MOVELB5KMEI    D2KMEI
     C                     ELSE
     C                     MOVE *BLANK    D2KMEI
     C                     ENDIF
      *
     C                     EXFMTDSP02
     C                     SETOF                     85
     C                     MOVEA'00000000'*IN,31
     C                     MOVE *BLANK    D2ERR
      * < F3 > BACK
     C           *INKC     IFEQ *ON
     C                     MOVEA'00000000'*IN,21
     C                     MOVE *BLANK    D1ERR
     C                     MOVE '#DSP1   '@STEP
     C                     GOTO #DSP2X
     C                     ENDIF
      *
     C                     EXSR #CHK2
      *
     C           *IN85     IFEQ *OFF
     C           *INKE     IFEQ *ON
     C                     EXSR #UPDAT
     C                     ELSE
     C                     MOVELMSG,13    D2ERR
     C                     MOVEL'#DSP2   '@STEP
     C                     ENDIF
      *
     C                     ELSE
     C                     MOVEL'#DSP2   '@STEP
     C                     ENDIF
      *
     C           #DSP2X    ENDSR
      *===============================================================
      *  CHECK SCREEN 2
      *===============================================================
     C           #CHK2     BEGSR
     C                     MOVEL*BLANK    D2KMEI
     C                     MOVE *OFF      *IN85
     C*--------------------
      * SKIP IF DELETE MODE
     C           D1KBN     IFEQ '0'
     C                     GOTO #CHK2X
     C                     ENDIF
      *--------------------
     C           D2TOKU    IFEQ 0
     C                     SETON                     3185
     C                     MOVELMSG,7     D2ERR
     C                     GOTO #CHK2X
     C                     ENDIF
      * CHECK TOKU
     C           D2TOKU    CHAINGADTL17              91
     C           *IN91     IFEQ *ON
     C                     SETON                     3185
     C                     MOVELMSG,10    D2ERR
     C                     GOTO #CHK2X
     C                     ENDIF
      *
     C           D2NONY    IFEQ 0
     C                     SETON                     3285
     C                     MOVELMSG,8     D2ERR
     C                     GOTO #CHK2X
     C                     ENDIF
     C* CHECK NONY
     C           D2NONY    SETLLGADTL17
     C                     DO   *HIVAL
     C           D2NONY    READEGADTL17                  91
     C   91                LEAVE
     C                     MOVELB5KMEI    D2KMEI
     C                     LEAVE
     C                     ENDDO
     C           *IN91     IFEQ *ON
     C                     SETON                     3285
     C                     MOVELMSG,9     D2ERR
     C                     GOTO #CHK2X
     C                     ENDIF
      * CHECK GROUP
     C                     MOVELD2TOKU    $DLV
     C                     CALL 'UTLR62'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTN    1
     C           $RTN      IFNE *BLANK
     C           $GRP      ORNE 'TYT'
     C                     SETON                     313285
     C                     MOVELMSG,11    D2ERR
     C                     GOTO #CHK2X
     C                     ENDIF
      * CHECK GROUP
     C                     MOVELD2NONY    $DLV
     C                     CALL 'UTLR62'
     C                     PARM           $DLV    4
     C                     PARM           $GRP    3
     C                     PARM           $NAME1 15
     C                     PARM           $NAME2 50
     C                     PARM           $RTN    1
     C           $RTN      IFNE *BLANK
     C           $GRP      ORNE 'TYT'
     C                     SETON                     313285
     C                     MOVELMSG,6     D2ERR
     C                     GOTO #CHK2X
     C                     ENDIF
      * CHECK DUPLICATE (ADD MODE)
     C           D1KBN     IFEQ '2'
     C                     Z-ADDD2NONY    K@NONY
     C                     Z-ADDD2TOKU    K@TOKU
     C           KEY02     SETLLFBCPL36
     C                     DO   *HIVAL
     C           KEY02     READEFBCPL36                  95
     C   95                LEAVE
     C           F3SKJY    IFEQ *BLANK
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN95     IFEQ *OFF
     C                     SETON                     313285
     C                     MOVELMSG,12    D2ERR
     C                     MOVE F3SHP1    D2ERR
     C                     GOTO #CHK2X
     C                     ENDIF
      *
     C                     ENDIF
      *
     C           #CHK2X    ENDSR
      *===============================================================
      * UPDATE
      *===============================================================
     C           #UPDAT    BEGSR
      *
     C           KEY01     CHAINFBCPP36              90
      *
     C           D1KBN     IFEQ '0'                        0-CANCEL
     C                     MOVE 'D'       F3SKJY           DELETE CODE
     C                     Z-ADDTODAY     F3SKDT
     C                     Z-ADDNOW       F3SKTM
     C                     MOVEL#WSID     F3SKWS
     C                     MOVEL#USER     F3SKUS
     C  N90                UPDATFBCPP361
     C                     ELSE
     C                     MOVE *BLANK    F3SKJY           DELETE CODE
     C                     Z-ADD0         F3SKDT
     C                     Z-ADD0         F3SKTM
     C                     MOVE *BLANK    F3SKWS
     C                     MOVE *BLANK    F3SKUS
     C                     Z-ADDTODAY     F3KODT           UPDATE DATE
     C                     Z-ADDNOW       F3KOTM
     C                     MOVEL#WSID     F3KOWS
     C                     MOVEL#USER     F3KOUS
     C                     MOVELD1SHP1    F3SHP1
     C                     MOVELD1SHP2    F3SHP2
     C                     Z-ADDD2TOKU    F3TOKU
     C                     Z-ADDD2NONY    F3NONY
      *
     C           *IN90     IFEQ *OFF
     C                     Z-ADDTODAY     F3KODT
     C                     Z-ADDNOW       F3KOTM
     C                     MOVEL#WSID     F3KOWS
     C                     MOVEL#USER     F3KOUS
     C                     UPDATFBCPP361
     C                     ELSE
     C                     Z-ADDTODAY     F3CRDT
     C                     Z-ADDNOW       F3CRTM
     C                     MOVEL#WSID     F3CRWS
     C                     MOVEL#USER     F3CRUS
     C                     WRITEFBCPP361
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     MOVE *BLANK    D1KBN
     C                     MOVE *BLANK    D1ERR
     C                     MOVEA'00000000'*IN,21
     C                     MOVE '#DSP1   '@STEP
      *
     C                     ENDSR
      *===============================================================
      *  INITIAL SET
      *===============================================================
     C           #INIT     BEGSR
      *
     C           KEY01     KLIST
     C                     KFLD           K@SHP1 10
     C                     KFLD           K@SHP2 10
      *
     C           KEY02     KLIST
     C                     KFLD           K@NONY  40
     C                     KFLD           K@TOKU  40
      *
     C                     TIME           @STIME
     C                     MOVEA*ALL'0'   *IN
     C                     MOVE *BLANK    D1KBN
     C                     MOVE *BLANK    D1SHP1
     C                     MOVE *BLANK    D1SHP2
     C                     MOVE *BLANK    D1ERR
     C                     MOVEL'#DSP1   '@STEP   8
      *
     C                     ENDSR
**  MSG -1---------2---------3---------4---------5--------->
 ENTER 0, 1 OR 2 FOR THE UPDATE ID.                          01
 ENTER TOYOTA NAME CODE !                                    02
 ENTER SEQ!                                                  03
 THERE IS NO TARGET DATA.                                    04
 NAME CODE AND SEQ IS ALREADY REGISTERED!                    05
 DELIVERY CODE IS NOT TOYOTA GROUP!                          06
 ENTER CUSTOMER CODE!                                        07
 ENTER DELIVERY CODE!                                        08
 DELIVERY CODE DOES NOT EXIST IN MASTER!                     09
 CUSTOMER CODE DOES NOT EXIST IN MASTER!                     10
 CUSTOMER CODE IS NOT TOYOTA GROUP!                          11
 CUSTOMER/DELEVERY WILL BE DUPLICATED!                       12
 PRESS F5 TO UPDATE...                                       13
