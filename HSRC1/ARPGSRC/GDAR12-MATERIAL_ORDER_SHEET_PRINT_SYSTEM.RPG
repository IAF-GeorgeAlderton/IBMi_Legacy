      *------*
      * PARM *
      *------*
     C           *ENTRY    PLIST
     C                     PARM           PSIRE   4
     C                     PARM           PODR1   2
     C                     PARM           PODR2   2
     C                     PARM           PODR3   2
      *-----*
      * KEY *
      *-----*
     C           K#PCT     KLIST
     C                     KFLD           K@KWD1  8
     C                     KFLD           K@KWD2  8
     C           KEY1      KLIST
     C                     KFLD           IBZAIS
     C                     KFLD           IBZAIK
     C                     KFLD           IBSIRE
      *
     C           KEY2      KLIST
     C                     KFLD           IBZAIS
     C                     KFLD           IBZAIK
     C                     KFLD           ORDER1
     C                     KFLD           ORDER2
     C                     KFLD           ORDER3
     C                     KFLD           ITEM
      *
     C           KEY3      KLIST
     C                     KFLD           IBZAIS
     C                     KFLD           IBZAIK
      *
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      *
     C                     MOVEL'MATERIAL'K@KWD1
     C                     MOVEL'SUMMARY 'K@KWD2
     C           K#PCT     CHAINAB#PPCT              90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDCTNBR1    D@DATE
     C                     Z-ADDCTNBR2    D@TIME
     C                     ENDIF
      *---------------*
      * GET ORDER NO. *
      *---------------*
     C                     Z-ADD0         XYEAR
     C                     Z-ADD0         ORDER2
     C                     Z-ADD0         ORDER3
     C                     SETOF                     10
     C           'ORDER '  CHAINGDLNP101             10
     C           *IN10     IFEQ '0'
     C           LNSKJY    IFEQ 'D'
     C           LNSKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     ELSE
     C                     Z-ADD*YEAR     XYEAR
     C                     Z-ADDUMONTH    ORDER2
     C           LNMOTH    IFEQ UMONTH
     C           LNIDNO    ADD  1         ORDER3
     C                     ELSE
#9999C                     Z-ADD10        ORDER3
     C                     END
     C                     END
     C*
     C                     UPDATGDLNP101
     C                     END
      *
     C           *IN10     IFEQ '1'
     C                     Z-ADD*YEAR     XYEAR
     C                     Z-ADDUMONTH    ORDER2
#9999C                     Z-ADD10        ORDER3
     C                     END
     C*
     C                     Z-ADD*DATE     XDATE   80
     C                     MOVE 'S'       HANY    1
     C                     MOVE *BLANK    ISIRE
     C                     MOVE '1'       D@PRT
      *----------*
      * SCREEN 1 *
      *----------*
     C           STP1      TAG
     C                     EXFMTDSP01
     C                     SETOF                     019902
      *-------*
      * CMD-1 *
      *-------*
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           ISIRE     IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVELER,1      MSG
     C                     GOTO STP1
     C                     END
      *
     C                     Z-ADD0         OSIRE   40
     C                     MOVELISIRE     OSIRE
     C                     MOVELISIRE     PSIRE
      *
     C                     SETOF                     15
     C           OSIRE     CHAINFGBPL011             15
      *
     C           *IN15     IFEQ '0'
     C           B2SKJY    IFEQ 'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     15
     C                     END
     C                     END
      *
     C           *IN15     IFEQ '1'
     C                     SETON                     0199
     C                     MOVELER,2      MSG
     C                     GOTO STP1
     C                     END
      *
     C           D@PRT     IFLT '1'
     C           D@PRT     ORGT '3'
     C                     SETON                     0299
     C                     MOVELER,4      MSG
     C                     GOTO STP1
     C                     ENDIF
      *-------*
      * CMD-5 *
      *-------*
     C           *INKE     IFEQ '0'
     C                     GOTO STP1
     C                     END
      *--------------*
      * GET ITEM NO. *
      *--------------*
     C                     SELEC
     C           D@PRT     WHEQ '1'
     C                     MOVEL'LANPRT03'@PRNTR  8
     C           D@PRT     WHEQ '2'
     C                     MOVEL'LANPRT02'@PRNTR  8
     C           D@PRT     WHEQ '3'
     C                     MOVEL'LANPRT07'@PRNTR  8
     C                     ENDSL
      *
     C                     MOVEACMD,1     ARY
     C                     MOVEA@PRNTR    ARY,60
     C                     MOVEAARY       P@CMD
     C                     Z-ADD70        P@LEN
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN GDLPR10
      *
     C                     Z-ADD0         ITEM    50
     C                     SETOF                     1088
     C           'ITEM  '  CHAINGDLNP101             10
     C           *IN10     IFEQ '0'
     C           LNSKJY    IFEQ 'D'
     C           LNSKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     ELSE
     C                     Z-ADD*YEAR     XYEAR
     C           LNYEAR    IFEQ *YEAR
     C                     Z-ADDLNIDNO    ITEM
     C                     ELSE
     C                     Z-ADD1         ITEM
     C                     END
     C                     END
     C                     END
      *
     C           *IN10     IFEQ '1'
     C                     Z-ADD1         ITEM
     C                     END
      *-------------------*
      * PRINT ORDER SHEET *
      *-------------------*
     C           OSIRE     SETLLGDAPL10
     C           *IN20     DOUEQ*ON
     C           OSIRE     READEGDAPL10                  20
     C           *IN20     IFEQ '0'
     C           IBSKJY    ANDEQ*BLANK
     C                     Z-ADD*DATE     IBKODT
     C                     TIME           IBKOTM
     C                     MOVEL#USER     IBKOME
     C                     Z-ADD0         MAI     30
     C                     Z-ADD0         MAIS    30
     C                     Z-ADD0         ZAN     30
     C                     Z-ADD0         LOTO    30
      *
     C                     MOVE IBPTCD    LAPTCD
     C                     MOVE IBZAIS    LAZAIS
     C                     Z-ADDIBZAIK    LAZAIK
%0001 *
     C           IBPTCD    IFEQ 'W'
     C           KEY1      SETGTIZAPL03
     C           *IN55     DOUEQ*ON
     C           KEY1      REDPEIZAPL031                 55
      *
     C           *IN55     IFEQ '0'
     C           ZCSKJY    ANDEQ*BLANK
     C           ZCUKHZ    ANDLE*DATE
     C           ZCSTHZ    ANDGT*DATE
     C                     Z-ADDZCLOTO    LOTO
     C                     LEAVE
     C                     ENDIF
     C  N55                ENDDO
      *
     C                     ENDIF
      *
     C           IBPTCD    IFEQ 'R'
     C           KEY1      SETGTIZBPL03
     C           *IN55     DOUEQ*ON
     C           KEY1      REDPEIZBPL031                 55
      *
     C           *IN55     IFEQ '0'
     C           ZDSKJY    ANDEQ*BLANK
     C           ZDUKHZ    ANDLE*DATE
     C           ZDSTHZ    ANDGT*DATE
     C                     Z-ADDZDSETI    LOTO
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
%0001 *
     C           LOTO      IFNE 0
     C           IBMAIS    DIV  LOTO      MAI
     C                     MVR            ZAN
     C                     END
     C           IBMAIS    SUB  ZAN       MAIS
      *------------------------*
      * CHECK NUMBER OF KANBAN *
      *------------------------*
     C           MAIS      IFEQ 0
     C                     GOTO SKIP
     C                     END
      *
     C           ZAN       IFGT 0
     C                     Z-ADDZAN       IBMAIS
     C                     ELSE
     C                     MOVEL'D'       IBSKJY
     C                     Z-ADD*DATE     IBSKDT
     C                     END
      *
     C           *IN77     IFEQ '0'
     C                     SETON                     77
     C                     Z-ADD*YEAR     YEAR
     C                     Z-ADDUMONTH    MONTH
     C                     Z-ADDUDAY      DAY
     C                     WRITEGDLPR101
     C                     END
      *----------*
      * OVERFROW *
      *----------*
     C           *IN95     IFEQ '1'
     C                     SETOF                     95
     C                     WRITEGDLPR101
     C                     END
     C                     WRITEGDLPR102
      *
     C                     UPDATGDAPP101
      *
     C                     MOVE *BLANK    LBSKJY
     C                     Z-ADD0         LBSKHZ
     C                     Z-ADD*DATE     LBKOHZ
     C                     TIME           LBKOTM
     C                     MOVEL#USER     LBKOME
      *
     C                     Z-ADDIBSIRE    LBSIRE
     C                     Z-ADDIBUKEI    LBUKEI
     C                     MOVELIBUKOJ    LBUKOJ
     C                     MOVELIBUUKE    LBUUKE
     C                     Z-ADDORDER1    LBODR1
     C                     Z-ADDORDER2    LBODR2
     C                     Z-ADDORDER3    LBODR3
     C                     Z-ADDITEM      LBITEM
     C                     Z-ADDMAIS      LBMAIS
     C                     MOVELIBPTCD    LBPTCD
     C                     MOVELIBZETI    LBZETI
     C                     MOVELIBZAIS    LBZAIS
     C                     Z-ADDIBZAIK    LBZAIK
     C                     Z-ADD*DATE     LBODHZ
     C                     Z-ADD0         LBKANY
     C                     Z-ADD0         LBKANM
     C                     Z-ADD0         LBKAND
     C                     Z-ADD0         LBSPYY
     C                     Z-ADD0         LBSPMM
     C                     Z-ADD0         LBSPDD
     C                     Z-ADD0         LBREYY
     C                     Z-ADD0         LBREMM
     C                     Z-ADD0         LBREDD
     C                     Z-ADD0         LBREMA
     C                     WRITEGDLPP101
      *
     C                     SETOF                     25
     C           KEY3      CHAINGDLPL251             25
      *
     C           *IN25     IFEQ '0'
     C           LDSKJY    IFEQ 'D'
     C           LDSKHZ    ANDLE*DATE
     C                     SETON                     25
     C                     END
     C                     END
      *
     C                     MOVE *BLANK    LDSKJY
     C                     Z-ADD0         LDSKHZ
     C                     Z-ADD*DATE     LDKOHZ
     C                     TIME           LDKOTM
     C                     MOVEL#USER     LDKOME
      *
     C                     MOVELIBZAIS    LDZAIS
     C                     Z-ADDIBZAIK    LDZAIK
     C                     MOVELIBZETI    LDZETI
     C                     MOVELIBPTCD    LDPTCD
     C           *IN25     IFEQ '1'
     C                     Z-ADDMAIS      LDSTCK
     C                     ELSE
     C                     ADD  MAIS      LDSTCK
     C                     END
     C           *IN25     IFEQ '1'
     C                     WRITEGDLPL251
     C                     ELSE
     C                     UPDATGDLPL251
     C                     END
      *
     C                     EXCPTDT
      *
     C                     ADD  1         ITEM
     C                     SETON                     88
     C           SKIP      TAG
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN88     IFEQ '0'
     C                     SETON                     99
     C                     MOVELER,3      MSG
     C                     GOTO STP1
     C                     END
      *
     C                     MOVELORDER1    PODR1
     C                     MOVELORDER2    PODR2
     C                     MOVELORDER3    PODR3
      *-----------------*
      * UPDATE ITEM NO. *
      *-----------------*
     C                     MOVE *BLANK    LNSKJY
     C                     Z-ADD0         LNSKHZ
     C                     Z-ADD*DATE     LNKOHZ
     C                     TIME           LNKOTM
     C                     MOVEL#USER     LNKOME
     C                     MOVEL'ITEM  '  LNIDKY
     C                     Z-ADDITEM      LNIDNO
     C                     Z-ADD*YEAR     LNYEAR
     C                     Z-ADDUMONTH    LNMOTH
      *
     C           *IN10     IFEQ '1'
     C                     WRITEGDLNP101
     C                     ELSE
     C                     UPDATGDLNP101
     C                     END
      *-----------------*
      * UPDATE ORDER NO. *
      *----------------*
     C                     SETOF                     10
     C           'ORDER '  CHAINGDLNP101             10
      *
     C                     MOVE *BLANK    LNSKJY
     C                     Z-ADD0         LNSKHZ
     C                     Z-ADD*DATE     LNKOHZ
     C                     TIME           LNKOTM
     C                     MOVEL#USER     LNKOME
     C                     MOVEL'ORDER '  LNIDKY
     C                     Z-ADDXYEAR     LNYEAR
     C                     Z-ADDORDER2    LNMOTH
     C                     Z-ADDORDER3    LNIDNO
      *
     C           *IN10     IFEQ '1'
     C                     WRITEGDLNP101
     C                     ELSE
     C                     UPDATGDLNP101
     C                     END
      *
     C                     SETON                     U1LR
     C                     RETRN
      *
     OGDLWP10 E                DT
     O                                    3 'IAF'
     O                         ORDER1     5
     O                         ORDER2     7
     O                         ORDER3     9
     O                         XDATE     17
     O                         ITEM      22
     O                         IBZAIS    37
     O                         IBZAIK    42
     O                         MAIS      45
     O                         IBPTCD    46
     O                         IBZETI    50
     O                         HANY      51
