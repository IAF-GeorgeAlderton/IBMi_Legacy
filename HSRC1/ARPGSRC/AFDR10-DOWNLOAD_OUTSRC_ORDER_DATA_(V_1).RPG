     H            Y.                                    1
     H** AFDR10 *******************************************************
     H* OUT SOURCE DATA CREATE                                        *
     H*                                                               *
     H* TCH JUL/22/04
     H* TCHK1 06/20/08 ADD EMT
     H* TCHK2 12/10/08 ADD PTC(2424)
     H* TCHK3 02/26/09 ADD DEPOR(2929)
     H* TCHK4 03/11/10 ADD SWD(2828) TALMA(3333)
     H* TCHK5 05/13/10 ADD SEKIDO(3111),SRA(3222),VICO(3444)
     H* TCHK6 01/27/12 ADD ROCKFORD SECONDARIES(4444)
     H* TCHK7 09/21/12 ADD FAS(5555)
     H**************************************************************************
     FAFDPW10 CF  E                    WORKSTN
     F                                              KINFDS @INFDS
     FAFDPL20 IF  E           K        DISK
     FAFDWP05 O   E                    DISK
      *--------------------------------------------------------------
     E                    CMD     1   1 78
     E                    ERR     1   1 78
TCHK7 *************       TAB1    1  20  5   TAB2   15
     E                    TAB1    1  21  5   TAB2   15
     I**************************************************************************
     I* BARCODE
     I*(KANRI CODE+ZETAI NO+TEHAI NO+PAGE NO+NIJI KAKO KUBUN+TAISYO KUBN+
     I**************************************************************************
     I@INFDS      DS
     I                                    B 370 3710@@LIN
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   80K@YMD
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80AFODAT
     I                                        1   40AFODYY
     I                                        5   60AFODMM
     I                                        7   80AFODDD
     I            DS
     I                                        1   80AFNDAT
     I                                        1   40AFNOYY
     I                                        5   60AFNOMM
     I                                        7   80AFNODD
     I            DS
     I                                        1   80W@ORDT
     I                                        1   40K@ODYY
     I                                        5   60K@ODMM
     I                                        7   80K@ODDD
     I            DS
     I                                        1  12 D@PART
     I                                        1   5 D@PRT1
     I                                        6  10 D@PRT2
     I                                       11  12 D@PRT3
     I            DS
     I                                        1  12 AFPART
     I                                        1   5 AFPAR1
     I                                        6  10 AFPAR2
     I                                       11  12 AFPAR3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
     C           *INZSR    BEGSR
      *-----------------------------------------------
      *
     C           K#AF20    KLIST
     C                     KFLD           K@SUPP  4
     C                     KFLD           K@YY    40
     C                     KFLD           K@MM    20
     C                     KFLD           K@DD    20
      *
     C                     MOVE '01'      @@ID    2
     C                     SETOF                     30
      *
     C                     ENDSR
     C**************************************************************************
     C*    1ST SCREEN
     C**************************************************************************
     C           #SCRN1    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
B02  C           *INKC     WHEQ '1'
     C                     MOVEL'99'      @@ID    2
     C*
     C                     OTHER
     C                     EXSR #CHK1
     C*
B04  C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
B04  C                     EXSR #WRT
     C           *IN98     IFEQ *OFF
     C                     MOVE ERR,1     D@MSG
     C                     ELSE
     C                     MOVEL'99'      @@ID
     C                     ENDIF
     C                     ENDIF
     C                     ENDSL
     C*
     C                     ENDSR
     C**************************************************************************
     C*                    @CHK1
     C**************************************************************************
     C           #CHK1     BEGSR
     C*
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,61
     C                     MOVE *BLANK    D@MSG
     C*  CHECK DATE
     C           D@TO      IFEQ *ZERO
     C                     Z-ADD99999999  D@TO
     C                     ENDIF
      *
     C           D@TO      IFLT D@FROM
     C                     MOVEA'11'      *IN,61
     C                     MOVE *ON       *IN99
     C                     ENDIF
      *
     C                     ENDSR
     C**************************************************************************
     C*    WRITE DATA FOR DOWNLOADING
     C**************************************************************************
     C           #WRT      BEGSR
      *
     C                     Z-ADDD@FROM    K@YMD
     C                     MOVE *OFF      *IN98
     C           *LOVAL    SETLLAFDPL20
     C           *IN80     DOUEQ*ON
     C                     READ AFDPL20                  80
     C           *IN80     IFEQ *OFF
     C           AFSKJY    ANDEQ*BLANK
     C                     MOVE AFSUPP    K@SUPP
      *
     C           K#AF20    SETLLAFDPL20
     C           *IN85     DOUEQ*ON
     C           K@SUPP    READEAFDPL20                  85
     C           *IN85     IFEQ *OFF
     C           AFSKJY    ANDEQ*BLANK
      *
     C           AFODAT    IFGT D@TO
     C                     LEAVE
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
     C                     CLEARAFDWP051
     C           AFSUPP    CAT  AFAKI1:0  SCODE   5 P
     C           SCODE     LOKUPTAB1      TAB2           90
     C           *IN90     IFEQ *ON
     C                     MOVELTAB2      AWSUPL
     C                     ENDIF
     C                     Z-ADDAFODAT    AWODAT
     C                     MOVE AFBINN    AWBIN
     C                     MOVELAFPAR1    AWPART    P
     C           AFPAR2    IFNE *BLANK
     C           AWPART    CAT  '-':0     AWPART    P
     C           AWPART    CAT  AFPAR2:0  AWPART    P
     C                     ENDIF
     C           AFPAR3    IFNE *BLANK
     C           AWPART    CAT  '-':0     AWPART    P
     C           AWPART    CAT  AFPAR3:0  AWPART    P
     C                     ENDIF
     C                     Z-ADDAFHAKO    AWBOX
     C                     MOVE AFODNO    AWODNO
     C                     Z-ADDAFNDAT    AWRDAT
     C                     MOVELAFAKI2    AWRBIN
     C                     WRITEAFDWP051
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           K@SUPP    SETGTAFDPL20
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *---------------------------------------------------------
