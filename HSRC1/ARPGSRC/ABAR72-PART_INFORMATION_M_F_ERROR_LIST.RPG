     F** ABAR72 ****************************************************
     F*  PART INFORMATION M/F ERROR LIST ...                       *
     F*         A-INOUE               97.09.29                     *
     F*  H-AMANO  2.10.28                                          *
     F*  TCHK1   04/13/10 CHG 'SEND TO' NAME                       *
     F*  TCHK2   05/07/14 CHG 'SEND TO' NAME                       *
     F*  JW1     12/05/18 ADD ERROR MSG ,7                         *
      *------------------------------------------------------------*
     F*    ADD REASON CODE
     F*       1:NO RECORD IN FCEPP01
     F*       2:DELETED
     F*       3:TAHZ = 0
     F*       4:TEHI <> G
     F*       5:TAHZ > *DATE
     F*       6:NOT AGAPL31,NOR AAPTL01
     F*************************************************************
     FABAWL72 IP  F     384            DISK
     FFGBPL01 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
      *--------------------------------------------------------------
     E**                  TAB1    1   6  1   TAB2   20
JW1  E                    TAB1    1   7  1   TAB2   20
     E                    HRT       500 21
     E                    ANN        31  7 0             PIECES N
     E                    WNN         9  9 0             PRINT PIECES
     E                    WND         9  5               PRINT DATE
     IABAWL72 AA  01
     I                                        1   40ATOKU L1
     I                                        5   80ANONY
     I                                        9   9 ANKOJ
     I                                       10  10 AGKOJ
     I                                       11  14 ANUKE
     I                                       15  18 AGUKE
     I                                       19  22 ASEBN
     I                                       23  27 AMHN1
     I                                       28  32 AMHN2
     I                                       33  37 AMHN3           02
     I                                       38  42 AMHN4           03
     I                                       43  47 ASHN1
     I                                       48  52 ASHN2
     I                                       53  54 ASHN3           04
     I                                       55  630ANNSU
     I                                       64  720AN1SU
     I                                       73  810AN2SU
     I                                       82  82 ANOKU
     I                                       83 299 ANN
     I                                      300 300 ATEHI
     I                                      301 301 @@ERCD
     I                                      302 3100FS4
     I                                      311 3190FS5
      *
     I            DS
     I                                        1   60UDYM
     I                                        5   60UMM0
      *
     I            DS
     I                                        1   5 #NMSD
     I                                        1   1 #NM1
     I                                        1   2 #NM
     I                                        3   3 #NS
     I                                        4   4 #ND1
     I                                        4   5 #ND
      * SYSTEM TIME & DATE
     I            DS
     I                                        1  140WTMDT
     I                                        1   60WTIME
     I                                        1   20WTIHH
     I                                        3   40WTIMM
     I                                        5   60WTISS
     I                                        7  140WDATE
     I                                        9  140WDAT6
     I                                        7  100WDAY4
     I                                        9  100WDAYY
     I                                       11  120WDAMM
     I                                       13  140WDADD
      *
TCHK1I              'PC MAMIYA   '        C         C@NAM1
TCHK2I              'SALES TEAM  '        C         C@NAM2
      *
     C*----------------------------*
     C*  ..FORCAST DATE SETUP  ..  *
     C*----------------------------*
     C           *ENTRY    PLIST
     C                     PARM           PDYM    6
     C                     MOVE PDYM      UDYM    60
      *
     C                     TIME           WTMDT
      * SET UP
     C           *IN20     IFEQ '0'
     C                     SETON                     20
     C                     TIME           WTIME   60
      *
     C           UMM0      IFEQ 12
     C                     Z-ADD01        UMM1    20
     C                     ELSE
     C           UMM0      ADD  1         UMM1
     C                     END
      *
     C           UMM1      IFEQ 12
     C                     Z-ADD01        UMM2    20
     C                     ELSE
     C           UMM1      ADD  1         UMM2
     C                     END
     C           UMM2      IFEQ 12
     C                     Z-ADD01        UMM3    20
     C                     ELSE
     C           UMM2      ADD  1         UMM3
     C                     END
     C           UMM3      IFEQ 12
     C                     Z-ADD01        UMM4    20
     C                     ELSE
     C           UMM3      ADD  1         UMM4
     C                     END
      *
     C                     MOVE '/'       #NS
     C                     MOVE *BLANK    #ND
      *
     C                     MOVE UMM0      #NM
     C           #NM1      IFEQ '0'
     C                     MOVE ' '       #NM1
     C                     END
     C                     MOVE #NMSD     #MM0    5
      *
     C                     MOVE UMM1      #NM
     C           #NM1      IFEQ '0'
     C                     MOVE ' '       #NM1
     C                     END
     C                     MOVE #NMSD     #MM1    5
      *
     C                     MOVE UMM2      #NM
     C           #NM1      IFEQ '0'
     C                     MOVE ' '       #NM1
     C                     END
     C                     MOVE #NMSD     #MM2    5
      *
     C                     MOVE UMM3      #NM
     C           #NM1      IFEQ '0'
     C                     MOVE ' '       #NM1
     C                     END
     C                     MOVE #NMSD     #MM3    5
      *
     C                     MOVE UMM4      #NM
     C           #NM1      IFEQ '0'
     C                     MOVE ' '       #NM1
     C                     END
     C                     MOVE #NMSD     #MM4    5
      *
     C                     SETON                     OF
      *
     C                     END
      *LIST OVER FLOW
     C           *INOF     IFEQ '1'
     C           *INL1     OREQ *ON
TCHK1C           ATOKU     IFEQ 3411
TCHK1C                     MOVELC@NAM1    W@NAME 12
TCHK1C                     ELSE
TCHK1C                     MOVELC@NAM2    W@NAME
TCHK1C                     END
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     END
      *
     C                     SETOF                     05
     C                     MOVE *BLANK    WTNM   15
     C           ATOKU     CHAINFGBPL011             05
     C           *IN05     IFEQ '0'
     C                     MOVE B2SMEI    WTNM
     C                     END
     C                     SETOF                     05
     C                     MOVE *BLANK    WNNM   15
     C           ANONY     CHAINFGBPL011             05
     C           *IN05     IFEQ '0'
     C                     MOVE B2SMEI    WNNM
     C                     END
      *
     C                     MOVE *BLANK    WNOKU   1
     C                     MOVE ANOKU     WNOKU
      *
     C                     MOVE *BLANK    WTEHI   8
     C**         ATEHI     IFEQ 'G'
     C**                   MOVEL'V-PROD'  WTEHI
     C**                   END
     C           ATEHI     IFEQ 'Z'
     C                     MOVEL'LIMIT'   WTEHI
     C                     END
     C           ATEHI     IFEQ 'S'
     C                     MOVEL'T-MFG'   WTEHI
     C                     END
      *
     C           @@ERCD    LOKUPTAB1      TAB2           10
     C                     EXCPTDT
      *
      **** SCHDULED DATE / PIECES PRINT
      *
     C                     MOVE #MM0      #NMSD
     C                     Z-ADD0         WNN
     C                     MOVE *BLANK    WND
      *
     C                     Z-ADD1         I       20
     C                     Z-ADD0         J       20
     C           1         DO   31        I
     C           ANN,I     IFNE 0
     C                     ADD  1         J
     C                     Z-ADDANN,I     WNN,J
     C                     MOVE I         #ND
     C           #ND1      IFEQ '0'
     C                     MOVE ' '       #ND1
     C                     END
     C                     MOVE #NMSD     WND,J
     C           J         IFEQ 9
     C                     EXSR PRTDT2
     C                     END
     C                     END
     C                     ENDDO
      *
     C                     XFOOTANN       WANN    90
     C           ANNSU     IFNE WANN
     C                     ADD  1         J
     C                     Z-ADDANNSU     WNN,J
     C                     MOVE #MM0      WND,J
     C           J         IFEQ 9
     C                     EXSR PRTDT2
     C                     END
     C                     ENDIF
      *
     C           AN1SU     IFNE 0
     C                     ADD  1         J
     C                     Z-ADDAN1SU     WNN,J
     C                     MOVE #MM1      WND,J
     C           J         IFEQ 9
     C                     EXSR PRTDT2
     C                     END
     C                     ENDIF
      *
     C           AN2SU     IFNE 0
     C                     ADD  1         J
     C                     Z-ADDAN2SU     WNN,J
     C                     MOVE #MM2      WND,J
     C           J         IFEQ 9
     C                     EXSR PRTDT2
     C                     END
     C                     ENDIF
      *
     C           FS4       IFNE 0
     C                     ADD  1         J
     C                     Z-ADDFS4       WNN,J
     C                     MOVE #MM3      WND,J
     C           J         IFEQ 9
     C                     EXSR PRTDT2
     C                     END
     C                     ENDIF
      *
     C           FS5       IFNE 0
     C                     ADD  1         J
     C                     Z-ADDFS5       WNN,J
     C                     MOVE #MM4      WND,J
     C           J         IFEQ 9
     C                     EXSR PRTDT2
     C                     END
     C                     ENDIF
      *
     C           J         IFNE 0
     C                     EXSR PRTDT2
     C                     END
      *
     C*----------------------------------*
     C*  ..SCHDULE DATE/PIECES PRINT ..  *
     C*----------------------------------*
     C           PRTDT2    BEGSR
     C** DT2 PRINT
     C           *INOF     IFEQ '1'
TCHK1C           ATOKU     IFEQ 3411
TCHK1C                     MOVELC@NAM1    W@NAME 12
TCHK1C                     ELSE
TCHK1C                     MOVELC@NAM2    W@NAME
TCHK1C                     END
     C                     EXCPTHD
     C                     SETOF                     OF
     C           @@ERCD    LOKUPTAB1      TAB2           10
     C                     EXCPTDT
     C                     END
     C                     EXCPTDT2
      *
     C** DT2 CLEAR
     C                     Z-ADD0         WNN
     C                     MOVE *BLANK    WND
     C                     Z-ADD0         J
     C                     ENDSR
     OQPRINT  E  102           HD
