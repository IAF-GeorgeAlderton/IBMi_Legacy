     H            Y.
     F** AL#R96  *******************************************
     F*ＷＥＢデータ照会ワーク作成                        *
     F*      ITS.        2015.05.29                        *
     F******************************************************
     FAL#PL01 IF  E           K        DISK
     FAL#PL0A IF  E           K        DISK
     FAL#WP96 UF  E           K        DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1ISS1  80
     C                     PARM           P1ISS2  80
     C                     PARM           P1SHI1  8
     C                     PARM           P1SHI2  8
     C                     PARM           P1SURT  9
     C                     PARM           P9CMD   2
      *
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      * ISSUE
     C                     MOVEL'1'       WKPTN   1
      * SHIP
     C           P1ISS1    IFEQ 0
     C           P1SHI1    ANDNE'00000000'
     C                     MOVEL'2'       WKPTN   1
     C                     ENDIF
      *
     C                     Z-ADDP1ISS2    WKISS2  80
     C           WKISS2    IFEQ 0
     C                     Z-ADD99999999  WKISS2
     C                     ENDIF
      *
     C                     MOVELP1SHI2    WKSHI2  8
     C           WKSHI2    IFEQ '00000000'
     C                     MOVEL*HIVAL    WKSHI2  8
     C                     ENDIF
      * ISSUE DATE
     C           WKPTN     IFEQ '1'
      *
     C           P1ISS1    SETLLAL#PL0A1
     C                     READ AL#PL0A1                 81
     C           *IN81     DOWEQ'0'
     C           CAKADT    ANDLEWKISS2
      *
   S1C           CASKJY    IFEQ 'D'
     C           CASKHZ    ANDLESDATE
     C                     ELSE
  S2 C           CAFIXD    IFNE 0
     C                     EXSR #SB410
  E2 C                     ENDIF
   E1C                     ENDIF
      *
     C                     READ AL#PL0A1                 81
     C                     ENDDO
      * SHIP DATE
     C                     ELSE
     C           P1SHI1    SETLLAL#PL011
     C                     READ AL#PL011                 81
     C           *IN81     DOWEQ'0'
     C           CASHID    ANDLEWKSHI2
     C           CASKJY    IFEQ 'D'
     C           CASKHZ    ANDLESDATE
     C                     ELSE
     C           CAFIXD    IFNE 0
     C                     EXSR #SB400
     C                     ENDIF
     C                     ENDIF
     C                     READ AL#PL011                 81
     C                     ENDDO
      *
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AL#WP96
      *-----------------------------------------------------
     CSR         #SB400    BEGSR
      *
     C                     MOVEL'0'       GET     1
      *
     C           P1SURT    IFEQ *BLANK
     C                     MOVEL'1'       GET
     C                     ELSE
     C           CASURT    IFEQ P1SURT
     C                     MOVEL'1'       GET
     C                     ENDIF
     C                     ENDIF
     C           GET       IFEQ '1'
     C                     EXSR #SB500
     C                     EXSR #SB510
     C                     EXSR #SB520
     C                     EXSR #SB550
     C                     ENDIF
      *
     CSR         ESB400    ENDSR
      *-----------------------------------------------------
      *  SB410
      *-----------------------------------------------------
     CSR         #SB410    BEGSR
      *
     C                     MOVEL'0'       GET2    1
      *
     C           P1SHI1    IFNE '00000000'
      *
     C           CASHID    IFGE P1SHI1
     C           CASHID    ANDLEWKSHI2
     C                     MOVEL'1'       GET2
     C                     ENDIF
     C* NO CHECK
     C                     ELSE
     C                     MOVEL'1'       GET2
     C                     ENDIF
     C*
     C           GET2      IFEQ '1'
     C                     EXSR #SB400
     C                     ENDIF
      *
     CSR         ESB410    ENDSR
      *-----------------------------------------------------
      *  AL#WP96  0 : SHID SHIT SURT
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C           KEYW0     KLIST
     C                     KFLD           KKTYPE  1
     C                     KFLD           CASHID
     C                     KFLD           CASHIT
     C                     KFLD           CASURT
     C                     KFLD           CATRKB  2
      *
     C                     MOVEL'0'       KKTYPE
     C           KEYW0     CHAINAL#WP961             22
     C           *IN22     IFEQ '0'
     C                     ADD  1         W1BOX
     C                     UPDATAL#WP961
     C                     ELSE
     C                     CLEARAL#WP961
     C                     MOVEL'0'       W1TYPE
     C                     MOVELCASHID    W1SHID
     C                     MOVELCASHIT    W1SHIT
     C                     MOVELCASURT    W1SURT
     C                     MOVELCATRKB    W1TRKB
     C                     Z-ADD1         W1BOX
     C                     WRITEAL#WP961
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
      *-----------------------------------------------------
      *  AL#WP96  1 : SHID SHIT SURT IAFB
      *-----------------------------------------------------
     CSR         #SB510    BEGSR
      *
     C           KEYW1     KLIST
     C                     KFLD           KKTYPE  1
     C                     KFLD           CASHID
     C                     KFLD           CASHIT
     C                     KFLD           CASURT
     C                     KFLD           CATRKB
     C                     KFLD           CAIAFB
      *
     C                     MOVEL'1'       KKTYPE
     C           KEYW1     CHAINAL#WP961             22
     C           *IN22     IFEQ '0'
     C                     ADD  1         W1BOX
     C                     UPDATAL#WP961
     C                     ELSE
     C                     CLEARAL#WP961
     C                     MOVEL'1'       W1TYPE
     C                     MOVELCASHID    W1SHID
     C                     MOVELCASHIT    W1SHIT
     C                     MOVELCASURT    W1SURT
     C                     MOVELCATRKB    W1TRKB
     C                     MOVELCAIAFB    W1IAFB
     C                     Z-ADD1         W1BOX
     C                     WRITEAL#WP961
     C                     ENDIF
      *
     CSR         ESB510    ENDSR
      *-----------------------------------------------------
      *  AL#WP96  2 : SHID SHIT SURT IAFB IAFP
      *-----------------------------------------------------
     CSR         #SB520    BEGSR
      *
     C           KEYW2     KLIST
     C                     KFLD           KKTYPE  1
     C                     KFLD           CASHID
     C                     KFLD           CASHIT
     C                     KFLD           CASURT
     C                     KFLD           CATRKB
     C                     KFLD           CAIAFB
     C                     KFLD           CAIAFP
     C                     KFLD           CANONY
     C                     KFLD           CANKOJ
     C                     KFLD           CANUKE
     C                     KFLD           CAORD#
     C                     KFLD           CAPALT
      *
     C                     MOVEL'2'       KKTYPE
     C           KEYW2     CHAINAL#WP961             22
     C           *IN22     IFEQ '0'
     C                     ADD  1         W1BOX
     C                     UPDATAL#WP961
     C                     ELSE
     C                     CLEARAL#WP961
     C                     MOVEL'2'       W1TYPE
     C                     MOVELCASHID    W1SHID
     C                     MOVELCASHIT    W1SHIT
     C                     MOVELCASURT    W1SURT
     C                     MOVELCATRKB    W1TRKB
     C                     MOVELCAIAFB    W1IAFB
     C                     MOVELCAIAFP    W1IAFP
     C                     MOVELCANONY    W1NONY
     C                     MOVELCANKOJ    W1NKOJ
     C                     MOVELCANUKE    W1NUKE
     C                     MOVELCAORD#    W1ORD#
     C                     MOVELCAPALT    W1PALT
     C                     Z-ADD1         W1BOX
     C                     WRITEAL#WP961
     C                     ENDIF
      *
     CSR         ESB520    ENDSR
      *-----------------------------------------------------
      *  AL#WP96  5 : DETAIL
      *-----------------------------------------------------
     CSR         #SB550    BEGSR
      *
     C                     CLEARAL#WP961
     C                     MOVEL'5'       W1TYPE
     C                     MOVELCASHID    W1SHID
     C                     MOVELCASHIT    W1SHIT
     C                     MOVELCASURT    W1SURT
     C                     MOVELCATRKB    W1TRKB
     C                     MOVELCANONY    W1NONY
     C                     MOVELCANKOJ    W1NKOJ
     C                     MOVELCANUKE    W1NUKE
     C                     MOVELCAORD#    W1ORD#
     C                     MOVELCAPALT    W1PALT
     C                     Z-ADD1         W1BOX
     C                     MOVELCATOKU    W1TOKU
     C                     MOVELCACADT    W1CADT
     C                     MOVELCASUPI    W1SUPI
     C                     MOVELCASUPC    W1SUPC
     C                     MOVELCADOCK    W1DOCK
     C                     MOVELCAKNB#    W1KNB#
     C                     MOVELCAMHN     W1MHN
     C                     MOVELCALIAD    W1LIAD
     C                     MOVELCASTAD    W1STAD
     C                     MOVELCAQTBO    W1QTBO
     C                     MOVELCASUPN    W1SUPN
     C                     MOVELCAMART    W1MART
     C                     MOVELCAULDA    W1ULDA
     C                     MOVELCABOX#    W1BOX#
     C                     MOVELCABOXT    W1BOXT
     C                     MOVELCANAMC    W1NAMC
     C                     MOVELCAINKK    W1INKK
     C                     MOVELCALPOS    W1LPOS
     C                     MOVELCANAM2    W1NAM2
     C                     MOVELCANAM3    W1NAM3
     C                     MOVELCANAD5    W1NAD5
     C                     MOVELCANAD6    W1NAD6
     C                     MOVELCAFILL    W1FILL
     C                     MOVELCATERM    W1TERM
     C                     MOVELCAALL     W1ALL
     C                     MOVELCAEXTR    W1EXTR
     C                     MOVELCATRKB    W1TRKB
     C                     MOVELCAIAFB    W1IAFB
     C                     MOVELCAIAFP    W1IAFP
     C                     MOVELCAFIXD    W1FIXD
     C                     MOVELCAFIXT    W1FIXT
     C                     MOVELCATIMS    W1TIMS
     C                     MOVELCAPPUL    W1PPUL
     C                     MOVELCASAT     W1SAT
     C                     MOVELCASHN1    W1SHN1
     C                     MOVELCASHN2    W1SHN2
     C                     MOVELCASHN3    W1SHN3
     C                     MOVELCASYOT    W1SYOT
     C                     MOVELCATKR1    W1TKR1
     C                     MOVELCATKR2    W1TKR2
     C                     MOVELCATKR3    W1TKR3
     C                     MOVELCATKR4    W1TKR4
     C                     MOVELCAKADT    W1KADT
     C                     MOVELCAKATI    W1KATI
     C                     MOVELCASEQ#    W1SEQ#
     C                     MOVELCAPLDT    W1PLDT
     C                     MOVELCAPLTI    W1PLTI
     C                     MOVELCASHME    W1SHME
     C                     WRITEAL#WP961
      *
     CSR         ESB550    ENDSR
