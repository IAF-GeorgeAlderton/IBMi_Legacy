     H            Y.
     F*** ABCR10 *******************************************
     F* A CALCULATION OF HALF-FINISHED GOODS KANBAN SHEETS *
     F*            H.ITO          89.11.24                 *
     F*            H.ITO        2000.11.27                 *
     F*----------+-----+----------+-----------------------------------*
     F*2021.03.23|DCS. |T.MITSUI  | CHANGE WITH THE NUMBER OF FIGURES *
     F*          |     |          |          EXPANSION OF THE "KANBAN"*
     F****************************************************** ABCR10 ***
     I            DS
     I                                        1   2 @KCDE
     I                                        1   1 @KCD1
     I                                        2   2 @KCD2
     C*
     C           *ENTRY    PLIST
     C                     PARM           PARM1   2        LR ﾆﾍｭc
     C                     PARM           PARM2   1        nﾃﾜﾌﾞ]k 1
     C                     PARM           PARM3   2                2
     C                     PARM           PARM4   2                3
     C                     PARM           PARM5   1                4
     C                     PARM           PARM6   90       iﾞｮf]ﾈｮmbﾇc
     C                     PARM           PARM7   50       ﾆｬcﾑcﾇc
     C                     PARM           PARM8   31       ﾆbﾛﾅg LT
     C                     PARM           PARM9   31       a]ﾈﾞ] LT
     C                     PARM           PARM10  40       ﾃcpｬcﾎﾞy]
     C                     PARM           PARM11  40       ﾈbgｬcﾅg
     C                     PARM           PARM12  3        ﾍgnﾒﾇc
     C                     PARM           PARM13  3        ﾍgnﾒﾜｮn
     C                     PARM           PARM14  1        f]ﾌﾞ] jﾞb
     C                     PARM           PARM15  1              ﾆｭc
     C                     PARM           PARM16  30       a]ﾈﾞ]ubﾇc
     C                     PARM           PARM17  50       f]ﾌﾞ]ubﾇc
     C                     PARM           PARM18  20       ﾌﾃﾇc
     C                     PARM           PARM19  6        ﾆｭﾒﾍﾇﾞi
     C                     MOVE PARM14    @KCD1
     C                     MOVE PARM15    @KCD2
     C                     MOVE PARM12    @HITO   30
     C                     MOVE PARM13    #HITO   30
     C                     Z-ADDPARM8     @SLT    52
     C                     Z-ADDPARM9     @ALT    52
     C                     MOVE PARM19    @HIZ    60
     C*
     C           PARM1     IFEQ 'LR'
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C*
     C           PARM6     DIV  20        @HSU    90       ﾍajﾒ ﾈｮmbﾇc
     C           @HSU      DIV  PARM7     @HKO    93       ﾍajﾒﾌﾃﾇc
     C           @HKO      ADD  0.009     @HHK    72
     C*
     C* ﾆｭcﾒｭcﾎﾞﾍ]ﾆﾞｭcﾇc
     C*
     C           @HHK      IFLE 5
     C                     Z-ADD1         @JYO    10
     C                     ELSE
     C                     Z-ADD0         @JYO
     C                     END
     C*
     C* LT ﾃﾞcib
     C*
     C           @SLT      ADD  @ALT      @TTT    41
     C           @TTT      ADD  @JYO      @TLT    41
     C*
     C* 1ubf]ﾌﾞ]ﾉﾌﾞab
     C*
     C           @KCD2     IFEQ 'A'
     C*
     C           @HHK      MULT @TLT      @AAA   111
     C           @AAA      ADD  0.9       @BBB    90
     C           PARM18    SUB  1         @CCC    30
     C           @BBB      ADD  @CCC      @DDD    50
     C           @DDD      ADD  PARM16    @MAIS   50
     C           @MAIS     IFLT 2
     C                     Z-ADD2         PARM17
     C                     ELSE
     C                     Z-ADD@MAIS     PARM17
     C                     END
     C*
     C           PARM17    IFLT @HITO
     C           @HIZ      IFEQ 0
     C                     Z-ADD@HITO     PARM17
     C                     END
     C                     END
     C*
     C                     END
     C*
     C* jﾞbﾆｫf]ﾌﾞ]ﾉﾌﾞab
     C*
     C           @KCD2     IFEQ 'D'
     C*
     C           @HHK      MULT @TLT      @AAA   111
     C           @AAA      ADD  0.9       @BBB    90
     C           @BBB      DIV  PARM18    @EEE    61
     C           @EEE      ADD  0.9       @FFF    50
     C           @FFF      ADD  PARM16    @MAIS   50
     C           @MAIS     IFLT 2
     C                     Z-ADD2         PARM17
     C                     ELSE
     C                     Z-ADD@MAIS     PARM17
     C                     END
     C*
     C           PARM17    IFLT @HITO
     C           @HIZ      IFEQ 0
     C                     Z-ADD@HITO     PARM17
     C                     END
     C                     END
     C*
     C                     END
      *
     C                     RETRN
