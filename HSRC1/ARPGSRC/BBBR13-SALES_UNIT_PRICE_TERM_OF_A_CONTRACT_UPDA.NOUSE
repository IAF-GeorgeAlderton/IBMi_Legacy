     C           GGUCH     BEGSR
      *
     C                     SETOF                     2030
     C                     MOVE *BLANK    WWKEY
     C           WWKOJO    IFEQ *BLANK
     C           WWTOKU    SETGTBBCPL021
     C                     ELSE
     C           KEY1      SETGTBBCPL021
     C                     END
      *
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           WWKOJO    IFEQ *BLANK
     C           WWTOKU    REDPEBBCPL021                 10
     C                     ELSE
     C           KEY1      REDPEBBCPL021                 10
     C                     END
     C           *IN10     IFEQ '0'
      *
     C           BCKEY     IFEQ WWKEY
     C           BCSKJY    IFEQ 'D'
     C           BCSKHZ    ANDLEUDATE
     C                     ELSE
      *
     C           *IN20     IFEQ '1'
     C                     SETOF                     20
     C                     MOVE *BLANK    WWKEY
     C                     ELSE
      *
     C           *IN30     IFEQ '0'
     C                     SETON                     30
     C                     Z-ADDUDATE     BCKOHZ
     C                     TIME           CTIME
     C                     MOVELUS        BCKOME
     C                     Z-ADDXXENYY    BCKEYY
     C                     Z-ADDXXENMM    BCKEMM
     C                     Z-ADDXXENDD    BCKEDD
     C                     UPDATBBCPL021
     C                     END
      *
     C                     END
     C                     END
     C                     END
      *
     C           BCKEY     IFNE WWKEY
     C                     MOVE BCKEY     WWKEY
      *
     C           *IN20     IFEQ '1'
     C                     ADD  1         GALL
     C                     ADD  1         GDLT
     C                     END
      *
     C                     SETOF                     2030
     C           BCSKJY    IFEQ 'D'
     C           BCSKHZ    ANDLEUDATE
     C                     SETON                     20
     C                     ELSE
      *
     C                     SETON                     U1
     C                     ADD  1         GALL
     C                     ADD  1         GUPD
     C                     Z-ADDUDATE     BCKOHZ
     C                     TIME           CTIME
     C                     MOVELUS        BCKOME
     C                     Z-ADDWWSTYY    BCKSYY
     C                     Z-ADDWWSTMM    BCKSMM
     C                     Z-ADDWWSTDD    BCKSDD
     C                     Z-ADDWWENYY    BCKEYY
     C                     Z-ADDWWENMM    BCKEMM
     C                     Z-ADDWWENDD    BCKEDD
     C                     UPDATBBCPL021
      *
     C                     END
     C                     END
     C                     END
     C  N10                END
