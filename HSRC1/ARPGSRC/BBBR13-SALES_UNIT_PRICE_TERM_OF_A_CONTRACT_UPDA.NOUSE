     C                     PARM           @@ENHZ  8
     C                     PARM           GALL
     C                     PARM           GDLT
     C                     PARM           GUPD
     C                     PARM           RALL
     C                     PARM           RDLT
     C                     PARM           RUPD
      *
     C                     MOVE @@TOKU    WWTOKU  40
     C                     MOVE @@KOJO    WWKOJO  1
     C                     MOVE @@STHZ    WWSTHZ  80
     C                     MOVE @@ENHZ    WWENHZ  80
     C                     MOVEL*BLANK    WWKEY  28
     C                     Z-ADD0         GALL    60
     C                     Z-ADD0         GDLT    60
     C                     Z-ADD0         GUPD    60
     C                     Z-ADD0         RALL    60
     C                     Z-ADD0         RDLT    60
     C                     Z-ADD0         RUPD    60
