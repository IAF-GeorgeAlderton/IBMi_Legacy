      *     fbﾆﾍlﾞi  ﾉ  ﾈﾞ]ﾆﾞl  ･  ynxﾓ
     C           WWSTDD    IFEQ 1
     C           WWSTMM    IFEQ 1
     C           WWSTYY    SUB  1         XXENYY
     C                     Z-ADD12        XXENMM
     C                     Z-ADD31        XXENDD
     C                     GOTO SET
     C                     END
     C                     Z-ADDWWSTYY    XXENYY
     C           WWSTMM    SUB  1         XXENMM
     C                     Z-ADD31        XXENDD
     C                     GOTO SET
     C                     ELSE
     C                     Z-ADDWWSTYY    XXENYY
     C                     Z-ADDWWSTMM    XXENMM
     C           WWSTDD    SUB  1         XXENDD
     C                     END
      *
     C           SET       TAG
      *
     C           @@KUBN    IFNE 'R'
     C                     EXSR GGUCH
     C                     END
     C           @@KUBN    IFNE 'G'
     C                     EXSR RGAI
     C                     END
      *
