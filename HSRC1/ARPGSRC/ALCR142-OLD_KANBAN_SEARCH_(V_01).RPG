     H            Y.
      ** ALCR14 **********************************************
      *  OLD KANBAN SEARCH (INQ)                             *
      *  J.WATANABE 2020.05.20                               *
      ********************************************************
     FALCPW142CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     FUEXPL14 IF  E           K        DISK
      ********************************************************
     E                    MSG     1   8 60
      *
     I            DS
     I                                        1 256 D2QRA
     I                                        1  50 D2QR01
     I                                       51 100 D2QR02
     I                                      101 150 D2QR03
     I                                      151 200 D2QR04
     I                                      201 250 D2QR05
     I                                      251 256 LTR61
      *
     I            DS
     I                                        1 256 D2QRB
     I                                        1  44 LTR62
     I                                       45  94 D2QR07
     I                                       95 144 D2QR08
     I                                      145 194 D2QR09
     I                                      195 244 D2QR10
     I                                      245 256 D2QR11
      *
     I            DS
     I                                        1  14 XLOC
     I                                        1   1 L1ATK1
     I                                        2   2 PH1
     I                                        3   4 L1ATK2
     I                                        5   5 PH2
     I                                        6   7 L1ATK3
     I                                        8   8 PH3
     I                                        9   9 L1ATK4
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *-----------------------------------------------------------*
      *     M  A  I  N  L  I  N  E                                *
      *-----------------------------------------------------------*
      *
     C                     EXSR #INIT
      *
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP1
     C           W@ID      CASEQ'02'      #DSP2
     C                     ENDCS
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *************************************************************
      * DISPLAY 1ST SCREEN
      *************************************************************
     C           #DSP1     BEGSR
      *
     C                     EXFMTDSP01
     C                     MOVEL*BLANKS   XMSG
     C                     MOVE *OFF      *IN85
     C                     MOVE *OFF      *IN41
     C                     MOVE *OFF      *IN42
      * F1/F3: EXIT
     C           *INKA     IFEQ *ON
     C           *INKC     OREQ *ON
     C                     MOVEL'99'      W@ID
     C                     GOTO XDSP1
     C                     ENDIF
      *
     C                     EXSR #CHK1
      *
     C           *IN85     IFEQ *OFF
     C                     MOVEL'02'      W@ID
     C                     ENDIF
      *
     C           XDSP1     ENDSR
      *************************************************************
      *  CHECK ENTRY DATA
      *************************************************************
     C           #CHK1     BEGSR
      * CHECK DATE FROM
     C           XFROM     IFEQ *BLANK
     C                     MOVELMSG,6     XMSG
     C                     SETON                     4185
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C                     MOVE XFROM     $SRC
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$TRUE1    @FROM   80
     C                     MOVEL$TRUE2    XFROM
     C                     ELSE
     C                     MOVELMSG,1     XMSG
     C                     SETON                     4185
     C                     GOTO XCHK1
     C                     ENDIF
      * CHECK DATE TO
     C           XTO       IFEQ *BLANK
     C                     MOVELMSG,7     XMSG
     C                     SETON                     4285
     C                     GOTO XCHK1
     C                     ENDIF
      *
     C           XTO       IFEQ '99999999'
     C                     Z-ADD99999999  @TO     80
     C                     ELSE
     C                     MOVE XTO       $SRC
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN    1
     C           $RTN      IFEQ *BLANK
     C                     MOVEL$TRUE1    @TO     80
     C                     MOVEL$TRUE2    XTO
     C                     ELSE
     C                     MOVELMSG,2     XMSG
     C                     SETON                     4285
     C                     GOTO XCHK1
     C                     ENDIF
     C                     ENDIF
      *
     C           @FROM     IFGT @TO
     C                     MOVELMSG,3     XMSG
     C                     SETON                     414285
     C                     ENDIF
      * IF NO ERROR
     C           *IN85     IFEQ *OFF
     C                     EXSR #SETD
      *
     C           RRN1      IFGT 0
     C                     MOVEL'02'      W@ID
     C                     ELSE
     C                     MOVELMSG,4     XMSG
     C                     SETON                     414285
     C                     ENDIF
     C                     ENDIF
      *
     C           XCHK1     ENDSR
      *************************************************************
      *  SET DATA IN SFL01
      *************************************************************
     C           #SETD     BEGSR
      *
     C                     EXSR #CLRSF
      *
     C           @FROM     SETLLUEXPL14
      *
     C                     DO   *HIVAL
     C                     READ UEXPL14                  98
     C   98                LEAVE
      *
     C           L1CRDT    IFGT @TO
     C                     LEAVE
     C                     ENDIF
      *
     C           L1OKNG    IFNE 'NG'
     C                     ITER
     C                     ENDIF
      *
     C                     CLEARSFL01
     C                     Z-ADDL1CRDT    S1CRDT
     C                     MOVELL1CRTM    S1CRTM
      *
     C                     MOVELXLOC      S1LOC
      *
     C                     MOVELL1PRT1    S1MHN1
     C                     MOVELL1PRT2    S1MHN2
     C                     MOVELL1PRT3    S1MHN3
     C                     Z-ADDL1NDAT    S1RD1
     C                     MOVELL1NTIM    S1RT1
     C                     Z-ADDL1ODAT    S1RD2
     C                     MOVELL1OTIM    S1RT2
     C**                   MOVELL1OKNG    S1NG
     C                     MOVELL1DATA    SVDATA
      *
     C                     ADD  1         RRN1
     C                     WRITESFL01
      *
     C                     ENDDO
      *
     C                     Z-ADDRRN1      COUNT   60
      *
     C                     ENDSR
      ************************************************************
      *  DSPLAY 2ND SCREEN
      ************************************************************
     C           #DSP2     BEGSR
      *
     C                     WRITEDSP99
     C                     MOVEL'1'       *IN70
     C                     EXFMTCTL01
     C                     MOVEL*BLANKS   XMSG
     C                     MOVEL'0'       *IN85
     C                     MOVEL'0'       *IN70
      *
     C                     SELEC
      * F3: EXIT
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
      * F12: BACK
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
     C                     OTHER
     C                     EXSR #CHK2
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************
      * CLEAR SUB FILE
      *************************************************************
     C           #CLRSF    BEGSR
      *
     C                     SETON                     71
     C                     WRITECTL01
     C                     SETOF                     71
     C                     Z-ADD0         RRN1
      *
     C                     ENDSR
      *************************************************************
      *  CHECK SUB FILE
      *************************************************************
     C           #CHK2     BEGSR
      *
      *
     C           1         DO   COUNT     RRN1
      *
     C           RRN1      CHAINSFL01                50
     C           *IN50     IFEQ *OFF
     C           S1SEL     ANDNE' '
     C                     EXSR #DSP3
     C           *IN03     IFEQ *ON
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVE *BLANK    S1SEL
     C                     UPDATSFL01
      *
     C                     ENDDO
      *
     C                     ENDSR
      *************************************************************
      * DISPLAY 3RD SCREEN
      *************************************************************
     C           #DSP3     BEGSR
      *
     C                     CLEARDSP02
      *
     C                     MOVELSVDATA    D2QRA
     C                     MOVE SVDATA    D2QRB
     C                     MOVELLTR61     D2QR06
     C                     MOVE LTR62     D2QR06
      *
     C                     EXFMTDSP02
      *
     C                     ENDSR
      *************************************************************
      * INITIAL SETTING
      *************************************************************
     C           #INIT     BEGSR
      *
     C           KEY12     KLIST
     C                     KFLD           KW@YY   40
     C                     KFLD           KW@MM   20
     C                     KFLD           KW@DD   20
      *
     C                     TIME           SDATE
     C                     MOVEL*BLANKS   XMSG
     C                     MOVEL'01'      W@ID    2
     C                     MOVELTODAY     XFROM
     C                     MOVELTODAY     XTO
     C                     Z-ADD0         RRN1    40
      *
     C                     MOVE '-'       PH1
     C                     MOVE '-'       PH2
     C                     MOVE '-'       PH3
      *
     C                     ENDSR
      *************************************************************
** (ERR) (60A).....2.........3.........4.........5.........6
FROM_DATE IS INCORRECT !                                      1
TO_DATE IS INCORRECT !                                        2
FROM_DATE > TO_DATE !                                         3
NO DATA FOUND !                                               4
PRESS F5 TO PROCESS...                                        5
ENTER FROM_DATE !                                             6
ENTER TO_DATE !                                               7
                                                              8
