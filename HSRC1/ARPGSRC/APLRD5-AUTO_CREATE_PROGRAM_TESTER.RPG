     I                                        1   1 W@1
     I                                        2  11 W@KFLD
     I                                       12  13 W@2
      *####################
      *  メインルーチン *
      *####################
     C           *ENTRY    PLIST
     C                     PARM           PPGMNM 10
     C                     PARM           PPGMLB 10
     C                     PARM           PTPGM   7
     C                     PARM           PTPGMD  8
      *
     C                     MOVE '0'       @ST     1
      *
     C                     READ INPUT                    90
     C           *IN90     DOWEQ'0'                        ¬DO_01
     C           DSAST     CABEQ'*'       $LOOP
      *
     C           DSENT     IFEQ '*ENTRY'                   ~¬IF_01
     C                     EXSR #CHK
     C           *IN90     CABEQ'1'       $CRT
     C                     END                             _｢IF_01
      *
     C           $LOOP     TAG
     C                     READ INPUT                    90
     C                     END                             ｢DO_01
      *
     C           $CRT      TAG
     C           @ST       IFEQ '1'                        ¬IF_01
     C                     EXSR CRTDDS
     C                     EXSR CRTRPG
     C                     END                             ｢IF_01
     C                     SETON                     LR
     C                     RETRN
      *****************************************************
     C           #CHK      BEGSR
      *****************************************************
     C                     READ INPUT                    90
     C                     Z-ADD*ZERO     I       40
     C                     MOVE *BLANK    FDLN
     C           *IN90     DOWEQ'0'                        ¬DO_01
     C           DSAST     CABEQ'*'       $CHKL
     C           DSPAR     IFEQ 'PARM'                     ~¬IF_01
     C                     ADD  1         I
     C                     MOVE '1'       @ST
     C                     MOVE DSPFL     FDLN,I
     C                     ELSE                            -+ELSE_01
     C                     GOTO $CHKE
     C                     END                             _｢IF_01
      *
     C           $CHKL     TAG
     C                     READ INPUT                    90
     C                     END                             ｢DO_01
      *
     C           $CHKE     TAG
     C           @ST       IFEQ '1'                        ¬IF_01
     C                     SETON                     90
     C                     END                             ｢IF_01
     C                     ENDSR
      *****************************************************
     C           CRTDDS    BEGSR
      *****************************************************
     C                     Z-ADD*ZERO     SEQNO
     C                     Z-ADD*ZERO     DATE
      *
     C                     READ INPSKTD                  70
     C           *IN70     DOWEQ'0'                        ¬DO_01
      *共通
     C           DSMRK     IFEQ *BLANK                     ~¬IF_01
     C                     ADD  100       SEQNO
     C                     MOVEADSDTA     SRC
     C                     MOVEA'     '   SRC,1
     C                     EXCPTWRTDDS
     C                     END                             _｢IF_01
      * @THED
     C           DSMRK     IFEQ '@THED'                    ~¬IF_01
     C                     MOVEADSDTA     SRC
     C                     MOVEAPPGMNM    SRC,10
     C                     MOVEA'     '   SRC,1
     C                     ADD  100       SEQNO
     C                     EXCPTWRTDDS
     C                     END                             _｢IF_01
      * @PGM
     C           DSMRK     IFEQ '@PGM '                    ~¬IF_01
     C                     MOVEADSDTA     SRC
     C                     MOVEAPTPGM     SRC,46
     C                     MOVEA'     '   SRC,1
     C                     ADD  100       SEQNO
     C                     EXCPTWRTDDS
     C                     END                             _｢IF_01
      * @HED
     C           DSMRK     IFEQ '@HED'                     ~¬IF_01
     C                     MOVEADSDTA     SRC
     C                     MOVEAPPGMNM    SRC,46
     C                     MOVEA'     '   SRC,1
     C                     ADD  100       SEQNO
     C                     EXCPTWRTDDS
     C                     END                             _｢IF_01
      * @PFLD   フィールドのＳＥＴ
     C           DSMRK     IFEQ '@PFLD'                    ~¬IF_01
     C                     Z-ADD*ZERO     J       40
     C                     Z-ADD2         WKLN    40
     C                     DO   I         J                ~~¬DO_02
      *
     C           FDLN,J    CABEQ*BLANK    $PFL1
     C                     MOVE FDLN,J    WKFDLN
     C                     MOVEADSDTA     SRC
      * LINE
     C                     ADD  1         WKLN
     C                     MOVE WKLN      A$LINE
      * POSITION
     C                     MOVE '05'      A$POS
      * HEADING
     C                     MOVE ''''      W@1
     C                     MOVE WKFLD     W@KFLD
     C                     MOVE ':'''     W@2
      *
     C                     MOVELW@HDG     A$HDG
     C                     ADD  100       SEQNO
     C                     MOVEA'     '   SRC,1
     C                     EXCPTWRTDDS
      *､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､､
      * FIELD ID
     C                     MOVEADSDTA     SRC
     C                     MOVELWKFLD     A$NAME
     C                     MOVE WKLEN     A$LEN
      *
     C           WKDEC     IFEQ *BLANK                     ~~~¬IF_02
     C           WKLEN     ANDGE'  4'
     C                     MOVEL'O'       A$TYPE
     C                     ENDIF                           ___｢IF_02
      * DECIMAL POINT
     C                     MOVE WKDEC     A$DEC
     C                     MOVEL'B'       A$IOB
     C                     MOVE WKLN      A$LINE
      * POSITION
     C                     MOVE '17'      A$POS
      *
     C                     ADD  100       SEQNO
     C                     MOVEA'     '   SRC,1
     C                     EXCPTWRTDDS
      * ﾆｭcﾇc s]ﾆｬc
     C           WKDEC     IFNE *BLANK                     ~~~¬IF_02
     C                     MOVE *ALL' '   SRC
     C                     MOVELEDTL,1    A$HDG
     C                     ADD  100       SEQNO
     C                     MOVEA'     A'  SRC,1
     C                     EXCPTWRTDDS
     C                     END                             ___｢IF_02
      * LINE
     C           I         IFLE 10                         ~~~¬IF_02
     C                     ADD  1         WKLN
     C                     END                             ___｢IF_02
     C                     END                             __｢DO_02
      *
     C                     END                             _｢IF_01
      *
     C           $PFL1     TAG
     C                     READ INPSKTD                  70
     C                     END                             ｢DO_01
      *
     C                     ENDSR
      *****************************************************
     C           CRTRPG    BEGSR
      *****************************************************
     C                     Z-ADD0         SEQNO
     C                     Z-ADD0         DATE
      *
     C                     READ INPSKTR                  70
     C           *IN70     DOWEQ'0'                        ¬DO_01
      *共通
     C           DSMRK1    IFNE '@'                        ~¬IF_01
     C                     MOVEADSDTA     SRC
     C                     ADD  100       SEQNO
     C                     EXCPTWRTRPG
     C                     END                             _｢IF_01
      * @THED
     C           DSMRK     IFEQ '@THED'                    ~¬IF_01
     C                     MOVEADSDTA     SRC
     C                     MOVEAPPGMNM    SRC,10
     C                     MOVEA'     '   SRC,1
     C                     ADD  100       SEQNO
     C                     EXCPTWRTRPG
     C                     END                             _｢IF_01
      * @DSPF
     C           DSMRK     IFEQ '@DSPF'                    ~¬IF_01
     C                     MOVEADSDTA     SRC
     C                     MOVELPTPGMD    F$FILE
     C                     ADD  100       SEQNO
     C                     MOVEA'     '   SRC,1
     C                     EXCPTWRTRPG
     C                     END                             _｢IF_01
      * @PGM
     C           DSMRK     IFEQ '@PGM'                     ~¬IF_01
     C                     MOVEADSDTA     SRC
     C                     MOVE ''''      C$ITT2
     C                     MOVELPPGMNM    C$ITM2
     C                     MOVE ''''      C$ITE2
     C                     ADD  100       SEQNO
     C                     MOVEA'     '   SRC,1
     C                     EXCPTWRTRPG
     C                     END                             _｢IF_01
      * @UDS
     C           DSMRK     IFEQ '@UDS '                    ~¬IF_01
     C                     MOVEADSDTA     SRC
     C                     Z-ADD*ZERO     J
     C                     Z-ADD500       K       40
     C                     DO   I         J                ~~¬DO_02
      *
     C           FDLN,J    CABEQ*BLANK    $RPG1
     C                     MOVE FDLN,J    WKFDLN
      * FIELD ID
     C                     MOVELWKFLD     I$NAME
     C                     MOVEL'@'       I$NAME
      * FROM - TO
     C                     MOVE WKLEN     M       40
     C                     MOVE K         I$FRM
     C                     ADD  M         K
     C           K         SUB  1         L       40
     C                     MOVE L         I$TO
      * DECIMAL POINT
      *                    MOVE WKDEC     I$DP
     C                     ADD  100       SEQNO
     C                     MOVEA'     '   SRC,1
     C                     EXCPTWRTRPG
     C                     END                             __｢DO_02
     C                     END                             _｢IF_01
      *
      * @PFLD
     C           DSMRK     IFEQ '@PFLD'                    ~¬IF_01
     C                     MOVEADSDTA     SRC
     C                     Z-ADD*ZERO     J
     C                     DO   I         J                ~~¬DO_02
      *
     C           FDLN,J    CABEQ*BLANK    $RPG1
     C                     MOVE *BLANK    C$RSLT
     C                     MOVELFDLN,J    C$RSLT
     C                     ADD  100       SEQNO
     C                     MOVEA'     '   SRC,1
     C                     EXCPTWRTRPG
     C                     END                             __｢DO_02
     C                     END                             _｢IF_01
      *
      * @MVD
     C           DSMRK     IFEQ '@MVD '                    ~¬IF_01
     C                     MOVEADSDTA     SRC
     C                     Z-ADD*ZERO     J
     C                     DO   I         J                ~~¬DO_02
      *
     C           FDLN,J    CABEQ*BLANK    $RPG1
     C                     MOVE *BLANK    C$ITX2
     C                     MOVELFDLN,J    C$ITX2
     C                     MOVEL'@'       C$ITX2
     C                     MOVE '  '      C$ITX2
     C                     MOVE *BLANK    C$RSLT
     C                     MOVELFDLN,J    C$RSLT
     C                     ADD  100       SEQNO
     C                     MOVEA'     '   SRC,1
     C                     EXCPTWRTRPG
     C                     END                             __｢DO_02
     C                     END                             _｢IF_01
      *
      * @MVP
     C           DSMRK     IFEQ '@MVP '                    ~¬IF_01
