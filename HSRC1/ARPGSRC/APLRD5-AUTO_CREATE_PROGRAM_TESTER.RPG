     C                     Z-ADD*ZERO     J
     C                     DO   I         J                ~~¬DO_02
      *
     C           FDLN,J    CABEQ*BLANK    $RPG1
     C                     MOVE *BLANK    C$ITX2
     C                     MOVELFDLN,J    C$ITX2
     C                     MOVE '  '      C$ITX2
     C                     MOVE *BLANK    C$RSLT
     C                     MOVELFDLN,J    C$RSLT
     C                     MOVEL'@'       C$RSLT
     C                     ADD  100       SEQNO
     C                     MOVEA'     '   SRC,1
