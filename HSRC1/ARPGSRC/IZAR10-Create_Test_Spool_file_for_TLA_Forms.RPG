     H            Y.
     FIZAWP01 IF  E           K        DISK
     FIZAPR01 O   E                    PRINTER
      *
     I              'CHARTER STEEL'       C         CHSTL
     I              'GREEN/WHITE'         C         GW
     I              'RED'                 C         RED
      *
     I            DS
     I                                        1   60TIME
     I                                        1   20TIMHH
     I                                        3   40TIMMM
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
      *----------------------------------------------------*
      *  MAIN ROUTINE                                    *
      *----------------------------------------------------*
     C                     TIME           SDATE
      *
     C                     Z-ADD100000    HEAT#   60
     C                     Z-ADD300000    M#      60
     C                     Z-ADD*ZERO     COIL#   30
      *
     C                     READ IZAWP01                  50
     C           *IN50     DOWEQ*OFF
      *
     C           B2SMEX    IFEQ CHSTL
      *
     C                     MOVELB2SMEX    P@SPNM
     C                     WRITEP@LN11
      *
     C                     MOVELZCZAIS    P@ZAIS
     C                     WRITEP@LN12
      *
     C                     Z-ADDZCZAIK    P@ZAIK
     C                     WRITEP@LN13
      *
     C                     Z-ADDZCTKJR    P@TTLW
     C                     WRITEP@LN14
      *
     C                     MOVEL'I A F'   P@IANM
     C                     WRITEP@LN15
      *
     C                     MOVELZCZIRO    P@ZIRO
     C                     SELEC
     C           ZCZIRO    WHEQ GW
     C                     MOVEL'O'       P@ZICD
     C           ZCZIRO    WHEQ RED
     C                     MOVEL'E'       P@ZICD
     C                     OTHER
     C                     MOVEL'OTHER'   P@ZIRO
     C                     MOVEL'Z'       P@ZICD
     C                     ENDSL
     C           'WK_'     CAT  P@ZICD:0  P@OVRL
     C                     WRITEP@LN16
      *
     C                     Z-ADDSDATE     P@ORDT
     C                     WRITEP@LN17
      *
     C                     ADD  1         HEAT#
     C                     ADD  1         M#
     C                     Z-ADD1         COIL#
     C                     MOVELHEAT#     P@HHH#
     C                     MOVELM#        P@MMM#
     C                     MOVELCOIL#     P@CCC#
      *
     C                     MOVEL*BLANKS   P@BARC
     C           ZCKNO2    CAT  ZCKNO3:0  P@BARC
     C           P@BARC    CAT  'M':0     P@BARC
     C           P@BARC    CAT  P@MMM#:0  P@BARC
     C           P@BARC    CAT  P@CCC#:0  P@BARC
      * CHECK DIGIT
     C                     MOVELP@BARC    PMAREA    P
     C                     MOVE '016'     PMBYTE
     C                     MOVE *BLANK    PMCHK
     C                     MOVE *BLANK    PMRTCD
     C                     CALL 'ALBRCC'
     C                     PARM           PMAREA100
     C                     PARM           PMBYTE  3
     C                     PARM           PMCHK   1
     C                     PARM           PMRTCD  1
      *
     C           P@BARC    CAT  PMCHK:1   P@BARC
     C                     WRITEP@LN18
      *
     C           ZCKNO2    CAT  ZCKNO3:0  P@PRID
     C                     WRITEP@LN19
      *
     C                     MOVELZCADR2    P@LCN1
     C                     MOVELZCADR3    P@LCN2
     C                     WRITEP@LN20
      *
     C                     ENDIF
     C                     READ IZAWP01                  50
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      ***************************************************
