     H            Y.
     F** ESVR01 ********************************************
     F*  PROGRAM: SAVE AB#WP2I TO AB#WP2IZ                 *
     F*  WRITTEN: JW (SRA) 2020.05.28                      *
     F*----------------------------------------------------*
     FAB#WP2I IF  E                    DISK
     FAB#WP2IZO   E                    DISK
      *--------------------------------------------------------
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
      * MAIN ROUTINE
      *--------------------------------------------------------
     C                     EXSR #INIT
      *
      * SAVE AB#WP2I --------------------------------------
     C                     DO   *HIVAL
     C                     READ AB#WP2I                  98
     C   98                LEAVE
      *
     C                     Z-ADDTODAY     I2CRDT
     C                     Z-ADDNOW       I2CRTM
     C                     MOVEL#USER     I2CRUS
      **                   MOVEL#WSID     I2CRWS
     C                     MOVEL'AB#WP2I 'I2CRPF
     C                     MOVEL#WSID     LTR3    3
     C                     MOVELLTR3      I2CRMB
      * GET PL#
     C           I2CRDT    IFNE SVCRDT
     C           I2CRPF    ORNE $FILE
     C           I2CRUS    ORNE $USER
     C           I2DELY    ORNE $NONY
     C           I2SHDT    ORNE $NOHZ
     C           I2ORDR    ORNE $ODRN
     C                     Z-ADDI2CRDT    SVCRDT
     C                     MOVELI2CRDT    $CRHZ
     C                     MOVELI2CRPF    $FILE
     C                     MOVELI2CRUS    $USER
     C                     MOVELI2DELY    $NONY
     C                     MOVELI2SHDT    $NOHZ
      *
     C                     SELEC
     C           I2DELY    WHEQ '0567'
     C                     MOVELI2RELS    LTR13  13
     C                     MOVE LTR13     $ODRN
     C                     OTHER
     C                     MOVELI2ORDR    $ODRN
     C                     ENDSL
      *
     C                     CALL 'UTLR51B'
     C                     PARM           $CRHZ
     C                     PARM           $FILE
     C                     PARM           $USER
     C                     PARM           $NONY
     C                     PARM           $NOHZ
     C                     PARM           $ODRN
     C                     PARM           $PICK#
     C                     ENDIF
     C                     MOVEL$PICK#    I2CRWS
      *
     C                     WRITEAB#WP2ZR
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------------
      * INITIAL SETTING
      *--------------------------------------------------------
     C           #INIT     BEGSR
      *
     C                     TIME           SDATE
      *
     C                     Z-ADD0         SVCRDT  80
     C                     MOVE *BLANK    $CRHZ   8
     C                     MOVE *BLANK    $FILE  10
     C                     MOVE *BLANK    $USER  10
     C                     MOVE *BLANK    $NONY   4
     C                     MOVE *BLANK    $NOHZ   8
     C                     MOVE *BLANK    $ODRN  10
     C                     MOVE *BLANK    $PICK#  9
      *
     C                     ENDSR
