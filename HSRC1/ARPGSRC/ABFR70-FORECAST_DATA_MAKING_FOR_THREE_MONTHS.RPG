      *検索用KEY定義
     C           KEYHIN    KLIST
     C                     KFLD           #KHIN1  5
     C                     KFLD           #KHIN2  5
     C                     KFLD           #KHIN3  2
      *
     C           KEYSAV    KLIST
     C                     KFLD           #KSHN1  5
     C                     KFLD           #KSHN2  5
     C                     KFLD           #KSHN3  2
      *
     C           KEYF81    KLIST
     C                     KFLD           #KHYY   40
     C                     KFLD           #KHMM   20
      *----------------------------------------------------*
      *  メインルーチン                                  *
      *----------------------------------------------------*
     C                     EXSR $SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR $SB200
     C                     ENDDO
     C                     EXSR $SB300
      *----------------------------------------------------*
      *   初期処理                                       *
      *----------------------------------------------------*
     CSR         $SB100    BEGSR
     C                     TIME           W$TIME
     C                     MOVE '01'      DSPSW   2
      *
     C                     MOVE W$HDD     @@HDD
     C                     MOVE W$HMM     @@HMM
     C                     MOVE W$HDD     @@HYY
     C                     Z-ADD0         @HYM
      *
     CSR         $S100E    ENDSR
      *----------------------------------------------------*
      *   主処理                                         *
      *----------------------------------------------------*
     CSR         $SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR $SB210
     C                     ENDDO
     C           DSPSW     DOWEQ'02'
     C                     EXSR $SB220
     C                     ENDDO
     CSR         $S200E    ENDSR
      *----------------------------------------------------*
      *   照会データ検索                                 *
      *----------------------------------------------------*
     CSR         $SB210    BEGSR
      *
     C                     EXFMTABFPW701
     C                     SETOF                     9931
     C                     MOVE *BLANK    @ERR
      * CMD-1
     C           *IN01     IFEQ '1'
     C                     MOVE '99'      DSPSW   2
     C                     GOTO $S210E
     C                     END
      *
      *入力項目チェック
      *
     C           @HYM      IFEQ 0
     C                     SETON                     9931
     C                     MOVELER,1      @ERR
     C                     GOTO $S210E
     C                     END
      *
     C                     Z-ADD0         @1NS    31
     C                     Z-ADD0         @2NS    31
     C                     Z-ADD0         @3NS    31
      * N
     C                     MOVE @HYY      #KHYY
     C                     MOVE @HMM      #KHMM
     C                     MOVE @HMM      @1N
     C                     Z-ADD0         CTRNS   31
     C                     EXSR $SB900
     C           CTRNS     IFEQ 0
     C                     SETON                     9931
     C                     SETOF                     05
     C                     MOVELER,2      @ERR
     C                     GOTO $S210E
     C                     END
     C                     Z-ADDCTRNS     @1NS    31
     C                     Z-ADDCTRNS     @1NSB
      * N+1
     C                     MOVE @HYY      @1HYY   40
     C                     MOVE @HMM      @1HMM   20
     C                     ADD  1         @1HMM
     C           @1HMM     IFGT 12
     C                     ADD  1         @1HYY
     C                     SUB  12        @1HMM
     C                     END
     C                     MOVE @1HYY     #KHYY
     C                     MOVE @1HMM     #KHMM
     C                     MOVE @1HMM     @2N
     C                     Z-ADD0         CTRNS   31
     C                     EXSR $SB900
     C                     Z-ADDCTRNS     @2NS    31
     C                     Z-ADDCTRNS     @2NSB
      * N+2
     C                     MOVE @HYY      @2HYY   40
     C                     MOVE @HMM      @2HMM   20
     C                     ADD  2         @2HMM
     C           @2HMM     IFGT 12
     C                     ADD  1         @2HYY
     C                     SUB  12        @2HMM
     C                     END
     C                     MOVE @2HYY     #KHYY
     C                     MOVE @2HMM     #KHMM
     C                     MOVE @2HMM     @3N
     C                     Z-ADD0         CTRNS   31
     C                     EXSR $SB900
     C                     Z-ADDCTRNS     @3NS    31
     C                     Z-ADDCTRNS     @3NSB
      *
     C                     MOVE '02'      DSPSW   2
      *
     CSR         $S210E    ENDSR
      *----------------------------------------------------*
      *   稼働日設定                                     *
      *----------------------------------------------------*
     CSR         $SB220    BEGSR
      *
     C                     EXFMTABFPW702
     C                     SETOF                     313233
     C                     SETOF                     99
     C                     MOVE *BLANK    @ERR
      * CMD-3
     C           *IN03     IFEQ '1'
     C                     MOVE '01'      DSPSW   2
     C                     GOTO $S220E
     C                     ENDIF
      *
     C                     Z-ADD@1NS      WKNS    31
     C                     EXSR $SB221
     C           *IN99     IFEQ '1'
     C                     SETON                     9931
     C                     GOTO $S220E
     C                     ENDIF
      *
     C                     Z-ADD@2NS      WKNS    31
     C                     EXSR $SB221
     C           *IN99     IFEQ '1'
     C                     SETON                     9932
     C                     GOTO $S220E
     C                     ENDIF
      *
     C                     Z-ADD@3NS      WKNS    31
     C                     EXSR $SB221
     C           *IN99     IFEQ '1'
     C                     SETON                     9933
     C                     GOTO $S220E
     C                     ENDIF
      *
      *--------------------*
      *  DATA MAKING       *
      *--------------------*
      * CMD-5
     C           *IN05     IFEQ '1'
     C                     MOVE '99'      DSPSW   2
      *
     C                     SETOF                       88
     C           *LOVAL    SETLLFCEPL011
     C                     DO   *HIVAL
     C                     READ FCEPL011                 88
     C   88                LEAVE
      *
     C           A2GSKD    IFEQ 'D'
     C           A2GSHZ    ANDLE*DATE
     C                     ITER
     C                     END
      *--------------------------------*
      * AMOUNT EACH DAY CALCULATION    *
      *--------------------------------*
     C                     MOVE *ALL'0'   FCGK
     C                     MOVE *ALL'0'   FCCD
     C                     MOVE A2BHB1    #KHIN1
     C                     MOVE A2BHB2    #KHIN2
     C                     MOVE A2BHB3    #KHIN3
     C                     Z-ADD20.0      @@NISU  31
     C                     SETOF                       21
     C           KEYHIN    CHAINFCEPL11              21
     C           *IN21     IFEQ '0'
     C           FCSKJY    ANDEQ'D'
     C           FCSKHZ    ANDLE*DATE
     C                     SETON                       21
     C                     END
     C           *IN21     IFEQ '0'
      *
     C                     Z-ADD1         I       20
     C           1         DO   10        I
     C           FCGK,I    IFNE 0
     C                     Z-ADDFCCD,I    @@NISU
     C                     LEAVE
     C                     END
     C                     ENDDO
      *
     C                     END
      *
     C                     Z-ADD0         WKGEKN
     C           A2GEKN    DIV  @@NISU    WKGEKN  90
     C                     MVR            WKHASU  90
     C           WKHASU    IFNE 0
     C                     ADD  1         WKGEKN
     C                     END
     C           WKGEKN    IFEQ 0
     C                     Z-ADD1         WKGEKN
     C                     END
      *
     C                     Z-ADDA2KSYS    @SYSS   50
     C           *DATE     IFGE A2SYHZ
     C                     Z-ADDA2SSYS    @SYSS
     C                     END
      *
     C                     MOVE A2BHB1    #KSHN1
     C                     MOVE A2BHB2    #KSHN2
     C                     MOVE A2BHB3    #KSHN3
      *
     C                     EXSR $SB500
     C           KEYSAV    SETGTFCEPL011
      *
     C                     ENDDO
      *
     C                     END
      *
     CSR         $S220E    ENDSR
      *----------------------------------------------------*
      *   稼働日設定チェック                             *
      *----------------------------------------------------*
     CSR         $SB221    BEGSR
      *
     C           WKNS      IFEQ 0
     C                     MOVELER,3      @ERR
     C                     SETON                     99
     C                     ENDIF
      *
     C           WKNS      IFGT 31
     C                     MOVELER,3      @ERR
     C                     SETON                     99
     C                     ENDIF
      *
     C           WKNS      DIV  0.5       AAA     30
     C                     MVR            BBB     31
     C           BBB       IFNE 0
     C                     MOVELER,4      @ERR
     C                     SETON                     99
     C                     ENDIF
      *
     CSR         $S221E    ENDSR
      *----------------------------------------------------*
      *   終了処理                                       *
      *----------------------------------------------------*
     CSR         $SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         $S300E    ENDSR
      *----------------------------------------------------*
      *   KANBAN CHECK                                     *
      *----------------------------------------------------*
     CSR         $SB500    BEGSR
     C                     MOVE *BLANK    W@KSEI  1
     C                     MOVE A2BHB1    #KHIN1
     C                     MOVE A2BHB2    #KHIN2
     C                     MOVE A2BHB3    #KHIN3
     C                     EXSR $SB600
     C   99                EXSR $SB601
     C   99                EXSR $SB602
     C  N99                EXSR $SB510
      *
     C                     MOVE *BLANK    W@KSEI
     C                     Z-ADD1         X       20
     C           1         DO   4         X
     C                     SETOF                     21
     C           KHN,X     IFNE *BLANK
     C                     MOVE '1'       W@KSEI
     C                     MOVE KHN,X     WKHIN
     C                     MOVE WKHN1     #KHIN1
     C                     MOVE WKHN2     #KHIN2
     C                     MOVE WKHN3     #KHIN3
     C                     EXSR $SB600
     C   99                EXSR $SB601
     C   99                EXSR $SB602
     C  N99                EXSR $SB510
     C                     END
     C                     ENDDO
      *
     CSR         $S500E    ENDSR
      *----------------------------------------------------*
      *   FORECAST DATA MAKING THREE MONTHS                *
      *----------------------------------------------------*
     CSR         $SB510    BEGSR
     C                     CLEARABFPP701
      *
     C           W@KSEI    IFEQ '1'
     C                     SETOF                     25
     C           KEYHIN    CHAINFCEPL011             25
     C           *IN25     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                       25
     C                     END
     C  N25                GOTO $S510E
     C                     END
      *
     C                     MOVE W$HYY     AXKOYY
     C                     MOVE W$HMM     AXKOMM
     C                     MOVE W$HDD     AXKODD
     C                     MOVE W$TIMH    AXKOJI
     C                     MOVE W$TIMM    AXKOFN
     C                     MOVEL@@USER    AXKOME
     C                     MOVEL'ABFR70'  AXPGMN
     C                     MOVE A2SEHI    AXSEHI
     C                     MOVE #KHIN1    AXBHB1
     C                     MOVE #KHIN2    AXBHB2
     C                     MOVE #KHIN3    AXBHB3
     C                     Z-ADDA2GEKN    AXGEKN
     C                     Z-ADD@1NS      AX1DAY
     C                     Z-ADD@2NS      AX2DAY
     C                     Z-ADD@3NS      AX3DAY
     C           WKGEKN    MULT @1NS      AX1SRY    H
     C           WKGEKN    MULT @2NS      AX2SRY    H
     C           WKGEKN    MULT @3NS      AX3SRY    H
     C                     MOVE @HYM      AXHYM
      *
     C                     Z-ADD@SYSS     AXSYSS
     C                     MOVE A2KTRK    AXTKR1
     C                     MOVE A2KTRT    AXTKR2
     C                     MOVE A2KTRR    AXTKR3
     C                     MOVE A2KTRD    AXTKR4
     C           *DATE     IFGE A2TRHZ
     C                     MOVE A2STRK    AXTKR1
     C                     MOVE A2STRT    AXTKR2
     C                     MOVE A2STRR    AXTKR3
     C                     MOVE A2STRD    AXTKR4
     C                     END
      *
     C                     WRITEABFPP701
     C                     Z-ADD0         @SYSS
      *
     CSR         $S510E    ENDSR
      *----------------------------------------------------*
      * COMPLETION HALF-FINISHED GOODS KANBAN M/F (AAPTL01)*
      *----------------------------------------------------*
     CSR         $SB600    BEGSR
     C                     SETOF                     81
     C                     SETON                     99
     C           KEYHIN    SETGTAAPTL011
      *
     C                     DO   *HIVAL
     C           KEYHIN    REDPEAAPTL011                 81
     C   81                LEAVE
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    ANDLE*DATE
     C                     ITER
     C                     END
      *
     C           *DATE     IFGE L5UKHZ
     C           *DATE     ANDLEL5STHZ
     C                     ELSE
     C                     ITER
     C                     END
     C           L5BMON    IFEQ 8990
     C                     SETOF                     99
     C                     LEAVE
     C                     END
      *
     C                     ENDDO
     CSR         $S600E    ENDSR
      *----------------------------------------------------*
      * COMPONENTS KANBAN M/F (AKBPL04)                    *
      *----------------------------------------------------*
     CSR         $SB601    BEGSR
     C                     SETOF                     81
     C           KEYHIN    SETGTAKBPL041
      *
     C                     DO   *HIVAL
     C           KEYHIN    REDPEAKBPL041                 81
     C   81                LEAVE
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    ANDLE*DATE
     C                     ITER
     C                     END
      *
     C           *DATE     IFGE L1UKHZ
     C           *DATE     ANDLEL1STHZ
     C                     ELSE
     C                     ITER
     C                     END
     C           L1BMON    IFEQ 8990
     C                     SETOF                     99
     C                     LEAVE
     C                     END
      *
     C                     ENDDO
     CSR         $S601E    ENDSR
      *----------------------------------------------------*
      * HALF-FINISHED GOODS KANBAN M/F (AANPL06)           *
      *----------------------------------------------------*
     CSR         $SB602    BEGSR
     C                     SETOF                     81
     C           KEYHIN    SETGTAANPL061
      *
     C                     DO   *HIVAL
     C           KEYHIN    REDPEAANPL061                 81
     C   81                LEAVE
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    ANDLE*DATE
     C                     ITER
     C                     END
      *
     C           *DATE     IFGE L7UKHZ
     C           *DATE     ANDLEL7STHZ
     C                     ELSE
     C                     ITER
     C                     END
     C           L7BMON    IFEQ 8990
     C                     SETOF                     99
     C                     LEAVE
     C                     END
      *
     C                     ENDDO
     CSR         $S602E    ENDSR
      *----------------------------------------------------*
      * THE NUMBER OF OPERATING DAYS CALCULATION           *
      *----------------------------------------------------*
     CSR         $SB900    BEGSR
     C           KEYF81    SETLLAGDPL121
     C                     SETOF                     81
     C                     DO   *HIVAL
     C           KEYF81    READEAGDPL121                 81
     C   81                LEAVE
      *
     C           F8HIRU    IFEQ *BLANK
     C                     ADD  .5        CTRNS
     C                     END
      *
     C           F8YORU    IFEQ *BLANK
     C                     ADD  .5        CTRNS
     C                     END
      *
     C                     ENDDO
     CSR         $S900E    ENDSR
