     C*************************
     C* 1.0                   *
     C*第１画面の処理       *
     C*************************
     C           $100S     TAG
     C                     EXFMTAUBPW541
     C                     SETOF                     101112
     C                     SETOF                     131470
     C                     SETOF                     1599
     C                     MOVE *BLANK    @ERR
     C           *INKA     IFEQ '1'
     C                     SETON                       LR
     C                     RETRN
     C                     END
     C           *INKC     IFEQ '1'
     C                     MOVE '3'       PARM2   1
     C                     MOVE *ZERO     @KCODE
     C                     MOVE *BLANK    @JOKEN
     C                     MOVE *BLANK    @YN
     C                     MOVE *BLANK    @PRINT
     C                     MOVE *ZERO     @HY
     C                     MOVE *ZERO     @HM
     C                     MOVE *ZERO     @HD
     C                     MOVE *ZERO     @BB
     C                     SETOF                       99
     C                     SETON                       LR
     C                     RETRN
     C                     END
     C*===== 日付のチエック =====*
     C                     MOVE @HY       WY
     C                     MOVE @HM       WM
     C                     MOVE @HD       WD
     C                     MOVE *ZERO     WB
     C                     MOVE WYMD      WHYMD   80
     C           WYMD      IFNE *ZERO
     C                     EXSR $SB200
     C           *IN90     IFEQ '1'
     C           *IN98     OREQ '1'
     C                     MOVEL$MSG,4    @ERR
     C                     SETON                     1199
     C                     GOTO $100S
     C                     END
     C                     END
     C*===== メッキ部門コードチェック=====*
     C           @KCODE    CHAINFGBPL011             10
     C           *IN10     IFEQ '1'
     C                     MOVEL$MSG,1    @ERR
     C                     SETON                       99
     C                     GOTO $100S
     C                     END
     C                     MOVE @KCODE    #KCODE
     C           #KEY      CHAINAS#PL161             71
     C           *IN71     IFEQ '1'
     C                     SETON                     1099
     C                     MOVEL$MSG,6    @ERR
     C                     GOTO $100S
     C                     END
     C*===== 条件のチエック=====*
     C           @JOKEN    IFNE 'A'
     C           @JOKEN    IFNE 'B'
     C           @JOKEN    IFNE 'C'
     C                     MOVEL$MSG,3    @ERR
     C                     SETON                     1399
     C                     GOTO $100S
     C                     END
     C                     END
     C                     END
     C           @JOKEN    IFEQ 'A'
     C           @JOKEN    OREQ 'B'
     C           WHYMD     IFEQ *ZERO
     C                     SETON                     1299
     C                     MOVEL$MSG,8    @ERR
     C                     GOTO $100S
     C                     END
     C                     END
     C*===== ＹＮチエック=====*
     C           @YN       IFNE 'Y'
     C           @YN       IFNE 'N'
     C                     MOVEL$MSG,5    @ERR
     C                     SETON                     1499
     C                     GOTO $100S
     C                     END
     C                     END
     C           @PRINT    IFNE 'Y'
     C           @PRINT    IFNE 'N'
     C                     MOVEL$MSG,5    @ERR
     C                     SETON                     1599
     C                     GOTO $100S
     C                     END
     C                     END
     C           @PRINT    IFEQ 'Y'
     C                     MOVE *BLANK    PSW1
     C                     EXSR $SB300
     C                     END
     C**********************
     C* 2.0                *
     C*第２画面項目セット*
     C**********************
     C                     SETOF                     81
     C                     MOVE *ZERO     X       20
     C                     MOVE *ZERO     CTRX    60
     C                     MOVE @KCODE    #KCODE
     C                     MOVELWYMD      #INHZ
     C                     MOVE @BB       #INBB
     C           @JOKEN    IFEQ 'A'
     C           #KEY1     SETGTAS#PL161
     C                     END
     C           @JOKEN    IFEQ 'C'
     C           WYMD      IFEQ *ZERO
     C           #KEY      SETLLAS#PL161
     C                     ELSE
     C           #KEY1     SETLLAS#PL161
     C                     END
     C                     END
     C           @JOKEN    IFEQ 'B'
     C           @BB       IFEQ *ZERO
     C           #KEY2     SETLLAS#PL161
     C                     ELSE
     C           #KEY1     SETLLAS#PL161
     C                     END
     C                     END
     C********************
     C*  FILE READ       *
     C********************
     C                     MOVEA'000000'  *IN,10
     C                     SETOF                     313233
     C                     Z-ADD0         IN      20
     C                     Z-ADD15        I       20
     C           RETRY     TAG
     C           *IN81     DOWEQ'0'
     C           @JOKEN    IFEQ 'A'
     C                     READPAS#PL161                 81
     C                     END
     C           @JOKEN    IFEQ 'B'
     C           @BB       IFEQ *ZERO
     C           #KEY2     READEAS#PL161                 81
     C                     ELSE
     C           #KEY1     READEAS#PL161                 81
     C                     END
     C                     END
     C           @JOKEN    IFEQ 'C'
     C                     READ AS#PL161                 81
     C                     END
     C           *IN81     CABEQ'1'       DSPLAY
     C           @JOKEN    IFEQ 'A'
     C           @JOKEN    OREQ 'C'
     C           #KCODE    IFEQ CUKAKO
     C                     ELSE
     C                     SETON                       81
     C                     GOTO DSPLAY
     C                     END
     C                     END
     C                     MOVE *BLANK    WKA
     C                     MOVE *BLANK    WKB
     C*************************
     C* 画面明細編集        *
     C*************************
     C*==== (@YN=N) vﾉc ﾌﾞ]fb ====*
     C           @YN       IFEQ 'N'
     C           CUBNHZ    IFNE *ZERO
     C           WKMKHZ    IFLT MINOU
     C                     MOVE '*'       WKA     1
     C                     END
     C                     END
     C           CUSMHZ    IFNE *ZERO
     C           WKMKHZ    IFLT MSAI
     C                     MOVE '*'       WKB     1
     C                     END
     C                     END
     C           WKA       IFEQ *BLANK
     C           WKB       ANDEQ*BLANK
     C                     GOTO RETRY
     C                     END
     C                     END
     C*==== (@YN=Y) vﾉc ﾉv ====*
     C           @YN       IFEQ 'Y'
     C           CUBNHZ    IFNE *ZERO
     C           CUMKHZ    IFEQ *DATE
     C           CUBNHZ    ANDEQ*DATE
     C           CUMKBB    IFLT CUBNBB
