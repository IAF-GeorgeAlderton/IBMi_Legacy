     C                     END
     C                     END
     C           CUMKHZ    IFEQ *DATE
     C           CUBNHZ    ANDEQ*DATE
     C           CUMKBB    ANDEQCUBNBB
     C                     MOVE *BLANK    WKA
     C                     END
     C           CUSMHZ    IFNE *ZERO
     C           CUMKHZ    IFEQ *DATE
     C           CUSMHZ    ANDEQ*DATE
     C           CUMKBB    IFLT CUSMBB
     C                     MOVE '*'       WKB
     C                     END
     C                     END
     C           CUMKHZ    IFLE *DATE
     C           CUSMHZ    ANDGE*DATE
     C                     MOVE '*'       WKB
     C                     END
     C                     END
     C           CUSMHZ    IFEQ *DATE
     C           CUMKHZ    ANDEQ*DATE
     C           CUMKBB    ANDEQCUSMBB
     C                     MOVE *BLANK    WKB
     C                     END
     C           WKA       IFEQ *BLANK
     C           WKB       ANDEQ*BLANK
     C                     GOTO RETRY
     C                     END
     C                     END
