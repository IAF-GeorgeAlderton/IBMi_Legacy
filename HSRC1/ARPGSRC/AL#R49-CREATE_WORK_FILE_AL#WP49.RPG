     H            Y.
     F** AL#R49  *******************************************
     F*未発行データからワーク作成                        *
     F*      ITS.        2015.05.26                        *
     F******************************************************
     FAL#PL41 IF  E           K        DISK
     FAL#WP49 UF  E           K        DISK                      A
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      *
     C           KEYC1     KLIST
     C                     KFLD           KKKADT  80
     C                     KFLD           KKKATI  60
      *発行前
     C                     Z-ADD0         KKKADT
     C                     Z-ADD0         KKKATI
     C           KEYC1     SETLLAL#PL411
     C           KEYC1     READEAL#PL411                 81
     C           *IN81     DOWEQ'0'
     C           C4SKJY    IFEQ 'D'
     C           C4SKHZ    ANDLESDATE
     C                     ELSE
     C                     EXSR #SB500
     C                     ENDIF
     C           KEYC1     READEAL#PL411                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AL#WP49
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C           KEYW0     KLIST
     C                     KFLD           C4FIXD
     C                     KFLD           C4FIXT
     C                     KFLD           C4TRKB
     C                     KFLD           C4IAFB
      *
     C           KEYW0     CHAINAL#WP491             22
     C           *IN22     IFEQ '0'
     C           C4SHID    IFEQ W9SHI1
     C           C4SHID    OREQ W9SHI2
     C           C4SHID    OREQ W9SHI3
     C                     ELSE
     C                     EXSR #SB511
     C                     ENDIF
     C                     ADD  C4BOX     W9BOX
     C                     ADD  1         W9KPLT
     C                     UPDATAL#WP491
     C                     ELSE
     C                     CLEARAL#WP491
     C                     MOVEL*BLANK    W9SEL
     C                     MOVELC4SURT    W9SURT
     C                     Z-ADDC4EXTR    W9EXTR
     C                     Z-ADDC4FIXD    W9FIXD
     C                     Z-ADDC4FIXT    W9FIXT
     C                     Z-ADDC4TIMS    W9TIMS
     C                     MOVELC4SHID    W9SHI1
     C                     Z-ADDC4BOX     W9BOX
     C                     Z-ADD1         W9KPLT
     C                     MOVELC4TRKB    W9TRKB
     C                     MOVELC4IAFB    W9IAFB
     C                     WRITEAL#WP491
     C                     ENDIF
      *
     CSR         ESB500    ENDSR
      *-----------------------------------------------------
      *  AL#WP49
      *-----------------------------------------------------
     CSR         #SB511    BEGSR
      *
     C                     SELEC
     C           W9SHI1    WHEQ *BLANK
     C                     MOVELC4SHID    W9SHI1
     C           W9SHI2    WHEQ *BLANK
     C                     MOVELC4SHID    W9SHI2
     C           W9SHI3    WHEQ *BLANK
     C                     MOVELC4SHID    W9SHI3
     C                     ENDSL
      *
     CSR         ESB511    ENDSR
