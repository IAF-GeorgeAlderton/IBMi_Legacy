     H            Y.
      * MBER31 *****************************************************************
      * DOWNLOAD SALES RESULT (OUT TO CSV)                                     *
      * J.WATANABE  2018.03.06                                                 *
      **************************************************************************
     FMBEWP30 IF  E           K        DISK
     FMBEWP31 O   E                    DISK
      *------------------------------------------------------------
     E                    TB      1   6 20
     I* SYSTEM TIME
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C                     EXSR #INIT
      *
     C                     DO   *HIVAL
     C                     READ MBEWP30                  95
     C   95                LEAVE
      * BILL DATE
     C                     CLEARMBEWP311
     C                     MOVELM3URHZ    $DATE1
     C                     MOVE 'YMD'     $YMD
     C                     MOVE '/'       $SEP    1
     C                     CALL 'EDTR01A'
     C                     PARM           $DATE1  8
     C                     PARM           $YMD    3
     C                     PARM           $SEP    1
     C                     PARM           $DATE2 10
     C                     MOVEL$DATE2    MXURHZ
      * CUST#
     C                     MOVELM3TOKU    $IN
     C                     MOVEL'04'      $LONG
     C                     CALL 'EDTR04A'
     C                     PARM           $IN    10
     C                     PARM           $LONG   2
     C                     PARM           $OUT   11
     C                     MOVEL$OUT      MXTOKU
      * DELV#
     C                     MOVELM3NONY    $IN
     C                     MOVEL'04'      $LONG
     C                     CALL 'EDTR04A'
     C                     PARM           $IN    10
     C                     PARM           $LONG   2
     C                     PARM           $OUT   11
     C                     MOVEL$OUT      MXNONY
      * SHIP DATE
     C                     MOVELM3NOHZ    $DATE1
     C                     MOVE 'YMD'     $YMD
     C                     MOVE '/'       $SEP    1
     C                     CALL 'EDTR01A'
     C                     PARM           $DATE1  8
     C                     PARM           $YMD    3
     C                     PARM           $SEP    1
     C                     PARM           $DATE2 10
     C                     MOVEL$DATE2    MXNOHZ
      * BIN#
     C                     MOVELM3NOBN    MXNOBN
     C                     MOVELM3ODRN    MXODRN
     C                     MOVELM3INVN    MXINVN
     C                     MOVELM3SRYO    MXSRYO
     C                     MOVELM3SYOS    MXSYOS
     C                     MOVELM3BOX     MXBOX
      * UNIT PRICE
     C                     Z-ADDM3UP      $IN2
     C                     CALL 'EDTR05A'
     C                     PARM           $IN2   156
     C                     PARM           $TRUE  17
     C                     PARM           $RTN    1
     C                     MOVEL$TRUE     MXUP
      * AMOUNT
     C                     Z-ADDM3AMT     $IN2
     C                     CALL 'EDTR05A'
     C                     PARM           $IN2   156
     C                     PARM           $TRUE  17
     C                     PARM           $RTN    1
     C                     MOVEL$TRUE     MXAMT
      * USER PART#
     C                     MOVELM3MHIN    $MHIN
     C                     CALL 'EDTR02A'
     C                     PARM           $MHIN  20
     C                     PARM           $MHIN2 23
     C                     MOVEL$MHIN2    MXMHIN
      * IAF PART#
     C                     MOVELM3SHIN    $SHIN
     C                     CALL 'EDTR02'
     C                     PARM           $SHIN  12
     C                     PARM           $SHIN2 14
     C                     MOVEL$SHIN2    MXSHIN
      *
     C                     MOVELM3NUKE    MXNUKE
     C                     WRITEMBEWP311
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      **************************************************************************
      * INITIALIZE
      **************************************************************************
     C           #INIT     BEGSR
      * HEADER
     C                     CLEARMBEWP311
     C                     MOVELTB,1      MXURHZ
     C                     MOVEL'CUST#   'MXTOKU
     C                     MOVEL'DELIV#  'MXNONY
     C                     MOVELTB,2      MXNOHZ
     C                     MOVEL'BIN#    'MXNOBN
     C                     MOVEL'ORDER#  'MXODRN
     C                     MOVEL'INVOICE#'MXINVN
     C                     MOVEL'QTY     'MXSRYO
     C                     MOVEL'Q/C     'MXSYOS
     C                     MOVEL'BOX     'MXBOX
     C                     MOVELTB,3      MXUP
     C                     MOVEL'AMOUNT  'MXAMT
     C                     MOVELTB,4      MXMHIN
     C                     MOVELTB,5      MXSHIN
     C                     MOVEL'DOCK    'MXNUKE
     C                     MOVELTB,6      MXFLD1
     C                     WRITEMBEWP311
      *
     C                     ENDSR
** TB (20A) .......2
BILLED_DATE           01
SHIP_DATE             02
UNIT_PRICE            03
USER_PART#            04
IAF_PART#             05
PGM: MBER31           06
