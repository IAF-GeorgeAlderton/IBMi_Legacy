      *** GDLR01 ******************************************
      *   UNIT PRICE MASTER UPDATE(MATERIAL)              *
      *   TCH(N.HYOTO) 2000.12.13                         *
      *****************************************************
     H            Y/                                    1
     F*
     FGDLPW81 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL01
      *        DETAIL CODE MANAGEMENT RECORD .LAYOUT ..LOGICAL FILE .. *
     FFGBPL01 IF  E           K        DISK
      * AOYAMA PRODUCTION PLACE CALENDAR FILE(INCLUDE HOLIDAY)
     FAGDPL12 IF  E           K        DISK
      * FINISHED MATERIAL KANBAN MASTER    *
     FIZAPL01 IF  E           K        DISK
      * ROD MATERIAL KANBAN MASTER  *
     FIZBPL01 IF  E           K        DISK
      * MATERIAL UNIT PRICE MASTER     *
     FGDLPL80 UF  E           K        DISK                      A
     F*
     E*================================================================
     E                    NAME    1   3 10
     E                    MSG     1  12 59
     I*================================================================
     I            DS
     I                                        1   60W@TIME
     I                                        1   40W@HM
     I*  SAKUJYO
     I            DS
     I                                        1   80LHSKDT
     I                                        1   40LHSKYY
     I                                        5   60LHSKMM
     I                                        7   80LHSKDD
     I*  KOUSINN
     I            DS
     I                                        1   80LHKODT
     I                                        1   40LHKOYY
     I                                        5   60LHKOMM
     I                                        7   80LHKODD
     I*
     I            DS
     I                                        1   40LHKOHS
     I                                        1   20LHKOHH
     I                                        3   40LHKOSS
     I* START DATE(SAVE FILE DATA BEFORE UPDATING)
     I            DS
     I                                        1   80@@STDT
     I                                        1   40W2STYY
     I                                        5   60W2STMM
     I                                        7   80W2STDD
     I* STARTING DATE *
     I            DS
     I                                        1   80S1STDT
     I                                        1   40S1STYY
     I                                        5   60S1STMM
     I                                        7   80S1STDD
     I* STARTING DATE (MASTER FILE)
     I            DS
     I                                        1   80LHSTHZ
     I                                        1   40LHSTYY
     I                                        5   60LHSTMM
     I                                        7   80LHSTDD
     I* ENDING DATE *
     I            DS
     I                                        1   80S1ENDT
     I                                        1   40S1ENYY
     I                                        5   60S1ENMM
     I                                        7   80S1ENDD
     I            DS
     I                                        1   80F8DATE
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     I* ENDING DATE (MASTER FILE)
     I            DS
     I                                        1   80LHENHZ
     I                                        1   40LHENYY
     I                                        5   60LHENMM
     I                                        7   80LHENDD
     I* DATE *
     I            DS
     I                                        1   80WWYMD
     I                                        1   40WWYY
     I                                        5   60WWMM
     I                                        7   80WWDD
     C*================================================================
     C*           PARM LIST                                          *
     C*================================================================
     C           *ENTRY    PLIST
     C                     PARM           PPUSER 10
     C*================================================================
     C*           KEY LIST                                           *
     C*================================================================
     C* FINISHED MATERIAL MASTER (IZAPL01)
     C           KEY1      KLIST
     C                     KFLD           D1WIRE
     C                     KFLD           D1WDIA
     C                     KFLD           K11
     C                     KFLD           D1VEND
     C* ROD MATERIAL KANBAN MASTER(IZBPL01)
     C           KEY2      KLIST
     C                     KFLD           D1WIRE
     C                     KFLD           D1WDIA
     C                     KFLD           K11
     C                     KFLD           D1VEND
     C*** MATERIAL UNIT PRICE M/F *** (GDLPL80)
     C           ISKEY2    KLIST
     C                     KFLD           K30
     C                     KFLD           K31
     C                     KFLD           D1WIRE
     C                     KFLD           D1WDIA
     C                     KFLD           D1TYPE
     C*                    KFLD           W2STYY
     C*                    KFLD           W2STMM
     C*                    KFLD           W2STDD
     C*
     C* AOYAMA PRODUCTION PLACE CALENDAR FILE(INCLUDE HOLIDAY)
     C           F8KEY     KLIST
     C                     KFLD           WWYY
     C                     KFLD           WWMM
     C                     KFLD           WWDD
     C*================================================================
     C*           MAIN ROUTINE                                       *
     C*================================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#SET1   '#SET1
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C           @STEP     CASEQ'#CHK2U  '#CHK2
     C           @STEP     CASEQ'#UPD    '#UPD
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*================================================================
     C*  INIT
     C*================================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     SETON                     OF
     C                     MOVE '1'       D1UPDT
     C                     Z-ADD*ZERO     D1VEND
     C                     MOVE *BLANK    D1TYPE
     C                     MOVE *BLANK    D1WIRE
     C                     Z-ADD*ZERO     D1WDIA
     C                     MOVE *BLANK    D1ERR
     C                     MOVE *BLANK    K31     1
     C                     Z-ADD111       K11     40
     C*
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
     C*================================================================
     C*  DSP1
     C*================================================================
     C           #DSP1     BEGSR
     C                     EXFMTDSP01
     C                     MOVE '#CHK1   '@STEP
     C* < F1=ON >
     C           *INKA     IFEQ *ON
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C                     ENDSR
     C*================================================================
     C*  CHK1
     C*================================================================
     C           #CHK1     BEGSR
     C                     MOVEA'0000'    *IN,11           <11 - 14>
     C                     SETOF                     18
     C                     MOVEA'0'       *IN,99           <99>
     C                     MOVE *BLANK    D1ERR
     C*
     C** UPDATE **
     C*
     C           D1UPDT    IFNE '0'
     C           D1UPDT    ANDNE'1'
     C           D1UPDT    ANDNE'2'
     C  N99                MOVELMSG,1     D1ERR
     C                     SETON                     9911
     C                     ENDIF
     C*
     C** VENDOR **
     C*
     C                     MOVE *BLANK    D2VDNM
     C           D1VEND    IFEQ *ZERO
     C  N99                MOVELMSG,4     D1ERR
     C                     SETON                     9912
     C*
     C                     ELSE
     C                     Z-ADDD1VEND    B2CODE
     C           B2CODE    CHAINFGBPL011             90
     C           *IN90     IFEQ *ON
     C  N99                MOVELMSG,4     D1ERR
     C                     SETON                     9912
     C                     ELSE
     C                     MOVELB2SMEI    D2VDNM
     C                     Z-ADDD1VEND    K30     40
     C                     ENDIF
     C                     ENDIF
     C*
     C** PART TYPE **
     C*
     C           D1TYPE    IFEQ 'W'
     C                     MOVEL'WIRE'    D2PTNM
     C*
     C                     ELSE
     C           D1TYPE    IFEQ 'R'
     C                     MOVEL'WIRE ROD'D2PTNM
     C*
     C                     ELSE
     C  N99                MOVELMSG,11    D1ERR
     C                     SETON                     9913
     C                     END
     C                     END
     C*
     C*
     C* MASTER FILE CHECK(FINISHED MATERIAL)
     C           D1TYPE    IFEQ 'W'
     C           KEY1      CHAINIZAPL01              92
     C           *IN92     IFEQ '1'
     C  N99                MOVELMSG,9     D1ERR
     C                     SETON                     991418
     C                     END
     C                     END
     C*
     C* MASTER FILE CHECK(ROD MATERIAL)
     C           D1TYPE    IFEQ 'R'
     C           KEY2      CHAINIZBPL01              93
     C           *IN93     IFEQ '1'
     C  N99                MOVELMSG,10    D1ERR
     C                     SETON                     991418
     C                     END
     C                     END
     C*
     C*
     C** FILE **
     C*
S1   C           *IN99     IFEQ *OFF
     C           ISKEY2    SETGTGDLPL801
     C                     MOVE ' '       @@SAKJ  1
     C                     DO   *HIVAL
     C           ISKEY2    REDPEGDLPL801            N    90
     C   90                LEAVE
     C           LHSKJY    IFEQ 'D'                        DELETE CODE
     C           LHSKDT    ANDLE*DATE                      DELETE DATE
     C                     MOVE '1'       @@SAKJ
     C                     ITER
     C                     ENDIF
     C                     LEAVE
     C                     ENDDO
     C*
 S2  C           *IN90     IFEQ *ON
     C  N99                MOVELMSG,2     D1ERR
     C                     SETON                     9914
 E2  C                     ENDIF
     C*
E1   C                     ENDIF
     C*
      *
     C           *IN99     IFEQ *ON
     C                     MOVE '#DSP1   '@STEP
     C                     ELSE
     C                     MOVE '#SET1   '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
     C*================================================================
      *  SET1
     C*================================================================
     C           #SET1     BEGSR
     C*
     C                     MOVEA'000'     *IN,15           <15-17>
     C                     MOVEA'0'       *IN,51           <51>
     C                     MOVEA'0'       *IN,99           <99>
     C                     MOVE *BLANK    D2ERR
     C                     Z-ADDD1VEND    D2VEND
     C                     MOVELD1TYPE    D2TYPE
     C                     MOVELD1WIRE    D2WIRE
     C                     Z-ADDD1WDIA    D2WDIA
     C*
     C** FILE **
     C*
     C** SFLCLR **
     C                     SETON                     21
     C                     WRITECTL01
     C                     SETOF                     21
     C                     Z-ADD*ZERO     RRN     40
     C                     Z-ADD*ZERO     LSTRRN  40
     C**
     C           ISKEY2    SETGTGDLPL801
     C*--------------------
S1   C                     DO   *HIVAL
     C           ISKEY2    REDPEGDLPL801            N    90
     C   90                LEAVE
     C           LHSKJY    IFEQ 'D'                        DELETE CODE
     C           LHSKDT    ANDLE*DATE                      DELETE DATE
     C                     ITER
     C                     ENDIF
     C*
     C                     Z-ADDLHSTHZ    S1STDT
     C                     Z-ADDLHENHZ    S1ENDT
     C                     Z-ADDLHTANK    S1SEA
     C                     ADD  1         RRN
     C                     WRITESFL01
E1   C                     ENDDO
     C*--------------------
     C                     Z-ADDRRN       LSTRRN
     C*
     C                     MOVELNAME,2    D2UPNM
     C*
     C                     MOVE '#DSP2   '@STEP
     C*
     C                     ENDSR
     C*================================================================
     C*  DSP2
     C*================================================================
     C           #DSP2     BEGSR
     C                     WRITEDSP02
     C                     SETON                     20
     C                     EXFMTCTL01
     C                     SETOF                     20
     C                     MOVE '#CHK2   '@STEP
     C* < F3=ON >
     C           *INKC     IFEQ *ON
     C                     MOVEA'0'       *IN,99           <99>
     C                     MOVE '#INIT   '@STEP
     C                     ENDIF
     C* < F5=ON >
     C           *INKE     IFEQ *ON
     C                     MOVE '#CHK2U  '@STEP
     C                     ENDIF
     C                     ENDSR
     C*================================================================
     C*  CHK2
     C*================================================================
     C           #CHK2     BEGSR
     C                     MOVEA'000'     *IN,15           <15-17>
     C                     MOVEA'0'       *IN,99           <99>
     C                     MOVE *BLANK    D2ERR
     C*
     C                     Z-ADD0         @@STDT  80
     C                     Z-ADD0         @@ENDT  80
     C                     Z-ADD0         @@NXST  80       NEXT-STSRT
     C                     Z-ADD0         @@SEA  145
     C*--------------------
     C*--------------------
S1   C                     DO   LSTRRN    RRN
     C           RRN       CHAINSFL01                90
     C   90                LEAVE
     C                     MOVEA'000'     *IN,15           <15-17>
     C                     MOVEA'0'       *IN,98           <98>
     C*
     C           S1STDT    IFEQ 0
     C           S1ENDT    ANDEQ0
     C           S1SEA     ANDEQ0
     C                     ELSE
     C                     EXSR #SFCHK
     C                     ENDIF
      *
     C                     UPDATSFL01
E1   C                     ENDDO
     C*--------------------
     C*--------------------
     C*
     C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK2U  '
     C                     MOVE '#UPD    '@STEP
     C                     ELSE
     C                     MOVE '#DSP2   '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
     C*================================================================
     C*
     C*================================================================
     C           #SFCHK    BEGSR
      *
      * STARTING DATE *
      *
S1   C           S1STDT    IFEQ *ZERO
     C  N99                MOVELMSG,6     D2ERR
     C                     SETON                     159998
     C*
X1   C                     ELSE
     C                     Z-ADDS1STDT    WWYMD
     C           F8KEY     CHAINAGDPL12              91
 S2  C           *IN91     IFEQ *ON
     C  N99                MOVELMSG,6     D2ERR
     C  N99                SETON                     159998
 E2  C                     ENDIF
E1   C                     ENDIF
      *
      * ENDING DATE *
      *
S1   C           S1ENDT    IFEQ *ZERO
     C  N99                MOVELMSG,6     D2ERR
     C                     SETON                     169998
X1   C                     ELSE
 S2  C           S1ENDT    IFNE 99999999
     C                     Z-ADDS1ENDT    WWYMD
     C           F8KEY     CHAINAGDPL12              91
  S3 C           *IN91     IFEQ *ON
11/17C* N99                MOVELMSG,6     D2ERR
11/17C* N99                SETON                     169998
  X3 C                     ELSE
  S4 C           @@STDT    IFNE 0
     C           S1ENDT    ANDGE@@STDT
     C  N99                MOVELMSG,5     D2ERR
     C  N99                SETON                     169998
  E4 C                     ENDIF
  E3 C                     ENDIF
 E2  C                     ENDIF
E1   C                     ENDIF
      *
      *
S1   C           S1STDT    IFGT S1ENDT
     C  N99                MOVELMSG,5     D2ERR
     C  N99                SETON                       1516
     C  N99                SETON                     9899
E1   C                     ENDIF
      *
      *  UNIT PRICE  BY SEA
      *
S1   C           S1SEA     IFEQ *ZERO
     C  N99                MOVELMSG,12    D2ERR
     C  N99                SETON                     179899
E1   C                     ENDIF
     C*
S1   C           *IN98     IFEQ *OFF
     C                     Z-ADDS1STDT    @@STDT  80
     C                     Z-ADDS1ENDT    @@ENDT  80
     C                     Z-ADDS1SEA     @@SEA  145
E1   C                     ENDIF
     C*
     C                     ENDSR
     C*================================================================
      *    UPD
     C*================================================================
     C           #UPD      BEGSR
      *
      * DELETE
      *
     C           ISKEY2    SETLLGDLPL801
     C*--------------------
S1   C                     DO   *HIVAL
     C           ISKEY2    READEGDLPL801                 90
     C   90                LEAVE
     C           LHSKJY    IFEQ 'D'                        DELETE CODE
     C           LHSKDT    ANDLE*DATE                      DELETE DATE
     C                     ITER
     C                     ENDIF
     C*
     C                     DELETGDLPL801
E1   C                     ENDDO
     C*--------------------
      *
      * WRITE
      *
     C*--------------------
S1   C                     DO   LSTRRN    RRN
     C           RRN       CHAINSFL01                90
     C   90                LEAVE
     C*
     C           S1STDT    IFEQ 0
     C           S1ENDT    ANDEQ0
     C           S1SEA     ANDEQ0
     C                     ELSE
     C                     MOVE ' '       LHSKJY           DELETE CODE
     C                     Z-ADD0         LHSKDT           DELETE DATE
     C                     Z-ADD*DATE     LHKODT
     C                     TIME           W@TIME
     C                     Z-ADDW@HM      LHKOHS
     C                     MOVELPPUSER    LHKOME
     C                     MOVELD2VEND    LHSIRE
     C                     MOVELD2TYPE    LHPTCD
     C                     MOVELD1WIRE    LHZAIS
     C                     Z-ADDD1WDIA    LHZAIK
     C                     Z-ADDS1STYY    LHSTYY
     C                     Z-ADDS1STMM    LHSTMM
     C                     Z-ADDS1STDD    LHSTDD
     C                     Z-ADDS1ENYY    LHENYY
     C                     Z-ADDS1ENMM    LHENMM
     C                     Z-ADDS1ENDD    LHENDD
     C                     Z-ADDS1SEA     LHTANK
     C                     WRITEGDLPL801
     C                     ENDIF
      *
E1   C                     ENDDO
     C*--------------------
     C                     MOVE '#INIT   '@STEP
     C*--------------------
     C                     ENDSR
     C*================================================================
**  NAME  **
"0":DELETE
"1":CHANGE
"2":ADD
**  MSG  **
01:INPUT ERROR.
02:UNIT PRICE MASTER FILE NOT FOUND.
03:UNIT PRICE MASTER FILE FOUND.
04:VENDOR CODE ERROR
05:DATA OVERLAP.
06:INCORRECT DATE.
07:DETAIL M/F <CODE COMPLETION> NOT FOUND.
08:ONLY THE LATEST RECORD CAN BE ERASED.
09:FINISHED MATERIAL MASTER DOES NOT EXIST.
10:ROD MATERIAL MASTER DOES NOT EXIST.
11:PART TYPE INCORRECT
12:PLEASE INPUT UNIT PRICE
