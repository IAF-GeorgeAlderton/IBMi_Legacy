     C                     Z-ADD0         D2TAHZ
     C           EAKH1     IFNE *BLANK
     C                     MOVELEAKH1     WKSHN
     C                     EXSR #SB211
     C                     MOVELP@SHNA    D2KH1
     C                     ENDIF
     C           EAKH2     IFNE *BLANK
     C                     MOVELEAKH2     WKSHN
     C                     EXSR #SB211
     C                     MOVELP@SHNA    D2KH2
     C                     ENDIF
     C           EAKH3     IFNE *BLANK
     C                     MOVELEAKH3     WKSHN
     C                     EXSR #SB211
     C                     MOVELP@SHNA    D2KH3
     C                     ENDIF
     C           EAKH4     IFNE *BLANK
     C                     MOVELEAKH4     WKSHN
     C                     EXSR #SB211
     C                     MOVELP@SHNA    D2KH4
     C                     ENDIF
     C                     MOVELEAZANM    D2ZANM
     C                     Z-ADDEAKAZI    D2KAZI
     C                     ENDIF
      *
     C                     MOVELH1SHN1    D1SHN1
     C                     MOVELH1SHN2    D1SHN2
     C                     MOVELH1SHN3    D1SHN3
     C                     MOVELH1ZANM    D2ZANM
     C                     Z-ADDH1KAZI    D2KAZI
     C                     Z-ADDH1STAT    D2STAT
