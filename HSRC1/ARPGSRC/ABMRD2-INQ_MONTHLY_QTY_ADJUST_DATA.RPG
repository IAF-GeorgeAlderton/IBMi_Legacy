     CSR         #CLR      BEGSR
      *
     C                     SETON                     71
     C                     WRITESFLCTL
     C                     SETOF                     7166
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN    40
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         @SFRC1
      *
     CSR         ECLR      ENDSR
      *----------------------------------------------------*
      * EDIT                                               *
      *----------------------------------------------------*
     CSR         #EDIT     BEGSR
      *
     C           KEYDN     KLIST
     C                     KFLD           DDSHN1
     C                     KFLD           DDSHN2
     C                     KFLD           DDSHN3
     C                     Z-ADD0         S1GEKN
     C           KEYDN     CHAINFCEPL011             20
     C           *IN20     IFEQ '0'
     C                     Z-ADDA2GEKN    S1GEKN
     C                     ENDIF
     C                     MOVEL*BLANK    S1SHN
     C           DDSHN1    CAT  '-':0     S1SHN
     C           S1SHN     CAT  DDSHN2:0  S1SHN
     C           DDSHN3    IFNE *BLANK
     C           S1SHN     CAT  '-':0     S1SHN
     C           S1SHN     CAT  DDSHN3:0  S1SHN
     C                     ENDIF
     C                     MOVELDDZANM    S1ZANM
     C                     Z-ADDDDKAZI    S1KAZI
     C                     Z-ADDDDSTAT    S1STAT
     C                     Z-ADDDDEND     S1END
     C                     Z-ADDDDQTY     S1QTY
     C                     MOVELDDSHN1    H1SHN1
     C                     MOVELDDSHN2    H1SHN2
     C                     MOVELDDSHN3    H1SHN3
     C                     MOVELDDZANM    H1ZANM
     C                     Z-ADDDDKAZI    H1KAZI
     C                     Z-ADDDDSTAT    H1STAT
     C                     Z-ADDDDEND     H1END
     C                     Z-ADDDDQTY     H1QTY
     C                     Z-ADDDDINPT    H1INPT
     C                     MOVELDDUSER    H1USER
      *
     CSR         EEDIT     ENDSR
      *----------------------------------------------------*
