      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INIT                                               *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * CONTROL                                            *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * INQ                                                *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     C                     SETOF                     8166
     C           *LOVAL    SETLLABMPPD11
     C                     READ ABMPPD11                 81
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ ABMPPD11                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     MOVE '02'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * SFL                                                *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C           CTRX      IFEQ 0
     C                     SETON                     72
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     ELSE
     C                     SETON                     7273
     C                     ENDIF
      *
     C                     WRITEABMPWD29
     C                     EXFMTSFLCTL
     C                     SETOF                     7273
     C                     SETOF                     3199
     C                     MOVEL*BLANK    D9ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      * F11 WASHER TOTAL
     C           *IN11     IFEQ '1'
     C                     CALL 'ABMCD7'
     C                     GOTO ESB220
     C                     ENDIF
      * F12 WIRE TOTAL
     C           *IN12     IFEQ '1'
     C                     CALL 'ABMCD8'
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           CTRX      IFEQ 0
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
      * ROLLDOWN/PAGEUP *
      *-----------------*
     C           *IN52     IFEQ '1'
     C*                    ADD  1         CTRX
      * 1ST. PAGE
     C           WKPAGE    IFEQ 1
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
     C           *IN81     IFEQ '1'
     C                     SETOF                     81
     C           *HIVAL    SETGTABMPPD11
     C                     READPABMPPD11                 81
     C                     SUB  1         CTRX
     C                     ENDIF
      *
     C                     ADD  16        CTRX
      *                         L--表示行数
     C                     SETOF                     6627
      *
     C           *IN81     DOWEQ'0'
     C           *IN27     ANDEQ'0'
     C                     EXSR #READP
     C                     READPABMPPD11                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXTP
     C                     ENDDO
      *
     C                     Z-ADD0         CTRX    40
      *
     C           *IN81     IFEQ '1'
     C           *LOVAL    SETLLABMPPD11
     C                     READ ABMPPD11                 81
     C                     ENDIF
      *
     C                     EXSR #CLR
     C                     SETOF                     8166
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ ABMPPD11                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     SUB  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      *--------------------*
      * ROLL-UP            *
      *--------------------*
     C           *IN51     IFEQ '1'
     C           *IN81     ANDEQ'0'
      *
     C                     EXSR #CLR
      *
     C                     SETOF                     6681
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C                     READ ABMPPD11                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     ADD  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      *
     C                     SETOF                     3099
     C                     Z-ADD1         X       20
     C           X         DOWLE16
     C           *IN99     ANDEQ'0'
     C           X         CHAINSFL                  27
     C           *IN27     IFEQ '0'
     C                     SELEC
     C           S1SEL     WHEQ ' '
     C           S1SEL     WHEQ 'M'
     C                     EXSR #SB230
     C                     MOVEL*BLANK    S1SEL
     C           S1SEL     WHEQ '1'
     C           KEYCN     CHAINFCEPL011             20
     C                     MOVEL*BLANK    P1KH1
     C                     MOVEL*BLANK    P1KH2
     C                     MOVEL*BLANK    P1KH3
     C                     MOVEL*BLANK    P1KH4
     C           *IN20     IFEQ '0'
     C                     MOVELA21HB     P1KH1
     C                     MOVELA22HB     P1KH2
     C                     MOVELA23HB     P1KH3
     C                     MOVELA24HB     P1KH4
     C                     ENDIF
     C                     CALL 'ABMRD3'
     C                     PARM           H1SHN1  5
     C                     PARM           H1SHN2  5
     C                     PARM           H1SHN3  2
     C                     PARM           H1ZANM 15
     C                     PARM           H1KAZI  52
     C                     PARM           P1KH1  12
     C                     PARM           P1KH2  12
     C                     PARM           P1KH3  12
     C                     PARM           P1KH4  12
     C                     MOVEL*BLANK    S1SEL
     C           S1SEL     WHEQ '2'
     C                     CALL 'ABMRD4'
     C                     PARM           H1SHN1  5
     C                     PARM           H1SHN2  5
     C                     PARM           H1SHN3  2
     C                     PARM           H1ZANM 15
     C                     PARM           H1KAZI  52
     C                     MOVEL*BLANK    S1SEL
     C                     OTHER
     C                     SETON                     3099
     C                     MOVELER,2      D9ERR
     C                     ENDSL
     C                     UPDATSFL
     C                     ENDIF
     C                     ADD  1         X
     C                     ENDDO
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * DETAIL                                             *
      *----------------------------------------------------*
     CSR         #SB230    BEGSR
      *
     C           KEYCN     KLIST
     C                     KFLD           H1SHN1
     C                     KFLD           H1SHN2
     C                     KFLD           H1SHN3
      *
     C           KEYCN     CHAINFCEPL011             20
     C           *IN20     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     20
     C                     ENDIF
     C           *IN20     IFEQ '0'
     C                     Z-ADDA2TAHZ    D2TAHZ
     C           A21HB     IFNE *BLANK
     C                     MOVELA21HB     WKSHN
     C                     EXSR #SB211
     C                     MOVELP@SHNA    D2KH1
     C                     ENDIF
     C           A22HB     IFNE *BLANK
     C                     MOVELA22HB     WKSHN
     C                     EXSR #SB211
     C                     MOVELP@SHNA    D2KH2
     C                     ENDIF
     C           A23HB     IFNE *BLANK
     C                     MOVELA23HB     WKSHN
     C                     EXSR #SB211
     C                     MOVELP@SHNA    D2KH3
     C                     ENDIF
     C           A24HB     IFNE *BLANK
     C                     MOVELA24HB     WKSHN
     C                     EXSR #SB211
     C                     MOVELP@SHNA    D2KH4
     C                     ENDIF
     C                     MOVELA2ZANM    D2ZANM
     C                     Z-ADDA2KAZI    D2KAZI
     C                     ENDIF
      *
     C           KEYCN     CHAINMRHPL211             21
     C           *IN21     IFEQ '0'
     C           EAGSJY    ANDEQ'D'
     C           EAGSHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ENDIF
     C           *IN21     IFEQ '0'
