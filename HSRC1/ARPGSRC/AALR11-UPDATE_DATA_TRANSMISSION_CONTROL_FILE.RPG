     FAALPW11 CF  E                    WORKSTN
     FFGBPL01 IF  E           K        DISK
     FAALPL11 UF  E           K        DISK                      A
     E                    DAS     1   1 22               mﾞｰj ﾆｬﾓb
     E                    MSG     1   9 60               d[ｰ xｮﾈｰﾆﾞ
     I            DS
     I                                        1   80DSAKBI
     I                                        1   40CLDTYY
     I                                        5   60CLDTMM
     I                                        7   80CLDTDD
     C****************************************************************
     C*  START PROGRAM  <AALR11>                                     *
     C****************************************************************
     ***
     ***  ﾎｧｰﾓnﾞ ﾉ hﾒa
     ***
     C           STP0      TAG
     C                     MOVEL*BLANK    KBN
     C                     MOVEL*BLANK    DATSU
     C                     MOVEL*BLANK    ERRMSG
     C                     MOVEL*BLANK    KBNAM
     C                     MOVEL*BLANK    DATNAM
     C                     Z-ADD0         BUMCD
     C                     SETOF                     010203
     C                     SETOF                     040590
     C                     SETOF                     99
     ***
     ***  ﾅbﾆｭ ﾉ ﾈｮn
     ***
     C           STP1      TAG
B001 C                     EXFMTAALPW111
     C                     SETOF                     010203
     C                     SETOF                     049990
     C                     MOVEL*BLANK    ERRMSG
     C   KA                SETON                     LR
     C   KA                RETRN
     C           KBN       COMP '0'                      10
     C  N10      KBN       COMP '1'                      10
     C  N10      KBN       COMP '2'                      10
     C           *IN,10    IFEQ '0'
     C                     SETON                     0199
     C                     MOVELMSG,1     ERRMSG
     C                     GOTO STP1
     C                     END
     C           BUMCD     IFEQ 0
     C                     SETON                     0299
     C                     MOVELMSG,2     ERRMSG
     C                     GOTO STP1
     C                     END
     C           BUMCD     COMP 8974                     10
     C  N10      BUMCD     COMP 8982                     10
     C  N10      BUMCD     COMP 8990                     10
     C  N10      BUMCD     COMP 9032                     10
     C  N10      BUMCD     COMP 8907                     10
     C  N10      BUMCD     COMP 9431                     10
     C  N10      BUMCD     COMP 0111                     10
     C           *IN,10    IFEQ '0'
     C                     SETON                     0299
     C                     MOVELMSG,3     ERRMSG
     C                     GOTO STP1
     C                     END
     C           DATSU     IFEQ *BLANK
     C                     SETON                     0399
     C                     MOVELMSG,4     ERRMSG
     C                     GOTO STP1
     C                     END
     C*          DATSU     COMP '0A'                     10
     C*          *IN,10    IFEQ '0'
     C*                    SETON                     0399
     C*                    MOVELMSG,5     ERRMSG
     C*                    GOTO STP1
     C*                    END
     C           KEY1      KLIST
     C                     KFLD           BUMCD
     C                     KFLD           DATSU
     C           KEY1      CHAINAALPL111             20
     C           *IN,20    IFEQ '0'
     C           KBN       IFEQ '2'
     C                     SETON                     0199
     C                     MOVELMSG,7     ERRMSG
     C                     GOTO STP1
     C                     END
     C                     ELSE
     C           KBN       IFNE '2'
     C                     SETON                     0199
     C                     MOVELMSG,6     ERRMSG
     C                     GOTO STP1
     C                     END
     C                     END
     C           KBN       IFNE '2'
     C           KBN       IFEQ '0'
     C                     MOVEL'CANCEL'  KBNAM
     C                     SETON                     90
     C                     ELSE
     C                     MOVEL'CHANGE'  KBNAM
     C                     END
     C                     GOTO STP2
     C                     END
     C           KBN       IFEQ '2'
     C                     MOVEL'ADD   '  KBNAM
     C                     MOVEL*BLANK    CLDTOK
     C                     MOVEL*BLANK    CLTENS
     C                     Z-ADD0         DSAKBI
     C                     Z-ADD0         CLJOBN
     C                     END
     C           STP2      TAG
     C           BUMCD     CHAINFGBPL011             30
     C   30                MOVEL*BLANK    B2SMEI
     C           DATSU     IFEQ '0A'
     C                     MOVELDAS,1     DATNAM
     C                     SETON                     40
     C                     END
     C           *IN,40    IFEQ '0'
     C                     MOVEL*BLANK    DATNAM
     C                     END
     C           STP3      TAG
     C                     EXFMTAALPW112
     C                     SETOF                     040599
     C                     MOVEL*BLANK    ERRMSG
     C   KC                GOTO STP0
     C           CLDTOK    COMP *BLANK                   10
     C  N10      CLDTOK    COMP 'H'                      10
     C  N10      CLDTOK    COMP '*'                      10
     C           *IN,10    IFEQ '0'
     C                     SETON                     0499
     C                     MOVELMSG,8     ERRMSG
     C                     GOTO STP3
     C                     END
     C           CLTENS    COMP *BLANK                   10
     C  N10      CLTENS    COMP '*'                      10
     C           *IN,10    IFEQ '0'
     C                     SETON                     0599
     C                     MOVELMSG,9     ERRMSG
     C                     GOTO STP3
     C                     END
     C  NKE                GOTO STP3
     C******
     C** ﾎｦbﾓ ﾉ ﾃcﾆ]
     C******
     C           KBN       IFEQ '2'
     C                     Z-ADDBUMCD     CLBMON
     C                     MOVE DATSU     CLDATA
     C                     Z-ADD0         DSAKBI
     C                     Z-ADD0         CLJOBN
     C                     WRITEAALPL111
     C                     GOTO STP0
     C                     END
     C*****
     C           KBN       IFEQ '1'
     C                     UPDATAALPL111
     C                     GOTO STP0
     C                     ELSE
     C                     DELETAALPL111
     C                     GOTO STP0
     C                     END
