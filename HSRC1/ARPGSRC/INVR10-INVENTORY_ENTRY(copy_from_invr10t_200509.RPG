     C                     KFLD           K@PREV 17
      *
     C           KEY4      KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
      *
     C                     Z-ADD*DATE     K@DATE
      *
     C                     MOVE '00'      @@ID    2
      *
TCH26C                     TIME           @TIME  140
     C*
     C                     ENDSR
     C*************************************************************************
     C*          USER ID ENTRY
     C*************************************************************************
     C           #SCRN0    BEGSR
      *
TCH26C           MSG       IFEQ *BLANKS
TCH26C                     CLEARD@USER
TCH26C                     ENDIF
      *
     C                     EXFMTDSP00
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
