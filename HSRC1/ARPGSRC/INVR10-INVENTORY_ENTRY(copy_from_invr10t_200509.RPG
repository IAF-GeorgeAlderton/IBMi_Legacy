     C                     MOVE D@APCV    K@PREV
     C           K#INVV    CHAININVPP10              96
     C           *IN96     IFEQ '0'
     C                     MOVE IVBARC    D@BARV
     C                     Z-ADDIVKANS    D@KANV
     C                     MOVE '0'       *INKD
     C           *INKC     DOWNE'1'
     C           *INKD     ANDNE'1'
     C                     EXFMTDSP07
     C           *INKC     IFEQ '1'
     C                     LEAVE
     C                     ENDIF
     C           *INKD     IFEQ '1'
