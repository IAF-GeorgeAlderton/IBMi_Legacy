TCHK7C           *IN99     IFEQ *OFF
TCHK7C                     MOVEL'01'      @@ID
TCHK7C                     END
     C                     ENDSL
      *
     C                     ENDSR
TCHK7C*************************************************************************
TCHK7C* TM-CODE CHECK
TCHK7C**************************************************************************
TCHK7C           #CHK00    BEGSR
TCHK7C*
TCHK7C                     SETOF                     6199
TCHK7C*
TCHK7C                     DO
TCHK7C*
TCHK7C           D@USER    IFEQ 111111
TCHK7C           D@USER    OREQ 222222
TCHK7C                     LEAVE
TCHK7C                     END
TCHK7C*
TCHK7C           D@USER    CHAINALBPL301             90
TCHK7C           *IN90     IFEQ *OFF
TCHK7C           ALSKJY    ANDEQ*BLANK
TCHK7C                     ELSE
TCHK7C                     SETON                     6199
TCHK7C           MSG       IFEQ *BLANK
TCHK7C                     MOVELERR,6     MSG
TCHK7C                     END
TCHK7C                     END
TCHK7C*
TCHK7C                     ENDDO
TCHK7C*
TCHK7C                     ENDSR
