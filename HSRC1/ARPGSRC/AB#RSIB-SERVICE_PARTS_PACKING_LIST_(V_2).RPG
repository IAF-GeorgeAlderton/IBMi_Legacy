      * (DEFAULT)
JW3  C           D@P2      IFEQ ' '
JW3  C           YA#MIX    IFEQ 0
 .   C                     MOVE 'N'       D@P2
 .   C                     Z-ADD0         D@CP2
     C                     ELSE
 .   C                     MOVE 'Y'       D@P2
 .   C                     Z-ADDYA#MIX    D@CP2
