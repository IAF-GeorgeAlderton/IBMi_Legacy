      * PRINTER
TCHK4C           D@PRT     IFNE '1'
TCHK4C           D@PRT     ANDNE'3'
TCHK4C           D@PRT     ANDNE'4'
TCHK4C           D@PRT     ANDNE'5'
TCHK4C           D@PRT     ANDNE'6'
TCHK4C           D@PRT     ANDNE'7'
TCHK4C           D@PRT     ANDNE'8'
TCHK4C           D@PRT     ANDNE'9'
JW3  C           D@PRT     ANDNE'X'
