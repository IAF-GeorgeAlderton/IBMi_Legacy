     C           KEY1      SETLLAB#PL131
     C           *IN90     DOUEQ*ON
     C           KEY1      READEAB#PL131                 90
B1   C           *IN90     IFEQ *OFF
      *
B2   C           BASKJY    IFEQ 'D'
     C           BASKHZ    ANDLETODAY
