     C                     Z-ADDCJAHAK    NORYK
     C                     MOVEA'1'       *IN,20
     C                     END
     C                     END
     C  N20                END
      *
     C                     MOVE *BLANK    SIN     4
     C           KHAKO     IFEQ NORYK
     C                     MOVEL' =  '    SIN
     C                     END
      *
     C           KHAKO     IFGT NORYK
     C                     MOVEL' >  '    SIN
     C                     END
      *
     C           KHAKO     IFLT NORYK
     C                     MOVEL' <  '    SIN
     C                     END
      *
     C           *INOF     IFEQ '1'
