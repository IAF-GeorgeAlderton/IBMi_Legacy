     C           $LIST     BEGSR                           *
     C******************************************************
      *
     C*  ﾞciﾞ]
     C                     MOVE *BLANK    ZGN     4
     C           ZOGEN     IFEQ 'Z'
     C                     MOVEL' +  '    ZGN
     C                     END
      *
     C           ZOGEN     IFEQ 'G'
     C                     MOVEL' -  '    ZGN
     C                     END
      *
     C*  nﾃﾜﾌﾞ]k
     C                     MOVE *BLANK    @TKR
     C                     MOVELTKR1      @TKR1
     C                     MOVELTKR2      @TKR2
     C                     MOVELTKR3      @TKR3
     C                     MOVELTKR4      @TKR4
     C           @TKR2     IFNE *BLANK
     C                     MOVEL'-'       @TKRA
     C                     END
      *
     C           @TKR3     IFNE *BLANK
     C                     MOVEL'-'       @TKRB
     C                     END
      *
     C           @TKR4     IFNE *BLANK
