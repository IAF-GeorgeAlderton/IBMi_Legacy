     C                     END
      *
     C*  ﾆｫob ﾍ]ﾌﾞ]
     C                     MOVE *BLANK    @HIN
     C                     MOVELHIN1      @HIN1
     C                     MOVELHIN2      @HIN2
     C                     MOVELHIN3      @HIN3
     C           @HIN2     IFNE *BLANK
     C                     MOVEL'-'       @HINA
     C                     END
      *
     C           @HIN3     IFNE *BLANK
     C                     MOVEL'-'       @HINB
     C                     END
      *
     C*  ﾃ]fbﾈｮmbﾇc ﾞciﾞ]ﾒl
     C                     MOVE *BLANK    PZG1    1
     C                     Z-ADD0         PAR1    61
     C           ZHHS      IFNE 0
     C           KHHS      DIV  ZHHS      AAA     83H
     C           AAA       MULT 100       PAR1      H
     C           PAR1      IFGE 100
     C                     MOVE '+'       PZG1
     C           PAR1      SUB  100       PAR1
     C                     ELSE
     C                     MOVE '-'       PZG1
     C           100       SUB  PAR1      PAR1
     C                     END
     C                     END
      *
     C*  ﾑhiﾞlobﾆﾞﾇc ﾞciﾞ]ﾒl
     C                     MOVE *BLANK    PZG2    1
     C                     Z-ADD0         PAR2    61
     C           ZHHS      IFNE 0
     C           NHK1      DIV  ZHHS      BBB     83H
     C           BBB       MULT 100       PAR2      H
     C           PAR2      IFGE 100
     C                     MOVE '+'       PZG2
     C           PAR2      SUB  100       PAR2
     C                     ELSE
     C                     MOVE '-'       PZG2
     C           100       SUB  PAR2      PAR2
     C                     END
     C                     END
      *
     C*  ﾑhﾑhiﾞlobﾆﾞﾇc ﾞciﾞ]ﾒl
     C                     MOVE *BLANK    PZG3    1
     C                     Z-ADD0         PAR3    61
     C           ZHHS      IFNE 0
     C           NHK2      DIV  ZHHS      CCC     83H
     C           CCC       MULT 100       PAR3      H
     C           PAR3      IFGE 100
     C                     MOVE '+'       PZG3
     C           PAR3      SUB  100       PAR3
     C                     ELSE
     C                     MOVE '-'       PZG3
     C           100       SUB  PAR3      PAR3
     C                     END
     C                     END
      *
     C           NLOT      ADD  NKJN      XXX     40
     C           XXX       MULT NMIS      KHAKO   50
      *
     C           KEY1      SETLLAAJPL111
