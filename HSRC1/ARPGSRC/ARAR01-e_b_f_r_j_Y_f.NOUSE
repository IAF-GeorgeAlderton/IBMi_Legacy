     C           #KEY1     KLIST
     C                     KFLD           @SHN1
     C                     KFLD           @SHN2
     C                     KFLD           @SHN3
     C*
     C           *ENTRY    PLIST
     C                     PARM           #PARM1  4        ﾎﾞy]ﾃｰnﾞ
     C*
     C           @SCR0     TAG
     C                     Z-ADD0         @BMON
     C                     MOVE *BLANK    @NYMDB
     C                     MOVE *BLANK    @BLOK
     C                     MOVE *BLANK    @KDAI
     C                     MOVE *BLANK    @SHIN
     C                     Z-ADD0         @MAIS
     C                     Z-ADD0         @HYMDB
     C                     Z-ADD0         @SYMDB
     C                     Z-ADD0         @MYMDB
     C                     Z-ADD0         @KYMDB
     C                     MOVE 'A'       @KKBN
     C                     MOVE *BLANK    @TSYO
     C                     Z-ADD0         @TBAN
     C                     MOVE '0'       @SYUK
     C                     MOVE *BLANK    @KAKO
     C                     MOVE *BLANK    @SYOT
     C                     MOVE *BLANK    #SW1    1
     C                     SETOF                     31
     C*
     C* fﾞx] - 1
     C*
     C                     Z-ADD0         CNT     10
     C                     MOVE *BLANK    MSG
     C           @SCR1     TAG
     C                     EXFMTARAPW011
     C                     MOVEA'00000'   *IN,01
     C                     MOVEA'00000'   *IN,06
     C                     MOVEA'00000'   *IN,11
     C                     MOVEA'0'       *IN,99
     C*
     C           *INKA     IFEQ '1'
     C                     MOVEL'1'       *INLR
     C                     RETRN
     C                     END
     C*
     C           *INKE     IFEQ '1'
     C                     MOVEL'1'       *INU1
     C                     MOVEL'1'       *INLR
     C                     RETRN
     C                     END
     C*
     C                     ADD  1         CNT
     C           CNT       IFEQ 1
     C                     MOVEA'1'       *IN,99
     C                     MOVELCMT,1     MSG
     C                     GOTO @SCR1
     C                     END
     C*
     C           @001      TAG
     C                     MOVE @BMON     ARBMON
     C                     MOVEL@NYMD     ARNOHZ
     C                     MOVEL@NBIN     ARNOBB
     C                     MOVEL@SHN1     ARSHN1
     C                     MOVEL@SHN2     ARSHN2
     C                     MOVEL@SHN3     ARSHN3
     C                     MOVEL@KDAI     ARKDAI
     C                     MOVEL@BLOK     ARBLOK
     C                     MOVEL@MAIS     ARMAIS
     C                     MOVEL@HYMD     ARHAHZ
     C                     MOVEL@HBIN     ARHABB
     C                     MOVEL@SYMD     ARSYHZ
     C                     MOVEL@SBIN     ARSYBB
     C                     MOVEL@MYMD     ARMKHZ
     C                     MOVEL@MBIN     ARMKBB
     C                     MOVEL@KYMD     ARKKHZ
     C                     MOVEL@KBIN     ARKKBB
     C                     MOVEL@TBAN     ARTBAN
     C                     MOVE @KKBN     ARKKBN
     C                     MOVE *BLANK    ARTKRO
     C                     MOVE '0000'    ARTOKU
     C                     MOVE '000000'  ARNUHZ
     C                     MOVE *BLANK    ARHOKN
     C                     MOVE @KAKO     ARKAKO
     C           @KDAI     IFEQ 'D'
     C                     MOVE 'A'       @KAKO
     C                     MOVE 'A'       ARKAKO
     C                     END
     C                     MOVE @TSYO     ARTSYO
     C                     MOVE @SYUK     ARSYUK
     C*
     C                     SETOF                     20
     C           #KEY1     CHAINFCEPL011             20
     C           *IN20     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     20
     C                     END
     C*
     C           *IN20     IFEQ '0'
     C           A2SYHZ    IFGT *DATE
     C                     MOVE A2KSYT    @SYOT
     C                     MOVE A2KSYT    ARSYOT
     C                     ELSE
     C                     MOVE A2SSYT    @SYOT
     C                     MOVE A2SSYT    ARSYOT
     C                     END
     C                     END
     C*
     C                     WRITEARAPP011
     C                     Z-ADD0         CNT
     C                     MOVE @BMON     #PARM1
     C*
     C                     MOVEL'*'       #SW1
     C           #SW1      IFEQ '*'
     C                     SETON                     31
     C                     END
     C*
     C                     EXSR #CLR1
     C                     GOTO @SCR1
     C******************************************************
     C           #CLR1     BEGSR
     C******************************************************
     C                     MOVE *BLANK    @SHIN
     C                     Z-ADD0         @MAIS
     C*                    Z-ADD0         @HYMDB
     C*                    Z-ADD0         @SYMDB
     C*                    Z-ADD0         @MYMDB
     C*                    Z-ADD0         @KYMDB
