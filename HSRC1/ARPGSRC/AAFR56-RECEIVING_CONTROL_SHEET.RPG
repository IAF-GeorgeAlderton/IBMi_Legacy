     C           KEY1      KLIST
     C                     KFLD           ZZSHN1
     C                     KFLD           ZZSHN2
     C                     KFLD           ZZSHN3
      *
     C           KEY2      KLIST
     C                     KFLD           ZZSHN1
     C                     KFLD           ZZSHN2
     C                     KFLD           ZZSHN3
     C                     KFLD           ZZKCD1
     C           KEY3      KLIST
     C                     KFLD           AFSHN1
     C                     KFLD           AFSHN2
     C                     KFLD           AFSHN3
      *
     C                     Z-ADDUDATE     WYMD
      *
     C                     SETOF                     10
     C                     Z-ADD1         A       20
     C                     MOVE *BLANK    WTEXT
     C           ZZKCD1    LOKUPTB1,A                    10
     C           *IN10     IFEQ '1'
     C                     MOVE TB2,A     WTEXT
     C                     END
      *
     C                     Z-ADD0         WGEKN
     C                     MOVE *BLANK    WSMEI
     C                     MOVE *BLANK    WTMEI
     C                     MOVE *BLANK    WDMEI
     C                     Z-ADD0         WSSYS
     C                     MOVE *BLANK    WSSYT
     C                     Z-ADD0         WSYHZ
     C                     MOVE *BLANK    WSTKR
     C                     Z-ADD0         WTRHZ
     C                     MOVE *BLANK    WZETI
     C                     Z-ADD0         WSOZI
     C                     Z-ADD0         WKASI
     C                     Z-ADD0         WTAHZ
      *
     C           ZZKCD1    IFEQ '0'
     C           ZZKCD1    OREQ '6'
      *
     C                     SETOF                     10
     C           KEY1      CHAINFCEPL011             10
     C           *IN10     IFEQ '0'
     C           A2GSKD    ANDEQ'D'
     C           A2GSHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
      *
     C           *IN10     IFEQ '0'
     C           KEY1      CHAINFCEPL111             11
     C           *IN11     IFEQ *OFF
     C           FCD,1     ANDNE*ZERO
     C           FGK,1     DIV  FCD,1     @@Q    111
     C           @@Q       MULT 20        WGEKN
     C                     ELSE
     C                     Z-ADDA2GEKN    WGEKN
     C                     ENDIF
      *
     C                     MOVE A2SMEI    WSMEI
     C                     MOVE A2TMEI    WTMEI
     C                     MOVE A2DMEI    WDMEI
     C                     Z-ADDA2SSYS    WSSYS
     C                     MOVE A2SSYT    WSSYT
     C                     Z-ADDA2SYHZ    WSYHZ
     C                     MOVE A2STKR    WSTKR
     C                     Z-ADDA2TRHZ    WTRHZ
     C                     MOVE A2ZETI    WZETI
     C                     Z-ADDA2SOZI    WSOZI
     C                     Z-ADDA2KASI    WKASI
     C                     Z-ADDA2TAHZ    WTAHZ
     C                     END
     C                     END
      *
     C           ZZKCD1    IFEQ '3'
      *
     C                     SETOF                     10
     C           KEY1      CHAINAKCPL011             10
     C           *IN10     IFEQ '0'
     C           M1SKJY    ANDEQ'D'
     C           M1SKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
      *
     C           *IN10     IFEQ '0'
      *
     C           KEY1      SETLLAEBPL02
     C           *IN95     DOUEQ*ON
     C           KEY1      READEAEBPL02                  95
     C           *IN95     IFEQ *OFF
     C           AFSKJY    ANDEQ*BLANK
     C           KEY3      CHAINFCEPL111             11
     C           *IN11     IFEQ *OFF
     C           FCD,1     ANDNE*ZERO
     C           FGK,1     DIV  FCD,1     @@Q    111
     C           @@Q       MULT 20        @@Q1    90
     C                     ADD  @@Q1      WGEKN
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C*******              Z-ADDM1GEKN    WGEKN
     C                     Z-ADDM1SSYS    WSSYS
     C                     MOVE M1SSYT    WSSYT
     C                     Z-ADDM1SYHZ    WSYHZ
     C                     MOVE M1ZENO    WZETI
     C                     Z-ADDM1KASI    WKASI
     C                     Z-ADDM1TAHZ    WTAHZ
     C                     END
      *
     C                     SETOF                     10
     C           KEY2      CHAINAKHPL061             10
     C           *IN10     IFEQ '0'
     C           M5SKJY    ANDEQ'D'
     C           M5SKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '0'
     C                     MOVE M5NTKR    WSTKR
     C                     Z-ADDM5UKHZ    WTRHZ
     C                     END
     C                     END
      *
     C                     MOVE '-'       @SH1
     C                     MOVE '-'       @SH2
     C                     MOVE ZZSHN1    @SHN1
     C                     MOVE ZZSHN2    @SHN2
     C                     MOVE ZZSHN3    @SHN3
      *
     C                     MOVE '-'       @TH1
     C                     MOVE '-'       @TH2
     C                     MOVE '-'       @TH3
     C                     MOVE WSTK1     @STK1
     C                     MOVE WSTK2     @STK2
     C                     MOVE WSTK3     @STK3
     C                     MOVE WSTK4     @STK4
      *
     C                     WRITEAAFPR561
