     H            Y.
     F*** APLR40 *********************************
     F*番地ハイフン付与プログラム              *
     F*   C:T.SAKASHITA             2011.11.01   *
     F*------------------------------------------*
     F* PARM( '1' '23' '45' '6' ' ')              *
     F********************************************
     I            DS
     I                                        1   9 W@BANA
     I                                        1   1 W@BAN1
     I                                        2   2 W@HF1
     I                                        3   4 W@BAN2
     I                                        5   5 W@HF2
     I                                        6   7 W@BAN3
     I                                        8   8 W@HF3
     I                                        9   9 W@BAN4
     C           *ENTRY    PLIST
     C                     PARM           P@BAN1  1
     C                     PARM           P@BAN2  2
     C                     PARM           P@BAN3  2
     C                     PARM           P@BAN4  1
     C                     PARM           O@BANC  9
      *
     C                     MOVE *BLANK    O@BANC
      *
     C           P@BAN1    IFEQ *BLANK
     C           P@BAN2    ANDEQ*BLANK
     C           P@BAN3    ANDEQ*BLANK
     C           P@BAN4    ANDEQ*BLANK
     C                     GOTO @END
     C                     END
      *
      *
     C                     MOVE P@BAN1    W@BAN1
     C                     MOVE P@BAN2    W@BAN2
     C                     MOVE P@BAN3    W@BAN3
     C                     MOVE P@BAN4    W@BAN4
      *
     C                     MOVE '-'       W@HF1
     C                     MOVE '-'       W@HF2
     C                     MOVE '-'       W@HF3
      *
     C                     MOVE W@BANA    O@BANC
      *
     C           @END      TAG
      *
     C                     SETON                     LR
     C                     RETRN
      *
