     H            Y.
     F** ABBR12 *********************************
     F*  ..SETTING NUMBER AUTOMATIC HANDLING..  *
     F*  ..CALENDAR N-1,N-2,N-3,N-4             *
     F*     I-HASADA               97.07.28     *
     F********************************* ABBR12 **
     FAGDPL12 IF  E           K        DISK
     I            DS
     I                                        1   80WYMD
     I                                        1   40WYY
     I                                        5   60WMM
      *
     C           KEY1      KLIST
     C                     KFLD           WYY
     C                     KFLD           WMM
      *
     C           *ENTRY    PLIST
     C                     PARM           PN1DD   3
     C                     PARM           PN2DD   3
     C                     PARM           PJ1DD   3
     C                     PARM           PJ2DD   3
     C                     PARM           PJ3DD   3
      *
     C                     Z-ADD1         A       20
     C                     Z-ADD*DATE     WYMD
     C           1         DO   4         A
      *
     C           WMM       IFEQ 01
     C                     SUB  1         WYY
     C                     Z-ADD12        WMM
     C                     ELSE
     C                     SUB  1         WMM
     C                     END
      *
     C                     Z-ADD0         WCD     31
     C           KEY1      SETLLAGDPL121
      *
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY1      READEAGDPL121                 10
     C           *IN10     IFEQ '0'
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         WCD
     C                     ELSE
      *
     C                     ADD  0.5       WCD
     C                     END
      *
     C                     END
     C                     END
     C  N10                END
      *
      *  IF WORKING DAY IS 0
     C           WCD       IFEQ 0
     C                     Z-ADD1         WCD
     C                     ENDIF
      *
     C           A         IFEQ 1
     C                     MOVE WCD       PN2DD
     C                     END
      *
     C           A         IFEQ 2
     C                     MOVE WCD       PN1DD
     C                     MOVE WCD       PJ3DD
     C                     END
      *
     C           A         IFEQ 3
     C                     MOVE WCD       PJ2DD
     C                     END
      *
     C           A         IFEQ 4
     C                     MOVE WCD       PJ1DD
     C                     END
      *
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
