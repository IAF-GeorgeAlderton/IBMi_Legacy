     H            Y.
     F** ABFRE3  ************************************************
     F*  FORD 9 DAYS EDI ORDERS                                 *
     F*  JW   2022.07.07                                        *
     F***********************************************************
     FAB#PLF1EIF  E           K        DISK
     FABFWPE3 O   E                    DISK
      ****************************************************
     E                    HDR     1   9 10
      ****************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1  20 F5MHIN
     I                                        1   5 F5MHN1
     I                                        6  10 F5MHN2
     I                                       11  15 F5MHN3
     I                                       16  20 F5MHN4
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      ****************************************************
      * MAIN ROUTINE
      ****************************************************
     C                     EXSR #INIT
      * READ AB#PPF1 ------------------
     C           K#F1      SETLLAB#PLF1E
     C                     DO   *HIVAL
     C           @PDAT     READEAB#PLF1E                 98
     C   98                LEAVE
      * END
     C           F5NOHZ    IFGT @END
     C                     LEAVE
     C                     ENDIF
      * IGNORE
     C           F5QTY     IFEQ 0
     C                     ITER
     C                     ENDIF
      *
     C                     EXSR #OUT1
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *----------------------------------------------------*
      *  OUTPUT ABFWPE3                                    *
      *----------------------------------------------------*
     C           #OUT1     BEGSR
      *
     C           FIRST     IFNE 'Y'
     C           F5NOHZ    ANDNESVNOHZ
     C                     CLEARABFWPE31
     C                     WRITEABFWPE31
     C                     EXSR #HDR
     C                     ENDIF
      *
     C                     CLEARABFWPE31
     C                     MOVELF5CRDT    RCV@DT
     C                     MOVELF5NOHZ    SHP@DT
     C                     MOVELF5STID    PLANT
     C                     MOVELF5NONY    DELV#
     C                     MOVELF5MHIN    U@PART
     C                     MOVELF5QTY     OD@QTY
     C                     MOVELF5QTY2    DM@QTY
     C                     MOVELF5NUKE    DOCK
     C                     MOVELF5STFC    ICCODE
      *
     C                     WRITEABFWPE31
     C                     MOVE 'N'       FIRST
     C                     Z-ADDF5NOHZ    SVNOHZ
      *
     C                     ENDSR
      *--------------------------------------------------
      * OUTPUT HEADER
      *--------------------------------------------------
     C           #HDR      BEGSR
      *
     C                     CLEARABFWPE31
     C                     MOVELHDR,1     RCV@DT
     C                     MOVELHDR,2     SHP@DT
     C                     MOVELHDR,3     PLANT
     C                     MOVELHDR,4     DELV#
     C                     MOVELHDR,5     U@PART
     C                     MOVELHDR,6     OD@QTY
     C                     MOVELHDR,7     DOCK
     C                     MOVELHDR,8     ICCODE
     C                     MOVELHDR,9     DM@QTY
     C                     WRITEABFWPE31
      *
     C                     ENDSR
      *--------------------------------------------------
      * INITIALIZE
      *--------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SDAT   8        SHIP DATE
     C                     PARM           $PDAT   8        PROCESS DATE
      *
     C           K#F1      KLIST
     C                     KFLD           K1DATE  80
     C                     KFLD           K1NOHZ  80
      *
     C                     TIME           SDATE
     C                     MOVEL$SDAT     @SDAT   80
     C                     MOVEL$PDAT     @PDAT   80
     C                     MOVE 'Y'       FIRST   1
     C                     Z-ADD0         SVNOHZ  80
      *
     C           $PDAT     IFEQ *BLANK
     C           $PDAT     OREQ *ZEROS
     C                     Z-ADDTODAY     @PDAT
     C                     ENDIF
      *
     C                     Z-ADD@PDAT     K1DATE
      * GET -4 DAYS
     C                     MOVEL@SDAT     $DT8
     C                     MOVE '-'       $SIGN
     C                     MOVEL'0004'    $DAYS
     C                     MOVE 'Y'       $IAF
     C                     CALL 'UTLR10'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN1   1
     C                     MOVEL$TGT8     @START  80
     C                     MOVEL$TGT8     K1NOHZ
      * GET +4 DAYS
     C                     MOVEL@SDAT     $DT8
     C                     MOVE '+'       $SIGN
     C                     MOVEL'0004'    $DAYS
     C                     MOVE 'Y'       $IAF
     C                     CALL 'UTLR10'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN1   1
     C                     MOVEL$TGT8     @END    80
      * HEADER
     C                     EXSR #HDR
      *
     C                     ENDSR
** HDR(10A)
RCV_DATE     01
SHP_DATE     02
PLANT        03
DELIV#       04
USR_PART     05
ORD_QTY      06
DOCK         07
IC_CODE      08
YTD_DEMAND   09
