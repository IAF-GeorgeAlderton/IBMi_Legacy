      ***************************************************
      *          MAIN ROUTINE                           *
      ***************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'01'      #SCRN1
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *BLANK    MAIS
     C                     MOVEL@OUTQ     PMPRNT    P
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------
     C           #SCRN1    BEGSR
      *-----------------------------------------------
      *
     C                     MOVE *ON       *INKE
     C                     GOTO @SKP1
      *
     C**                   EXFMTDSP01
      *
     C           @SKP1     TAG
     C                     MOVE *BLANK    XMSG
     C                     MOVEA'00000'   *IN,61
      *
     C**         *INKI     IFEQ *ON
     C**                   CALL 'ABBR7L'
     C**                   GOTO @SCRN9
     C**                   ENDIF
      *
     C**         *INKC     IFEQ *ON
     C**                   MOVE '99'      @@ID
     C**                   ELSE
     C                     EXSR #CHK1
      * DATE ERROR
     C           *IN85     IFEQ *ON
     C           *IN61     ANDEQ*ON
     C                     MOVE '99'      @@ID
     C                     GOTO @SCRN9
     C                     ENDIF
      *
     C           *IN85     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #WRT
      *
     C           D@CPY     IFNE *ZERO
     C                     EXSR #RED
     C                     EXSR #PMTCH
     C                     OPEN ABBWP72
     C                     EXSR #PRT
     C                     ENDIF
      *
     C                     MOVE '99'      @@ID
     C                     ENDIF
     C**                   ENDIF
      *
     C           @SCRN9    ENDSR
      *-----------------------------------------------
      * CHECK INPUT FIELD
      *-----------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     SETOF                     85
     C           D@YMD     IFEQ 0
     C                     MOVELMSG,1     XMSG
     C                     SETON                     6185
     C                     GOTO #CHK1X
     C                     ENDIF
      *
     C           D@YMD     ADD  20000000  W@YMD
     C           K#ADG     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C  N85                MOVELMSG,2     XMSG
     C                     SETON                     6185
     C                     GOTO #CHK1X
     C                     ELSE
     C                     Z-ADDF8YOBI    Q       10
     C                     MOVE WD,Q      @WDD    3
     C                     ENDIF
      *
     C           W@YMD     CHAINABBPL71              90
     C           *IN90     IFEQ *ON
     C  N85                MOVELMSG,3     XMSG
     C                     SETON                     6185
     C                     GOTO #CHK1X
     C                     ENDIF
      * SHIFT SHOULD BE 1/2/3
     C           D@SHFT    IFLT '1'
     C           D@SHFT    ORGT '3'
     C  N85                MOVELMSG,4     XMSG
     C                     SETON                     6385
     C                     GOTO #CHK1X
     C                     ENDIF
      * COPY
     C           D@CPY     IFLT 1
     C           D@CPY     ORGT 11
     C  N85                MOVELMSG,5     XMSG
     C                     SETON                     6285
     C                     GOTO #CHK1X
     C                     ENDIF
      * LIST TYPE
     C           D@TYPE    IFNE ' '
     C           D@TYPE    ANDNE'1'
     C  N85                MOVELMSG,7     XMSG
     C                     SETON                     6585
     C                     GOTO #CHK1X
     C                     ENDIF
      *
     C                     MOVE W@YMD     PDAT
      * PRINTER SHOULD BE ' ' OR 01-08
     C           D@PRT     IFEQ *BLANK
     C           D@PRT     OREQ '1'
     C           D@PRT     OREQ '2'
     C           D@PRT     OREQ '3'
     C           D@PRT     OREQ '4'
     C           D@PRT     OREQ '5'
     C           D@PRT     OREQ '6'
     C           D@PRT     OREQ '7'
     C           D@PRT     OREQ '8'
     C           D@PRT     OREQ '9'
     C                     SELEC
     C           D@PRT     WHEQ *BLANK
     C                     MOVEL'QPRINTC '@OUTQ   8
     C           D@PRT     WHEQ '1'
     C                     MOVEL'LANPRT02'@OUTQ
     C           D@PRT     WHEQ '2'
     C                     MOVEL'LANPRT09'@OUTQ
     C           D@PRT     WHEQ '3'
     C                     MOVEL'LANPRT03'@OUTQ
     C           D@PRT     WHEQ '4'
     C                     MOVEL'LANPRT04'@OUTQ
     C           D@PRT     WHEQ '5'
     C                     MOVEL'QPRINTB '@OUTQ
     C           D@PRT     WHEQ '6'
     C                     MOVEL'QPRINT  '@OUTQ
     C           D@PRT     WHEQ '7'
     C                     MOVEL'LANPRT10'@OUTQ
     C           D@PRT     WHEQ '8'
     C                     MOVEL'LANPRT05'@OUTQ
     C           D@PRT     WHEQ '9'
     C                     MOVEL'QDKT    '@OUTQ
     C                     ENDSL
     C                     ELSE
     C  N85                MOVELMSG,6     XMSG
     C                     SETON                     6485
     C                     GOTO #CHK1X
     C                     ENDIF
      * IF NO ERROR
     C           *IN85     IFEQ *OFF
     C                     MOVELMSG,8     XMSG
     C                     ENDIF
      *
     C           #CHK1X    ENDSR
      *-----------------------------------------------
      *
      *-----------------------------------------------
     C           #WRT      BEGSR
      *
     C           D@CPY     IFNE *ZERO
     C                     MOVEACMD,1     ARY
     C                     MOVE D@CPY     @CPY    2
     C                     MOVEA@CPY      ARY,54
     C                     MOVEA@OUTQ     ARY,63
     C                     MOVEAARY       P@CMD
     C                     Z-ADD75        P@LEN
     C                     CALL 'QCMDEXC' P#CMD
     C                     OPEN QPRINT
     C                     ENDIF
      * 10 DAYS
     C                     Z-ADD0         @W10    31
     C                     Z-ADD*DATE     K@YMD
     C                     Z-ADD*ZERO     QQ
     C           K#ADGX    SETGTAGDPL121
     C                     DO   *HIVAL
     C                     READPAGDPL121                 90
     C           *IN90     IFEQ *OFF
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADDF8YMD     @10DT   80
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         @W10
     C                     ELSE
     C                     ADD  0.5       @W10
     C                     ENDIF
     C                     ADD  1         QQ
     C           QQ        IFEQ 10
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     OPEN ABBWP71
     C                     OPEN ABBWL71
      *
     C                     CLEARABBWP711
     C                     MOVE *BLANK    WLOCT   6
      * BIG LOOP
     C           K#71      SETLLABBPL71
     C           *IN80     DOUEQ*ON
     C           K#71      READEABBPL71                  80
     C           *IN80     IFEQ *OFF
     C           A7KQTY    ANDNE*ZERO
      *
      * CHECK LIST TYPE
     C           D@TYPE    IFEQ '1'
     C           A7ISDT    ANDEQ0
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE *BLANK    APKUBN  1
     C           A7KNID    IFNE 'A'
     C                     MOVE '9'       APKUBN
     C                     END
      *
      *
     C           W7PART    IFNE *BLANK
     C           W7PART    IFNE A7PART
     C           WLOCT     ORNE A7LOCT
     C           W7KNID    ORNE A7KNID
     C                     EXSR #OUT
     C                     ENDIF
     C                     ENDIF
      *
     C           4         SUBSTA7LOCT:2  W7LOC4
      *
     C                     ADD  A7KQTY    W7KQTY
     C                     MOVE A7PART    W7PART
     C                     MOVE A7LOCT    WLOCT
     C                     MOVE A7KNID    W7KNID
     C           W7ISDT    IFEQ *ZERO
     C                     Z-ADDA7ISDT    W7ISDT
     C                     ELSE
     C           A7ISDT    IFLT W7ISDT
     C           A7ISDT    ANDNE*ZERO
     C                     Z-ADDA7ISDT    W7ISDT
     C                     ENDIF
     C                     ENDIF
      * ASJ
     C                     MOVE A7MCHN    W7MCHN
     C                     MOVE A7CMNT    W7CMNT
     C                     Z-ADDA7LOTS    W7LOTS
     C                     Z-ADDA7DATE    W7DATE
     C           A7MCHN    IFEQ *BLANK
     C           K#AAM     CHAINAAMPL11              91
     C           *IN91     IFEQ *OFF
     C                     Z-ADD1         W       20
     C                     MOVE *BLANK    @NEW
     C           A7LOCT    LOKUPNTKR,W                   10
     C           *IN10     IFEQ *ON
     C                     Z-ADDCHG,W     @CHG
     C           @CHGDT    IFGT *DATE
     C                     MOVE '1'       @NEW
     C                     ENDIF
     C                     ELSE
     C           A7LOCT    LOKUPOTKR,W                   10
     C           *IN10     IFEQ *ON
     C                     MOVE '1'       @NEW
     C                     ENDIF
     C                     ENDIF
      *
     C           @NEW      IFEQ *BLANK
     C           NPRC,W    ANDEQ'HN '
     C                     MOVE 'ASJ'     W7MCHN
     C                     ENDIF
      *
     C           @NEW      IFEQ '1'
     C           OPRC,W    ANDEQ'HN '
     C                     MOVE 'ASJ'     W7MCHN
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      ***************************
      * GET SIZE(GROUP)         *
      ***************************
     C                     MOVELW7LOC4    #LOC1   1
     C                     MOVELW7LOC4    #LOC2   2
     C                     SELEC
     C           #LOC1     WHEQ 'J'
     C           #LOC1     OREQ 'Z'
     C           #LOC2     OREQ 'G7'
     C           #LOC2     OREQ 'G8'
     C                     MOVEL'CV*'     W7SIZE
     C           #LOC1     WHEQ 'X'
     C           #LOC1     OREQ 'G'
     C                     MOVEL'ST*'     W7SIZE
     C           #LOC1     WHEQ 'V'
     C                     MOVEL'NU*'     W7SIZE
     C                     OTHER
     C                     MOVE *BLANK    W7SIZE
     C                     MOVE *BLANK    W7FIL5
     C                     ENDSL
      *
     C           W7SIZE    IFEQ *BLANK
      ***************************
      * MACHINE MASTER          *
      ***************************
     C           K#PP7G    KLIST
     C                     KFLD           K@MCHN  3
     C                     KFLD           K@LOCT  6
      *
     C                     MOVELW7MCHN    K@MCHN
     C                     MOVEL*BLANK    K@LOCT
     C           K#PP7G    CHAINABBPP7G              91
     C           *IN91     IFEQ *OFF
     C           A#SKJY    ANDEQ' '
     C                     MOVELA#SIZE    W7SIZE           SIZE
     C                     MOVELA#SIZE    W7FIL5
     C                     ELSE
     C                     MOVEL*BLANK    K@MCHN
     C                     MOVELA7LOCT    K@LOCT
     C           K#PP7G    CHAINABBPP7G              91
     C           *IN91     IFEQ *OFF
     C           A#SKJY    ANDEQ' '
     C                     MOVELA#SIZE    W7SIZE           SIZE
     C                     MOVELA#SIZE    W7FIL5
     C                     ELSE
     C                     MOVEL'999'     W7SIZE
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
      * ADJUST SIZE (ADD GROUP)
     C           W7SIZE    IFEQ '999'
     C                     MOVEL'OQ*'     W7SIZE
     C                     ENDIF
     C                     MOVELW7LOC4    #LOC1   1
     C                     MOVELW7LOC4    #LOC2   2
      * POSITION 10, 20 OR 30
     C                     MOVELW7LOC4    #LOC1   1        1桁目
     C                     SELEC
     C           #LOC1     WHEQ 'H'                        <HD>
     C           #LOC1     OREQ 'D'                        <HD>
     C                     MOVEL'10'      W7LCID
     C           #LOC1     WHEQ 'T'                        <RL>
     C           #LOC1     OREQ 'M'                        <RL>
     C           #LOC1     OREQ 'N'                        <RL>
     C                     MOVEL'20'      W7LCID
     C                     OTHER                           1桁目
     C                     MOVEL'30'      W7LCID
     C                     ENDSL
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           W7PART    IFNE *BLANK
     C                     EXSR #OUT
     C                     ENDIF
      *
     C                     CLOSEABBWP71
     C                     CLOSEABBWL71
      *
     C                     ENDSR
      *-----------------------------------------------
      *
      *-----------------------------------------------
     C           #OUT      BEGSR
      *
     C                     GOTO @JUMP
      *
     C           W7MCHN    IFEQ 'R78'
     C                     Z-ADD0         SAKA    40
     C                     END
     C           W7MCHN    IFEQ 'R37'
     C                     Z-ADD0         SAKA    40
     C                     END
      *
     C                     MOVE *BLANK    W@A001
      *
     C           W7MCHN    CHAINFCDPP9B              92
     C           *IN92     IFEQ *OFF
     C           F9SKBN    ANDEQ'D'
     C                     SETON                     92
     C                     END
      *
     C           *IN92     IFEQ '0'
     C                     MOVELW7LCID    W@A001  1
     C                     SELEC
     C           W@A001    WHEQ '1'
     C                     MOVEL'5'       W7LCID
     C           W@A001    WHEQ '2'
     C                     MOVEL'6'       W7LCID
     C           W@A001    WHEQ '3'
     C                     MOVEL'7'       W7LCID
     C                     ENDSL
     C                     END
      *
     C           @JUMP     TAG
      *
     C                     WRITEABBWP711
     C                     CLEARABBWP711
      *
     C                     ENDSR
      *-----------------------------------------------
      *
      *-----------------------------------------------
     C           #RED      BEGSR
      *
     C                     OPEN ABBWP71
     C                     OPEN ABBWL71
     C                     OPEN ABBWP72
      *
     C           *LOVAL    SETLLABBWP71
     C                     DO   *HIVAL
     C                     READ ABBWP71                  95
     C   95                LEAVE
     C                     MOVELW7SIZE    K@SIZE  3        SIZE
     C*
     C                     MOVE '10'      K@ID    2
     C                     EXSR #REDX
     C                     MOVE '20'      K@ID    2
     C                     EXSR #REDX
     C                     MOVE '30'      K@ID    2
     C                     EXSR #REDX
     C                     MOVE '50'      K@ID    2
     C                     EXSR #REDX
     C                     MOVE '60'      K@ID    2
     C                     EXSR #REDX
     C                     MOVE '70'      K@ID    2
     C                     EXSR #REDX
     C*
     C           K@SIZE    SETGTABBWP71
     C                     ENDDO
      *
     C                     CLOSEABBWP72
      *
     C                     ENDSR
      *-----------------------------------------------
      *
      *-----------------------------------------------
     C           #REDX     BEGSR
      *
     C           K#WP71    KLIST
     C                     KFLD           K@SIZE  3
     C                     KFLD           K@ID
      *
     C                     MOVELK@ID      W@ID    2
     C                     MOVE '9'       W@ID
     C                     Z-ADD*ZERO     W@SQNO  50
     C           K@ID      IFEQ '30'
     C           K@ID      OREQ '70'
     C           K#WP71    SETLLABBWP71                    所番地順
     C                     ELSE
     C           K#WP71    SETLLABBWL71                    機番順
     C**         K#WP71    SETLLABBWP71                    所番地順
     C                     ENDIF
      *
     C           *IN90     DOUEQ*ON
     C           K@ID      IFEQ '30'
     C           K@ID      OREQ '70'
     C           K@SIZE    READEABBWP71                  90
     C                     ELSE
     C           K@SIZE    READEABBWL71                  90
     C                     ENDIF
     C           *IN90     IFEQ *OFF
     C           W7LCID    IFGT W@ID
     C                     LEAVE
     C                     ENDIF
      * CHECK LIST TYPE
     C           D@TYPE    IFEQ '1'
     C           W7ISDT    ANDEQ0
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         W@SQNO
     C                     MOVELK@ID      W7EXNO
     C                     Z-ADDW@SQNO    W7SEQN
     C           W7KNID    IFEQ 'A'
     C           K#FCC     CHAINAAMPL11              91
     C           *IN91     IFEQ *OFF
     C                     Z-ADD15        W       20
     C                     DO   15
     C                     MOVE *BLANK    @NEW    1
     C           CHG,W     IFNE *ZERO
     C                     Z-ADDCHG,W     @CHG
     C           @CHGDT    IFGT *DATE
     C                     MOVE '1'       @NEW
     C                     ENDIF
     C                     ENDIF
      *
     C           @NEW      IFEQ *BLANK
     C           NCKQ,W    IFNE *BLANK
     C                     MOVE NCKQ,W    W7KAN
     C                     MOVE NTKR,W    W7LOC
     C                     MOVE NPRC,W    W7PRC
     C                     LEAVE
     C                     ENDIF
     C                     ELSE
     C           OCKQ,W    IFNE *BLANK
     C                     MOVE OCKQ,W    W7KAN
     C                     MOVE OTKR,W    W7LOC
     C                     MOVE OPRC,W    W7PRC
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     SUB  1         W
     C                     ENDDO
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVELW7SIZE    W7FIL5
      *  GET FIRST PROCESS MACHINE
     C                     MOVE *BLANK    $LOC
     C                     CALL 'UTLR15'
     C                     PARM           W7PRT1
     C                     PARM           W7PRT2
     C                     PARM           W7PRT3
     C                     PARM           $LOC    6
     C                     PARM           @MCN
     C                     PARM           @MCN1   3        FIRST PROC MACHINE
     C                     PARM           @RTN    1
     C                     MOVEL@MCN1     W7FIL3
      * ARRANGE SIZE
     C                     MOVE *BLANK    W7FIL2
     C           W7SIZE    IFEQ 'CV*'
     C                     MOVEL'CV '     W7SIZE
     C                     MOVEL'99'      W7FIL2
     C                     ENDIF
     C           W7SIZE    IFEQ 'ST*'
     C                     MOVEL'ST '     W7SIZE
     C                     MOVEL'99'      W7FIL2
     C                     ENDIF
     C           W7SIZE    IFEQ 'NU*'
     C                     MOVEL'NUT'     W7SIZE
     C                     MOVEL'99'      W7FIL2
     C                     ENDIF
     C           W7SIZE    IFEQ 'OQ*'
     C                     MOVEL'OQ '     W7SIZE
     C                     MOVEL'99'      W7FIL2
     C                     ENDIF
      *
     C                     WRITEABBWP721
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------
      *
      *-----------------------------------------------
     C           #PMTCH    BEGSR
      *
     C                     OPEN ABBWL72
     C           K#72LR    KLIST
     C                     KFLD           K#PRT1
     C                     KFLD           K#PRT2
     C                     KFLD           K#PRT3
     C                     KFLD           K#LOC4
     C           *LIKE     DEFN W7PRT1    K#PRT1
     C           *LIKE     DEFN W7PRT2    K#PRT2
     C           *LIKE     DEFN W7PRT3    K#PRT3
     C           *LIKE     DEFN W7LOC4    K#LOC4
     C                     MOVEL*BLANK    K#PRT1
     C                     MOVEL*BLANK    K#PRT2
     C                     MOVEL*BLANK    K#PRT3
     C                     MOVEL*BLANK    K#LOC4
     C           *LOVAL    SETLLABB72LR
      *
     C                     DO   *HIVAL
      *
     C                     READ ABB72LR                  89
     C   89                LEAVE
      *
     C           K#PRT1    IFEQ *BLANK
     C           K#PRT2    ANDEQ*BLANK
     C           K#PRT3    ANDEQ*BLANK
     C                     MOVELW7PRT1    K#PRT1
     C                     MOVELW7PRT2    K#PRT2
     C                     MOVELW7PRT3    K#PRT3
     C                     ITER
     C                     END
     C           W7PRT1    IFNE K#PRT1
     C           W7PRT2    ORNE K#PRT2
     C           W7PRT3    ORNE K#PRT3
     C                     MOVELW7PRT1    K#PRT1
     C                     MOVELW7PRT2    K#PRT2
     C                     MOVELW7PRT3    K#PRT3
     C                     ITER
     C                     END
      *
     C                     DO
     C           K#FCC     CHAINAAMPL11              88
     C   88                LEAVE
      *
     C                     Z-ADD1         I1      20
     C                     Z-ADD2         I2      20
     C                     DO   *HIVAL
      *
     C           I2        IFGT 15
     C           NTKR,I2   OREQ *BLANK
     C                     MOVELNTKR,I1   @6
     C                     MOVEL@4        K#LOC4
     C           K#72LR    CHAINABB72LR              88
     C   88                LEAVE
     C                     MOVEL*ON       W7FIL1
     C                     UPDATABB72LR
     C                     LEAVE
     C                     END
     C           NTKR,I2   IFEQ '------'
     C           NTKR,I2   OREQ '++++++'
     C                     ADD  1         I2
     C                     ITER
     C                     END
     C           NTKR,I1   IFEQ '------'
     C           NTKR,I1   OREQ '++++++'
     C                     ADD  1         I1
     C                     ITER
     C                     END
     C                     MOVELNTKR,I2   @6
     C                     MOVEL@4        K#LOC4
     C           K#72LR    CHAINABB72LR              88
     C*TCHK 88             LEAVE
     C           *IN88     IFEQ *ON
     C                     ADD  1         I1
     C                     ADD  1         I2
     C                     ITER
     C                     END
     C                     MOVELW7ISDT    W@ISDT  8
     C                     MOVELNTKR,I1   @6
     C                     MOVEL@4        K#LOC4
     C           K#72LR    CHAINABB72LR              88
     C*TCHK 88             LEAVE
     C           *IN88     IFEQ *ON
     C                     ADD  1         I1
     C                     ADD  1         I2
     C                     ITER
     C                     END
     C                     MOVE W@ISDT    W7FIL4
     C                     MOVEL*ON       W7FIL1
     C                     UPDATABB72LR
     C                     ADD  1         I1
     C                     ADD  1         I2
      *
     C                     ENDDO
      *
     C                     ENDDO
      *
     C                     MOVEL'9999'    K#LOC4
     C           K#72LR    SETGTABB72LR
      *
     C                     ENDDO
      *
     C                     CLOSEABBWL72
      *
     C                     ENDSR
      *-----------------------------------------------
      *
      *-----------------------------------------------
     C           #PRT      BEGSR
      *
     C                     Z-ADD0         @CT@
     C                     Z-ADD0         @QT@
     C                     Z-ADD0         @ATTL   50
     C                     Z-ADD0         @PTTL   50
      *
     C                     TIME           @@TIME  60
     C                     MOVE *ALL'-'   @@LN1 130
     C                     MOVE *ALL'-'   @@LN2 198
     C                     Z-ADDW@YMD     W@DAT6  60
      *
     C           K#WP72    KLIST
     C                     KFLD           K@DATE  80
     C                     KFLD           K@SIZE
      *
     C           *LOVAL    SETLLABBWP72
     C                     DO   *HIVAL
     C                     READ ABBWP72                  89
     C   89                LEAVE
      *
     C                     MOVELW7DATE    K@DATE  80
     C                     MOVELW7SIZE    K@SIZE
     C                     MOVEA'00'      *IN,97
     C                     MOVE '1'       $$EXNO  1        = 1, 2, 3
     C                     EXSR #PRT01
     C                     MOVEA'00'      *IN,97
     C                     MOVE '2'       $$EXNO           = 5, 6, 7
     C                     EXSR #PRT01
     C           K#WP72    SETGTABBWP72
     C                     ENDDO
      * PRINT GROUP TOTAL
     C           1         DO   SQ2       IX
     C           IX        IFEQ 1
     C                     MOVE *OFF      *IN49
     C                     ELSE
     C                     MOVE *ON       *IN49
     C                     ENDIF
     C   OF                EXSR #HED
     C                     EXCPT@TT2
     C                     ENDDO
      * PRINT GRAND TOTAL
     C           @ATTL     IFNE 0
     C           @PTTL     ORNE 0
     C                     Z-ADD@QT@      @QTT
     C                     Z-ADD@CT@      @CTT
     C                     Z-ADD@ATTL     @ATT
     C                     Z-ADD@PTTL     @PTT
     C           D@TYPE    IFEQ '1'
     C                     MOVELTT1,6     @TITL1
     C                     ELSE
     C                     MOVELTT1,2     @TITL1
     C                     ENDIF
     C           @QTT,1    ADD  @QTT,2    @QTT,4
     C                     ADD  @QTT,3    @QTT,4
     C           @CTT,1    ADD  @CTT,2    @CTT,4
     C                     ADD  @CTT,3    @CTT,4
     C                     MOVE *OFF      *IN48
     C                     EXCPT@TT1
     C                     ENDIF
      *
     C           D@TYPE    IFEQ *BLANK
      * PRINT KANBAN TOTAL (TYPE:ALL)
     C                     EXSR #KAN@A
     C                     ELSE
      * PRINT KANBAN TOTAL (TYPE:APICS ONLY)
     C                     EXSR #KAN@P
     C                     EXSR #KAN@N
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------
      * START PRINT
      *-----------------------------------------------
     C           #PRT01    BEGSR
      *
     C                     Z-ADD*ZERO     WSQNO   50
     C                     MOVE *BLANK    WLCID   1
     C                     MOVE *BLANK    @@LID   1
     C                     MOVE *BLANK    WKNID   1
     C                     Z-ADD*ZERO     @QT
     C                     Z-ADD*ZERO     @CTT
     C                     Z-ADD*ZERO     @QTT
     C                     Z-ADD*ZERO     @ATT    50
     C                     Z-ADD*ZERO     @PTT    50
     C                     Z-ADD*ZERO     @SD4
     C                     Z-ADD*ZERO     @SD8
     C                     Z-ADD*ZERO     LOT
     C                     Z-ADD*ZERO     @SET
     C                     Z-ADD*ZERO     @ACT
     C                     MOVEL*BLANK    @DUP
     C                     MOVE *BLANK    WPART
      *
     C           K#WP72    SETLLABBWP72
     C           *IN80     DOUEQ*ON
     C           K#WP72    READEABBWP72                  80
     C*
     C  N80      $$EXNO    IFEQ '1'                        = 1, 2, 3
     C           W7EXNO    IFGE '5'
     C                     ITER
     C                     ENDIF
     C                     ELSE
     C           W7EXNO    IFLT '5'
     C                     ITER
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN80     IFEQ *OFF
     C           @NEXT@    TAG
      * DETAIL LINE
     C           WSQNO     IFNE *ZERO
     C           WSQNO     ANDNEW7SEQN
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXSR #HED
     C                     ENDIF
      *
     C                     EXSR #DTL1
     C  N98                MOVE *ON       *IN98
     C                     ENDIF
      *
     C                     MOVE W7EXNO    X       10
     C                     SELEC
     C           W7EXNO    WHEQ '5'
     C                     Z-ADD1         X
     C           W7EXNO    WHEQ '6'
     C                     Z-ADD2         X
     C           W7EXNO    WHEQ '7'
     C                     Z-ADD3         X
     C                     ENDSL
     C           W7LC      IFEQ '1'
     C           W7LC      OREQ '2'
     C           W7LC      OREQ '5'
     C           W7LC      OREQ '6'
     C                     MOVE W7MCHN    MCN,X
     C                     ENDIF
      *
     C                     SELEC
     C           W7KNID    WHEQ 'Q'
     C                     MOVEL'OQ'      KID,X     P
     C           W7KNID    WHEQ 'L'
     C                     MOVEL'LAN'     KID,X
     C           W7KNID    WHEQ 'R'
     C                     MOVEL'RL'      KID,X     P
     C           W7KNID    WHEQ '1'
     C                     MOVEL'AOQ'     KID,X     P
     C           W7KNID    WHEQ '2'
     C                     MOVEL'RRT'     KID,X     P
     C           W7KNID    WHEQ 'S'
     C                     MOVEL'SB '     KID,X     P
     C           W7KNID    WHEQ 'K'
     C                     MOVEL'KRO'     KID,X     P
     C           W7KNID    WHEQ 'F'
     C                     MOVEL'FRL'     KID,X     P
     C           W7KNID    WHEQ 'Z'
     C                     MOVEL'BZ '     KID,X     P
     C           W7KNID    WHEQ 'Y'
     C                     MOVEL'SL '     KID,X     P
     C           W7KNID    WHEQ 'H'
     C                     MOVEL'HN '     KID,X     P
     C                     OTHER
     C                     MOVELW7KNID    KID,X     P
     C                     ENDSL
      *
     C                     MOVE W7PRT1    @PRT1
     C                     MOVE W7PRT2    @PRT2
     C                     MOVE W7PRT3    @PRT3
     C           @PRT2     IFNE *BLANK
     C                     MOVEL'-'       @HFN1
     C                     ELSE
     C                     MOVE *BLANK    @HFN1
     C                     ENDIF
     C           @PRT3     IFNE *BLANK
     C                     MOVEL'-'       @HFN2
     C                     ELSE
     C                     MOVE *BLANK    @HFN2
     C                     ENDIF
     C                     MOVE @PART     PRT,X
      *
     C           W7FIL1    IFEQ *ON
     C*TCHK                MOVEL'@@@'     @DUP,X
     C           W7KNID    IFEQ 'Q'
     C           W7FIL4    ANDNE*ZERO
     C                     MOVELW7FIL4    W@DUP1
     C                     MOVEL'/'       W@DUP2
     C                     MOVE W7FIL4    W@DUP3
     C                     MOVELW@DUP     @DUP,X
     C                     ELSE
     C                     MOVEL'@@@  '   @DUP,X
     C                     END
     C                     ELSE
     C                     MOVEL*BLANK    @DUP,X
     C                     END
      *
     C                     Z-ADD*ZERO     @ACQY   90
     C                     Z-ADD@10DT     K@NODT
      *
     C           X         IFEQ 1
     C                     MOVE *BLANK    ITM
     C                     Z-ADD*ZERO     QQ      30
     C           K#FCC     SETLLGHCPL22
     C           *IN95     DOUEQ*ON
     C           K#FCC     READEGHCPL22                  95
     C           *IN95     IFEQ *OFF
     C                     MOVE MMJHN1    @@JHN1
     C                     MOVE MMJHN2    @@JHN2
     C                     MOVE MMJHN3    @@JHN3
     C           @@JHIN    LOKUPITM                      96
     C           *IN96     IFEQ *ON
     C                     ITER
     C                     ENDIF
     C                     ADD  1         QQ
     C                     MOVE @@JHIN    ITM,QQ
     C                     EXSR #ACTQ
     C                     ENDIF
     C                     ENDDO
      *
     C                     ELSE
     C                     MOVE W7PRT1    @@JHN1
     C                     MOVE W7PRT2    @@JHN2
     C                     MOVE W7PRT3    @@JHN3
     C                     EXSR #ACTQ
     C                     ENDIF
      *
     C                     Z-ADD0         WSYS    50
     C           K#FCC     CHAINFCEPL011             95
     C           *IN95     IFEQ '0'
     C           A2GSKD    ANDEQ*BLANK
      *
     C           *DATE     IFGE A2SYHZ
     C                     Z-ADDA2SSYS    WSYS
     C                     ELSE
     C                     Z-ADDA2KSYS    WSYS
     C                     END
     C                     ENDIF
      *
     C           WSYS      IFNE 0
     C           @ACQY     DIV  WSYS      @ABOX   70
     C                     MVR            @@MVR   70
     C                     END
     C           @@MVR     IFGT *ZERO
     C                     ADD  1         @ABOX
     C                     ENDIF
     C           @W10      IFNE 0
     C           @ABOX     DIV  @W10      @ACTB   41H
