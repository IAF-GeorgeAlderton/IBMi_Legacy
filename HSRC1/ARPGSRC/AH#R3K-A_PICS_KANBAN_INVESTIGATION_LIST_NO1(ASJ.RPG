     C           *IN90     IFEQ '0'
      *
     C           *ENTRY    PLIST
     C                     PARM           US     10
     C                     PARM           PKYM    6
     C                     PARM           PYMD1   8
     C                     PARM           PYMD2   8
     C*****                PARM           PMAIS   30
     C                     PARM           PMAIS   50
     C                     PARM           PTOTL   30
     C                     PARM           PTSURA  40
     C*                    PARM           PTSURA  30
     C                     PARM           WSYS
     C                     PARM           LT
     C                     PARM           @@SET
      *
     C                     Z-ADD0         @YYMM
     C                     MOVE PKYM      $KYM
      *
     C           *DATE     DIV  100       @@YM    60
      *
     C                     SETON                     2190
     C                     Z-ADD0         PAG     50
     C                     MOVE *BLANK    PSW     1
      *----------------------------------------------------*
      *   RUN ONLY THE FIRST TIME
      *----------------------------------------------------*
     C           PSW       IFEQ *BLANK
     C                     MOVE *DATE     HYMD8
TCHK3C                     MOVELPKYM      HYMD8
     C                     TIME           TIME
     C                     MOVE *BLANK    J8NM
     C           US        CHAINRGAPL111             10
     C  N10                MOVELJ8NAME    J8NM
     C                     MOVE '1'       PSW     1
     C                     END
      *
     C*----------------------------------------*
     C*  N MONTH, N+1 MONTH, N+2 MONTH DATE    *
     C*----------------------------------------*
     C                     MOVELHYMD8     NYMD1
      *
     C                     Z-ADDNYMD1     NYMD2
     C           NMM1      ADD  1         NMM2
     C           NMM2      IFEQ 13
     C                     Z-ADD01        NMM2
     C           NYY1      ADD  1         NYY2
     C                     END
      *
     C                     Z-ADDNYMD2     NYMD3
     C           NMM2      ADD  1         NMM3
     C           NMM3      IFEQ 13
     C                     Z-ADD01        NMM3
     C           NYY2      ADD  1         NYY3
     C                     END
      *
     C*----------------------------------------------------*
     C*  ESTABLISHED MONTH, N MONTH, N+1 MONTH, N+2 MONTH WORKING DAY
     C*----------------------------------------------------*
     C                     Z-ADD1         A
     C                     Z-ADD0         @CDD
     C           1         DO   4         A
     C                     Z-ADD@YYMM,A   @UYM
      *
     C                     Z-ADD0         $KCD    31
     C           KEY3      SETLLAGDPL121
      *
     C                     DO   *HIVAL
     C                     SETOF                     09
     C*
     C           KEY3      READEAGDPL121                 09
     C           *IN09     IFEQ '0'
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
      *
     C           F8HIRU    IFEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         $KCD
     C                     ELSE
      *
     C                     ADD  0.5       $KCD
     C                     END
      *
     C                     END
     C                     END
     C  N09                END
      *
     C                     Z-ADD$KCD      @CDD,A
     C                     END
     C                     END
      *
     C           *INL1     IFEQ '1'
      *
     C                     Z-ADD*ZERO     BHK
     C                     Z-ADD*ZERO     BHN
     C                     Z-ADD*ZERO     BBN
     C                     Z-ADD*ZERO     BBI
      *
     C                     MOVE *BLANK    @MEMO
     C                     MOVEL*BLANK    @PSON
     C                     Z-ADD*ZERO     @MDAT
     C           KEY       CHAINAH#PP80              85
     C           *IN85     IFEQ *OFF
     C                     MOVELAHMEMO    @MEMO
     C                     Z-ADDAHYEAR    @MYY
     C                     Z-ADDAHMNTH    @MMM
     C                     Z-ADDAHDAY     @MDD
     C           AHUSER    CHAINRGAPL111             85
     C  N85                MOVELJ8NAME    @PSON
     C                     ENDIF
      *
     C           *IN21     IFEQ '1'
     C                     SETOF                     10
     C                     ADD  1         PAG
     C           PAG       IFEQ 1
     C                     WRITEHED
     C                     SETOF                     21
     C                     END
     C                     END
      *
      *----------------------------------------------------*
      *  SET THE PART NUMBER
      *----------------------------------------------------*
     C                     MOVE *BLANK    HINA
     C                     MOVE *BLANK    HINB
     C                     MOVELAHHIN1    HIN1
     C                     MOVELAHHIN2    HIN2
     C                     MOVELAHHIN3    HIN3
      *
     C           HIN2      IFNE *BLANK
     C                     MOVEL'-'       HINA
     C                     END
      *
     C           HIN3      IFNE *BLANK
     C                     MOVEL'-'       HINB
     C                     END
      * HALF FINISHED PRODUCT
     C                     MOVE *BLANK    BNCHII
     C                     MOVE *BLANK    HINI
TCHK1C           KEY       SETLLFCEPL41
TCHK1C                     DO   *HIVAL
TCHK1C           KEY       READEFCEPL41                  85
TCHK1C   85                LEAVE
TCHK1C           F4GSKD    IFEQ *BLANK
TCHK1C                     LEAVE
TCHK1C                     END
TCHK1C                     ENDDO
      *
     C           *IN85     IFEQ *OFF
     C                     MOVELF4PRT1    HIN1I
     C                     MOVELF4PRT2    HIN2I
     C                     MOVELF4PRT3    HIN3I
      *
     C           HIN2I     IFNE *BLANK
     C                     MOVEL'-'       HINAI
     C                     END
      *
     C           HIN3I     IFNE *BLANK
     C                     MOVEL'-'       HINBI
     C                     END
      *
     C           KEYI      CHAINFCEPL011             40
     C           *IN40     IFEQ '0'
      *
     C           A2TRHZ    IFGT AHYMD
     C                     MOVE A2KTRK    BNT1I
     C                     MOVE A2KTRT    BNT2I
     C                     MOVE A2KTRR    BNT3I
     C                     MOVE A2KTRD    BNT4I
      *
     C           A2KTRK    IFEQ *BLANK
     C           A2KTRT    ANDEQ*BLANK
     C           A2KTRR    ANDEQ*BLANK
     C           A2KTRD    ANDEQ*BLANK
     C                     MOVE A2STRK    BNT1I
     C                     MOVE A2STRT    BNT2I
     C                     MOVE A2STRR    BNT3I
     C                     MOVE A2STRD    BNT4I
     C                     END
     C                     ELSE
      *
     C                     MOVE A2STRK    BNT1I
     C                     MOVE A2STRT    BNT2I
     C                     MOVE A2STRR    BNT3I
     C                     MOVE A2STRD    BNT4I
     C                     END
      *
      *
     C           A2SYHZ    IFGT AHYMD
     C                     Z-ADDA2KSYS    WSYSX   70
     C           A2KSYS    IFEQ 0
     C                     Z-ADDA2SSYS    WSYSX
     C                     ENDIF
     C                     ELSE
     C                     Z-ADDA2SSYS    WSYSX
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
      *
      * %0002 FINISHED PARTS
     C           KEY       SETGTAAPTL011
     C                     DO   *HIVAL
     C           KEY       REDPEAAPTL011                 10
     C   10                LEAVE
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
     C           L5STYY    IFNE 9999
     C                     ITER
     C                     ENDIF
     C                     MOVE L5TKR1    BNT1I
     C                     MOVE L5TKR2    BNT2I
     C                     MOVE L5TKR3    BNT3I
     C                     MOVE L5TKR4    BNT4I
     C                     LEAVE
     C                     ENDDO
      *
     C           BNT2I     IFNE *BLANK
     C                     MOVE '-'       BN1I
     C                     END
     C           BNT3I     IFNE *BLANK
