     C           *IN20     IFEQ '0'
     C           I         IFEQ 1
     C                     Z-ADDF8YMD     WSYMD   80
     C                     END
     C                     Z-ADDF8YMD     WYMD
      *
     C                     SUB  1         U
     C                     Z-ADDF8MD      HMD,U
      *
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     MOVE '*'       HCD,U
