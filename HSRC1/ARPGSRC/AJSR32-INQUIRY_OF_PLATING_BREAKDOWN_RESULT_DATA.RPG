     H            Y.
      ** AJSR32 *******************************************
      * INQUIRY OF PLATING BREAKDOWN RESULT DATA.         *
      * PROGRAM ID.  : AJSR32. <RPG>                      *
      * CREATE DATE. : 1997/MAR/13.                       *
      * AUTHOR.      : S.OHTAKE.                          *
      ******************************************* AJSR32 **
     FAJSPW32 CF  E                    WORKSTN
     F                                        RRN   KSFILE DSP2R
     FAJSPL32 IF  E           K        DISK
     FAJSPL34 IF  E           K        DISK
      *****************************************************************
     E                    MSG     1   6 60               d[ｰxｮﾈｰﾆﾞ
      *****************************************************************
     I            DS
     I                                        1   80J3SKHZ
     I                                        1   40J3SKYY
     I                                        5   60J3SKMM
     I                                        7   80J3SKDD
     I            DS
     I                                        1   80J3WKHZ
     I                                        1   40J3BRYY
     I                                        5   60J3BRMM
     I                                        7   80J3BRDD
     I            DS
     I                                        1   60J3WKTM
     I                                        1   20J3BRJI
     I                                        3   40J3BRFN
     I                                        5   60J3BRBY
     I            DS
     I                                        1   80J3KEHZ
     I                                        1   40J3REYY
     I                                        5   60J3REMM
     I                                        7   80J3REDD
     I            DS
     I                                        1   60J3KETM
     I                                        1   20J3REJI
     I                                        3   40J3REFN
     I                                        5   60J3REBY
     I            DS
     I                                        1   80SHIZ
     I                                        1   40SYY
     I                                        5   60SMM
     I                                        7   80SDD
     I            DS
     I                                        1   80EHIZ
     I                                        1   40EYY
     I                                        5   60EMM
     I                                        7   80EDD
      *****************************************************************
      *  START  PROGRAM <AJSR32>
      *****************************************************************
     C           STP0      TAG
     C                     MOVE *BLANK    COD
     C                     Z-ADD*ZERO     SHIZ
     C                     Z-ADD*ZERO     EHIZ
      ******************************************************
      *  EXFMT  <fﾞx] 1>                                   *
      ******************************************************
     C           STP1      TAG
     C                     Z-ADD*ZERO     RRN     50
     C                     EXFMTAJSPW321
     C                     MOVEA'000'     *IN,01
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    ERR
     C                     MOVEA'1'       *IN,92
     C                     WRITEDSP2C
     C                     MOVEA'0'       *IN,92
      *
B001 C           *INKA     IFEQ '1'
     C                     MOVEL'1'       *INLR
     C                     RETRN
E001 C                     END
      ******************************************************
      *  <fﾞx] 1 ﾉ kｩｮh>                                   *
      ******************************************************
B001 C           COD       IFEQ 0
     C                     MOVEA'1'       *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,1     ERR
     C                     GOTO STP1
E001 C                     END
      *
B001 C           SHIZ      IFNE *ZERO
B002 C           SMM       IFGT 12
     C           SMM       ORLT 01
     C           SDD       ORGT 31
     C           SDD       ORLT 01
     C                     MOVEA'1'       *IN,02
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,4     ERR
     C                     GOTO STP1
E002 C                     END
E001 C                     END
      *
B001 C           EHIZ      IFNE *ZERO
B002 C           EMM       IFGT 12
     C           EMM       ORLT 01
     C           EDD       ORGT 31
     C           EDD       ORLT 01
     C                     MOVEA'1'       *IN,03
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,6     ERR
     C                     GOTO STP1
E002 C                     END
E001 C                     END
      *
     C           KEY1      KLIST
     C                     KFLD           COD
     C                     KFLD           SYY
     C                     KFLD           SMM
     C                     KFLD           SDD
      *
     C           KEY3      KLIST
     C                     KFLD           SYY
     C                     KFLD           SMM
     C                     KFLD           SDD
     C*                    KFLD           COD
      *
     C           KEY2      KLIST
     C                     KFLD           COD
      *
     C           @LOOP     TAG
     C                     Z-ADD*ZERO     CNTR    50
     C                     EXSR #SET
      *
     C           ERR       IFNE *BLANK
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP1
     C                     END
      *
     C                     Z-ADD1         RCDNBR
      ******************************************************
      *  EXFMT  (fﾞx] 2)                                   *
      ******************************************************
     C           STP2      TAG
     C                     MOVEA'0'       *IN,81
     C                     WRITEDSP2X
     C                     MOVEA'1'       *IN,91
     C                     EXFMTDSP2C
     C                     MOVEA'0'       *IN,91
      *
     C                     MOVEA'0'       *IN,44
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    ERR
      *
B001 C           *INKC     IFEQ '1'
     C                     GOTO STP0
E001 C                     END
      *  ﾜｰﾓ aｮﾎﾟ
     C           *IN,81    IFEQ '1'
     C                     Z-ADD*ZERO     CNTR
     C                     EXSR ROLLUP
     C                     Z-ADDRRN       RCDNBR
     C   44                MOVEA'1'       *IN,99
     C                     GOTO STP2
     C                     END
      *
     C                     Z-ADD1         RCDNBR
      *
     C                     Z-ADDRRN       XXRRN   50
B001 C                     DO   *HIVAL    RRN@@   50
     C           RRN@@     CHAINDSP2R                42
B002 C           *IN,42    IFEQ '0'
E002 C                     END
E001 C  N42                END
      *
     C                     Z-ADD*ZERO     RRN
     C                     GOTO @LOOP
      ******************************************************
     C           #SET      BEGSR                           *
      ******************************************************
      *  ﾅﾎﾞﾎｦbﾓ ﾈｮn
     C                     MOVEA'1'       *IN,92
     C                     WRITEDSP2C
     C                     MOVEA'0'       *IN,92
      *
     C           COD       IFEQ 9999
     C           KEY3      SETLLAJSPL341
     C                     ELSE
     C           KEY1      SETLLAJSPL321
     C                     ENDIF
      *  ﾅﾎﾞﾎｦbﾓ ﾛﾃｰnﾞ CLR
     C                     Z-ADD*ZERO     @CODE
     C                     Z-ADD*ZERO     @BTIM
     C                     Z-ADD*ZERO     @BRHZ
     C                     Z-ADD*ZERO     @BRTM
     C                     Z-ADD*ZERO     @REHZ
     C                     Z-ADD*ZERO     @RETM
     C                     MOVE *BLANK    @BRNA
     C                     Z-ADD*ZERO     #CODE
     C                     Z-ADD*ZERO     #BTIM
     C                     Z-ADD*ZERO     #BRHZ
     C                     Z-ADD*ZERO     #BRTM
     C                     Z-ADD*ZERO     #REHZ
     C                     Z-ADD*ZERO     #RETM
     C                     MOVE *BLANK    #BRNA
      *
B001 C                     DO   *HIVAL
     C           MORE1     TAG
     C           COD       IFEQ 9999
     C                     READ AJSPL341                 40
     C   40                GOTO @@@
     C                     ELSE
     C           KEY2      READEAJSPL321                 40
     C   40                GOTO @@@
     C                     ENDIF
      *
     C           J3SKJY    IFEQ 'D'
     C           J3SKHZ    IFLE *DATE
     C                     GOTO MORE1
     C                     END
     C                     END
      *
B002 C           *IN,40    IFEQ '0'
     C                     MOVEA'0'       *IN,21
     C           J3WKHZ    CABLTSHIZ      @END
     C           J3WKHZ    CABGTEHIZ      @@@
     C                     Z-ADDJ3BRCD    @CODE
     C                     Z-ADDJ3WKHZ    @BRHZ
     C                     Z-ADDJ3WKTM    @BRTM
     C                     Z-ADDJ3BTIM    @BTIM
     C                     Z-ADDJ3KEHZ    @REHZ
     C                     Z-ADDJ3KETM    @RETM
     C                     MOVE J3BRNA    @BRNA
      *
     C                     ADD  1         RRN
     C                     ADD  1         CNTR
     C                     WRITEDSP2R
      * MAX mﾞｰj <15>
     C           CNTR      CABEQ15        @@@
E002 C                     END
     C           @END      TAG
E001 C  N40                END
      *
     C           @@@       TAG
      *  fﾞbnc mﾞｰj oﾆ
B001 C           RRN       IFEQ 0
     C                     MOVEA'111'     *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,2     ERR
     C                     END
      *
     C                     ENDSR
      ******************************************************
     C           ROLLUP    BEGSR                           *
      ******************************************************
     C                     MOVE *BLANK    SW      1
B001 C                     DO   *HIVAL
     C           MORE2     TAG
     C           COD       IFEQ 9999
     C                     READ AJSPL341                 40
     C   40                GOTO @ROLE
     C                     ELSE
     C           KEY2      READEAJSPL321                 40
     C   40                GOTO @ROLE
     C                     ENDIF
      *
     C           J3SKJY    IFEQ 'D'
     C           J3SKHZ    IFLE *DATE
     C                     GOTO MORE2
     C                     END
     C                     END
      *
B002 C           *IN,40    IFEQ '0'
     C           J3WKHZ    CABLTSHIZ      @END1
     C           J3WKHZ    CABGTEHIZ      @ROLE
     C                     MOVEL'*'       SW
     C                     Z-ADDJ3BRCD    @CODE
     C                     Z-ADDJ3WKHZ    @BRHZ
     C                     Z-ADDJ3WKTM    @BRTM
     C                     Z-ADDJ3BTIM    @BTIM
     C                     Z-ADDJ3KEHZ    @REHZ
     C                     Z-ADDJ3KETM    @RETM
     C                     MOVE J3BRNA    @BRNA
      *
     C                     ADD  1         RRN
     C                     ADD  1         CNTR
     C                     WRITEDSP2R
     C           CNTR      CABEQ15        @ROLE
E002 C                     END
     C           @END1     TAG
E001 C  N40                END
      *
     C           @ROLE     TAG
      *  ﾃﾛbﾆﾞｭc mﾞｰj oﾆ
B001 C           SW        IFEQ *BLANK
     C                     MOVEA'1'       *IN,44
E001 C                     END
      *
     C                     ENDSR
      *****************************************************************
**  MSG (ERROR MESSAGE )
E-01 INPUT
E-02 THERE ISN'T APPLICABLE DATA.
E-03 INPUT BREAKDOWN DAY START
E-04 BREAKDOWN DAY START ISN'T RIGHT
E-05 INPUT BREAKDOWN DAY EXIT
E-06 BREAKDOWN DAY EXIT ISN'T RIGHT
