     F******************************************** BTMRC1 **
     FINVPW49 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN   KSFILE SFREC1
     FINVWP41 IF  E                    DISK
      *
     IINFDS       DS
     I                                    B 378 3790$$RRN
     I****************************
     I*プログラム状況データ構造*
     I****************************
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
     C*
     C           *ENTRY    PLIST
     C                     PARM           P@BAN1  1
     C                     PARM           P@BAN2  2
     C                     PARM           P@BAN3  2
     C                     PARM           P@BAN4  1
     C*
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C* 初期ﾈｮmb
     C*===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C*  SFLCLR
     C                     SETON                     72
     C                     WRITESFCTL1
     C                     SETOF                     72
     C                     Z-ADD0         RRN     40
     C                     Z-ADD0         ENDRRN  40
     C                     MOVE *BLANK    @@UMU   1        データ有無
      *
     C                     DO   *HIVAL
     C                     READ INVWP41                  88
     C   88                LEAVE
      *
     C           P@BAN1    IFNE *BLANK
     C           P@BAN1    IFNE I2LOC1
     C           P@BAN2    ORNE I2LOC2
     C           P@BAN3    ORNE I2LOC3
     C           P@BAN4    ORNE I2LOC4
     C                     ITER
     C                     END
     C                     END
      * PRE LOAD
     C           P#QTY     DIV  P@SSYS    O@BOX1  51
      * RUNNING
     C           P#QTY2    DIV  P@SSYS    O@BOX2  51
      * QD
     C           P#QTY3    DIV  P@SSYS    O@BOX3  51
      *
     C                     ADD  1         RRN
     C                     WRITESFREC1
      *
E1   C                     ENDDO
     C*-------------------------
     C*
     C           @END      TAG
     C*
     C           RRN       IFEQ 0
     C                     MOVE '#END    '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     Z-ADD1         DSPRRN
     C                     ENDIF
     C                     ENDSR
     C*===============================================================
      *画面１*
     C*===============================================================
     C           #DSP1     BEGSR
      *
     C           @DSP01    TAG
      *
     C                     SETON                     71
     C                     WRITEDSP01
     C                     EXFMTSFCTL1
     C                     SETOF                     71
     C                     MOVEA'0'       *IN,99
     C                     Z-ADD$$RRN     DSPRRN
      *----*
      * F3 *
      *----*
     C   KC                MOVE '#END    '@STEP
      *
     C                     ENDSR
