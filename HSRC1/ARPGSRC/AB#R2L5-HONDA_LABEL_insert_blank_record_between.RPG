     H            Y.
      ** AB#R2L5 ************************************************************
      *  ..HONDA LABEL ---- INSERT BLANK RECORD BETWEEN LOCATIONS..         *
      *  LEC  10/23/19                                                      *
      *---------------------------------------------------------            *
      *  JW1      2023.07.25 ADD AB#XP01A (LOG)                             *
      ***********************************************************************
      *
     FAB#WPUF IF  E           K        DISK
     FAB#WP2U O   E                    DISK                      A
JW1  FAB#XP01AO   E                    DISK
     IINPDS     E DSAB#WPUF
     I                                        1 256 INRC1
     I                                      257 338 INRC2
     ISAVDS       DS
     I                                        1 256 SAVRC1
     I                                      257 338 SAVRC2
JW1  I            DS
.    I                                        1  140SDATE
.    I                                        1   60NOW
.    I                                        7  140TODAY
.    I           SDS
.    I                                        1   8 #PGM
.    I                                      244 253 #WSID
JW1  I                                      254 263 #USER
      ***********************************************************
      *
      *  read from input and write to output and when location changes,
      *      insert blank record...
      *
     C                     READ AB#WPUF                  52
      *
     C                     MOVELU2LOC2    SAVLC2  2
     C                     MOVELU2LOC3    SAVLC3  2
      *
     C           *IN52     DOWEQ*OFF
      *
     C           U2LOC2    IFNE SAVLC2
     C           U2LOC3    ORNE SAVLC3
     C                     MOVELINPDS     SAVDS
     C                     CLEARAB#WP2U1
     C                     MOVEL'BLANK'   U2MPNO
     C                     MOVEL'BLANK'   U2SPAR
     C                     WRITEAB#WP2U1
      *
JW1  C                     MOVEL'AB#WP2U 'IXWRKF    P
.    C                     EXSR #XP01
      *
     C                     MOVELSAVDS     INPDS
     C                     ENDIF
      *
     C                     WRITEAB#WP2U1
     C                     MOVELU2LOC2    SAVLC2
     C                     MOVELU2LOC3    SAVLC3
      *
     C                     READ AB#WPUF                  52
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *================================================================
      *  ..LABEL DATA ISSUE LOG
      *================================================================
JW1  C           #XP01     BEGSR
 V   C                     TIME           SDATE
 V   C                     Z-ADDTODAY     IXKOHZ           TODAY
     C                     Z-ADDNOW       IXKOTM           NOW
     C                     MOVEL#USER     IXKOUS
     C                     MOVEL#WSID     IXKOWS
     C                     MOVEL#PGM      IXKOPG
      *
     C                     MOVE *BLANK    IXTOKU           CUSTOMER
     C                     MOVELU2NONY    IXNONY           DELIVERY
     C                     MOVELU2NKOJ    IXNKOJ           FACTORY
     C                     MOVELU2NUKE    IXNUKE           DOCK
     C                     MOVE *BLANK    IXODRN           ORDER #
     C                     MOVELU2SERL    IXSERL           SERIAL NUMBER
     C                     MOVELU2SHDT    IXDEDT           INVOICE DATE
     C                     MOVELU2NOBN    IXNOBN           INVOICE BIN
     C                     MOVE *BLANK    IXPL#
      *
     C                     MOVELU2MPNO    IXMHIN
     C                     MOVELU2SPAR    IXSHIN
     C                     MOVELU2SHNO    IXINVN
     C                     MOVE *BLANK    IXHPOS
     C                     MOVE *BLANK    IXROUT
     C                     Z-ADD0         IXSRYO
     C                     Z-ADD0         IXSYOS
 .   C                     Z-ADD0         IXUSYS
 .   C                     WRITEAB#XP1A1
      *
JW5  C                     ENDSR
      ***********************************************************
