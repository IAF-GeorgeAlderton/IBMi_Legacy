     H            Y.
     F** ABMRFF *********************************************
     F*副資材　箱色データ
     F*   HOTTA.          2018.12.17                        *
     F*******************************************************
     FABMPPF0 IF  E           K        DISK
     FABMWPFE UF  E           K        DISK                      A
      *
     I            DS
     I                                        1   80W@DATE
     I                                        1   60W@DTYM
     I                                        1   40W@DTYY
     I                                        5   60W@DTMM
     I                                        7   80W@DTDD
      *
     I            DS
     I                                        1   80F2CRDT
     I                                        1   60F2CRYM
      *
     I            DS
     I                                        1  140WTIME
     I                                        7  14 SDATE
     I                                        1   6 STIME
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
      *
     C                     MOVEL*DATE     C1YM    60
     C                     Z-ADD*DATE     W@DATE
      * N-1
     C           W@DTMM    IFEQ 1
     C                     SUB  1         W@DTYY
     C                     Z-ADD12        W@DTMM
     C                     ELSE
     C                     SUB  1         W@DTMM
     C                     ENDIF
     C                     Z-ADDW@DTYM    C1YM1   60
      * N-2
     C           W@DTMM    IFEQ 1
     C                     SUB  1         W@DTYY
     C                     Z-ADD12        W@DTMM
     C                     ELSE
     C                     SUB  1         W@DTMM
     C                     ENDIF
     C                     Z-ADDW@DTYM    C1YM2   60
      *
     C           *HIVAL    SETGTABMPPF01
     C                     READPABMPPF01                 80
     C           *IN80     DOWEQ'0'
     C           F2CRYM    ANDGEC1YM2
     C           F2SKJY    IFEQ 'D'
     C           F2SKHZ    ANDLE*DATE
     C                     ELSE
     C                     EXSR #SB200
     C                     ENDIF
     C                     READPABMPPF01                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           F2BCCD    CHAINABMWPFE1             37
     C           *IN37     IFEQ '0'
     C                     SELEC
     C           F2CRYM    WHEQ C1YM
     C                     ADD  F2KMAX    W2KMAX
     C           F2CRYM    WHEQ C1YM1
     C                     ADD  F2KMAX    W2KMA1
     C           F2CRYM    WHEQ C1YM2
     C                     ADD  F2KMAX    W2KMA2
     C                     ENDSL
      *
     C                     UPDATABMWPFE1
     C                     ELSE
     C                     CLEARABMWPFE1
     C                     MOVELF2BCCD    W2BCCD
     C                     MOVELF2BCNM    W2BCNM
     C                     SELEC
     C           F2CRYM    WHEQ C1YM
     C                     Z-ADDF2KMAX    W2KMAX
     C           F2CRYM    WHEQ C1YM1
     C                     Z-ADDF2KMAX    W2KMA1
     C           F2CRYM    WHEQ C1YM2
     C                     Z-ADDF2KMAX    W2KMA2
     C                     ENDSL
     C                     WRITEABMWPFE1
     C                     ENDIF
      *
     CSR         ESB200    ENDSR
