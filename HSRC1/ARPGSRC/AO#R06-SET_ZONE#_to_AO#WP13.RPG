     H            Y.
     F** AO#R06  *******************************************
     F*  AO#WP13にゾーン＃をセット               *
     F*     SAKAKI.       2020.02.03                       *
     F******************************************************
     FAO#WP13 UF  E           K        DISK
     FAO#WP12 IF  E           K        DISK
     FAL#PP00 IF  E           K        DISK
     E                    ZTB     1   4  4
     E                    ZN          4  1               ZONE#
     E                    ZB          4  5 0             ZONE#の箱数
     E                    ZP          4  5 0             ZONE#のパレット数
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      *ＭＡＸ
     C                     Z-ADD8         PLTMAX  30
      *ゾーン数
     C                     Z-ADD2         ZONNMB  30
     C                     MOVEL'ZONNMB'  KEY    10
     C           KEY       CHAINAL#PP001             20
     C           *IN20     IFEQ '0'
     C                     Z-ADDC0VALU    ZONNMB
     C                     ENDIF
      *
     C                     CLEARZN
     C                     Z-ADDZONNMB    A       30
     C           A         IFLE 8
     C                     MOVEAZTB,A     ZN
     C                     ELSE
     C                     MOVEAZTB,2     ZN
     C                     ENDIF
      *
     C                     READ AO#WP131                 81
     C           *IN81     DOWEQ'0'
     C                     CLEARZB
     C                     CLEARZP
     C                     MOVELZN,1      W@ZONE  1
     C                     Z-ADD0         W@BOX   50
     C                     Z-ADD0         W@PLTS  50
     C                     MOVELX3TRKB    SVTRKB  2
     C                     MOVELX3SURT    SVSURT  9
     C                     MOVELX3IAFB    SVIAFB  3
     C                     MOVELX3PPU2    SVPPU2  1
     C                     EXSR #SB001
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------*
      * ZONE#
      *----------------------------------------*
     CSR         #SB001    BEGSR
      *
     C           KEYW12    KLIST
     C                     KFLD           X3TRKB
     C                     KFLD           X3SURT
     C                     KFLD           X3PPUL
     C                     KFLD           X3NONY
     C                     KFLD           X3IAFB
      *ゾーンごとの最大パレット数
     C                     Z-ADD0         ZONMAX  30
     C           KEYW12    CHAINAO#WP12              71
     C           *IN71     IFEQ '0'
     C           W2KPLT    DIV  ZONNMB    ZONMAX
     C                     ENDIF
     C           ZONMAX    IFEQ 0
     C                     Z-ADD4         ZONMAX
     C                     ENDIF
      *
     C           *IN81     DOWEQ'0'
     C           X3TRKB    ANDEQSVTRKB
     C           X3SURT    ANDEQSVSURT
     C           X3IAFB    ANDEQSVIAFB
     C           X3PPU2    ANDEQSVPPU2
     C                     MOVELW@ZONE    X3ZONE
     C                     UPDATAO#WP131
     C                     EXSR #SB100
     C                     EXSR #SB150
     C                     READ AO#WP131                 81
     C                     ENDDO
      *
     CSR         ESB001    ENDSR
      *----------------------------------------*
      * ZONE#
      *----------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     Z-ADD1         A
     C           W@ZONE    LOKUPZN,A                     29
     C           *IN29     IFEQ '1'
     C                     ADD  X3BOX     ZB,A
     C                     ADD  1         ZP,A
     C                     ENDIF
      *
     CSR         ESB100    ENDSR
      *----------------------------------------*
      * ZONE#
      *----------------------------------------*
     CSR         #SB150    BEGSR
      *
     C                     MOVELZN,1      W@ZONE  1
     C                     Z-ADD99999     W@BOX   50
     C                     Z-ADD0         W@PLTS  50
      *
     C                     Z-ADD1         A
     C           A         DOWLEZONNMB
     C           ZN,A      IFNE *BLANK
     C           ZB,A      ANDLTW@BOX
     C           ZP,A      ANDLTZONMAX
     C                     MOVELZN,A      W@ZONE  1
     C                     Z-ADDZB,A      W@BOX   50
     C                     ENDIF
     C                     ADD  1         A
     C                     ENDDO
      *
     CSR         ESB150    ENDSR
**
A
AB
ABC
ABCD
