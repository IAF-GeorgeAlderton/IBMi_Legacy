     H            Y.
     F**AKAR2A1 **************************************************
     F* MANUFACTURING PROCESS INFORMATION INQUIRY                *
     F* JW      2022.9.30                                        *
     F* (RECREATED FROM AKAR2A)                                  *
     F************************************************************
     FAKAPW2A1CF  E                    WORKSTN
     E                    ER      1   4 60
     I            DS
     I                                        1  12 CKHIN
     I                                        1   5 CKHIN1
     I                                        6  10 CKHIN2
     I                                       11  12 CKHIN3
      ****************************************************
      * MAIN
      ****************************************************
     C                     EXSR #INIT
      * DISPLAY 1ST SCREEN
     C                     DO   *HIVAL
     C                     EXFMTDSP01
     C                     SETOF                     4199
     C                     MOVE *BLANK    CKHIN
      * F1: END
     C           *INKA     IFEQ '1'
     C                     LEAVE
     C                     ENDIF
      *
     C                     EXSR #CHK1
     C           *IN99     IFEQ *ON
     C                     ITER
     C                     ENDIF
      * IF NO ERROR...
     C           SNNO      IFEQ '3'
     C                     EXSR #AKH
     C           @CMD3     IFEQ *ON
     C                     MOVE ' '       SNNO
     C                     ITER
     C                     ENDIF
     C                     LEAVE
     C                     ENDIF
      *
     C                     EXSR #DSP2
     C           F1FLG2    IFEQ *ON
     C                     LEAVE
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      ****************************************************
      * AKHCA1: COMPONENTS KANBAN INQ
      ****************************************************
     C           #AKH      BEGSR
      *
     C                     MOVE *BLANK    @CMD3
     C                     CALL 'AKHCA1'  ACALL3
      *
     C                     ENDSR
      ****************************************************
      * DISPLAY 2ND SCREEN
      ****************************************************
     C           #DSP2     BEGSR
      *
     C                     DO   *HIVAL
     C                     EXFMTDSP02
     C                     SETOF                     4299
     C                     MOVE *BLANK    PER
     C                     MOVE *OFF      F1FLG2  1
     C                     MOVE *OFF      F3FLG2  1
      * F1: END
     C           *INKA     IFEQ *ON
     C                     MOVE *ON       F1FLG2
     C                     MOVE ' '       SNNO
     C                     LEAVE
     C                     ENDIF
      * F3: BACK
     C           *INKC     IFEQ *ON
     C                     MOVE *ON       F3FLG2
     C                     MOVE ' '       SNNO
     C                     LEAVE
     C                     ENDIF
      *
     C           CKHIN     IFEQ *BLANK
     C                     SETON                     4299
     C                     MOVE ER,2      MSG
     C                     ITER
     C                     ENDIF
      * IF NO ERROR...
     C                     MOVE *BLANK    PCMD3
     C           SNNO      IFEQ 'Y'
     C                     MOVE SNNO      PSNO
     C                     CALL 'AKAR27'  ACALL4
     C           PCMD3     IFEQ *ON
     C                     MOVE *ON       F3FLG2
     C                     MOVE ' '       SNNO
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C           SNNO      IFEQ 'X'
     C           STP3      TAG
     C                     MOVE SNNO      PSNO
     C                     CALL 'AKAR27'  ACALL4
     C           PCMD3     IFEQ *ON
     C                     MOVE *ON       F3FLG2
     C                     MOVE ' '       SNNO
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C**         PER       IFNE *BLANK
     C**                   GOTO STPER
     C**                   END
     C**                   END
      *
     C                     CALL 'AKAR28'  ACALL2
     C           PCMD3     IFEQ *ON
     C                     MOVE *ON       F3FLG2
     C                     MOVE ' '       SNNO
     C                     LEAVE
     C                     ENDIF
      *
     C           PER       IFEQ 'E'
     C                     SETON                     4299
     C                     MOVE ER,3      MSG
     C                     ITER
     C                     ENDIF
      *
     C           PER       IFEQ '9'
     C                     SETON                     4299
     C                     MOVE ER,4      MSG
     C                     ITER
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      ****************************************************
      * CHECK ENTERY
      ****************************************************
     C           #CHK1     BEGSR
      *
     C           SNNO      IFNE 'X'
     C           SNNO      ANDNE'Y'
     C           SNNO      ANDNE'0'
     C           SNNO      ANDNE'1'
     C           SNNO      ANDNE'2'
     C           SNNO      ANDNE'3'
     C           SNNO      ANDNE'4'
     C           SNNO      ANDNE'6'
     C           SNNO      ANDNE'7'
     C           SNNO      ANDNE'A'
     C           SNNO      ANDNE'B'
     C           SNNO      ANDNE'C'
     C           SNNO      ANDNE'D'
     C           SNNO      ANDNE'E'
     C           SNNO      ANDNE'F'
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     ENDIF
      *
     C                     ENDSR
      ****************************************************
      * INITIAL SETTING
      ****************************************************
     C           #INIT     BEGSR
      *
     C           ACALL1    PLIST
     C                     PARM           PCMD3   1
     C                     PARM           PER     1
     C                     PARM           CKHIN
      *
     C           ACALL2    PLIST
     C                     PARM           PCMD3
     C                     PARM           SNNO
     C                     PARM           PER
     C                     PARM           CKHIN1
     C                     PARM           CKHIN2
     C                     PARM           CKHIN3
      *
     C           ACALL3    PLIST
     C                     PARM           @CMD3   1
      *
     C           ACALL4    PLIST
     C                     PARM           PCMD3   1
     C                     PARM           PER     1
     C                     PARM           CKHIN
     C                     PARM           PSNO    1
     C                     ENDSR
**  ER (ERROR-MESSAGE)
E-01 SELECT OPTION: A,B,C,D,E,F,X,Y,0,1,2,3,4,6 OR 7.
E-02 ENTER IAF PART NO.
E-03 IAF PART# NOT FOUND IN COMPONENT KANBAN MASTER
E-04 NO DATA FOR IAF PART NO.
