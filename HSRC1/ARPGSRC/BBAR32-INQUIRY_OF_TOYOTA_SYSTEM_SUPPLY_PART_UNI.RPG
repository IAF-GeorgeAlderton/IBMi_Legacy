      *
     C           HINU3     IFNE *BLANK
     C                     MOVEL'-'       HINUB
     C                     END
      *
     C                     MOVEA'00000'   *IN,20
     C           GNKYX     IFNE *BLANK
     C                     MOVEA'10000'   *IN,20
