     C   21      KEY4      READEBBBPL071                 40
     C   22      KEY3      READEBBBPL071                 40
     C   23      KEY2      READEBBBPL071                 40
     C   24      KEY1      READEBBBPL071                 40
      *
     C           *IN,40    IFEQ '1'
