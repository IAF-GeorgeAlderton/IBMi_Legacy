     H            Y.
     F** ABFR08 ********************************************
     F*  FORD ROUTE MASTER INQ BY DELIVERY CODE            *
     F*  JW         2022.12.14                             *
     F******************************************************
     FABFPW08 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN   KSFILE SFL01
     FABFDL01 IF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
      *
     IINFDS       DS
     I                                    B 378 3790$$RRN
     I****************************
     I            DS
     I                                        1   80QASKHZ
     I                                        1   40QASKYY
     I                                        5   60QASKMM
     I                                        7   80QASKDD
     I            DS
     I                                        1  10 QAEFHZ
     I                                        1   40QAEFYY
     I                                        5   5 WKDT
     I                                        6   70QAEFMM
     I                                        8   8 WKDT2
     I                                        9  100QAEFDD
     I            DS
     I                                        1  10 QAKOHZ
     I                                        1   40QAKOYY
     I                                        5   5 WKDT3
     I                                        6   70QAKOMM
     I                                        8   8 WKDT4
     I                                        9  100QAKODD
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
      ****************************************************************
      *  MAIN ROUTINE
      ****************************************************************
     C                     EXSR #INIT
      *
     C           @STEP     DOUEQ'#END'
      *
     C                     SETON                     71
     C                     WRITEDSP01
     C                     EXFMTCTL01
     C                     SETOF                     71
     C                     MOVEA'0'       *IN,99
     C                     Z-ADD$$RRN     DSPRRN
      *----*
     C                     SELEC
      * F1: END
     C           *INKA     WHEQ *ON
     C                     MOVEL'#END'    @STEP
      * F3: END
     C           *INKC     WHEQ *ON
     C                     MOVEL'#END'    @STEP
      * F12:END
     C           *INKL     WHEQ *ON
     C                     MOVEL'#END'    @STEP
      *
     C                     OTHER
      *
     C           *IN73     IFEQ *OFF
     C                     MOVELXNONY     @NONY
     C                     EXSR #SET1
     C                     ENDIF
      *
     C                     ENDSL
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
      * SET DATA IN SFL01
     C*===============================================================
     C           #SET1     BEGSR
     C*  SFLCLR
     C                     MOVEA*ALL'0'   *IN
     C                     SETON                     72
     C                     WRITECTL01
     C                     SETOF                     72
     C                     MOVE *BLANK    @@UMU   1
      *
     C           @NONY     SETLLABFDL01
S1   C                     DO   *HIVAL
     C                     READ ABFDL01                  90
     C   90                LEAVE
      *
 S2  C           QASKJY    IFEQ 'D'
     C                     ITER
 E2  C                     ENDIF
      * BREAK
     C           RRN       IFNE 0
     C           QANONY    IFNE SVNONY
     C           QADOCK    ORNE SVDOCK
     C                     ADD  1         RRN
     C                     CLEARSFL01
     C                     WRITESFL01
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADDQANONY    SVNONY
     C                     MOVELQADOCK    SVDOCK
      *
     C                     CLEARSFL01
     C                     MOVELQAPLAN    SBPLAN
     C                     MOVELQADOCK    SBDOCK
     C                     MOVELQADOCK    SBDOCX
     C                     MOVELQAICCD    SBICCD
     C                     MOVELQAROUT    SBROUT
     C                     MOVELQAMODE    SBMODE
     C                     MOVELQANONY    SBNONY
      * GET BIN#
     C                     MOVELQANONY    $NONY
     C                     MOVELQADOCK    $DOCK
     C                     CALL 'UTLR34G'
     C                     PARM           $NONY   4
     C                     PARM           $DOCK   4
     C                     PARM           $BIN#   2
JW   C                     PARM           $ROUT   4
     C                     MOVEL$BIN#     SBBIN
      *
     C           QANONY    CHAINFGBPL01              55
     C  N55                MOVELB2SMEI    SBSMEI
      *
      *
     C                     MOVEL'/'       WKDT
     C                     MOVEL'/'       WKDT2
     C                     MOVELQAEFHZ    SBEFHZ
      *
     C                     MOVEL'/'       WKDT3
     C                     MOVEL'/'       WKDT4
     C                     MOVELQAKOHZ    SBKOHZ
     C                     MOVELQAKOME    SBKOUS
      *
     C                     ADD  1         RRN
     C                     WRITESFL01
E1   C                     ENDDO
     C*-------------------------
     C           RRN       IFEQ 0
     C                     CLEARSFL01
     C                     MOVE 'NO DATA 'SBSMEI
     C                     ADD  1         RRN
     C                     WRITESFL01
     C                     ENDIF
      *
     C                     Z-ADD1         DSPRRN
     C                     Z-ADDRRN       ENDRRN  40
      *
     C                     ENDSR
     C*===============================================================
     C* INITIAL SET
     C*===============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4
      *
     C           $NONY     IFEQ *BLANK
     C                     Z-ADD0         @NONY   40
     C                     ELSE
     C                     MOVEL$NONY     @NONY
     C                     ENDIF
      *
     C                     MOVEL@NONY     XNONY
     C                     EXSR #SET1
      *
     C                     MOVE *BLANK    @STEP   4
     C                     Z-ADDQANONY    SVNONY  40
     C                     MOVELQADOCK    SVDOCK  4
     C                     Z-ADD0         RRN     40
      *
     C                     ENDSR
