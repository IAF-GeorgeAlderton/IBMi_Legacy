     H            Y.
     F** UTLR52 ****************************************************
     F*  UTILITY - RETRIEVE PACKING LIST PARAMETERS                *
     F*  WRITTEN: JW (SRA)                                         *
     F*           03/23/2017                                       *
     F*  FUNCTION: RETRIEVE PAKING LIST COPY# ETC...               *
     F*------------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR52'
     F*                    PARM           $NONY   4
     F*                    PARM           $PTYP   2
     F*                    PARM           $PCPY   2
     F*                    PARM           $CTYP   2
     F*                    PARM           $CCPY   2
     F*                    PARM           $CNAM  10
     F*                    PARM           $LTYP   1
     F*                    PARM           $LCPY   2
     F*                    PARM           $MCPY   2
     F*                    PARM           $SUPP  10
     F*                    PARM           $BMAX   3
     F*                    PARM           $TRAN  30
     F*                    PARM           $RTN    1
     F*   IN  $NONY   4  DELIVERY
     F*   OUT $PTYP   2  PACKING LIST TYPE
     F*       $PCPY   2  # OF PACKING LIST
     F*       $CTYP   2  CUSTOM SHEET TYPE
     F*       $CCPY   2  # OF CUSTOM SHEET
     F*       $CNAM  10  CUSTOM COUNTRY
     F*       $LTYP   1  LABEL TYPE
     F*       $LCPY   2  # OF LABEL
     F*       $MCPY   2  # OF MIX PALLET LIST
     F*       $SUPP  10  SUPPLIER
     F*       $BMAX   3  MAX BOX
     F*       $TRAN  30  TRANSPORTER
     F*       $RTN    1  RETURN
     F******************************************************
     FAB#PL90 IF  E           K        DISK
      *--------------------------------------------------------
     E                    DAT        10  1
      *--------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
     C                     EXSR #INZ
      *
     C           $NONY     CHAINAB#PL90              91
     C           *IN91     IFEQ *ON
     C                     MOVE '*'       $RTN
     C                     GOTO ENDP
     C                     ENDIF
      *
     C                     MOVELYATYPE    $PTYP
     C                     MOVELYAPICK    $PCPY
     C                     MOVELYACTYP    $CTYP
     C                     MOVELYACUST    $CCPY
     C                     MOVELYACNAM    $CNAM
     C                     MOVELYALABE    $LTYP
     C                     MOVELYA#LAB    $LCPY
     C                     MOVELYA#MIX    $MCPY
     C                     MOVELYASUPP    $SUPP
     C                     MOVELYAMXPL    $BMAX
     C                     MOVELYATRAN    $TRAN
      *
     C           ENDP      TAG
     C                     SETON                     LR
     C                     RETRN
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
     C           #INZ      BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4
     C                     PARM           $PTYP   2
     C                     PARM           $PCPY   2
     C                     PARM           $CTYP   2
     C                     PARM           $CCPY   2
     C                     PARM           $CNAM  10
     C                     PARM           $LTYP   1
     C                     PARM           $LCPY   2
     C                     PARM           $MCPY   2
     C                     PARM           $SUPP  10
     C                     PARM           $BMAX   3
     C                     PARM           $TRAN  30
     C                     PARM           $RTN    1
      *
     C                     MOVE *BLANK    $PTYP
     C                     MOVE *BLANK    $PCPY
     C                     MOVE *BLANK    $CTYP
     C                     MOVE *BLANK    $CCPY
     C                     MOVE *BLANK    $CNAM
     C                     MOVE *BLANK    $LTYP
     C                     MOVE *BLANK    $LCPY
     C                     MOVE *BLANK    $MCPY
     C                     MOVE *BLANK    $SUPP
     C                     MOVE *BLANK    $BMAX
     C                     MOVE *BLANK    $TRAN
     C                     MOVE *BLANK    $RTN
      *
     C                     ENDSR
