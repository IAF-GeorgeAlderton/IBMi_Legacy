     H            Y.
     F** AB#R2C3 ************************************************************
     F*  PALLET# ADD TO LABEL DATA FOR TAKATA(2D)                           *
     F*                                                                     *
     F* TCHK1 01/02/07 CREATE                                               *
     F****************************************** AB#R2C *********************
     FAB#WP2F IF  E                    DISK
     FAB#PL90 IF  E           K        DISK
     FAB#WP2FAO   E                    DISK
     E*****************************************************************
     I            DS
     I                                        1   5 W@PLNX
     I                                        1   1 W@PLN1
     I                                        2   2 W@PLN2
     I                                        3   3 W@PLN3
     I                                        4   4 W@PLN4
     I                                        5   5 W@PLN5
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     C***********************************************************************
     C                     EXSR @INZ
     C                     EXSR @MAIN
     C*
     C                     MOVEL*ON       *INLR
     C                     RETRN
     C***********************************************************
     C* @INZ:INITIALIZE WORK AREA
     C***********************************************************
     C           @INZ      BEGSR
     C*
     C                     Z-ADD*ZERO     W@MXPL  50
     C                     Z-ADD*ZERO     W@CCNT  50
     C                     Z-ADD1         W@PLNO  50
     C*
     C                     MOVEL*OFF      W@1ST   1
     C*
     C                     ENDSR
     C***********************************************************
     C* @MAIN
     C***********************************************************
     C           @MAIN     BEGSR
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AB#WP2F                  99
     C   99                LEAVE
     C*
     C* GET THE NUMBER OF LABEL
     C           W@1ST     IFEQ *OFF
     C           F2NONY    CHAINAB#PL90              98
     C           *IN98     IFEQ '0'
     C                     Z-ADDYAMXPL    W@MXPL
     C                     Z-ADDYA#LAB    W#LAB   50
     C           W#LAB     IFNE *ZERO
     C           W#LAB     MULT W@MXPL    W@MXPL
     C                     END
     C                     END
     C                     MOVEL*ON       W@1ST
     C                     END
     C*
     C                     ADD  1         W@CCNT
     C           W@CCNT    IFGT W@MXPL
     C                     Z-ADD1         W@CCNT
     C                     ADD  1         W@PLNO
     C                     END
     C                     MOVELW@PLNO    W@PLNX
     C                     DO
     C           W@PLN1    IFEQ *ZERO
     C                     MOVEL*BLANK    W@PLN1
     C                     ELSE
     C                     LEAVE
     C                     END
     C           W@PLN2    IFEQ *ZERO
     C                     MOVEL*BLANK    W@PLN2
     C                     ELSE
     C                     LEAVE
     C                     END
     C           W@PLN3    IFEQ *ZERO
     C                     MOVEL*BLANK    W@PLN3
     C                     ELSE
     C                     LEAVE
     C                     END
     C           W@PLN4    IFEQ *ZERO
     C                     MOVEL*BLANK    W@PLN4
     C                     ELSE
     C                     LEAVE
     C                     END
     C                     ENDDO
     C*
     C                     CLEARAB#WP2AR
     C*
     C                     MOVELF2FAD1    FAFAD1
     C                     MOVELF2FAD2    FAFAD2
     C                     MOVELF2FAD3    FAFAD3
     C                     MOVELF2FAD4    FAFAD4
     C                     MOVELF2FAD5    FAFAD5
     C                     MOVELF2TAD1    FATAD1
     C                     MOVELF2TAD2    FATAD2
     C                     MOVELF2TAD3    FATAD3
     C                     MOVELF2TAD4    FATAD4
     C                     MOVELF2PLNT    FAPLNT
     C                     MOVELF22DBR    FA2DBR
     C                     MOVELF2SYOS    FASYOS
     C                     MOVELF2MHND    FAMHND
     C                     MOVELF2REFR    FAREFR
     C                     MOVELF2MHIN    FAMHIN
     C                     MOVELF2LCPL    FALCPL
     C                     MOVELF2SHDT    FASHDT
     C                     MOVELF2CNTY    FACNTY
     C                     MOVELF2WEIG    FAWEIG
     C                     MOVELF2REF1    FAREF1
     C                     MOVELF2REF2    FAREF2
     C                     MOVELF2REF3    FAREF3
     C                     MOVELF2REF4    FAREF4
     C                     MOVELF2ZETI    FAZETI
     C                     MOVELF2SBAN    FASBAN
     C                     MOVELF2LOC1    FALOC1
     C                     MOVELF2LOC2    FALOC2
     C                     MOVELF2LOC3    FALOC3
     C                     MOVELF2LOC4    FALOC4
     C                     MOVELF2CNAM    FACNAM
     C                     MOVELF2SERL    FASERL
     C                     MOVELF2NONY    FANONY
     C                     MOVELF2NKOJ    FANKOJ
     C                     MOVELF2NUKE    FANUKE
     C*
     C                     MOVE W@PLNX    FAREF5
     C*
     C                     WRITEAB#WP2AR
     C*
     C                     ENDDO
     C*
     C                     ENDSR
