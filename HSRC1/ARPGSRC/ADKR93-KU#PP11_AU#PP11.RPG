     C           *ENTRY    PLIST
     C                     PARM           PHM     4
      *
     C                     CALL 'ADKR90'
     C                     PARM           PHM     4
     C                     PARM           P1APHZ  80
     C                     PARM           P1APBN  20
     C                     TIME           WDATE
     C           KEYKQ     KLIST
     C                     KFLD           K#NKHZ  80
     C                     KFLD           K#NKTI  60
     C                     Z-ADD0         K#NKHZ
     C                     Z-ADD0         K#NKTI
      *
     C                     Z-ADD0         @@SS
     C                     Z-ADD20160307  @@SSHZ
     C                     Z-ADD040000    @@SSTI
      *
     C           KEYKQ     SETLLKU#PL111
     C           KEYKQ     READEKU#PL111                 80
     C           *IN80     DOWEQ'0'
     C           KQSKJY    IFEQ 'D'
     C           KQSKHZ    ANDLE*DATE
     C                     ELSE
     C           KQSS      IFLT @@SS
     C                     Z-ADDSDATE     KQNKHZ
     C                     Z-ADDSTIME     KQNKTI
     C                     Z-ADD99999999  KQAPHZ
     C                     Z-ADD99        KQAPBN
     C                     UPDATKU#PL111
     C                     ELSE
     C                     EXSR #SB100
     C                     ENDIF
     C                     ENDIF
     C           KEYKQ     READEKU#PL111                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------*
      *                                   *
      *-----------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVEL'0'       ###GET  1
     C                     EXSR #SB110
     C                     EXSR #SB120
     C                     EXSR #SB130
     C           ###GET    IFEQ '1'
     C                     EXSR #SB500
     C                     Z-ADDSDATE     KQNKHZ
     C                     Z-ADDSTIME     KQNKTI
     C                     Z-ADDP1APHZ    KQAPHZ
     C                     Z-ADDP1APBN    KQAPBN
     C                     UPDATKU#PL111
     C                     ENDIF
      *
     CSR         ESB100    ENDSR
      *-----------------------------------*
      * ACAPL11                           *
      *-----------------------------------*
     CSR         #SB110    BEGSR
      *
     C           KEYAGA    KLIST
     C                     KFLD           KQSHN1
     C                     KFLD           KQSHN2
     C                     KFLD           KQSHN3
     C           KEYAGA    CHAINAGAPL311             22
     C           *IN22     IFEQ '0'
     C           CBSKJY    ANDEQ'D'
     C           CBSKHZ    ANDLE*DATE
     C                     SETON                     22
     C                     ENDIF
     C           *IN22     IFEQ '1'
     C                     GOTO ESB110
     C                     ENDIF
      *
     C           #KEY2     KLIST
     C                     KFLD           CBMBMN
     C                     KFLD           CBKDAI
      *
     C           #KEY3     KLIST
     C                     KFLD           CBMBMN
     C                     KFLD           CBKDAI
     C                     KFLD           CBSHN1
     C                     KFLD           CBSHN2
     C                     KFLD           CBSHN3
      *
     C                     Z-ADD0         XXBMON  40
     C                     MOVE *BLANK    XXKCD1  1
     C                     MOVE *BLANK    XXSW1   1
     C           CBKDAI    IFEQ '0'
     C****       CBMBMN    OREQ 8907
     C                     Z-ADD0111      XXBMON
     C                     ELSE
     C           #KEY2     SETLLACAPL111
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           #KEY2     READEACAPL111                 10
     C           *IN10     IFEQ '0'
     C           I1SKJY    IFEQ 'D'
     C           I1SKHZ    ANDLE*DATE
     C                     ELSE
     C                     SETON                     10
     C                     MOVE '*'       XXSW1
     C                     Z-ADDI1BMON    XXBMON
     C                     MOVE I1KCD1    XXKCD1
     C                     ENDIF
     C                     ENDIF
     C  N10                ENDDO
      *
     C           XXSW1     IFEQ *BLANK
     C                     Z-ADD0111      XXBMON
     C                     ELSE
     C                     SETOF                     11
     C           #KEY3     CHAINACAPL111             11
     C           *IN11     IFEQ '0'
     C           I1SKJY    ANDEQ'D'
     C           I1SKHZ    ANDLE*DATE
     C                     SETON                     11
     C                     ENDIF
     C           *IN11     IFEQ '0'
     C                     Z-ADDI1BMON    XXBMON
     C                     ELSE
     C           XXBMON    IFEQ 8907
     C           XXKCD1    IFNE '0'
     C                     Z-ADD8990      XXBMON
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB110    ENDSR
      *-----------------------------------*
      * AAIPL11,AAIPL31                   *
      *-----------------------------------*
     CSR         #SB120    BEGSR
      * GET A-PICS ORDER NO.(BIN)
     C                     Z-ADD0         WKDATI 120
     C                     Z-ADD0         WKBIN   20
     C                     Z-ADD0         WKTOHZ  80
     C                     Z-ADD0         WKYOHZ  80
     C                     Z-ADD0         WKZNHZ  80
     C                     MOVELPHM       HHMM1
     C           XXBMON    CHAINAAIPL111             49
     C           *IN49     IFEQ '0'
     C                     MOVE CDBI,HH1  WKBIN
     C                     Z-ADDCDTOHZ    WKTOHZ
     C                     Z-ADDCDYOHZ    WKYOHZ
     C                     Z-ADDCDZNHZ    WKZNHZ
     C                     ENDIF
      * GET PICKUP TIME
     C           KEYG21    KLIST
     C                     KFLD           #KBMON  40
     C                     KFLD           #KBIN   20
     C                     MOVELXXBMON    #KBMON
     C                     Z-ADDWKBIN     #KBIN
     C                     MOVEL'0'       GET     1
     C                     Z-ADD0         W2TIME  40
     C                     Z-ADD0         W2ADJS  10
     C           KEYG21    SETLLAAIPL311
     C           KEYG21    READEAAIPL311                 49
     C           *IN49     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           G2SKJY    IFEQ 'D'
     C           G2SKHZ    ANDLE*DATE
     C                     ELSE
     C                     MOVEL'1'       GET
     C                     Z-ADDG2TIME    W2TIME  40
     C                     Z-ADDG2ADJS    W2ADJS
     C                     ENDIF
     C           KEYG21    READEAAIPL311                 49
     C                     ENDDO
      *前日はカレンダーから
     C                     EXSR #SB140
      *
     C                     Z-ADD0         WKDATI
     C                     Z-ADD00000000  WKDATE
     C                     Z-ADD0000      WKTIME
     C           GET       IFEQ '1'
     C***        W2TIME    IFGE 0000
     C***        W2TIME    ANDLE0759
     C           W2ADJS    IFEQ 1
     C                     Z-ADDWKZNHZ    WKDATE
     C                     Z-ADDW2TIME    WKTIME
     C                     ELSE
     C                     Z-ADDWKTOHZ    WKDATE
     C                     Z-ADDW2TIME    WKTIME
     C                     ENDIF
     C                     ENDIF
      *
     CSR         ESB120    ENDSR
      *-----------------------------------*
      * PICKUP                            *
      *-----------------------------------*
     CSR         #SB130    BEGSR
      *
     C                     Z-ADD0         KQDATI
     C                     Z-ADDKQTHHZ    KQDATE
     C                     Z-ADDKQTHTI    KQTIME
     C                     MOVEL'0'       ###GET  1
     C*****      KQDATI    IFLE WKDATI
     C           KQSS      IFLE WKDATI
     C                     MOVEL'1'       ###GET  1
     C                     ENDIF
      *
     CSR         ESB130    ENDSR
      *-----------------------------------------*
      *前日                                   *
      *-----------------------------------------*
     CSR         #SB140    BEGSR
      *
     C           KEYF88    KLIST
