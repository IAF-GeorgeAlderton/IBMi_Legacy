TCH60F* TCH  ADDED PARINT OPT.                   *
TCHK1F* TCHK1 03/20/06 BUG FIX                   *
TCHK2F* TCHK2 02/09/09 ADD PRINTER               *
%0001F* T.SAKAKI 08/02/16 ADD LOGIC FOR J LOCAION *
JW1  F* JW       09/01/20 ADD PRINTER (G/L ROOM) *
     F********************************************
     FAH#PW3L CF  E                    WORKSTN
     FAAPTL01 IF  E           K        DISK
%0001FAAPPL03 IF  E           K        DISK
     FAANPL06 IF  E           K        DISK
     FFCEPL03 IF  E           K        DISK
     FAH#WP30 IF  E           K        DISK                      A
     E                    ER      1  10 60               ERROR MSG
     I            DS
     I                                        1   80YMD
     I                                        1   40YY
     I                                        5   60MM
     I                                        7   80DD
     I            DS
     I                                        1   80AHSKHZ
     I                                        1   40AHSKYY
     I                                        5   60AHSKMM
     I                                        7   80AHSKDD
     I            DS
     I                                        1   80AHKOHZ
     I                                        1   40AHKOYY
     I                                        5   60AHKOMM
     I                                        7   80AHKODD
     I            DS
     I                                        1   60WTIME
     I                                        1   20AHKOHH
     I                                        3   40AHKOSS
     I            DS
     I                                        1   6 LOC1
     I                                        1   1 LOC11
     I                                        2   2 LOC1A
     I                                        2   3 LOC12
     I                                        4   5 LOC13
     I                                        6   6 LOC14
     I            DS
     I                                        1   6 LOC2
     I                                        1   1 LOC21
     I                                        2   3 LOC22
     I                                        4   5 LOC23
     I                                        6   6 LOC24
     I            DS
     I                                        1   6 A2LOC
     I                                        1   1 A2STRK
     I                                        2   3 A2STRT
     I                                        4   5 A2STRR
     I                                        6   6 A2STRD
%0001I            DS
     I                                        1   6 L5LOC
     I                                        1   1 L5TKR1
     I                                        2   3 L5TKR2
     I                                        4   5 L5TKR3
     I                                        6   6 L5TKR4
     C           KEY       KLIST
     C                     KFLD           HIN1
     C                     KFLD           HIN2
     C                     KFLD           HIN3
      *
     C           KEYL      KLIST
     C                     KFLD           LOC11
     C                     KFLD           LOC12
     C                     KFLD           LOC13
     C                     KFLD           LOC14
      *
     C           KEYA      KLIST
     C                     KFLD           HIN1
     C                     KFLD           HIN2
     C                     KFLD           HIN3
     C                     KFLD           YMD
     C                     KFLD           BIN
     C           KEYB      KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
     C                     KFLD           YMD
     C                     KFLD           BIN
%0001C           KEYC      KLIST
     C                     KFLD           L5SHN1
     C                     KFLD           L5SHN2
     C                     KFLD           L5SHN3
     C                     KFLD           YMD
     C                     KFLD           BIN
     C           KEYF      KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
      *
     C           *ENTRY    PLIST
     C                     PARM           US     10        USER NAME
     C                     PARM           P1SFLG  1
     C                     PARM           P1RFLG  1
TCH60C                     PARM           OUTQ    8
      *
TCH60C                     MOVE '3'       WPRT    1
      *
     C                     Z-ADD*DATE     AHSKHZ
      *
     C                     Z-ADD*DATE     YMD
     C                     Z-ADD1         BIN
     C                     Z-ADD0         COUNT   30
      *
      *
     C           STP1      TAG
     C                     MOVE *BLANK    HIN1
     C                     MOVE *BLANK    HIN2
     C                     MOVE *BLANK    HIN3
     C                     MOVE *BLANK    LOC1
     C                     MOVE *BLANK    LOC2
      *
     C                     MOVE 'N'       @SFLG
     C                     MOVE 'N'       @RFLG
     C           STP2      TAG
     C                     EXFMTAH#PW3A1
     C                     SETOF                     010203
     C                     SETOF                     060708
     C                     SETOF                     99
      *
     C*  CMD-1
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
TCH60C           WPRT      IFNE '1'
     C           WPRT      ANDNE'2'
     C           WPRT      ANDNE'3'
TCHK2C           WPRT      ANDNE'4'
JW1  C           WPRT      ANDNE'5'
TCHK2C           WPRT      ANDNE'9'
     C                     SETON                     0899
     C                     MOVE ER,10     MSG
     C                     GOTO STP2
     C                     ENDIF
      *
     C           WPRT      IFEQ '1'
     C                     MOVEL'QPRINT  'OUTQ
     C                     ENDIF
     C           WPRT      IFEQ '2'
     C                     MOVEL'QPRINTC 'OUTQ
     C                     ENDIF
     C           WPRT      IFEQ '3'
     C                     MOVEL'LANPRT03'OUTQ
TCH60C                     ENDIF
TCHK2C           WPRT      IFEQ '4'
TCHK2C                     MOVEL'QPRINTB 'OUTQ
TCHK2C                     ENDIF
JW1  C           WPRT      IFEQ '5'
 |   C                     MOVEL'LANPRT04'OUTQ
JW1  C                     ENDIF
TCHK2C           WPRT      IFEQ '9'
TCHK2C                     MOVEL'QDKT    'OUTQ
TCHK2C                     ENDIF
      *
     C*  CHECK INTERNAL PART NUMBER
     C           HIN1      IFEQ *BLANK
     C           HIN2      ANDEQ*BLANK
     C           HIN3      ANDEQ*BLANK
     C           LOC1      ANDEQ*BLANK
     C           LOC2      ANDEQ*BLANK
     C                     SETON                     0199
     C                     SETON                     0607
     C                     MOVE ER,1      MSG
     C                     GOTO STP2
     C                     END
     C*
     C           HIN1      IFNE *BLANK
     C                     MOVE *BLANK    CFLG    1
     C           KEY       SETGTAAPTL011
     C           #READ1    TAG
     C           KEY       REDPEAAPTL011                 10
     C*
     C           *IN10     IFEQ '0'
     C           L5SKJY    IFNE ' '
     C                     GOTO #READ1
     C                     END
     C*
     C           L5STYY    IFNE 9999
     C                     GOTO #READ1
     C                     END
     C                     MOVE '*'       CFLG
     C*
     C                     END
      *
     C           CFLG      IFEQ *BLANK
     C           KEY       SETGTAANPL061
     C           #READ2    TAG
     C           KEY       REDPEAANPL061                 10
     C           *IN10     IFEQ '0'
     C           L7SKJY    IFNE ' '
     C                     GOTO #READ2
     C                     END
     C           L7STYY    IFNE 9999
     C                     GOTO #READ2
     C                     END
     C                     MOVE '*'       CFLG
     C                     END
     C                     END
      *
     C           CFLG      IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,2      MSG
     C                     GOTO STP2
     C                     END
      *
     C                     ENDIF
      *
     C*  CHECK THE DAY OF INVESTIGATION
     C           YMD       IFEQ 0
     C                     SETON                     0299
     C                     MOVE ER,3      MSG
     C                     GOTO STP2
     C                     END
      *
     C           YY        IFLT 1988
     C           MM        ORGT 12
     C           MM        ORLT 01
     C           DD        ORGT 31
     C           DD        ORLT 01
     C                     SETON                     0299
     C                     MOVE ER,4      MSG
     C                     GOTO STP2
     C                     END
      *
     C* TIME  & BIN CHECK
     C           BIN       IFEQ 0
     C                     SETON                     0399
     C                     MOVE ER,5      MSG
     C                     GOTO STP2
     C                     END
      *MSK 00.12.05
     C           @SFLG     IFNE 'Y'
     C           @SFLG     ANDNE'N'
     C                     SETON                     0499
     C                     MOVE ER,7      MSG
     C                     GOTO STP2
     C                     END
     C           @RFLG     IFNE 'Y'
     C           @RFLG     ANDNE'N'
     C                     SETON                     0599
     C                     MOVE ER,8      MSG
     C                     GOTO STP2
     C                     END
      * LOCATION CHECK
     C           LOC2      IFEQ *BLANK
     C           LOC1      ANDNE*BLANK
     C                     MOVE LOC1      LOC2
     C                     ENDIF
      *
     C           LOC2      IFLT LOC1
     C                     SETON                     060799
     C                     MOVE ER,9      MSG
     C                     GOTO STP2
     C                     ENDIF
      *
     C  NKE                GOTO STP2
      *
      *MSK 00.12.05
     C                     MOVE @SFLG     P1SFLG
     C                     MOVE @RFLG     P1RFLG
     C*  ADDTIONAL
     C           HIN1      IFNE *BLANK
     C                     SETOF                     90
     C           KEYA      CHAINAH#WP301             90
     C           *IN90     IFEQ '0'
     C           AHSKJY    IFEQ 'D'
     C           AHSKHZ    ANDLE*DATE
     C                     GOTO STP2
     C                     END
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVE ER,6      MSG
     C                     GOTO STP2
     C                     END
      *
      *
     C                     Z-ADD*DATE     AHKOHZ
     C                     TIME           WTIME
     C                     MOVELUS        AHKOME
     C                     MOVELHIN1      AHHIN1
     C                     MOVELHIN2      AHHIN2
     C                     MOVELHIN3      AHHIN3
     C                     Z-ADDYMD       AHYMD
     C                     Z-ADDBIN       AHBIN
      *
     C                     SETON                     U1
     C   90                WRITEAH#WP301
     C   90                ADD  1         COUNT
      *
     C                     ELSE
      *
     C           LOC12     IFEQ 'P1'
     C           LOC12     OREQ 'P2'
     C           LOC14     IFEQ LOC24
     C                     MOVE *ON       *IN50
     C                     ELSE
     C                     MOVE *OFF      *IN50
     C                     ENDIF
     C                     ENDIF
      *
     C           KEYL      SETLLFCEPL03
     C           *IN80     DOUEQ*ON
     C                     READ FCEPL03                  80
     C           *IN80     IFEQ *OFF
     C           A2GSKD    ANDEQ*BLANK
     C           A2LOC     IFGT LOC2
     C                     LEAVE
     C                     ENDIF
      *
     C           *IN50     IFEQ *ON
     C           A2STRD    ANDNELOC14
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE *BLANK    CFLG
     C           KEYF      SETGTAAPTL011
     C           *IN91     DOUEQ*ON
     C           KEYF      REDPEAAPTL011                 91
     C*
     C           *IN91     IFEQ *OFF
     C           L5SKJY    ANDEQ*BLANK
     C           L5STYY    ANDEQ9999
     C                     MOVE '*'       CFLG
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           CFLG      IFEQ *BLANK
      *
     C           KEYF      SETGTAANPL061
     C           *IN92     DOUEQ*ON
     C           KEYF      REDPEAANPL061                 92
     C*
     C           *IN92     IFEQ *OFF
     C           L7SKJY    ANDEQ*BLANK
     C           L7STYY    ANDEQ9999
     C                     MOVE '*'       CFLG
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
     C                     ENDIF
      *
     C           CFLG      IFEQ *BLANK
     C                     ITER
     C                     END
      *
     C           KEYB      CHAINAH#WP301             90
     C           *IN90     IFEQ '0'
     C                     ITER
     C                     ENDIF
      *
     C                     Z-ADD*DATE     AHKOHZ
     C                     TIME           WTIME
     C                     MOVELUS        AHKOME
     C                     MOVELA2BHB1    AHHIN1
     C                     MOVELA2BHB2    AHHIN2
     C                     MOVELA2BHB3    AHHIN3
     C                     Z-ADDYMD       AHYMD
     C                     Z-ADDBIN       AHBIN
      *
     C                     SETON                     U1
     C                     WRITEAH#WP301
     C                     ADD  1         COUNT
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDIF
 %0001* FOR J LOCATION KN-HT PARTS
S1   C           LOC11     IFEQ '1'
     C           LOC1A     ANDEQ'J'
      *
     C           KEYL      SETLLAAPPL031
     C                     DO   *HIVAL
     C                     READ AAPPL031                 10
      *
     C           L5LOC     IFGT LOC2
     C                     LEAVE
     C                     ENDIF
      * DELETED
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    ANDLE*DATE
     C                     ITER
     C                     ENDIF
      * EFFECTIVE
     C           L5STYY    IFNE 9999
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE '*'       CFLG
      *
  S2 C           CFLG      IFEQ '*'
     C           KEYC      CHAINAH#WP301             90
   S3C           *IN90     IFEQ '1'
     C                     Z-ADD*DATE     AHKOHZ
     C                     TIME           WTIME
     C                     MOVELUS        AHKOME
     C                     MOVELL5SHN1    AHHIN1
     C                     MOVELL5SHN2    AHHIN2
     C                     MOVELL5SHN3    AHHIN3
     C                     Z-ADDYMD       AHYMD
     C                     Z-ADDBIN       AHBIN
     C                     SETON                     U1
     C                     WRITEAH#WP301
     C                     ADD  1         COUNT
   E3C                     ENDIF
  E2 C                     ENDIF
      *
     C                     ENDDO
E1   C                     ENDIF
      *
     C                     GOTO STP1
      *
**  ERR
E-01 INPUT INTRAL COMPANY PART NO OR LOCATION CODE.
E-02 THERE ISN'T INT CO P/N IN LEVELD PROD FIXED ORDERING F
E-03 INPUT INVESTIGATION DAY
E-04 INVESTIGATION DAY ISN'T RIGHT
E-05 INPUT INVESTIGATION TIME OR BIN
E-06 ADD WAS APPOINTED, BUT M/F EXIST.
E-07 SHIPMENT INFORMATION IS < Y/N >.
E-08 SATURDAY KANBAN INFOMATION IS < Y/N >
E-09 LOCATION CODE ERROR.
E-10 INVALID PRINTER OPTION
