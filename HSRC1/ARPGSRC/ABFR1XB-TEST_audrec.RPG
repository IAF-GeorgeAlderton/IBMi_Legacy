     H            Y.
     F** ABFR1X *****************************
     F* TEST AUDREC
     F* T.SAKAKI    2017.02.01
     F************************ ABFR1X **
     FAUDRECL6IF  E           K        DISK
     FOUTDTA  IF  E           K        DISK
     FAB#FP1X O   E                    DISK
      *
     I            DS
     I                                        1  80 OQDDTA
     I                                        2  10 H#GSI3
     I                                       11  19 H#GSI1
     I                                       39  43 H#PLID
     I                                       45  500H#DATA
     I                                       52  550H#TIME
     I                                       57  60 H#GSI2
     I                                       78  80 H#STID
      *
     I              'AVRTA'               C         WK1
     I              'ST*856'              C         WK2
     I              'ST**92'              C         WK3
      *----------------------------------------------------*
      * KEY LIST                                           *
      *----------------------------------------------------*
     C           KEY1      KLIST
     C                     KFLD           P1KEY1 30
     C                     KFLD           P1KEY2  4
     C                     KFLD           P1KEY3  1
     C                     KFLD           P1KEY4  6
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     MOVEL'FORD'    P1KEY1
     C                     MOVEL'S'       P1KEY3
     C                     MOVEL'SH'      P1KEY4
     C*-------------------------
     C*-------------------------
     C           KEY1      SETLLAUDRECL6
     C*-------------------------
     C                     DO   *HIVAL
     C           KEY1      READEAUDRECL6                 90
     C   90                LEAVE
     C*
     C                     MOVEL*BLANK    IDATA
     C                     MOVEL*BLANK    SVDAT
     C                     MOVEL*BLANK    SVDT2
     C*
     C                     MOVE AFDCBM    XXDCBM  70
     C           XXDCBM    SETLLOUTDTA
     C*-------------------------
     C                     DO   *HIVAL
     C           XXDCBM    READEOUTDTA                   91
     C   91                LEAVE
     C*
     C                     MOVELOQDDTA    IDATA  80
     C*
     C           OQDREC    IFEQ 2
     C                     CLEARAB#FP1X1
     C                     Z-ADDXXDCBM    F4DCBM
     C                     MOVELH#GSI1    F4GSI1
     C                     Z-ADDH#DATA    F4DATE
     C                     Z-ADDH#TIME    F4TIME
     C           F4DATE    IFLT 130000
     C                     LEAVE
     C                     ENDIF
     C***
     C* AVRTA*XXXXX
     C           WK1       SCAN OQDDTA    WK1W    30
     C           WK1W      ADD  6         WK1S    30
     C                     Z-ADDWK1S      @1      30
     C           5         SUBSTIDATA:@1  F4PRTN
     C* AVRTA*XXXXXXXXXXXXXX
     C           WK1       SCAN OQDDTA    WK1W    30
     C           WK1W      ADD  24        WK1S    30
     C                     Z-ADDWK1S      @1      30
     C           4         SUBSTIDATA:@1  F4GSI2
     C*
     C* ST*856*XXXXXXXXX
     C           WK2       SCAN IDATA     WK2W    30
     C           WK2W      ADD  7         WK2S    30
     C                     Z-ADDWK2S      @2      30
     C           @2        IFGT 73
     C                     MOVELIDATA     SVDAT 160
     C                     ELSE
     C           9         SUBSTIDATA:@2  F4GSI3
     C                     ENDIF
     C*
     C                     ENDIF
     C*
     C           OQDREC    IFEQ 3
     C*
     C                     MOVELIDATA     SVDT2 240
     C*
     C           @2        IFGT 73
     C           SVDAT     CAT  IDATA:0   SVDAT
     C           WK2       SCAN SVDAT     WK2W    30
     C           WK2W      ADD  7         WK2S    30
     C                     Z-ADDWK2S      @2      30
     C           9         SUBSTSVDAT:@2  F4GSI3
     C                     ENDIF
     C*
     C                     ENDIF
     C*
     C           OQDREC    IFEQ 4
     C           SVDT2     CAT  IDATA:0   SVDT2
     C                     ENDIF
     C*
     C           OQDREC    IFEQ 5
     C           SVDT2     CAT  IDATA:0   SVDT2
     C* ST**92*XXXXX
     C           WK3       SCAN SVDT2     WK3W    30
     C           WK3W      ADD  7         WK3S    30
     C                     Z-ADDWK3S      @3      30
     C           5         SUBSTSVDT2:@3  F4SHPT
     C**
     C                     ENDIF
     C*
     C           OQDREC    IFEQ 6
     C                     WRITEAB#FP1X1
     C                     LEAVE
     C                     ENDIF
     C*
     C*
     C                     ENDDO
     C*
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
