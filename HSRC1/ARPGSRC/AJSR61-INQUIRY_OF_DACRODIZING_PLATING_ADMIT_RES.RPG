     C           STP0      TAG
     C                     MOVE *BLANK    MACH
     C                     Z-ADD*ZERO     SHIZ
     C                     Z-ADD*ZERO     EHIZ
      ******************************************************
      *  EXFMT  <fﾞx] 1>                                   *
      ******************************************************
     C           STP1      TAG
     C                     Z-ADD*ZERO     RRN     50
     C                     EXFMTAJSPW611
     C                     MOVEA'000'     *IN,01
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    ERR
     C                     MOVEA'1'       *IN,92
     C                     WRITEDSP2C
     C                     MOVEA'0'       *IN,92
      *
B001 C           *INKA     IFEQ '1'
     C                     MOVEL'1'       *INLR
     C                     RETRN
E001 C                     END
      ******************************************************
      *  <fﾞx] 1 ﾉ kｩｮh>                                   *
      ******************************************************
B001 C           MACH      IFEQ *BLANK
     C                     MOVEA'1'       *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,1     ERR
     C                     GOTO STP1
E001 C                     END
      *
B001 C           SHIZ      IFNE *ZERO
B002 C           SMM       IFGT 12
     C           SMM       ORLT 01
     C           SDD       ORGT 31
     C           SDD       ORLT 01
     C                     MOVEA'1'       *IN,02
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,4     ERR
     C                     GOTO STP1
E002 C                     END
E001 C                     END
      *
B001 C           EHIZ      IFNE *ZERO
B002 C           EMM       IFGT 12
     C           EMM       ORLT 01
     C           EDD       ORGT 31
     C           EDD       ORLT 01
     C                     MOVEA'1'       *IN,03
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,6     ERR
     C                     GOTO STP1
E002 C                     END
E001 C                     END
      *
     C           KEY1      KLIST
     C                     KFLD           MACH
     C                     KFLD           SYY
     C                     KFLD           SMM
     C                     KFLD           SDD
      *
     C           KEY2      KLIST
     C                     KFLD           MACH
      *
     C           @LOOP     TAG
     C                     Z-ADD*ZERO     CNTR    50
     C                     EXSR #SET
      *
     C           ERR       IFNE *BLANK
     C                     MOVEA'1'       *IN,99
     C                     GOTO STP1
     C                     END
      *
     C                     Z-ADD1         RCDNBR
      ******************************************************
      *  EXFMT  (fﾞx] 2)                                   *
      ******************************************************
     C           STP2      TAG
     C                     MOVEA'0'       *IN,81
     C                     WRITEDSP2X
     C                     MOVEA'1'       *IN,91
     C                     EXFMTDSP2C
     C                     MOVEA'0'       *IN,91
      *
     C                     MOVEA'0'       *IN,44
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    ERR
      *
B001 C           *INKC     IFEQ '1'
     C                     GOTO STP0
E001 C                     END
      *  ﾜｰﾓ aｮﾎﾟ
     C           *IN,81    IFEQ '1'
     C                     Z-ADD*ZERO     CNTR
     C                     EXSR ROLLUP
     C                     Z-ADDRRN       RCDNBR
     C   44                MOVEA'1'       *IN,99
     C                     GOTO STP2
     C                     END
      *
     C                     Z-ADD1         RCDNBR
      *
     C                     Z-ADDRRN       XXRRN   50
B001 C                     DO   *HIVAL    RRN@@   50
     C           RRN@@     CHAINDSP2R                42
B002 C           *IN,42    IFEQ '0'
B003 C           OP        IFEQ 'M'
      *  ﾅﾎﾞﾎｦbﾓ ﾍﾍｭcﾆﾞ ---> fﾞx]2 ﾉ ﾎｧｰﾓnﾞ
     C                     MOVEL#KNKB     XXKNKB
     C                     MOVEL#ZNO      XXZNO
     C                     MOVEL#TNO      XXTNO
     C                     MOVEL#PNO1     XXPNO1
     C                     MOVEL#PNO2     XXPNO2
     C                     MOVEL#PNO3     XXPNO3
     C                     MOVEL#PNO4     XXPNO4
     C                     MOVEL#2JIK     XX2JIK
     C                     MOVEL#TISG     XXTISG
     C                     MOVEL#SYKB     XXSYKB
     C                     MOVEL#HAKO     XXHAKO
     C                     Z-ADD#KEIS     XXKEIS
     C                     MOVEL#IRO      XXIRO
     C                     Z-ADD#SYOS     XXSYOS
     C                     MOVEL#MHKO     XXMHKO
     C                     Z-ADD#TANJ     XXTANJ
     C                     Z-ADD#THIZ     XXTHIZ
     C                     Z-ADD#TTIM     XXTTIM
     C                     Z-ADD#TNMJ     XXTNMJ
     C                     MOVE #KIBN     XXKIBN
     C                     Z-ADD#KHIZ     XXKHIZ
     C                     Z-ADD#KTIM     XXKTIM
     C                     Z-ADD#KEIJ     XXKEIJ
     C                     MOVE #TOCD     XXTOCD
     C                     MOVE #ZAI1     XXZAI1
     C                     MOVE #ZAI2     XXZAI2
      *  EXFMT fﾞx] 2
     C                     EXSR #SET2
     C                     MOVE *BLANK    OP
     C                     UPDATDSP2R
E003 C                     END
E002 C                     END
E001 C  N42                END
      *
     C                     Z-ADD*ZERO     RRN
     C                     GOTO @LOOP
      ******************************************************
     C           #SET      BEGSR                           *
      ******************************************************
      *  ﾅﾎﾞﾎｦbﾓ ﾈｮn
     C                     MOVEA'1'       *IN,92
     C                     WRITEDSP2C
     C                     MOVEA'0'       *IN,92
      *
     C           KEY1      SETLLAJSPL151
      *  ﾅﾎﾞﾎｦbﾓ ﾛﾃｰnﾞ CLR
     C                     MOVE *BLANK    OP
     C                     MOVE *BLANK    @HIN
     C                     MOVE *BLANK    @THI
     C                     MOVE *BLANK    @PNO1
     C                     MOVE *BLANK    @PNO2
     C                     MOVE *BLANK    @PNO3
     C                     MOVE *BLANK    @PNO4
     C                     Z-ADD*ZERO     @KEIS
     C                     MOVE *BLANK    @IRO
     C                     Z-ADD*ZERO     @THIZ
     C                     Z-ADD*ZERO     @TTIM
     C                     Z-ADD*ZERO     @GRYO
     C                     MOVE *BLANK    #KNKB
     C                     MOVE *BLANK    #ZNO
     C                     MOVE *BLANK    #TNO
     C                     MOVE *BLANK    #PNO1
     C                     MOVE *BLANK    #PNO2
     C                     MOVE *BLANK    #PNO3
     C                     MOVE *BLANK    #PNO4
     C                     MOVE *BLANK    #2JIK
     C                     MOVE *BLANK    #TISG
     C                     MOVE *BLANK    #SYKB
     C                     MOVE *BLANK    #HAKO
     C                     Z-ADD*ZERO     #KEIS
     C                     MOVE *BLANK    #IRO
     C                     Z-ADD*ZERO     #SYOS
     C                     MOVE *BLANK    #MHKO
     C                     Z-ADD*ZERO     #TANJ
     C                     Z-ADD*ZERO     #THIZ
     C                     Z-ADD*ZERO     #TTIM
     C                     Z-ADD*ZERO     #TNMJ
     C                     MOVE *ZERO     #KIBN
     C                     Z-ADD*ZERO     #KHIZ
     C                     Z-ADD*ZERO     #KTIM
     C                     Z-ADD*ZERO     #KEIJ
     C                     MOVE *BLANK    #TOCD
     C                     MOVE *BLANK    #ZAI1
     C                     MOVE *BLANK    #ZAI2
      *
B001 C                     DO   *HIVAL
     C           MORE1     TAG
     C           KEY2      READEAJSPL151                 40
     C   40                GOTO @@@
      *
     C           J1SKJY    IFEQ 'D'
     C           J1SKHZ    IFLE *DATE
     C                     GOTO MORE1
     C                     END
     C                     END
      *
B002 C           *IN,40    IFEQ '0'
     C                     MOVEA'0'       *IN,21
     C           J1WKHZ    CABLTSHIZ      @END
     C           J1WKHZ    CABGTEHIZ      @@@
      *
     C           J1HIN2    IFNE *BLANK
     C                     MOVEL'-'       HINA
     C                     END
      *
     C           J1HIN3    IFNE *BLANK
     C                     MOVEL'-'       HINB
     C                     END
     C                     MOVE HIN       @HIN
     C                     MOVELJ1THAI    @THI
     C                     MOVELJ1PAG1    @PNO1
     C                     MOVELJ1PAG2    @PNO2
     C                     MOVELJ1PAG3    @PNO3
     C                     MOVELJ1PAG4    @PNO4
     C                     Z-ADDJ1MKSU    @KEIS
     C                     MOVELJ1IROK    @IRO
     C                     Z-ADDJ1WKHZ    @THIZ
     C                     Z-ADDJ1WKTM    @TTIM
     C                     Z-ADDJ1WMJY    @GRYO
     C                     MOVELJ1KANK    #KNKB
     C                     MOVELJ1ZETI    #ZNO
     C                     MOVELJ1THAI    #TNO
     C                     MOVELJ1PAG1    #PNO1
     C                     MOVELJ1PAG2    #PNO2
     C                     MOVELJ1PAG3    #PNO3
     C                     MOVELJ1PAG4    #PNO4
     C                     MOVELJ12JKA    #2JIK
     C                     MOVELJ1TASY    #TISG
     C                     MOVELJ1SYKO    #SYKB
     C                     MOVELJ1HKBR    #HAKO
     C                     Z-ADDJ1MKSU    #KEIS
     C                     MOVELJ1IROK    #IRO
     C                     Z-ADDJ1SYUY    #SYOS
     C                     MOVELJ1HKFA    #MHKO
     C                     Z-ADDJ1TANJ    #TANJ
     C                     Z-ADDJ1WKHZ    #THIZ
     C                     Z-ADDJ1WKTM    #TTIM
     C                     Z-ADDJ1WMJY    #TNMJ
     C                     MOVE J1MKKB    #KIBN
     C                     Z-ADDJ1KEHZ    #KHIZ
     C                     Z-ADDJ1KETM    #KTIM
     C                     Z-ADDJ1WAIT    #KEIJ
     C                     MOVE J1TOCD    #TOCD
     C                     MOVE J1ZBR1    #ZAI1
     C                     MOVE J1ZBR2    #ZAI2
      *
     C           J1SAIK    IFEQ '0'
     C                     MOVEA'0'       *IN,21
     C                     ELSE
     C                     MOVEA'1'       *IN,21
     C                     END
      *
     C                     ADD  1         RRN
     C                     ADD  1         CNTR
     C                     WRITEDSP2R
      * MAX mﾞｰj <15>
     C           CNTR      CABEQ15        @@@
E002 C                     END
     C           @END      TAG
E001 C  N40                END
      *
     C           @@@       TAG
      *  fﾞbnc mﾞｰj oﾆ
B001 C           RRN       IFEQ 0
     C                     MOVEA'111'     *IN,01
     C                     MOVEA'1'       *IN,99
     C                     MOVELMSG,2     ERR
     C                     END
      *
     C                     ENDSR
      ******************************************************
     C           #SET2     BEGSR                           *
      ******************************************************
     C           STP3      TAG
     C                     EXFMTAJSPW612
      *
     C                     MOVEA'0'       *IN,01
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    ERR
      *
B001 C           *INKC     IFEQ '1'
     C                     MOVEA'1'       *IN,42
     C                     GOTO #SET2E
E001 C                     END
      *
     C           #SET2E    ENDSR
      ******************************************************
     C           ROLLUP    BEGSR                           *
      ******************************************************
     C                     MOVE *BLANK    SW      1
B001 C                     DO   *HIVAL
     C           KEY2      READEAJSPL151                 40
     C           MORE2     TAG
     C   40                GOTO @ROLE
      *
     C           J1SKJY    IFEQ 'D'
     C           J1SKHZ    IFLE *DATE
     C                     GOTO MORE2
     C                     END
     C                     END
      *
B002 C           *IN,40    IFEQ '0'
     C           J1WKHZ    CABLTSHIZ      @END1
     C           J1WKHZ    CABGTEHIZ      @ROLE
     C                     MOVEL'*'       SW
     C                     MOVE HIN       @HIN
     C                     MOVELJ1THAI    @THI
     C                     MOVELJ1PAG1    @PNO1
     C                     MOVELJ1PAG2    @PNO2
     C                     MOVELJ1PAG3    @PNO3
     C                     MOVELJ1PAG4    @PNO4
     C                     Z-ADDJ1MKSU    @KEIS
     C                     MOVELJ1IROK    @IRO
     C                     Z-ADDJ1WKHZ    @THIZ
     C                     Z-ADDJ1WKTM    @TTIM
     C                     Z-ADDJ1WMJY    @GRYO
     C                     MOVELJ1KANK    #KNKB
     C                     MOVELJ1ZETI    #ZNO
     C                     MOVELJ1THAI    #TNO
     C                     MOVELJ1PAG1    #PNO1
     C                     MOVELJ1PAG2    #PNO2
     C                     MOVELJ1PAG3    #PNO3
     C                     MOVELJ1PAG4    #PNO4
     C                     MOVELJ12JKA    #2JIK
     C                     MOVELJ1TASY    #TISG
     C                     MOVELJ1SYKO    #SYKB
     C                     MOVELJ1HKBR    #HAKO
     C                     Z-ADDJ1MKSU    #KEIS
     C                     MOVELJ1IROK    #IRO
     C                     Z-ADDJ1SYUY    #SYOS
     C                     MOVELJ1HKFA    #MHKO
     C                     Z-ADDJ1TANJ    #TANJ
     C                     Z-ADDJ1WKHZ    #THIZ
     C                     Z-ADDJ1WKTM    #TTIM
     C                     Z-ADDJ1WMJY    #TNMJ
     C                     MOVE J1MKKB    #KIBN
     C                     Z-ADDJ1KEHZ    #KHIZ
     C                     Z-ADDJ1KETM    #KTIM
     C                     Z-ADDJ1WAIT    #KEIJ
     C                     MOVE J1TOCD    #TOCD
     C                     MOVE J1ZBR1    #ZAI1
     C                     MOVE J1ZBR2    #ZAI2
      *
     C           J1SAIK    IFEQ '0'
     C                     MOVEA'0'       *IN,21
     C                     ELSE
     C                     MOVEA'1'       *IN,21
     C                     END
      *
     C                     ADD  1         RRN
     C                     ADD  1         CNTR
     C                     WRITEDSP2R
     C           CNTR      CABEQ15        @ROLE
E002 C                     END
     C           @END1     TAG
E001 C  N40                END
      *
     C           @ROLE     TAG
      *  ﾃﾛbﾆﾞｭc mﾞｰj oﾆ
B001 C           SW        IFEQ *BLANK
     C                     MOVEA'1'       *IN,44
E001 C                     END
      *
     C                     ENDSR
