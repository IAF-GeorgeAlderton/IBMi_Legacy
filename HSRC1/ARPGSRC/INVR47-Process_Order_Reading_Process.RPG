     H            Y.                                    1
     F** INVR47 **********************************
     F*工程順読み処理
     F*   %0001 T.SAKAKI  2016.07.08 CHANGE
     F********************************** INVR42 **
     FINVWP41 IP  E                    DISK
     FFCEPL01 IF  E           K        DISK
     FINVWP47 O   F     512            DISK
     F*INVPP40BO   E                    DISK                      A
     FINVPP46 O   E                    DISK                      A
     IINVWP411
     I                                              A2BHB1L1
     I                                              A2BHB2L1
     I                                              A2BHB3L1
     I            DS
     I                                        1   6 I2LOC
     I                                        1   1 I2LOC1
     I                                        2   3 I2LOC2
     I                                        4   5 I2LOC3
     I                                        6   6 I2LOC4
      *
     C           *INL1     IFEQ '1'
     C                     MOVE *BLANK    @FLG    1
     C                     Z-ADD0         W@ALL  120
     C                     Z-ADD0         W@LONG  42
     C                     END
      *
     C           P#BMON    IFNE '0111'
     C           P#BMON    ANDNE'8990'
     C                     MOVE '*'       @FLG
     C                     END
      *最も長いＬＴ
     C           P@LT      IFGE W@LONG
     C                     Z-ADDP@LT      W@LONG
     C                     END
      *外注以降の在庫数量
     C           @FLG      IFEQ '*'
     C                     ADD  W@KANQ    W@ALL
     C                     ADD  AFQTYS    W@ALL
     C***                  ADD  P#QTY     W@ALL
     C***                  ADD  P#QTY2    W@ALL
     C***                  ADD  P#RUNB    W@ALL
     C***                  ADD  P#QTY3    W@ALL
     C                     END
      *
     CL1                   EXSR #L1
      *-----------------------------------------------------
     C           #L1       BEGSR
      *
     C           @FLG      IFEQ '*'
      *
     C           FCEKEY    KLIST
     C                     KFLD           A2BHB1
     C                     KFLD           A2BHB2
     C                     KFLD           A2BHB3
      *
     C                     Z-ADD0         W@SSSS 120
     C                     Z-ADD0         W@GEKN 120
      *
     C           FCEKEY    CHAINFCEPL01              88
     C           *IN88     IFEQ '0'
     C           A2GEKN    DIV  20        W@GEKN
     C* * *      W@GEKN    MULT W@LONG    W@SSSS
%0001C* * *      W@GEKN    MULT 3         W@SSSS
     C           W@GEKN    MULT 5         W@SSSS
     C                     END
      *
     C                     MOVE *BLANK    W#FLG   1
     C           W@SSSS    IFGT W@ALL
     C                     MOVE '*'       W#FLG
     C                     END
      *
     C  N77                EXCPTOHED
     C                     SETON                     77
     C                     EXCPTODAT
      *
     C                     Z-ADD0         I2QTY
     C* * *                Z-ADD0         I2DATE
     C* * *                Z-ADD0         I2TIME
      *
     C* * *                WRITEINVPP401
      *
     C                     MOVE A2BHB1    @@@HN1
     C                     MOVE A2BHB2    @@@HN2
     C                     MOVE A2BHB3    @@@HN3
     C           W#FLG     IFEQ *BLANK
     C                     WRITEINVPP461
     C                     END
      *
     C                     END
      *
     C           EL1       ENDSR
      *-----------------------------------------------------
     OINVWP47 E                OHED
     O                                      'PART NO.,'
     O                                      'FIN. STORE,'
     O                                      'STOCK,'
     O                                      'MOST LONG LT,'
     O                                      'SETTING/DAY,'
     O                                      'SETTING*LT,'
     O                                      'NG FLAG,'
      *
     OINVWP47 E                ODAT
     O                                      '="'
     O                         A2BHB1
     O                         A2BHB2
     O                         A2BHB3
     O                                      '"'
     O                                      ','
     O                                      '="'
     O                         I2LOC2
     O                                      '-'
     O                         I2LOC3
     O                                      '"'
     O                                      ','
     O                         W@ALL
     O                                      ','
     O                         W@LONG       '  .  '
     O                                      ','
     O                         W@GEKN
     O                                      ','
     O                         W@SSSS
     O                                      ','
     O                         W#FLG
