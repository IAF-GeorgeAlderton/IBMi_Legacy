     H            Y.
     F** FBCR40 ************************************
     F* CREATE UNIT PRICE M/F CSV DATA             *
     F*       T.SAKASHITA         2006.01.07       *
     F************************************ FBCR40 **
     FFBCPL03 IP  E           K        DISK
     FFBCWP40 O   F    2048            DISK
     IFBCPL031
     I                                              FBTOKUL1
     I                                              FBNONYL1
     I                                              FBNKOJL1
     I                                              FBNUKEL1
     I                                              FBMHN1L1
     I                                              FBMHN2L1
     I                                              FBMHN3L1
     I                                              FBMHN4L1
     C           *IN55     IFEQ '0'
     C                     SETON                     55
     C                     EXCPTOHED
     C                     END
      *
     C           FBSKJY    IFNE 'D'
     C                     SETON                     56
     C                     Z-ADDFBTOKU    W@TOKU  40
     C                     Z-ADDFBNONY    W@NONY  40
     C                     MOVELFBNKOJ    W@NKOJ  1
     C                     MOVELFBNUKE    W@NUKE  4
     C                     MOVELFBMHN1    W@MHN1  5
     C                     MOVELFBMHN2    W@MHN2  5
     C                     MOVELFBMHN3    W@MHN3  5
     C                     MOVELFBMHN4    W@MHN4  5
     C                     MOVELFBSHN1    W@SHN1  5
     C                     MOVELFBSHN2    W@SHN2  5
     C                     MOVELFBSHN3    W@SHN3  2
     C                     Z-ADDFBNTAN    W@NTAN 105
     C                     Z-ADDFBTKHZ    W@TKHZ  80
     C                     Z-ADDFBTSHZ    W@TSHZ  80
     C                     END
      *
     CL1 56                EXCPTODAT
     CL1                   SETON                     56
     OFBCWP40 E                OHED
     O                                      'CUSTOMER'
     O                                      ','
     O                                      'DELIVERY'
     O                                      ','
     O                                      'FACTORY'
     O                                      ','
     O                                      'DOCK'
     O                                      ','
     O                                      'USER PART NO.'
     O                                      ','
     O                                      'UNIT PRICE'
     O                                      ','
     O                                      'START'
     O                                      ','
     O                                      'END'
     O                                      ','
     O        E                ODAT
     O                         W@TOKU
     O                                      ','
     O                         W@NONY
     O                                      ','
     O                         W@NKOJ
     O                                      ','
     O                         W@NUKE
     O                                      ','
     O                                      '="'
     O                         W@MHN1
     O                         W@MHN2
     O                         W@MHN3
     O                         W@MHN4
     O                                      '"'
     O                                      ','
     O                         W@NTAN1
     O                                      ','
     O                         W@TKHZ
     O                                      ','
     O                         W@TSHZ
     O                                      ','
