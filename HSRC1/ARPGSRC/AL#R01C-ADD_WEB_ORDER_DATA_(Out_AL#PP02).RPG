     H            Y.
     F** AL#R01C *******************************************
     F*  ADD WEB ORDER DATA                                *
     F*  JW      2019.02.13                                *
     F*  LEC     2020.07.09  ADD LOGIC FOR NEW FIELDS      *
     F******************************************************
     FAL#WP01 IF  F     256            DISK
     FAL#PP21 IF  E           K        DISK
     FAB#PPDC IF  E           K        DISK
     FAL#PL06 IF  E           K        DISK
     FAL#PP02 O   E                    DISK                      A
      *
     IAL#WP01 AA  01
     I                                        1 256 IALL
     I                                        1   1 IRECT
     I                                        2   2 ICADT
     I                                        3  32 ISUPI
     I                                       33  37 ISUPC
     I                                       38  39 IDOCK
     I                                       40  43 IKNB#
     I                                       44  55 IMHN
     I                                       44  48 IMHN1
     I                                       49  53 IMHN2
     I                                       54  55 IMHN3
     I                                       56  65 ILIAD
     I                                       66  75 ISTAD
     I                                       76  80 IQTBO
     I                                       81 100 ISUPN
     I                                      101 109 IMART
     I                                      110 118 ISURT
     I                                      119 126 IULDA
     I                                      127 134 ISHID
     I                                      135 140 ISHIT
     I                                      141 152 IORD#
     I                                      153 156 IBOX#
     I                                      157 160 IBOXT
     I                                      161 165 INAMC
     I                                      166 182 IINKK
     I                                      183 184 ILPOS
     I                                      185 194 INAM2
     I                                      195 196 INAM3
     I                                      197 198 IPALT
     I                                      199 208 INAD5
     I                                      209 210 INAD6
     I                                      211 255 IFILL
     I                                      241 250 IMAN#
     I                                      251 252 IBIN#
     I                                      256 256 ITERM
      *
     I            DS
     I                                        1   9 @9
     I                                        1   4 XCUST
     I                                        5   5 XFACT
     I                                        6   9 XSHTO
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
     C                     READ AL#WP01                  90
     C           *IN90     DOWEQ'0'
     C           IRECT     IFEQ '2'
     C                     EXSR #SB400
     C           GETAAA    IFEQ '0'
     C                     EXSR #SB500
     C                     ENDIF
     C                     ENDIF
     C                     READ AL#WP01                  90
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *  AL#PP02
      *-----------------------------------------------------
     CSR         #SB400    BEGSR
      *
     C                     MOVEL'0'       GETAAA  1
     C           IALL      SETLLAL#PL061
     C           IALL      READEAL#PL061                 88
     C           *IN88     DOWEQ'0'
     C           GETAAA    ANDEQ'0'
     C           CASKJY    IFEQ 'D'
     C           CASKHZ    ANDLESDATE
     C                     ELSE
     C                     MOVEL'1'       GETAAA
     C                     ENDIF
     C           IALL      READEAL#PL061                 88
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *-----------------------------------------------------
      *  AL#PP02
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C                     CLEARAL#PP021
      *
     C                     Z-ADDSDATE     CAKOHZ
     C                     Z-ADDSTIME     CAKOTI
     C                     MOVELW#USER    CAKOME
     C           INAMC     CHAINAL#PP211             26
     C           *IN26     IFEQ '0'
     C           C2SKJY    ANDEQ'D'
     C           C2SKHZ    ANDLESDATE
     C                     SETON                     26
     C                     ENDIF
      *
     C           *IN26     IFEQ '0'
     C                     MOVELC2TOKU    CATOKU
     C                     MOVELC2NONY    CANONY
     C                     MOVELC2NKOJ    CANKOJ
     C                     ELSE
     C           INAMC     IFEQ '60EXP'
     C                     MOVELIDOCK     INUKE   4 P
     C           INUKE     CHAINAB#PPDC              26
     C           *IN26     IFEQ *OFF
     C                     MOVELADNONY    CANONY
     C                     MOVELADTOKU    CATOKU
     C                     MOVE ADNKOJ    CANKOJ
     C                     ELSE
     C                     MOVEL*BLANKS   CANONY
     C                     MOVEL*BLANKS   CATOKU
     C                     MOVE *BLANKS   CANKOJ
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
      *
     C                     MOVELIDOCK     CANUKE
     C                     Z-ADDSDATE     CAWBRD
     C                     Z-ADDSTIME     CAWBRT
     C                     MOVELICADT     CACADT
     C                     MOVELISUPI     CASUPI
     C                     MOVELISUPC     CASUPC
     C                     MOVELIDOCK     CADOCK
     C                     MOVELIKNB#     CAKNB#
     C                     MOVELIMHN      CAMHN
     C                     MOVELILIAD     CALIAD
     C                     MOVELISTAD     CASTAD
     C                     MOVELIQTBO     CAQTBO
     C                     MOVELISUPN     CASUPN
     C                     MOVELIMART     CAMART
     C                     MOVELISURT     CASURT
     C                     MOVELIULDA     CAULDA
     C                     MOVELISHID     CASHID
     C                     MOVELISHIT     CASHIT
     C                     MOVELIORD#     CAORD#
     C                     MOVELIBOX#     CABOX#
     C                     MOVELIBOXT     CABOXT
     C                     MOVELINAMC     CANAMC
     C                     MOVELIINKK     CAINKK
     C                     MOVELILPOS     CALPOS
     C                     MOVELINAM2     CANAM2
     C                     MOVELINAM3     CANAM3
     C                     MOVELIPALT     CAPALT
     C                     MOVELINAD5     CANAD5
     C                     MOVELINAD6     CANAD6
     C                     MOVELIFILL     CAFILL
     C                     MOVELITERM     CATERM
     C                     MOVELIALL      CAALL
      *
     C                     Z-ADD0         CAEXTR
     C                     MOVEL*BLANK    CATRKB
     C                     MOVEL*BLANK    CAIAFB
     C                     MOVEL*BLANK    CAIAFP
     C                     Z-ADD0         CAFIXD
     C                     Z-ADD0         CAFIXT
     C                     MOVEL*BLANK    CASHN1
     C                     MOVEL*BLANK    CASHN2
     C                     MOVEL*BLANK    CASHN3
     C                     MOVEL*BLANK    CATKR1
     C                     MOVEL*BLANK    CATKR2
     C                     MOVEL*BLANK    CATKR3
     C                     MOVEL*BLANK    CATKR4
     C                     Z-ADD0         CAKADT
     C                     Z-ADD0         CAKATI
     C                     Z-ADD0         CASEQ#
     C                     Z-ADD0         CAPLDT
     C                     Z-ADD0         CAPLTI
     C                     MOVEL*BLANK    CASHME
      *
     C                     WRITEAL#PP021
      *
     CSR         ESB500    ENDSR
