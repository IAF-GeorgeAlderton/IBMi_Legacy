     C**************************************************************************
     C*         INITIALIZE
     C**************************************************************************
     C           *INZSR    BEGSR
     C* PREV MONTH
     C                     TIME           WSDT
     C           WSSMMM    SUB  1         K@MMMM
     C           K@MMMM    IFLE *ZERO
     C                     ADD  12        K@MMMM
     C           WSSYYY    SUB  1         K@YYYY
     C                     ELSE
     C                     Z-ADDWSSYYY    K@YYYY
     C                     END
     C* PREV MONTH WORKING DAYS
     C                     Z-ADD*ZERO     W@DAYS  31
     C           K#AGD     KLIST
     C                     KFLD           K@YYYY  40
     C                     KFLD           K@MMMM  20
     C           K#AGD     SETLLAGDPL12
     C                     DO   *HIVAL
     C           K#AGD     READEAGDPL12                  99
     C   99                LEAVE
     C                     SELEC
     C           F8HIRU    WHEQ *BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     ADD  1         W@DAYS
     C           F8HIRU    WHNE *BLANK
     C           F8YORU    ANDNE*BLANK
     C                     ADD  0         W@DAYS
     C                     OTHER
     C                     ADD  0.5       W@DAYS
     C                     ENDSL
     C                     ENDDO
     C*
     C                     ENDSR
     C*************************************************************************
     C*
     C**************************************************************************
     C           #CTL20    BEGSR
      *
     C                     EXSR #SET20
     C                     Z-ADD1         W#RNP2  40
      *
     C                     DO   *HIVAL
     C*
     C                     WRITEFMT099
     C                     Z-ADDW#RNP2    #RCN02
     C                     EXFMTCTL020
     C*
     C           @@REC     IFNE *ZERO
     C                     Z-ADD@@REC     W#RNP2
     C                     END
     C*
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN49
     C*
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     LEAVE
     C                     OTHER
     C                     ENDSL
     C*
     C                     ENDDO
     C*
     C                     ENDSR
     C*************************************************************************
     C*
     C**************************************************************************
     C           #SET20    BEGSR
      *
     C                     EXSR #SET2A
      *
     C                     MOVEL*ON       *IN41
     C                     WRITECTL020
