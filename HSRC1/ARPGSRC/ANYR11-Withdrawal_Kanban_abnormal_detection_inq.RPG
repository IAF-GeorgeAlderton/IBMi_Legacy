     C                     Z-ADDL6LTIM    YWLT
     C                     Z-ADDL6KEIS    YWCOEF
     C                     Z-ADDL6KMAX    YWKMAX
     C           L6SYOS    IFNE *ZERO
     C           L6KTSU    DIV  L6SYOS    W@KTSU  92
     C           W@KTSU    ADD  0.09      YWKTSU
     C                     END
     C           K#ANZ     KLIST
     C                     KFLD           L6SHN1
     C                     KFLD           L6SHN2
     C                     KFLD           L6SHN3
     C                     KFLD           L6KCD1
     C                     KFLD           L6KCD2
     C           K#ANZ     CHAINANZPP01              98
     C           *IN98     IFEQ *OFF
     C           Z1SKJY    ANDEQ*BLANK
     C                     Z-ADDZ1DUPH    YWMAX
     C                     END
     C*
     C                     Z-ADD*ZERO     W@QTY1
     C                     Z-ADD*ZERO     W@QTY2
     C                     Z-ADD*ZERO     W@CNT1
     C                     Z-ADD*ZERO     W@CNT2
     C                     Z-ADD*ZERO     W@CNT3
     C           *LOVAL    SETLLGADPL11
     C*
     C                     DO   *HIVAL
     C*
     C                     READ GADPL11                  97
     C   97                LEAVE
     C           B5SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C*
     C                     Z-ADD*ZERO     W@QTYA
     C*
     C           K#ABB1    KLIST
     C                     KFLD           L6SHN1
     C                     KFLD           L6SHN2
     C                     KFLD           L6SHN3
     C                     KFLD           B5TOKU
     C                     KFLD           B5NONY
     C                     KFLD           B5NKOJ
     C                     KFLD           B5NUKE
     C           K#ABB1    SETLLABBPL02
     C                     MOVEL*OFF      W@FCST  1
     C                     DO   *HIVAL
     C           K#ABB1    READEABBPL02                  96
     C   96                LEAVE
     C                     ADD  Q5NNNM    W@QTY1  90
     C                     ADD  Q5NNNM    W@QTYA  90
     C                     MOVEL*ON       W@FCST
     C                     ENDDO
     C*
     C                     MOVEL*OFF      W@SHP   1
     C           W@FCST    IFEQ *OFF
     C           K#MBD1    KLIST
     C                     KFLD           B5TOKU
     C                     KFLD           B5NONY
     C                     KFLD           B5NKOJ
     C                     KFLD           B5NUKE
     C                     KFLD           L6SHN1
     C                     KFLD           L6SHN2
     C                     KFLD           L6SHN3
     C           K#MBD1    SETLLMBDPL06
     C                     DO   *HIVAL
     C           K#MBD1    READEMBDPL06                  96
     C   96                LEAVE
     C                     ADD  F3TNSU    W@QTY1
     C                     ADD  F3TNSU    W@QTYA
     C                     MOVEL*ON       W@SHP
     C                     ENDDO
     C                     END
     C*
     C           W@FCST    IFEQ *OFF
     C           W@SHP     ANDEQ*OFF
     C                     ITER
     C                     END
     C*
     C           K#PP80    KLIST
     C                     KFLD           B5TOKU
     C                     KFLD           B5NONY
     C                     KFLD           B5NKOJ
     C                     KFLD           B5NUKE
     C           K#PP80    CHAINADAPP80              95
     C           *IN95     IFEQ *OFF
     C           AHSKJY    ANDEQ*BLANK
     C                     ADD  W@QTYA    W@QTY2  90
     C           B5HIZK    IFGT 1
     C           B5HIZK    SUB  1         W@HIZK  20
     C           W@QTYA    MULT W@HIZK    W@CNT1  90
     C           L6SYOS    IFNE *ZERO
     C           W@CNT1    DIV  L6SYOS    W@CNT2  92
     C                     ADD  W@CNT2    W@CNT3  92
     C                     END
     C                     END
     C                     END
     C*
     C                     ENDDO
     C*
     C           L6SYOS    IFNE *ZERO
     C           W@QTY1    DIV  L6SYOS    YWTBX1    H
     C           YWTBX1    DIV  W@DAYS    W@CNT4  92
     C           W@CNT4    ADD  0.09      YWDBX1
     C           W@QTY2    DIV  L6SYOS    YWTBX2    H
     C           YWTBX2    DIV  W@DAYS    W@CNT5  92
     C           W@CNT5    ADD  0.09      YWDBX2
     C                     END
     C*
     C           W@CNT3    DIV  W@DAYS    W@CNT6  91
     C           W@CNT6    ADD  0.9       W@CNT7  90
     C           YWMAX     SUB  W@CNT7    YWCHK1
     C*
     C                     WRITEANYWP111
