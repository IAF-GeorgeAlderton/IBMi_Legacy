     C**************************************************************************
     C           #SET2A    BEGSR
     C*
     C           *LOVAL    SETLLAAHTL06
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AAHTL06                  99
     C   99                LEAVE
     C           L6SKJY    IFNE *BLANK
     C                     ITER
     C                     END
     C           L6STYY    IFNE 9999
     C                     ITER
     C                     END
     C           L6ATK1    IFNE '0'
     C                     ITER
     C                     END
     C*
     C                     CLEARANYWP111
     C*
     C                     MOVEL*BLANK    W@SHIN
     C                     MOVELL6SHN1    W@SHN1
     C           L6SHN2    IFNE *BLANK
     C                     MOVEL'-'       W@SHNA
     C                     END
     C                     MOVELL6SHN2    W@SHN2
     C           L6SHN3    IFNE *BLANK
