     C                     Z-ADDYWDBX1    S2DBX1
     C                     Z-ADDYWTBX2    S2TBX2
     C                     Z-ADDYWDBX2    S2DBX2
     C                     Z-ADDYWCHK1    S2CHK1
     C*
     C                     ADD  1         RRN2
     C                     WRITESFL020
     C*
     C                     ENDDO
     C*
     C           RRN2      IFEQ *ZERO
     C                     SETON                     49
     C                     CLEARSFL020
     C                     Z-ADD1         RRN2
     C                     WRITESFL020
     C                     MOVELERR,1     MSG
     C                     END
     C*
