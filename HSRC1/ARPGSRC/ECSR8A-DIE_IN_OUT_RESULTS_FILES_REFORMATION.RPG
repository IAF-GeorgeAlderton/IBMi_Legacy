     F******************************************** ECSR8A **
     FECSPP80 IP  E                    DISK
     FECSWP8A O   E                    DISK
     FECSWP8B O   E                    DISK
     I            DS
     I                                        1   80J1WIHZ
     I                                        1   40J1WINY
     I                                        5   60J1WINM
     I                                        7   80J1WIND
      *
     C           *ENTRY    PLIST
     C                     PARM           PHIZK   8
     C                     PARM           PRECD   7
     C                     PARM           PKENS   7
     C                     MOVE PHIZK     WHIZK   80
      *
     C                     ADD  1         WRECD   70
      *
     C           J1WIHZ    IFGT WHIZK
     C                     ADD  1         WKENS   70
     C                     WRITEECSWP8A1
     C                     ELSE
     C                     WRITEECSWP8B1
     C                     END
      *
     CLR                   MOVE WRECD     PRECD
     CLR                   MOVE WKENS     PKENS
