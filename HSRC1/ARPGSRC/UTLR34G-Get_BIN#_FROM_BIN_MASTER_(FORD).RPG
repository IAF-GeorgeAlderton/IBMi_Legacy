     H            Y.
     F** UTLR34G********************************************************
     F*  PROGRAM    : UTILITY- GET BIN# FROM BIN MASTER                *
     F*  WRITTEN    : JW (SRA)  2024.11.18                             *
     F*----------------------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR34G'
     F*                    PARM           $NONY   4
     F*                    PARM           $DOCK   4
     F*                    PARM           $BIN#   2
     F*                    PARM           $ROUT   4
     F*
     F*   IN  $NONY   4A  DELIVERY CODE                                *
     F*   "   $DOCK   4A  DOCK                                         *
     F*   OUT $BIN#   2A  BIN#                                         *
     F*   "   $ROUT   4A  ROUTE#                                       *
     F******************************************************************
     FABFDL01 IF  E           K        DISK
     FABFBP10 IF  E           K        DISK
      *------------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------------
      *   MAIN
      *------------------------------------------------------------
     C                     EXSR #INIT
      * READ ROUTE MASTER
     C           K#ADF     SETGTABFDL01R
     C                     DO   *HIVAL
     C           K#ADF     REDPEABFDL01R                 88
     C   88      K#ADF     SETGTABFDL01R
     C   88                LEAVE
      *
     C           QASKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVE QAROUT    @ROUT            GET ROUTE
     C                     LEAVE
     C                     ENDDO
      * GET BIN# FROM ROUTE
     C           @ROUT     CHAINABFBP10              95
     C           *IN95     IFEQ *OFF
     C                     MOVELB1BINN    $BIN#            GET BIN#
     C                     MOVEL@ROUT     $ROUT
     C                     ENDIF
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------------
      * INITIALIZE
      *------------------------------------------------------------
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $NONY   4
     C                     PARM           $DOCK   4
     C                     PARM           $BIN#   2
     C                     PARM           $ROUT   4
      *
     C           K#ADF     KLIST
     C                     KFLD           K@NONY  40
     C                     KFLD           K@DOCK  4
      *
     C                     MOVEL$NONY     K@NONY
     C                     MOVEL$DOCK     K@DOCK
     C                     MOVE '06'      $BIN#
     C                     MOVE '    '    $ROUT
     C                     MOVE *BLANK    @ROUT   4
      *
     C                     ENDSR
