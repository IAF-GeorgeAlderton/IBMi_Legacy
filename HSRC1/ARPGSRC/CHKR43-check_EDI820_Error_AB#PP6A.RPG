     H            Y.
     F***CHKR43*****************************************************************
     F*  PROGRAM    : CHECK EDI820 ERROR                                       *
     F*             : RUN IN FCKC00 (10:10AM BY JOBSCDE)                       *
     F*  ????? NOT SURE WHAT'S THE PURPOSE OF THIS REPORT ???????
     F*  WRITTEN    : 2019.09.30                                               *
     F*  WRITTEN BY : JW (SRA)                                                 *
     F*-----------------------------------------------
     F*  JW1          2023.03.22 ADD MTMUS TO THE TABLE
     F**************************************************************************
     FAB#PL6B IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     E                    ERR     1   5 40
     E                    NAM     1  30  5
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I           SDS
     I                                        1  10 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************************************
     C                     EXSR #INIT
      *
     C           @CRT      SETLLAB#PL6B
     C                     DO   *HIVAL
     C           @CRT      READEAB#PL6B                  98
     C   98                LEAVE
      *
     C           APCNAM    LOKUPNAM                      99
     C           *IN99     IFEQ *OFF
     C                     MOVELERR,1     XMSG
     C                     EXSR #PRINT
     C                     ENDIF
     C                     ENDDO
      *
     C           SEQ#      IFNE 0
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *----------------------------------------------------*
      *  PRINT                                             *
      *----------------------------------------------------*
     C           #PRINT    BEGSR
      *
     C                     MOVELAPMANI    XPMANI 15
      *
     C           LIN#      IFGE 66
     C                     EXCPT@HDR
     C                     Z-ADD3         LIN#
     C                     ENDIF
      *
     C                     ADD  1         SEQ#
     C                     EXCPT@DTL
     C                     ADD  1         LIN#
      *
     C                     ENDSR
      *----------------------------------------------------*
      *  INITIAL SETTING                                   *
      *----------------------------------------------------*
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $RTN    1
      *
     C                     MOVE *BLANK    $RTN
     C                     TIME           SDATE
     C                     Z-ADD0         SEQ#    40
     C                     Z-ADD88        LIN#    30
     C                     MOVE *BLANK    XMSG   40
      *
      * GET PREVIOUS 7 DAYS
     C                     MOVELTODAY     $DT8
     C                     MOVE '-'       $SIGN
     C                     MOVEL'0001'    $DAYS
     C                     MOVE 'Y'       $IAF
     C                     CALL 'UTLR10'
     C                     PARM           $DT8    8
     C                     PARM           $SIGN   1
     C                     PARM           $DAYS   4
     C                     PARM           $IAF    1
     C                     PARM           $TGT8   8
     C                     PARM           $RTN    1
     C                     MOVEL$TGT8     @CRT    80
      *
     C                     ENDSR
      *****************************************************************
     OQPRINT  E   01           @HDR
     O                         #PGM      11
     O                                   40 '** EDI 820 ERROR REP'
     O                                   60 'ORT **              '
     O                                   89 'DATE'
     O                         TODAY     92 '    .  .  '
     O                         NOW      102 '  :  :  '
     O                                  106 'P.'
     O                         PAGE  Z  110
     O        E   03           @HDR
     O                                    5 'SEQ#'
     O                                   14 'CRT_DATE'
     O                                   22 'TIME'
     O                                   28 'ID'
     O                                   37 'MANI#'
     O                                   61 'QTY'
     O                                   67 'PART1'
     O                                   73 'PART2'
     O                                   78 'SIRE'
     O                                  101 '____ERROR MSG_______'
     O        E 1              @DTL
     O                         SEQ#  1 +000
     O                         APPRDT  +001 '    /  /  '
     O                         APPRTM  +001 '0 :  :  '
     O                         APCNAM  +001
     O                         XPMANI  +001
     O                         APIQTY1 +001
     O                         APPAR1  +001
     O                         APPAR2  +001
     O                         APSIRE  +001
     O                         XMSG    +002
** ERR   1.........2.........3.........4
ID NOT FOUND !




