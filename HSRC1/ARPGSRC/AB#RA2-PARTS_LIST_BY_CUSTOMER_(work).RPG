     FAB#PWA2 CF  E                    WORKSTN
     FMBDPL02 IF  E           K        DISK
     FAB#PL01 IF  E           K        DISK
     FAB#PL07 IF  E           K        DISK
     FAB#WPA2 O   E           K        DISK                      A
      *-----------------------------------------------------------
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *-----------------------------------------------------------
     C                     EXSR #SCRN1
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-----------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@ID    1
      *
     C           K#MBD     KLIST
     C                     KFLD           K@TOKU
     C                     KFLD           D@NONY
      *
     C                     ENDSR
      *-----------------------------------------------------------
     C           #SCRN1    BEGSR
      *-----------------------------------------------------------
     C           *INKA     DOUEQ*ON
     C                     EXFMTDSP01
      *
     C                     SELEC
      * F1: END
     C           *INKA     WHEQ *ON
     C                     MOVE '9'       P@ID
      * F5 OR ENTR
     C                     OTHER
     C                     EXSR #CHK
      * F5: PRINT
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #OUT
     C                     MOVE *ON       *INKA
     C                     ENDIF
      * F7: DOWNLOAD
     C           *IN99     IFEQ *OFF
     C           *INKG     ANDEQ*ON
     C                     EXSR #OUT
     C                     CALL 'AB#CA3B'
     C                     MOVE *ON       *INKA
     C                     MOVE '9'       P@ID
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDDO
      *
     C                     ENDSR
      *-----------------------------------------------------------
     C           #CHK      BEGSR
      *
     C                     MOVEA'00'      *IN,61
     C                     MOVE *OFF      *IN99
     C           D@NONY    IFNE *ZERO
     C           D@NONY    CHAINAB#PL07              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6199
     C                     ELSE
     C                     MOVE B1TOKU    K@TOKU  40
     C                     ENDIF
     C                     ENDIF
      *
     C           D@CUST    IFNE *ZERO
     C           D@CUST    CHAINAB#PL01              90
     C           *IN90     IFEQ *ON
     C                     SETON                     6299
     C                     ENDIF
     C                     ENDIF
      *
     C           D@CUST    IFEQ *ZERO
     C           D@NONY    ANDEQ*ZERO
     C                     SETON                     626199
     C                     ENDIF
      *
     C                     ENDSR
      *-----------------------------------------------------------
     C           #OUT      BEGSR
      *
     C           D@NONY    IFNE *ZERO
     C           K#MBD     SETLLMBDPL02
     C                     MOVE '2'       P@ID
     C                     ELSE
     C           D@CUST    SETLLMBDPL02
     C                     MOVE '1'       P@ID
     C                     ENDIF
      *
     C           *IN90     DOUEQ*ON
     C           D@NONY    IFNE *ZERO
     C           K#MBD     READEMBDPL02                  90
     C                     ELSE
     C           D@CUST    READEMBDPL02                  90
     C                     ENDIF
     C           *IN90     IFEQ *OFF
     C           F3SKJY    ANDEQ*BLANK
     C                     WRITEAB#WPA21
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
