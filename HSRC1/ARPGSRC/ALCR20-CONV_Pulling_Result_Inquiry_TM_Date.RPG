     C                     SETON                     3249
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,1     MSG
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
      *  check to time is valid
     C           F1TOTM    IFGT 2359
     C                     SETON                     3549
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,5     MSG
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
      *  DATE FROM > TO ?
     C           W1SCFH    IFGT W1SCTH
     C                     SETON                     313249
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,2     MSG
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C           F1TOTM    IFEQ *ZERO
     C                     Z-ADD2359      F1TOTM
     C                     ENDIF
      *
      *  DATE/TIME FROM > TO DATE/TIME  ?
     C           F1FROM    IFGT F1TO
     C                     SETON                     313249
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,2     MSG
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
JW1   *  SECTION
 |   C           XSECT     IFNE *BLANK
 |   C           XSECT     ANDNE'CV'
 |   C           XSECT     ANDNE'OQ'
 |   C           XSECT     ANDNE'HR'
 |   C                     SETON                     33  49
 |   C           MSG       IFEQ *BLANK
 |   C                     MOVELERR,4     MSG
 |   C                     LEAVE
 |   C                     ENDIF
JW1  C                     ENDIF
