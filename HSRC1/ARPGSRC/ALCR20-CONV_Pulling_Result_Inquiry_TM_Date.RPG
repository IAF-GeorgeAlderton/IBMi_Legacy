     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
     C                     Z-ADDF1SCFH    W1SCFH
     C                     Z-ADDF1SCFH    CHKAHZ
      *
      *  check from date is valid
     C           K#AGDA    CHAINAGDPL12              50
     C           *IN50     IFEQ *ON
     C                     SETON                     3149
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,1     MSG
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
      *
      *  check from time is valid
     C           F1FRTM    IFGT 2359
     C                     SETON                     3449
     C           MSG       IFEQ *BLANK
     C                     MOVELERR,5     MSG
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C* DATE TO
     C           F1SCTH    IFEQ *ZERO
