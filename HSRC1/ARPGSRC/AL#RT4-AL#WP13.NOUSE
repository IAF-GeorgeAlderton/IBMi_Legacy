     H            Y.
     F** AL#RT4  *******************************************
     F*  AL#WP13                                           *
     F*      ITS.        2015.05.20                        *
     F******************************************************
     FAL#WP11 IF  E           K        DISK
     FAL#WP12 IF  E           K        DISK
     FAL#WP13 O   E                    DISK                      A
     E                    IB        999  3
     E                    CT        999  8 0
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60STIME
     I                                        7  140SDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
      *-----------------------------------------------------
      *  MAIN ROUTINE
      *-----------------------------------------------------
     C                     TIME           WTIME
      *
     C           *HIVAL    SETGTAL#WP111
     C                     READPAL#WP111                 81
     C           *IN81     DOWEQ'0'
     C                     EXSR #SB399
     C                     EXSR #SB400
     C**********           READPAL#WP111                 81
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *-----------------------------------------------------
      *ＩＡＦ便をテーブルに格納
      *-----------------------------------------------------
     CSR         #SB399    BEGSR
      *
     C           KEYW2     KLIST
     C                     KFLD           W1SHID
     C                     KFLD           W1TRKB
     C                     KFLD           W1SURT
     C                     CLEARIB
     C                     CLEARCT
     C                     Z-ADD0         X       40
     C           KEYW2     SETGTAL#WP121
     C           KEYW2     REDPEAL#WP121                 82
     C           *IN82     DOWEQ'0'
     C                     ADD  1         X
     C                     MOVELW2IAFB    IB,X
     C                     Z-ADDW2KPLT    CT,X
     C           KEYW2     REDPEAL#WP121                 82
     C                     ENDDO
      *ＩＡＦ便の数
     C                     Z-ADDX         MAX     40
      *
     CSR         ESB399    ENDSR
      *-----------------------------------------------------
      *ＩＡＦ便をセットしてワーク作成
      *-----------------------------------------------------
     CSR         #SB400    BEGSR
      *
     C                     Z-ADD0         X
     C                     MOVEL'ADD'     COND    3
     C                     MOVELW1SHID    SVSHID  8
     C                     MOVELW1NONY    SVNONY  40
     C                     MOVELW1NKOJ    SVNKOJ  1
     C                     MOVELW1NUKE    SVNUKE  4
     C                     MOVELW1ORD#    SVORD# 12
     C                     MOVELW1TRKB    SVTRKB  2
     C                     MOVELW1SURT    SVSURT  9
      *
     C           *IN81     DOWEQ'0'
     C           W1SHID    ANDEQSVSHID
     C***        W1NONY    ANDEQSVNONY
     C***        W1NKOJ    ANDEQSVNKOJ
     C***        W1NUKE    ANDEQSVNUKE
     C***        W1ORD#    ANDEQSVORD#
     C           W1TRKB    ANDEQSVTRKB
     C           W1SURT    ANDEQSVSURT
     C                     EXSR #SB510
     C                     EXSR #SB500
     C                     READPAL#WP111                 81
     C                     ENDDO
      *
     CSR         ESB400    ENDSR
      *-----------------------------------------------------
      * AL#WP13
      *-----------------------------------------------------
     CSR         #SB500    BEGSR
      *
     C                     CLEARAL#WP131
     C                     MOVELW1SHID    W3SHID
     C                     MOVELW1SHIT    W3SHIT
     C                     MOVELW1NONY    W3NONY
     C                     MOVELW1NKOJ    W3NKOJ
     C                     MOVELW1NUKE    W3NUKE
     C                     MOVELW1ORD#    W3ORD#
     C                     MOVELW1SURT    W3SURT
     C                     MOVELW1EXTR    W3EXTR
     C                     MOVELW1PALT    W3PALT
     C                     Z-ADDW1BOX     W3BOX
     C                     MOVELW1TRKB    W3TRKB
     C                     MOVELWKIAFB    W3IAFB
     C                     WRITEAL#WP131
      *
     CSR         ESB500    ENDSR
      *-----------------------------------------------------
      *ＩＡＦ便のセット
      *-----------------------------------------------------
     CSR         #SB510    BEGSR
      *
     C                     Z-ADD0         LOOP    50
     C                     MOVEL*BLANK    WKIAFB  3
     C           WKIAFB    DOWEQ*BLANK
     C           LOOP      ANDLE999
     C                     EXSR #SB511
     C                     ADD  1         LOOP
     C                     ENDDO
      *
     C           WKIAFB    IFEQ *BLANK
     C                     ENDIF
      *
     CSR         ESB510    ENDSR
      *-----------------------------------------------------
      * AL#WP13
      *-----------------------------------------------------
     CSR         #SB511    BEGSR
      *
     C                     SELEC
      *
     C           COND      WHEQ 'SUB'
     C           X         IFEQ 1
     C                     MOVEL'ADD'     COND
     C                     ELSE
     C                     SUB  1         X
     C                     ENDIF
      *
     C           COND      WHEQ 'ADD'
     C           X         IFEQ MAX
     C                     MOVEL'SUB'     COND
     C                     ELSE
     C                     ADD  1         X
     C                     ENDIF
      *
     C                     ENDSL
      *
     C           CT,X      IFGT 0
     C                     MOVELIB,X      WKIAFB  3
     C                     SUB  1         CT,X
     C                     ENDIF
      *
     CSR         ESB511    ENDSR
