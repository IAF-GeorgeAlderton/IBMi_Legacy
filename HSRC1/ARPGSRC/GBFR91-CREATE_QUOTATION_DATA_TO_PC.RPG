     C           #CHK      BEGSR
      *
     C                     SETOF                     9961
     C           D@CUST    CHAINGBFPL51              90
     C           *IN90     IFEQ *ON
     C                     SETON                     9961
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   WRITE
      *------------------------------------------------------
     C           #WRT      BEGSR
      *
     C           D@CUST    SETLLGBFPL51
      *
     C           *IN80     DOUEQ*ON
     C           D@CUST    READEGBFPL51                  80
     C           *IN80     IFEQ *OFF
      *
     C                     Z-ADD*ZERO     PFX
     C                     MOVE *BLANK    PRX
     C           1         DO   10        Y       20
     C           PRC,Y     IFNE *BLANK
     C                     Z-ADD1         X       20
     C           PRC,Y     LOKUPPRW,X                    10
     C           *IN10     IFEQ *OFF
     C                     ADD  1         P
     C                     MOVE PRC,Y     PRW,P
     C                     Z-ADDP         X
     C                     ENDIF
     C                     MOVE PRC,Y     PRX,X
     C                     Z-ADDPFG,Y     PFX,X
     C                     ENDIF
     C                     ENDDO
