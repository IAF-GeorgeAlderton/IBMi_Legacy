     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#KEY     KLIST
     C                     KFLD           G9TOKU
     C                     KFLD           G9MHN1
     C                     KFLD           G9MHN2
     C                     KFLD           G9MHN3
     C                     KFLD           G9MHN4
