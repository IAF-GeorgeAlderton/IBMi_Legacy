     C                     RETRN
      *
      *
     C*---------------------------------------*
     C*   サブルーチン                      *
     C*   積載量パーセント計算サブルーチン  *
     C*---------------------------------------*
     C           KSAN      BEGSR
     C                     Z-ADD0         WBMON   40
     C                     MOVE *BLANK    WKCD1   1
     C                     MOVE *BLANK    WSW1
      *
     C           CBKDAI    IFEQ '0'
     C                     Z-ADD8907      WBMON
     C                     ELSE
      *
     C           KEYM1     SETLLACAPL111
      *
     C                     DO   *HIVAL
     C                     SETOF                     30
     C           KEYM1     READEACAPL111                 30
     C           *IN30     IFEQ '0'
     C           I1SKJY    IFEQ 'D'
     C           I1SKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     SETON                     30
     C                     MOVE '*'       WSW1
     C                     Z-ADDI1BMON    WBMON
     C                     MOVE I1KCD1    WKCD1
      *
     C                     END
     C                     END
     C  N30                END
      *
     C           WSW1      IFEQ *BLANK
     C                     Z-ADD8990      WBMON
     C                     ELSE
      *
     C                     SETOF                     31
     C           KEYM2     CHAINACAPL111             31
     C           *IN31     IFEQ '0'
     C           I1SKJY    ANDEQ'D'
     C           I1SKHZ    ANDLE*DATE
     C                     SETON                     31
     C                     END
     C           *IN31     IFEQ '0'
     C                     Z-ADDI1BMON    WBMON
     C                     ELSE
      *
     C           WBMON     IFEQ 8907
     C           WKCD1     IFNE '0'
     C                     Z-ADD8990      WBMON
     C                     END
     C                     END
     C                     END
     C                     END
     C                     END
      *
     C                     SETOF                     04
     C           WBMON     CHAINAAIPL111             04
     C           *IN04     CABEQ'1'       EXIT
      *
     C                     Z-ADD1         I       20
     C           1         DO   CDCIBI    I
     C                     SETOF                     05
     C           KEYB      CHAINAAVPL111             05
     C           *IN05     CABEQ'1'       STEP11
     C           CGMCBK    CABEQ0         STEP11
      *
     C           TP,I      DIV  CGMCBK    TOJIP   32H
     C           FP,I      DIV  CGMCBK    FOJIP   32H
     C           CP,I      DIV  CGMCBK    COJIP   32H
     C           YP,I      DIV  CGMCBK    YOJIP   32H
      *
     C           TOJIP     MULT 100       TJP,I
     C           FOJIP     MULT 100       FJP,I
     C           COJIP     MULT 100       CJP,I
     C           YOJIP     MULT 100       YJP,I
      *
     C           STEP11    TAG
     C                     END
     C           EXIT      TAG
     C                     ENDSR
      *
      *
     C*----------------------------*
     C*     ..サブルーチン..     *
     C*  ..箱数＝Ｃ箱比率計算..  *
     C*----------------------------*
     C           SUBRC     BEGSR
      *
     C*----------------------------------*
     C*  ..社内かんばん切替マスター..  *
     C*----------------------------------*
     C                     SETOF                     10
     C                     MOVE *BLANK    WTKRO
     C                     MOVE *BLANK    WKDAI   1
     C           KEY3      CHAINAAMPL111             10
     C           *IN10     IFEQ '0'
     C           CKSKJY    ANDEQ'D'
     C           CKSKHZ    ANDLE*DATE
     C                     SETON                     10
     C                     END
     C           *IN10     IFEQ '0'
      *
     C                     Z-ADD16        A       20
     C                     Z-ADD1         B       20
     C           1         DO   15        B
     C                     SETOF                     11
     C           A         SUB  B         Z       20
     C                     MOVELCKHZ,Z    CYMD    80
     C           CYMD      IFGT *DATE
     C           CKQR,Z    IFEQ 'C'
     C           CKQR,Z    OREQ 'D'
     C           CKQR,Z    OREQ 'E'
     C                     SETON                     11
     C                     MOVE CKQR,Z    WKDAI
     C                     MOVE CKQT,Z    WTKRO
     C                     END
     C                     ELSE
      *
     C           CKKR,Z    IFEQ 'C'
     C           CKKR,Z    OREQ 'D'
     C           CKKR,Z    OREQ 'E'
     C                     SETON                     11
     C                     MOVE CKKR,Z    WKDAI
     C                     MOVE CKNB,Z    WTKRO
     C                     END
     C                     END
     C  N11                END
     C                     END
      *
     C                     Z-ADD0         WCBKO   20       Cﾌﾞﾃﾍﾒl
      *
     C*--------------------------------*
     C*  ..メッキかんばんマスター..  *
     C*--------------------------------*
      *
     C           WKDAI     IFEQ 'C'
     C           KEY4      SETGTAAFPL031
     C                     DO   *HIVAL
     C                     SETOF                     12
     C           KEY4      REDPEAAFPL031                 12
     C           *IN12     IFEQ '0'
     C           A3SKJY    IFEQ 'D'
     C           A3SKHZ    ANDLE*DATE
     C                     ELSE
     C           A3UKHZ    IFLE *DATE
     C           A3STHZ    ANDGT*DATE
     C                     SETON                     12
      *
     C                     Z-ADDA3CBKO    WCBKO            Cﾌﾞﾃﾍﾒl
      *
     C                     END
     C                     END
     C                     END
     C  N12                END
     C                     ELSE
      *
     C*----------------------------------*
     C*  ..トンネルかんばんマスター..  *
     C*----------------------------------*
     C           WKDAI     IFEQ 'D'
     C           KEY4      SETGTAAGPL031
     C                     DO   *HIVAL
     C                     SETOF                     12
     C           KEY4      REDPEAAGPL031                 12
     C           *IN12     IFEQ '0'
     C           O4SKJY    IFEQ 'D'
     C           O4SKHZ    ANDLE*DATE
     C                     ELSE
     C           O4UKHZ    IFLE *DATE
     C           O4STHZ    ANDGT*DATE
     C                     SETON                     12
      *
     C                     Z-ADDO4CBKO    WCBKO            Cﾌﾞﾃﾍﾒl
     C                     END
     C                     END
     C                     END
     C  N12                END
     C                     ELSE
      *
     C*------------------------------*
     C*  ..引取かんばんマスター..  *
     C*------------------------------*
     C                     Z-ADD1         WCBKO            Cﾌﾞﾃﾍﾒl
     C                     END
     C                     END
      *
     C                     ENDSR
**  TYT (TITLE )
LVL PROD FIX ODR F ACNT BOOK
**  MSG (ERROR MESSAGE )
E-01 INPUT SECTION CODE
E-02 SECTION CODE ISN'T RIGHT
E-03 RANGE OF  PART NO ISN'T RIGHT
E-04 LEVEL PROD FIXED ODRING FILE IS NO MORE DATA FOLLOWING
