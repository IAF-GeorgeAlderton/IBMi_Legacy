     H            Y.
      ** UEXR55 ****************************************************
      *  CREATE AB#EP61 AND AB#EP62 BY PACKING LIST#               *
      *  JW     2024.12.11                                         *
      **************************************************************
      *  CALLING SEQ.
      *                    CALL 'UEXR55 '
      *                    PARM           $BARC   9
      *                    PARM           $SHID  10
      * IN   $BARC    9A  PACKING LIST#
      * IN   $SHID   10A  EDI ID#
      *==========================================================
     FAB#XL01DIF  E           K        DISK
     FAB#EP61 O   E                    DISK
     FAB#EP62 O   E                    DISK
      *==========================================================
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   80EKKOHZ
     I                                        1   40EKKOYY
     I                                        5   60EKKOMM
     I                                        7   80EKKODD
     I            DS
     I                                        1   40EKKOTM
     I                                        1   20EKKOHH
     I                                        3   40EKKOMN
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *==========================================================
      ** MAIN ROUTINE
      *==========================================================
     C                     EXSR #INIT
      * GET LATEST MASTER#
     C                     EXSR #MAST
      *
      * OUTPUT EP61
     C                     EXSR #EP61
      *
      * OUTPUT EP62
     C                     EXSR #EP62
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *==========================================================
      ** GET FIRST MASTER# FROM XP01A
      *==========================================================
     C           #MAST     BEGSR
      *
     C                     MOVE *BLANK    XMAST1 18        FIRST MASTER#
     C                     MOVE *BLANK    K#SERL
     C           KEY1      SETLLAB#XL01D
     C                     DO   *HIVAL
     C           KEY1X     READEAB#XL01D                 98
     C   98                LEAVE
      *
     C                     MOVELIXSERL    XMAST1
     C                     MOVELIXNONY    XNONY   4
     C                     LEAVE
      *
     C                     ENDDO
      *
     C                     ENDSR
      *==========================================================
      ** OUTPUT AB#EP61
      *==========================================================
     C           #EP61     BEGSR
      *
     C                     MOVELXMAST1    K#SERL
     C           KEY1      SETLLAB#XL01D
     C                     DO   *HIVAL
     C           KEY1X     READEAB#XL01D                 98
     C   98                LEAVE
      *
     C                     CLEARAB#EP611
     C                     MOVEL$SHID     E2SHID
     C                     MOVELXNONY     E2PRTN
      *
     C                     MOVE IXSERL    LTR10  10
     C                     MOVELLTR10     E2MAN#    P
     C                     MOVE *BLANK    E2BLN#
     C                     MOVELLTR10     E2INVN    P
     C                     MOVELIXODRN    E2ORDN
     C                     MOVE *BLANK    E2SUPL
     C                     Z-ADD0         E2DEHZ
     C                     Z-ADD1         E2#LOD
     C                     Z-ADD1         E2#UNT
     C                     MOVE *BLANK    E2PKCD
      * MASTER LABEL
     C           E2PRTN    IFEQ '5426'                     TSUSHO
     C                     MOVELLTR10     E2SERL    P
     C                     ELSE
     C                     MOVELIXSERL    E2SERL
     C                     ENDIF
      *
     C                     WRITEAB#EP611
      *
     C                     ENDDO
      *
     C                     ENDSR
      *==========================================================
      ** OUTPUT AB#EP62
      *==========================================================
     C           #EP62     BEGSR
      *
     C                     MOVELXMAST1    K#SERL
     C           KEY1      SETLLAB#XL01D
     C                     DO   *HIVAL
     C           KEY1X     READEAB#XL01D                 98
     C   98                LEAVE
      *
     C                     CLEARAB#EP621
     C                     MOVEL$SHID     E3SHID
     C                     MOVELXNONY     E3PRTN
     C                     MOVE IXSERL    LTR10
     C                     MOVELLTR10     E3MAN#    P
     C                     MOVE '0000'    E3SBAN
     C                     Z-ADDIXSYOS    E3SYOS
     C                     Z-ADDIXSRYO    E3SRYO
     C                     Z-ADDIXSRYO    E3ORQY
     C                     MOVELIXMHIN    E3MHIN
     C                     MOVE *BLANK    E3RLS#
     C                     MOVE *BLANK    E3RLLN
     C                     MOVE *BLANK    E3RESE
     C                     MOVE *BLANK    E3DEHZ
     C                     MOVE *BLANK    E3RVSN
     C                     MOVE *BLANK    E3PGID
      * PRICE
     C                     MOVELIXTOKU    PTOKU
     C                     MOVELIXNONY    PNONY
     C                     MOVELIXNKOJ    PNKOJ
     C                     MOVELIXNUKE    PNUKE
     C                     MOVELIXMHIN    PMHIN
     C                     MOVELIXDEDT    PNOHZ8
     C                     CALL 'FBCR10'
     C                     PARM           PTOKU   4        IN
     C                     PARM           PNONY   4        "
     C                     PARM           PNKOJ   1        "
     C                     PARM           PNUKE   4        "
     C                     PARM           PMHIN  20        "
     C                     PARM           PNOHZ8  8        "
     C                     PARM           PTANK  105       OUT
     C                     PARM           PCHEK   1        "
     C                     Z-ADDPTANK     E3TANK
      *
     C                     MOVELIXODRN    E3ORDN
      *
     C                     Z-ADDTODAY     E1DATE
     C                     Z-ADDNOW       E1TIME
     C                     Z-ADDIXDEDT    E1NOHZ
     C                     MOVELIXNOBN    E1NBIN
     C                     Z-ADD0         E1NOTM
     C                     MOVELLTR10     E1INVN    P
     C                     MOVELIXODRN    E1ORDN
     C                     MOVE *BLANK    E1TRCK
     C                     Z-ADD0         ETPLT
     C                     Z-ADDIXFIL3    ETBOX
     C                     MOVE *BLANK    ETRMD
     C                     Z-ADD0         ETWHT
     C                     MOVE *BLANK    ESCAC
     C                     Z-ADD0         ETNET
      *
     C                     MOVE *BLANK    E3ECL
     C                     MOVE *BLANK    E3DESC
     C                     MOVELIXSHIN    E3SHIN
     C                     Z-ADD0         E3POL#
     C                     Z-ADDIXSRYO    E3CRYO
     C                     Z-ADD0         E3PODT
     C                     WRITEAB#EP621
      *
     C                     ENDDO
      *
     C                     ENDSR
      *==========================================================
      ** INITIAL SETTINGS
      *==========================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $PL#    9        IN
     C                     PARM           $SHID  10        IN
      *
     C           KEY1      KLIST
     C                     KFLD           K#PL#   9
     C                     KFLD           K#WRKF 10
     C                     KFLD           K#SERL 18
      *
     C           KEY1X     KLIST
     C                     KFLD           K#PL#
     C                     KFLD           K#WRKF
      *
     C                     TIME           SDATE
     C                     MOVEL$PL#      K#PL#
     C                     MOVEL'AB#WP2O' K#WRKF    P
     C                     MOVE *BLANK    K#SERL
      *
     C                     ENDSR
