     C                     Z-ADD@2EMM     FBTSMM
     C                     Z-ADD@2EDD     FBTSDD
      *
     C                     MOVE @MHN1     WMHN1
     C                     MOVE @MHN2     WMHN2
     C                     MOVE @MHN3     WMHN3
     C                     MOVE @MHN4     WMHN4
      *
     C                     MOVELFBTOKU    PTOKU   4
     C                     MOVELFBNONY    PNONY   4
     C                     MOVELFBNKOJ    PNKOJ   1
     C                     MOVELFBNUKE    PNUKE   4
     C                     MOVELWKMHIN    PMHIN  20
     C                     MOVEL*BLANK    PSHIN  12
     C                     MOVEL*BLANK    @FLG    1
      *
     C                     CALL 'BBHR50'
     C                     PARM           PTOKU   4
     C                     PARM           PNONY   4
     C                     PARM           PNKOJ   1
     C                     PARM           PNUKE   4
     C                     PARM           PMHIN  20
     C                     PARM           PSHIN  12
     C                     PARM           @FLG    1
      *
     C                     MOVE PSHIN     FBSHIN
      *
JW   C           FBIND     IFEQ *BLANK
JW   C                     MOVE 'N'       FBIND
JW   C                     ENDIF
      *
     C                     WRITEFBCPL031
JW1   * OUT LOG#
"    C                     MOVE 'A'       LOGFLG  1
"    C                     EXSR #LOG
      *
     C                     ENDIF
     C                     ENDDO
      *
     CSR         $S500E    ENDSR
      *----------------------------------------------------*
      *  DETAIL M/F FILE READ                              *
      *----------------------------------------------------*
     CSR         $SB900    BEGSR
     C                     SETOF                       21
     C           KEYB21    CHAINFGBPL011             21
     C           *IN21     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLEHYMD8
     C                     SETON                     21
     C                     END
     CSR         $S900E    ENDSR
      *----------------------------------------------------*
      *  CALECNDER  CHECK                                  *
      *----------------------------------------------------*
     CSR         $SB901    BEGSR
     C                     SETOF                     21
TCHK1C*
TCHK1C           #KHMM     IFLT 01
TCHK1C           #KHMM     ORGT 12
TCHK1C                     SETON                     21
TCHK1C                     GOTO $S901E
TCHK1C                     END
TCHK1C           #KHDD     IFGT 31
TCHK1C                     SETON                     21
TCHK1C                     GOTO $S901E
TCHK1C                     END
TCHK1C*
     C           #KHMM     IFEQ 01
     C           #KHMM     OREQ 03
     C           #KHMM     OREQ 05
     C           #KHMM     OREQ 07
     C           #KHMM     OREQ 08
     C           #KHMM     OREQ 10
     C           #KHMM     OREQ 12
     C           #KHDD     IFGT 31
     C                     SETON                     21
     C                     GOTO $S901E
     C                     END
     C                     END
     C           #KHMM     IFEQ 04
     C           #KHMM     OREQ 06
     C           #KHMM     OREQ 09
     C           #KHMM     OREQ 11
     C           #KHDD     IFGT 30
     C                     SETON                     21
     C                     GOTO $S901E
     C                     END
     C                     END
      *
     C                     Z-ADD0         WHD
     C                     Z-ADD0         URU
     C                     Z-ADD0         AMA
     C                     Z-ADD0         URU1
     C                     Z-ADD0         AMA1
     C                     Z-ADD0         URU2
     C                     Z-ADD0         AMA2
     C           #KHMM     IFEQ 02
     C                     Z-ADD28        WHD
     C           #KHYY     DIV  4         URU     40
     C                     MVR            AMA     40
     C           AMA       IFEQ 0
     C                     Z-ADD29        WHD
     C           #KHYY     DIV  100       URU1    40
     C                     MVR            AMA1    40
     C           #KHYY     DIV  400       URU2    40
     C                     MVR            AMA2    40
      *
     C           AMA1      IFEQ 0
     C           AMA2      ANDNE0
     C                     Z-ADD28        WHD
     C                     END
      *
     C                     END
     C           #KHDD     IFGT WHD
     C                     SETON                       21
     C                     GOTO $S901E
     C                     END
      *
     C                     END
     CSR         $S901E    ENDSR
      *----------------------------------------------------*
      *  DATE CALCULATION                                  *
      *----------------------------------------------------*
     CSR         $SB910    BEGSR
     C                     Z-ADD#KHYY     WHY     40
     C                     Z-ADD#KHMM     WHM     20
TCHK1C*                    Z-ADD#KHYY     WHD     20
TCHK1C                     Z-ADD#KHDD     WHD     20
     C           #KHDD     SUB  1         WHD
      *
     C           WHD       IFEQ 0
     C           #KHMM     SUB  1         WHM
     C                     END
      *
     C           WHM       IFEQ 0
     C           #KHYY     SUB  1         WHY
     C                     END
      *
     C           WHM       IFEQ 0
     C                     Z-ADD12        WHM
     C                     END
      *
     C           WHD       IFEQ 0
      *
     C           WHM       IFEQ 01
     C           WHM       OREQ 03
     C           WHM       OREQ 05
     C           WHM       OREQ 07
     C           WHM       OREQ 08
     C           WHM       OREQ 10
     C           WHM       OREQ 12
     C                     Z-ADD31        WHD
     C                     END
      *
     C           WHM       IFEQ 04
     C           WHM       OREQ 06
     C           WHM       OREQ 09
     C           WHM       OREQ 11
     C                     Z-ADD30        WHD
     C                     END
      *
     C           WHM       IFEQ 02
     C                     Z-ADD28        WHD
     C           WHY       DIV  4         URU     40
     C                     MVR            AMA     40
     C           AMA       IFEQ 0
     C                     Z-ADD29        WHD
     C           WHY       DIV  100       URU1    40
     C                     MVR            AMA1    40
     C           WHY       DIV  400       URU2    40
     C                     MVR            AMA2    40
      *
     C           AMA1      IFEQ 0
     C           AMA2      ANDNE0
     C                     Z-ADD28        WHD
     C                     END
      *
     C                     END
     C                     END
      *
     C                     END
      *
     CSR         $S910E    ENDSR
