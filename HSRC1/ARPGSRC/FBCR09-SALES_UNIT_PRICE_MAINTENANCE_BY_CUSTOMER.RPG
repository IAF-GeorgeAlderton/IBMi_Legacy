     C           $SB600    BEGSR
      * AB#PP01
     C           K#APP     SETLLAB#PL09
     C           *IN90     DOUEQ*ON
     C           K#APX     READEAB#PL09                  90
     C           *IN90     IFEQ *OFF
     C           B1SKJY    ANDEQ*BLANK
     C           B1TOKU    ANDEQ#KTOKU
TCHK1C*          B1NONY    ANDEQ#KNONY
TCHK1C           B1NONY    LOKUPNON                      91
TCHK1C  N91                ITER
      *
     C*****      @NUKE     IFNE *BLANK
     C*          B1NUKE    ANDNE@NUKE
     C*                    ITER
     C*****                ENDIF
      *
     C           B1NOHZ    IFGT @2EYMD
