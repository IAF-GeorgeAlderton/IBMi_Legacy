     H            Y/
     F***************************************************
     F*  UPDATE MONTHLY INVENTORY                       *
     F*        IMPORT COMPONENT PART                    *
     F*                                                 *
     F*                                                 *
     F***************************************************
     FAZAPW30 CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     F                                              KINFDS @INFDS
     FAKBPL08 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FAZAPL50 UF  E           K        DISK                      A
     FAZAPP51 UF  E           K        DISK                      A
      *------------------------------------------------------------
     E                    CMD     1   2 78
      *------------------------------------------------------------
     I@INFDS      DS
     I                                    B 378 3790@@REC
     I            DS
     I                                        1   60D@YYMM
     I                                        1   40D@YY
     I                                        5   60D@MM
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *------------------------------------------------------
      *  MAIN ROUTINE
      *------------------------------------------------------
     C           W@ID      DOWNE'99'
     C           W@ID      CASEQ'01'      #DSP01
     C           W@ID      CASEQ'02'      #DSP02
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *------------------------------------------------------
      *  INITIALIZE
      *------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#AKB     KLIST
     C                     KFLD           D@LOC1
     C                     KFLD           D@LOC2
     C                     KFLD           D@LOC3
     C                     KFLD           D@LOC4
     C           K#AZA     KLIST
     C                     KFLD           D@YYMM
     C                     KFLD           S@LOC1
     C                     KFLD           S@LOC2
     C                     KFLD           S@LOC3
     C                     KFLD           S@LOC4
     C                     KFLD           S@PRT1
     C                     KFLD           S@PRT2
     C                     KFLD           S@PRT3
     C           K#AGD     KLIST
     C                     KFLD           D@YY
     C                     KFLD           D@MM
     C           K#AZ5     KLIST
     C                     KFLD           S@PRT1
     C                     KFLD           S@PRT2
     C                     KFLD           S@PRT3
      *
     C           *YEAR     MULT 100       D@YYMM
     C                     ADD  *MONTH    D@YYMM
      *
     C                     Z-ADD*ZERO     RRN1    40
     C                     Z-ADD*ZERO     @@RRN   40
     C                     MOVEL'01'      W@ID    2
      *
     C                     ENDSR
      *------------------------------------------------------
      *   1ST SCREEN
      *------------------------------------------------------
     C           #DSP01    BEGSR
      *
     C                     MOVELCMD,1     D@CMD
     C                     WRITEDSP99
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK1
     C           *IN99     IFEQ *OFF
     C                     MOVEL'02'      W@ID
     C                     EXSR #SET
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CHECK
      *------------------------------------------------------
     C           #CHK1     BEGSR
      *
     C                     EXSR #CLR
     C           D@YYMM    IFEQ *ZERO
     C                     MOVE *ON       *IN61
     C                     MOVE *ON       *IN99
     C                     ELSE
     C           K#AGD     CHAINAGDPL12              90
     C           *IN90     IFEQ *ON
     C                     MOVE *ON       *IN61
     C                     MOVE *ON       *IN99
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   CLEAR
      *------------------------------------------------------
     C           #CLR      BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     MOVEA'00000000'*IN,60
     C                     MOVE *BLANK    D@MSG
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR 2ND SCREEN
      *------------------------------------------------------
     C           #SET      BEGSR
      *
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1
     C                     Z-ADD*ZERO     @@RRN
     C           K#AKB     SETLLAKBPL08
      *
     C                     EXSR #SET1
      *
     C           RRN1      IFEQ 0
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     Z-ADD0         #RCNO
     C                     ENDIF
      *
     C                     ENDSR
      *------------------------------------------------------
      *   SET DATA FOR 2ND SCREEN
      *------------------------------------------------------
     C           #SET1     BEGSR
      *
     C                     Z-ADD*ZERO     W@C     10
     C           *IN80     DOUEQ*ON
     C                     READ AKBPL08                  80
     C           *IN80     IFEQ *OFF
     C           L1SKJY    IFNE *BLANK
     C                     ITER
     C                     ENDIF
     C           L1STYY    IFNE 9999
     C                     ITER
     C                     ENDIF
      *
     C                     CLEARSFL01
      *
     C                     MOVE L1TKR1    S@LOC1
     C                     MOVE L1TKR2    S@LOC2
     C                     MOVE L1TKR3    S@LOC3
     C                     MOVE L1TKR4    S@LOC4
     C                     MOVE L1SHN1    S@PRT1
     C                     MOVE L1SHN2    S@PRT2
     C                     MOVE L1SHN3    S@PRT3
     C                     Z-ADDL1SYOS    S@QTBX
     C           K#AZA     CHAINAZAPL50             N90
     C           *IN90     IFEQ *OFF
     C                     Z-ADDZ5BOXQ    S@INVQ
     C                     ENDIF
     C           K#AZ5     CHAINAZAPP51             N90
     C           *IN90     IFEQ *OFF
     C                     MOVELZ5MEMO    S@MEMO
     C                     ENDIF
      *
     C                     ADD  1         RRN1
     C           RRN1      DIV  17        @@ANS   30
     C                     MVR            @@MVR   30
     C           @@MVR     IFEQ 1
     C                     Z-ADD*ZERO     W@C
     C                     ENDIF
      *
     C                     ADD  1         W@C
     C           W@C       IFEQ 2
     C                     MOVE *ON       *IN01
     C                     Z-ADD*ZERO     W@C
     C                     ELSE
     C                     MOVE *OFF      *IN01
     C                     ENDIF
      *
     C                     WRITESFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     Z-ADD1         #RCNO
      *
     C                     ENDSR
      *------------------------------------------------------
      *   2ST SCREEN
      *------------------------------------------------------
     C           #DSP02    BEGSR
      *
     C                     MOVELCMD,2     D@CMD
     C                     WRITEDSP99
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN51
      *
     C                     Z-ADD@@REC     #RCNO
     C                     SELEC
     C           *INKC     WHEQ *ON
     C                     MOVEL'99'      W@ID
     C           *INKL     WHEQ *ON
     C                     MOVEL'01'      W@ID
      *
     C                     OTHER
     C                     EXSR #CHK2
     C           *IN99     IFEQ *OFF
     C           *INKE     ANDEQ*ON
     C                     EXSR #UPD
     C                     MOVE '01'      W@ID
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *------------------------------------------------------
      *  CHECK - 2ND SCREEN
      *------------------------------------------------------
     C           #CHK2     BEGSR
      *
     C                     MOVE *OFF      *IN99
     C                     Z-ADD*ZERO     W@C     10
     C                     Z-ADD*ZERO     WRRN    40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
     C           WRRN      DIV  17        @@ANS   30
     C                     MVR            @@MVR   30
     C           @@MVR     IFEQ 1
     C                     Z-ADD*ZERO     W@C
     C                     ENDIF
      *
     C                     ADD  1         W@C
     C           W@C       IFEQ 2
     C                     MOVE *ON       *IN01
     C                     Z-ADD*ZERO     W@C
     C                     ELSE
     C                     MOVE *OFF      *IN01
     C                     ENDIF
      *
     C                     UPDATSFL01
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      *------------------------------------------------------
      *  UPDATE
      *------------------------------------------------------
     C           #UPD      BEGSR
      *
     C                     Z-ADD*ZERO     WRRN    40
     C           *IN90     DOUEQ*ON
     C                     ADD  1         WRRN
     C           WRRN      CHAINSFL01                90
     C           *IN90     IFEQ *OFF
      *
     C           K#AZ5     CHAINAZAPP51              95
     C           *IN95     IFEQ *OFF
     C                     Z-ADD*DATE     Z5UPDT
     C                     TIME           Z5UPTM
     C                     MOVEL#PGM      Z5UPGM
     C                     MOVEL#USER     Z5USER
     C                     MOVE #WSID     Z5UPWS
     C                     MOVELS@MEMO    Z5MEMO
     C                     UPDATAZAPP511
     C                     ELSE
     C           S@MEMO    IFNE *BLANK
     C                     CLEARAZAPP511
     C                     Z-ADD*DATE     Z5UPDT
     C                     TIME           Z5UPTM
     C                     MOVEL#PGM      Z5UPGM
     C                     MOVEL#USER     Z5USER
     C                     MOVE #WSID     Z5UPWS
     C                     MOVE S@PRT1    Z5PRT1
     C                     MOVE S@PRT2    Z5PRT2
     C                     MOVE S@PRT3    Z5PRT3
     C                     MOVELS@MEMO    Z5MEMO
     C                     WRITEAZAPP511
     C                     ENDIF
     C                     ENDIF
      *
     C           K#AZA     CHAINAZAPL50              95
     C           *IN95     IFEQ *OFF
     C                     Z-ADD*DATE     Z5UPDT
     C                     TIME           Z5UPTM
     C                     MOVEL#PGM      Z5UPGM
     C                     MOVEL#USER     Z5USER
     C                     MOVE #WSID     Z5UPWS
     C                     Z-ADDS@INVQ    Z5BOXQ
     C                     Z-ADDS@QTBX    Z5UNIT
     C                     UPDATAZAPP501
     C                     ELSE
     C           S@INVQ    IFNE *ZERO
     C                     CLEARAZAPP501
     C                     Z-ADD*DATE     Z5UPDT
     C                     TIME           Z5UPTM
     C                     MOVEL#PGM      Z5UPGM
     C                     MOVEL#USER     Z5USER
     C                     MOVE #WSID     Z5UPWS
     C                     Z-ADDS@INVQ    Z5BOXQ
     C                     MOVE S@LOC1    Z5LOC1
     C                     MOVE S@LOC2    Z5LOC2
     C                     MOVE S@LOC3    Z5LOC3
     C                     MOVE S@LOC4    Z5LOC4
     C                     MOVE S@PRT1    Z5PRT1
     C                     MOVE S@PRT2    Z5PRT2
     C                     MOVE S@PRT3    Z5PRT3
     C                     Z-ADDS@QTBX    Z5UNIT
     C                     Z-ADDD@YYMM    Z5YYMM
     C                     WRITEAZAPP501
     C                     ENDIF
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
**  CMD
F3: EXIT
F3: EXIT     F5: UPDATE    F12: PREV
