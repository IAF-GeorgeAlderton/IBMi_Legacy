     H            Y.
      ** ECSRA2 **************************
      * 海外拠点金型出庫実績データ作成 *
      *  EXCEL CSV形式                 *
      *    I-HASADA        2017/10/06    *
      ************************** ECSRA2 **
     FECSWPA1 IP  F     100            DISK
     FECSWPA2 O   F     300            DISK
      *
     E                    HIZ        12  6 0             日付1-12
     E                    HJS        12  9 0             実績数量1-12
      *
     IECSWPA1 AA  01
     I                                        1   40EQBMON
     I                                        5   6 EQKAT1L1
     I                                        7  10 EQKAT2L1
     I                                       11  11 EQKAT3
     I                                       12  140EQSYOS
     I                                       15  15 EQTKR1
     I                                       16  17 EQTKR2
     I                                       18  19 EQTKR3
     I                                       20  20 EQTKR4
     I                                       21  272EQSRYO
     I                                       28  300EQKOSU
     I                                       31  380EQYOHZ
     I                                       31  340EQYOYY
     I                                       35  360EQYOMM
     I                                       37  380EQYODD
     I                                       39  410EQMAIS
      *
     I            DS
     I                                        1   60WJSYM
     I                                        1   40WJSYY
     I                                        5   60WJSMM
      *
      ***
     C           *ENTRY    PLIST
     C                     PARM           PJSYY   4
      *
      *=========
      *  sｮjﾞｰ
     C           *IN10     IFEQ '0'
     C                     SETON                     10
      *
     C                     CLEARHIZ
     C           1         DO   12        X       20
     C                     MOVELPJSYY     WJSYY
     C                     Z-ADDX         WJSMM
     C                     Z-ADDWJSYM     HIZ,X
     C                     END
      *
     C                     EXCPTHD
     C                     END
      *
      *
     C           *INL1     IFEQ '1'
     C                     CLEARHJS
     C                     END
      *
     C                     Z-ADDEQYOMM    A       20
     C                     ADD  EQKOSU    HJS,A
      *
      *
     CL1                   EXSR SUBL1
      *
      *
      ******************
      * サブルーチン *
      ******************
     C           SUBL1     BEGSR
      *
      *****
      * 海外所番地
     C                     MOVE *BLANK    WTKR1   1
     C                     MOVE *BLANK    WTKR2   1
     C                     MOVE *BLANK    WTKR3   1
     C           EQTKR2    IFNE *BLANK
     C                     MOVEL'-'       WTKR1
     C                     END
     C           EQTKR3    IFNE *BLANK
     C                     MOVEL'-'       WTKR2
     C                     END
     C           EQTKR4    IFNE *BLANK
     C                     MOVEL'-'       WTKR3
     C                     END
      *
      *========
      *  mﾞｰj
     C                     EXCPTDT
      *
     C                     ENDSR
      *
      ***
     OECSWPA2 E                HD
     O                                      '海外拠点金型出庫実績'
     O                                      'データ'
