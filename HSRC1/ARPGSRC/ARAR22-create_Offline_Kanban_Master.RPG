     F******************************************* ARAR22 ***
     FARAWP21 IP  F     300  2AI     1 DISK
     FARAWP22 O   F     256            DISK                      A
     IARAWP21 AA  01
     I                                        1   2 @FILE
     I                                        3 249 ADAT1
     I                                      250 300 ADAT2
     C           @FILE     IFEQ 'MK'
     C           @FILE     OREQ 'TN'
     C           @FILE     OREQ 'HT'
     C           @FILE     OREQ 'KN'
     C                     Z-ADD0         WKEIZ   10
     C           @FILE     IFEQ 'TN'
     C                     Z-ADD1         WKEIZ
     C                     MOVELADAT1     WDATA 247
     C                     EXCPTARAWTR
     C                     Z-ADD0         WKEIZ
     C                     MOVELADAT2     WDATA
     C                     EXCPTARAWTR
     C                     ELSE
     C                     MOVELADAT1     WDATA
     C                     EXCPTARAWTR
     C                     END
     C                     END
     OARAWP22 EADD             ARAWTR
     O                                    2 'DT'
     O                                    6 '0000'
     O                         @FILE      8
     O                         WKEIZ      9
     O                         WDATA  B 256
