     H            Y.
     F*** ABCR09 *******************************
     F* CALCULATION  OF COMPLETION PART KANBAN SHEETS *
     F* H.ITO              1990.12.17          *
     F*----------+-----+----------+-----------------------------------*
     F*2021.02.11|DCS. |T.MITSUI  | CHANGE WITH THE NUMBER OF FIGURES *
     F*          |     |          |          EXPANSION OF THE "KANBAN"*
     F****************************************************** ABCR09 ***
     C           *ENTRY    PLIST
     C                     PARM           PARM1   2        LRﾆﾍｭc
     C                     PARM           PARM2   1        nﾃﾜﾌﾞ]k1
     C                     PARM           PARM3   2               2
     C                     PARM           PARM4   2               3
     C                     PARM           PARM5   1               4
     C                     PARM           PARM6   90       ﾈｮmbﾇc iﾞｮf]
     C                     PARM           PARM7   50       ﾆｬcﾑcﾇc
     C                     PARM           PARM8   31       ﾆbﾛﾅg L.T
     C                     PARM           PARM9   31       a]ﾈﾞ] L.T
     C                     PARM           PARM10  40       ﾆﾞﾃcmbﾎﾞy]
     C                     PARM           PARM11  40       ﾈbgｬcﾅg
     C                     PARM           PARM12  3        ﾍgnﾒﾇc
     C                     PARM           PARM13  3        ﾍgnﾒﾜｮn
     C                     PARM           PARM14  1        f]ﾌﾞ] jﾞb
     C                     PARM           PARM15  1              ﾆｭc
     C                     PARM           PARM16  30       a]ﾈﾞ]ubﾇc
     C                     PARM           PARM17  50       f]ﾌﾞ]ubﾇc
     C                     PARM           PARM18  6        ﾆｭﾒﾍﾇﾞi
     C                     PARM           PARM19  20       ﾌﾃﾇc
      *
     C           PARM1     IFEQ 'LR'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           PARM6     DIV  20        @HSU    70       ﾍajﾒﾈｮmbﾇc
     C           @HSU      DIV  PARM7     @HHK    72       ﾍajﾒ ﾌﾃﾇc
      *
     C* ﾆｭcﾒｭcﾎﾞﾍ] ﾆﾞｭcﾇc
     C*
     C           @HHK      IFLE 5
     C                     Z-ADD1         @JYO    10
     C                     ELSE
     C                     Z-ADD0         @JYO
     C                     END
      *
     C* lcﾆﾞｭcf]ﾌﾞ] ibﾅ]ﾆg
     C*
     C           PARM8     ADD  PARM9     @TLT    31
     C           @HSU      MULT @TLT      @AAA   101
     C                     Z-ADD0         @BBB    71
     C           @AAA      DIV  PARM7     @BBB
     C                     MVR            @AMR    50
      *
     C           @AMR      IFNE 0
     C                     ADD  1         @BBB
     C                     END
      *
     C           @BBB      ADD  @JYO      @CCC    50
     C           PARM19    SUB  1         @DDD    50
     C           @CCC      ADD  @DDD      @EEE    50
     C           @EEE      ADD  PARM16    PARM17
      *
     C           PARM17    IFLT 2
     C                     Z-ADD2         PARM17
     C                     END
      *
     C                     RETRN
