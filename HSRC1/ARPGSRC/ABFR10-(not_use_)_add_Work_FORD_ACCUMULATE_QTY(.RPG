     H            Y/
     F** ABFR09 *****************************************
     F* ADD WORK FORD ACCUMULATE QTY(ABFAP99) TO ABFAP01*
     F* FORD all plant                                  *
     F*                                                 *
     F* J.WATANABE 2017.01.03                           *
     F***************************************************
     FABFAP01 UF  E           K        DISK
      *------------------------------------------------------------
     I            DS
     I                                        1  140W@TIME
     I                                        1   20W@H
     I                                        3   40W@M
     I                                        5   60W@S
     I                                        7  140W@YMD
     I                                        7  140@DATE8
     I                                        9  140@DATE6
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *==================================================
      *
     C                     EXSR #INT
      * CLEAR ABFAP01
     C                     EXSR #CLR
      *
     C                     MOVEL*ON       *INLR
     C                     RETRN
      *==================================================
      *  CLEAR ABFAP01
      *==================================================
     C           #CLR      BEGSR
     C                     MOVE *OFF      *IN96
     C           *LOVAL    SETLLABFAP01R
     C           *IN96     DOWEQ*OFF
     C                     READ ABFAP01R                 96
     C           *IN96     IFEQ *OFF
     C                     Z-ADD0         CFCAMN
     C                     Z-ADD0         CFCAMT
     C                     Z-ADD*YEAR     CFUPDY
     C                     Z-ADD*MONTH    CFUPDM
     C                     Z-ADD*DAY      CFUPDD
     C                     Z-ADDW@H       CFUPTH
     C                     Z-ADDW@M       CFUPTM
     C                     MOVEL#USER     CFUPNM
     C                     UPDATABFAP01R
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
     C*=====================================================
     C* Initial SET
     C*=====================================================
     C           #INT      BEGSR
     C*
     C                     TIME           W@TIME
     C*
     C                     ENDSR
