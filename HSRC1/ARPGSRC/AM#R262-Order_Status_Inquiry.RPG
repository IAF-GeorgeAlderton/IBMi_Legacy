     H            Y.                                    1
      ***AM#R262  **************************************************************
      *  ORDER STATUS INQUIRY                                                  *
      *
      **************************************************************************
     FAM#PW262CF  E                    WORKSTN
     F                                        RRN1  KSFILE SFL01
     FAL#PP21 IF  E           K        DISK
     FAB#PPDC IF  E           K        DISK
     FAB#PL1C IF  E           K        DISK
     FAB#PL1S IF  E           K        DISK
     F            AB#PP101                          KRENAMEAB#PL1S1
     FAL#PL0C IF  E           K        DISK
     FAL#PL28 IF  E           K        DISK
     FAB#PL65EIF  E           K        DISK
     FFGBPL01 IF  E           K        DISK
     FAM#PL08 IF  E           K        DISK
     FAM#PL25 IF  E           K        DISK
     FAM#PL21 IF  E           K        DISK
     FAM#PL400IF  E           K        DISK
      **************************************************************************
     E                    ERR     1  10 70
      **************************************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      * SYSTEM TIME
     I            DS
     I                                        1  140WSDT
     I                                        1   60WSSTM6
     I                                        1   40WSSTM4
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  140WSSDAT
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
      * SHIP DATE
     I            DS
     I                                        1   80SHID
     I                                        1   40NOYY
     I                                        5   60NOMM
     I                                        7   80NODD
      * PART NUMBER
     I            DS
     I                                        1  20 PART
     I                                        1   5 MHN1
     I                                        6  10 MHN2
     I                                       11  15 MHN3
     I                                       16  20 MHN4
      * EDITED PART NUMBER FOR SUBFILE
     I            DS
     I                                        1  14 EPART
     I                                        1   5 EMHN1
     I I            '-'                       6   6 DASH1
     I                                        7  11 EMHN2
     I I            '-'                      12  12 DASH2
     I                                       13  14 EMHN3
     I            DS
     I                                        1   80W1SHDT
     I                                        1   40W1SHYY
     I                                        5   60W1SHMM
     I                                        7   80W1SHDD
      *
      *  BARCODE SCANNED
     I            DS
     I                                        1 250 BC
     I                                        1   1 BCTYPE
     I                                        1  50 F1BC1
     I                                       51 100 F1BC2
     I                                      101 150 F1BC3
     I                                      151 200 F1BC4
     I                                      201 250 F1BC5
      *
      * MANIFEST BARCODE
     I            DS
     I                                        1  50 MFBC
     I                                        1   5 MFNAMC
     I                                        3   5 MFTYPE
     I                                        6  10 MFSUPP
     I                                       11  12 MFDOCK
     I                                       13  24 MFORD#
     I                                       25  33 MFMRTE
     I                                       34  36 MFSDCK
     I                                       37  38 MFPALT
     I                                       39  40 MFMROS
     I                                       41  44 MFSKID
     I                                       44  44 MFSIDE
     I                                       45  50 MFFIL2
      *  CONTAINER BARCODE
     I            DS
     I                                        1 250 CONBC
     I                                        2  16 TXT1
     I                                       17  31 TXT2
     I                                       32  36 SUPP
     I                                       37  38 DCCOD
     I                                       39  42 SBAN
     I                                       43  54 PARTNO
     I                                       55  64 LNAD
     I                                       65  74 STAD
     I                                       75  79 LOTS
     I                                       80  99 SUPNM
     I                                      100 108 MAINR
     I                                      109 117 SUBR
     I                                      118 125 UNDAT
     I                                      126 133 SHDT
     I                                      134 139 SHTM
     I                                      140 151 ORNO
     I                                      152 155 BXNBR
     I                                      156 159 BXTOT
     I                                      160 164 DEST
     I                                      196 197 PALT
      *
      * DATE/TIME
     I            DS
     I                                        1   80DSDATE
     I                                        9  140DSTIME
     I                                        5   6 DSMM
     I                                        7   8 DSDD
     I                                        9  10 DSHH
     I                                       11  12 DSMN
     IDTTM        DS
     I                                        1   2 DTMM
     I                                        3   3 SLASH
     I                                        4   5 DTDD
     I                                        6   6 BLNK
     I                                        7   8 DTHH
     I                                        9   9 COLON
     I                                       10  11 DTMN
      **************************************************************************
      *                    MAIN ROUTINE
      **************************************************************************
     C           @@ID      DOWNE'99'
     C           @@ID      CASEQ'10'      #FMT10
     C           @@ID      CASEQ'20'      #FMT20
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      **************************************************************************
      *         INITIALIZE
      **************************************************************************
     C           *INZSR    BEGSR
      *
     C           K#PL1C    KLIST
     C                     KFLD           ORDNO
     C                     KFLD           NONY
     C                     KFLD           DOCK4
      *
     C           K#PL1S    KLIST
     C                     KFLD           INVNO
     C                     KFLD           NONY
     C                     KFLD           DOCK4
      *
     C           K#PL0C    KLIST
     C                     KFLD           NAMC
     C                     KFLD           ORD#
     C                     KFLD           DOCK4
      *
     C           K#PL28    KLIST
     C                     KFLD           ORD#
     C                     KFLD           NAMC
     C                     KFLD           DOCK
      *
     C           K#PL65    KLIST
     C                     KFLD           NONYCH
     C                     KFLD           DOCK4
     C                     KFLD           ORD#
      *
     C           K#PL08    KLIST
     C                     KFLD           NONY
     C                     KFLD           DOCK
     C                     KFLD           ORD#
      *
     C           K#PL25    KLIST
     C                     KFLD           SVMFBC
      *
     C           K#PL0P    KLIST
     C                     KFLD           NAMC
     C                     KFLD           ORD#
     C                     KFLD           DOCK4
     C                     KFLD           SVPALT
      *
     C           K#PL2P    KLIST
     C                     KFLD           ORD#
     C                     KFLD           NAMC
     C                     KFLD           DOCK
     C                     KFLD           SVPALT
      *
     C           K#PL40    KLIST
     C                     KFLD           R2SUPP
     C                     KFLD           R2SURT
     C                     KFLD           SHID
     C                     KFLD           SHIT
      *
     C                     MOVEL*BLANKS   BC
     C                     MOVEL*BLANKS   MSG
      *
     C                     MOVEL'20'      @@ID    2
     C                     MOVEL*OFF      *IN99
      *
     C                     ENDSR
      *************************************************************************
      *     1ST SCREEN(MANIFEST/CONTAINER BARCODE)
      **************************************************************************
     C           #FMT10    BEGSR
      *
     C                     MOVE *OFF      *IN48
     C                     WRITEFMT099
     C                     EXFMTFMT010
     C                     MOVEL*BLANK    MSG
     C                     MOVE *OFF      *IN31
     C                     MOVE *OFF      *IN99
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKE     WHEQ *ON
     C                     MOVE *OFF      *IN31
     C                     MOVE *OFF      *IN99
     C                     MOVE '20'      @@ID
     C                     OTHER
     C           BCTYPE    IFEQ 'C'
     C                     MOVELBC        CONBC
     C                     EXSR #CONT
     C                     ELSE
     C                     MOVELF1BC1     MFBC
     C                     MOVEL'A'       MFSIDE
     C                     EXSR #MANI
     C                     ENDIF
     C                     EXSR #CHECK
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET30
     C                     EXSR #FMT30
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************************
      *     CHECK FIELDS NEEDED TO DETERMINE ORDER STATUS -- NAMC, DOCK, ORDER#
      **************************************************************************
     C           #CHECK    BEGSR
      *
     C                     TIME           WSDT
      *
     C           @@ID      IFEQ '10'
     C           BC        IFEQ *BLANK
     C                     SETON                     314142
     C                     SETON                     4399
     C                     MOVELERR,1     MSG
     C                     GOTO #ECHK
     C                     ENDIF
     C                     ENDIF
      *
      * check namc code...
     C                     SELEC
     C           NAMC      WHEQ '60EXP'
     C           DOCK4     CHAINAB#PPDC              50
     C           *IN50     IFEQ *ON
     C                     SETON                     314142
     C                     SETON                     99
     C                     MOVELERR,5     MSG
     C                     GOTO #ECHK
     C                     ELSE
     C                     MOVELADNONY    NONY    40
     C                     ENDIF
     C                     OTHER
     C           NAMC      CHAINAL#PP21              50
     C           *IN50     IFEQ *ON
     C                     SETON                     314199
     C                     MOVELERR,4     MSG
     C                     GOTO #ECHK
     C                     ELSE
     C                     MOVELC2NONY    NONY
     C                     ENDIF
     C                     ENDSL
      *
      *  check dock code...
     C           DOCK      IFEQ *BLANKS
     C                     SETON                     314299
     C                     MOVELERR,5     MSG
     C                     GOTO #ECHK
     C                     ENDIF
      *
      *  check order number...
     C           ORD#      IFEQ *BLANKS
     C                     SETON                     314399
     C                     MOVELERR,6     MSG
     C                     GOTO #ECHK
     C                     ENDIF
      *
     C           #ECHK     ENDSR
      *************************************************************************
      *     MANUALLY SELECT NAMC/DOCK/ORDER
      **************************************************************************
     C           #FMT20    BEGSR
      *
     C                     MOVE *OFF      *IN48
     C                     WRITEFMT099
     C                     EXFMTFMT020
     C                     MOVEL*BLANK    MSG
     C                     MOVEL*OFF      *IN99
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C           *INKE     WHEQ *ON
     C                     SETOF                     414243
     C                     MOVE '10'      @@ID
     C                     OTHER
     C                     MOVELF2NAMC    NAMC
     C                     MOVELF2DOCK    DOCK
     C                     MOVELF2ORD#    ORD#
     C                     EXSR #CHECK
     C           *IN99     IFEQ *OFF
     C                     EXSR #SET30
     C                     EXSR #FMT30
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************************
      *     GET NAMC, DOCK, ORD# FROM CONTAINER BARCODE
      **************************************************************************
     C           #CONT     BEGSR
      *
     C                     MOVELDEST      NAMC    5
     C                     MOVELDCCOD     DOCK    2
     C                     MOVELORNO      ORD#   12
      *
     C                     ENDSR
      *************************************************************************
      *     GET NAMC, DOCK, ORD# FROM MANIFEST BARCODE
      **************************************************************************
     C           #MANI     BEGSR
      *
     C                     MOVELMFNAMC    NAMC
     C                     MOVELMFDOCK    DOCK
     C                     MOVELMFORD#    ORD#
      *
     C                     ENDSR
      *************************************************************************
      *     SET SCREEN 3
      **************************************************************************
     C           #SET30    BEGSR
      *
     C                     CLEARCTL01
     C                     MOVE *ON       *IN52
     C                     WRITECTL01
     C                     MOVE *OFF      *IN52
     C                     Z-ADD*ZERO     RRN1    40
      *
     C                     MOVELDOCK      F3DOCK
     C                     MOVELORD#      F3ORD#
     C                     MOVELNONY      F3NONY
     C                     MOVELNAMC      F3SURT
     C                     Z-ADD*ZERO     F3SHID
     C                     Z-ADD*ZERO     F3SHIT
      *
      *  get customer name...
     C           NONY      CHAINFGBPL01              53
     C           *IN53     IFEQ *OFF
     C                     MOVELB2SMEI    F3SMEI
     C                     ENDIF
      *
     C                     MOVELDOCK      DOCK4   4
     C                     MOVELORD#      INVN   12
     C                     MOVELNONY      NONYCH  4
     C                     Z-ADD*ZERO     TBOX    40
      *
      *  check sales order file...
      *
      *      if canada...
     C           NONY      IFEQ 3503
     C                     MOVELORD#      ORDNO  10
     C           K#PL1C    CHAINAB#PL1C              98
     C           *IN98     DOWEQ*OFF
     C           BASKJY    IFEQ *BLANK
     C           BAUSYS    IFGT *ZERO
     C           BAODER    DIV  BAUSYS    BOX     40
     C                     ELSE
     C                     Z-ADD*ZERO     BOX
     C                     ENDIF
     C                     ADD  BOX       TBOX
     C                     MOVEL'Y'       AB10YN
     C                     ENDIF
     C           K#PL1C    READEAB#PL1C                  98
     C                     ENDDO
     C                     ENDIF
      *
      *      if NOT canada...
     C           NONY      IFNE 3503
     C                     MOVELINVN      INVNO  16
     C           K#PL1S    CHAINAB#PL1S              98
     C           *IN98     DOWEQ*OFF
     C           BASKJY    IFEQ *BLANK
     C           BAUSYS    IFGT *ZERO
     C           BAODER    DIV  BAUSYS    BOX     40
     C                     ELSE
     C                     Z-ADD*ZERO     BOX
     C                     ENDIF
     C                     ADD  BOX       TBOX
     C                     MOVEL'Y'       AB10YN
     C                     ENDIF
     C           K#PL1S    READEAB#PL1S                  98
     C                     ENDDO
     C                     ENDIF
      *
     C                     Z-ADDTBOX      AB10#
      *
     C                     Z-ADD*ZERO     TBOX
      *
      *  check web order files...
      *
      *    regular web order file...
     C           K#PL0C    CHAINAL#PL0C              98
     C           *IN98     DOWEQ*OFF
     C           CASKJY    IFEQ *BLANK
     C                     ADD  1         TBOX
     C           F3SHID    IFEQ *ZERO
     C                     MOVELCASHID    F3SHID
     C                     MOVELCASHIT    F3SHIT
     C                     MOVEL'Y'       AL01YN
     C                     ENDIF
     C                     ENDIF
     C           K#PL0C    READEAL#PL0C                  98
     C                     ENDDO
      *
     C                     Z-ADDTBOX      AL01#
     C                     Z-ADD*ZERO     TBOX
      *
      *    supplemental web order file...
     C           K#PL28    CHAINAL#PL28              98
     C           *IN98     DOWEQ*OFF
     C           CASKJY    IFEQ *BLANK
     C                     ADD  1         TBOX
     C           F3SHID    IFEQ *ZERO
     C                     MOVELCASHID    F3SHID
     C                     MOVELCASHIT    F3SHIT
     C                     ENDIF
     C                     MOVEL'Y'       AL02YN
     C                     ENDIF
     C           K#PL28    READEAL#PL28                  98
     C                     ENDDO
      *
     C                     Z-ADDTBOX      AL02#
     C                     Z-ADD*ZERO     TBOX
      *
      *    shipping pull file...
     C           K#PL65    CHAINAB#PL65E             98
     C           *IN98     DOWEQ*OFF
     C           A6SKJY    IFEQ *BLANK
     C                     ADD  1         TBOX
     C                     MOVEL'Y'       AB65YN
     C                     ENDIF
     C           K#PL65    READEAB#PL65E                 98
     C                     ENDDO
      *
     C                     Z-ADDTBOX      AB65#
     C                     Z-ADD*ZERO     TBOX
      *
     C                     MOVEL*BLANKS   SVPALT
     C                     MOVEL*BLANKS   SVSKID
     C                     Z-ADD*ZERO     SVPACK
     C                     MOVEL*BLANKS   SVMFBC
     C                     MOVE ' '       @FIRST
      *
     C                     Z-ADD*ZERO     SHRT#
      * fill the subfile with Pallet Info....
     C           K#PL08    SETLLAM#PL08
     C           *IN90     DOUEQ*ON
     C           K#PL08    READEAM#PL08                  90
     C           *IN90     IFEQ *OFF
      *
     C           R1HNTE    IFEQ 'NG'
     C           R1SKJY    OREQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELR1SKID    SKID    3
      *
     C           @FIRST    IFEQ ' '
     C                     MOVELR1PALT    SVPALT  2
     C                     MOVELSKID      SVSKID  3
     C                     Z-ADD*ZERO     SVPACK  30
     C                     MOVELR1MFBC    SVMFBC 50
     C                     MOVE 'X'       @FIRST  1
     C                     ENDIF
      *
     C           R1SHME    IFEQ 'SHORT'
     C           R1EXCD    ANDEQ'12'
     C                     ADD  1         SHRT#
     C                     ENDIF
      *
     C           R1PALT    IFEQ SVPALT
     C           SKID      ANDEQSVSKID
     C                     ADD  1         SVPACK
     C                     ELSE
     C                     MOVELSVPALT    S@PALT
     C                     MOVELSVSKID    S@SKID
     C                     Z-ADDSVPACK    S@PACK
     C                     MOVE '/'       S@SLSH
     C                     MOVELSVMFBC    S@MFBC
     C                     EXSR GETORD
     C                     EXSR GETSCS
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     CLEARSFL01
     C                     MOVE R1PALT    SVPALT
     C                     MOVELSKID      SVSKID
     C                     Z-ADD1         SVPACK
     C                     MOVELR1MFBC    SVMFBC
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      * Process Last...
     C           SVPACK    IFGT *ZERO
     C                     MOVELSVPALT    S@PALT
     C                     MOVELSVSKID    S@SKID
     C                     Z-ADDSVPACK    S@PACK
     C                     MOVE '/'       S@SLSH
     C                     MOVELSVMFBC    S@MFBC
     C                     EXSR GETORD
     C                     EXSR GETSCS
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     CLEARSFL01
     C                     ENDIF
      *
     C           RRN1      IFEQ *ZERO
     C                     MOVEL' No Data'S@SKDT    P
     C                     ADD  1         RRN1
     C                     WRITESFL01
     C                     CLEARSFL01
     C                     ENDIF
      *
     C                     ENDSR
      *************************************************************************
      *     3RD SCREEN(FILES STATUSES)
      **************************************************************************
     C           #FMT30    BEGSR
      *
     C                     MOVE *ON       *IN48
     C                     WRITEFMT099
     C                     MOVE *ON       *IN51
     C                     EXFMTCTL01
     C                     MOVE *OFF      *IN48
     C                     MOVE *OFF      *IN51
     C                     MOVEL*BLANK    MSG
     C                     MOVE *OFF      *IN31
     C                     MOVE *OFF      *IN99
      *
     C                     SELEC
     C           *INKA     WHEQ *ON
     C                     MOVE '99'      @@ID
     C                     OTHER
     C                     ENDSL
      *
     C                     ENDSR
      *************************************************************************
      *     GET SCS INFORMATION FOR SKID BUILD, TRAILER BUILD, ROUTE, & OVERRIDE
      **************************************************************************
     C           GETSCS    BEGSR
      *
     C                     MOVE *BLANKS   DTTM
      *
      *    get the last date/time for skid build...
     C                     MOVE *OFF      *IN98
     C           K#PL25    SETGTAM#PL25
     C           K#PL25    REDPEAM#PL25                  98
     C           *IN98     IFEQ *OFF
     C                     Z-ADDR5CRHZ    DSDATE
     C                     Z-ADDR5CRTI    DSTIME
      *
     C                     MOVE DSMM      DTMM
     C                     MOVE '/'       SLASH
     C                     MOVE DSDD      DTDD
     C                     MOVE DSHH      DTHH
     C                     MOVE ':'       COLON
     C                     MOVE DSMN      DTMN
      *
     C                     MOVELDTTM      S@SKDT
      *
     C           R5APIC    IFEQ '*NULL'
     C                     MOVEL'N'       S@SKOK
     C                     ELSE
     C                     MOVEL'Y'       S@SKOK
     C                     ENDIF
     C                     ENDIF
      *
     C           K#PL25    CHAINAM#PL21              98
     C           *IN98     IFEQ *OFF
     C           R2TICK    CAT  R2SHIT    S@TICK
     C                     MOVELR2F5OV    S@OVR
      *
      * get trailer send results from SCS log...
     C                     MOVELR2SHID    SHID
     C                     MOVELR2SHIT    SHIT    60
      *
     C                     MOVE *OFF      *IN98
     C           K#PL40    SETGTAM#PL400
     C           K#PL40    REDPEAM#PL400                 98
     C           *IN98     IFEQ *OFF
     C                     Z-ADDL1DATE    DSDATE
     C                     Z-ADDL1TIME    DSTIME
      *
     C                     MOVE DSMM      DTMM
     C                     MOVE '/'       SLASH
     C                     MOVE DSDD      DTDD
     C                     MOVE DSHH      DTHH
     C                     MOVE ':'       COLON
     C                     MOVE DSMN      DTMN
      *
     C                     MOVELDTTM      S@TRDT
      *
     C           L1CFM#    IFEQ '*NULL'
     C                     MOVEL'N'       S@TROK
     C                     ELSE
     C                     MOVEL'Y'       S@TROK
     C                     ENDIF
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     ENDSR
      *************************************************************************
      *     GET CONTAINER QTY ORDERED FOR THIS PALLET CODE
      **************************************************************************
     C           GETORD    BEGSR
      *
     C                     Z-ADD*ZERO     S@ORD
      *    regular web order file...
     C           K#PL0P    CHAINAL#PL0C              98
     C           *IN98     DOWEQ*OFF
     C           CASKJY    IFEQ *BLANK
     C                     ADD  1         S@ORD
     C                     ENDIF
     C           K#PL0P    READEAL#PL0C                  98
     C                     ENDDO
      *
     C           S@ORD     IFEQ *ZERO
     C           K#PL2P    CHAINAL#PL28              80
     C           *IN80     DOWEQ*OFF
     C           CASKJY    IFEQ *BLANK
     C                     ADD  1         S@ORD
     C                     ENDIF
     C           K#PL2P    READEAL#PL28                  80
     C                     ENDDO
     C                     ENDIF
      *
     C                     ENDSR
      *************************************************************************
** ERR
SCAN BARCODE
MANIFEST NOT FOUND
CONTAINER NOT FOUND
INVALID NAMC
DOCK CODE IS BLANK
ORDER# IS BLANK




