     C*===============================================================
     C*  START  PROGRAM
     C*===============================================================
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#CHK1   '#CHK1
     C           @STEP     CASEQ'#SFSET  '#SFSET
     C           @STEP     CASEQ'#DSP2   '#DSP2
     C           @STEP     CASEQ'#CHK2   '#CHK2
     C           @STEP     CASEQ'#CHG    '#CHG
     C           @STEP     CASEQ'#DSP3   '#DSP3
     C           @STEP     CASEQ'#CHK3   '#CHK3
     C           @STEP     CASEQ'#CHK3U  '#CHK3
     C           @STEP     CASEQ'#UPDAT  '#UPDAT
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C*   << INIT >>
     C*===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C                     MOVE 'IAF'     D1ODR0
     C                     Z-ADD0         D1ODR1
     C                     Z-ADD0         D1ODR2
     C                     Z-ADD0         D1ODR3
     C                     MOVE *BLANK    D1HIN1
     C                     MOVE *BLANK    D1HIN2
     C                     MOVE *BLANK    D1HIN3
     C                     MOVE *BLANK    D1MSG
     C                     MOVE '#DSP1   '@STEP
     C*
     C                     ENDSR
      *===============================================================
      *  画面１　表示
      *===============================================================
     C           #DSP1     BEGSR
     C*
     C                     EXFMTDSP01
     C                     SETOF                     020399
     C                     MOVE *BLANK    D1MSG
     C*
     C                     MOVE '#CHK1   '@STEP
     C*  < F1 >  EXIT
     C           *INKA     IFEQ *ON
     C                     MOVE '#END    '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  画面１　チェック
      *===============================================================
     C           #CHK1     BEGSR
     C           D1ODR     IFEQ 0
     C                     SETON                     0299
     C                     MOVELER,1      D1MSG
     C                     ENDIF
     C*
S1   C           *IN99     IFEQ *OFF
     C                     MOVE '#SFSET  '@STEP
X1   C                     ELSE
     C                     MOVE '#DSP1   '@STEP
E1   C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *
      *===============================================================
     C           #SFSET    BEGSR
     C           KEY01     KLIST
     C                     KFLD           D1ODR
     C                     KFLD           D1HIN1
     C                     KFLD           D1HIN2
     C                     KFLD           D1HIN3
     C                     SETON                     83    SFLCLR
     C                     WRITESFCTL
     C                     SETOF                     8311
     C                     Z-ADD0         RRN1    40
     C*
     C           KEY01     SETLLGDGPL18
     C*--------------------
S1   C                     DO   *HIVAL
     C           D1ODR     READEGDGPL18                  90
     C   90                LEAVE
 S2  C           ICSKJY    IFEQ 'D'
     C           ICSKHZ    ANDLE*DATE                                  )
     C                     ITER
 E2  C                     ENDIF
     C*
 S2  C           ICIFMK    IFEQ 'C'
     C                     ITER
 E2  C                     ENDIF
     C*
     C                     MOVE *BLANK    S1CHG
     C                     MOVE *BLANK    S1HIN            PART NO.
     C                     MOVE ICHIN1    S1HIN1           PART NO1
     C                     MOVE ICHIN2    S1HIN2           PART NO2
     C                     MOVE ICHIN3    S1HIN3           PART NO3
     C                     MOVE '-'       S1HF1
     C                     MOVE '-'       S1HF2
     C           S1HIN3    IFEQ *BLANK                     PART NO3
     C                     MOVE ' '       S1HF2
     C           S1HIN2    IFEQ *BLANK                     PART NO2
     C                     MOVE ' '       S1HF1
     C                     ENDIF
     C                     ENDIF
     C                     Z-ADDICITEM    S1ITEM           ITEM NO
     C           ICHANY    IFEQ 'A'
     C                     MOVE ' AIR'    S1CARY           CARRY
     C                     ELSE
     C                     MOVE 'SHIP'    S1CARY           CARRY
     C                     ENDIF
     C                     Z-ADDICDLHZ    S1DLVR           DELIVERY
     C                     Z-ADDICSURY    S1SURY           QTY
     C                     Z-ADDICSYOS    S1SYOS           QTY/BOX
     C                     Z-ADDICMAIS    S1MAIS           BOX
     C                     MOVE *BLANK    S1INVO           INVOICE
     C           ICINVO    IFNE *BLANK
     C                     MOVE '*'       S1INVO           INVOICE
     C                     ENDIF
     C                     ADD  1         RRN1
     C                     WRITESFREC1
E1   C                     ENDDO
     C*--------------------
     C           RRN1      IFEQ 0
     C                     SETON                     99
     C                     MOVELER,2      D1MSG
     C                     MOVE '#DSP1   '@STEP
     C                     ELSE
     C                     Z-ADDRRN1      ENDRRN  40
     C                     Z-ADD1         RRN
     C                     MOVE '#DSP2   '@STEP
E1   C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *  画面２　表示
      *===============================================================
     C           #DSP2     BEGSR
     C*
     C                     WRITEDSP02
     C                     SETON                     8182
     C                     EXFMTSFCTL
     C                     SETOF                     818299
     C                     MOVE *BLANK    D2MSG
     C                     Z-ADD$$RRN     TOPRRN  40
     C*
     C                     MOVE '#CHK2   '@STEP
     C*  < F3 >  PRV SCREEN
     C           *INKC     IFEQ *ON
     C                     MOVE '#DSP1   '@STEP
     C                     ENDIF
     C*  < F5 >  INPUT OK
     C*          *INKE     IFEQ *ON
     C*                    MOVE '#CHK2   '@STEP
     C*                    ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *===============================================================
     C           #CHK2     BEGSR
     C*
     C                     Z-ADD0         @SEL    40
     C                     Z-ADD0         ERRRRN  40
     C                     Z-ADD0         CHGRRN  40
     C*--------------------
S1   C                     DO   ENDRRN    RRN1
     C           RRN1      CHAINSFREC1               91
     C   91                LEAVE
     C                     SETOF                     11
     C*
 S2  C           S1CHG     IFNE *BLANK                     CHG
     C           S1CHG     ANDNE'0'                        CHG
     C           S1CHG     ANDNE'1'                        CHG
     C                     MOVELER,3      D2MSG
     C                     SETON                     1199
     C                     Z-ADDRRN1      ERRRRN
 E2  C                     ENDIF
     C*
 S2  C           S1CHG     IFEQ '0'                        CHG
  2  C           S1CHG     OREQ '1'                        CHG
  S3 C           @SEL      IFEQ 0
     C                     Z-ADDRRN1      CHGRRN
  X3 C                     ELSE
     C                     SETON                     11
  S4 C           ERRRRN    IFEQ 0
     C                     Z-ADDRRN1      ERRRRN
  E4 C                     ENDIF
  E3 C                     ENDIF
     C                     ADD  1         @SEL
 E2  C                     ENDIF
     C*
     C                     UPDATSFREC1
E1   C  N99                ENDDO
     C*--------------------
     C           @SEL      IFEQ 0
     C                     MOVELER,4      D2MSG
     C                     SETON                     99
     C                     ELSE
     C           @SEL      IFNE 1
     C                     MOVELER,5      D2MSG
     C                     SETON                     99
     C                     ENDIF
     C                     ENDIF
     C*
S1   C           *IN99     IFEQ *OFF
     C                     MOVE '#CHG    '@STEP
X1   C                     ELSE
 S2  C           ERRRRN    IFNE 0
     C                     Z-ADDERRRRN    RRN
 X2  C                     ELSE
     C                     Z-ADDTOPRRN    RRN
 E2  C                     ENDIF
     C                     MOVE '#DSP2   '@STEP
E1   C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *
      *===============================================================
     C           #CHG      BEGSR
     C*
     C           KEY02     KLIST
     C                     KFLD           D1ODR
     C                     KFLD           S1ITEM           ITEM NO
     C*
     C                     SETOF                     202122
     C                     SETOF                     2324
     C           CHGRRN    CHAINSFREC1               91
     C           KEY02     CHAINGDGPL16             N92
     C*
S1   C           *IN92     IFEQ *ON
     C                     MOVELER,6      D2MSG
     C                     SETON                     99
X1   C                     ELSE
     C*
 S2  C           ICSKJY    IFEQ 'D'
     C           ICSKHZ    ANDLE*DATE                                  )
     C                     MOVELER,6      D2MSG
     C                     SETON                     99
 E2  C                     ENDIF
     C*
 S2  C  N99      ICIFMK    IFEQ 'C'
     C                     SETON                     1199
     C                     MOVELER,6      D2MSG
 E2  C                     ENDIF
 S2  C  N99      ICIFMK    IFEQ '*'
     C                     SETON                     1199
     C                     MOVELER,11     D2MSG
 E2  C                     ENDIF
E1   C                     ENDIF
     C*
     C           *IN99     IFEQ *ON
     C  N91                UPDATSFREC1
     C                     Z-ADDCHGRRN    RRN
     C                     MOVE '#DSP2   '@STEP
     C                     ELSE
     C           S1CHG     COMP '0'                      20:DELET
     C                     MOVE S1CHG     D3CHG
     C   20                MOVE ' DELETE 'D3UPDT
     C   20                MOVE '0'       D3UPCD  1
     C  N20                MOVE ' CHANGE 'D3UPDT
     C  N20                MOVE '1'       D3UPCD
     C                     MOVELS1HIN     D3HIN            PART NO.
     C                     MOVE *ALL'-'   D3ODR
     C                     MOVE D1ODR0    D3ODR0
     C                     Z-ADDD1ODR1    D3ODR1
     C                     Z-ADDD1ODR2    D3ODR2
     C                     Z-ADDD1ODR3    D3ODR3
     C                     Z-ADDICITEM    D3ITEM           ITEM NO
     C                     Z-ADDICSYOS    D3SYOS           QTY/BOX
     C                     Z-ADDICMAIS    D3MAIS           BOX
     C                     Z-ADDICSURY    D3SURY           QTY
     C                     MOVE ICHANY    D3HANY
     C                     Z-ADDICDLVY    D3DLVY           DELIVERY
     C                     Z-ADDICDLVM    D3DLVM           DELIVERY
     C                     Z-ADDICDLVD    D3DLVD           DELIVERY
     C                     MOVE *ALL'-'   D3LINE
     C                     MOVE ICINVO    D3INVO           INVOICE
     C                     Z-ADDICODHZ    D3ODHZ
     C                     Z-ADDICSURY    D3ODSU
     C                     Z-ADDICSPHZ    D3SIHZ
     C                     Z-ADDICSURT    D3SURT
     C                     Z-ADDICIFHZ    D3IFHZ
     C                     Z-ADDICIFSU    D3IFSU
     C                     MOVE *BLANK    D3MSG
     C                     MOVE '#DSP3   '@STEP
     C                     ENDIF
     C                     ENDSR
      *===============================================================
      *  画面３　表示
      *===============================================================
     C           #DSP3     BEGSR
     C*
     C                     EXFMTDSP03
     C                     SETOF                     212223
     C                     SETOF                     24  99
     C                     MOVE *BLANK    D3MSG
     C*
     C                     MOVE '#CHK3   '@STEP
     C*  < F3 >  GO BACK
     C           *INKC     IFEQ *ON
     C                     Z-ADDCHGRRN    RRN
     C                     MOVE '#DSP2   '@STEP
     C                     ENDIF
     C*  < F5 >  UPDAT
     C           *INKE     IFEQ *ON
     C                     MOVE '#CHK3U  '@STEP
     C                     ENDIF
     C*
     C                     ENDSR
      *===============================================================
      *
      *===============================================================
     C           #CHK3     BEGSR
      *-----------*
      * Q'TY/BOX  *
      *-----------*
     C           D3SYOS    IFEQ 0
     C                     SETON                     2199
     C                     MOVELER,7      D3MSG
     C                     END
      *----------*
      * BOX Q'TY *
      *----------*
     C  N99      D3MAIS    IFEQ 0
     C                     SETON                     2299
     C                     MOVELER,8      D3MSG
     C                     ENDIF
      *
     C           D3SYOS    MULT D3MAIS    D3SURY
      *
     C           D3INVO    IFNE *BLANK                     INVOICE
     C           D3SURY    ANDLTICSURT
     C                     SETON                     212299
     C                     MOVELER,13     D3MSG
     C                     ENDIF
      *----------*
     C  N99      D3HANY    IFNE 'S'
     C           D3HANY    ANDNE'A'
     C                     SETON                     2399
     C                     MOVELER,13     D3MSG
     C                     ENDIF
      *----------*
     C           D3HANY    IFEQ 'S'
     C           D3DLVY    IFEQ 0                          DELIVERY
     C           D3DLVM    ANDEQ0                          DELIVERY
     C           D3DLVD    ANDEQ0                          DELIVERY
     C                     ELSE
     C                     SETON                     2499
     C                     MOVELER,13     D3MSG
     C                     ENDIF
     C                     ENDIF
      *----------*
     C           D3HANY    IFEQ 'A'
     C*********  D3DLVY                                    DELIVERY
     C           D3DLVM    IFLT 1                          DELIVERY
     C           D3DLVM    ORGT 12                         DELIVERY
     C                     SETON                     2499
     C                     MOVELER,13     D3MSG
     C                     ENDIF
     C           D3DLVD    IFLT 1                          DELIVERY
     C           D3DLVD    ORGT 31                         DELIVERY
     C                     SETON                     2499
     C                     MOVELER,13     D3MSG
     C                     ENDIF
     C                     ENDIF
      *
     C           *IN99     IFEQ *OFF
     C           @STEP     ANDEQ'#CHK3U  '
     C                     MOVE '#UPDAT  '@STEP
     C                     ELSE
     C                     MOVE '#DSP3   '@STEP
     C                     ENDIF
     C                     ENDSR
      *===============================================================
      *
      *===============================================================
     C           #UPDAT    BEGSR
     C                     EXCPTDT
      *--------*
      * UPDATE *
      *--------*
     C           KEY02     CHAINGDGPL16              92
     C                     MOVE *BLANK    ICSKJY
     C                     Z-ADD0         ICSKHZ
     C                     Z-ADD*DATE     ICKOHZ
     C                     TIME           ICKOTI
     C                     MOVEL@@USID    ICKOME
      *
     C           S1CHG     IFEQ '0'                        :DELET
     C                     MOVE 'C'       ICIFMK
     C                     ENDIF
      *
     C           S1CHG     IFEQ '1'                        :UPDATE
     C                     Z-ADDD3SYOS    ICSYOS
     C                     Z-ADDD3MAIS    ICMAIS
     C           ICMAIS    MULT ICSYOS    ICSURY
     C                     MOVE *BLANK    ICIFMK
>>>> C           ICIFSU    IFGE ICSURY
     C                     MOVE '*'       ICIFMK
     C                     ENDIF
     C                     MOVE D3HANY    ICHANY
     C                     Z-ADDD3DLVY    ICDLVY           DELIVERY
     C                     Z-ADDD3DLVM    ICDLVM           DELIVERY
     C                     Z-ADDD3DLVD    ICDLVD           DELIVERY
     C                     ENDIF
      *
     C  N92                UPDATGDGPL161
     C                     SETON                     U1
     C                     MOVE '#SFSET  '@STEP
      *
     C                     ENDSR
      *===============================================================
      *===============================================================
      *-------------*
      * OUTPUT FILE *
      *-------------*
     OGDGWP23 E                DT
     O                         D3UPCD
     O                         D3ODR1
     O                         D3ODR2
     O                         D3ODR3
     O                         ICSEIH
     O                         ICITEM
     O                         S1HIN1
     O                         S1HIN2
     O                         S1HIN3
     O                         ICSYOS
     O                         ICMAIS
     O                         ICSURY
** MSG
E-01 INPUT ORDER NUMBER.
E-02 THIS DATA IS NOT IN THE DAYLY ORDER DATA FILE.
E-03 INPUT  '0' OR '1'
E-04 SELECT CHANGE DATA.
E-05 SELECT ONLY ONE.
E-06 THIS DATA ALREADY HAS BEEN CANCELLED.
E-07 INPUT Q'TY PAR BOX.
E-08 INPUT BOX Q'TY.
E-09 INPUT PART NUMBER.
E-10 PART NUMBER ERROR.
E-11 THE DATA IS ALREADY COMPLETED.
E-12 THIS ITEM NO. HAS BEEN ALREADY USED.
E-13 INPUT DATA IS NOT CORRECT.
E-14 THIS ORDER NO. HAS BEEN ALREADY USED.
E-15 ORDER NO. MORE THAN 50 IS AVAILABLE FOR ORDER ADDITION.
E-16 ITEM NO. MORE THAN 90001 IS AVAILABE FOR ITEM ADDITION.
E-17 NOT INPUT ORDER NO. OF ADDITIONAL ORDER.
E-18 NOT INPUT ITEM NO. OF ADDITIONAL ORDER.
