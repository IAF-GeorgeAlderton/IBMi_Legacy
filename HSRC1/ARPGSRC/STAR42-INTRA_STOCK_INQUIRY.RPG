     H            Y.
     F** STAR42 **************************************
     F* INQ INTRA STOCK DATA
     F*    SAKAKI.        2020.02.14                 *
     F************************************************
     FSTAPW42 CF  E                    WORKSTN
     F                                        RRN   KSFILE SFL
     F                                              KINFDS INFDS
     FSTAPL10 IF  E           K        DISK
     FSTAPL23 IF  E           K        DISK
      *
     E                    ER      1  11 65
      *
     I            DS
     I                                        1  20 S1BARC
     I                                        1   1 S1IKBN
     I                                        6   8 S1VLOT
     I                                        8   8 S1PAGT
     I                                        9  10 S1VPAG
     I                                        9  11 S1PROC
     I                                       12  14 S1PAGE
     I                                       13  16 S1LOT
      *
     I            DS
     I                                        1  20 S2BAR1
     I                                        9  11 S#PROC
     I                                       12  14 S#PAGE
      *
     I            DS
     I                                        1  20 S2BAR2
     I                                        9  11 S3PROC
     I                                       12  14 S3PAGE
      *
     I            DS
     I                                        1   6 S1ATK
     I                                        1   1 S1ATK1
     I                                        2   3 S1ATK2
     I                                        4   5 S1ATK3
     I                                        6   6 S1ATK4
      *
     I            DS
     I                                        1  140WTIME
     I                                        1   60WTITM
     I                                        1   20TIMHH
     I                                        3   40TIMMM
     I                                        5   60TIMSS
     I                                        7  140WTIHZ
     I                                        7  100WTIYY
     I                                       11  120WTIMM
     I                                       13  140WTIDD
      *
     I            DS
     I                                        1   60S2CRTI
     I                                        1   2 S2CRTH
     I                                        3   4 S2CRTM
     I                                        5   6 S2CRTS
      *
     I            DS
     I                                        1  140S@IN
     I                                        1   80S@INHZ
     I                                        9  140S@INTI
      *
     I            DS
     I                                        1  140S@OU
     I                                        1   80S@OUHZ
     I                                        9  140S@OUTI
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 ##USER
     I                                      264 269 W#JBNO
      *
     IINFDS       DS
     I                                    B 370 3710$CUR
     I                                    B 378 3790$POS
      *
      *----------------------------------------------------*
      * PLIST                                              *
      *----------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1PROC  3
     C                     PARM           P1ATK   5
     C                     PARM           P1ATK1  1
     C                     PARM           P1ATK2  2
     C                     PARM           P1ATK3  2
     C                     PARM           P1ATK4  1
     C                     PARM           P1KBN   1
      *
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INIT                                               *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     TIME           WTIME
     C                     MOVEL'01'      DSPSW   2
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
     C                     CALL 'APLR30'
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P@SHNA 14
     C                     MOVELP@SHNA    C1SHN
     C                     MOVELP1PROC    C1PROC
     C                     MOVELP1ATK     C1ATK
     C           KEYA      KLIST
     C                     KFLD           K1SHN1  5
     C                     KFLD           K1SHN2  5
     C                     KFLD           K1SHN3  2
     C                     KFLD           K1ATK1  1
     C                     KFLD           K1ATK2  2
     C                     KFLD           K1ATK3  2
     C                     KFLD           K1ATK4  1
     C                     MOVELP1SHN1    K1SHN1
     C                     MOVELP1SHN2    K1SHN2
     C                     MOVELP1SHN3    K1SHN3
     C                     MOVELP1ATK1    K1ATK1
     C                     MOVELP1ATK2    K1ATK2
     C                     MOVELP1ATK3    K1ATK3
     C                     MOVELP1ATK4    K1ATK4
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * CONTROL                                            *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      * INQ                                                *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     Z-ADD1         WKPAGE  30
     C                     EXSR #CLR
      *
     C                     SETOF                     8166
     C           KEYA      SETLLSTAPL101
     C           KEYA      READESTAPL101                 81
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C           KEYA      READESTAPL101                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     MOVE '02'      DSPSW
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * SFL                                                *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C           CTRX      IFEQ 0
     C                     SETON                     72
     C                     SETON                     99
     C                     MOVELER,1      D9ERR
     C                     ELSE
     C                     SETON                     7273
     C                     ENDIF
      *
     C                     WRITESTAPW429
     C                     EXFMTSFLCTL
     C                     SETOF                     7273
     C                     SETOF                     3199
     C                     MOVEL*BLANK    D9ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVE '99'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           CTRX      IFEQ 0
     C                     GOTO ESB220
     C                     ENDIF
      * F12
     C           *IN12     IFEQ '1'
     C                     EXSR #SB999
     C                     CALL 'STAR43'
     C                     PARM           P1SHN1  5
     C                     PARM           P1SHN2  5
     C                     PARM           P1SHN3  2
     C                     PARM           P1PROC  3
     C                     PARM           P1ATK   5
     C                     PARM           P1ATK1  1
     C                     PARM           P1ATK2  2
     C                     PARM           P1ATK3  2
     C                     PARM           P1ATK4  1
     C                     PARM           P1BARC 20
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
      * ROLLDOWN/PAGEUP *
      *-----------------*
     C           *IN52     IFEQ '1'
     C*                    ADD  1         CTRX
      * 1ST. PAGE
     C           WKPAGE    IFEQ 1
     C                     GOTO ESB220
     C                     ENDIF
      *-----------------*
     C           *IN81     IFEQ '1'
     C                     SETOF                     81
     C           KEYA      SETGTSTAPL101
     C           KEYA      REDPESTAPL101                 81
     C                     SUB  1         CTRX
     C                     ENDIF
      *
     C                     ADD  15        CTRX
      *                         L--表示行数
     C                     SETOF                     6627
      *
     C           *IN81     DOWEQ'0'
     C           *IN27     ANDEQ'0'
     C                     EXSR #READP
     C           KEYA      REDPESTAPL101                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXTP
     C                     ENDDO
      *
     C                     Z-ADD0         CTRX    40
      *
     C           *IN81     IFEQ '1'
     C           KEYA      SETLLSTAPL101
     C           KEYA      READESTAPL101                 81
     C                     ENDIF
      *
     C                     EXSR #CLR
     C                     SETOF                     8166
      *
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C           KEYA      READESTAPL101                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     SUB  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      *--------------------*
      * ROLL-UP            *
      *--------------------*
     C           *IN51     IFEQ '1'
     C           *IN81     ANDEQ'0'
      *
     C                     EXSR #CLR
      *
     C                     SETOF                     6681
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #READ
     C           KEYA      READESTAPL101                 81
     C                     ENDDO
      * NEXT
     C                     SETOF                     66
     C           *IN81     DOWEQ'0'
     C           *IN66     ANDEQ'0'
     C                     EXSR #NEXT
     C                     ENDDO
      *
     C                     ADD  1         WKPAGE
     C                     GOTO ESB220
     C                     ENDIF
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * READ                                               *
      *----------------------------------------------------*
     CSR         #READ     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREAD
     C                     ENDIF
      *
     C                     EXSR #EDIT
     C                     ADD  1         RRN
     C                     ADD  1         @RRN
     C                     ADD  1         CTRX
     C                     WRITESFL
      *
     C           CTRX      IFEQ 15
     C                     SETON                       66
     C                     ENDIF
      *
     CSR         EREAD     ENDSR
      *----------------------------------------------------*
      * READP                                              *
      *----------------------------------------------------*
     CSR         #READP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ *BLANK
     C                     GOTO EREADP
     C                     ENDIF
      *
     C                     SUB  1         CTRX           27
      *
     CSR         EREADP    ENDSR
      *----------------------------------------------------*
      * SELECT                                             *
      *----------------------------------------------------*
     CSR         #SELEC    BEGSR
      *
     C           S1SKJY    IFEQ 'D'
     C           S1SKHZ    ANDLE*DATE
     C                     GOTO ESELEC
     C                     ENDIF
     C*
     C* NORMAL STOCK ONLY
     C           P1KBN     IFEQ '1'
     C*
     C                     SELEC
     C*   PLASTIC
     C           S1IKBN    WHEQ 'A'
     C           S1IKBN    OREQ 'R'
     C*  A888899X01050C. <- IF X IS NOT DIGIT IT IS TEMP. KANBAN
     C           S1PAGT    IFGE '0'
     C           S1PAGT    ANDLE'9'
     C                     ELSE
     C                     GOTO ESELEC
     C                     ENDIF
     C*   INTRA
     C           S1IKBN    WHGE '0'
     C           S1IKBN    ANDLE'9'
     C                     MOVE S1PAGE    W1PAGE  30
     C*  IF PAGE NO IS 300 OR MORE, IT IS TEMP. KANBAN
     C           W1PAGE    IFGE 300
     C                     GOTO ESELEC
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     ENDIF
      *
     C                     MOVEL'1'       WKGET
      *
     CSR         ESELEC    ENDSR
      *----------------------------------------------------*
      * CLEAR                                              *
      *----------------------------------------------------*
     CSR         #CLR      BEGSR
      *
     C                     SETON                     71
     C                     WRITESFLCTL
     C                     SETOF                     7166
     C                     Z-ADD0         RRN     30
     C                     Z-ADD0         @RRN    40
     C                     Z-ADD0         CTRX    40
     C                     Z-ADD1         @SFRC1
      *
     CSR         ECLR      ENDSR
      *----------------------------------------------------*
      * EDIT                                               *
      *----------------------------------------------------*
     CSR         #EDIT     BEGSR
      *
     C                     MOVELS1BARC    S2BARC
      *
     C                     MOVEL*BLANK    S2PAGE
     C                     MOVELS1PAGE    S2PAGE
      *
     C* PLASTIC
     C           S1IKBN    IFEQ 'A'
     C           S1IKBN    OREQ 'R'
     C           S1VLOT    CAT  '-':0     S2PAGE
     C           S2PAGE    CAT  S1VPAG:0  S2PAGE
     C                     ENDIF
      * PT/BPT
     C           S1IKBN    IFEQ 'I'
     C                     MOVELS1LOT     S2PAGE
     C                     ENDIF
      *
     C                     Z-ADD0         S2INDT
     C                     Z-ADD0         S2OUDT
     C                     Z-ADD0         S2GET   10
     C                     MOVEL*BLANK    S2INTI
     C                     MOVEL*BLANK    S2OUTI
     C                     Z-ADD0         S@IN
     C                     Z-ADD0         S@OU
     C                     MOVELP1SHN1    K1SHN1
     C                     MOVELP1SHN2    K1SHN2
     C                     MOVELP1SHN3    K1SHN3
     C                     MOVELP1ATK1    K1ATK1
     C                     MOVELP1ATK2    K1ATK2
     C                     MOVELP1ATK3    K1ATK3
     C                     MOVELP1ATK4    K1ATK4
     C           KEYA      SETGTSTAPL23
     C           KEYA      REDPESTAPL23                  46
     C           *IN46     DOWEQ'0'
     C           S2GET     ANDLT2
     C*
1    C           S2SKJY    IFEQ 'D'
|    C           S2SKHZ    ANDLE*DATE
|    C           S2ERCD    ORNE *BLANK
1    C                     ELSE
|    C*
     C* IN
     C                     SELEC
     C           S2SYOR    WHEQ '1'
     C*
 2   C           S1BARC    IFEQ S2BAR1
 |3  C           S2INDT    IFEQ 0
 ||  C                     ADD  1         S2GET
 ||  C                     Z-ADDS2CRHZ    S@INHZ
 ||  C                     MOVELS2CRTH    S@INTI
 ||  C                     Z-ADDS2CRHZ    S2INDT
 ||  C                     MOVELS2CRTH    S2INTI
 ||  C           S2INTI    CAT  ':':0     S2INTI
 ||  C           S2INTI    CAT  S2CRTM:0  S2INTI
 |3  C                     ENDIF
 2   C                     ENDIF
     C* OUT
     C           S2SYOR    WHEQ '2'
     C*
 2   C           S1BARC    IFEQ S2BAR2
 |3  C           S2OUDT    IFEQ 0
 ||  C                     ADD  1         S2GET
 ||  C                     Z-ADDS2CRHZ    S@OUHZ
 ||  C                     MOVELS2CRTH    S@OUTI
 ||  C                     Z-ADDS2CRHZ    S2OUDT
 ||  C                     MOVELS2CRTH    S2OUTI
 ||  C           S2OUTI    CAT  ':':0     S2OUTI
 ||  C           S2OUTI    CAT  S2CRTM:0  S2OUTI
 |3  C                     ENDIF
 2   C                     ENDIF
     C*
     C                     ENDSL
     C*
     C                     ENDIF
     C           KEYA      REDPESTAPL23                  46
     C                     ENDDO
     C                     Z-ADDS1TUHK    S2TUHK
     C           S@IN      IFGT S@OU
     C                     Z-ADD0         S2OUDT
     C                     MOVEL*BLANK    S2OUTI
     C                     ENDIF
      *
     CSR         EEDIT     ENDSR
      *----------------------------------------------------*
      * NEXT                                               *
      *----------------------------------------------------*
     CSR         #NEXT     BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXT
     C                     ENDIF
      *
     C           KEYA      READESTAPL101                 81
      *
     CSR         ENEXT     ENDSR
      *----------------------------------------------------*
      * PRV                                                *
      *----------------------------------------------------*
     CSR         #NEXTP    BEGSR
      *
     C                     MOVEL*BLANK    WKGET   1
     C                     EXSR #SELEC
     C           WKGET     IFEQ '1'
     C                     SETON                     66
     C                     GOTO ENEXTP
     C                     ENDIF
      *
     C           KEYA      REDPESTAPL101                 81
      *
     CSR         ENEXTP    ENDSR
      *----------------------------------------------------*
      *   戻り値のセット                                 *
      *----------------------------------------------------*
     CSR         #SB999    BEGSR
      *
     C                     MOVEL*BLANK    P1BARC
      *カーソル位置の取得
     C           $CUR      DIV  256       S@SLIN
     C                     MVR            S@SCLM
     C           S@SLIN    SUB  6         Y       30
     C           Y         ADD  1         X       30
     C           X         CHAINSFL                  25
     C           *IN25     IFEQ '0'
     C***                  MOVELS2PAGE    P1PAGE
     C                     MOVELS2BARC    P1BARC
     C                     ENDIF
     CSR         ESB999    ENDSR
**
ER-1 NO DATA.
ER-2 DETAIL 'M'.
