     C           KEYT61    READEGCQPL111                 81
     C           *IN81     IFEQ '0'
     C                     Z-ADDHYMD8     WKHYMD
     C                     MOVE 'D'       T6SKJY
     C                     MOVE WKHY      T6SKYY
     C                     MOVE WKHM      T6SKMM
     C                     MOVE WKHD      T6SKDD
     C                     MOVE WKHY      T6KOYY
     C                     MOVE WKHM      T6KOMM
     C                     MOVE WKHD      T6KODD
     C                     MOVE TIMHH     T6KOHH
     C                     MOVE TIMSS     T6KOSS
     C                     MOVELUSER      T6KOME
     C                     UPDATGCQPL111
     C                     END
     C  N81                END
     CSR         $S500E    ENDSR
      *----------------------------------------------------*
      *   DIE KANBAN M/F ADD                               *
      *----------------------------------------------------*
     CSR         $SB520    BEGSR
     C                     Z-ADDHYMD8     WKHYMD
     C                     MOVE *BLANK    T6SKJY
     C                     Z-ADD0         T6SKYY
     C                     Z-ADD0         T6SKMM
     C                     Z-ADD0         T6SKDD
     C                     MOVE WKHY      T6KOYY
     C                     MOVE WKHM      T6KOMM
     C                     MOVE WKHD      T6KODD
     C                     MOVE TIMHH     T6KOHH
     C                     MOVE TIMSS     T6KOSS
     C                     MOVELUSER      T6KOME
      *
     C                     MOVE @KAT1     T6KAT1
     C                     MOVE @KAT2     T6KAT2
     C                     MOVE @KAT3     T6KAT3
     C                     MOVE @TKR1     T6TKR1
     C                     MOVE @TKR2     T6TKR2
     C                     MOVE @TKR3     T6TKR3
     C                     MOVE @TKR4     T6TKR4
     C                     MOVE @TKR5     T6TKR5
     C                     Z-ADD@HAHY     T6HAYY
     C                     Z-ADD@HAHM     T6HAMM
     C                     Z-ADD@HAHD     T6HADD
     C                     Z-ADD@TUHY     T6TUYY
     C                     Z-ADD@TUHM     T6TUMM
     C                     Z-ADD@TUHD     T6TUDD
     C                     Z-ADD@KALL     T6KALL
     C                     Z-ADD@KMIN     T6KMIN
     C                     Z-ADD@KMAX     T6KMAX
     C                     Z-ADD@SRMS     T6SRMS
     C                     Z-ADD@MAIS     T6MAIS
     C                     MOVEL@KSKB     T6KSKB
     C                     Z-ADD@SRYO     T6SRYO
     C                     MOVE @SETI     T6SETI
     C                     Z-ADD@KOCD1    T6KOCD
     C                     MOVEL@KOTP     T6KOTP
     C                     MOVE @KOBD     T6KOBD
     C                     Z-ADD@LTIM     T6LTIM
     C                     Z-ADD@SYOS     T6SYOS
     C                     Z-ADD@KIJN     T6KIJN
     C                     Z-ADD@KELT     T6KELT
     C                     Z-ADD@KIHY     T6KIYY
     C                     Z-ADD@KIHM     T6KIMM
     C                     Z-ADD@KIHD     T6KIDD
      *
     C                     MOVE WKDOUT    T6DOUT
     C                     MOVE WKKOUT    T6KOUT
     C                     MOVE WKKSHK    T6KSHK
     C                     MOVE WKALHK    T6ALHK
     C                     MOVE WKMXHK    T6MXHK
      *
     C                     WRITEGCQPL111
      *
     CSR         $S520E    ENDSR
      *----------------------------------------------------*
      *   DIE KANBAN M/F READ                              *
      *----------------------------------------------------*
     CSR         $SB900    BEGSR
      *
     C                     Z-ADD9         T6KSKB
     C           KEYT61    SETLLGCQPL111
     C           KEYT61    READEGCQPL111                 81
     C           *IN81     IFEQ '0'
     C           T6SKJY    IFEQ 'D'
     C           T6SKHZ    ANDLEHYMD8
     C                     SETON                       81
     C                     END
     C                     END
     CSR         $S900E    ENDSR
      *----------------------------------------------------*
      *   SETTING M/F    READ                              *
      *----------------------------------------------------*
     CSR         $SB910    BEGSR
      *
     C           KEYA41    CHAINAABPL01              21
     C           *IN21     IFEQ '0'
     C           A4SKJY    IFEQ 'D'
     C           A4SKHZ    ANDLEHYMD8
     C                     SETON                       21
     C                     END
     C                     END
     CSR         $S910E    ENDSR
      *----------------------------------------------------*
      *   CALUCULATION                                     *
      *----------------------------------------------------*
     CSR         $SB920    BEGSR
      * REASON CODE SET
     C           @KSKBN    IFEQ *BLANK
     C           WKMAIS    IFNE 0
     C           @SETI     IFGE '01'
     C           @SETI     ANDLE'49'
      *
     C                     MOVE '*'       @KSKBN
     C           @KSKB     IFEQ 9
     C                     Z-ADD0         WKKSKB
     C                     ELSE
     C           @KSKB     ADD  1         WKKSKB
     C                     END
      *
     C                     ELSE
     C                     Z-ADDW6KSKB    WKKSKB
     C                     END
     C                     END
     C                     Z-ADDWKKSKB    @KSKB
     C                     END
      * KANBAN SHEETS SET
     C                     Z-ADD0         WKSRYO
     C                     Z-ADD0         WKKOSU
     C**         @SRYO     MULT 4         WKSRYO
     C**         @SYOS     IFNE 0
     C**         WKSRYO    DIV  @SYOS     WKKOSU
     C**                   ADD  0.9       WKKOSU
     C**                   END
      * 2005.09.29
     C                     Z-ADD0         WKSU1  114
     C                     Z-ADD0         WKSU2  114
     C                     Z-ADD0         WKSU3  114
     C                     Z-ADD0         WKSU4  114
     C                     Z-ADD0         WKSU5  114
     C                     Z-ADD0         WKSU6  114
     C                     Z-ADD0         WKSU7  114
     C                     Z-ADD0         WKSU8  114
     C*******    @SRYO     MULT 1.25      WKSU1
     C*******    @SYOS     MULT 20        WKSU2
     C**********           Z-ADD30        WKSU3
     C********** 50        MULT 1.2       WKSU3
     C*******    42        MULT 1.2       WKSU3
     C*******    WKSU1     DIV  WKSU2     WKSU4
     C*******    WKSU3     MULT WKSU4     WKSU5
     C*******    @SRYO     DIV  @SYOS     WKSU6
     C*******    WKSU5     ADD  WKSU6     WKSU7
     C*******    WKSU7     ADD  0.9       WKKOSU
     C*===============================================================*
     C*    月間必要数×安全係数                                     *
     C*  (( -------------------- )×( L/T×補正係数))             *
     C*     収容数×平均稼働日                                      *
     C*                                                               *
     C*                       月間必要数                            *
     C*                  ＋( ----------×在庫係数)＝かんばん枚数*
     C*                         収容数                              *
     C*                                                               *
     C*   ※かんばん枚数は小数点以下切り上げ                        *
     C*===============================================================*
     C           @SRYO     MULT 1.25      WKSU1
     C           @SYOS     MULT 20        WKSU2
     C           WKSU1     DIV  WKSU2     WKSU3
     C           34        MULT 1.1       WKSU4
     C           WKSU3     MULT WKSU4     WKSU5
     C           @SRYO     DIV  @SYOS     WKSU6
     C           WKSU6     MULT 0.5       WKSU7
     C           WKSU5     ADD  WKSU7     WKSU8
     C*****      WKSU8     ADD  0.9       WKKOSU
     C           WKSU8     ADD  0.9999    WKKOSU
      *
     C                     Z-ADDWKKOSU    @MAIS
      *
     C                     SETOF                     35
TCHK1C*          T6KAT1    LOKUP$TYU                     35
TCHK1C           @KAT1     LOKUP$TYU                     35
     C           *IN35     IFEQ '1'
     C           @MAIS     IFLT 2
     C**********           Z-ADD2         @MAIS
     C                     Z-ADD1         @MAIS
     C                     END
     C                     ELSE
     C           @MAIS     IFLT 1
     C                     Z-ADD1         @MAIS
     C                     END
     C                     END
      *
     C           WKMAIS    IFEQ *ZERO
     C                     Z-ADD@MAIS     @KMAX
     C                     GOTO #RTN1
     C                     END
      *
TCHK1C*          T6DOUT    IFNE *BLANK
TCHK1C           WKDOUT    IFNE *BLANK
     C                     Z-ADDWKALL     @KALL
     C                     Z-ADDWKMAX     @KMIN
     C                     END
     C                     MOVE @MAIS     @KMAX
      *
     C           WKHY      IFNE @TUHY
     C           WKHY      SUB  @TUHY     WKYY
     C           WKYY      IFLE 01
     C                     Z-ADDWKHM      WKMM
     C                     Z-ADDWKHD      WKDD
     C           WKDD      CABLE@TUHD     #PAS1
     C                     END
     C           @KALL     CABLT@KMIN     #PAS1
     C           @KMIN     CABGE30        #PAS1
     C           @SETI     IFGE '01'
     C           @SETI     ANDLE'49'
     C                     GOTO #PAS1
     C                     END
     C                     SETON                       99
     C                     MOVE $MSG,22   @MSG
     C                     GOTO $S920E
     C                     END
     C           #PAS1     TAG
     C                     Z-ADD0         @SRMS
     C           WKDOUT    IFNE *BLANK
     C                     MOVE *BLANK    WKKSHK
     C                     Z-ADD0         WKALHK
     C                     Z-ADD0         WKMXHK
     C                     END
      *
     C           W6KSKB    IFEQ @KSKB
     C           WKDOUT    CABEQ'Y'       #RTN1
     C           WKKSHK    CABEQ*BLANK    #RTN1
     C                     Z-ADDWKALHK    WKKALL
     C                     Z-ADDWKMXHK    WKMAX
     C                     ELSE
     C           WKKSHK    IFNE *BLANK
     C                     Z-ADDWKALHK    WKKALL
     C                     Z-ADDWKMXHK    WKMAX
     C                     END
     C                     END
     C                     Z-ADD0         @KALL
     C                     Z-ADD0         @KMIN
     C           WKKALL    IFGT WKMAX
     C           WKKALL    SUB  WKMAX     @SRMS
     C                     END
     C           #RTN1     TAG
      *
     C           @SETI     IFGE '01'
     C           @SETI     ANDLE'49'
     C           @KBN      IFEQ '1'
     C                     Z-ADD*DATE     @TUHZ
     C                     END
     C                     END
      *
      * PUT CMD-5
     C           *IN05     IFEQ '1'
      *
     C           W6KSKB    IFEQ @KSKB
     C           WKDOUT    CABEQ'Y'       #RTN2
     C           WKKSHK    CABEQ*BLANK    #RTN2
     C                     END
     C           WKDOUT    IFNE *BLANK
     C                     MOVEL'H'       WKKSHK
     C                     Z-ADDWKKALL    WKALHK
     C                     Z-ADDWKMAX     WKMXHK
     C                     END
      *
     C           #RTN2     TAG
     C           WKMAIS    IFNE *ZERO
     C           W6KSKB    IFEQ @KSKB
     C           @KMIN     IFEQ @KMAX
     C                     GOTO $S920E
     C                     END
     C                     END
     C                     END
     C                     Z-ADD*DATE     @TUHZ
     C                     MOVE *BLANK    WKDOUT
     C                     MOVEL'Y'       WKKOUT
      *
     C                     END
      *
     CSR         $S920E    ENDSR
