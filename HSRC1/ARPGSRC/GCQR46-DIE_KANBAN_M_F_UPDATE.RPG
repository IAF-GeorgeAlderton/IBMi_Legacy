     C                     MOVE *BLANK    DSPSW2  1
     C                     MOVE *BLANK    WKKSHK  1
     C                     MOVE *BLANK    WKKOUT  1
     C                     MOVE *BLANK    WKDOUT  1
     C                     Z-ADD0         WKALHK  30
     C                     Z-ADD0         WKMXHK  30
     C                     Z-ADD0         W6KSKB  10
     C                     Z-ADD8990      @KOCD
     CSR         $S100S    ENDSR
      *
      *----------------------------------------------------*
      *   MAIN  PROCESS                                    *
      *----------------------------------------------------*
     CSR         $SB200    BEGSR
     C                     MOVE '1'       DSPSW1
     C                     MOVE '0'       DSPSW2
     C           *IN01     DOWEQ'0'
     C           DSPSW1    ANDEQ'1'
     C                     EXSR $SB210
     C                     END
      *
     C           *IN01     DOWEQ'0'
     C           *IN03     ANDEQ'0'
     C           *IN05     ANDEQ'0'
     C           DSPSW2    ANDEQ'1'
     C                     EXSR $SB220
     C                     END
     CSR         $S200E    ENDSR
      *----------------------------------------------------*
      *   FIRST DISPLAY  PROCESS (GCQPW461)                *
      *----------------------------------------------------*
     CSR         $SB210    BEGSR
     C                     EXFMTGCQPW461
      * PUT CMD-1
     C           *IN01     IFEQ '1'
