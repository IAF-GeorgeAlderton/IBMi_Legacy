     CSR         $SB100    BEGSR
     C                     TIME           TIME
     C                     Z-ADD*DATE     HYMD8   80
     C                     MOVE HYMD8     WKHYMD
     C                     MOVEA'00000000'*IN,11
     C                     SETOF                     1999
     C                     Z-ADD0         WKALL   20
     C                     Z-ADD0         WKMAX   30
     C                     Z-ADD0         WKKALL  30
     C                     Z-ADD0         WKYY    40
     C                     Z-ADD0         WKMM    20
     C                     Z-ADD0         WKDD    20
     C                     Z-ADD0         WKKSKB  10
     C                     Z-ADD0         WKSRYO 102
     C                     Z-ADD0         WKKOSU 102
     C                     Z-ADD0         WKMAIS  20
