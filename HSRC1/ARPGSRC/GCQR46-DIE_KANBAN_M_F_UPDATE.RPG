     C                     END
     C                     SETOF                     111213
     C                     SETOF                     149915
     C                     MOVE *BLANK    @MSG
      * ITEM CHECK
     C           @KBN      IFEQ *BLANK
     C                     SETON                     1199
     C                     MOVEL$MSG,1    @MSG
     C                     GOTO $S210E
     C                     END
     C           @KBN      IFNE '0'
     C           @KBN      ANDNE'1'
     C           @KBN      ANDNE'2'
     C                     SETON                     1199
     C                     MOVEL$MSG,2    @MSG
     C                     GOTO $S210E
     C                     END
      *
     C           @TKR1     IFEQ *BLANK
     C           @TKR2     ANDEQ*BLANK
     C           @TKR3     ANDEQ*BLANK
     C           @TKR4     ANDEQ*BLANK
     C           @TKR5     ANDEQ*BLANK
     C                     SETON                     1299
     C                     MOVEL$MSG,3    @MSG
     C                     GOTO $S210E
     C                     END
     C           @TKR1     IFNE '6'
     C                     SETON                     1599
     C                     MOVEL$MSG,4    @MSG
