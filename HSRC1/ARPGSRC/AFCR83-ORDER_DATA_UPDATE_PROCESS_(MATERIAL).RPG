     F*  H.AMANO 2001.08.15                                *
     F*     RETRIEVE WEIGHT FROM IZAPL01 IN CASE OF ADDITION
     F*                                                    *
     F******************************************** AFCR83 **
     FAFCPW83 CF  E                    WORKSTN
     FAFCPL91 UF  E           K        DISK                      A
     FFGBPL01 IF  E           K        DISK
     FIZAPL01 IF  E           K        DISK
     FAFCNP90 UF  E           K        DISK                      A
     E                    #NO        10  1
     E                    #SH        10 15
     E                    #ZK        10  5 2
     E                    #ZE        10  4
     E                    #MA        10  3 0
     E                    #SY        10  6 0
     E                    ER      1  30 60
     E                    KBN     1   3  1   CMT     9
     I            DS
     I                                        1   80C9SKHZ
     I                                        1   40C9SKYY
     I                                        5   60C9SKMM
     I                                        7   80C9SKDD
     I            DS
     I                                        1   80C9KOHZ
     I                                        1   40C9KOYY
     I                                        5   60C9KOMM
     I                                        7   80C9KODD
     I            DS
     I                                        1   9 C9ERR
     I                                        1   1 C9ERR1
     I                                        2   2 C9ERR2
     I                                        3   3 C9ERR3
     I                                        4   4 C9ERR4
     I                                        5   5 C9ERR5
     I                                        6   6 C9ERR6
     I                                        7   7 C9ERR7
     I                                        8   8 C9ERR8
     I                                        9   9 C9ERR9
     I            DS
     I                                        1   80A2GSHZ
     I                                        1   40A2GSYY
     I                                        5   60A2GSMM
     I                                        7   80A2GSDD
     I* MATERIAL KANBAN MASTER
     I            DS
     I                                        1   80ZCSKHZ
     I                                        1   40ZCSKYY
     I                                        5   60ZCSKMM
     I                                        7   80ZCSKDD
     I* MATERIAL KANBAN MASTER
     I            DS
     I                                        1   80ZCSTHZ
     I                                        1   40ZCSTYY
     I                                        5   60ZCSTMM
     I                                        7   80ZCSTDD
     I* MATERIAL KANBAN MASTER
     I            DS
     I                                        1   80ZCUKHZ
     I                                        1   40ZCUKYY
     I                                        5   60ZCUKMM
     I                                        7   80ZCUKDD
     I            DS
     I                                        1   60C9KOTI
     I                                        1   20C9KOHH
     I                                        3   40C9KOSS
     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
     I            DS
     I                                        1   80KDATE
     I                                        1   60KYYMM
     I            DS
     I                                        1  10 #NO
     I                                        1   1 @NO1
     I                                        2   2 @NO2
     I                                        3   3 @NO3
     I                                        4   4 @NO4
     I                                        5   5 @NO5
     I                                        6   6 @NO6
     I                                        7   7 @NO7
     I                                        8   8 @NO8
     I                                        9   9 @NO9
     I                                       10  10 @NO0
     I            DS
     I                                        1 150 #SH
     I                                        1  15 @ZAIS1
     I                                       16  30 @ZAIS2
     I                                       31  45 @ZAIS3
     I                                       46  60 @ZAIS4
     I                                       61  75 @ZAIS5
     I                                       76  90 @ZAIS6
     I                                       91 105 @ZAIS7
     I                                      106 120 @ZAIS8
     I                                      121 135 @ZAIS9
     I                                      136 150 @ZAIS0
     I            DS
     I                                        1  40 #ZE
     I                                        1   4 @ZETI1
     I                                        5   8 @ZETI2
     I                                        9  12 @ZETI3
     I                                       13  16 @ZETI4
     I                                       17  20 @ZETI5
     I                                       21  24 @ZETI6
     I                                       25  28 @ZETI7
     I                                       29  32 @ZETI8
     I                                       33  36 @ZETI9
     I                                       37  40 @ZETI0
     I            DS
     I                                        1  502#ZK
     I                                        1   52@ZAIK1
     I                                        6  102@ZAIK2
     I                                       11  152@ZAIK3
     I                                       16  202@ZAIK4
     I                                       21  252@ZAIK5
     I                                       26  302@ZAIK6
     I                                       31  352@ZAIK7
     I                                       36  402@ZAIK8
     I                                       41  452@ZAIK9
     I                                       46  502@ZAIK0
     I            DS
     I                                        1  300#MA
     I                                        1   30@MAIS1
     I                                        4   60@MAIS2
     I                                        7   90@MAIS3
     I                                       10  120@MAIS4
     I                                       13  150@MAIS5
     I                                       16  180@MAIS6
