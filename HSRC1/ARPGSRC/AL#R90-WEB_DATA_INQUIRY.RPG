     H            Y.
     F** AL#R90 *********************************************
     F*  INQ WEB DATA                                       *
     F*  ITS.    2015.05.29                                 *
JW1  F*  JW      2021.10.12 ADD F5 RUN                      *
     F*******************************************************
     FAL#PW90 CF  E                    WORKSTN
     E                    ER      1  20 60
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1ISS1  80
     C                     PARM           P1ISS2  80
     C                     PARM           P1SHI1  8
     C                     PARM           P1SHI2  8
     C                     PARM           P1SURT  9
     C                     PARM           P9CMD   2
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     TIME           SDATE
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVEL'01'      DSPSW   2
     C                     MOVEL*BLANK    P1ISS1
     C                     MOVEL*BLANK    P1ISS2
     C                     MOVEL*BLANK    P1SHI1
     C                     MOVEL*BLANK    P1SHI2
     C                     MOVEL*BLANK    P1SURT
     C                     MOVEL*BLANK    P9CMD
     C                     Z-ADD0         D1SHI1
     C                     Z-ADD0         D1SHI2
     C                     MOVEL*BLANK    D1SURT
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTAL#PW901
     C                     SETOF                     303132
     C                     SETOF                     333435
     C                     SETOF                     99
     C                     MOVEL*BLANK    D1ERR
      * F1: END
     C           *IN01     IFEQ '1'
     C                     MOVEL'01'      P9CMD
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      * ISSUE DATE
     C           D1ISS1    IFEQ 0
     C           D1SHI1    ANDEQ0
     C                     MOVELER,1      D1ERR
     C                     SETON                     313234
     C                     SETON                     3599
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1ISS2    IFNE 0
     C           D1ISS1    IFGT D1ISS2
     C                     MOVELER,2      D1ERR
     C                     SETON                     343599
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      * SHIP DATE
     C           D1SHI2    IFNE 0
     C           D1SHI1    IFGT D1SHI2
     C                     MOVELER,2      D1ERR
     C                     SETON                     313299
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      * IF NOEEROR...
     C                     MOVE D1ISS1    P1ISS1
     C                     MOVE D1ISS2    P1ISS2
     C                     MOVELD1SHI1    P1SHI1
     C                     MOVELD1SHI2    P1SHI2
     C                     MOVELD1SURT    P1SURT
     C**JW1                MOVEL'05'      P9CMD
JW1   * F5: RUN
     C           *IN05     IFEQ '1'
     C                     MOVEL'05'      P9CMD
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      * F7: DOWNLOAD
     C           *IN07     IFEQ '1'
     C                     MOVEL'07'      P9CMD
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
JW1   * ENTER KEY
     C                     MOVELER,3      D1ERR
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
** ER
E-01 ENTER ISSUE DATE OR SHIP DATE!
E-02 FROM DATE IS GREATER THAN TO!
PRESS F5 TO RUN...
E-04
E-05
E-06
