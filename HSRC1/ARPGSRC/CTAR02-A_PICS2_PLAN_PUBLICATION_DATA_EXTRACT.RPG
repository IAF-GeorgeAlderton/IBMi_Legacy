      *
     C           KEY       KLIST
     C                     KFLD           CISHN1
     C                     KFLD           CISHN2
     C                     KFLD           CISHN3
      *
     C                     Z-ADD*DATE     WUYMD
      *
     C           CISKJY    IFEQ 'D'
     C           CISKHZ    ANDLE*DATE
     C                     ELSE
      *
     C           WUYM      IFEQ CIKEYM
     C                     SETOF                     10
      *
     C*----------------------------------------*
     C*  ..平準化確定発注累積ファイル......  *
     C*----------------------------------------*
     C                     SETOF                     11
     C                     Z-ADD0         WSYOS   50
     C***                  Z-ADD0         WMKBA   20
     C                     Z-ADD0         WPROL   30
     C           KEY       CHAINCABPL011             11
     C           *IN11     IFEQ '0'
     C           C3SKJY    ANDEQ'D'
     C           C3SKHZ    ANDLE*DATE
     C                     SETON                     11
     C                     END
     C           *IN11     IFEQ '0'
     C                     Z-ADDC3SJSU    WSYOS
     C****                 Z-ADDC3MKBA    WMKBA
     C                     Z-ADDC3PROL    WPROL
     C* * *                END
      *
     C*----------------------*
     C*  ..マイナス箱数..  *
     C*----------------------*
     C           HMH,A     IFNE 0
     C                     SETON                     10
     C                     Z-SUBHMH,A     WHAKO   30
     C           WHAKO     MULT WSYOS     WBHAS   70
     C                     ADD  WBHAS     C3BHAS
     C                     END
      *
     C*--------------------*
     C*  ..プラス箱数..  *
     C*--------------------*
     C           HPH,A     IFNE 0
     C                     SETON                     10
     C                     Z-ADDHPH,A     WHAKO
      *
     C           WHAKO     MULT WSYOS     WBHAS   70
     C                     ADD  WBHAS     C3BHAS
      *
     C                     Z-ADD0         W@T1SU
     C                     EXSR #SET
     C                     ADD  W@T1SU    C3T1SU
      *
     C                     END
      *
     C           *IN10     IFEQ '1'
     C                     MOVE '*'       HZM,A
     C                     UPDATCTAPP011
     C                     END
      *
     C* * *      *IN11     IFEQ '0'
     C                     UPDATCABPL011
     C                     END
      *
     C                     END
     C                     END
      *-----------------------------------------------------
     C           #SET      BEGSR
      *
     C           C3BHAS    IFLE 0
     C                     GOTO ESET
     C                     END
      *収容数×バレル＝手配単位数
     C                     Z-ADD0         W@TESU  80
     C***        WSYOS     MULT WMKBA     W@TESU
     C*
     C* QTY. X  PRODUCTION LOT
     C           WSYOS     MULT WPROL     W@TESU
      *  BARREL QTY. / LOT QTY. = # OF LOT
     C                     Z-ADD0         W@AMR   80
     C                     Z-ADD0         W@TEHI  80
     C           C3BHAS    DIV  W@TESU    W@TEHI  80
     C                     MVR            W@AMR
      *
      * # OF LOT X PRODUCTION LOT = # OF BOX
     C           W@TEHI    MULT WPROL     W@T1SU  40
     C                     Z-ADDW@AMR     C3BHAS
      *
     C           ESET      ENDSR
