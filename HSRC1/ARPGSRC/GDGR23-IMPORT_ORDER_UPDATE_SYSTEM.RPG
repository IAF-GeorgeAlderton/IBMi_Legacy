     C                     GOTO STP1
     C                     END
      *
     C           *IN15     IFEQ '0'
     C           ICSKJY    IFEQ 'D'
     C           ICSKHZ    ANDLE*DATE
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVELER,4      MSG
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C           IUPDT     IFEQ '0'
     C           ICIFMK    IFEQ 'C'
     C                     SETON                     010203
     C                     SETON                     99
