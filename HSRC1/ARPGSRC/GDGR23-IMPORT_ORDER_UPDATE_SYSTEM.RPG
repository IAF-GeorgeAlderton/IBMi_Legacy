     C*                    END
      *
     C*                    SETOF                     20
     C*          'ITEM3 '  CHAINGDGPL301             20
      *
     C*          *IN20     IFEQ '1'
     C*                    MOVE *BLANK    IFSKJY
     C*                    Z-ADD0         IFSKYY
     C*                    Z-ADD0         IFSKMM
     C*                    Z-ADD0         IFSKDD
     C*                    Z-ADD*DATE     IFKOHZ
     C*                    TIME           IFKOTM
     C*                    MOVELUS        IFKOME
     C*                    MOVEL'ITEM3 '  IFKEY
     C*                    Z-ADDIITEM     IFNO
     C*                    Z-ADD0         IFMONT
     C*                    Z-ADD*YEAR     IFYEAR
     C*                    WRITEGDGPL301
     C*                    END
      *
     C*          *IN20     IFEQ '0'
