      *------*
      * PARM *
      *------*
     C           *ENTRY    PLIST
     C                     PARM           US     10
      *-------------*
      * KEY1 - KEY2 *
      *-------------*
     C           KEY1      KLIST
     C                     KFLD           ZODER   60
     C                     KFLD           IITEM
      *
     C           KEY2      KLIST
     C                     KFLD           IHIN1
     C                     KFLD           IHIN2
     C                     KFLD           IHIN3
      *----------------*
      * INITIALIZATION *
      *----------------*
     C           STP0      TAG
     C                     MOVE *BLANK    IUPDT
     C                     MOVE *BLANK    IODR1
     C                     MOVE *BLANK    IODR2
     C                     MOVE *BLANK    IODR3
     C                     Z-ADD0         IITEM
      *----------*
      * SCREEN 1 *
      *----------*
     C           STP1      TAG
     C                     EXFMTGDGPW231
     C                     SETOF                     010203
     C                     SETOF                     99
      *-------*
      * CMD-1 *
      *-------*
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C                     Z-ADD1         A       20
     C                     SETOF                     10
     C           IUPDT     LOKUPUP1,A                    10
      *
     C           *IN10     IFEQ '0'
     C                     SETON                     0199
     C                     MOVELER,1      MSG
     C                     GOTO STP1
     C                     END
     C                     MOVELUP2,A     OUPDT
      *
%0001C*          IUPDT     IFNE '2'
     C           IODR1     IFEQ *BLANK
     C           IODR2     ANDEQ*BLANK
     C           IODR3     ANDEQ*BLANK
     C                     SETON                     0299
     C                     MOVELER,2      MSG
     C                     GOTO STP1
     C                     END
      *
     C                     Z-ADD0         ZODER
     C                     MOVELIODR1     ZODR1
     C                     MOVELIODR2     ZODR2
     C                     MOVELIODR3     ZODR3
      *
     C           ZODR2     IFLT 1
     C           ZODR2     ORGT 12
     C                     SETON                     0299
     C                     MOVELER,13     MSG
     C                     GOTO STP1
     C                     END
%0001 *
     C*          IUPDT     IFEQ '2'
     C*          ZODR2     IFNE UMONTH
     C*                    SETON                     0299
     C*                    MOVELER,13     MSG
     C*                    GOTO STP1
     C*                    END
     C*                    END
%0001 *
     C           ZODR3     IFEQ 0
     C                     SETON                     0299
     C                     MOVELER,13     MSG
     C                     GOTO STP1
     C                     END
      *
     C           IITEM     IFEQ 0
     C                     SETON                     0399
     C                     MOVELER,3      MSG
     C                     GOTO STP1
     C                     END
%0001C*                    END
      *
     C                     MOVEL'-'       IBAR1
     C                     MOVEL'-'       IBAR2
     C                     MOVEL'IAF-'    IBAR3
     C                     MOVEL'-'       IBAR4
     C                     MOVEL'-'       IBAR5
%0001 *
     C*          IUPDT     IFEQ '2'
     C*          IODR1     IFNE *BLANK
     C*          IODR2     ORNE *BLANK
     C*          IODR3     ORNE *BLANK
     C*                    SETON                     0299
     C*                    MOVELER,17     MSG
     C*                    GOTO STP1
     C*                    END
      *
     C*          IITEM     IFNE 0
     C*                    SETON                     0399
     C*                    MOVELER,18     MSG
     C*                    GOTO STP1
     C*                    END
      *
     C*                    Z-ADDUYEAR     ZODR1
     C*                    Z-ADDUMONTH    ZODR2
     C*                    SETOF                     10
     C*          'ORDER2'  CHAINGDGPL301             10
      *
     C*          *IN10     IFEQ '1'
     C*                    Z-ADD50        ZODR3
     C*                    END
      *
     C*          *IN10     IFEQ '0'
     C*          IFNO      ADD  1         ZODR3
     C*          IFYEAR    IFNE *YEAR
     C*                    Z-ADD50        ZODR3
     C*                    END
     C*          IFYEAR    IFEQ *YEAR
     C*          IFMONT    IFNE UMONTH
     C*                    Z-ADD50        ZODR3
     C*                    END
     C*                    END
     C*                    END
      *
     C*                    MOVELZODR1     IODR1
     C*                    MOVELZODR2     IODR2
     C*                    MOVELZODR3     IODR3
      *
     C*                    SETOF                     10
     C*          'ITEM3 '  CHAINGDGPL301             10
      *
     C*          *IN10     IFEQ '1'
     C*                    Z-ADD90001     IITEM
     C*                    END
      *
     C*          *IN10     IFEQ '0'
     C*          IFNO      ADD  1         IITEM
     C*          IFYEAR    IFNE *YEAR
     C*                    Z-ADD90001     IITEM
     C*                    END
     C*                    END
%0001C*                    END
