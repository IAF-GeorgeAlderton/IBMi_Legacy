     C                     GOTO STP1
     C                     END
      *
     C           ICIFMK    IFEQ '*'
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVELER,11     MSG
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C           IUPDT     IFEQ '1'
     C           ICIFMK    IFEQ 'C'
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVELER,5      MSG
     C                     GOTO STP1
     C                     END
      *
     C           ICIFMK    IFEQ '*'
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVELER,11     MSG
     C                     GOTO STP1
     C                     END
     C                     END
      *
     C                     MOVELICHIN1    IHIN1
     C                     MOVELICHIN2    IHIN2
     C                     MOVELICHIN3    IHIN3
     C                     Z-ADDICSYOS    ISYOS
     C                     Z-ADDICMAIS    IHAKO
     C                     Z-ADDICODHZ    OODHZ
     C                     Z-ADDICSURY    OOQTY
     C           IHAKO     MULT ISYOS     ZOQTY
     C                     Z-ADDICSPHZ    OSPHZ
     C                     Z-ADDICSURT    OSQTY
     C                     Z-ADDICIFHZ    OREHZ
     C                     Z-ADDICIFSU    ORQTY
     C                     MOVE *BLANK    OPTCD
     C                     MOVELICSEIH    OPTCD
      *
     C                     EXSR SUB1
      *
     C                     SETOF                     11
     C           IUPDT     IFEQ '0'
     C                     SETON                     11
     C                     END
     C                     GOTO STP3
     C                     END
      *
     C           IUPDT     IFEQ '2'
     C           *IN15     IFEQ '0'
     C           ICSKJY    IFEQ 'D'
     C           ICSKHZ    ANDLE*DATE
     C                     ELSE
     C                     SETON                     010203
     C                     SETON                     99
     C                     MOVELER,6      MSG
     C                     GOTO STP1
     C                     END
     C                     END
     C                     MOVE *BLANK    IHIN1
     C                     MOVE *BLANK    IHIN2
     C                     MOVE *BLANK    IHIN3
     C                     Z-ADD0         ISYOS
     C                     Z-ADD0         OSYOS
     C                     Z-ADD0         IHAKO
     C                     Z-ADD0         ZOQTY
     C                     GOTO STP4
     C                     END
      *----------*
      * SCREEN 2 *
      *----------*
     C           STP3      TAG
     C                     EXFMTGDGPW232
     C                     SETOF                     010299
      *-------*
      * CMD-3 *
      *-------*
     C           *INKC     IFEQ '1'
     C                     GOTO STP0
     C                     END
