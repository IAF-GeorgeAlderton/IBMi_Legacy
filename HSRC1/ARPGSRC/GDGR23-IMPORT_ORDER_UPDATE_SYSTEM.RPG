      * PARTS NO. *
      *-----------*
     C           IHIN1     IFEQ *BLANK
     C           IHIN2     ANDEQ*BLANK
     C           IHIN3     ANDEQ*BLANK
     C                     SETON                     0199
     C                     MOVELER,9      MSG
     C                     GOTO STP4
     C                     END
      *
     C                     EXSR SUB1
      *
     C                     MOVE *BLANK    OPTCD   1
      *----------------*
      * FINISHED PARTS *
      *----------------*
     C           KEY2      SETGTAAPTL011
     C                     DO   *HIVAL
     C                     SETOF                     20
     C           KEY2      REDPEAAPTL011                 20
      *
     C           *IN20     IFEQ '0'
     C           L5SKJY    IFEQ 'D'
     C           L5SKHZ    ANDLE*DATE
     C                     ELSE
     C           L5UKHZ    IFLE *DATE
     C           L5STHZ    ANDGE*DATE
     C                     MOVEL'0'       OPTCD
     C                     MOVELL5ZETI    IZETI
     C                     GOTO JUMP
     C                     END
     C                     END
     C                     END
     C  N20                ENDDO
      *--------*
      * WASHER *
      *--------*
     C           KEY2      SETGTAKBPL051
     C                     DO   *HIVAL
     C                     SETOF                     20
     C           KEY2      REDPEAKBPL051                 20
      *
     C           *IN20     IFEQ '0'
     C           L1SKJY    IFEQ 'D'
     C           L1SKHZ    ANDLE*DATE
     C                     ELSE
     C           L1UKHZ    IFLE *DATE
     C           L1STHZ    ANDGE*DATE
     C                     MOVEL'3'       OPTCD
     C*                    MOVELL1ZETI    IZETI
     C                     GOTO JUMP
     C                     END
     C                     END
     C                     END
     C  N20                ENDDO
      *---------------------*
      * HALF-FINISHED PARTS *
      *---------------------*
     C           KEY2      SETGTAANPL06
     C                     DO   *HIVAL
     C                     SETOF                     20
     C           KEY2      REDPEAANPL061                 20
      *
     C           *IN20     IFEQ '0'
     C           L7SKJY    IFEQ 'D'
     C           L7SKHZ    ANDLE*DATE
     C                     ELSE
     C           L7UKHZ    IFLE *DATE
     C           L7STHZ    ANDGE*DATE
     C                     MOVEL'6'       OPTCD
     C                     MOVELL7ZETI    IZETI
     C                     GOTO JUMP
     C                     END
     C                     END
     C                     END
     C  N20                ENDDO
      *
     C                     SETON                     0199
     C                     MOVELER,10     MSG
     C                     GOTO STP4
     C           JUMP      TAG
      *
     C                     EXSR SUB1
      *----------*
      * Q'TY/BOX *
      *----------*
     C           ISYOS     IFEQ 0
     C                     SETON                     0299
     C                     MOVELER,7      MSG
     C                     GOTO STP4
     C                     END
      *----------*
      * BOX Q'TY *
      *----------*
     C           IHAKO     IFEQ 0
     C                     SETON                     0399
     C                     MOVELER,8      MSG
     C                     GOTO STP4
     C                     END
      *
     C           ISYOS     MULT IHAKO     ZOQTY
      *-------*
      * CMD-5 *
      *-------*
     C           *INKE     IFEQ '0'
     C                     GOTO STP4
     C                     END
      *
     C           STP5      TAG
     C                     EXCPTDT
      *--------*
      * UPDATE *
      *--------*
     C                     MOVE *BLANK    ICSKJY
     C                     Z-ADD0         ICSKHZ
     C                     Z-ADD*DATE     ICKOHZ
     C                     TIME           ICKOTI
     C                     MOVELUS        ICKOME
      *
     C           IUPDT     IFEQ '0'
     C                     MOVE 'C'       ICIFMK
     C                     END
      *
     C           IUPDT     IFEQ '1'
     C                     Z-ADDISYOS     ICSYOS
     C                     Z-ADDIHAKO     ICMAIS
     C           IHAKO     MULT ISYOS     ICSURY
     C                     MOVE *BLANK    ICIFMK
     C           ORQTY     IFGE ZOQTY
     C                     MOVE '*'       ICIFMK
     C                     END
     C                     END
      *
     C           IUPDT     IFEQ '2'
     C                     Z-ADDZODER     ICODER
     C                     Z-ADDIITEM     ICITEM
     C                     MOVELIZETI     ICZETI
     C                     MOVELIHIN1     ICHIN1
     C                     MOVELIHIN2     ICHIN2
     C                     MOVELIHIN3     ICHIN3
     C                     Z-ADDISYOS     ICSYOS
     C                     Z-ADDIHAKO     ICMAIS
     C                     MOVELOPTCD     ICSEIH
     C                     Z-ADDISYOS     ICSYOS
     C                     Z-ADDIHAKO     ICMAIS
     C           IHAKO     MULT ISYOS     ICSURY
     C                     Z-ADD*DATE     ICODHZ
     C                     MOVE *BLANK    ICINVO
     C                     Z-ADD0         ICSURT
     C                     Z-ADD0         ICSPHZ
     C                     Z-ADD0         ICIFSU
     C                     Z-ADD0         ICIFHZ
     C                     MOVE *BLANK    ICIFMK
     C                     Z-ADD0         ICMJHZ
%0001 *
     C*                    SETOF                     20
     C*          'ORDER2'  CHAINGDGPL301             20
      *
     C*          *IN20     IFEQ '1'
     C*                    MOVE *BLANK    IFSKJY
     C*                    Z-ADD0         IFSKYY
     C*                    Z-ADD0         IFSKMM
     C*                    Z-ADD0         IFSKDD
     C*                    Z-ADD*DATE     IFKOHZ
     C*                    TIME           IFKOTM
     C*                    MOVELUS        IFKOME
     C*                    MOVEL'ORDER2'  IFKEY
     C*                    Z-ADDZODR3     IFNO
     C*                    Z-ADDZODR2     IFMONT
     C*                    Z-ADD*YEAR     IFYEAR
     C*                    WRITEGDGPL301
     C*                    END
      *
     C*          *IN20     IFEQ '0'
     C*                    MOVE *BLANK    IFSKJY
     C*                    Z-ADD0         IFSKYY
     C*                    Z-ADD0         IFSKMM
     C*                    Z-ADD0         IFSKDD
     C*                    Z-ADD*DATE     IFKOHZ
     C*                    TIME           IFKOTM
     C*                    MOVELUS        IFKOME
     C*                    Z-ADDZODR3     IFNO
     C*                    Z-ADDZODR2     IFMONT
     C*                    Z-ADD*YEAR     IFYEAR
