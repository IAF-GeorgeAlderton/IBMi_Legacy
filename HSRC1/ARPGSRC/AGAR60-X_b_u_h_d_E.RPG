     C                     MOVELUYEAR     FHKOYY
     C                     MOVELUMONTH    FHKOMM
     C                     MOVELUDAY      FHKODD
     C                     MOVEL@TIHH     FHKOHH
     C                     MOVEL@TIMM     FHKOMM
     C           @MKROA    IFNE '999'
