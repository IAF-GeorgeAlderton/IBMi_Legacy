      *sbﾆﾞﾏ]f fhmb FILE UPDATE & UPDATE FILE CREATE       *
      *----------------------------------------------------*
      *
      *  FSW1   ===>  ' '  ﾃcﾆ] mﾞｰj oﾆ
      *               '*'  ﾃcﾆ] mﾞｰj aﾒ
      *
     C                     SETOF                         81
     C           1         SETLLAGAPP311
     C                     DO   *HIVAL
     C                     READ AGAPP311                 81
     C           *IN81     IFEQ '0'
     C                     MOVE *BLANK    FSW1    1
     C                     SETOF                         82
      *
      *== sbﾆﾞﾏ]f ﾎabﾓ ﾑvnﾌﾞﾆ
      *
     C           CBSKJY    IFEQ 'D'
     C           CBSKHZ    ANDLE*DATE
     C                     SETON                         82
     C                     END
      *
     C           *IN82     IFEQ '0'
