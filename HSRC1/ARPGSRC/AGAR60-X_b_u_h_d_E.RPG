     C           @MMKR     ANDEQCBMMKR
     C           @NEXT     ANDEQCBNEXT
      *
      *== ud ﾃcmb ibﾜ
      *
     C           @MKROA    IFNE '999'
     C           @MBMN     IFEQ CBMBMN
     C                     MOVE @MKROA    CBMKRO
     C                     MOVE '*'       FSW1
     C                     END
     C                     END
      *
      *== xlg ﾃcmb ibﾜ
      *
     C           @TKROA    IFNE '999'
     C           @MMKR     IFEQ CBMMKR
     C                     MOVE @TKROA    CBTKRO
     C                     MOVE '*'       FSW1
     C                     END
     C                     END
      *
      *
      *== 2ﾆﾞfﾃc  ibﾜ
      *
     C           @KKROA    IFNE '999'
     C           @NEXT     IFEQ CBNEXT
     C                     MOVE @KKROA    CBKKRO
     C                     MOVE '*'       FSW1
     C                     END
     C                     END
      *
     C           FSW1      IFEQ '*'
      *
      *== c]ﾃ] ibﾜ kdlh uﾇjｰ UPDATE
      *
     C                     SETOF                     85
     C           #KEYFH    CHAINAAKPL411             85
     C           *IN85     IFEQ '0'
     C           FHSKJY    ANDEQ'D'
     C           FHSKHZ    ANDLE*DATE
     C                     SETON                     85
     C                     END
     C           *IN85     IFEQ '0'
