     H            Y.
     F*** MCER45 *********************************************
     F* ENTIRE ABOLITION PART NO M/F ACCOUNT BOOK <INPUT DAY ORDER> *
     F*             H.ITO                90.02.15            *
     F********************************************* MCER45 ***
     FMCEPW45 CF  E                    WORKSTN
     FMCEPL44 IF  E           K        DISK
     FMCEWP45 O   F     128            DISK
     E                    $MSG    1   8 60
     I            DS
     I                                        1   80@SDAZB
     I                                        1   40@SDAYY
     I                                        5   60@SDAYM
     I                                        7   80@SDAYD
     I            DS
     I                                        1   80@EDAZB
     I                                        1   40@EDAYY
     I                                        5   60@EDAYM
     I                                        7   80@EDAYD
     C           *ENTRY    PLIST
     C                     PARM           PARM1   8        *fbﾆﾍﾞ
     C                     PARM           PARM2   8        *ﾆｬcﾒｭcﾍﾞ
     C                     PARM           PARM3   1        *ﾎﾞ]ﾓb jbﾎﾟ
     C*
     C           KEY1      KLIST
     C                     KFLD           #KHY    40
     C                     KFLD           #KHM    20
     C                     KFLD           #KHD    20
     C*
     C                     MOVE *DATE     @DATE
     C                     MOVE *ZERO     @SDAZB
     C                     MOVE *ZERO     @EDAZB
     C                     MOVE *BLANK    @TYPE
     C                     MOVE *BLANK    @MSG
     C*
     C           @SCR1     TAG
     C                     EXFMTMCEPW451
     C                     MOVEA'000'     *IN,11
     C                     MOVEA'00'      *IN,90
     C                     MOVEA'0'       *IN,99
     C                     MOVE *BLANK    @MSG
     C*
     C           *IN01     IFEQ '1'
     C                     SETON                       LR
     C   LR                RETRN
     C                     END
     C*
     C* ﾆｬcib fbﾆﾍﾞ
     C*
     C           @SDAZB    IFEQ *ZERO
     C                     ELSE
     C                     SETOF                     9091
     C                     MOVE @SDAYY    HY      40
     C                     MOVE @SDAYM    HM      20
     C                     MOVE @SDAYD    HD      20
     C                     EXSR $SB200
     C           *IN90     IFEQ '1'
     C           *IN91     OREQ '1'
     C                     SETON                     1199
     C                     MOVEL$MSG,3    @MSG
     C                     GOTO @SCR1
     C                     END
     C                     END
     C*
     C* ﾆｬcib ﾆｬcﾒﾑcﾍﾞ
     C*
     C           @EDAZB    IFEQ *ZERO
     C                     ELSE
     C                     SETOF                     9091
     C                     MOVE @EDAYY    HY      40
     C                     MOVE @EDAYM    HM      20
     C                     MOVE @EDAYD    HD      20
     C                     EXSR $SB200
     C           *IN90     IFEQ '1'
     C           *IN91     OREQ '1'
     C                     SETON                     1299
     C                     MOVEL$MSG,3    @MSG
     C                     GOTO @SCR1
     C                     END
     C                     END
     C*
     C* ﾎﾞ]ﾓb jbﾎﾟ
     C*
     C           @TYPE     IFEQ *BLANK
     C                     SETON                     1399
     C                     MOVEL$MSG,4    @MSG
     C                     GOTO @SCR1
     C                     END
     C           @TYPE     IFEQ 'A'
     C           @TYPE     OREQ 'B'
     C                     ELSE
     C                     SETON                     1399
     C                     MOVEL$MSG,4    @MSG
     C                     GOTO @SCR1
     C                     END
     C*
     C* fﾞbnc mﾞｰj ]ﾅﾞb kdlh
     C*
     C                     SETOF                       82
     C           KEY1      SETLLMCEPL441             8282
     C           *IN82     IFEQ '1'
     C                     SETON                     99
     C                     MOVEL$MSG,6    @MSG
     C                     GOTO @SCR1
     C                     END
     C/SPACE 1
     C  N05                GOTO @SCR1
     C/SPACE 1
     C           @SDAZB    IFEQ *ZERO
     C                     MOVE *ZERO     @SDAZB
     C                     END
     C           @EDAZB    IFEQ *ZERO
     C                     Z-ADD999999    @EDAZB
     C                     END
     C                     MOVE @SDAYY    #KHY    40
     C                     MOVE @SDAYM    #KHM    20
     C                     MOVE @SDAYD    #KHD    20
     C/SPACE 1
     C                     MOVE @SDAZB    PARM1
     C                     MOVEL@EDAZB    PARM2
     C                     MOVE @TYPE     PARM3
     C/SPACE 1
     C           KEY1      SETLLMCEPL441
     C                     SETOF                     8081
     C           *IN81     DOWEQ'0'
     C                     READ MCEPL441                 81
     C           *IN81     IFEQ '0'
     C           M1TRHZ    ANDGE@SDAZB
     C           M1TRHZ    ANDLE@EDAZB
     C           M1SKJY    IFEQ 'D'
     C           M1SKHZ    CABLE*DATE     RETRY
     C                     END
     C                     MOVE '*'       PSW     1
     C                     EXSR $SB900
     C                     END
     C           RETRY     TAG
     C  N81                END
     C                     SETON                     LR
     CLR                   RETRN
     C/SPACE 1
     CSR         $SB900    BEGSR
     C           PSW       IFEQ '*'
     C                     MOVE M1HIN1    T1HIN1  5
     C                     MOVE M1HIN2    T1HIN2  5
     C                     MOVE M1HIN3    T1HIN3  2
     C                     MOVE M1SPEN    T1SPEN  9
     C                     MOVE M1HKB1    T1HKB1  1
     C                     MOVE M1HKB2    T1HKB2  1
     C                     MOVE M1TOKU    T1TOKU  40
     C                     MOVE M1KOJO    T1KOJO  1
     C                     MOVE M1UKER    T1UKER  4
     C                     Z-ADDM1ZIKO    T1ZIKO  70
     C                     Z-ADDM1HAKO    T1HAKO  40
     C                     Z-ADDM1JRYO    T1JRYO  60
     C                     Z-ADDM1KRYY    T1KRYY  40
     C                     Z-ADDM1KRMM    T1KRMM  20
     C                     Z-ADDM1KRDD    T1KRDD  20
     C                     MOVE M1KKBN    T1KKBN  1
     C                     Z-ADDM1UKYY    T1UKYY  40
     C                     Z-ADDM1UKMM    T1UKMM  20
     C                     Z-ADDM1UKDD    T1UKDD  20
     C                     Z-ADDM1TRYY    T1TRYY  40
     C                     Z-ADDM1TRMM    T1TRMM  20
     C                     Z-ADDM1TRDD    T1TRDD  20
     C                     MOVE M1TANT    T1TANT  2
     C                     MOVE M1BKO1    T1BKO1 25
     C                     MOVE M1BKO2    T1BKO2 25
     C                     SETON                     U1
     C                     EXCPTFILE
     C*
     C* ﾃcyh ﾉ hﾒaｰ
     C*
     C                     MOVE *BLANK    T1HIN1
     C                     MOVE *BLANK    T1HIN2
     C                     MOVE *BLANK    T1HIN3
     C                     MOVE *BLANK    T1SPEN
     C                     MOVE *BLANK    T1HKB1
     C                     MOVE *BLANK    T1HKB2
     C                     Z-ADD0         T1TOKU
     C                     MOVE *BLANK    T1KOJO
     C                     MOVE *BLANK    T1UKER
     C                     Z-ADD0         T1ZIKO
     C                     Z-ADD0         T1HAKO
     C                     Z-ADD0         T1JRYO
     C                     Z-ADD0         T1KRYY
     C                     Z-ADD0         T1KRMM
     C                     Z-ADD0         T1KRDD
     C                     MOVE *BLANK    T1KKBN
     C                     Z-ADD0         T1UKYY
     C                     Z-ADD0         T1UKMM
     C                     Z-ADD0         T1UKDD
     C                     Z-ADD0         T1TRYY
     C                     Z-ADD0         T1TRMM
     C                     Z-ADD0         T1TRDD
     C                     MOVE *BLANK    T1TANT
     C                     MOVE *BLANK    T1BKO1
     C                     MOVE *BLANK    T1BKO2
     C                     END
     CSR         $S900E    ENDSR
     C/SPACE 1
     C*****************************************************
     C*     ﾍ lﾞ i  k ｩ ｮ h
     C*****************************************************
     CSR         $SB200    BEGSR
     C           HY        DIV  4         URUDOS  50
     C                     MVR            AMARI   50
     C*  01
     C           HM        IFEQ 01
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  02
     C           HM        IFEQ 02
     C           AMARI     IFNE *ZERO
     C           HD        IFLT 01
     C           HD        ORGT 28
     C                     SETON                       90
     C                     END
     C           HD        IFLT 01
     C           HD        ORGT 29
     C                     SETON                       90
     C                     END
     C                     END
     C                     END
     C*  03
     C           HM        IFEQ 03
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  04
     C           HM        IFEQ 04
     C           HD        IFLT 01
     C           HD        ORGT 30
     C                     SETON                       90
     C                     END
     C                     END
     C*  05
     C           HM        IFEQ 05
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  06
     C           HM        IFEQ 06
     C           HD        IFLT 01
     C           HD        ORGT 30
     C                     SETON                       90
     C                     END
     C                     END
     C*  07
     C           HM        IFEQ 07
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  08
     C           HM        IFEQ 08
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  09
     C           HM        IFEQ 09
     C           HD        IFLT 01
     C           HD        ORGT 30
     C                     SETON                       90
     C                     END
     C                     END
     C*  10
     C           HM        IFEQ 10
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  11
     C           HM        IFEQ 11
     C           HD        IFLT 01
     C           HD        ORGT 30
     C                     SETON                       90
     C                     END
     C                     END
     C*  12
     C           HM        IFEQ 12
     C           HD        IFLT 01
     C           HD        ORGT 31
     C                     SETON                       90
     C                     END
     C                     END
     C*  01 -- 12
     C           HM        IFLT 01
     C           HM        ORGT 12
     C                     SETON                       91
     C                     END
     C           HY        IFEQ *ZERO
     C                     SETON                       91
     C                     END
     CSR         $S200E    ENDSR
     C*
     OMCEWP45 E                FILE
     O                         T1HIN1     5
     O                         T1HIN2    10
     O                         T1HIN3    12
     O                         T1SPEN    21
     O                         T1HKB1    22
     O                         T1HKB2    23
     O                         T1TOKU    27
     O                         T1KOJO    28
     O                         T1UKER    32
     O                         T1ZIKO    39
     O                         T1HAKO    43
     O                         T1JRYO    49
     O                         T1KRYY    53
     O                         T1KRMM    55
     O                         T1KRDD    57
     O                         T1KKBN    58
     O                         T1UKYY    62
     O                         T1UKMM    64
     O                         T1UKDD    66
     O                         T1TRYY    70
     O                         T1TRMM    72
     O                         T1TRDD    74
     O                         T1TANT    76
     O                         T1BKO1   101
     O                         T1BKO2   126
     O/SPACE 1
**   $MSG
ERR-1 TOTALIZATION START DAY ERROR
ERR-2 DATE LOGICAL ERROR
ERR-3 TOTALIZATION EXIT DAY ERROR
ERR-4 CLASSIFICATION TYPE IS NOT INPUT
ERR-5 CLASSIFICATION TYPE IS ( 'A' OR 'B') NOT RIGHT
ERR-6 APPLICABLE DATA DOESN'T EXIST
