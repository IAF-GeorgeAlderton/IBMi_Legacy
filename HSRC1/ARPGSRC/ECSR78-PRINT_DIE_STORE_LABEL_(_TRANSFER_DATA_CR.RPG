     H            Y.
     F** ECSR78 *******************************************
     F*  PRINT DIE STORE LABEL DATA                       *
     F*          2019.05.15  MAEDA.                       *
     F*****************************************************
     F*          FILE DEFINITION                          *
     F*****************************************************
     FECSWP73 IF  E                    DISK
     FECSPP78 O   E                    DISK                      A
     F*
     I*****************************************************
     I*          DATA STRUCTURE                           *
     I*****************************************************
     I*==< SYSTEM DATE/TIME >==*
     I            DS
     I                                        1  140S@TIME
     I                                        1   60S@HMS
     I                                        7  140S@YMD
     I*==< SYSTEM INFORMATION >==*
     I           SDS
     I                                     *PROGRAM @@PGID
     I                                      244 253 @@WSID
     I                                      254 263 @@USID
     I                                      264 269 @@JBNO
     I            DS
     I                                        1  15 W0BAR@
     I                                        1  14 W0BA14
     C*****************************************************
     C*          MAIN ROUTINE                             *
     C*****************************************************
     C           *ENTRY    PLIST
     C                     PARM           P@INPK  1
      *
     C                     TIME           S@TIME
     C*                    ____________
     C           1         SETLLECSWP73
     C                     READ ECSWP73                  91
     C*                    ~~~~~~~~~~~~
D----C           *IN91     DOWEQ'0'
|    C*
     C                     CLEARECSPP781
     C                     Z-ADDS@YMD     EPKOHZ
     C                     Z-ADDS@HMS     EPKOJK
     C                     MOVEL@@USID    EPKOME
     C                     MOVELW0KAT1    EPKAT1
     C                     MOVELW0KAT2    EPKAT2
     C                     MOVELW0KAT3    EPKAT3
     C                     MOVELW0KAT4    EPKAT4
     C                     Z-ADDW0ISNO    EPISNO
     C                     Z-ADDW0ISYY    EPISYY
     C                     Z-ADDW0ISMM    EPISMM
     C                     Z-ADDW0ISDD    EPISDD
     C                     Z-ADDW0ISJK    EPISJK
     C                     MOVELW0BAR@    EPBAR@
     C                     MOVELW0LOC1    EPLOC1
     C                     MOVELW0LOC2    EPLOC2
     C                     MOVELW0LOC3    EPLOC3
     C                     MOVELW0LOC4    EPLOC4
     C                     MOVELP@INPK    EPINPK
     C                     WRITEECSPP781
|    C                     READ ECSWP73                  91
|    C*                    ~~~~~~~~~~~~
E----C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
