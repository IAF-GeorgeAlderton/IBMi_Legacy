     H            Y.
     F** ABMR31 *********************************************
     F*設定数変更結果
     F*    HOTTA.               2018.09.14                  *
     F*******************************************************
     FABMWP31 IF  E                    DISK
     FABMPP31 O   E                    DISK                      A
     FAAJPL11 IF  E           K        DISK
     FABMPPC5 IF  E           K        DISK
     FGHCPL21 IF  E           K        DISK
      *
     I            DS
     I                                        1   80BHSKHZ
     I                                        1   40BHSKYY
     I                                        5   60BHSKMM
     I                                        7   80BHSKDD
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P@DTYM  60
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
     C                     READ ABMWP311                 80
     C           *IN80     DOWEQ'0'
     C                     EXSR #SB500
     C                     READ ABMWP311                 80
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *---------------------------------------------*
      * FORECAST ABMPP11                            *
      *---------------------------------------------*
     CSR         #SB500    BEGSR
      *
     C                     CLEARABMPP311
     C                     Z-ADD*DATE     S5KOHZ
     C                     TIME           S5KOTI
     C                     MOVELW#USER    S5KOME
     C                     Z-ADD*DATE     S5CRDT
     C                     Z-ADDP@DTYM    S5NTYM
     C                     MOVEL@BJHN1    S5SHN1
     C                     MOVEL@BJHN2    S5SHN2
     C                     MOVEL@BJHN3    S5SHN3
     C                     MOVEL@BATOB    S5ATOB
     C                     MOVEL@BATOK    S5ATOK
     C                     MOVEL@BATK1    S5ATK1
     C                     MOVEL@BATK2    S5ATK2
     C                     MOVEL@BATK3    S5ATK3
     C                     MOVEL@BATK4    S5ATK4
     C                     Z-ADD@BSSYS    S5SSYS
     C                     MOVEL@BSSYT    S5SSYT
     C                     MOVEL@BKCD1    S5KCD1
     C                     MOVEL@BKCD2    S5KCD2
      *
     C           KEYAAJ    KLIST
     C                     KFLD           @BATK1
     C                     KFLD           @BATK2
     C                     KFLD           @BATK3
     C                     KFLD           @BATK4
     C                     MOVEL*BLANK    @JKSYO  1
     C           KEYAAJ    SETLLAAJPL111
     C           KEYAAJ    READEAAJPL111                 38
     C           *IN38     DOWEQ'0'
     C                     Z-ADDCJBRYO    S5BRYO
     C                     Z-ADDCJSDAI    S5SDAI
     C                     MOVELCJSSYO    S5SSYO
     C                     MOVELCJKSYO    @JKSYO
     C           KEYAAJ    READEAAJPL111                 38
     C                     ENDDO
     C                     Z-ADD0         S5MAGS
     C                     EXSR #SB600
      *
     C                     SELEC
      *
     C           @BKCD1    WHEQ '0'
     C           S5MAGS    IFGT 8
     C                     Z-ADD8         S5MAGS
     C                     ENDIF
     C           @BATOB    IFEQ '5555'
     C           S5MAGS    IFLT 2
     C                     Z-ADD2         S5MAGS
     C                     ENDIF
     C                     ENDIF
      *
     C           @BKCD1    WHEQ '6'
     C           S5MAGS    IFGT 8
     C                     Z-ADD8         S5MAGS
     C                     ENDIF
      *
     C           @BKCD1    WHEQ '3'
     C           S5MAGS    IFGT 5
     C                     Z-ADD5         S5MAGS
     C                     ENDIF
      *
     C                     ENDSL
      *
     C                     Z-ADD@BKTSU    S5KTSU
     C                     Z-ADD@BKMAX    S5KMAX
     C                     Z-ADD@BKLOT    S5KLOT
     C           @BKLOT    IFEQ 0
     C                     Z-ADD1         S5KLOT
     C                     ENDIF
     C                     Z-ADD@BMAXH    S5MAXH
     C                     Z-ADD@BPADJ    S5PADJ
     C                     Z-ADD@BAUAJ    S5AUAJ
     C                     Z-ADD@BDUPH    S5DUPH
     C                     Z-ADD@BOTHH    S5OTHH
     C           @BKCD1    IFEQ 'C'
     C           @BKCD1    OREQ 'E'
     C           @BKCD1    OREQ '0'
     C           @BKCD1    OREQ '3'
     C           S5SSYS    IFNE 0
     C           S5KTSU    DIV  S5SSYS    S5BOXM
     C                     ENDIF
     C                     ELSE
     C           S5KTSU    DIV  20        @5KTSU  90
     C           S5SSYS    IFNE 0
     C           @5KTSU    DIV  S5SSYS    S5BOXM
     C                     ENDIF
     C                     ENDIF
     C           S5BOXM    IFEQ 0
     C                     Z-ADD0.1       S5BOXM
     C                     ENDIF
      *
     C                     Z-ADD@AKTSU    S5KTSA
     C                     Z-ADD@AKMAX    S5KMAA
     C                     Z-ADD@ANSRY    S5NSRY
     C                     Z-ADD0         S5KLOA
     C                     Z-ADD0         WKLOT   30
     C                     MOVEL@BATOB    KBATOB
     C                     MOVEL@BATOK    KBATOK
     C                     EXSR #SB711
     C           WKLOT     IFEQ 0
     C                     MOVEL'****'    KBATOB
     C                     MOVEL'***'     KBATOK
     C                     EXSR #SB711
     C                     ENDIF
      *
     C                     Z-ADDWKLOT     S5KLOA
     C           @BKLOT    IFEQ 1
     C                     Z-ADD1         S5KLOA
     C                     ENDIF
      *
     C                     Z-ADD@AMAXH    S5MAXA
     C                     Z-ADD@APADJ    S5PADA
     C                     Z-ADD@AAUAJ    S5AUAA
     C                     Z-ADD@ADUPH    S5DUPA
     C                     Z-ADD@AOTHH    S5OTHA
     C                     MOVEL@ACMT1    S5CMTA
     C                     Z-ADD@UMAXD    S5MAXD
     C                     Z-ADD@UMAX     S5MAX
     C                     Z-ADD@CMAX     S5CMAX
     C                     Z-ADD@NBOXD    S5BOXD
     C                     MOVEL@APICS    S5PICS
     C                     Z-ADD@SA       S5SA
     C                     Z-ADD@SA2      S5SA2
     C                     MOVEL@5DUP@    S5DUP@
     C                     Z-ADD@5DUP#    S5DUP#
     C                     MOVEL@AKERR    S5KERR
     C                     WRITEABMPP311
      *
     CSR         ESB500    ENDSR
      *---------------------------*
      *間口数
      *---------------------------*
     CSR         #SB600    BEGSR
      *
     C                     SELEC
      *
     C           @BKCD1    WHEQ 'A'
     C                     EXSR #SB610
      *
     C           @BKCD1    WHEQ 'C'
     C                     SELEC
     C           @BKCD2    WHEQ 'Z'
     C                     EXSR #SB620
     C           @BKCD2    WHEQ 'A'
     C                     EXSR #SB621
     C                     ENDSL
      *
     C           @BKCD1    WHEQ 'B'
     C                     EXSR #SB630
      *
     C           @BKCD1    WHEQ 'E'
     C                     EXSR #SB640
      *
     C           @BKCD1    WHEQ '0'
     C           @BATOB    IFEQ '5555'
     C                     EXSR #SB650
     C                     ELSE
     C                     EXSR #SB651
     C                     ENDIF
      *
     C           @BKCD1    WHEQ '6'
     C                     EXSR #SB660
      *
     C           @BKCD1    WHEQ '3'
     C                     EXSR #SB670
      *
     C                     ENDSL
      *
     CSR         ESB600    ENDSR
      *---------------------------*
      *間口数　工程内
      *---------------------------*
     CSR         #SB610    BEGSR
      *
     C                     Z-ADD0         WKMAX   50
     C                     Z-ADD0         MAGS    30
     C           @BATOB    IFEQ '0111'
     C                     Z-ADD@AKMAX    WKMAX
     C                     ELSE
     C           @AKMAX    MULT 0.7       WKMAX
     C                     ENDIF
     C           WKMAX     DIV  2         S5MAGS    H
     C           @JKSYO    IFNE 'D'
     C           S5SDAI    ANDEQ2
     C           S5SSYO    ANDEQ'B'
     C           WKMAX     DIV  4         S5MAGS    H
     C                     ENDIF
      *
     CSR         ESB610    ENDSR
      *---------------------------*
      *間口数　メッキC-A
      *---------------------------*
     CSR         #SB620    BEGSR
      *
     C                     Z-ADD0         WKMAX   50
     C                     Z-ADD0         MAGS    30
     C           @BATOB    IFEQ '0111'
     C                     Z-ADD@AKMAX    WKMAX
     C                     ELSE
     C           @AKMAX    MULT 0.7       WKMAX
     C                     ENDIF
     C           WKMAX     DIV  32        S5MAGS
     C                     MVR            AMR     73
     C           AMR       IFNE 0
     C                     ADD  1         S5MAGS
     C                     ENDIF
      *
     CSR         ESB620    ENDSR
      *---------------------------*
      *間口数　メッキC-Z
      *---------------------------*
     CSR         #SB621    BEGSR
      *
     C                     Z-ADD0         WKMAX   50
     C                     Z-ADD0         MAGS    30
     C                     Z-ADD@AKMAX    WKMAX
     C           WKMAX     DIV  32        S5MAGS
     C                     MVR            AMR     73
     C           AMR       IFNE 0
     C                     ADD  1         S5MAGS
     C                     ENDIF
      *
     CSR         ESB621    ENDSR
      *---------------------------*
      *間口数　焼入れ
      *---------------------------*
     CSR         #SB630    BEGSR
      *
     C                     Z-ADD0         WKMAX   50
     C                     Z-ADD0         MAGS    30
     C                     Z-ADD@AKMAX    WKMAX
     C           WKMAX     DIV  2         S5MAGS    H
      *
     CSR         ESB630    ENDSR
      *---------------------------*
      *間口数　引取E
      *---------------------------*
     CSR         #SB640    BEGSR
      *
     C                     Z-ADD0         WKMAX   50
     C                     Z-ADD0         MAGS    30
     C                     Z-ADD@AKMAX    WKMAX
     C           WKMAX     DIV  32        S5MAGS
     C                     MVR            AMR     73
     C           AMR       IFNE 0
     C                     ADD  1         S5MAGS
     C                     ENDIF
      *
     CSR         ESB640    ENDSR
      *---------------------------*
      *間口数　完成品0  後工程5555
      *---------------------------*
     CSR         #SB650    BEGSR
      *
     C                     Z-ADD0         WKMAX   50
     C                     Z-ADD0         MAGS    30
     C                     Z-ADD@NBOXD    WKMAX
     C           WKMAX     DIV  32        S5MAGS
     C                     MVR            AMR     73
     C           AMR       IFNE 0
     C                     ADD  1         S5MAGS
     C                     ENDIF
      *
     CSR         ESB650    ENDSR
      *---------------------------*
      *間口数　完成品0  後工程5555以外
      *---------------------------*
     CSR         #SB651    BEGSR
      *
     C                     Z-ADD0         WKMAX   50
     C                     Z-ADD0         MAGS    30
     C           @NBOXD    MULT 12        WKMAX
     C           WKMAX     DIV  32        S5MAGS
     C                     MVR            AMR     73
     C           AMR       IFNE 0
     C                     ADD  1         S5MAGS
     C                     ENDIF
      *
     CSR         ESB651    ENDSR
      *---------------------------*
      *間口数　半成品6
      *---------------------------*
     CSR         #SB660    BEGSR
      *
     C                     Z-ADD0         WKMAX   50
     C                     Z-ADD0         MAGS    30
     C           @NBOXD    MULT 12        WKMAX
     C           WKMAX     DIV  32        S5MAGS
     C                     MVR            AMR     73
     C           AMR       IFNE 0
     C                     ADD  1         S5MAGS
     C                     ENDIF
      *
     CSR         ESB660    ENDSR
      *---------------------------*
      *間口数　構成品3
      *---------------------------*
     CSR         #SB670    BEGSR
      *
     C                     Z-ADD0         WKMAX   50
     C                     Z-ADD0         MAGS    30
     C           @BATOB    IFEQ '0111'
     C           @BATOB    OREQ '8990'
     C           @NBOXD    MULT 12        WKMAX
     C                     ELSE
     C           @AKMAX    MULT 0.7       WKMAX
     C                     ENDIF
     C           WKMAX     DIV  32        S5MAGS
     C                     MVR            AMR     73
     C           AMR       IFNE 0
     C                     ADD  1         S5MAGS
     C                     ENDIF
      *
     CSR         ESB670    ENDSR
      *---------------------------*
      *ﾜｮnサイズ
      *---------------------------*
     CSR         #SB711    BEGSR
      *完成品番でＧＨＣから設定数多いデータ
     C           KEYGHC    KLIST
     C                     KFLD           JHN1    5
     C                     KFLD           JHN2    5
     C                     KFLD           JHN3    2
     C                     MOVEL@BJHN1    JHN1
     C                     MOVEL@BJHN2    JHN2
     C                     MOVEL@BJHN3    JHN3
     C                     Z-ADD@ANSRY    W7SETI  90
     C           KEYGHC    SETLLGHCPL211
     C           KEYGHC    READEGHCPL211                 94
     C           *IN94     DOWEQ'0'
     C           M7SRYO    IFGT W7SETI
     C                     Z-ADDM7SRYO    W7SETI
     C                     ENDIF
     C           KEYGHC    READEGHCPL211                 94
     C                     ENDDO
      *
     C           W7SETI    DIV  20        W@KSSU  90
     C                     Z-ADD0         W@HAKD  51
     C           @BSSYS    IFNE 0
     C           W@KSSU    DIV  @BSSYS    W@HAKD
     C                     ENDIF
      *
     C           KEYB5     KLIST
     C                     KFLD           KBATOB  4
     C                     KFLD           KBATOK  3
     C                     MOVEL'0'       GET     1
     C           KEYB5     SETLLABMPPC51
     C           KEYB5     READEABMPPC51                 94
     C           *IN94     DOWEQ'0'
     C           GET       ANDEQ'0'
     C           BHSKJY    IFEQ 'D'
     C           BHSKHZ    ANDLE*DATE
     C                     ELSE
     C                     SELEC
     C           BHFUGO    WHEQ '1'
     C           W@HAKD    IFLT BHHTSU
     C                     Z-ADDBHLOT     WKLOT
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           BHFUGO    WHEQ '2'
     C           W@HAKD    IFGT BHHTSU
     C                     Z-ADDBHLOT     WKLOT
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           BHFUGO    WHEQ '3'
     C           W@HAKD    IFEQ BHHTSU
     C                     Z-ADDBHLOT     WKLOT
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           BHFUGO    WHEQ '4'
     C           W@HAKD    IFLE BHHTSU
     C                     Z-ADDBHLOT     WKLOT
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           BHFUGO    WHEQ '5'
     C           W@HAKD    IFGE BHHTSU
     C                     Z-ADDBHLOT     WKLOT
     C                     MOVEL'1'       GET
     C                     ENDIF
     C           BHFUGO    WHEQ '6'
     C           W@HAKD    IFNE BHHTSU
     C                     Z-ADDBHLOT     WKLOT
     C                     MOVEL'1'       GET
     C                     ENDIF
     C                     ENDSL
     C                     ENDIF
     C           KEYB5     READEABMPPC51                 94
     C                     ENDDO
      *
     CSR         ESB711    ENDSR
