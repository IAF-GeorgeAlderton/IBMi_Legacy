     F** AB#R02 ****************************
     F*INQUIRY & UPDATE OF SALES BY P/N
     F* I-HASADA              89.03.25     *
     F**************************** AB#R02 **
     FAB#PW02 CF  E                    WORKSTN
     FAB#PL03 IF  E           K        DISK
     FAB#WP02 O   E                    DISK
     E                    ER      1   3 60               d[ｰ xｮﾈｰﾆﾞ
     I            DS
     I                                        1  12 ISHIN
     I                                        1   5 ISHN1
     I                                        6  10 ISHN2
     I                                       11  12 ISHN3
     C           KEY       KLIST
     C                     KFLD           ISHN1
     C                     KFLD           ISHN2
     C                     KFLD           ISHN3
      *
     C           *ENTRY    PLIST
     C                     PARM           PSHZ    8
     C                     PARM           PEHZ    8
     C                     PARM           PSHIN  12
     C                     PARM           PYN     1
     C                     MOVE PSHZ      WSHZ    80
     C                     MOVE PEHZ      WEHZ    80
     C                     MOVE 'N'       IYN
      *
     C           STP1      TAG
     C                     EXFMTAB#PW021
     C                     SETOF                     010299
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     U1LR
     C                     RETRN
     C                     END
      *
     C           *INKC     IFEQ '1'
     C                     SETON                     U3LR
     C                     RETRN
     C                     END
      *
     C           ISHIN     IFEQ *BLANK
     C                     SETON                     0199
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
      *
     C           IYN       IFNE 'Y'
     C           IYN       ANDNE'N'
     C                     SETON                     0299
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
      *
     C                     MOVE ISHIN     PSHIN
     C                     MOVE IYN       PYN
      *
     C           KEY       SETLLAB#PL031
     C                     SETOF                     11
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY       READEAB#PL031                 10
     C           *IN10     IFEQ '0'
     C           B1SKJY    IFEQ 'D'
     C           B1SKHZ    ANDLE*DATE
     C                     ELSE
     C           B1NOHZ    IFGE WSHZ
     C           B1NOHZ    ANDLEWEHZ
     C                     SETON                     11
     C                     Z-ADDB1TOKU    ABTOKU
     C                     Z-ADDB1NONY    ABNONY
     C                     MOVE B1NKOJ    ABNKOJ
     C                     MOVE B1NUKE    ABNUKE
     C                     MOVELB1MHIN    ABMHIN
     C                     Z-ADDB1NOHZ    ABNOHZ
     C                     Z-ADDB1SRYO    ABSRYO
     C                     WRITEAB#WP021
     C                     END
     C                     END
     C                     END
     C  N10                END
      *
     C           *IN11     IFEQ '0'
     C                     SETON                     0199
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     END
      *
     C                     SETON                     LR
     C                     RETRN
** ER
