     C                     MOVELMTH,I     W#MMMM
     C                     MOVE W@YYYY    W#YYYY
     C                     MOVELW#MMYY    W@SDT1  5
     C*
     C                     SUB  1         W@MMMM
     C           W@MMMM    IFLE *ZERO
     C                     Z-ADD12        W@MMMM
     C                     SUB  1         W@YYYY
     C                     END
     C                     Z-ADDW@MMMM    I       20
     C                     MOVELMTH,I     W#MMMM
     C                     MOVE W@YYYY    W#YYYY
     C                     MOVELW#MMYY    W@SDT2  5
     C*
