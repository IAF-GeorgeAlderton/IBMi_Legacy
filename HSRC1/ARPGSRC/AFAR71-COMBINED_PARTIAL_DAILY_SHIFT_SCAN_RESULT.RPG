     H            Y.
     F** AFAR71 ********************************************
     F*  COMBINED PARTIAL DAILY+SHIFT SCAN RESULT LIST     *
     F*                                                    *
     F* TCHK1 11/17/08 CREATE(COPY FROM AFAR70)            *
     F******************************************* AFAR71 ***
     FAFAPL67 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     ********************************************************
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
     I* SYSTEM DATE
     I            DS
     I                                        1  140WSDT
     I                                        1   20WSSHHH
     I                                        3   40WSSNNN
     I                                        5   60WSSSSS
     I                                        7  100WSSYYY
     I                                       11  120WSSMMM
     I                                       13  140WSSDDD
     I                                        1   40WSSTM4
     I                                        1   60WSSTM6
     I                                        7  140WSSDAT
     I* START
     I            DS
     I                                        1  120K@STDT
     I                                        1   40K@STYY
     I                                        5   60K@STMM
     I                                        7   80K@STDD
     I                                        9  120K@STTM
     I                                        9  100K@STHH
     I                                       11  120K@STSS
     I* END
     I            DS
     I                                        1  120K@EDDT
     I                                        1   40K@EDYY
     I                                        5   60K@EDMM
     I                                        7   80K@EDDD
     I                                        9  120K@EDTM
     I                                        9  100K@EDHH
     I                                       11  120K@EDSS
     I            DS
     I                                        1  120AAKODT
     I                                        1   80AAKOHZ
     I                                        1   40AAKOYY
     I                                        5   60AAKOMM
     I                                        7   80AAKODD
     I                                        9  120AAKOTM
     I                                        9  100AAKOHH
     I                                       11  120AAKOSS
     I            DS
     I                                        1  12 W@PART
     I                                        1   5 W@PRT1
     I                                        6  10 W@PRT2
     I                                       11  12 W@PRT3
      *---------------------------------------------------------
      *   MAIN ROUTINE
      *---------------------------------------------------------
     C                     EXSR #PRT
      *
     C                     MOVEL*IN88     P@PRNT
     C                     MOVE *ON       *INLR
     C                     RETRN
      *---------------------------------------------------------
      *   INITIAL ROUTINE
      *---------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           P@SHFT  1
     C                     PARM           P@PRNT  1
     C                     MOVEL*BLANK    P@PRNT
      *
     C                     TIME           WSDT
     C                     MOVE *ALL'-'   W@LINE112
      *
     C           P@SHFT    IFEQ '1'
     C           P@SHFT    OREQ '2'
     C                     Z-ADDWSSYYY    K@STYY
     C                     Z-ADDWSSMMM    K@STMM
     C                     Z-ADDWSSDDD    K@STDD
     C                     ELSE
     C           K#AFA     KLIST
     C                     KFLD           WSSYYY
     C                     KFLD           WSSMMM
     C                     KFLD           WSSDDD
     C           K#AFA     SETLLAGDPL12
     C           *IN98     DOUEQ*ON
     C                     READPAGDPL12                  98
     C           *IN98     IFEQ *OFF
     C                     Z-ADDF8KAYY    K@STYY
     C                     Z-ADDF8KAMM    K@STMM
     C                     Z-ADDF8KADD    K@STDD
     C                     LEAVE
     C                     END
     C                     ENDDO
     C                     END
      *
     C                     Z-ADDWSSYYY    K@EDYY
     C                     Z-ADDWSSMMM    K@EDMM
     C                     Z-ADDWSSDDD    K@EDDD
      *
     C                     SELEC
     C           P@SHFT    WHEQ '1'
     C                     Z-ADD0700      K@STTM
     C                     Z-ADD1459      K@EDTM
     C           P@SHFT    WHEQ '2'
     C                     Z-ADD1500      K@STTM
     C                     Z-ADD2259      K@EDTM
     C           P@SHFT    WHEQ '3'
     C                     Z-ADD2300      K@STTM
     C                     Z-ADD0659      K@EDTM
     C                     ENDSL
      *
     C                     ENDSR
      *---------------------------------------------------------
      *  SET DATA
      *---------------------------------------------------------
     C           #PRT      BEGSR
      *
     C           K#PL67    KLIST
     C                     KFLD           K@STYY
     C                     KFLD           K@STMM
     C                     KFLD           K@STDD
     C                     KFLD           K@STHH
     C                     KFLD           K@STSS
     C           K#PL67    SETLLAFAPL67
     C*
     C                     DO   *HIVAL
     C*
     C                     READ AFAPL67                  97
     C   97                LEAVE
     C           AASKJY    IFNE *BLANK
     C                     ITER
     C                     END
      *
     C           AAKODT    IFGE K@STDT
     C           AAKODT    ANDLTK@EDDT
     C                     EXSR #OUT
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     ENDSR
      *---------------------------------------------------------
      *  PRINT
      *---------------------------------------------------------
     C           #OUT      BEGSR
      *
     C           *IN88     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
      *
     C  N88                MOVE *ON       *IN88
      *
     C                     EXCPT@DTL
      *
     C                     ENDSR
      *------------------------------------------------------
     OQPRINT  E    1           @HED
     O                         #PGM       8
     O                         WSSDATY   88
     O                         WSSTM6    98 '  :  :  '
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O*
     O        E    2           @HED
     O                                   25 'COMBINED PARTIAL SCANNED'
     O                                   32 'RESULT'
     O                                   45 'SHIFT:'
     O                         P@SHFT    47
     O*
     O        E    4           @HED
     O                                   13 'READING INFO.'
     O                                   20 'TM#'
     O                                   36 'KANBAN#1'
     O                                   52 'KANBAN#2'
     O                                   68 'KANBAN#3'
     O                                   81 'LOT#1'
     O                                   90 'LOT#2'
     O                                   99 'LOT#3'
      *
     O        E    5           @HED
     O                                    5 'PART#'
     O                                   15 'ID'
     O                                   24 'N.LOT#'
     O                                   36 'KANBAN#4'
     O                                   52 'KANBAN#5'
     O                                   68 'KANBAN#6'
     O                                   81 'LOT#4'
     O                                   90 'LOT#5'
     O                                   99 'LOT#6'
     O                                  109 'ISSUED'
     O        E    6           @HED
     O                         W@LINE   112
     O*
     O        E 1              @DTL
     O                         AAKOHZ    10 '    /  /  '
     O                         AAKOTM    16 '  :  '
     O                         AAKOME    27
     O                         AAKAN1    42
     O                         AAKAN2    58
     O                         AAKAN3    74
     O                         AALOT1    83
     O                         AALOT2    92
     O                         AALOT3   101
     O        E 1              @DTL
     O                         AAPART    12
     O                         AAZETI    17
     O                         AANLOT    23
     O                         AAKAN4    42
     O                         AAKAN5    58
     O                         AAKAN6    74
     O                         AALOT4    83
     O                         AALOT5    92
     O                         AALOT6   101
     O                         AACOPY4  107
