     H            Y.
     F** FCKRA1 **********************************************
     F*月間設定数経歴ファイルより対象期間の必要数を取得し、*
     F*Ｎ月・Ｎ＋１月・Ｎ＋２月の数量を返す。              *
     F* 2005.02.01 MSK                                       *
     F********************************************* FCKRA1 ***
     FFCEPL11 IF  E           K        DISK                           UC
     FAGDPL12 IF  E           K        DISK                           UC
     E                    FYK        10  1               削除区分    (u)
     E                    FGK        10  9 0             月間必要数(u)
     E                    FGH        10  8 0             月間数切替日(u)
     E                    FCD        10  3 1             稼働日数(u)
     E                    WGK        10  9 0             月間必要数(W)
     E                    WGH        10  6 0             月間数切替日(W)
     E                    WCD        10  3 1             稼働日数(W)
     E                    KR         10  6 0                           (u)
     E                    KD0        10  3 1                           (u)
     E                    KD1        10  3 1                           (u)
     E                    KD2        10  3 1                           (u)
      *
     I            DS
     I                                        1  10 FYK
     I                                        1   1 FCYK01
     I                                        2   2 FCYK02
     I                                        3   3 FCYK03
     I                                        4   4 FCYK04
     I                                        5   5 FCYK05
     I                                        6   6 FCYK06
     I                                        7   7 FCYK07
     I                                        8   8 FCYK08
     I                                        9   9 FCYK09
     I                                       10  10 FCYK10
     I            DS
     I                                        1  900FGK
     I                                        1   90FCGK01
     I                                       10  180FCGK02
     I                                       19  270FCGK03
     I                                       28  360FCGK04
     I                                       37  450FCGK05
     I                                       46  540FCGK06
     I                                       55  630FCGK07
     I                                       64  720FCGK08
     I                                       73  810FCGK09
     I                                       82  900FCGK10
     I            DS
     I                                        1  800FGH
     I                                        1   80FCGH01
     I                                        9  160FCGH02
     I                                       17  240FCGH03
     I                                       25  320FCGH04
     I                                       33  400FCGH05
     I                                       41  480FCGH06
     I                                       49  560FCGH07
     I                                       57  640FCGH08
     I                                       65  720FCGH09
     I                                       73  800FCGH10
     I            DS
     I                                        1  301FCD
     I                                        1   31FCCD01
     I                                        4   61FCCD02
     I                                        7   91FCCD03
     I                                       10  121FCCD04
     I                                       13  151FCCD05
     I                                       16  181FCCD06
     I                                       19  211FCCD07
     I                                       22  241FCCD08
     I                                       25  271FCCD09
     I                                       28  301FCCD10
     I            DS
     I                                        1  12 HIN
     I                                        1   5 ISHN1
     I                                        6  10 ISHN2
     I                                       11  12 ISHN3
     I            DS
     I                                        1   6 YYMM
     I                                        1   40YY
     I                                        1   20Y1
     I                                        3   40Y2
     I                                        3   6 YM
     I                                        5   60MM
     I            DS
     I                                        1   80WWHZ
     I                                        3   80WKHZ
     I                                        1   40WKYY
     I                                        5   60WKMM
     I                                        7   80WKDD
     I            DS
     I                                        1   80FCSKHZ
     I                                        1   40FCSKYY
     I                                        5   60FCSKMM
     I                                        7   80FCSKDD
      *------------------------------------------------------*
      *  PLIST                                               *
      *      INPUT                                           *
      *        PYM   :対象年月(YYMM)                       *
      *        PHIN1 :品番１                               *
      *        PHIN2 :品番２                               *
      *        PHIN3 :品番３                               *
      *        OPNCLS:初回コール時'1'をセット            *
      *             終了時'9'をセット                  *
      *      OUTPUT                                          *
      *        PSNO  :Ｎ月必要数                           *
      *        PSNO  :Ｎ＋１月必要数                       *
      *        PSNO  :Ｎ＋２月必要数                       *
      *        PSTS  : '0'検索ＯＫ '9'検索ＮＧ           *
      *------------------------------------------------------*
     C           *ENTRY    PLIST
     C                     PARM           PYM     4
     C                     PARM           PHIN1   5
     C                     PARM           PHIN2   5
     C                     PARM           PHIN3   2
     C                     PARM           OPNCLS  1
     C                     PARM           PSN0    90
     C                     PARM           PSN1    90
     C                     PARM           PSN2    90
     C                     PARM           PSTS    1
      *----------------------------------------------------*
      *  KLIST                                             *
      *----------------------------------------------------*
     C           KEY       KLIST
     C                     KFLD           ISHN1
     C                     KFLD           ISHN2
     C                     KFLD           ISHN3
     C           KEYF81    KLIST
     C                     KFLD           KYY     40
     C                     KFLD           KMM     20
      *----------------------------------------------------*
     C           OPNCLS    IFEQ '1'
     C                     OPEN FCEPL11
     C                     OPEN AGDPL12
     C                     END
      *強制終了
     C           OPNCLS    IFEQ '9'
     C                     CLOSEFCEPL11
     C                     CLOSEAGDPL12
     C                     RETRN
     C                     END
      *
     C                     MOVEL'0'       PSTS
     C                     MOVELPYM       YM
     C           Y2        IFGE 90
     C                     Z-ADD19        Y1
     C                     ELSE
     C                     Z-ADD20        Y1
     C                     ENDIF
     C                     MOVELPHIN1     ISHN1
     C                     MOVELPHIN2     ISHN2
     C                     MOVELPHIN3     ISHN3
     C                     Z-ADD0         SN     101
     C                     Z-ADD0         SN1    101
     C                     Z-ADD0         SN2    101
     C                     EXSR $SB900
     C           *IN21     IFEQ '0'
     C                     EXSR $SB901
     C                     ENDIF
     C                     Z-ADDSN        PSN0
     C                     Z-ADDSN1       PSN1
     C                     Z-ADDSN2       PSN2
      *
     C                     EXSR $SB300
      *----------------------------------------------------*
      *     終了処理                                     *
      *----------------------------------------------------*
     CSR         $SB300    BEGSR
     C                     RETRN
     CSR         $S300E    ENDSR
      *
      *--------------------------*
      *設定数経歴ファイル      *
      *--------------------------*
     CSR         $SB900    BEGSR
     C           KEY       CHAINFCEPL111             21
     C           *IN21     IFEQ '0'
     C           FCSKJY    ANDEQ'D'
     C           FCSKHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ENDIF
      *
     C           *IN21     IFEQ '1'
     C                     MOVEL'9'       PSTS
     C                     GOTO $S900E
     C                     ENDIF
      *有効切替日データのみ抜出
     C                     Z-ADD1         X
     C                     Z-ADD0         Y
     C                     Z-ADD0         WGK
     C                     Z-ADD0         WGH
     C                     Z-ADD0         WCD
     C           1         DO   10        X
     C           FGH,X     IFNE 0
     C           FYK,X     ANDNE'*'
     C           Y         IFEQ 0
     C                     ADD  1         Y
     C                     Z-ADDFGK,X     WGK,Y
     C                     Z-ADDFGH,X     WGH,Y
     C                     Z-ADDFCD,X     WCD,Y
     C                     ELSE
     C           FGH,X     IFLT WGH,Y
     C                     ADD  1         Y
     C                     Z-ADDFGK,X     WGK,Y
     C                     Z-ADDFGH,X     WGH,Y
     C                     Z-ADDFCD,X     WCD,Y
     C                     END
     C                     END
     C                     END
     C                     ENDDO
     C*
      *切替日をソート
     C                     MOVE WGH       KR
     C                     SORTAKR
     CSR         $S900E    ENDSR
      *--------------------------*
      *稼働日より設定数取得    *
      *--------------------------*
     CSR         $SB901    BEGSR
      *
     C                     Z-ADD0         KAD1    31
     C                     Z-ADD0         KAD2    31
     C                     Z-ADD0         KAD3    31
     C                     Z-ADD0         SN     101
     C                     Z-ADD0         SN1    101
     C                     Z-ADD0         SN2    101
      *Ｎ月
     C                     Z-ADDYY        KYY
     C                     Z-ADDMM        KMM
     C           KEYF81    SETLLAGDPL121
     C                     DO   *HIVAL
     C           KEYF81    READEAGDPL121                 81
     C           *IN81     IFEQ '0'
     C           F8HIRU    IFEQ *BLANK
     C                     ADD  0.5       KAD1
     C                     EXSR $SB902
     C                     ENDIF
     C           F8YORU    IFEQ *BLANK
     C                     ADD  0.5       KAD1
     C                     EXSR $SB902
     C                     ENDIF
     C                     ENDIF
     C  N81                ENDDO
      *Ｎ＋１月
     C                     Z-ADDYY        KYY
     C           MM        ADD  1         KMM
     C           KMM       IFGT 12
     C                     Z-ADD1         KMM
     C                     ADD  1         KYY
     C                     ENDIF
     C           KEYF81    SETLLAGDPL121
     C                     DO   *HIVAL
     C           KEYF81    READEAGDPL121                 81
     C           *IN81     IFEQ '0'
     C           F8HIRU    IFEQ *BLANK
     C                     ADD  0.5       KAD2
     C                     EXSR $SB903
     C                     ENDIF
     C           F8YORU    IFEQ *BLANK
     C                     ADD  0.5       KAD2
     C                     EXSR $SB903
     C                     ENDIF
     C                     ENDIF
     C  N81                ENDDO
      *Ｎ＋２月
     C                     ADD  1         KMM
     C           KMM       IFGT 12
     C                     Z-ADD1         KMM
     C                     ADD  1         KYY
     C                     ENDIF
     C           KEYF81    SETLLAGDPL121
     C                     DO   *HIVAL
     C           KEYF81    READEAGDPL121                 81
     C           *IN81     IFEQ '0'
     C           F8HIRU    IFEQ *BLANK
     C                     ADD  0.5       KAD3
     C                     EXSR $SB904
     C                     ENDIF
     C           F8YORU    IFEQ *BLANK
     C                     ADD  0.5       KAD3
     C                     EXSR $SB904
     C                     ENDIF
     C                     ENDIF
     C  N81                ENDDO
      *
     CSR         $S901E    ENDSR
      *--------------------------*
      *Ｎ月の必要数            *
      *--------------------------*
     CSR         $SB902    BEGSR
      *
     C                     Z-ADDF8KAYY    WKYY
     C                     Z-ADDF8KAMM    WKMM
     C                     Z-ADDF8KADD    WKDD
     C                     Z-ADD10        X       20
     C                     Z-ADD1         Y       20
     C                     SETOF                         51
     C                     DO   *HIVAL
     C           KR,X      IFLE WKHZ
     C           KR,X      LOKUPWGH,Y                    20
     C                     Z-ADD0         SETI
     C           WCD,Y     IFNE 0
     C           WGK,Y     DIV  WCD,Y     SETI   101
     C                     ENDIF
     C           SETI      MULT 0.5       WSU    101
     C                     ADD  WSU       SN
     C                     ADD  0.5       KD0,Y
     C                     SETON                         51
     C                     ENDIF
     C                     SUB  1         X
     C           X         IFEQ 0
     C                     LEAVE
     C                     ENDIF
     C  N51                ENDDO
      *
     CSR         $S902E    ENDSR
      *--------------------------*
      *Ｎ＋１月の必要数        *
      *--------------------------*
     CSR         $SB903    BEGSR
      *
     C                     Z-ADDF8KAYY    WKYY
     C                     Z-ADDF8KAMM    WKMM
     C                     Z-ADDF8KADD    WKDD
     C                     Z-ADD10        X       20
     C                     Z-ADD1         Y       20
     C                     SETOF                         52
     C                     DO   *HIVAL
     C           KR,X      IFLE WKHZ
     C           KR,X      LOKUPWGH,Y                    20
     C                     Z-ADD0         SETI
     C           WCD,Y     IFNE 0
     C           WGK,Y     DIV  WCD,Y     SETI   101
     C                     ENDIF
     C           SETI      MULT 0.5       WSU    101
     C                     ADD  WSU       SN1
     C                     ADD  0.5       KD1,Y
     C                     SETON                         52
     C                     ENDIF
     C                     SUB  1         X
     C           X         IFEQ 0
     C                     LEAVE
     C                     ENDIF
     C  N52                ENDDO
      *
     CSR         $S903E    ENDSR
      *--------------------------*
      *Ｎ＋２月の必要数        *
      *--------------------------*
     CSR         $SB904    BEGSR
      *
     C                     Z-ADDF8KAYY    WKYY
     C                     Z-ADDF8KAMM    WKMM
     C                     Z-ADDF8KADD    WKDD
     C                     Z-ADD10        X       20
     C                     Z-ADD1         Y       20
     C                     SETOF                         53
     C                     DO   *HIVAL
     C           KR,X      IFLE WKHZ
     C           KR,X      LOKUPWGH,Y                    20
     C                     Z-ADD0         SETI
     C           WCD,Y     IFNE 0
     C           WGK,Y     DIV  WCD,Y     SETI   101
     C                     ENDIF
     C           SETI      MULT 0.5       WSU    101
     C                     ADD  WSU       SN2
     C                     ADD  0.5       KD2,Y
     C                     SETON                         53
     C                     ENDIF
     C                     SUB  1         X
     C           X         IFEQ 0
     C                     LEAVE
     C                     ENDIF
     C  N53                ENDDO
      *
     CSR         $S904E    ENDSR
