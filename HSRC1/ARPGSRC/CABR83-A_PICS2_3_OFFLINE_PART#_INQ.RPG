     H            Y.
     F** CABR83 ********************************************
     F* CABPP80照会                                      *
     F*  T.SAKASHITA                        2020.09.28     *
     F******************************************** BTMRC1 **
     FCABPW83 CF  E                    WORKSTN
     F                                              KINFDS INFDS
     F                                        RRN   KSFILE SFREC1
     FCABPP80 IF  E           K        DISK
      *
     IINFDS       DS
     I                                    B 378 3790$$RRN
     I****************************
     I*プログラム状況データ構造*
     I****************************
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
     C*
     C           *ENTRY    PLIST
     C                     PARM           P@HIN1  5
     C                     PARM           P@HIN2  5
     C                     PARM           P@HIN3  2
     C                     PARM           P@UKYY  40
     C                     PARM           P@UKMM  20
     C                     PARM           P@UKDD  20
     C                     PARM           P@UKBB  20
     C                     PARM           P@RTN   2
     C*
     C                     MOVE P@HIN1    W@HIN1  5
     C                     MOVE P@HIN2    W@HIN2  5
     C                     MOVE P@HIN3    W@HIN3  2
     C*
     C                     MOVE *BLANK    P@HIN1
     C                     MOVE *BLANK    P@HIN2
     C                     MOVE *BLANK    P@HIN3
     C*
     C                     Z-ADD0         P@UKYY
     C                     Z-ADD0         P@UKMM
     C                     Z-ADD0         P@UKDD
     C                     Z-ADD0         P@UKBB
     C                     MOVEL*BLANK    P@RTN
     C*
     C                     MOVE '#INIT   '@STEP   8
     C*
     C           @STEP     DOUEQ'#END    '
     C           @STEP     CASEQ'#INIT   '#INIT            初期処理
     C           @STEP     CASEQ'#DSP1   '#DSP1
     C           @STEP     CASEQ'#SKIP   '#SKIP
     C                     ENDCS
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*===============================================================
     C* 初期ﾈｮmb
     C*===============================================================
     C           #INIT     BEGSR
     C                     MOVEA*ALL'0'   *IN
     C*  SFLCLR
     C                     SETON                     72
     C                     WRITESFCTL1
     C                     SETOF                     72
     C                     Z-ADD0         RRN     40
     C                     Z-ADD0         ENDRRN  40
     C                     MOVE *BLANK    @@UMU   1        データ有無
     C*
     C           *LOVAL    SETLLCABPP80
     C*-------------------------
S1   C                     DO   *HIVAL
     C                     READ CABPP80                  90
     C   90                LEAVE
 S2  C           C3SKJY    IFEQ 'D'
     C                     ITER
 E2  C                     ENDIF
      *
     C           W@HIN1    IFNE *BLANK
     C           W@HIN1    ANDNEC3SHN1
     C                     ITER
     C                     END
      *
     C           W@HIN2    IFNE *BLANK
     C           W@HIN2    ANDNEC3SHN2
     C                     ITER
     C                     END
      *
     C           W@HIN3    IFNE *BLANK
     C           W@HIN3    ANDNEC3SHN3
     C                     ITER
     C                     END
      *
     C                     ADD  1         RRN
     C                     WRITESFREC1
E1   C                     ENDDO
     C*-------------------------
     C           RRN       IFEQ 0
     C           RRN       OREQ 1
     C                     MOVE '#SKIP   '@STEP
     C                     ELSE
     C                     MOVE '#DSP1   '@STEP
     C                     Z-ADD1         DSPRRN
     C                     ENDIF
     C                     ENDSR
     C*===============================================================
      *画面１*
     C*===============================================================
     C           #DSP1     BEGSR
      *
     C           RRN       IFEQ 0
     C                     SETON                     74
     C                     ELSE
     C                     SETON                     7174
     C                     ENDIF
     C                     WRITEDSP01
     C                     EXFMTSFCTL1
     C                     SETOF                     71
     C                     MOVEA'0'       *IN,99
     C                     Z-ADD$$RRN     DSPRRN
      *----*
      * F3 *
      *----*
     C   KC                MOVE '#END    '@STEP
     C   KC                MOVEL'88'      P@RTN
     C   KC                GOTO EDSP1
      *
     C           $RRN      IFNE 0
     C           $RRN      CHAINSFREC1               95
     C           *IN95     IFEQ *OFF
     C                     MOVE C3SHN1    P@HIN1
     C                     MOVE C3SHN2    P@HIN2
     C                     MOVE C3SHN3    P@HIN3
     C                     Z-ADDC3UKYY    P@UKYY
     C                     Z-ADDC3UKMM    P@UKMM
     C                     Z-ADDC3UKDD    P@UKDD
     C                     Z-ADDC3UKBB    P@UKBB
     C                     SETON                     LR
     C                     RETRN
     C                     END
     C                     END
      *
     C           EDSP1     ENDSR
     C*===============================================================
      * SKIP
     C*===============================================================
     C           #SKIP     BEGSR
     C*
     C           RRN       IFEQ 0
     C                     MOVEL'99'      P@RTN
     C                     ELSE
      *
     C           1         CHAINSFREC1               95
     C           *IN95     IFEQ *OFF
     C                     MOVE C3SHN1    P@HIN1
     C                     MOVE C3SHN2    P@HIN2
     C                     MOVE C3SHN3    P@HIN3
     C                     Z-ADDC3UKYY    P@UKYY
     C                     Z-ADDC3UKMM    P@UKMM
     C                     Z-ADDC3UKDD    P@UKDD
     C                     Z-ADDC3UKBB    P@UKBB
     C                     ENDIF
      *
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *
     C           ESKIP     ENDSR
