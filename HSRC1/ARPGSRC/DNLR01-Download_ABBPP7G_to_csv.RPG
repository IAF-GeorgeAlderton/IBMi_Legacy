     H            Y/                                    1
     H** DNLR01 *******************************************************
     H*  DOWNLOAD ABBPP7G TO CSV                                      *
     H*  J.WATANABE  2021.06.18                                      *
     H*****************************************************************
     FABBPL7G IF  E           K        DISK
     FDNLWP01 O   E                    DISK
      *================================================================
     C*  START  PROGRAM
     C*===============================================================
     C                     EXSR #HEAD
     C                     EXSR #DTL
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
     C*===============================================================
     C* SET HEADER
     C*===============================================================
     C           #HEAD     BEGSR
      *
     C                     MOVEL'SIZE'    D1SIZE    P
     C                     MOVEL'MACHINE' D1MANO    P
     C                     MOVEL'LOCATION'D1LOCT    P
     C                     MOVEL'UPD DATE'D1DATE    P
     C                     MOVEL'UPD TIME'D1TIME    P
     C                     MOVEL'UPD USER'D1USER    P
     C                     WRITEDNLWP011
      *
     C                     ENDSR
     C*===============================================================
     C* SET DETAIL
     C*===============================================================
     C           #DTL      BEGSR
     C           *LOVAL    SETLLABBPL7G
     C                     DO   *HIVAL
     C                     READ ABBPL7G                  98
     C   98                LEAVE
      * END
     C           A#SKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      *
     C                     MOVELA#SIZE    D1SIZE    P
     C                     MOVELA#MANO    D1MANO    P
     C                     MOVELA#LOCT    D1LOCT    P
      *
     C                     MOVELA#DATE    $SRC      P
     C                     CALL 'UTLR01A'
     C                     PARM           $SRC   10
     C                     PARM           $TRUE1  8
     C                     PARM           $TRUE2 10
     C                     PARM           $RTN1   1
     C                     MOVEL$TRUE2    D1DATE    P
      *
     C                     MOVELA#TIME    $TIME6    P
     C                     CALL 'UTLR01C'
     C                     PARM           $TIME6  6
     C                     PARM           $TIME8  8
     C                     PARM           $RTN2   1
     C           $RTN2     IFEQ *BLANK
     C                     MOVEL$TIME8    D1TIME    P
     C                     ELSE
     C                     MOVELA#TIME    D1TIME    P
     C                     ENDIF
      *
     C                     MOVELA#USER    D1USER    P
      *
     C                     WRITEDNLWP011
     C                     ENDDO
      *
     C                     ENDSR
