     H            Y.
     F** AFAR70 *********************************************
     F*  COMBINED PARTIAL CONTAINERS DAILY LIST   *
     F*      SEP/05/03                                      *
     F******************************************* AFAR69 ****
     F*AFAPL65 IF  E           K        DISK
     FAFAPL66 IF  E           K        DISK
     FAGDPL12 IF  E           K        DISK
     FQPRINT  O   F     132     OF     PRINTER
     ********************************************************
     I* SYSTEM DATE
     I            DS
     I                                        1  120WTIME
     I                                        1   60SYTM1
     I                                        7  120SYDT1
     I            DS
     I                                        1   80W@DATE
     I                                        1   40K@YY
     I                                        5   60K@MM
     I                                        7   80K@DD
     I            DS
     I                                        1   80AADATE
     I                                        1   40AAYYYY
     I                                        5   60AAMMMM
     I                                        7   80AADDDD
     I            DS
     I                                        1  12 W@PART
     I                                        1   5 W@PRT1
     I                                        6  10 W@PRT2
     I                                       11  12 W@PRT3
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *---------------------------------------------------------
      *   MAIN ROUTINE
      *---------------------------------------------------------
     C                     EXSR #PRT
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *---------------------------------------------------------
      *   INITIAL ROUTINE
      *---------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           K#AFA     KLIST
     C                     KFLD           K@YY
     C                     KFLD           K@MM
     C                     KFLD           K@DD
      *
     C                     TIME           WTIME
     C                     MOVE *ALL'-'   W@LINE 35
      *
     C                     ENDSR
      *---------------------------------------------------------
      *  SET DATA
      *---------------------------------------------------------
     C           #PRT      BEGSR
      *
     C                     Z-ADD*DATE     W@DATE
     C           K#AFA     SETLLAGDPL12
     C           *IN90     DOUEQ*ON
     C                     READPAGDPL12                  90
     C           *IN90     IFEQ *OFF
     C           F8HIRU    ANDEQ*BLANK
     C           F8YORU    ANDEQ*BLANK
     C                     Z-ADDF8KAYY    K@YY
     C                     Z-ADDF8KAMM    K@MM
     C                     Z-ADDF8KADD    K@DD
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVE *BLANK    W@ZETI  4
     C                     Z-ADD*ZERO     W@BOX   50
     C           K#AFA     SETLLAFAPL66
     C           *IN80     DOUEQ*ON
     C           K#AFA     READEAFAPL66                  80
     C           *IN80     IFEQ *OFF
      *
     C           W@ZETI    IFNE *BLANK
     C           W@ZETI    ANDNEAAZETI
     C                     EXSR #OUT
     C                     Z-ADD*ZERO     W@BOX
     C                     ENDIF
      *
     C                     MOVE AAZETI    W@ZETI
     C                     MOVE AAPART    W@PART
     C                     ADD  AACOPY    W@BOX
     C                     ENDIF
     C                     ENDDO
      *
     C           W@BOX     IFNE *ZERO
     C                     EXSR #OUT
     C                     ENDIF
      *
     C                     ENDSR
      *---------------------------------------------------------
      *  PRINT
      *---------------------------------------------------------
     C           #OUT      BEGSR
      *
     C           *IN98     IFEQ *OFF
     C           *INOF     OREQ *ON
     C                     EXCPT@HED
     C                     ENDIF
      *
     C  N98                MOVE *ON       *IN98
      *
     C                     EXCPT@DTL
      *
     C                     ENDSR
      *------------------------------------------------------
     OQPRINT  E    1           @HED
     O                         #PGM       8
     O                         UDATE Y   88
     O                         SYTM1     98 '  :  :  '
     O                                  104 'PAGE'
     O                         PAGE  Z  108
     O*
     O        E    2           @HED
     O                                   25 'COMBINED PARTIAL SCANNED'
     O                                   32 'RESULT'
     O*
     O        E    3           @HED
     O                                    9 'DATE :'
     O                         W@DATE    20 '    /  /  '
      *
     O        E    5           @HED
     O                                    5 'PART#'
     O                                   20 'ID'
     O                                   30 'BOXES'
     O        E    6           @HED
     O                         W@LINE    35
     O*
     O        E 1              @DTL
     O                         W@PRT1     5
     O                         W@PRT2    11
     O                         W@PRT3    14
     O                         W@ZETI    20
     O                         W@BOX 1   30
