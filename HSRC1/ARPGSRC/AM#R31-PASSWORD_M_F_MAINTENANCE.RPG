     F** AM#R31 *********************************************
     F*  PASSWORD M/F                                       *
     F*  ITS.     2015.06.04                                *
JW1  F*  JW       2019.10.25 ADD OPT5 FOR QD                *
JW2  F*  JW       2019.11.07 CHG INQUIRY PROGRAM (AM#R32)   *
JW2  F*  JW       2019.11.07 CHG ACCESS AUTHORITY           *
     F*******************************************************
     FAM#PW31 CF  E                    WORKSTN
     FAM#PP31 UF  E           K        DISK                      A
     FALBPL30 IF  E           K        DISK
     E                    ER      1  20 60
     E                    PG      1  10 10
     E                    R3P        10  1
      *
     I            DS
     I                                        1  140SDATE
     I                                        1   60WTIME
     I                                        7  140WDATE
      *
     I            DS
     I                                        1   80ALSKHZ
     I                                        1   40ALSKYY
     I                                        5   60ALSKMM
     I                                        7   80ALSKDD
      *
     I            DS
     I                                        1  10 R3P
     I                                        1   1 R3PGM1
     I                                        2   2 R3PGM2
     I                                        3   3 R3PGM3
     I                                        4   4 R3PGM4
     I                                        5   5 R3PGM5
     I                                        6   6 R3PGM6
     I                                        7   7 R3PGM7
     I                                        8   8 R3PGM8
     I                                        9   9 R3PGM9
     I                                       10  10 R3PGMA
      *
     I           SDS
     I                                     *PROGRAM W#PGM
     I                                      244 253 W#WSID
     I                                      254 263 W#USER
     I                                      264 269 W#JBNO
      *
     C           *ENTRY    PLIST
     C                     PARM           P1PGM   20
JW1  C                     MOVELP1PGM     IX      20
      *
      *----------------------------------------------------*
      *   K  E  Y   L  I  S  T                             *
      *----------------------------------------------------*
      *
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     C                     TIME           SDATE
     C                     EXSR #SB100
     C           DSPSW     DOUEQ'99'
     C                     EXSR #SB200
     C                     ENDDO
     C                     EXSR #SB300
      *----------------------------------------------------*
      * INZ                                                *
      *----------------------------------------------------*
     CSR         #SB100    BEGSR
      *
     C                     MOVEL'01'      DSPSW   2
     C                     MOVEL*BLANK    D1UPD
     C                     Z-ADD0         D1WKCD
     C                     MOVEL*BLANK    D1WKNM
     C                     Z-ADDP1PGM     X       20
     C**                   MOVELPG,X      D1TXT
     C                     MOVELPG,X      D1TTL
      *
     CSR         ESB100    ENDSR
      *----------------------------------------------------*
      * MAIN                                               *
      *----------------------------------------------------*
     CSR         #SB200    BEGSR
      *
     C           DSPSW     DOWEQ'01'
     C                     EXSR #SB210
     C                     ENDDO
      *
     C           DSPSW     DOWEQ'02'
     C                     EXSR #SB220
     C                     ENDDO
      *
     CSR         ESB200    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB210    BEGSR
      *
     C                     EXFMTAM#PW311
     C                     SETOF                     303132
     C                     SETOF                     333435
     C                     SETOF                     99
     C                     MOVEL*BLANK    D1ERR
      *
     C           *IN01     IFEQ '1'
     C                     MOVEL'99'      DSPSW
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           *IN10     IFEQ '1'
     C                     CALL 'ALBC30'
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           *IN12     IFEQ '1'
JW2  C                     CALL 'AM#R32'
     C                     PARM           P1PGM
JW2  C                     PARM           P1WKCD  60
     C           P1WKCD    IFNE 0
     C                     Z-ADDP1WKCD    D1WKCD
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
     C           D1UPD     IFEQ *BLANK
     C                     MOVELER,1      D1ERR
     C                     SETON                     3099
     C                     GOTO ESB210
     C                     ENDIF
      *
     C           D1UPD     IFEQ '0'
     C           D1UPD     OREQ '1'
     C           D1UPD     OREQ '2'
     C                     ELSE
     C                     MOVELER,1      D1ERR
     C                     SETON                     3099
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     MOVEL*BLANK    D1WKNM
     C           D1WKCD    IFEQ 0
     C                     MOVELER,2      D1ERR
     C                     SETON                     3199
     C                     GOTO ESB210
     C                     ENDIF
      *
     C                     MOVEL*BLANK    WKWKNM 20
     C           D1WKCD    CHAINALBPL301             21
     C           *IN21     IFEQ '0'
     C                     MOVELALWKNM    WKWKNM
     C                     ENDIF
     C           *IN21     IFEQ '0'
     C           ALSKJY    ANDEQ'D'
     C           ALSKHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ENDIF
      *
     C           D1UPD     IFEQ '1'
     C           D1UPD     OREQ '2'
     C           *IN21     IFEQ '1'
     C                     MOVELER,3      D1ERR
     C                     SETON                     3199
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
     C                     MOVELWKWKNM    D1WKNM
      *
     C           D1WKCD    CHAINAM#PP311             21
     C           *IN21     IFEQ '0'
     C           R3SKJY    ANDEQ'D'
     C           R3SKHZ    ANDLE*DATE
     C                     SETON                     21
     C                     ENDIF
      * MODE: DLT/CHG
     C           *IN21     IFEQ '1'
     C           D1UPD     IFEQ '0'
     C           D1UPD     OREQ '1'
     C                     MOVELER,5      D1ERR
     C                     SETON                     303199
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
JW2   * MODE: DLT/CHG
 |   C           *IN21     IFEQ '0'
 |   C           D1UPD     IFEQ '0'
 |   C           D1UPD     OREQ '1'
 |   C           R3P,IX    IFEQ ' '
 |   C                     MOVELER,4      LTR40  40
 |   C                     MOVE PG,IX     LTR40
 |   C                     MOVELLTR40     D1ERR     P
 |   C                     SETON                     303199
 |   C                     GOTO ESB210
 |   C                     ENDIF
 |   C                     ENDIF
JW2  C                     ENDIF
      * MODE: ADD
     C           *IN21     IFEQ '0'
     C           D1UPD     IFEQ '2'
JW2  C           R3P,IX    ANDEQ'1'
     C                     MOVELER,6      D1ERR
     C                     SETON                     303199
     C                     GOTO ESB210
     C                     ENDIF
     C                     ENDIF
      *
     C                     SETOF                     19
     C                     SELEC
      *
     C           D1UPD     WHEQ '0'
     C                     MOVELR3P,IX    D2PGM
     C                     SETON                     19
      *
     C           D1UPD     WHEQ '1'
     C                     MOVELR3P,IX    D2PGM
      *
     C           D1UPD     WHEQ '2'
     C                     MOVEL*BLANK    D2PGM
      *
     C                     ENDSL
      *
     C                     MOVE '02'      DSPSW   2
      *
     CSR         ESB210    ENDSR
      *----------------------------------------------------*
      *                                                    *
      *----------------------------------------------------*
     CSR         #SB220    BEGSR
      *
     C                     EXFMTAM#PW312
     C                     SETOF                     303132
     C                     SETOF                     99
     C                     MOVEL*BLANK    D2ERR
      * F3
     C           *IN03     IFEQ '1'
     C                     MOVEL*BLANK    D1UPD
     C                     Z-ADD0         D1WKCD
     C                     MOVEL*BLANK    D1WKNM
     C                     MOVE '01'      DSPSW
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           D2PGM     IFEQ ' '
     C           D2PGM     OREQ '1'
     C                     ELSE
     C                     MOVELER,7      D2ERR
     C                     SETON                     303199
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           *IN05     IFEQ '0'
     C                     GOTO ESB220
     C                     ENDIF
      *
     C           D1WKCD    CHAINAM#PP311             21
     C                     SELEC
     C           D1UPD     WHEQ '0'
     C                     EXSR #DLT
     C           D1UPD     WHEQ '1'
     C                     EXSR #UPD
     C           D1UPD     WHEQ '2'
     C                     EXSR #WRT
     C                     ENDSL
      *
     C                     MOVEL*BLANK    D1UPD
     C                     Z-ADD0         D1WKCD
     C                     MOVEL*BLANK    D1WKNM
     C                     MOVE '01'      DSPSW   2
      *
     CSR         ESB220    ENDSR
      *----------------------------------------------------*
      * END                                                *
      *----------------------------------------------------*
     CSR         #SB300    BEGSR
     C                     SETON                     LR
     C                     RETRN
     CSR         ESB300    ENDSR
      *----------------------------------------------------*
      * DELETE                                             *
      *----------------------------------------------------*
     CSR         #DLT      BEGSR
      *
     C           *IN21     IFEQ '0'
     C**                   MOVEL'D'       R3SKJY
     C**                   Z-ADD*DATE     R3SKHZ
     C                     MOVE ' '       R3P,IX
     C                     UPDATAM#PP311
     C                     ENDIF
      *
     CSR         EDLT      ENDSR
      *----------------------------------------------------*
      * CHANGE                                             *
      *----------------------------------------------------*
     CSR         #UPD      BEGSR
      *
     C           *IN21     IFEQ '0'
     C                     Z-ADD*DATE     R3KOHZ
     C                     TIME           R3KOTI
     C                     MOVELW#USER    R3KOME
     C                     MOVELD2PGM     R3P,IX
     C                     UPDATAM#PP311
     C                     ENDIF
      *
     CSR         EUPD      ENDSR
      *----------------------------------------------------*
      * ADD                                                *
      *----------------------------------------------------*
     CSR         #WRT      BEGSR
      *
     C**                   CLEARAM#PP311
     C                     MOVEL*BLANK    R3SKJY
     C                     Z-ADD0         R3SKHZ
     C                     Z-ADD*DATE     R3KOHZ
     C                     TIME           R3KOTI
     C                     MOVELW#USER    R3KOME
     C                     Z-ADDD1WKCD    R3WKCD
     C                     MOVELD2PGM     R3P,IX
     C           *IN21     IFEQ '0'
     C                     UPDATAM#PP311
     C                     ELSE
     C                     WRITEAM#PP311
     C                     ENDIF
      *
     CSR         EWRT      ENDSR
** ER,
E-01 ENTER 0,1 OR 2 !
E-02 ENTER WORKER NO.!
E-03 WORKER NOT FOUND !
E-04 WORKER IS NOT ASSINED TO
E-05 NO DATA IN M/F
E-06 ALREADY EXIST !
E-07 ENTER 1 !
** PG,
SHIPPING
CONVEYANCE
PACKING
HEAT TREAT
QD
