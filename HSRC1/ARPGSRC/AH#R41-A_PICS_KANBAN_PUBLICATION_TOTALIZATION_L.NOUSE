     I            DS
     I                                        1   80B2SKHZ
     I                                        1   40B2SKYY
     I                                        5   60B2SKMM
     I                                        7   80B2SKDD
     I            DS
     I                                        1   80F8KAHZ
     I                                        1   40F8KAYY
     I                                        5   60F8KAMM
     I                                        7   80F8KADD
     C           *ENTRY    PLIST
     C                     PARM           US     10
      *
     C  N01                GOTO @END
      *
     C           *IN90     IFEQ '0'
     C                     MOVEA'1'       *IN,90
     C                     Z-ADD0         MAIS
     C                     Z-ADD0         TEN
     C                     Z-ADD0         KHIZ    20
     C                     MOVE *ALL'~'   W128  128
     C                     Z-ADD0         HEM
     C                     Z-ADD0         HET
     C                     Z-ADD0         GOM
     C                     Z-ADD0         GOT
     C                     MOVEL'1'       *INOF
     C                     MOVEA'1'       *IN,21
     C                     Z-ADD0         CNT     30
     C                     END
      *
     C           *IN,21    IFEQ '1'
     C                     MOVE *BLANK    USNM
     C           US        CHAINRGAPL111             11
     C           *IN,11    IFEQ '0'
     C           J8SKJY    ANDEQ'D'
     C                     MOVEA'1'       *IN,11
     C                     END
      *
     C  N11                MOVELJ8NAME    USNM
      *
     C                     MOVE *BLANK    NAME
     C           @KOJO     IFEQ 8907
     C                     MOVEL'PURCHS'  NAME
     C                     ELSE
     C           @BMON     CHAINFGBPL011             10
     C           *IN,10    IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,10
     C                     END
      *
     C  N10                MOVELB2SMEI    NAME
     C                     END
      *
     C           @BMON     CHAINFGBPL011             20
     C           *IN,20    IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     MOVEA'1'       *IN,20
     C                     END
      *
     C  N20                MOVELB2SMEI    @NAME
      *
     C                     TIME           TIME    60
     C                     Z-ADD*DATE     DAY     60
     C                     ADD  1         CNT
     C                     WRITEHED
     C                     MOVEA'0'       *IN,21
     C                     END
      *
     C           @BIN      IFLE 10
     C                     Z-ADD@BIN      Z       20
     C                     ADD  @MAIS     MAIS,Z
     C                     ADD  1         TEN,Z
     C                     END
      *
     C           @END      TAG
      *
     CL1                   XFOOTMAIS      MAI11
     CL1                   XFOOTTEN       TEN11
     CL1                   ADD  MAI11     GMAI    60
      *
     CL1                   EXSR SUB1
     CL1                   WRITEDET
     CL1                   Z-ADD0         MAIS
     CL1                   Z-ADD0         TEN
     CL1                   ADD  MAI11     WGMAI   80
     CL1                   ADD  TEN11     WGTEN   70
     CL1                   Z-ADD0         MAI11
     CL1                   Z-ADD0         TEN11
      *
     CL2                   XFOOTGOM       GOM11
     CL2                   XFOOTGOT       GOT11
     CL2                   EXSR SUB3
     CL2                   EXSR SUB2
     CL2                   WRITETOT
     CL2                   Z-ADD0         HEM
     CL2                   Z-ADD0         HET
     CL2                   Z-ADD0         GOM
     CL2                   Z-ADD0         GOT
     CL2                   Z-ADD0         GMAI
     CL2                   Z-ADD0         WGMAI
     CL2                   Z-ADD0         WGTEN
     CL2                   MOVEA'1'       *IN,21
      *
     C******************************************************
     C*              便単位のカウント
     C******************************************************
     C           SUB1      BEGSR
      *
     C                     Z-ADD1         A       20
     C                     DO   10        A
     C                     ADD  MAIS,A    GOM,A
     C                     ADD  TEN,A     GOT,A
     C                     END
      *
     C                     ENDSR
      *
     C******************************************************
     C*                便単位の平均
     C******************************************************
     C           SUB2      BEGSR
      *
     C                     Z-ADD1         B       20
     C                     DO   10        B
     C           GOM,B     DIV  KHIZ      HEM,B     H
     C           GOT,B     DIV  KHIZ      HET,B     H
     C                     END
      *
     C           WGMAI     DIV  KHIZ      HEM11     H
     C           WGTEN     DIV  KHIZ      HET11     H
      *
     C                     ENDSR
      *
     C******************************************************
     C*                 稼働日計算
     C******************************************************
     C           SUB3      BEGSR
      *
     C                     Z-ADD0         KHIZ
     C                     SETOF                     55
     C           WYM       KLIST
     C                     KFLD           @YY
     C                     KFLD           @MM
      *
     C           WYM       SETLLAGDPL121
     C                     DO   *HIVAL
     C                     SETOF                         55
     C           WYM       READEAGDPL121                 55
     C           *IN55     IFEQ '0'
     C           F8KAHZ    IFLE *DATE
     C           F8HIRU    IFEQ '*'
     C           F8YORU    ANDEQ'*'
     C                     ELSE
     C                     ADD  1         KHIZ
     C                     END
     C                     ELSE
     C                     SETON                     55
     C                     END
     C                     END
     C  N55                ENDDO
      *
     C                     ENDSR
