     H            Y.
     F** AFGR06 *********************************************
     F* CREATE EDI ORDER 850 DETAIL                         *
     F*     T.SAKAKI                        2016.11.15      *
     F*******************************************************
     FAFGPL03 IF  E           K        DISK
      * FLAT DATA
     FOUTPUT  O   F    1075            DISK
      *
     I            DS
     I                                        1  140@TIME
     I                                        1   60@SYSTM
     I                                        9  140@SYHZ6
     I                                        7  140@SYSHZ
     I            DS
     I                                        1  11 W2ORDQ
     I                                        1   9 W2ORDL
     I                                       10  11 W2ORDR
     I            DS
     I                                        1   9 W3ORDQ
     I                                        1   6 W3ORDL
     I                                        7   7 W3ORD2
     I                                        8   9 W3ORDR
     I            DS
     I                                        1  10 W4ORDQ
     I                                        1   7 W4ORDL
     I                                        8   8 W4ORD2
     I                                        9  10 W4ORDR
     I*
     I            DS
     I                                        1  13 W1UNTP
     I                                        1   8 W1UNTL
     I                                        9  13 W1UNTR
     I            DS
     I                                        1  14 W2UNTP
     I                                        1   8 W2UNTL
     I                                        9   9 W2UNT2
     I                                       10  14 W2UNTR
     I*
     I            DS
     I                                        1   80AGREQD
     I                                        3   80AGREQ6
     I           SDS
     I                                     *PROGRAM W$PGM
     I                                      244 253 W$WSID
     I                                      254 263 W$USER
     I                                      264 269 W$JBNO
      *
     I              '0123456789'          C         DIGITS
      *================================================================
      *  ENTRY LIST
      *================================================================
     C           *ENTRY    PLIST
     C                     PARM           P@SUPP  4
     C                     PARM           P@GPPO 17
     C                     PARM           P@SERN 10
      *================================================================
      *  KEY LIST
      *================================================================
      *================================================================
     C* MAIN
      *================================================================
     C                     TIME           @TIME
     C                     MOVE P@SERN    P@SER6  6
     C*
     C                     Z-ADD1         WKASID  60
     C*
     C           P@GPPO    SETLLAFGPL031
     C                     DO   *HIVAL
     C           P@GPPO    READEAFGPL031                 80
     C   80                LEAVE
     C*  DELETED RECORD ?
     C           AGSKJY    IFEQ 'D'
     C           AGSKDT    ANDLE@SYSHZ
     C                     ITER
     C                     END
     C*  DOES NOT MATCH SUPPLIER ?
     C                     MOVELAGVDCD    WKSUPP  4
     C           P@SUPP    IFNE WKSUPP
     C                     ITER
     C                     END
      * CONVERT
      *   AGORDQ
     C                     Z-ADDAGORDQ    W1ORDQ 112
     C                     MOVE W1ORDQ    W2ORDQ 11
     C           W2ORDR    IFEQ '00'
     C                     MOVE W2ORDL    W3ORDQ  9
     C                     MOVE W2ORDL    W4ORDQ 10
     C                     ELSE
     C                     MOVE W2ORDL    W3ORDL
     C                     MOVE '.'       W3ORD2
     C                     MOVE W2ORDR    W3ORDR
     C                     MOVE W2ORDL    W4ORDL
     C                     MOVE '.'       W4ORD2
     C                     MOVE W2ORDR    W4ORDR
     C                     ENDIF
      *   AGUNTP
     C                     MOVE AGUNTP    W1UNTP 13
     C                     MOVE W1UNTL    W2UNTL
     C                     MOVE '.'       W2UNT2
     C                     MOVE W1UNTR    W2UNTR
     C*
     C*
     C                     EXCPTDTWRT
     C                     ADD  1         WKASID
     C*
     C                     ENDDO
     C*
     C*
     C                     SETON                     LR
     C                     RETRN
      *================================================================
      * OUTPUT
      *================================================================
     OOUTPUT  E                DTWRT
     O                                    1 'D'
     O* RECORD ID  2-7
     O                         P@SER6     7
     O*------------------------------------------------
     O* PO101 : ASSIGNED IDENTIFICATION  8-13
     O                         WKASID    13
     O* PO102 : QUANTITY ORDERED  14-22
     O                         W3ORDQ    22
     O* PO103 : UNIT CODE 23-24
     O                         AGUNCD    24
     O* PO104 : UNIT PRICE  25-38
     O                         W2UNTP    38
     O* PO105 : UNIT PRICE CODE 39-40
     O                         AGUOM2    40
     O* PO107 : PRODUCT/SERVICE ID  41-70
     O                         AGINBR    70
     O* CUR02 : CURRENCY CODE  71-73
     O                         AGCURR    73
     O* PID02 : ITEM DESCRIPTION  74-153
     O                         AGITDS   153
     O* SCH01 : QUANTITY  154-163
     O                         W4ORDQ   163
     O* SCH02 : UNIT CODE  164-165
     O                         AGUNCD   165
     O* SCH07 : REQUESTED DATE  166-171
     O                         AGREQ6   171
