     C           *ENTRY    PLIST
     C                     PARM           USER   10
     C                     PARM           PTYPE   1
     C                     PARM           KBN     1
      *----------------------------------------------------------------
      *  KEY LIST
      *----------------------------------------------------------------
     C           KEY01     KLIST
     C                     KFLD           K@SHN1  5
     C                     KFLD           K@SHN2  5
     C                     KFLD           K@SHN3  2
     C*
     C           KEY02     KLIST
     C                     KFLD           K@KAT1  2
     C                     KFLD           K@KAT2  4
     C*
     C           KEY03     KLIST
     C                     KFLD           K@KKT1
     C                     KFLD           K@KKT2
     C*
     C           KEY04     KLIST
     C                     KFLD           K@KAT1
     C                     KFLD           K@KAT2
     C                     KFLD           K@KKT1  2
     C                     KFLD           K@KKT2  4
     C                     KFLD           K@KOJY  4
      *
     C           KEY07     KLIST
     C                     KFLD           K@KKT1
     C           KEYA1     KLIST
     C                     KFLD           @NKT1   2
     C                     KFLD           @NKT2   4
     C                     KFLD           @NKT3   1
     C*
     C                     READ CCQWP02                  90
     C           *IN90     DOWEQ'0'
     C*
     C                     MOVELISHN1     K@SHN1
     C                     MOVELISHN2     K@SHN2
     C                     MOVELISHN3     K@SHN3
     C*
     C           KEY01     SETLLWK350W01
     C                     EXSR $RED1
     C           REDFLG    IFEQ '0'
     C*<< NEW >>
     C           IKTBN     IFEQ *BLANK
     C                     MOVEL*BLANK    W@ODNW  1
     C                     EXSR $WRT1
     C                     ELSE
     C                     MOVEL'1'       W@ODNW
     C                     EXSR $WRT1
     C                     ENDIF
     C                     ELSE
     C*<< OLD >>
     C                     EXSR $WRT2
     C                     ENDIF
     C*
     C                     READ CCQWP02                  90
     C                     ENDDO
     C*
     C                     SETON                     LR
     C                     RETRN
     C*
     C*****************************************************
     C*  $RED1  READ WK300L1                            *
     C*****************************************************
     C           $RED1     BEGSR
     C*
     C                     MOVEL'0'       REDFLG  1
     C*
     C           REDFLG    DOWEQ'0'
     C           KEY01     READEWK350W01                 91
     C           *IN91     IFEQ '1'
     C                     MOVEL'1'       REDFLG
     C                     ELSE
     C                     LEAVE
     C                     END
     C*
     C                     ENDDO
     C*
     C           $RED1E    ENDSR
     C*****************************************************
     C*  $WRT1  WRITE CCQWP06                           *
     C*****************************************************
     C           $WRT1     BEGSR
     C*
     C           IKTBN     IFNE '1'
     C*<<引当型>>
     C           PTYPE     IFNE '3'
     C                     EXCPTDT
     C                     ENDIF
     C*<<型部品>>
     C           PTYPE     IFNE '2'
     C                     EXSR $WRT3
     C                     ENDIF
      *
     C                     ELSE
     C                     EXCPTDT
     C                     ENDIF
     C*
     C           $WRT1E    ENDSR
     C*****************************************************
     C*  $WRT2  WRITE CCQWP07                           *
     C*****************************************************
     C           $WRT2     BEGSR
     C*
     C                     EXCPTDT3
     C*
     C           $WRT2E    ENDSR
     C*****************************************************
     C*  $WRT3  WRITE CCQWP06                           *
     C*****************************************************
     C           $WRT3     BEGSR
     C*
     C                     MOVELIKAT1     K@KAT1
     C                     MOVELIKAT2     K@KAT2
     C           KEY02     SETLLWK400L11
     C                     EXSR $RED3
     C           *IN92     DOWEQ'0'
     C                     Z-ADDK4KOSU    W@KOSU  20
     C*
     C                     MOVEL*BLANK    W@KANM 10
     C           KEY07     CHAINFCQPL211             93
     C           *IN93     IFEQ '0'
     C                     MOVELO9KANM    W@KANM
     C                     ENDIF
     C*
     C                     MOVE *BLANK    WOKAT  15
     C           KEY03     CHAINFCQPL311             94
     C           *IN94     IFEQ '0'
     C                     MOVELQ4QKAT    WOKAT
     C                     ENDIF
     C*
     C*------------------------------*
     C*   ..型かんばんマスター..   *
     C*   ..新型番                 *
     C*------------------------------*
     C                     MOVE *BLANK    WTKRO
      *
     C                     MOVELK4KKT1    @NKT1
     C                     MOVELK4KKT2    @NKT2
     C                     MOVEL*BLANK    @NKT3
     C           KEYA1     SETLLGCQPL121
     C                     DO   *HIVAL
     C                     SETOF                     30
     C           KEYA1     READEGCQPL121                 30
     C           *IN30     IFEQ '0'
     C           T6SKJY    IFEQ 'D'
     C           T6SKHZ    ANDLE*DATE
     C                     ELSE
     C           *DATE     IFGE T6KIHZ
     C                     SETON                     30
     C                     MOVE T6TKR2    WTKR2
     C                     MOVE T6TKR3    WTKR3
     C                     MOVE T6TKR4    WTKR4
     C                     END
     C                     END
     C                     END
     C  N30                END
      *
     C           WTKR3     IFNE *BLANK
     C                     MOVE '-'       H1
     C                     END
     C           WTKR4     IFNE *BLANK
     C                     MOVE '-'       H2
     C                     END
     C           WTKR5     IFNE *BLANK
     C                     MOVE '-'       H3
     C                     END
     C*
     C                     EXCPTDT2
     C                     EXSR $RED3
     C                     ENDDO
     C*
     C           $WRT3E    ENDSR
     C*****************************************************
     C*  $RED3  READ  WK400L11 <<型構成マスター>>     *
     C*****************************************************
     C           $RED3     BEGSR
     C*
     C           @RED3     TAG
     C*
     C           KEY02     READEWK400L11                 92
     C           *IN92     IFEQ '0'
     C           K4SKJY    IFEQ 'D'
     C           K4SKHZ    ANDLE*DATE
     C                     GOTO @RED3
     C                     ENDIF
     C*
     C                     MOVELK4KKT1    K@KKT1
     C                     MOVELK4KKT2    K@KKT2
     C                     EXSR $KOJO
     C                     SETOF                     95
     C           KEY04     SETLLWK420L11
     C           *IN95     DOWEQ'0'
     C           KEY04     READEWK420L11                 95
     C           *IN95     IFEQ '1'
     C                     GOTO @RED3
     C                     ELSE
     C           K2SKJY    IFEQ 'D'
     C           K2SKHZ    ANDLE*DATE
     C                     ELSE
     C                     LEAVE
     C                     ENDIF
     C                     ENDIF
     C                     ENDDO
     C*
     C                     MOVEL'1'       OYAFLG  1
     C           K4OYAK    IFEQ 'O'
     C                     MOVEL'0'       OYAFLG
     C                     ENDIF
     C                     ENDIF
     C*
     C           $RED3E    ENDSR
