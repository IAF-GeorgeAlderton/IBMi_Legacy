      ***********************************************************************
     FAB#PWBB CF  E                    WORKSTN
     FAB#NP31 UF  E           K        DISK                      A
     FAB#PL76 IF  E           K        DISK
     FAB#PL13 IF  E           K        DISK
     FAB#PL1A IF  E           K        DISK
     FAB#PP70 O   E                    DISK                      A
     FAB#WP2Q O   E           K        DISK                           UC
     FAB#PL66 IF  E           K        DISK                      A
JW4  FAB#XP01AO   E                    DISK
      *****************************************************************
     E                    ER      1  15 60
     E                    MNO        10  8
     E                    CMD     1   1 60
     E                    HOME       10  1
     I*****************************************************************
     I@INFDA      DS
     I                                    B 397 4000@@RCD
     I            DS
     I                                        1   60@@TIM
     I                                        1   20@@HH
     I                                        3   40@@MM
     I            DS
     I                                        1   80PUDAT
     I                                        1   40PUNOYY
     I                                        5   60PUNOMM
     I                                        7   80PUNODD
      * SHIPPING DATE(DISPLAY)
     I            DS
     I                                        1   80K@NOHZ
     I                                        1   40PNOYY
     I                                        3   40PNOY
     I                                        4   40PY
     I                                        5   60PNOMM
     I                                        7   80PNODD
      *
     ISHIN        DS
     I                                        1   5 BASHN1
     I                                        6  10 BASHN2
     I                                       11  12 BASHN3
      *
JW4  I            DS
 .   I                                        1  140SDATE
 .   I                                        1   60NOW
 .   I                                        7  140TODAY
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *---------------------------------------------------------
      *  MAIN
      *---------------------------------------------------------
     C           @@DSP     DOWNE'99'
     C           @@DSP     CASEQ'01'      #SCRN1
     C           @@DSP     CASEQ'02'      #SCRN2
     C                     ENDCS
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *-------------------------------------------------------
      * INITIALIZE
      *-------------------------------------------------------
     C           *INZSR    BEGSR
      *
     C           P2        PLIST
     C                     PARM           PIQTY  300       NUMERIC QTY
     C                     PARM           POQTY  30        CHAR    QTY
      *
     C           P#CMD     PLIST
     C                     PARM           P@CMD 256
     C                     PARM           P@LEN  155
      ***********************************************************************
      * KEY1                                                                *
      ***********************************************************************
     C           K#66X     KLIST
     C                     KFLD           K@CUST
     C                     KFLD           K@NONY
     C                     KFLD           K@NKOJ
     C                     KFLD           K@NUKE
     C                     KFLD           K@NOHZ
     C                     KFLD           K@NBIN
     C                     KFLD           K@MLBL  8
      *
     C           K#66      KLIST
     C                     KFLD           K@CUST
     C                     KFLD           K@NONY
     C                     KFLD           K@NKOJ
     C                     KFLD           K@NUKE
     C                     KFLD           K@NOHZ
     C                     KFLD           K@NBIN
      *
     C           K#1A      KLIST
     C                     KFLD           K@NOHZ
     C                     KFLD           K@NBIN
     C                     KFLD           K@NONY
     C                     KFLD           K@NKOJ
     C                     KFLD           K@NUKE
     C                     KFLD           K@ODRN
      *
     C           KEY1      KLIST
     C                     KFLD           K@NONY
     C                     KFLD           PNOYY
     C                     KFLD           PNOMM
     C                     KFLD           PNODD
     C                     KFLD           K@NUKE
      *
     C           K#44      KLIST
     C                     KFLD           K@NONY
     C                     KFLD           K@NOHZ
     C                     KFLD           K@NUKE
     C                     KFLD           BAMHN1
     C                     KFLD           BAMHN2
     C                     KFLD           BAMHN3
     C                     KFLD           BAMHN4
     C                     KFLD           BANOBN
     C                     KFLD           ORD#15 15
      *
     C                     MOVE '01'      @@DSP   2
     C                     MOVE *ALL'0'   WKBLAK 10
     C                     Z-ADD1         BIN
      *
     C                     MOVE *BLANK    PNONY
     C                     MOVE *BLANK    PNKOJ
     C                     MOVE *BLANK    PNUKE
     C                     Z-ADD*ZERO     PNOHZ
     C                     MOVEL*BLANK    PODRN
JW4  C                     TIME           SDATE
      *
     C                     ENDSR
     C***********************************************************
     C* BARCODE ENTRY
     C***********************************************************
     C           #SCRN1    BEGSR
      *
     C                     EXFMTDSP01
      *
     C                     SELEC
     C           *INKI     WHEQ *ON
     C                     MOVE '02'      @@DSP
     C           *INKC     WHEQ *ON
     C                     MOVE '99'      @@DSP
     C                     OTHER
     C                     EXSR @CHK1
      * CHECK OK?
     C           *IN99     IFEQ '0'
     C           *INKE     ANDEQ*ON
      *
      ** get all home positions...
     C                     EXSR @HOME
     C                     Z-ADDI         ##LBLS  20
      ** write output for all home positions...
     C                     DO   ##LBLS    I
     C                     MOVELHOME,I    ##HOME  1
     C                     EXSR @WRT1
     C                     ENDDO
      *
     C                     MOVE *ON       *IN87
     C                     MOVE *BLANK    D@BARC
     C                     Z-ADD*ZERO     D@NBR
     C                     ENDIF
     C                     ENDSL
      *
     C                     ENDSR
      ***********************************************************
      * BARCODE ENTRY
      ***********************************************************
     C           @CHK1     BEGSR
      *
     C                     MOVEAWKBLAK    *IN,30
     C                     MOVE *BLANK    MSG
     C                     SETOF                     8799
     C           D@BARC    CHAINAB#PL76              90
     C           *IN90     IFEQ *ON
     C                     SETON                     9931
     C                     MOVE ER,13     MSG
     C                     ELSE
     C                     MOVELPUNONY    K@NONY  40
     C                     MOVELPUNONY    PNONY
     C                     MOVELPUNKOJ    K@NKOJ  1
     C                     MOVELPUNUKE    K@NUKE  4
     C                     Z-ADDPUBINN    K@NBIN  20
     C                     Z-ADDPUDAT     K@NOHZ  80
     C                     Z-ADDPUCUST    K@CUST  40
     C                     MOVELPUODRN    K@ODRN 10
     C                     ENDIF
      *
     C           D@NBR     IFEQ *ZERO
     C                     SETON                     3299
     C                     MOVE ER,14     MSG
     C                     ENDIF
      *
     C                     ENDSR
      ***********************************************************
      * @MANUALLY
      ***********************************************************
     C           #SCRN2    BEGSR
      *
     C                     EXFMTDSP02
      * CLEAR MSG
     C                     MOVEAWKBLAK    *IN,30
     C                     SETOF                     8799
      *
     C                     SELEC
     C           *INKC     WHEQ '1'
     C                     MOVE '99'      @@DSP
      *
     C           *INKL     WHEQ *ON
     C                     MOVE '01'      @@DSP
     C                     OTHER
     C                     EXSR @CHK2
      *
     C           *INKE     IFEQ '1'
      * CHECK OK?
     C           *IN99     ANDEQ'0'
      *
      ** get all home positions...
     C                     EXSR @HOME
     C                     Z-ADDI         ##LBLS  20
      ** write output for all home positions...
     C                     DO   ##LBLS    I
     C                     MOVELHOME,I    ##HOME
     C                     EXSR @WRT1
     C                     ENDDO
      *
     C                     MOVE *ON       *IN87
     C                     MOVE *BLANK    PNONY
     C                     MOVE *BLANK    PNKOJ
     C                     MOVE *BLANK    PNUKE
     C                     MOVE *BLANK    PODRN
     C                     Z-ADD*ZERO     PNOHZ
     C                     Z-ADD*ZERO     BIN
     C                     Z-ADD*ZERO     D@NBR
     C                     END
      *
     C                     ENDSL
      *
     C                     ENDSR
      ***********************************************************
      * @CHK1:CHECK ITEMS ON 1ST. SCREEN
      ***********************************************************
     C           @CHK2     BEGSR
      *
     C                     MOVEAWKBLAK    *IN,30
     C                     MOVE *BLANK    MSG
     C                     SETOF                     8799
      * DELIVERY CODE BLANK ?
     C           PNONY     IFEQ *BLANK
     C                     SETON                     9931
     C                     MOVELER,1      MSG
     C                     GOTO #CHK2
     C                     END
      *
      * FACTORY CODE BLANK ?
     C           PNKOJ     IFEQ *BLANK
     C                     SETON                     9932
     C                     MOVELER,2      MSG
     C                     GOTO #CHK2
     C                     END
      *
      * DOCK CODE BLANK ?
     C           PNUKE     IFEQ *BLANK
     C                     SETON                     9933
     C                     MOVELER,3      MSG
     C                     GOTO #CHK2
     C                     END
      *
      * SHIPPING DATE
     C           PNOHZ     IFEQ 0
     C                     SETON                     9934
     C                     MOVELER,4      MSG
     C                     GOTO #CHK2
     C                     END
      *
     C           PNOMM     IFLT 1
     C           PNOMM     ORGT 12
     C                     SETON                     9934
     C                     MOVELER,5      MSG
     C                     GOTO #CHK2
     C                     END
      *
     C           PNODD     IFLT 1
     C           PNODD     ORGT 31
     C                     SETON                     9934
     C                     MOVELER,5      MSG
     C                     GOTO #CHK2
     C                     END
      * BIN       *
     C           BIN       IFEQ 0
     C                     SETON                     9935
     C                     MOVELER,6      MSG
     C                     GOTO #CHK2
     C                     END
      * ORDER#    *
     C           PODRN     IFEQ *BLANK
     C                     SETON                     9937
     C                     MOVELER,15     MSG
     C                     GOTO #CHK2
     C                     END
      *
     C           D@NBR     IFEQ *ZERO
     C                     SETON                     3699
     C                     MOVE ER,14     MSG
     C                     GOTO #CHK2
     C                     ENDIF
      *
     C                     Z-ADDPNOHZ     K@NOHZ  80
     C                     Z-ADDBIN       K@NBIN  20
     C                     MOVELPNONY     K@NONY
     C                     MOVELPNKOJ     K@NKOJ  1
     C                     MOVELPNUKE     K@NUKE  4
     C                     MOVELPODRN     K@ODRN 10
      *
     C           K#1A      SETLLAB#PL1A
     C           *IN90     DOUEQ*ON
     C           K#1A      READEAB#PL1A                  90
     C           *IN90     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
      *
     C                     Z-ADDBATOKU    K@CUST
      *                    MOVELBANUKE    K@NUKE
     C                     LEAVE
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN90     IFEQ *ON
     C                     MOVEA'11111'   *IN,31
     C                     MOVEL*ON       *IN37
     C                     SETON                     99
     C                     MOVELER,12     MSG
     C                     ENDIF
      *
     C           #CHK2     ENDSR
      ***********************************************************
     C           @NMBR     BEGSR
      ***********************************************************
      *
     C                     Z-ADD99999999  @@14   140
     C           K@NONY    CHAINAB#NP31              97
     C                     Z-ADD*DATE     N3UDAT
     C                     TIME           N3UTIM
     C                     MOVEL#PGM      N3UPGM
     C                     MOVEL#USER     N3UUSR
     C                     MOVEL#WSID     N3UWIS
     C                     Z-ADDK@NONY    N3NONY
     C           *IN97     IFEQ *ON
     C                     Z-ADD1         N3NMBR
     C                     WRITEAB#NP311
     C                     ELSE
     C                     ADD  1         N3NMBR
     C           N3NMBR    IFGE @@14
     C                     Z-ADD1         N3NMBR
     C                     ENDIF
     C                     UPDATAB#NP311
     C                     ENDIF
      *
     C                     ENDSR
      ***********************************************************
      * @HOME: GET ALL HOME POSITIONS FOR SELECTED ORDERS
      ***********************************************************
     C           @HOME     BEGSR
      *
     C                     Z-ADD*ZERO     I
     C                     MOVEA*BLANKS   HOME
      *
     C           KEY1      SETLLAB#PL13
     C           *IN93     DOUEQ*ON
     C           KEY1      READEAB#PL131                 93
     C           *IN93     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
      *
     C           BANOBN    IFNE K@NBIN
     C                     ITER
     C                     ENDIF
     C           K@ODRN    IFNE *BLANKS
     C           BAODRN    ANDNEK@ODRN
     C                     ITER
     C                     ENDIF
     C           BANKOJ    IFNE K@NKOJ
     C                     ITER
     C                     ENDIF
      *
      * keep a list of Home Positions...
     C           BAHPOS    LOKUPHOME                     44
     C           *IN44     IFEQ *OFF
     C                     ADD  1         I       20
     C                     MOVELBAHPOS    HOME,I
     C                     ENDIF
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     ENDSR
      ***********************************************************
      * @WRT1:WRITE LABEL DATA
      ***********************************************************
     C           @WRT1     BEGSR
      *
     C                     Z-ADD*ZERO     @ITM    30
     C                     Z-ADD*ZERO     @SRYO  110
      *
     C           KEY1      SETLLAB#PL13
     C           *IN93     DOUEQ*ON
     C           KEY1      READEAB#PL131                 93
     C           *IN93     IFEQ *OFF
     C           BASKJY    ANDEQ*BLANK
      *
     C           BANOBN    IFNE K@NBIN
     C                     ITER
     C                     ENDIF
     C           K@ODRN    IFNE *BLANKS
     C           BAODRN    ANDNEK@ODRN
     C                     ITER
     C                     ENDIF
     C           BANKOJ    IFNE K@NKOJ
     C                     ITER
     C                     ENDIF
      *
     C                     ADD  1         @ITM
     C                     ADD  BASRYO    @SRYO
     C                     MOVELBAMHIN    @MHIN  20
     C                     MOVELBAHPOS    @HPOS   1
      *
     C                     ENDIF
     C                     ENDDO
      *
     C           *IN22     IFEQ *OFF
     C                     MOVELCMD,1     P@CMD
     C                     Z-ADD30        P@LEN
     C                     CALL 'QCMDEXC' P#CMD          99
     C                     MOVE *ON       *IN22
     C                     ENDIF
     C                     OPEN AB#WP2Q
      *
     C                     Z-ADD*ZERO     X       20
     C                     MOVE *BLANK    MNO
     C           K#66      SETLLAB#PL66
     C           *IN90     DOUEQ*ON
     C           K#66      READEAB#PL66                  90
     C           *IN90     IFEQ *OFF
     C                     ADD  1         X
     C           X         IFGT 10
     C                     LEAVE
     C                     ENDIF
     C                     MOVELA6MLBL    MNO,X
     C                     MOVE A6MLBL    K@MLBL
     C           K#66X     SETGTAB#PL66
     C                     ENDIF
     C                     ENDDO
      *
     C                     MOVEL##HOME    I2LVL
     C                     MOVEL'0242C'   I2SIRE
      *
     C                     MOVELK@NKOJ    I2FACT
     C           @ITM      IFEQ 1
     C                     MOVEL@MHIN     I2PART
     C                     Z-ADD@SRYO     PIQTY
     C                     MOVE *BLANK    POQTY
     C                     CALL 'AB#R2K'  P2
     C                     MOVELPOQTY     I2CQTY
     C                     ELSE
     C                     MOVEL'0'       I2PART    P
     C                     MOVEL*BLANK    I2CQTY
     C                     ENDIF
      *
     C           1         DO   D@NBR     Y       60
     C                     EXSR @NMBR
     C                     MOVE N3NMBR    I2SERL
     C                     MOVELPNONY     I2SERL
      * write to ekanban file for shipping scans...
     C                     EXSR #PP70
      *
     C                     MOVE N3NMBR    I2SERL
     C                     MOVELPNONY     I2SERL
     C                     MOVE I2SERL    I2CASE
     C                     MOVEL'242'     I2CASE
      *
      * write to napck parts case file...
     C                     EXSR #P66
      *
     C                     MOVELBAODRN    I2ODRN
     C                     MOVELSHIN      I2IPAR
     C                     MOVEL#PGM      I2PGM
      *
     C                     MOVELPNONY     I2DELY
      *
      * write to napck parts case label file...
     C                     WRITEAB#WP2Q1
      *
JW4  C                     MOVEL'AB#WP2Q 'IXWRKF    P
 "   C                     EXSR #XP01
      *
     C                     ENDDO
      *
     C                     CLOSEAB#WP2Q
      *
     C                     ENDSR
      ***********************************************************
      * WRITE CASE DATA FOR 0323
      ***********************************************************
     C           #P66      BEGSR
      *
     C                     CLEARAB#PP661
     C                     Z-ADD*DATE     A6KYMD
     C                     TIME           A6KTIM
     C                     MOVE K@CUST    A6TOKU
     C                     MOVE K@NONY    A6NONY
     C                     MOVE K@NKOJ    A6NKOJ
     C                     MOVEL##HOME    A6NUKE
     C                     MOVELI2CASE    A6MLBL
     C                     Z-ADDK@NOHZ    A6NYMD
     C                     Z-ADDK@NBIN    A6NBIN
     C                     MOVELK@ODRN    A6ORDN
     C                     MOVEL##HOME    A6HPOS
      *
     C                     WRITEAB#PP661
      *
     C                     ENDSR
     C***********************************************************
      *  SET FIELDS FOR AB#PP70
     C***********************************************************
     C           #PP70     BEGSR
      *
     C                     CLEARAB#PP701
     C                     Z-ADD*YEAR     EKKOYY
     C                     Z-ADD*MONTH    EKKOMM
     C                     Z-ADD*DAY      EKKODD
     C                     TIME           @@TIM
     C                     MOVE @@HH      EKKOHH
     C                     MOVE @@MM      EKKOMN
     C                     MOVEL#USER     EKKOME
     C                     MOVE K@NONY    EKNONY
     C                     MOVE K@NKOJ    EKNKOJ
     C                     MOVEL##HOME    EKNUKE
      *
     C                     MOVE PNOYY     EKNOYY
     C                     MOVE PNOMM     EKNOMM
     C                     MOVE PNODD     EKNODD
     C                     Z-ADDK@CUST    EKTOKU
     C                     MOVE K@NBIN    EKNOBN
     C                     MOVE N3NMBR    EKSERL
     C                     MOVELPNONY     EKSERL
     C                     WRITEAB#PP701
      *
     C                     ENDSR
      *================================================================
JW4   *  ..LABEL DATA ISSUE LOG                            *
      *================================================================
     C           #XP01     BEGSR
     C                     Z-ADDTODAY     IXKOHZ           TODAY
     C                     TIME           IXKOTM           NOW
     C                     MOVELEKTOKU    IXTOKU           CUSTOMER
     C                     MOVELI2DELY    IXNONY           DELIVERY
     C                     MOVELI2FACT    IXNKOJ           FACTORY
     C                     MOVELEKNUKE    IXNUKE           DOCK
     C                     MOVELI2ODRN    IXODRN           ORDER #
     C                     MOVELI2SERL    IXSERL           SERIAL NUMBER
     C                     MOVELI2SHDT    IXDEDT           INVOICE DATE
     C                     MOVELEKNOBN    IXNOBN           INVOICE BIN
      *
     C                     MOVEL*BLANK    IXPL#
     C                     MOVEL#USER     IXKOUS
     C                     MOVEL#WSID     IXKOWS
     C                     MOVEL#PGM      IXKOPG
      *
     C                     MOVELI2PART    IXMHIN
 .   C                     MOVELI2IPAR    IXSHIN
 .   C                     MOVE *BLANK    IXINVN
 .   C                     MOVELEKNUKE    IXHPOS
 .   C                     MOVE *BLANK    IXROUT
     C                     MOVELI2CASE    IXFIL1
     C                     MOVELI2CQTY    IXFIL2
 .   C                     Z-ADD0         IXSRYO
 .   C                     Z-ADD0         IXSYOS
 .   C                     Z-ADD0         IXUSYS
      *
JW4  C                     WRITEAB#XP1A1
     C                     ENDSR
     C***********************************************************
** ER
E-01 ENTER DELIVERY CODE.
E-02 ENTER FACTORY CODE.
E-03 ENTER DOCK CODE.
E-04 ENTER SHIPPING DATE.
E-05 DATE IS WRONG.
E-06 ENTER BIN.
E-07 ENTER BOTH SERIAL NUMBER FROM AND SERIAL NUMBER TO
E-08 PLEASE MARK AT LEAST 1 OPTION
E-09 THIS FROM,TO IS ONLY FOR ARVIN SANGO
E-10 THIS FROM,TO IS ONLY FOR TRW-KOYO
E-11 THIS FROM,TO IS ONLY FOR OTHERS
E-12 NO DATA IN ORDER FILE(AB#PP10)
E-13 BARCODE ERROR
E-14 ENTER # OF LABELS.
E-15 ENTER ORDER#.
** CMD
CLRPFM AB#WP2Q
