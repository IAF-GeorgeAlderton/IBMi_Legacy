     C                     XFOOTGOMI      WGMI
      *
     C                     XFOOTBGOK      BWGKN
     C                     XFOOTBGOM      BWGMI
     C                     XFOOTCGOK      CWGKN
     C                     XFOOTCGOM      CWGMI
     C                     XFOOTDGOK      DWGKN
     C                     XFOOTDGOM      DWGMI
TCHK1C                     XFOOTIGOK      IWGKN
TCHK1C                     XFOOTIGOM      IWGMI
TCHK1C                     XFOOTJGOK      JWGKN
TCHK1C                     XFOOTJGOM      JWGMI
