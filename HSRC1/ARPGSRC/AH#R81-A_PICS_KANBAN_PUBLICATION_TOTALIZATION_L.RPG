      ******************************************************
      *              便単位のカウント
      ******************************************************
     C           SUB1      BEGSR
      *
     C                     Z-ADD1         C       20
     C                     DO   10        C
     C                     ADD  HKEN,C    GOKN,C
     C                     ADD  HMAI,C    GOMI,C
      *
     C                     ADD  BKEN,C    BGOK,C
     C                     ADD  BMAI,C    BGOM,C
     C                     ADD  CKEN,C    CGOK,C
     C                     ADD  CMAI,C    CGOM,C
     C                     ADD  DKEN,C    DGOK,C
     C                     ADD  DMAI,C    DGOM,C
TCHK1C                     ADD  IKEN,C    IGOK,C
TCHK1C                     ADD  IMAI,C    IGOM,C
TCHK1C                     ADD  JKEN,C    JGOK,C
TCHK1C                     ADD  JMAI,C    JGOM,C
     C                     ADD  EKEN,C    EGOK,C
     C                     ADD  EMAI,C    EGOM,C
     C                     ADD  FKEN,C    FGOK,C
     C                     ADD  FMAI,C    FGOM,C
     C                     ADD  GKEN,C    GGOK,C
     C                     ADD  GMAI,C    GGOM,C
     C                     ADD  SKEN,C    SGOK,C
     C                     ADD  SMAI,C    SGOM,C
     C                     ADD  TKEN,C    TGOK,C
     C                     ADD  TMAI,C    TGOM,C
     C                     END
      *
     C                     ENDSR
      ******************************************************
      *                便単位の平均
      ******************************************************
     C           SUB2      BEGSR
      *
     C                     Z-ADD1         E       20
     C                     DO   10        E
     C           GOKN,E    DIV  KHIZ      HEKN,E    H
     C           GOMI,E    DIV  KHIZ      HEMI,E    H
     C                     END
      *
     C                     XFOOTHEKN      WHKN
     C                     XFOOTHEMI      WHMI
      *
     C                     ENDSR
      *
     C******************************************************
     C*                 稼働日計算
     C******************************************************
     C           SUB3      BEGSR
      *
     C                     Z-ADD0         KHIZ
     C                     Z-ADD1         B       20
     C                     SETOF                     55
     C           WYM       KLIST
     C                     KFLD           WYY
     C                     KFLD           WMM
      *
     C           WYM       SETLLAGDPL111
     C                     SETOF                         55
     C                     DO   *HIVAL
     C           WYM       READEAGDPL111                 55
     C           *IN55     IFEQ '0'
     C                     ADD  1         KHIZ
     C                     END
     C  N55                ENDDO
      *
     C                     ENDSR
      *
     C******************************************************
     C*                 ＢＺ・ＤＣ・ＳＥＣに分類
     C******************************************************
     C           #BUN      BEGSR
      *
     C           CFKDAI    IFEQ 'C'
     C                     SELEC
     C           CFMLIN    WHEQ 'A'
     C                     ADD  1         BKEN,A
     C                     ADD  CFMAIS    BMAI,A
     C           CFMLIN    WHEQ 'B'
     C                     ADD  1         CKEN,A
     C                     ADD  CFMAIS    CMAI,A
TCHK1C           CFMLIN    WHEQ 'C'
TCHK1C                     ADD  1         IKEN,A
TCHK1C                     ADD  CFMAIS    IMAI,A
     C           CFMLIN    WHEQ 'D'
     C                     ADD  1         DKEN,A
     C                     ADD  CFMAIS    DMAI,A
     C           CFMLIN    WHEQ 'E'
     C                     ADD  1         EKEN,A
     C                     ADD  CFMAIS    EMAI,A
TCHK1C           CFMLIN    WHEQ 'F'
TCHK1C                     ADD  1         JKEN,A
TCHK1C                     ADD  CFMAIS    JMAI,A
     C                     OTHER
     C                     ADD  1         FKEN,A
     C                     ADD  CFMAIS    FMAI,A
     C                     ENDSL
     C                     END
      *
     C           CFKDAI    IFEQ 'E'
     C*****                ADD  1         SKEN,A
     C******               ADD  CFMAIS    SMAI,A
     C           KEY1      KLIST
     C                     KFLD           WSHN1
     C                     KFLD           WSHN2
     C                     KFLD           WSHN3
     C                     MOVE *BLANK    WSHN1   5
     C                     MOVE *BLANK    WSHN2   5
     C                     MOVE *BLANK    WSHN3   2
      *
     C                     MOVE CFSHN1    WSHN1
     C                     MOVE CFSHN2    WSHN2
     C                     MOVE CFSHN3    WSHN3
      *
     C           KEY1      SETLLAAHTL011
     C                     DO   *HIVAL
     C                     SETOF                     50
     C           KEY1      READEAAHTL011                 50
     C           *IN50     IFEQ '1'
     C                     GOTO EXIT1
     C                     END
     C           *IN50     IFEQ '0'
     C           CFHTHZ    IFLT L6UKHZ
     C           CFHTHZ    ORGT L6STHZ
     C                     GOTO EXIT1
     C                     END
      *   xｮgかんばんマスター  **************************
     C                     MOVE L6SHN1    WSHN1
     C                     MOVE L6SHN2    WSHN2
     C                     MOVE L6SHN3    WSHN3
      *
     C                     SELEC
     C           L6ATOK    WHEQ 'KRO'
     C                     ADD  1         GKEN,A
     C                     ADD  CFMAIS    GMAI,A
     C           L6ATOK    WHEQ 'JC '
     C                     ADD  1         SKEN,A
     C                     ADD  CFMAIS    SMAI,A
     C                     OTHER
     C                     ADD  1         TKEN,A
     C                     ADD  CFMAIS    TMAI,A
     C                     ENDSL
      *
     C*          KEY1      SETLLAAFTL011
     C*                    DO   *HIVAL
     C*                    SETOF                     60
     C*          KEY1      READEAAFTL011                 60
     C*          *IN60     IFEQ '1'
     C*                    GOTO EXIT2
     C*                    END
      *
     C*          *IN60     IFEQ '0'
     C*          CFHTHZ    IFLT A3UKHZ
     C*          CFHTHZ    ORGT A3STHZ
     C*                    GOTO EXIT2
     C*                    END
      *
     C*          A3RAIN    IFEQ 'A'
     C*                    ADD  1         BKEN,A
     C*                    ADD  CFMAIS    BMAI,A
     C*                    SETON                     50
     C*                    GOTO EXIT1
     C*                    END
      *
     C*          A3RAIN    IFEQ 'D'
     C*                    ADD  1         DKEN,A
     C*                    ADD  CFMAIS    DMAI,A
     C*                    SETON                     50
     C*                    GOTO EXIT1
     C*                    END
      *
     C*                    END
     C*          EXIT2     TAG
     C* N60                ENDDO
      *****************************************************
     C                     END
     C           EXIT1     TAG
     C  N50                ENDDO
     C                     END
      *
     C                     ENDSR
