      *
     C                     SETOF                     02
     C                     MOVEL'XXXXXXXX'WNAM   16
     C           WBMON     CHAINFGBPL011             02
     C           *IN02     IFEQ '0'
     C           B2SKJY    ANDEQ'D'
     C           B2SKHZ    ANDLE*DATE
     C                     SETON                     02
     C                     END
     C           *IN02     IFEQ '0'
     C                     MOVELB2SMEI    WNAM
     C                     END
      *
     C                     WRITEAH#PR801
     C                     Z-ADD0         HKEN
     C                     Z-ADD0         HMAI
      *
     C                     Z-ADD0         BKEN
     C                     Z-ADD0         BMAI
     C                     Z-ADD0         CKEN
     C                     Z-ADD0         CMAI
     C                     Z-ADD0         DKEN
     C                     Z-ADD0         DMAI
TCHK1C                     Z-ADD0         IKEN
TCHK1C                     Z-ADD0         IMAI
TCHK1C                     Z-ADD0         JKEN
TCHK1C                     Z-ADD0         JMAI
     C                     Z-ADD0         EKEN
     C                     Z-ADD0         EMAI
     C                     Z-ADD0         FKEN
     C                     Z-ADD0         FMAI
     C                     Z-ADD0         GKEN
     C                     Z-ADD0         GMAI
     C                     Z-ADD0         SKEN
     C                     Z-ADD0         SMAI
     C                     Z-ADD0         TKEN
     C                     Z-ADD0         TMAI
      *
     C                     EXSR SUB3
      *
     C                     SETOF                     0304
     C                     Z-ADD0         B       20
      *
     C                     DO   *HIVAL
     C                     SETOF                     02
     C                     READ AH#WP81                  02
     C           *IN02     IFEQ '0'
      *
     C                     SETON                     03
     C           *IN04     IFEQ '0'
     C                     SETON                     04
     C                     Z-ADDCFHTDD    WHTDD
     C                     END
      *
     C           CFHTDD    IFNE WHTDD
     C                     XFOOTHKEN      WKEN
     C                     XFOOTHMAI      WMAI
      *
     C                     XFOOTBKEN      BWKN
     C                     XFOOTBMAI      BWMI
     C                     XFOOTCKEN      CWKN
     C                     XFOOTCMAI      CWMI
     C                     XFOOTDKEN      DWKN
     C                     XFOOTDMAI      DWMI
TCHK1C                     XFOOTIKEN      IWKN
TCHK1C                     XFOOTIMAI      IWMI
TCHK1C                     XFOOTJKEN      JWKN
TCHK1C                     XFOOTJMAI      JWMI
     C                     XFOOTEKEN      EWKN
     C                     XFOOTEMAI      EWMI
     C                     XFOOTFKEN      FWKN
     C                     XFOOTFMAI      FWMI
     C                     XFOOTGKEN      GWKN
     C                     XFOOTGMAI      GWMI
     C                     XFOOTSKEN      SWKN
     C                     XFOOTSMAI      SWMI
     C                     XFOOTTKEN      TWKN
     C                     XFOOTTMAI      TWMI
      *
     C                     ADD  1         B
     C           B         IFGT 5
     C                     Z-ADD1         B
     C                     WRITEAH#PR801
     C                     END
     C                     WRITEAH#PR802
      *
     C                     EXSR SUB1
     C                     Z-ADDCFHTDD    WHTDD
     C                     Z-ADD0         HKEN
     C                     Z-ADD0         HMAI
      *
     C                     Z-ADD0         BKEN
     C                     Z-ADD0         BMAI
     C                     Z-ADD0         CKEN
     C                     Z-ADD0         CMAI
     C                     Z-ADD0         DKEN
     C                     Z-ADD0         DMAI
TCHK1C                     Z-ADD0         IKEN
TCHK1C                     Z-ADD0         IMAI
TCHK1C                     Z-ADD0         JKEN
TCHK1C                     Z-ADD0         JMAI
     C                     Z-ADD0         EKEN
     C                     Z-ADD0         EMAI
     C                     Z-ADD0         FKEN
     C                     Z-ADD0         FMAI
     C                     Z-ADD0         GKEN
     C                     Z-ADD0         GMAI
     C                     Z-ADD0         SKEN
     C                     Z-ADD0         SMAI
     C                     Z-ADD0         TKEN
     C                     Z-ADD0         TMAI
      *
     C                     END
      *
     C                     Z-ADDCFHTBB    A       20
     C                     ADD  1         HKEN,A
     C                     ADD  CFMAIS    HMAI,A
      ************************************************************
     C                     EXSR #BUN
      ************************************************************
     C                     END
     C  N02                END
      *
     C           *IN03     IFEQ '1'
     C                     XFOOTHKEN      WKEN
     C                     XFOOTHMAI      WMAI
      *
     C                     XFOOTBKEN      BWKN
     C                     XFOOTBMAI      BWMI
     C                     XFOOTCKEN      CWKN
     C                     XFOOTCMAI      CWMI
     C                     XFOOTDKEN      DWKN
     C                     XFOOTDMAI      DWMI
TCHK1C                     XFOOTIKEN      IWKN
TCHK1C                     XFOOTIMAI      IWMI
TCHK1C                     XFOOTJKEN      JWKN
TCHK1C                     XFOOTJMAI      JWMI
