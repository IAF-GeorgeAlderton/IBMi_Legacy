     H            Y.
     F* AFDR14 **********************************************************
     F* PRINT NOT RETURNED BOX REPORT                                   *
     F* JW    2018.09.18                                                *
     F*******************************************************************
     FAFDPL23 IF  E           K        DISK
     FAFDWP14 UF  E           K        DISK                      A
      *------------------------------------------------------------------
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   80#FROM
     I                                        1   40#FRYY
     I                                        5   60#FRMM
     I                                        7   80#FRDD
     I            DS
     I                                        1   80AFODHZ
     I                                        1   40AFODYY
     I                                        5   60AFODMM
     I                                        7   80AFODDD
     I            DS
     I                                        1  12 AFSHIN
     I                                        1   5 AFPAR1
     I                                        6  10 AFPAR2
     I                                       11  12 AFPAR3
      *
     I           SDS
     I                                        1   8 #PGM
     I                                      244 253 #WSID
     I                                      254 263 #USER
      *************************************************
      * MAIN ROUTINE
      *************************************************
     C                     EXSR #INIT
      *
     C           KEY1      SETLLAFDPL23
      *
     C                     DO   *HIVAL
     C                     READ AFDPL23                  98
     C   98                LEAVE
      * END?
     C           AFODHZ    IFGT #TO
     C                     LEAVE
     C                     ENDIF
      * DELETED?
     C           AFSKJY    IFEQ 'D'
     C                     ITER
     C                     ENDIF
      * RECEIVED?
     C           AFNOYY    IFNE 0
     C                     ITER
     C                     ENDIF
      *
     C           KEY2      CHAINAFDWP14              97
     C           *IN97     IFEQ *OFF
     C                     ADD  AFHAKO    A4BOX
     C                     UPDATAFDWP141
     C                     ELSE
     C                     MOVELAFSUPP    A4SUPP
     C                     MOVELAFSHIN    A4SHIN
     C                     Z-ADDAFHAKO    A4BOX
     C                     WRITEAFDWP141
     C                     ENDIF
      *
     C                     ENDDO
      *
     C                     MOVE *ON       *INLR
     C                     RETRN
      *************************************************
      * INITIAL SET
      *************************************************
     C           #INIT     BEGSR
     C*  PARAMETER
     C           *ENTRY    PLIST
     C                     PARM           $FROM  10
     C                     PARM           $TO    10
     C*  KEY
     C           KEY1      KLIST
     C                     KFLD           #YY     40
     C                     KFLD           #MM     20
     C                     KFLD           #DD     20
      *
     C           KEY2      KLIST
     C                     KFLD           AFSUPP
     C                     KFLD           AFSHIN
     C*
     C                     MOVEL$FROM     LTR8    8
     C                     MOVELLTR8      #FROM
     C                     Z-ADD#FRYY     #YY
     C                     Z-ADD#FRMM     #MM
     C                     Z-ADD#FRDD     #DD
     C                     MOVEL$TO       LTR8
     C                     MOVELLTR8      #TO     80
     C                     MOVE 'Y'       FIRST   1
     C                     TIME           SDATE
      *
     C                     ENDSR
      *************************************************
