     H            Y.
     F** UTLR26 ********************************************
     F*  PROGRAM: GET SERVICE PART LOCATION FROM IAF PART  *
     F*  WRITTEN: JW (SRA)                                 *
     F*           08/14/2019                               *
     F*----------------------------------------------------*
     F*  CALLING SEQ.
     F*                    CALL 'UTLR26'
     F*                    PARM           $SHN1   5
     F*                    PARM           $SHN2   5
     F*                    PARM           $SHN3   2
     F*                    PARM           $LOC1   1
     F*                    PARM           $LOC2   2
     F*                    PARM           $LOC3   2
     F*                    PARM           $LOC4   1
     F*                    PARM           $RTN    1
     F*  IN  $SHN1 :  5A IAF PART1
     F*      $SHN2 :  5A IAF PART2
     F*      $SHN3 :  2A IAF PART3
     F*  OUT $LOC1 :  1A LOCATION1
     F*      $LOC2 :  2A LOCATION2
     F*      $LOC3 :  2A LOCATION3
     F*      $LOC4 :  1A LOCATION4
     F*      $RTN  :  1A RETURN CODE (BLANK/*)
     F******************************************************
     FFCEPL30 IF  E           K        DISK
     F******************************************************
     I            DS
     I                                        1  140SDATE
     I                                        1   60NOW
     I                                        7  140TODAY
     I            DS
     I                                        1   80A2DATE
     I                                        1   40A2TRYY
     I                                        5   60A2TRMM
     I                                        7   80A2TRDD
     I            DS
     I                                        1   80A2SYHZ
     I                                        1   40A2SYYY
     I                                        5   60A2SYMM
     I                                        7   80A2SYDD
      *
      *--------------------------------------------------------
      *                    MAIN PROCESS
      *--------------------------------------------------------
      *
     C                     EXSR #INIT
      *
     C           KEY1      CHAINFCEPL30              98
     C           *IN98     IFEQ *OFF
      * LOCATION
     C           F3SYMD    IFGT TODAY
     C                     MOVELF3KTRK    $LOC1
     C                     MOVELF3KTRT    $LOC2
     C                     MOVELF3STRR    $LOC3
     C                     MOVELF3KTRD    $LOC4
     C                     ELSE
     C                     MOVELF3STRK    $LOC1
     C                     MOVELF3STRT    $LOC2
     C                     MOVELF3STRR    $LOC3
     C                     MOVELF3STRD    $LOC4
     C                     ENDIF
     C                     ENDIF
      *
     C           $LOC1     IFEQ *BLANK
     C           *IN98     OREQ *ON
     C                     MOVE '*'       $RTN
     C                     ENDIF
      *
     C                     SETON                     LR
     C                     RETRN
      *=============================================================
      *                    INITIAL PROCESS
      *=============================================================
     C           #INIT     BEGSR
      *
     C           *ENTRY    PLIST
     C                     PARM           $SHN1   5
     C                     PARM           $SHN2   5
     C                     PARM           $SHN3   2
     C                     PARM           $LOC1   1
     C                     PARM           $LOC2   2
     C                     PARM           $LOC3   2
     C                     PARM           $LOC4   1
     C                     PARM           $RTN    1
      *
     C           KEY1      KLIST
     C                     KFLD           $SHN1
     C                     KFLD           $SHN2
     C                     KFLD           $SHN3
      *
     C                     CLEAR$LOC1
     C                     CLEAR$LOC2
     C                     CLEAR$LOC3
     C                     CLEAR$LOC4
     C                     CLEAR$RTN
     C                     TIME           SDATE
      *
     C                     ENDSR
