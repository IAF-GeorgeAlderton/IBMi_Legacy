     FAJBPW70 CF  E                    WORKSTN
     E                    HMB        12 10
     E                    HSR        12 10
     E                    HLB        12 10
     E                    ER      1   3 60
     I            DS
     I                                        1 120 HMB
     I                                        1  10 IMB01
     I                                       11  20 IMB02
     I                                       21  30 IMB03
     I                                       31  40 IMB04
     I                                       41  50 IMB05
     I                                       51  60 IMB06
     I                                       61  70 IMB07
     I                                       71  80 IMB08
     I                                       81  90 IMB09
     I                                       91 100 IMB10
     I                                      101 110 IMB11
     I                                      111 120 IMB12
     I            DS
     I                                        1 120 HSR
     I                                        1  10 ISR01
     I                                       11  20 ISR02
     I                                       21  30 ISR03
     I                                       31  40 ISR04
     I                                       41  50 ISR05
     I                                       51  60 ISR06
     I                                       61  70 ISR07
     I                                       71  80 ISR08
     I                                       81  90 ISR09
     I                                       91 100 ISR10
     I                                      101 110 ISR11
     I                                      111 120 ISR12
     I            DS
     I                                        1 120 HLB
     I                                        1  10 ILB01
     I                                       11  20 ILB02
     I                                       21  30 ILB03
     I                                       31  40 ILB04
     I                                       41  50 ILB05
     I                                       51  60 ILB06
     I                                       61  70 ILB07
     I                                       71  80 ILB08
