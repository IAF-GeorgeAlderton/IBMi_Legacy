     I                                      111 120 ILB12
      *
     C           *ENTRY    PLIST
     C                     PARM           PCMD    1
     C                     PARM           PIN98   1
      *
     C                     MOVE PIN98     *IN98
      *
     C           STP1      TAG
     C                     EXFMTAJBPW703
     C                     SETOF                     010203
     C                     SETOF                     040506
     C                     SETOF                     070809
     C                     SETOF                     101112
     C                     SETOF                     131415
     C                     SETOF                     161718
     C                     SETOF                     192021
     C                     SETOF                     222324
     C                     SETOF                     252627
     C                     SETOF                     282930
     C                     SETOF                     313233
     C                     SETOF                     343536
     C                     SETOF                     99
      *
     C           *INKA     IFEQ '1'
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C           *INKB     IFEQ '1'
     C                     MOVE '2'       PCMD
     C                     SETON                     LR
     C                     RETRN
     C                     END
      *
     C                     Z-ADD1         A       20
     C                     Z-ADD0         B       20
     C                     Z-ADD12        C       20
     C                     Z-ADD24        D       20
     C           1         DO   12        A
     C                     ADD  1         B
     C                     ADD  1         C
     C                     ADD  1         D
      *
     C           HMB,A     IFNE *BLANK
      *
     C           HSR,A     IFEQ *BLANK
     C                     MOVE '1'       *IN,C
     C                     SETON                     99
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
     C           HLB,A     IFEQ *BLANK
     C                     MOVE '1'       *IN,D
     C                     SETON                     99
     C                     MOVE ER,1      MSG
     C                     GOTO STP1
     C                     END
      *
     C                     MOVE *BLANK    WER     1
     C                     MOVE HMB,A     WMB    10
     C                     MOVE HSR,A     WSR    10
     C                     MOVE HLB,A     WLB    10
      * ALCOBJ
     C                     MOVEL'A'       WTYPE   1
     C                     CALL 'AJBC71'
     C                     PARM           WER
     C                     PARM           WMB
     C                     PARM           WSR
     C                     PARM           WLB
     C                     PARM           WTYPE
      *
     C           WER       IFEQ '*'
     C                     MOVE '1'       *IN,B
     C                     MOVE '1'       *IN,C
     C                     MOVE '1'       *IN,D
     C                     SETON                     99
     C                     MOVE ER,3      MSG
     C                     GOTO STP1
     C                     END
      *
     C                     ELSE
      *
     C           HSR,A     IFNE *BLANK
     C                     MOVE '1'       *IN,C
     C                     SETON                     99
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
     C           HLB,A     IFNE *BLANK
     C                     MOVE '1'       *IN,D
     C                     SETON                     99
     C                     MOVE ER,2      MSG
     C                     GOTO STP1
     C                     END
      *
     C                     ENDIF
     C                     END
      *
     C           *INKE     IFEQ *OFF
     C           *INKI     ANDEQ*OFF
     C                     GOTO STP1
     C                     ENDIF
      *
     C                     MOVE '5'       PCMD
      *
     C                     Z-ADD1         A
     C           1         DO   12        A
     C           HMB,A     IFNE *BLANK
     C                     MOVE HMB,A     WMB
     C                     MOVE HSR,A     WSR
     C                     MOVE HLB,A     WLB
      * F5
     C           *INKE     IFEQ *ON
     C                     CALL 'AJFC14'
     C                     PARM           WMB
     C                     PARM           WSR
     C                     PARM           WLB
     C                     ENDIF
      * F9  HULFT
     C           *INKI     IFEQ *ON
     C                     CALL 'AJFCH1'
     C                     PARM           WMB
     C                     PARM           WSR
     C                     PARM           WLB
     C                     ENDIF
      * DLCOBJ
     C                     MOVEL'D'       WTYPE   1
     C                     CALL 'AJBC71'
     C                     PARM           WER
     C                     PARM           WMB
     C                     PARM           WSR
     C                     PARM           WLB
     C                     PARM           WTYPE
      *
     C                     ENDIF
     C                     ENDDO
      *
     C                     SETON                     LR
     C                     RETRN
      *
** ER
E-01反転している項目が入力されていない。
E-02反転している項目は入力できない。
E-03反転している項目はソースファイルがない。
