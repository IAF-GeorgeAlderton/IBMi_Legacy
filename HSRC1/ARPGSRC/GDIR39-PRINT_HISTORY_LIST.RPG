      * INZ *
      *-----*
     C           *IN05     IFEQ '0'
     C                     SETON                     05
     C                     Z-ADD0         GSKSU   70
     C                     Z-ADD0         GSKHK   30
     C                     Z-ADD0         GRESU   70
     C                     Z-ADD0         GREHK   30
     C                     Z-ADD0         GMISU   70
     C                     Z-ADD0         GMIHK   30
     C                     TIME           WTIME   60
     C                     MOVE *BLANK    MINO    1
     C                     MOVE *BLANK    $HANY   1
     C                     EXCPTHD
     C                     END
      *
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     END
      *
     C           *INL1     IFEQ '1'
     C                     EXCPTDT1
     C                     END
      *----------------------*
      * SHIPPING INFORMATION *
      *----------------------*
     C                     SETOF                     20
     C           KEY       SETLLGDIPL25
     C                     DO   *HIVAL
     C                     SETOF                     10
     C           KEY       READEGDIPL251                 10
     C           *IN10     IFEQ '0'
     C           IKSKJY    IFEQ 'D'
     C           IKSKHZ    ANDLE*DATE
     C                     ELSE
      *
     C                     MOVE IKHANY    $HANY
     C           IKNYUK    IFEQ *BLANK
     C                     ADD  IKSURY    GSKSU
     C                     ELSE
     C                     ADD  IKSURY    GSKSU
     C                     ADD  IKSURY    GRESU
     C                     END
     C           *INOF     IFEQ '1'
     C                     EXCPTHD
     C                     SETOF                     OF
     C                     END
     C                     END
     C                     END
     C  N10                ENDDO
      *
     C           ISURY     SUB  GSKSU     GMISU
     C           GMISU     IFGT 0
     C                     MOVEL'*'       MINO
     C                     END
     C           IKSYOS    IFNE 0
     C           GSKSU     DIV  IKSYOS    GSKHK
     C           GRESU     DIV  IKSYOS    GREHK
     C           GMISU     DIV  IKSYOS    GMIHK
     C                     END
     C                     EXCPTDT2
     C                     MOVE *BLANK    MINO
     C                     MOVE *BLANK    $HANY
